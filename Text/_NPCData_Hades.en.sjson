      InheritFrom = "BaseSubtitle"
      DisplayName = "Hello, Daughter!"
      Speaker = "Persephone"
      Event = "GlobalVoiceLines.PersephoneGreetingVoiceLines"
    }
    {
      Id = "Zagreus_0431"
      InheritFrom = "BaseNarrative"
      DisplayName = "You said yourself Mother could use some rest. Why don't you join her? I can keep an eye on things."
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.HadesZagreusChattingLines"
    }
    {
      Id = "Hades_0390"
      InheritFrom = "BaseNarrative"
      DisplayName = "No. Nyx is with the Queen. Nor shall I leave my daughter unattended."
      Speaker = "Hades"
      Event = "GlobalVoiceLines.HadesZagreusChattingLines"
    }
    {
      Id = "Zagreus_0432"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Scoff> Unattended? {#Prev}You act like I may not be the best influence on her!"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.HadesZagreusChattingLines"
    }
    {
      Id = "Hades_0391"
      InheritFrom = "BaseNarrative"
      DisplayName = "I do not act."
      Speaker = "Hades"
      Event = "GlobalVoiceLines.HadesZagreusChattingLines"
    }
    {
