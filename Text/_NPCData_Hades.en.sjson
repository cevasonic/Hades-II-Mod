      Event = "GlobalVoiceLines.PersephoneGreetingVoiceLines"
    }
    {
      Id = "Persephone_0036"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're here!"
      Speaker = "Persephone"
      Event = "GlobalVoiceLines.PersephoneGreetingVoiceLines"
    }
    {
      Id = "Persephone_0037"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It's you!"
      Speaker = "Persephone"
      Event = "GlobalVoiceLines.PersephoneGreetingVoiceLines"
    }
    {
      Id = "Persephone_0038"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hades, {#Emph}look!"
