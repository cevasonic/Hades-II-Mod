      Event = "GlobalVoiceLines.HadesCurseVoiceLines"
    }
    {
      Id = "Hades_0379"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}You are nothing, Typhon."
      Speaker = "Hades"
      Event = "GlobalVoiceLines.HadesCurseVoiceLines"
    }
    {
      Id = "Hades_0376"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Curse you, monster...!"
      Speaker = "Hades"
      Event = "GlobalVoiceLines.HadesCurseVoiceLines"
    }
    {
      Id = "Hades_0377"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Blast you, monster!"
      Speaker = "Hades"
      Event = "GlobalVoiceLines.HadesCurseVoiceLines"
    }
    {
      Id = "Hades_0378"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Wretched monster."
      Speaker = "Hades"
      Event = "GlobalVoiceLines.HadesCurseVoiceLines"
    }
    {
      Id = "Hades_0086"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Curse you, Father..."
      Speaker = "Hades"
      Event = "GlobalVoiceLines.HadesCurseVoiceLines"
    }
    {
