  lang = "en"
  Texts = [
    {
      Id = "MelinoeField_5082"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I don't plan to..."
      Speaker = "Melinoe"
      Event = "NPC_Hades_Field_01.UpgradeMenuOpenVoiceLines"
    }
    {
      Id = "MelinoeField_1570"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We've every chance in the world..."
      Speaker = "Melinoe"
      Event = "NPC_Hades_Field_01.UpgradeMenuOpenVoiceLines"
    }
    {
      Id = "MelinoeField_2834"
      InheritFrom = "BaseSubtitle"
      DisplayName = "They... fight pretty well."
      Speaker = "Melinoe"
      Event = "NPC_Hades_Field_01.UpgradeMenuOpenVoiceLines"
    }
    {
      Id = "MelinoeField_5180"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not always, no..."
      Speaker = "Melinoe"
      Event = "NPC_Hades_Field_01.UpgradeMenuOpenVoiceLines"
    }
    {
      Id = "MelinoeField_5221"
      InheritFrom = "BaseSubtitle"
      DisplayName = "For fashion's sake? {#Emph}Hah{#Prev}, no..."
      Speaker = "Melinoe"
      Event = "NPC_Hades_Field_01.UpgradeMenuOpenVoiceLines"
    }
    {
      Id = "MelinoeField_1566"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Be well, Lord Father."
      Speaker = "Melinoe"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "MelinoeField_1567"
      InheritFrom = "BaseSubtitle"
      DisplayName = "In shadow, I serve!"
      Speaker = "Melinoe"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Melinoe_5165"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hail, Lord Father!"
      Speaker = "Melinoe"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Melinoe_5064"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Be well, Mother!"
      Speaker = "Melinoe"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Melinoe_5065"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thank you for being here."
      Speaker = "Melinoe"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Melinoe_5066"
      InheritFrom = "BaseSubtitle"
      DisplayName = "So glad to see you."
      Speaker = "Melinoe"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Melinoe_5067"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Take care, Mother."
      Speaker = "Melinoe"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Persephone_0050"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You too, my baby girl."
      Speaker = "Persephone"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Persephone_0051"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Only because of you."
      Speaker = "Persephone"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Persephone_0052"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, Daughter..."
      Speaker = "Persephone"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Persephone_0053"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You take care too."
      Speaker = "Persephone"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Persephone_0054"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}<Sigh>"
      Speaker = "Persephone"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Persephone_0055"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hello!"
      Speaker = "Persephone"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Persephone_0056"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The old one at least."
      Speaker = "Persephone"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Persephone_0057"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, thank you."
      Speaker = "Persephone"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Persephone_0058"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We could use it."
      Speaker = "Persephone"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Persephone_0059"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We'll need it."
      Speaker = "Persephone"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Hades_0253"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Greetings."
      Speaker = "Hades"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Hades_0254"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hail, Daughter."
      Speaker = "Hades"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Hades_0255"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Darkness suits me best."
      Speaker = "Hades"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Hades_0256"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Go unseen."
      Speaker = "Hades"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Hades_0127"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hrm."
      Speaker = "Hades"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Hades_0136"
      InheritFrom = "BaseSubtitle"
      DisplayName = "To shadow, you'll return."
      Speaker = "Hades"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Hades_0131"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, Daughter..."
      Speaker = "Hades"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Hades_0128"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Greetings..."
      Speaker = "Hades"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Hades_0129"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We tried that once."
      Speaker = "Hades"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Hades_0130"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Death..."
      Speaker = "Hades"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Hades_0132"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not here it won't."
      Speaker = "Hades"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Hades_0133"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Here?"
      Speaker = "Hades"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Hades_0134"
      InheritFrom = "BaseSubtitle"
      DisplayName = "As you say."
      Speaker = "Hades"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Hades_0135"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hail..."
      Speaker = "Hades"
      Event = "NPC_Hades_Field_01.InteractVoiceLines"
    }
    {
      Id = "Hades_0049"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Pah! {#Prev}Another tormentor come to break me, or to try. And such a frail one, at that. Has the Titan Lord a lack for decent help?"
      Speaker = "Hades"
      Event = "HadesFirstMeeting"
    }
    {
      Id = "Melinoe_1056"
      InheritFrom = "BaseNarrative"
      DisplayName = "You... are you... the master of this beast?"
      Speaker = "Melinoe"
      Event = "HadesFirstMeeting"
    }
    {
      Id = "Hades_0026"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The master of this beast? Ha, haha! {#Prev}Well, if I'm to be remembered, I could think of far worse ways than that. Though, this {#Emph}beast {#Prev}has yet to so much as snarl at you..."
      Speaker = "Hades"
      Event = "HadesFirstMeeting"
    }
    {
      Id = "Melinoe_1057_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Gasp> {#Prev}Lord Hades, you're my.... Father, I'm... Melinoë. I'm your daughter."
      Speaker = "Melinoe"
      Event = "HadesFirstMeeting"
    }
    {
      Id = "Hades_0027"
      InheritFrom = "BaseNarrative"
      DisplayName = "...My daughter. Melinoë? Merciful Fates...! You cannot be here. He shall find you. He'll find you, and..."
      Speaker = "Hades"
      Event = "HadesFirstMeeting"
    }
    {
      Id = "Melinoe_1058"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I'll slay him where he stands. Where is he?"
      Speaker = "Melinoe"
      Event = "HadesFirstMeeting"
    }
    {
      Id = "Hades_0028"
      InheritFrom = "BaseNarrative"
      DisplayName = "He's in my blasted House! Where you were meant to be, and I. Look at me, Daughter. I could not confront him on my own. What do you expect shall happen?"
      Speaker = "Hades"
      Event = "HadesFirstMeeting"
    }
    {
      Id = "Melinoe_1059"
      InheritFrom = "BaseNarrative"
      DisplayName = "I expect he'll underestimate me. Father, let me free you from these bonds!"
      Speaker = "Melinoe"
      Event = "HadesFirstMeeting"
    }
    {
      Id = "Hades_0029"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}No! {#Prev}No, that would bring greater ruin, nothing more. Now, get out of this place. Though let me lend to you what strength I still possess."
      Speaker = "Hades"
      Event = "HadesFirstMeeting"
    }
    {
      Id = "MelinoeField_1689"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I'll slay him where he stands. He's in the area, is he not?"
      Speaker = "Melinoe"
      Event = "HadesFirstMeeting_B"
    }
    {
      Id = "MelinoeField_1688"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I'll slay him where he stands. And not for the first."
      Speaker = "Melinoe"
      Event = "HadesFirstMeeting_C"
    }
    {
      Id = "Hades_0145"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Not for the first{#Prev}, truly? Then you must know the meaninglessness of the act! Look at me, Daughter. I could do nothing against him on my own. Even though I, too, have fought him before. {#Emph}Slain {#Prev}him before!"
      Speaker = "Hades"
      Event = "HadesFirstMeeting_C"
    }
    {
      Id = "MelinoeField_1690"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm sorry, Father. But I shall not be deterred, even by you. Now let me free you from these bonds!"
      Speaker = "Melinoe"
      Event = "HadesFirstMeeting_C"
    }
    {
      Id = "Hades_0031"
      InheritFrom = "BaseNarrative"
      DisplayName = "What are you doing here again? I told you, you {#Emph}cannot {#Prev}be here!"
      Speaker = "Hades"
      Event = "HadesMeeting02"
    }
    {
      Id = "Melinoe_1061"
      InheritFrom = "BaseNarrative"
      DisplayName = "And I told {#Emph}you {#Prev}I'd be back for you. Though my priority is Chronos. You vanquished him before. Can you reveal to me any weaknesses? Anything at all?"
      Speaker = "Melinoe"
      Event = "HadesMeeting02"
    }
    {
      Id = "Hades_0032"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}I {#Prev}vanquished him with the aid of {#Emph}five other gods! {#Prev}What hope have you, alone? He has no weakness, save his arrogance. And it appears you have that weakness, too."
      Speaker = "Hades"
      Event = "HadesMeeting02"
    }
    {
      Id = "Melinoe_1062"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then it seems we are equally matched. Father, how long have you been this way? Is there aught I can do?"
      Speaker = "Melinoe"
      Event = "HadesMeeting02"
    }
    {
      Id = "Hades_0033"
      InheritFrom = "BaseNarrative"
      DisplayName = "You think I've any sense of time in such a place? And I've said already what you can do: {#Emph}Risk not your everything. {#Prev}Go now, and be unseen."
      Speaker = "Hades"
      Event = "HadesMeeting02"
    }
    {
      Id = "Hades_0034"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know not how you withstood the Titan, if truly you confronted him. Quickly now, tell me but this: Have you been... are you well?"
      Speaker = "Hades"
      Event = "HadesMeeting03"
    }
    {
      Id = "Melinoe_1063"
      InheritFrom = "BaseNarrative"
      DisplayName = "Am I... well? All my life I've been preparing for this moment, to bring the usurper of the House of Hades to justice. So, I'll have to get back to you, depending on how it goes."
      Speaker = "Melinoe"
      Event = "HadesMeeting03"
    }
    {
      Id = "Hades_0035"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I'm sorry... I'm sorry. Get back to me if you must. I'd grant your vengeance if I could. But this is all that I can do for now."
      Speaker = "Hades"
      Event = "HadesMeeting03"
    }
    {
      Id = "MelinoeField_1495"
      InheritFrom = "BaseNarrative"
      DisplayName = "It hurts my heart to see you like this, Father. But, it brings me peace. And strength. Helps that this chamber isn't crawling with Satyrs..."
      Speaker = "Melinoe"
      Event = "HadesAboutPain01"
    }
    {
      Id = "Hades_0053"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh they have sense enough to keep their distance from me... or perhaps Cerberus. Well if seeing me in this pitiable state should spur you to your fullest wrath, then so be it."
      Speaker = "Hades"
      Event = "HadesAboutPain01"
    }
    {
      Id = "MelinoeField_1496"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's not quite it; I don't feel loathing or hatred. Elsewhere in Tartarus, perhaps, but not here. Not anymore. I just hope my presence doesn't cause you further pain."
      Speaker = "Melinoe"
      Event = "HadesAboutPain01"
    }
    {
      Id = "Hades_0054"
      InheritFrom = "BaseNarrative"
      DisplayName = "No. The only pain... is that your mother and I, your brother, this dog, that we were not... we could not be there to see you grow. Each time I see you now... it fills an absence that was there."
      Speaker = "Hades"
      Event = "HadesAboutPain01"
    }
    {
      Id = "Hades_0117"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you'd indulge a senseless curiosity... how fares my House? Your brother, he was more or less in charge of the decor. I highly doubt the Titan shares his taste."
      Speaker = "Hades"
      Event = "HadesAboutHouse01"
    }
    {
      Id = "MelinoeField_1573"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, unless Zagreus was enamored of gold trim and the Titan's sneering likeness everywhere, then it's probably quite different from what you recall..."
      Speaker = "Melinoe"
      Event = "HadesAboutHouse01"
    }
    {
      Id = "Hades_0118"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Urgh... {#Prev}you have your mother's candor to a fault. You ought have told me everything was {#Emph}fine! {#Prev}The comfort of lies at times is all we have."
      Speaker = "Hades"
      Event = "HadesAboutHouse01"
    }
    {
      Id = "Hades_0147"
      InheritFrom = "BaseNarrative"
      DisplayName = "I cannot believe that I am asking but, how fares Olympus in all this? Even trapped within this chamber, it is evident to me that the Titan's legions are at war."
      Speaker = "Hades"
      Event = "HadesAboutSurface01"
    }
    {
      Id = "MelinoeField_1692"
      InheritFrom = "BaseNarrative"
      DisplayName = "The surface swarms with the dead, and the armies of Chronos are besieging the mountain. Our family is holding them back. I've been trying to break the stalemate in their favor, but all in all, it's not a pretty sight up there right now."
      Speaker = "Melinoe"
      Event = "HadesAboutSurface01"
    }
    {
      Id = "Hades_0148"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Not a pretty sight up there... {#Prev}you mean to say you've seen all this firsthand? {#Emph}How?"
      Speaker = "Hades"
      Event = "HadesAboutSurface01"
    }
    {
      Id = "MelinoeField_1693"
      InheritFrom = "BaseNarrative"
      DisplayName = "You mean our birthright. Would you believe I learned a means by which I could withstand the surface climate for a while? Long enough to make a difference up there... or to try."
      Speaker = "Melinoe"
      Event = "HadesAboutSurface01"
    }
    {
      Id = "Hades_0149"
      InheritFrom = "BaseNarrative"
      DisplayName = "Impossible... yet seemingly, all these impossibilities continue to occur. So you must vanquish the Titan, as well as come to the rescue of Olympus. How utterly absurd that you are burdened with all that...."
      Speaker = "Hades"
      Event = "HadesAboutSurface01"
    }
    {
      Id = "Hades_0173"
      InheritFrom = "BaseNarrative"
      DisplayName = "To think that you have seen Olympus with your own eyes... your brother never had that opportunity. And I myself... my life is here, and I've no memories of mountaintops."
      Speaker = "Hades"
      Event = "HadesAboutAutomatons01"
    }
    {
      Id = "MelinoeField_2833"
      InheritFrom = "BaseNarrative"
      DisplayName = "It must have been a sight to behold, once. Now it's beset with the Titan's legions, and mindless Automaton defenders that want {#Emph}me {#Prev}destroyed just as much as our foes."
      Speaker = "Melinoe"
      Event = "HadesAboutAutomatons01"
    }
    {
      Id = "Hades_0174"
      InheritFrom = "BaseNarrative"
      DisplayName = "I told them never to depend on such contraptions! A proper army needs to be driven by glory, if not fear. Their Automatons feel {#Emph}nothing! {#Prev}How well can they possibly fight?"
      Speaker = "Hades"
      Event = "HadesAboutAutomatons01"
    }
    {
      Id = "Hades_0168"
      InheritFrom = "BaseNarrative"
      DisplayName = "The darkness stirs in such a way as I've not felt since very long ago. This cannot be the Titan's work. It must be that of the Witch of the Crossroads, if not you."
      Speaker = "Hades"
      Event = "HadesAboutShrine01"
    }
    {
      Id = "MelinoeField_2009"
      InheritFrom = "BaseNarrative"
      DisplayName = "Father: {#Emph}In shadow, I serve; to shadow, I return. {#Prev}Thus have I sworn the Oath of the Unseen, who serve this realm, and execute the will of Night."
      Speaker = "Melinoe"
      Event = "HadesAboutShrine01"
    }
    {
      Id = "Hades_0169"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know less of the Unseen than you suppose. As it should be, lest the Titan could have learned much more. Then, may you serve the will of Night judiciously..."
      Speaker = "Hades"
      Event = "HadesAboutShrine01"
    }
    {
      Id = "Hades_0177"
      InheritFrom = "BaseNarrative"
      DisplayName = "That skull you have in hand, is that... how did you come to possess it? It once had been entrusted to your mother's care... for her protection, and in a way, yours."
      Speaker = "Hades"
      Event = "HadesAboutPersephoneAspect01"
    }
    {
      Id = "MelinoeField_2836"
      InheritFrom = "BaseNarrative"
      DisplayName = "Mother's Aspect of the Argent Skull Revaal deemed me a worthy-enough bearer... but it was Headmistress Hecate who first gathered the Nocturnal Arms for my task."
      Speaker = "Melinoe"
      Event = "HadesAboutPersephoneAspect01"
    }
    {
      Id = "Hades_0178"
      InheritFrom = "BaseNarrative"
      DisplayName = "Forged by the Fates! Who so like playing us for fools. That skull did not protect the Queen as much as I would have preferred; but perhaps its work merely is not yet complete."
      Speaker = "Hades"
      Event = "HadesAboutPersephoneAspect01"
    }
    {
      Id = "Hades_0050"
      InheritFrom = "BaseNarrative"
      DisplayName = "Such a cacophony occurred, after you last visited. Exactly when I cannot say. All of the Titan's wretched servants flew into a panic. Their cries would not cease. What transpired?"
      Speaker = "Hades"
      Event = "HadesAboutChronosBossW01"
    }
    {
      Id = "MelinoeField_1493"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps they were concerned for their master. Or busy trying to bring him back to life. Because I slew him, finally. And it won't be the last time."
      Speaker = "Melinoe"
      Event = "HadesAboutChronosBossW01"
    }
    {
      Id = "Hades_0051"
      InheritFrom = "BaseNarrative"
      DisplayName = "Blood and darkness, {#Emph}hah... urgh! {#Prev}Then you accomplished... that which once took half the blasted strength of Olympus... all on your own."
      Speaker = "Hades"
      Event = "HadesAboutChronosBossW01"
    }
    {
      Id = "MelinoeField_1494"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not on my own at all. I had their strength, if not their support; as you've given me yours. Father, we can stop him. And for now... we can kill him."
      Speaker = "Melinoe"
      Event = "HadesAboutChronosBossW01"
    }
    {
      Id = "Hades_0052"
      InheritFrom = "BaseNarrative"
      DisplayName = "He shall seek vengeance with a renewed zeal. This entire plot of his is driven by the same impulse. Then, kill him if you must. At least... his many deaths ought keep him occupied."
      Speaker = "Hades"
      Event = "HadesAboutChronosBossW01"
    }
    {
      Id = "MelinoeField_1691"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps they were concerned for their master. Or busy trying to bring him back to life. Because I slew him once again. And it won't be the last time."
      Speaker = "Melinoe"
      Event = "HadesAboutChronosBossW01_B"
    }
    {
      Id = "Hades_0146"
      InheritFrom = "BaseNarrative"
      DisplayName = "Blood and darkness, {#Emph}hah! Urgh... {#Prev}To have achieved such an outcome... which once required half the blasted strength of all Olympus, on your own..."
      Speaker = "Hades"
      Event = "HadesAboutChronosBossW01_B"
    }
    {
      Id = "MelinoeField_1568"
      InheritFrom = "BaseNarrative"
      DisplayName = "When Chronos took our family and the House, and you bade the Witch of the Crossroads take me... I remember it somehow, or dreamt of it. Did he... demand you tell him of the Fates?"
      Speaker = "Melinoe"
      Event = "HadesAboutChronosNightmare01"
    }
    {
      Id = "Hades_0273"
      InheritFrom = "BaseNarrative"
      DisplayName = "How could you possibly...? Perhaps the Fates themselves permitted you that bit of insight. My father sought them, but I revealed nothing. Couldn't have even if I so desired, for no one knows where those three are, save {#Emph}them."
      Speaker = "Hades"
      Event = "HadesAboutChronosNightmare01"
    }
    {
      Id = "MelinoeField_1569"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wait, you never told Chronos how to find the Fates? Then how {#Emph}did {#Prev}he? Because he's captured them. Not long ago, perhaps, but nonetheless. I'm certain of it."
      Speaker = "Melinoe"
      Event = "HadesAboutChronosNightmare01"
    }
    {
      Id = "Hades_0274"
      InheritFrom = "BaseNarrative"
      DisplayName = "What?! No... but if this is true, well then my father's plan for conquest is much closer to fruition than I thought. If not even they could stop him... Daughter, what chance do {#Emph}you {#Prev}have...?"
      Speaker = "Hades"
      Event = "HadesAboutChronosNightmare01"
    }
    {
      Id = "MelinoeField_4150"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wait, you never told Chronos how to find the Fates? Then how {#Emph}did {#Prev}he? Because he captured them... before all this I mean. I'm certain of it."
      Speaker = "Melinoe"
      Event = "HadesAboutChronosNightmare01_B"
    }
    {
      Id = "Hades_0276"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}What? {#Prev}Why am I only learning of this {#Emph}now? {#Prev}We'll shake the information out of him, then, and locate them immediately!"
      Speaker = "Hades"
      Event = "HadesAboutChronosNightmare01_B"
    }
    {
      Id = "Hades_0397"
      InheritFrom = "BaseNarrative"
      DisplayName = "...My father... he visited me recently. Demanding that I tell him where to find you. I made clear I did not know. But you are drawing more of his attention."
      Speaker = "Hades"
      Event = "HadesAboutUltimateProgress01"
    }
    {
      Id = "MelinoeField_5078"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're saying he tortured you, that blasted wretch. He won't need to find me; I'm about to find him."
      Speaker = "Melinoe"
      Event = "HadesAboutUltimateProgress01"
    }
    {
      Id = "Hades_0398"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do not misunderstand... we merely spoke. Granted, that is a rarity in itself. He never knew what to do with my brothers or me... never should have had us at all."
      Speaker = "Hades"
      Event = "HadesAboutUltimateProgress01"
    }
    {
      Id = "MelinoeField_5079"
      InheritFrom = "BaseNarrative"
      DisplayName = "Father, please don't speak that way. What even happened with you all...? I know the tales of how you vanquished him, but... know so little of how it was for you growing up."
      Speaker = "Melinoe"
      Event = "HadesAboutUltimateProgress01"
    }
    {
      Id = "Hades_0399"
      InheritFrom = "BaseNarrative"
      DisplayName = "...We often fought. He believed we would take after him. None of us did. And when the Fates decided that the time had come for us to rule in his stead... he resisted. Bitterly. But these old memories... I would leave them buried."
      Speaker = "Hades"
      Event = "HadesAboutUltimateProgress01"
    }
    {
      Id = "MelinoeField_5080"
      InheritFrom = "BaseNarrative"
      DisplayName = "Please hang on, Father. I have to safeguard the details, but... I'm getting closer to something... a way to stop Chronos. Forever."
      Speaker = "Melinoe"
      Event = "HadesAboutUltimateProgress02"
    }
    {
      Id = "Hades_0400"
      InheritFrom = "BaseNarrative"
      DisplayName = "Forever... even when my brothers, foster-sisters, and I vanquished him... we knew he would eventually be back... a deathless Titan. But we thought... it would be on our terms. We were such fools."
      Speaker = "Hades"
      Event = "HadesAboutUltimateProgress02"
    }
    {
      Id = "MelinoeField_5081"
      InheritFrom = "BaseNarrative"
      DisplayName = "What else could you have done? He left you with no choice. And you lacked the means to destroy him utterly."
      Speaker = "Melinoe"
      Event = "HadesAboutUltimateProgress02"
    }
    {
      Id = "Hades_0401"
      InheritFrom = "BaseNarrative"
      DisplayName = "It was for the best that we lacked such means... we would have used them and continued using them. I merely judge the dead, or used to... I was never fit to judge the living."
      Speaker = "Hades"
      Event = "HadesAboutUltimateProgress02"
    }
    {
      Id = "Hades_0402"
      InheritFrom = "BaseNarrative"
      DisplayName = "To think that you might stop the Titan forever. In my youth I could not even believe we were related. Yet now I realize... I have grown old, and wretched, and wrathful... like him."
      Speaker = "Hades"
      Event = "HadesAboutUltimateProgress03"
    }
    {
      Id = "MelinoeField_5063"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lord Father, it was my wrath that brought me to this point! And how can you possibly compare yourself? Look what the Titan did to you..."
      Speaker = "Melinoe"
      Event = "HadesAboutUltimateProgress03"
    }
    {
      Id = "Hades_0394"
      InheritFrom = "BaseNarrative"
      DisplayName = "We did this to {#Emph}each other! {#Prev}Gods and Titans... doomed to live forever, yet learn nothing all the while. Do as you must... but take no vengeance in my name."
      Speaker = "Hades"
      Event = "HadesAboutUltimateProgress03"
    }
    {
      Id = "Hades_0171"
      InheritFrom = "BaseNarrative"
      DisplayName = "Daughter, answer me something. How is it that the Titan's armies are well-organized enough to siege Olympus, when the Titan himself cowers here in Tartarus?"
      Speaker = "Hades"
      Event = "HadesAboutPrometheus01"
    }
    {
      Id = "MelinoeField_2832"
      InheritFrom = "BaseNarrative"
      DisplayName = "We have another Titan to contend with there: Prometheus is leading the attack. I don't know how exactly he got free, or what he truly wants... other than vengeance on the gods."
      Speaker = "Melinoe"
      Event = "HadesAboutPrometheus01"
    }
    {
      Id = "Hades_0172"
      InheritFrom = "BaseNarrative"
      DisplayName = "Is vengeance on the gods an insufficient desire in itself? I wanted nothing to do with his sentencing... but your Lord Uncle Zeus, he... well, he would always claim that he could fashion more-creative punishments than I..."
      Speaker = "Hades"
      Event = "HadesAboutPrometheus01"
    }
    {
      Id = "MelinoeField_3101"
      InheritFrom = "BaseNarrative"
      DisplayName = "Father, I'm afraid the matter on Olympus is more dire than we thought... for Chronos reawakened Typhon, who is very, {#Emph}very {#Prev}large... and dead-set on destroying the Palace of Zeus."
      Speaker = "Melinoe"
      Event = "HadesAboutTyphon01"
    }
    {
      Id = "Hades_0191"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Pah! {#Prev}Such a predictable and reckless action on the Titan's part. Although your uncle Zeus may not be quite as spry as when he and that monster previously clashed."
      Speaker = "Hades"
      Event = "HadesAboutTyphon01"
    }
    {
      Id = "MelinoeField_3102"
      InheritFrom = "BaseNarrative"
      DisplayName = "You don't seem so surprised. How did you all defeat Typhon before? I've never fought something like him."
      Speaker = "Melinoe"
      Event = "HadesAboutTyphon01"
    }
    {
      Id = "Hades_0192"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nor should you fight something like him, Daughter! Let Zeus clean up his mess. His thunderbolt proved quite effective in the past... although you'd think that an embodiment of storms and rage would be immune."
      Speaker = "Hades"
      Event = "HadesAboutTyphon01"
    }
    {
      Id = "MelinoeField_3103"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm not about to abandon our family to face this threat on their own."
      Speaker = "Melinoe"
      Event = "HadesAboutTyphon01"
    }
    {
      Id = "Hades_0193"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then you're in the wrong place. For if you think thwarting the Titan shall stop Typhon in turn, you're wrong. A monster such as that cannot be controlled. Go, see for yourself."
      Speaker = "Hades"
      Event = "HadesAboutTyphon01"
    }
    {
      Id = "MelinoeField_3930"
      InheritFrom = "BaseNarrative"
      DisplayName = "You don't seem so surprised. How did you all defeat Typhon before? My methods thus far have not produced long-lasting results."
      Speaker = "Melinoe"
      Event = "HadesAboutTyphon01_B"
    }
    {
      Id = "Hades_0275"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your {#Emph}methods? {#Prev}Let Zeus clean up his mess. His thunderbolt proved quite effective in the past... although you'd think that an embodiment of storms and rage would be immune."
      Speaker = "Hades"
      Event = "HadesAboutTyphon01_B"
    }
    {
      Id = "Hades_0194"
      InheritFrom = "BaseNarrative"
      DisplayName = "What news of Typhon recently, Daughter? Zeus used to boast of how he vanquished that monstrosity alone. Now I imagine more of a concerted effort is required."
      Speaker = "Hades"
      Event = "HadesAboutTyphon02"
    }
    {
      Id = "MelinoeField_3104"
      InheritFrom = "BaseNarrative"
      DisplayName = "Father, if you bear some grudge with Uncle Zeus, that's only to the benefit of all our enemies. Typhon yet threatens the mountaintop... he can be driven back, but never for long."
      Speaker = "Melinoe"
      Event = "HadesAboutTyphon02"
    }
    {
      Id = "Hades_0195"
      InheritFrom = "BaseNarrative"
      DisplayName = "We buried him under a mountain once; no ordinary show of strength, for other methods failed. Well, I trust my brother has some sort of {#Emph}plan. {#Prev}He never lacked for those."
      Speaker = "Hades"
      Event = "HadesAboutTyphon02"
    }
    {
      Id = "Hades_0196"
      InheritFrom = "BaseNarrative"
      DisplayName = "...When first we had to fend off Typhon long ago, we dared not think the Titan Lord whom we had already disposed of was responsible. Surely not even {#Emph}he {#Prev}in all his arrogance believed that such a monster would bend to his will!"
      Speaker = "Hades"
      Event = "HadesAboutTyphon03"
    }
    {
      Id = "MelinoeField_3105"
      InheritFrom = "BaseNarrative"
      DisplayName = "All Chronos probably expected was that the monster would immediately attack Olympus. How could he have awakened such a thing without our family even noticing?"
      Speaker = "Melinoe"
      Event = "HadesAboutTyphon03"
    }
    {
      Id = "Hades_0197"
      InheritFrom = "BaseNarrative"
      DisplayName = "With Nyx herself amongst the Titan Lord's captives, all that transpires deep within the Earth cannot be known by anyone. And now... even though both Typhon and the Titan fell to us before... we have never had to face them both at once."
      Speaker = "Hades"
      Event = "HadesAboutTyphon03"
    }
    {
      Id = "Hades_0198"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have not seen you in some time... perhaps you've been preoccupied with thwarting Typhon as he makes attempts to break into my brother's nigh-impenetrable mountain palace."
      Speaker = "Hades"
      Event = "HadesAboutTyphon04"
    }
    {
      Id = "MelinoeField_3106"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's a rather accurate assessment of my recent outings, yes. Typhon may appear to be invincible, but there's not a creature alive that likes repeatedly being struck in the face."
      Speaker = "Melinoe"
      Event = "HadesAboutTyphon04"
    }
    {
      Id = "Hades_0199"
      InheritFrom = "BaseNarrative"
      DisplayName = "An age-old tactic that served well your predecessors in the greatest battles of their youth. I had a feeling that would be the case; in the end, little changes with time."
      Speaker = "Hades"
      Event = "HadesAboutTyphon04"
    }
    {
      Id = "Hades_0175"
      InheritFrom = "BaseNarrative"
      DisplayName = "Who else besides Prometheus does Chronos have under his thumb? I would know every last Titan or such ilk who deigned to turn on us."
      Speaker = "Hades"
      Event = "HadesAboutChronosAllies01"
    }
    {
      Id = "MelinoeField_2835"
      InheritFrom = "BaseNarrative"
      DisplayName = "Besides marauding hordes of Satyrs and such, the ones that come to mind include the Cyclops Polyphemus... and Nyx's daughter Eris... though she may be acting on her own."
      Speaker = "Melinoe"
      Event = "HadesAboutChronosAllies01"
    }
    {
      Id = "Hades_0176"
      InheritFrom = "BaseNarrative"
      DisplayName = "Strife could never be controlled, Nyx knew only too well. As for that Cyclops... he and your Uncle Poseidon have some history that may have spurred his impulses. Well... it is not yet the longest list of enemies, at least."
      Speaker = "Hades"
      Event = "HadesAboutChronosAllies01"
    }
    {
      Id = "Hades_0106"
      InheritFrom = "BaseNarrative"
      DisplayName = "Daughter, tell me what... became of the Witch of the Crossroads, should you know. When all seemed lost... your mother and I, we left you in her care."
      Speaker = "Hades"
      Event = "HadesAboutHecate01"
    }
    {
      Id = "MelinoeField_1497"
      InheritFrom = "BaseNarrative"
      DisplayName = "And she has cared for me ever since. Prepared me. Though, we had best not speak of her in these chambers. Suffice it to say, the Unseen remain in shadow."
      Speaker = "Melinoe"
      Event = "HadesAboutHecate01"
    }
    {
      Id = "Hades_0107"
      InheritFrom = "BaseNarrative"
      DisplayName = "Good. She was... well as you say, we'd best say nothing more. Though if you have the opportunity, extend to her my deepest gratitude."
      Speaker = "Hades"
      Event = "HadesAboutHecate01"
    }
    {
      Id = "Hades_0166"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nyx, herself... even she was powerless against the Titan. Two of Night Incarnate's own sons served in my House along with her... I suppose he has them, too."
      Speaker = "Hades"
      Event = "HadesAboutNyx01"
    }
    {
      Id = "MelinoeField_2008"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, Hypnos is with {#Emph}us! {#Prev}Fast asleep for all this time, perhaps some sort of... defensive response, for we have found no way to wake him. Brave Schelemeus is with us as well!"
      Speaker = "Melinoe"
      Event = "HadesAboutNyx01"
    }
    {
      Id = "Hades_0167"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hypnos, asleep {#Emph}again? {#Prev}And I've no recollection of that other name... but Time has worn on me. Regardless, if the Witch yet leads the Unseen, the will of Night is not yet lost."
      Speaker = "Hades"
      Event = "HadesAboutNyx01"
    }
    {
      Id = "Hades_0164"
      InheritFrom = "BaseNarrative"
      DisplayName = "My brothers each are aiding you, are they? Zeus, doubtless leading from behind the safety of his palace walls... Poseidon, blustering as though his victory is already at hand..."
      Speaker = "Hades"
      Event = "HadesAboutBrothers01"
    }
    {
      Id = "MelinoeField_2007"
      InheritFrom = "BaseNarrative"
      DisplayName = "Father, they're fighting to defend their home... and they're fighting for {#Emph}you! {#Prev}You're right that neither one is much inclined to show concern, but why should they? Fear spreads."
      Speaker = "Melinoe"
      Event = "HadesAboutBrothers01"
    }
    {
      Id = "Hades_0165"
      InheritFrom = "BaseNarrative"
      DisplayName = "They sat oblivious upon their surface realm for far too long...! But do not listen to my rantings about them. Had you known your own brother, perhaps you'd better understand the impulse for such ill-conceived remarks..."
      Speaker = "Hades"
      Event = "HadesAboutBrothers01"
    }
    {
      Id = "Hades_0108"
      InheritFrom = "BaseNarrative"
      DisplayName = "What has that blasted Titan done to Cerberus, that he should storm into this place with such abandon, only to be ushered out again? Takes a small army of Satyrs to drive him back..."
      Speaker = "Hades"
      Event = "HadesAboutCerberus01"
    }
    {
      Id = "MelinoeField_1498"
      InheritFrom = "BaseNarrative"
      DisplayName = "Chronos casts him out into the Mourning Fields above. Then rage and despair congeal about him, and his better senses take leave. My own path leads me through where he resides."
      Speaker = "Melinoe"
      Event = "HadesAboutCerberus01"
    }
    {
      Id = "Hades_0109"
      InheritFrom = "BaseNarrative"
      DisplayName = "So you must face him in that sorry state. Thank you, Daughter, for taking pity on the moody beast. He has seen better, but been through worse. You were too young to form a bond before, but perhaps... it is not too late."
      Speaker = "Hades"
      Event = "HadesAboutCerberus01"
    }
    {
      Id = "Hades_0200"
      InheritFrom = "BaseNarrative"
      DisplayName = "Cerberus has been quite agitated, and I'm realizing why. It's not just having to roam through the Mourning Fields; he probably can sense Typhon's return."
      Speaker = "Hades"
      Event = "HadesAboutCerberus02"
    }
    {
      Id = "MelinoeField_3316"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just about every monster I've confronted probably is traceable to Typhon in some way. I doubt he had a close relationship with any of his kin; not even Cerberus."
      Speaker = "Melinoe"
      Event = "HadesAboutCerberus02"
    }
    {
      Id = "Hades_0201"
      InheritFrom = "BaseNarrative"
      DisplayName = "I doubt that too. It seems not one of us is able to escape our fathers' influence. Yet here we all are, still."
      Speaker = "Hades"
      Event = "HadesAboutCerberus02"
    }
    {
      Id = "Hades_0205"
      InheritFrom = "BaseNarrative"
      DisplayName = "It may be best to keep your distance there, or rather for that dog. Although... the Witch of the Crossroads, she once had a hound much like that one..."
      Speaker = "Hades"
      Event = "HadesAboutHoundFamiliar01"
    }
    {
      Id = "MelinoeField_3319"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then this must be the very same. She's called Hecuba, and I'm certain she'll be respectful both to you and Cerberus. Besides, they already met in the Fields..."
      Speaker = "Melinoe"
      Event = "HadesAboutHoundFamiliar01"
    }
    {
      Id = "Hades_0206"
      InheritFrom = "BaseNarrative"
      DisplayName = "A creature possessed of loyalty and courage, then. A quite-uncommon combination, whether in beasts or otherwise. Be on your best behavior with her, Cerberus."
      Speaker = "Hades"
      Event = "HadesAboutHoundFamiliar01"
    }
    {
      Id = "MelinoeField_1577"
      InheritFrom = "BaseNarrative"
      DisplayName = "Where's Cerberus, Father? He's usually right here. I saw him in the Fields as before!"
      Speaker = "Melinoe"
      Event = "HadesAboutBouldy01"
    }
    {
      Id = "Hades_0124"
      InheritFrom = "BaseNarrative"
      DisplayName = "He runs amok at my behest. Spreads the attention of the Titan's legions thin. Eventually they drive him back, but can do him no harm."
      Speaker = "Hades"
      Event = "HadesAboutBouldy01"
    }
    {
      Id = "MelinoeField_1578"
      InheritFrom = "BaseNarrative"
      DisplayName = "So just you and the boulder, then. Looking as though it's not been heaved up any hills in quite a while. Chronos doesn't make you do it?"
      Speaker = "Melinoe"
      Event = "HadesAboutBouldy01"
    }
    {
      Id = "Hades_0125"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd have less difficult a time than a mere Shade. Besides, these shackles cannot be unlocked, save by the Titan's command. But I'd remain here for eternity before I'd grovel at his feet."
      Speaker = "Hades"
      Event = "HadesAboutBouldy01"
    }
    {
      Id = "MelinoeField_1579"
      InheritFrom = "BaseNarrative"
      DisplayName = "You say this boulder was companion to a mortal king? I... sense something from it. There can be so much energy within a common stone."
      Speaker = "Melinoe"
      Event = "HadesAboutBouldy01"
    }
    {
      Id = "Hades_0126"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll take you at your word. The boulder and I... we're not as close as was its last relationship. Though perhaps you shall coax something from it; the Witch apparently has taught you everything."
      Speaker = "Hades"
      Event = "HadesAboutBouldy01"
    }
    {
      Id = "MelinoeField_1578_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "So just you and the boulder, then. Looking as though it's not been heaved up any hills in quite a while. You say this boulder was companion to a mortal king? I... sense something from it. There can be so much energy within a common stone."
      Speaker = "Melinoe"
      Event = "HadesAboutBouldy01_B"
    }
    {
      Id = "Hades_0279"
      InheritFrom = "BaseNarrative"
      DisplayName = "Has that boulder yet revealed anything to you? I know not why I ask, mere baseless superstition on my part... but I have seen you go to it from time to time."
      Speaker = "Hades"
      Event = "HadesAboutBouldy02"
    }
    {
      Id = "MelinoeField_4153"
      InheritFrom = "BaseNarrative"
      DisplayName = "You spoke gently of the prisoner once held here, as though you had forgiven him. I used to think that was impossible in Tartarus. The boulder now reminds me otherwise."
      Speaker = "Melinoe"
      Event = "HadesAboutBouldy02"
    }
    {
      Id = "Hades_0280"
      InheritFrom = "BaseNarrative"
      DisplayName = "Most of the wretches who we once held captive here had no hope of forgiveness or freedom at all, yet even they broke loose, if undeservedly. Then let the boulder stand as testament to all that has transpired, and shall come to pass."
      Speaker = "Hades"
      Event = "HadesAboutBouldy02"
    }
    {
      Id = "Hades_0113"
      InheritFrom = "BaseNarrative"
      DisplayName = "...The scent of blood. You're injured. And you expect to face the Titan still? At least you're in the right place should you die."
      Speaker = "Hades"
      Event = "HadesAboutCharon01"
    }
    {
      Id = "MelinoeField_1571"
      InheritFrom = "BaseNarrative"
      DisplayName = "I won't be dying here no matter what. As for my injuries, perhaps Lord Charon has some Life Essence in stock."
      Speaker = "Melinoe"
      Event = "HadesAboutCharon01"
    }
    {
      Id = "Hades_0114"
      InheritFrom = "BaseNarrative"
      DisplayName = "Even now, the Boatman plies his trade? Absurd. Our entire operation was shut down! Although... I ought remember that he serves this realm, not me."
      Speaker = "Hades"
      Event = "HadesAboutCharon01"
    }
    {
      Id = "Hades_0160"
      InheritFrom = "BaseNarrative"
      DisplayName = "Daughter. Tell me something of yourself, for I know not a thing. For instance... what is it that you like to do? When you are not... attempting this."
      Speaker = "Hades"
      Event = "HadesAboutMelinoe01"
    }
    {
      Id = "MelinoeField_1994"
      InheritFrom = "BaseNarrative"
      DisplayName = "What do I like to do? Well... I ensure all of my reagents are in order, so when practicing my craft, what I need is always close at hand. And I like to... {#Emph}ungh{#Prev}, Father, this rings false..."
      Speaker = "Melinoe"
      Event = "HadesAboutMelinoe01"
    }
    {
      Id = "Hades_0161"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Mm. {#Prev}Neither the time nor place for trivialities... perhaps, however, at some point... we may discuss such matters more. But there are scores to settle first."
      Speaker = "Hades"
      Event = "HadesAboutMelinoe01"
    }
    {
      Id = "Hades_0115"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have the Death Defiance. Runs in the family. Your brother Zagreus, he was also rather sturdy for his stature. Hard-headed, as a boy."
      Speaker = "Hades"
      Event = "HadesAboutZagreus01"
    }
    {
      Id = "MelinoeField_1572"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't speak of him as though he's gone! Chronos has him, and Mother, and the rest. But when all this is over... we'll see each other again."
      Speaker = "Melinoe"
      Event = "HadesAboutZagreus01"
    }
    {
      Id = "Hades_0116"
      InheritFrom = "BaseNarrative"
      DisplayName = "How can you be so certain? To make such guarantees of the unknown! The Titan... my father... he shall not stop. He is the most hard-headed of us all."
      Speaker = "Hades"
      Event = "HadesAboutZagreus01"
    }
    {
      Id = "Hades_0119"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your mother was so proud when you were born. We... did not always think that we would have another child. But we decided to try again."
      Speaker = "Hades"
      Event = "HadesAboutPersephone01"
    }
    {
      Id = "MelinoeField_1574"
      InheritFrom = "BaseNarrative"
      DisplayName = "And you did the most important thing parents can do. You {#Emph}protected {#Prev}me. As for my mother, I know her beautiful smile. The way she's looking at me in the painting that I have."
      Speaker = "Melinoe"
      Event = "HadesAboutPersephone01"
    }
    {
      Id = "Hades_0120"
      InheritFrom = "BaseNarrative"
      DisplayName = "The painting, it survived?! The Witch, she must have taken it... and such a risk, for such a thing. Know that your mother's radiance... cannot be captured. No matter the artist's skill."
      Speaker = "Hades"
      Event = "HadesAboutPersephone01"
    }
    {
      Id = "MelinoeField_1995"
      InheritFrom = "BaseNarrative"
      DisplayName = "You saw what happened... what Chronos did to Mother, and my brother, and the rest. Where are they? Where is he holding them?"
      Speaker = "Melinoe"
      Event = "HadesAboutFamily01"
    }
    {
      Id = "Hades_0162"
      InheritFrom = "BaseNarrative"
      DisplayName = "My knowledge of this is not up-to-date. He... made everybody stop, somehow. I saw them, still as stone; not petrified exactly but ensnared, in the Great Hall of the House. He must have stored them someplace else inside..."
      Speaker = "Hades"
      Event = "HadesAboutFamily01"
    }
    {
      Id = "MelinoeField_1996"
      InheritFrom = "BaseNarrative"
      DisplayName = "Even when I'm able to vanquish Chronos on a given night, most of the House is sealed off, and I'm unable to remain for long. How can we break them out...?"
      Speaker = "Melinoe"
      Event = "HadesAboutFamily01"
    }
    {
      Id = "Hades_0163"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps if you ask the Titan very nicely, he shall comply? Daughter, I know of no way to undo his work, and have no wisdom to impart. But {#Emph}this{#Prev}, I can provide."
      Speaker = "Hades"
      Event = "HadesAboutFamily01"
    }
    {
      Id = "Hades_0202"
      InheritFrom = "BaseNarrative"
      DisplayName = "I used to have a sense for all the blessings of our kin; their Boons were not permitted in this realm. That sense has dulled, for only now do I detect the influence of Ares here..."
      Speaker = "Hades"
      Event = "HadesAboutAres01"
    }
    {
      Id = "MelinoeField_3317"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your sense for surface blessings is intact, Father. I met Ares only after all the rest. It seems this war has taken such a turn that he's now helping put a stop to it."
      Speaker = "Melinoe"
      Event = "HadesAboutAres01"
    }
    {
      Id = "Hades_0203"
      InheritFrom = "BaseNarrative"
      DisplayName = "Is that what he told you...? The only reason I can think of that my nephew would endeavor to conclude a war is if it meant still-greater wars could then be waged instead. Nevertheless, if he is claiming to be on your side, he would not lie outright."
      Speaker = "Hades"
      Event = "HadesAboutAres01"
    }
    {
      Id = "MelinoeField_3317_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your sense for surface blessings is intact, Father. I met Ares only after all the rest."
      Speaker = "Melinoe"
      Event = "HadesAboutAres01_B"
    }
    {
      Id = "Hades_0203_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "The only reason I can think of that my nephew would endeavor to conclude a war is if it meant still-greater wars could then be waged instead. Nevertheless, if he is claiming to be on your side, he would not lie outright."
      Speaker = "Hades"
      Event = "HadesAboutAres01_B"
    }
    {
      Id = "Hades_0121"
      InheritFrom = "BaseNarrative"
      DisplayName = "This chamber... it once held a prisoner of mine. A mortal king who had attempted to cheat Death! I forced the wretch to heave that boulder up that path forever. He forgave me anyway."
      Speaker = "Hades"
      Event = "HadesAboutSisyphus01"
    }
    {
      Id = "MelinoeField_1575"
      InheritFrom = "BaseNarrative"
      DisplayName = "Forget him, Father. What purpose does it serve to dwell on some dead mortal now? Chronos wants you to wallow in your guilt. Don't."
      Speaker = "Melinoe"
      Event = "HadesAboutSisyphus01"
    }
    {
      Id = "Hades_0122"
      InheritFrom = "BaseNarrative"
      DisplayName = "You misunderstand. The prisoner, he was called Sisyphus the King. His boulder there was like a friend. He... asked his friend to keep me company. Until more company arrived, he said."
      Speaker = "Hades"
      Event = "HadesAboutSisyphus01"
    }
    {
      Id = "MelinoeField_1576"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well then I'm grateful to that boulder and the king. Chronos must not have accounted for your former prisoners being fond of you."
      Speaker = "Melinoe"
      Event = "HadesAboutSisyphus01"
    }
    {
      Id = "Hades_0123"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh most of them are not. Some chose to join the Titan's legions and remain here in Tartarus. Not anywhere I cast my gaze, of course."
      Speaker = "Hades"
      Event = "HadesAboutSisyphus01"
    }
    {
      Id = "MelinoeField_1575_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "Forget him, Father. What purpose does it serve to dwell on some dead mortal now?"
      Speaker = "Melinoe"
      Event = "HadesAboutSisyphus01_B"
    }
    {
      Id = "Hades_0303"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your mother sends you her warmest regards, and regrets that she was unable to join me here this time. Certain matters at the House require {#Emph}her {#Prev}attention, if not mine."
      Speaker = "Hades"
      Event = "HadesAboutPersephoneAway01"
    }
    {
      Id = "MelinoeField_4164"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thank you, and please give my regards to Mother, in kind. So you get to be {#Emph}here {#Prev}while she takes care of things {#Emph}there... {#Prev}do you draw lots to determine who does what?"
      Speaker = "Melinoe"
      Event = "HadesAboutPersephoneAway01"
    }
    {
      Id = "Hades_0304"
      InheritFrom = "BaseNarrative"
      DisplayName = "Drawing lots is how I wound up in this realm, and is not something I have done again. This is simpler, besides: Being here is how I can best ensure your continued success."
      Speaker = "Hades"
      Event = "HadesAboutPersephoneAway01"
    }
    {
      Id = "Hades_0412"
      InheritFrom = "BaseNarrative"
      DisplayName = "How... how is it you already have my blessing, Daughter? Is that... you have our family's heirloom... the Jeweled Pom. Where did you get it?"
      Speaker = "Hades"
      Event = "HadesAboutStoryReset01"
    }
    {
      Id = "MelinoeField_5219"
      InheritFrom = "BaseNarrative"
      DisplayName = "I... I don't remember where I got it, I... haven't I always had it? Father... I... didn't you... I don't understand."
      Speaker = "Melinoe"
      Event = "HadesAboutStoryReset01"
    }
    {
      Id = "Hades_0413"
      InheritFrom = "BaseNarrative"
      DisplayName = "Most likely the Witch of the Crossroads procured it, but who can say? My father's influence is strong... Time wears on memory, perhaps. But here... I can add to its power."
      Speaker = "Hades"
      Event = "HadesAboutStoryReset01"
    }
    {
      Id = "Persephone_0068"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, Melinoë, you're back! We thought we might find you here... well, Hades did. I never would have guessed."
      Speaker = "Persephone"
      Event = "HadesWithPersephone01"
    }
    {
      Id = "Hades_0215"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your Mother and I had looked forward to seeing you again ever since you departed. How have you fared? Are matters in the Crossroads well in hand?"
      Speaker = "Hades"
      Event = "HadesWithPersephone01"
    }
    {
      Id = "MelinoeField_4148"
      InheritFrom = "BaseNarrative"
      DisplayName = "Everything is more or less all right, Father. It's good to see you in this chamber in far better spirits than before, though... why return to such a place? I'd have thought you'd rather be just about anywhere else."
      Speaker = "Melinoe"
      Event = "HadesWithPersephone01"
    }
    {
      Id = "Hades_0216"
      InheritFrom = "BaseNarrative"
      DisplayName = "The House is partially in order but the rest of Tartarus yet bears the mark of my father's extravagant tastes. Whatever harm he caused our family, undoing his decor shall take longer still!"
      Speaker = "Hades"
      Event = "HadesWithPersephone01"
    }
    {
      Id = "MelinoeField_4149"
      InheritFrom = "BaseNarrative"
      DisplayName = "Grandfather shall do his part. It also means I get to say hello."
      Speaker = "Melinoe"
      Event = "HadesWithPersephone01"
    }
    {
      Id = "Hades_0217"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well I shall do my small part then, in the retracing of your steps. Provided I may be of service still."
      Speaker = "Hades"
      Event = "HadesWithPersephone01"
    }
    {
      Id = "MelinoeField_5008"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Soot from the House..."
      Speaker = "Melinoe"
      Event = "HadesWithPersephone01"
    }
    {
      Id = "MelinoeField_4169"
      InheritFrom = "BaseNarrative"
      DisplayName = "How have the two of you been doing in all this? It must be quite a stressful time, having to get the House and Underworld back in order."
      Speaker = "Melinoe"
      Event = "HadesWithPersephone02"
    }
    {
      Id = "Hades_0307"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, it is somewhat less stressful than being imprisoned, fearing the worst for my family and dog, and watching the Underworld become unrecognizable."
      Speaker = "Hades"
      Event = "HadesWithPersephone02"
    }
    {
      Id = "Persephone_0144"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's very different in my case. In this life... one moment I was a new mother, and now I'm not! For what it's worth, you were always an adorable baby, Melinoë. "
      Speaker = "Persephone"
      Event = "HadesWithPersephone02"
    }
    {
      Id = "MelinoeField_4170"
      InheritFrom = "BaseNarrative"
      DisplayName = "You could always try and have another child, I suppose? We have nowhere near the numbers on Olympus, besides."
      Speaker = "Melinoe"
      Event = "HadesWithPersephone02"
    }
    {
      Id = "Hades_0308"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Augh! {#Prev}Let us not tempt the Fates with such talk, wherever they may be. You and your brother are more than sufficient."
      Speaker = "Hades"
      Event = "HadesWithPersephone02"
    }
    {
      Id = "MelinoeField_4154"
      InheritFrom = "BaseNarrative"
      DisplayName = "How fare the renovations to the House thus far? It was looking rather far along even before I departed."
      Speaker = "Melinoe"
      Event = "HadesWithPersephone03"
    }
    {
      Id = "Hades_0281"
      InheritFrom = "BaseNarrative"
      DisplayName = "Appearances can be deceiving, as you must already know, Daughter. The initial work is rather quick. Addressing the details takes much, much longer."
      Speaker = "Hades"
      Event = "HadesWithPersephone03"
    }
    {
      Id = "Persephone_0014"
      InheritFrom = "BaseNarrative"
      DisplayName = "Especially if all the details must be exactly as before."
      Speaker = "Persephone"
      Event = "HadesWithPersephone03"
    }
    {
      Id = "Hades_0282"
      InheritFrom = "BaseNarrative"
      DisplayName = "And why should we settle for less? Anything that we did not want changed ought to remain as we desired it."
      Speaker = "Hades"
      Event = "HadesWithPersephone03"
    }
    {
      Id = "MelinoeField_4155"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sounds like a big undertaking. Can I do something to assist?"
      Speaker = "Melinoe"
      Event = "HadesWithPersephone03"
    }
    {
      Id = "Persephone_0015"
      InheritFrom = "BaseNarrative"
      DisplayName = "Best leave this one to us, Melinoë. We're pleased to see you here! Your father can administer his blessings and take his mind off of everything! Isn't that right, Hades?"
      Speaker = "Persephone"
      Event = "HadesWithPersephone03"
    }
    {
      Id = "Hades_0283"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Grumble> {#Prev}Just make your choice and go, Daughter."
      Speaker = "Hades"
      Event = "HadesWithPersephone03"
    }
    {
      Id = "Hades_0284"
      InheritFrom = "BaseNarrative"
      DisplayName = "Gold, everywhere, {#Emph}pah! {#Prev}The light refracting from it constantly assaults my eyes. This reconstruction shall be interminable! We're nowhere {#Emph}close {#Prev}to finishing the House itself!"
      Speaker = "Hades"
      Event = "HadesWithPersephoneAboutRenovations01"
    }
    {
      Id = "Persephone_0016"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's all right, Hades. Things were quite recently much worse, and we've weathered worse storms. Why all the urgency?"
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutRenovations01"
    }
    {
      Id = "Hades_0285"
      InheritFrom = "BaseNarrative"
      DisplayName = "If not for {#Emph}my {#Prev}sake, then for {#Emph}yours! {#Prev}These grounds ought to be as you always liked. But we shall tolerate my father's taste a while longer, if we must.... Apologies, Melinoë! {#Emph}Erm{#Prev}, here."
      Speaker = "Hades"
      Event = "HadesWithPersephoneAboutRenovations01"
    }
    {
      Id = "MelinoeField_4156"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's really good to see you both here. Do all the Satyrs and such leave you well alone?"
      Speaker = "Melinoe"
      Event = "HadesWithPersephoneAboutLegions01"
    }
    {
      Id = "Hades_0286"
      InheritFrom = "BaseNarrative"
      DisplayName = "We're not the ones having to violate the principles of reality as we understand it, Daughter. It seems my father must permit his zealous followers to run free awhile longer to prevent any further {#Emph}misunderstandings {#Prev}between us."
      Speaker = "Hades"
      Event = "HadesWithPersephoneAboutLegions01"
    }
    {
      Id = "Persephone_0017"
      InheritFrom = "BaseNarrative"
      DisplayName = "But to answer more directly, Melinoë, the Satyrs and such all flee from us on sight. Often with little goatlike screams!"
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutLegions01"
    }
    {
      Id = "Hades_0287"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know that you are not so fortunate. The least your mother and I can do is prepare you for the final confrontation that awaits."
      Speaker = "Hades"
      Event = "HadesWithPersephoneAboutLegions01"
    }
    {
      Id = "Hades_0292"
      InheritFrom = "BaseNarrative"
      DisplayName = "We heard that you were on your way, Daughter. So your mother ensured we each would be here in time to greet you."
      Speaker = "Hades"
      Event = "HadesWithPersephoneAboutGreeting01"
    }
    {
      Id = "Persephone_0020"
      InheritFrom = "BaseNarrative"
      DisplayName = "Way to reveal my entire plan, Hades! We just wanted to say hi, Melinoë. Since we can't exactly have you over at the House for now."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutGreeting01"
    }
    {
      Id = "MelinoeField_4159"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hello to each of you in turn. How has everyone been? Zagreus, and all the other Houseservants?"
      Speaker = "Melinoe"
      Event = "HadesWithPersephoneAboutGreeting01"
    }
    {
      Id = "Hades_0293"
      InheritFrom = "BaseNarrative"
      DisplayName = "They all are back to work; and well we ought, now that we're done exchanging pleasantries. Do rid us of my father's lingering threat, while we rid this place of his horrid styling."
      Speaker = "Hades"
      Event = "HadesWithPersephoneAboutGreeting01"
    }
    {
      Id = "Persephone_0069"
      InheritFrom = "BaseNarrative"
      DisplayName = "I asked your father to prioritize the renovation of this chamber, if this is to be the place where we meet up now and again. And do you know what he said?"
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutChamber01"
    }
    {
      Id = "Hades_0372"
      InheritFrom = "BaseNarrative"
      DisplayName = "I merely said we ought to leave this chamber's updating for last... for I would not erase the memory of how it is. Though perhaps it shall remain this way for {#Emph}ages {#Prev}at the current rate."
      Speaker = "Hades"
      Event = "HadesWithPersephoneAboutChamber01"
    }
    {
      Id = "Persephone_0079"
      InheritFrom = "BaseNarrative"
      DisplayName = "Our daughter, part of the Unseen... officially, Hades and I aren't even supposed to {#Emph}know {#Prev}of you... where you reside... nothing."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutUnseen01"
    }
    {
      Id = "Hades_0373"
      InheritFrom = "BaseNarrative"
      DisplayName = "The protection of the Underworld is a responsibility we all share... but in retrospect, Nyx, in her wisdom, took certain additional precautions, yes."
      Speaker = "Hades"
      Event = "HadesWithPersephoneAboutUnseen01"
    }
    {
      Id = "MelinoeField_4457"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't know how well-kept of a secret the Unseen are at this point. We had to emerge from the shadows once or twice in all this."
      Speaker = "Melinoe"
      Event = "HadesWithPersephoneAboutUnseen01"
    }
    {
      Id = "Persephone_0080"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nyx herself would be the first to say it's useful for the Underworld to instill in others a certain kind of fear. But I feel so fortunate we know you not just from whispered tales of vengeance, but for who you are, Melinoë."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutUnseen01"
    }
    {
      Id = "Hades_0305"
      InheritFrom = "BaseNarrative"
      DisplayName = "Has Chronos... my father... has he been amenable to your requirements in all of this? No sudden or discernible changes of behavior or demeanor?"
      Speaker = "Hades"
      Event = "HadesAboutNeoChronos01"
    }
    {
      Id = "MelinoeField_4165"
      InheritFrom = "BaseNarrative"
      DisplayName = "He's been himself... his newer self, that is. Rather contrite, and I daresay enthusiastic about alleviating the negative effects that still linger here and above."
      Speaker = "Melinoe"
      Event = "HadesAboutNeoChronos01"
    }
    {
      Id = "Hades_0306"
      InheritFrom = "BaseNarrative"
      DisplayName = "We ought remain on guard nevertheless. Although, my father never could hide his contempt. If you have rid him of that... then he truly is no longer the Titan I once knew."
      Speaker = "Hades"
      Event = "HadesAboutNeoChronos01"
    }
    {
      Id = "MelinoeField_4171"
      InheritFrom = "BaseNarrative"
      DisplayName = "How is Grandfather faring in the Isles of the Blessed? I was pleased to learn Lord Uncle Zeus and you were even able to find him an available post there."
      Speaker = "Melinoe"
      Event = "HadesAboutNeoChronos02"
    }
    {
      Id = "Hades_0309"
      InheritFrom = "BaseNarrative"
      DisplayName = "...My father is, surprisingly, quite competent in this newfound regard, at least thus far. The work itself is not too burdensome, although the residents of the Isles of the Blessed can be very demanding."
      Speaker = "Hades"
      Event = "HadesAboutNeoChronos02"
    }
    {
      Id = "MelinoeField_4172"
      InheritFrom = "BaseNarrative"
      DisplayName = "So Grandfather is looking after the most vaunted of Elysium, making certain that their needs are met, that sort of thing?"
      Speaker = "Melinoe"
      Event = "HadesAboutNeoChronos02"
    }
    {
      Id = "Hades_0310"
      InheritFrom = "BaseNarrative"
      DisplayName = "Essentially, that is correct. He is attentive to detail, and not prone to forgetfulness. We shall be monitoring him to ensure he remains that way."
      Speaker = "Hades"
      Event = "HadesAboutNeoChronos02"
    }
    {
      Id = "Hades_0386"
      InheritFrom = "BaseNarrative"
      DisplayName = "Most fear to tread within this chamber, but quite recently the visage of Nyx herself charged in. Saluted in a huff and strode on past! One of Nyx's daughters?"
      Speaker = "Hades"
      Event = "HadesAboutNemesis01"
    }
    {
      Id = "MelinoeField_5028"
      InheritFrom = "BaseNarrative"
      DisplayName = "That sounds like Nemesis. She's wanted to get her hands on Chronos practically more than I ever did. Going after the traces of him now, the same as me. We have a thing going."
      Speaker = "Melinoe"
      Event = "HadesAboutNemesis01"
    }
    {
      Id = "Hades_0387"
      InheritFrom = "BaseNarrative"
      DisplayName = "That almost makes me feel some pity for those traces, then. To have to face Retribution or Vengeance, if not both."
      Speaker = "Hades"
      Event = "HadesAboutNemesis01"
    }
    {
      Id = "Hades_0414"
      InheritFrom = "BaseNarrative"
      DisplayName = "Daughter... we had... meant to ask you at some point, about your arm, because... well, it is but a curiosity, and one you need not indulge, if the subject is best avoided..."
      Speaker = "Hades"
      Event = "HadesWithPersephoneAboutBackstory01"
    }
    {
      Id = "MelinoeField_5220"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, right! I'm so accustomed to it now that I never thought to mention it. I... had a bit of an accident, a long time ago. Turned out that my grasp over life and death was not as strong as I thought. It's been a good reminder ever since."
      Speaker = "Melinoe"
      Event = "HadesWithPersephoneAboutBackstory01"
    }
    {
      Id = "Hades_0415"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yet your connection to the dead we sense is very strong. Well, we each have our scars from lessons learned... most are not as noticeable or intriguing. Your mother and I figured it was more of a personal choice."
      Speaker = "Hades"
      Event = "HadesWithPersephoneAboutBackstory01"
    }
    {
      Id = "Hades_0411"
      InheritFrom = "BaseNarrative"
      DisplayName = "We've you to thank for the return of Hypnos. He would not cease apologizing for his dereliction of duty. He now is taking stock of the number of days he missed work."
      Speaker = "Hades"
      Event = "HadesWithPersephoneAboutHypnosWakeUp01"
    }
    {
      Id = "Persephone_0150"
      InheritFrom = "BaseNarrative"
      DisplayName = "We figured that would help to keep him occupied... seeing as we haven't been able to take in as many newcomers as we once did."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutHypnosWakeUp01"
    }
    {
      Id = "Hades_0295"
      InheritFrom = "BaseNarrative"
      DisplayName = "The court has remained closed! Nevertheless, there are growing numbers of Shades awaiting their turns, and we require Hypnos to keep them orderly and informed."
      Speaker = "Hades"
      Event = "HadesWithPersephoneAboutHypnosWakeUp01"
    }
    {
      Id = "Persephone_0022"
      InheritFrom = "BaseNarrative"
      DisplayName = "He's going to have difficulty keeping all of them at bay if there's no telling when court shall reopen, though."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutHypnosWakeUp01"
    }
    {
      Id = "Hades_0296"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Augh{#Prev}, we need not bore our daughter with administrative drudgery. The point was merely that this missing son of Nyx has now been located. One fewer matter to resolve."
      Speaker = "Hades"
      Event = "HadesWithPersephoneAboutHypnosWakeUp01"
    }
    {
      Id = "Hades_0311"
      InheritFrom = "BaseNarrative"
      DisplayName = "Did your mother and I hear correctly that you and your brother clashed? In the midst of Elysium for all to see...?"
      Speaker = "Hades"
      Event = "HadesWithPersephoneAboutZagreusFight01"
    }
    {
      Id = "MelinoeField_4376"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, Father, it's not what you think! It was what you could call an exhibition match; a friendly challenge, nothing more. Though Zagreus did not go easy on me."
      Speaker = "Melinoe"
      Event = "HadesWithPersephoneAboutZagreusFight01"
    }
    {
      Id = "Hades_0312"
      InheritFrom = "BaseNarrative"
      DisplayName = "A shrewd decision on the boy's part, then, or more likely it was yours. For all the troubles in the Underworld, this type of {#Emph}exhibition match{#Prev}, as you refer to it, may be exactly what the Shades require."
      Speaker = "Hades"
      Event = "HadesWithPersephoneAboutZagreusFight01"
    }
    {
      Id = "Persephone_0027"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}A morale boost! {#Prev}I suppose they do enjoy this type of violent entertainment over there. Well, as long as Melinoë and Zagreus are open to it..."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutZagreusFight01"
    }
    {
      Id = "Hades_0313"
      InheritFrom = "BaseNarrative"
      DisplayName = "You trained with the Witch of the Crossroads, he trained with the greatest warrior that ever fought in mortal wars. Who is superior shall perhaps be subject to debate."
      Speaker = "Hades"
      Event = "HadesWithPersephoneAboutZagreusFight01"
    }
    {
      Id = "Persephone_0148"
      InheritFrom = "BaseNarrative"
      DisplayName = "You fought with your brother again? In another life, I was surprised how well the two of you got on when you were growing up. Perhaps since he was older..."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutZagreusFight02"
    }
    {
      Id = "MelinoeField_5223"
      InheritFrom = "BaseNarrative"
      DisplayName = "We did get into quite a bit of trouble, as I recall. But I couldn't have asked for a better big brother. He looked out for me, played with me... and now I get to beat up on him!"
      Speaker = "Melinoe"
      Event = "HadesWithPersephoneAboutZagreusFight02"
    }
    {
      Id = "Persephone_0149"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, no need to go easy on him. Just as long as it's only for show! I'd say we've had our fill of real in-fighting in our family for the foreseeable future."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutZagreusFight02"
    }
    {
      Id = "Persephone_0151"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wanted to mention, Achilles sends his greetings and well-wishes! Says he fondly recalls the practice bouts you had with Zagreus... {#Emph}erm{#Prev}, might have had. He and the other Houseservants are doing better lately."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutAchilles01"
    }
    {
      Id = "MelinoeField_5178"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm glad to hear it, and please send him my greetings and well-wishes in return. Having known him, at least in our other past... I was concerned he'd take what happened very hard. I mean the attack on the House."
      Speaker = "Melinoe"
      Event = "HadesWithPersephoneAboutAchilles01"
    }
    {
      Id = "Persephone_0152"
      InheritFrom = "BaseNarrative"
      DisplayName = "I think he did take it hard, in his way. His responsibility is to protect the House, but Chronos was too much for him... for any of us. Perhaps gods such as we, or heroes such as Achilles, need the world to remind us to have a little humility from time to time..."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutAchilles01"
    }
    {
      Id = "Persephone_0153"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do you remember how you used to play with Cerberus as though he were your trusty steed? At least he's still getting plenty of activity thanks to you."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutCerberus01"
    }
    {
      Id = "MelinoeField_5179"
      InheritFrom = "BaseNarrative"
      DisplayName = "I remember, yes! You helped me get on him and not fall down. He was very patient and gentle considering I was quite rough with him. Where I grew up in the Crossroads, I had much smaller beasts to keep me company."
      Speaker = "Melinoe"
      Event = "HadesWithPersephoneAboutCerberus01"
    }
    {
      Id = "Persephone_0154"
      InheritFrom = "BaseNarrative"
      DisplayName = "The more the better, I suppose. You were always our princess growing up, in that other past... perhaps we weren't quite as strict with you as Hecate."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutCerberus01"
    }
    {
      Id = "Persephone_0155"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're of course so much like the daughter I remember from the other past we shared, or dreamed. But the small ways in which you're different from that Melinoë are fascinating. You seem... more mature. In control."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutAltChildhood01"
    }
    {
      Id = "MelinoeField_5224"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well... I suppose I had to grow up faster in the Crossroads than in the House, so perhaps that explains it. I also didn't have quite as much training in that life. But I'm still me, I think!"
      Speaker = "Melinoe"
      Event = "HadesWithPersephoneAboutAltChildhood01"
    }
    {
      Id = "Persephone_0156"
      InheritFrom = "BaseNarrative"
      DisplayName = "I always wondered to what extent we are who we are down to the core, or whether it's our surroundings and upbringing that shapes us. The truth may lie somewhere in the middle."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutAltChildhood01"
    }
    {
      Id = "Persephone_0024"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have my blessings as well, you know that, don't you, Melinoë? Unfortunately, I'm not supposed to offer you the more-tangible kind while we're cleaning up after Chronos."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutBlessings01"
    }
    {
      Id = "Hades_0301"
      InheritFrom = "BaseNarrative"
      DisplayName = "Surely my own blessings shall suffice? Our daughter has already faced and vanquished this Titan many times... there is no need to alter what has already been working well."
      Speaker = "Hades"
      Event = "HadesWithPersephoneAboutBlessings01"
    }
    {
      Id = "MelinoeField_4163"
      InheritFrom = "BaseNarrative"
      DisplayName = "Simply seeing you two is enough to carry me to the end. Though I'm certain Mother's blessings would have made me even stronger. Power over life and death and such...!"
      Speaker = "Melinoe"
      Event = "HadesWithPersephoneAboutBlessings01"
    }
    {
      Id = "Persephone_0025"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, when you put it {#Emph}that {#Prev}way... I suppose I take after my own mother more than I sometimes let on."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutBlessings01"
    }
    {
      Id = "Hades_0302"
      InheritFrom = "BaseNarrative"
      DisplayName = "Daughter... your mother brought life to this realm where it never should have been able to take hold, and we are richer for it."
      Speaker = "Hades"
      Event = "HadesWithPersephoneAboutBlessings01"
    }
    {
      Id = "Persephone_0083"
      InheritFrom = "BaseNarrative"
      DisplayName = "That little Pom we gave you. We commissioned a very small number using only the finest gemstones, and always meant for you to have one once you were of age..."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutKeepsake01"
    }
    {
      Id = "MelinoeField_4459"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, surprise! And thank you. Not only is it beautiful, but it makes me feel more connected to the two of you."
      Speaker = "Melinoe"
      Event = "HadesWithPersephoneAboutKeepsake01"
    }
    {
      Id = "Persephone_0084"
      InheritFrom = "BaseNarrative"
      DisplayName = "Poms are said to have that effect. One could eat just a handful of their seeds and never want to leave the Underworld again!"
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutKeepsake01"
    }
    {
      Id = "Persephone_0087"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Skull Revaal... Nyx once offered it to me for my protection, just in case. I never would have thought it would protect me even while not in my care."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutPersephoneAspect01"
    }
    {
      Id = "MelinoeField_4461"
      InheritFrom = "BaseNarrative"
      DisplayName = "Would you like it back at this point, Mother? Perhaps my time as Revaal's bearer is drawing to a close now that you're back."
      Speaker = "Melinoe"
      Event = "HadesWithPersephoneAboutPersephoneAspect01"
    }
    {
      Id = "Persephone_0088"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, whether the Fates already predetermined this or I'm deciding it right now, no thank you. If the Argent Skull has gotten you {#Emph}this {#Prev}far, then you two make a proper team."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutPersephoneAspect01"
    }
    {
      Id = "Persephone_0146"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're bearing my Aspect of the Skull Revaal, and making use of our family's Jeweled Pom... I'd hoped that we could aid you, but not expected this to be the way!"
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutPersephoneAspect02"
    }
    {
      Id = "MelinoeField_5222"
      InheritFrom = "BaseNarrative"
      DisplayName = "Father's blessing and the Argent Skull make a potent combination. And I'm reminded of all the times we shared... well, that we could have shared."
      Speaker = "Melinoe"
      Event = "HadesWithPersephoneAboutPersephoneAspect02"
    }
    {
      Id = "Persephone_0147"
      InheritFrom = "BaseNarrative"
      DisplayName = "Even if that other past is merely what could have been, the memories are real, and I'll cherish them... alongside the memories that we've been making since."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutPersephoneAspect02"
    }
    {
      Id = "Persephone_0159"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nyx doesn't always show it, but she's very grateful for everything you've done, you know. You're even using her own Aspect of Xinth... it's a good thing she isn't too prideful!"
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutNyxAspect01"
    }
    {
      Id = "MelinoeField_5226"
      InheritFrom = "BaseNarrative"
      DisplayName = "I often have to remind myself that so much of the world as I know it exists thanks to her... not to mention the Unseen. She's amazing... though must be very busy."
      Speaker = "Melinoe"
      Event = "HadesWithPersephoneAboutNyxAspect01"
    }
    {
      Id = "Persephone_0160"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, the original reason your father came here at all was to alleviate some of that burden. And to think... presiding over the entire Underworld was only {#Emph}part {#Prev}of her responsibilities. Thank you for helping her."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutNyxAspect01"
    }
    {
      Id = "Persephone_0095"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sometimes I wish we could spend more time together, you know? But then I recall how it was for {#Emph}me {#Prev}growing up. Just... don't forget we're here if you need anything."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutDemeter01"
    }
    {
      Id = "MelinoeField_4467"
      InheritFrom = "BaseNarrative"
      DisplayName = "Of course I won't. How was it living with Grandmother? She seems so intense, and capable... I like her a lot."
      Speaker = "Melinoe"
      Event = "HadesWithPersephoneAboutDemeter01"
    }
    {
      Id = "Persephone_0096"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm glad. Your Grandmother Demeter and I, we had our difficulties now and then, but it's been better since I moved down here. My grand conclusion from it all is simply that children need their space... as hard as it is to let them go."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneAboutDemeter01"
    }
    {
      Id = "Hades_0288"
      InheritFrom = "BaseNarrative"
      DisplayName = "We heard of the return of the Three Fates. How much you had to do with it shall be for you to know, but tell us... were they in good spirits, at the least?"
      Speaker = "Hades"
      Event = "HadesWithPersephonePostEpilogue01"
    }
    {
      Id = "MelinoeField_4157"
      InheritFrom = "BaseNarrative"
      DisplayName = "They seemed to be. Clotho, who spoke the most by far, she seemed in quite a cheery mood, now that you mention it! So much so that I have trouble imagining her otherwise..."
      Speaker = "Melinoe"
      Event = "HadesWithPersephonePostEpilogue01"
    }
    {
      Id = "Hades_0289"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then we are fortunate, perhaps... for they can be a temperamental bunch. Their moods may not solely dictate the nature of their weavings, but certainly must correlate."
      Speaker = "Hades"
      Event = "HadesWithPersephonePostEpilogue01"
    }
    {
      Id = "Persephone_0018"
      InheritFrom = "BaseNarrative"
      DisplayName = "We were told that they would cease their weavings for a while. You don't believe it, do you, though, Hades...?"
      Speaker = "Persephone"
      Event = "HadesWithPersephonePostEpilogue01"
    }
    {
      Id = "Hades_0290"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, absolutely not. Although I welcome each of you to draw whichever conclusions you see fit."
      Speaker = "Hades"
      Event = "HadesWithPersephonePostEpilogue01"
    }
    {
      Id = "Persephone_0019"
      InheritFrom = "BaseNarrative"
      DisplayName = "Melinoë, what do you make of this new age the Fates foretold? You know you have some mortal blood in you... perhaps it's for the best."
      Speaker = "Persephone"
      Event = "HadesWithPersephonePostEpilogue02"
    }
    {
      Id = "MelinoeField_4158"
      InheritFrom = "BaseNarrative"
      DisplayName = "We did all right with the Fates seemingly leaving everything to us... so if that's the way of things moving forward, I'm open to it. Though, what happens to the Underworld, if the gods are to hold less sway?"
      Speaker = "Melinoe"
      Event = "HadesWithPersephonePostEpilogue02"
    }
    {
      Id = "Hades_0291"
      InheritFrom = "BaseNarrative"
      DisplayName = "We shall adapt, as we have always done. But unless this {#Emph}new age {#Prev}causes mortals to be relieved of their defining trait — that they all perish, soon enough — then I should think what we do here shall always serve a vital purpose."
      Speaker = "Hades"
      Event = "HadesWithPersephonePostEpilogue02"
    }
    {
      Id = "MelinoeField_4464"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do you two ever... do you have opportunity to speak with the Witch of the Crossroads... with Hecate, now and again?"
      Speaker = "Melinoe"
      Event = "HadesWithPersephonePostEpilogue03"
    }
    {
      Id = "Persephone_0091"
      InheritFrom = "BaseNarrative"
      DisplayName = "Given her charge, we're not really supposed to be seen sipping Ambrosia together at this point, though the same is true of you. We do hear about her but respect her privacy."
      Speaker = "Persephone"
      Event = "HadesWithPersephonePostEpilogue03"
    }
    {
      Id = "MelinoeField_4465"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh I see, well... anyhow, I think... that it would mean a lot to her to hear from you every so often, if you don't mind? She fought so hard for your return... harder than anyone."
      Speaker = "Melinoe"
      Event = "HadesWithPersephonePostEpilogue03"
    }
    {
      Id = "Persephone_0092"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hahah{#Prev}, well. I think we can find a way to get the occasional message through the veil, right, Hades? Hecate shall always have our gratitude. She saved our little daughter, after all."
      Speaker = "Persephone"
      Event = "HadesWithPersephonePostEpilogue03"
    }
    {
      Id = "Hades_0036"
      InheritFrom = "BaseNarrative"
      DisplayName = "Cease with this foolishness, Daughter. There is no stopping him. He is inevitability itself."
      Speaker = "Hades"
      Event = "HadesChat01"
    }
    {
      Id = "Hades_0037"
      InheritFrom = "BaseNarrative"
      DisplayName = "You risk too much by visiting me here."
      Speaker = "Hades"
      Event = "HadesChat02"
    }
    {
      Id = "Hades_0038"
      InheritFrom = "BaseNarrative"
      DisplayName = "My son would never listen to me; I was a fool to think it a distinctive trait."
      Speaker = "Hades"
      Event = "HadesChat03"
    }
    {
      Id = "Hades_0039"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've little strength of late, but you shall have it nonetheless."
      Speaker = "Hades"
      Event = "HadesChat04"
    }
    {
      Id = "Hades_0040"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thank you for looking after Cerberus, though look after yourself."
      Speaker = "Hades"
      Event = "HadesChat05"
    }
    {
      Id = "Hades_0041"
      InheritFrom = "BaseNarrative"
      DisplayName = "You are as willful as your brother, aren't you..."
      Speaker = "Hades"
      Event = "HadesChat06"
    }
    {
      Id = "Hades_0096"
      InheritFrom = "BaseNarrative"
      DisplayName = "Whenever you return... so does a portion of my strength."
      Speaker = "Hades"
      Event = "HadesChat07"
    }
    {
      Id = "Hades_0097"
      InheritFrom = "BaseNarrative"
      DisplayName = "Take no unnecessary risks and go unseen, Daughter."
      Speaker = "Hades"
      Event = "HadesChat08"
    }
    {
      Id = "Hades_0098"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have vanquished the Titan before; you know full well what it takes."
      Speaker = "Hades"
      Event = "HadesChat09"
    }
    {
      Id = "Hades_0099"
      InheritFrom = "BaseNarrative"
      DisplayName = "I am of little use like this. You need not stray from your path on my account."
      Speaker = "Hades"
      Event = "HadesChat10"
    }
    {
      Id = "Hades_0100"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hold nothing back against the Titan. That you are family matters not to him."
      Speaker = "Hades"
      Event = "HadesChat11"
    }
    {
      Id = "Hades_0101"
      InheritFrom = "BaseNarrative"
      DisplayName = "Be on your way, Daughter. I require no assistance here."
      Speaker = "Hades"
      Event = "HadesChat12"
    }
    {
      Id = "Hades_0102"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Witch of the Crossroads swore no harm would come to you; ensure she keeps her word."
      Speaker = "Hades"
      Event = "HadesChat13"
    }
    {
      Id = "Hades_0103"
      InheritFrom = "BaseNarrative"
      DisplayName = "How strange to have a moment's peace with you and Cerberus, in such an age."
      Speaker = "Hades"
      Event = "HadesChat14"
    }
    {
      Id = "Hades_0104"
      InheritFrom = "BaseNarrative"
      DisplayName = "We have anticipated your arrival, ever since the dog bounded in here."
      Speaker = "Hades"
      Event = "HadesChat15"
    }
    {
      Id = "Hades_0105"
      InheritFrom = "BaseNarrative"
      DisplayName = "Go, take your vengeance. Our family, we've more than enough to spare."
      Speaker = "Hades"
      Event = "HadesChat16"
    }
    {
      Id = "Hades_0047"
      InheritFrom = "BaseNarrative"
      DisplayName = "He is no mere Titan. He is Time itself; and Time cannot be stopped..."
      Speaker = "Hades"
      Event = "HadesChat18"
    }
    {
      Id = "Hades_0111"
      InheritFrom = "BaseNarrative"
      DisplayName = "These shackles sap me of my force of will; but not entirely."
      Speaker = "Hades"
      Event = "HadesChat19"
    }
    {
      Id = "Hades_0112"
      InheritFrom = "BaseNarrative"
      DisplayName = "This is not how I imagined my daughter would spend the evenings of her youth..."
      Speaker = "Hades"
      Event = "HadesChat20"
    }
    {
      Id = "Hades_0316"
      InheritFrom = "BaseNarrative"
      DisplayName = "These blessings are mere trifles, but if they have been effective, so be it."
      Speaker = "Hades"
      Event = "HadesPostTrueEndingChat01"
    }
    {
      Id = "Hades_0320"
      InheritFrom = "BaseNarrative"
      DisplayName = "Zagreus sends his regards. The Underworld has kept him busy recently."
      Speaker = "Hades"
      Event = "HadesPostTrueEndingChat02"
    }
    {
      Id = "Hades_0321"
      InheritFrom = "BaseNarrative"
      DisplayName = "What my father did to Tartarus is a disgrace we shall correct in time..."
      Speaker = "Hades"
      Event = "HadesPostTrueEndingChat03"
    }
    {
      Id = "Hades_0327"
      InheritFrom = "BaseNarrative"
      DisplayName = "If there is something more that we can do to facilitate your efforts, merely ask."
      Speaker = "Hades"
      Event = "HadesPostTrueEndingChat04"
    }
    {
      Id = "Hades_0330"
      InheritFrom = "BaseNarrative"
      DisplayName = "We trust that the Witch of the Crossroads and the rest are lately doing well?"
      Speaker = "Hades"
      Event = "HadesPostTrueEndingChat05"
    }
    {
      Id = "Hades_0331"
      InheritFrom = "BaseNarrative"
      DisplayName = "My father may be different now, but if any old trace of him remains, destroy it."
      Speaker = "Hades"
      Event = "HadesPostTrueEndingChat06"
    }
    {
      Id = "Hades_0334"
      InheritFrom = "BaseNarrative"
      DisplayName = "Let us ensure that nothing like what we have withstood shall ever again transpire."
      Speaker = "Hades"
      Event = "HadesPostTrueEndingChat07"
    }
    {
      Id = "Hades_0335"
      InheritFrom = "BaseNarrative"
      DisplayName = "I shall always have wrath to spare for any remnants of my father's former self."
      Speaker = "Hades"
      Event = "HadesPostTrueEndingChat08"
    }
    {
      Id = "Hades_0318"
      InheritFrom = "BaseNarrative"
      DisplayName = "Matters in the House are well in hand. We trust that all is likewise well with you."
      Speaker = "Hades"
      Event = "HadesPostTrueEndingChat09"
    }
    {
      Id = "Hades_0324"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your work has drawn you to the surface more and more, so it is good to see you here."
      Speaker = "Hades"
      Event = "HadesPostTrueEndingChat10"
    }
    {
      Id = "Persephone_0061"
      InheritFrom = "BaseNarrative"
      DisplayName = "You must have been an adorable little girl, but you're not so bad right now."
      Speaker = "Persephone"
      Event = "HadesWithPersephonePostTrueEndingChat01"
    }
    {
      Id = "Persephone_0062"
      InheritFrom = "BaseNarrative"
      DisplayName = "One of these days or nights we'll have to tidy up this particular chamber, Hades..."
      Speaker = "Persephone"
      Event = "HadesWithPersephonePostTrueEndingChat02"
    }
    {
      Id = "Persephone_0065"
      InheritFrom = "BaseNarrative"
      DisplayName = "Go show that possibility of Chronos whose side of the family is really in charge here."
      Speaker = "Persephone"
      Event = "HadesWithPersephonePostTrueEndingChat03"
    }
    {
      Id = "MelinoeField_1499"
      InheritFrom = "BaseNarrative"
      DisplayName = "Father, while I know this wasn't necessarily permitted, I thought if maybe it would be of any comfort at all, that I might offer you this Nectar?"
      Speaker = "Melinoe"
      Event = "HadesGiftDecline01"
    }
    {
      Id = "Hades_0110"
      InheritFrom = "BaseNarrative"
      DisplayName = "Exactly like your brother, blast... I fear I'm not in any mood or state for such a thing. Concern yourself not with my comfort, but with the target of your wrath."
      Speaker = "Hades"
      Event = "HadesGiftDecline01"
    }
    {
      Id = "MelinoeField_4206"
      InheritFrom = "BaseNarrative"
      DisplayName = "Mother, Father, I'm so grateful to have you back in my life. We've so much to catch up on, but all the time in the world. For now, this is just a small House-warming gift."
      Speaker = "Melinoe"
      Event = "HadesWithPersephoneGift01"
    }
    {
      Id = "Persephone_0070"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh {#Emph}thank {#Prev}you, this is {#Emph}perfect! {#Prev}Our supply back at the House has disappeared... perhaps Chronos had a taste for it."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneGift01"
    }
    {
      Id = "Hades_0218"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nectar from the highest peaks... to think we once forbade this substance here, though that was well before your time. Thank you, Daughter. And we have something here for you, in turn. A small token, but a symbol of our family as well."
      Speaker = "Hades"
      Event = "HadesWithPersephoneGift01"
    }
    {
      Id = "Persephone_0071"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thank you, Daughter. We could certainly make use of this. Hades had a particular idea for it, in fact."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneGift02"
    }
    {
      Id = "Hades_0219"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you would permit it, Daughter... I would offer up such Nectar to the Shades assisting in the Underworld renovations underway. As an added token of appreciation for their toil. Is that acceptable to you?"
      Speaker = "Hades"
      Event = "HadesWithPersephoneGift02"
    }
    {
      Id = "MelinoeField_4377"
      InheritFrom = "BaseNarrative"
      DisplayName = "Of course, Father, it's yours to do with as you please. And I can think of no finer purpose for it than to reward those Shades who have remained loyal to us through all this."
      Speaker = "Melinoe"
      Event = "HadesWithPersephoneGift02"
    }
    {
      Id = "Persephone_0072"
      InheritFrom = "BaseNarrative"
      DisplayName = "Such a fine bottle. We graciously accept! You know, you remind me of your brother sometimes..."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneGift03"
    }
    {
      Id = "Hades_0220"
      InheritFrom = "BaseNarrative"
      DisplayName = "These customs that we share from those above... I ask that you not follow our traditions blindly. Such traditions may be partially responsible for the many mistakes that led us to this point."
      Speaker = "Hades"
      Event = "HadesWithPersephoneGift03"
    }
    {
      Id = "MelinoeField_4378"
      InheritFrom = "BaseNarrative"
      DisplayName = "I share your cautious feeling about this, Father, but... of the many traditions of the gods, the act of giving Nectar to those we care for seems one of the better ones, in my estimation."
      Speaker = "Melinoe"
      Event = "HadesWithPersephoneGift03"
    }
    {
      Id = "Hades_0221"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Perhaps so."
      Speaker = "Hades"
      Event = "HadesWithPersephoneGift03"
    }
    {
      Id = "Hades_0222"
      InheritFrom = "BaseNarrative"
      DisplayName = "You ought have many others who would welcome such a gift. To have been raised in the seclusion of those Crossroads... I fear it must have been a very solitary life. More so than one would like."
      Speaker = "Hades"
      Event = "HadesWithPersephoneGift04"
    }
    {
      Id = "Persephone_0073"
      InheritFrom = "BaseNarrative"
      DisplayName = "Solitude is not always such a bad thing, but... certainly it couldn't have been easy on you."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneGift04"
    }
    {
      Id = "MelinoeField_4379"
      InheritFrom = "BaseNarrative"
      DisplayName = "You need have no such fear. Growing up in the Crossroads was never easy, but... I never felt alone. I always had somebody or something to confide in... I would speak sometimes even to a fountain that we have in your honor."
      Speaker = "Melinoe"
      Event = "HadesWithPersephoneGift04"
    }
    {
      Id = "Hades_0223"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your words are not as persuasive to me as either one of us would like. If you had grown up in my House, you would have been showered with attention, not forced to harden your hands with toil... especially for one so young."
      Speaker = "Hades"
      Event = "HadesWithPersephoneGift04"
    }
    {
      Id = "MelinoeField_4380"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have never regretted what I had to do, Father. And what friendships I have, I cherish. Perhaps I could have grown up with more, but I had everything I needed. Besides my parents. And brother and dog."
      Speaker = "Melinoe"
      Event = "HadesWithPersephoneGift04"
    }
    {
      Id = "Persephone_0074"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And now you have us, too."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneGift04"
    }
    {
      Id = "MelinoeField_4381"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thank the Fates."
      Speaker = "Melinoe"
      Event = "HadesWithPersephoneGift04"
    }
    {
      Id = "MelinoeField_4382"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know some of the Nectar's going to our loyal Shades, but I would like for you and Mother to enjoy this one yourselves. Whenever the occasion fits, just... sometime."
      Speaker = "Melinoe"
      Event = "HadesWithPersephoneGift05"
    }
    {
      Id = "Hades_0225"
      InheritFrom = "BaseNarrative"
      DisplayName = "The occasion for such pleasantries... perhaps after our Underworld renovations are complete, and we have taken proper stock of our resources and the Shades, then finally we may accept a moment of reprieve."
      Speaker = "Hades"
      Event = "HadesWithPersephoneGift05"
    }
    {
      Id = "Persephone_0029"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, stop it, Hades. Surely we can make good on Melinoë's request sooner than that. You know better than anyone that the toil never ends, so the moments of reprieve have to be seized when they present themselves."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneGift05"
    }
    {
      Id = "Hades_0226"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thus speaks the Queen. Thank you for this, Daughter. But you truly need not spare such thoughts on us. We have each other once again. I myself have want for nothing more."
      Speaker = "Hades"
      Event = "HadesWithPersephoneGift05"
    }
    {
      Id = "MelinoeField_4383"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now that you've had a Nectar for a small occasion of some sort, I did also want to give you this. For a more-special time, perhaps long from now, after we've practically forgotten how it was living apart, and the circumstances call for merriment."
      Speaker = "Melinoe"
      Event = "HadesWithPersephoneGift06"
    }
    {
      Id = "Persephone_0075"
      InheritFrom = "BaseNarrative"
      DisplayName = "This is... Ambrosia, and with such a hue as could have only come from the source... Daughter, {#Emph}thank you...!"
      Speaker = "Persephone"
      Event = "HadesWithPersephoneGift06"
    }
    {
      Id = "Hades_0227"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ambrosia from the heavens themselves... I scarce remember its savor. But I never shall forget what it was like living apart. Nor should any of us long for Time to take the pain of it away. Let us remember always how we reached this point together."
      Speaker = "Hades"
      Event = "HadesWithPersephoneGift06"
    }
    {
      Id = "MelinoeField_4384"
      InheritFrom = "BaseNarrative"
      DisplayName = "When I was little, Lady Hecate said something similar... that the pain of the past shall always linger, though assert itself less frequently with age. Well then, perhaps we ought to celebrate the memory itself. An aeon from now, for all I care."
      Speaker = "Melinoe"
      Event = "HadesWithPersephoneGift06"
    }
    {
      Id = "Persephone_0076"
      InheritFrom = "BaseNarrative"
      DisplayName = "A celebration an aeon from now would leave us with plenty of time for preparation, so... why not, Hades? Ambrosia such as this ought to age nicely till then."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneGift06"
    }
    {
      Id = "MelinoeField_4385"
      InheritFrom = "BaseNarrative"
      DisplayName = "Please let me know if I can help with any of the planning when the time comes. Or if there's anything else I can do while you're getting the House back in order."
      Speaker = "Melinoe"
      Event = "HadesWithPersephoneGift06"
    }
    {
      Id = "Persephone_0077"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's we who should be asking this of you. When you were born, Hades and I thanked the Fates that we were blessed with such a child. But we had positively no idea..."
      Speaker = "Persephone"
      Event = "HadesWithPersephoneGift06"
    }
    {
      Id = "MelinoeField_4207_B"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thank you both...!"
      Speaker = "Melinoe"
      Event = "HadesWithPersephoneGift06"
    }
    {
      Id = "Persephone_0028"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Please, take it."
      Speaker = "Persephone"
      Event = "NPC_Hades_Field_01.GiftGivenVoiceLines"
    }
    {
      Id = "MelinoeField_4207"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thank you both for this."
      Speaker = "Melinoe"
      Event = "NPC_Hades_Field_01.GiftGivenVoiceLines"
    }
    {
      Id = "Hades_0258"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I have no mood for this."
      Speaker = "Hades"
      Event = "NPC_Hades_Field_01.OnHitVoiceLines"
    }
    {
      Id = "Hades_0259"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How like your brother."
      Speaker = "Hades"
      Event = "NPC_Hades_Field_01.OnHitVoiceLines"
    }
    {
      Id = "Hades_0260"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Cease this."
      Speaker = "Hades"
      Event = "NPC_Hades_Field_01.OnHitVoiceLines"
    }
    {
      Id = "Hades_0261"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Daughter?"
      Speaker = "Hades"
      Event = "NPC_Hades_Field_01.OnHitVoiceLines"
    }
    {
      Id = "Hades_0046"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, blood and darkness..."
      Speaker = "Hades"
      Event = "NPC_Hades_Field_01.OnHitVoiceLines"
    }
    {
      Id = "Hades_0042"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Lash out, if you must."
      Speaker = "Hades"
      Event = "NPC_Hades_Field_01.OnHitVoiceLines"
    }
    {
      Id = "Hades_0043"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You need not fail as I."
      Speaker = "Hades"
      Event = "NPC_Hades_Field_01.OnHitVoiceLines"
    }
    {
      Id = "Hades_0044"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Leave me be."
      Speaker = "Hades"
      Event = "NPC_Hades_Field_01.OnHitVoiceLines"
    }
    {
      Id = "Hades_0045"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Leave me, I said."
      Speaker = "Hades"
      Event = "NPC_Hades_Field_01.OnHitVoiceLines"
    }
    {
      Id = "Hades_0257"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Shadows conceal you."
      Speaker = "Hades"
      Event = "NPC_Hades_02.InteractVoiceLines"
    }
    {
      Id = "Hades_0408"
      InheritFrom = "BaseNarrative"
      DisplayName = "...When I was having difficulties with my son... sometimes I thought of you, Father. I could not fathom having had more children to contend with all at once."
      Speaker = "Hades"
      Event = "HadesTrueEnding01"
    }
    {
      Id = "Chronos_1474"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes, well... I was not terribly successful at contending with you lot, now, was I? Particularly Zeus... to think that I shall see him and the others again soon."
      Speaker = "Chronos"
      Event = "HadesTrueEnding01"
    }
    {
      Id = "Hades_0409"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can make no assurances about how you shall be received. These dreamlike memories we share did not reach Mount Olympus, it seems. But Zeus does have my full report."
      Speaker = "Hades"
      Event = "HadesTrueEnding01"
    }
    {
      Id = "Chronos_1475"
      InheritFrom = "BaseNarrative"
      DisplayName = "Surely a ringing endorsement! But I merely jest. If Time can be so cruel, then it is only fitting for his children to be much the same. Would you not agree, Granddaughter?"
      Speaker = "Chronos"
      Event = "HadesTrueEnding01"
    }
    {
      Id = "MelinoeField_5217"
      InheritFrom = "BaseNarrative"
      DisplayName = "We may have more in common than we'd like to admit. But in any event, Lord Uncle Zeus asked you to come alone. Only the Fates now know what lies in store... although there's still no sign of them, even with Nyx's aid?"
      Speaker = "Melinoe"
      Event = "HadesTrueEnding01"
    }
    {
      Id = "Chronos_1476"
      InheritFrom = "BaseNarrative"
      DisplayName = "None. I cast them into the abyss. Had I known precisely where, they would have known how to get back. Yet if my hypothesis about such possibilities as we experienced is correct... we may find them."
      Speaker = "Chronos"
      Event = "HadesTrueEnding01"
    }
    {
      Id = "MelinoeField_5167"
      InheritFrom = "BaseNarrative"
      DisplayName = "We shall. And I look forward to testing this hypothesis. Perhaps we'll all learn something about ourselves."
      Speaker = "Melinoe"
      Event = "HadesTrueEnding01"
    }
    {
      Id = "Chronos_1477"
      InheritFrom = "BaseNarrative"
      DisplayName = "Would that we could! Gods and Titans may be doomed to live forever... but we need not be bound to our old ways."
      Speaker = "Chronos"
      Event = "HadesTrueEnding01"
    }
    {
      Id = "MelinoeField_5168"
      InheritFrom = "BaseNarrative"
      DisplayName = "Indeed. {#Emph}Erm{#Prev}, Father...? Thank you for all your hospitality. It gladdens me to see you doing well."
      Speaker = "Melinoe"
      Event = "HadesTrueEnding01"
    }
    {
      Id = "Hades_0410"
      InheritFrom = "BaseNarrative"
      DisplayName = "I would not be if not for you, Daughter. I trust that we shall see each other again soon. And perhaps even you, Father."
      Speaker = "Hades"
      Event = "HadesTrueEnding01"
    }
    {
      Id = "Chronos_1478"
      InheritFrom = "BaseNarrative"
      DisplayName = "Likewise, Hades. At least this House is mostly to your preference again. Beyond these halls, of course, much more is to be done."
      Speaker = "Chronos"
      Event = "HadesTrueEnding01"
    }
    {
      Id = "MelinoeField_5169"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes, well... Father, I wish you the best with the ongoing Underworld renovations. As for us, our chariot is here."
      Speaker = "Melinoe"
      Event = "HadesTrueEnding01"
    }
    {
      Id = "Chronos_1027"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That it is. I am prepared."
      Speaker = "Chronos"
      Event = "HadesTrueEnding01"
    }
    {
      Id = "Zagreus_0434"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well this is a rare treat. The both of you together in this lounge! What brings you here, Grandfather?"
      Speaker = "Zagreus"
      Event = "HadesHideAndSeek01"
    }
    {
      Id = "Chronos_1413"
      InheritFrom = "BaseNarrative"
      DisplayName = "I yet seek the girl's whereabouts, is what! I have turned over this residence in its entirety, and found nary a sign! She is already as elusive as you always were, Hades."
      Speaker = "Chronos"
      Event = "HadesHideAndSeek01"
    }
    {
      Id = "Hades_0392"
      InheritFrom = "BaseNarrative"
      DisplayName = "That or your old senses have dulled. She went running over there by the Head Chef, where she yet lingers in silence. Go, before her patience wears thin."
      Speaker = "Hades"
      Event = "HadesHideAndSeek01"
    }
    {
      Id = "Zagreus_0435"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Erm... {#Prev}what Father meant to say was, {#Emph}no, we've no idea where my good son's little sister is! {#Prev}She could be anywhere! Have you tried checking the administrative chamber? Gods, I sound like Hypnos."
      Speaker = "Zagreus"
      Event = "HadesHideAndSeek01"
    }
    {
      Id = "Chronos_1414"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I do appreciate the hint."
      Speaker = "Chronos"
      Event = "HadesHideAndSeek01"
    }
    {
      Id = "Zagreus_0436"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Keep up the good work!"
      Speaker = "Zagreus"
      Event = "HadesHideAndSeek01"
    }
    {
      Id = "Chronos_1415"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Where are you, my girl...?"
      Speaker = "Chronos"
      Event = "HadesHideAndSeek01"
    }
    {
      Id = "MelinoeField_5053"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}<Laugh>"
      Speaker = "Melinoe"
      Event = "HadesHideAndSeek01"
    }
    {
      Id = "Persephone_0137"
      InheritFrom = "BaseNarrative"
      DisplayName = "My beautiful daughter... we were just talking about you! How you were as a child, both in this life and the other. Growing up is so difficult... and you had to do it twice."
      Speaker = "Persephone"
      Event = "PersephoneTrueEnding01"
    }
    {
      Id = "MelinoeField_5157"
      InheritFrom = "BaseNarrative"
      DisplayName = "Which makes me beyond fortunate. Hecate was the best caretaker I can imagine. And I'm so grateful to have experienced a life with you, Mother... where there was so much warmth. And now you've met this other side of me."
      Speaker = "Melinoe"
      Event = "PersephoneTrueEnding01"
    }
    {
      Id = "Persephone_0138"
      InheritFrom = "BaseNarrative"
      DisplayName = "And I shall eagerly await getting to know this other side of you even better. And, Hecate...? You're certain it's no burden to you... to continue looking after her, just in case?"
      Speaker = "Persephone"
      Event = "PersephoneTrueEnding01"
    }
    {
      Id = "HecateField_0435"
      InheritFrom = "BaseNarrative"
      DisplayName = "I swore to you that no harm shall come to your daughter, O Queen, and that vow remains. And I shall always care for her, whether she resides with me or not."
      Speaker = "Hecate"
      Event = "PersephoneTrueEnding01"
    }
    {
      Id = "Persephone_0139"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then it's settled...! And, Melinoë... for what it's worth... I likewise opted not to live at home when I was in my youth!"
      Speaker = "Persephone"
      Event = "PersephoneTrueEnding01"
    }
    {
      Id = "HecateField_0436"
      InheritFrom = "BaseNarrative"
      DisplayName = "Please reconsider this, Melinoë... you cannot be serious about returning to that dusty glade. Your rightful home is here, and you may be unable to return while you are with us due to laws much older than ours. To serve the Unseen..."
      Speaker = "Hecate"
      Event = "PersephoneTrueEnding01"
    }
    {
      Id = "MelinoeField_5158"
      InheritFrom = "BaseNarrative"
      DisplayName = "...is to serve in shadow. I know full well, Headmistress, and do not make this decision lightly, but... I can't leave the Crossroads. Especially when we've so much left to do."
      Speaker = "Melinoe"
      Event = "PersephoneTrueEnding01"
    }
    {
      Id = "Persephone_0140"
      InheritFrom = "BaseNarrative"
      DisplayName = "Working with Chronos on this new venture of his... you've been instrumental in altering Time as we know it, so you're certainly the best fit to keep things that way."
      Speaker = "Persephone"
      Event = "PersephoneTrueEnding01"
    }
    {
      Id = "MelinoeField_5159"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ensuring Time keeps working in our favor seems like a good way to spend my own time! It should be interesting, and the matter is close to my heart. Perhaps I was born for this."
      Speaker = "Melinoe"
      Event = "PersephoneTrueEnding01"
    }
    {
      Id = "Persephone_0141"
      InheritFrom = "BaseNarrative"
      DisplayName = "You were born for much more. But we'll do our share. Cerberus has already taken to prancing through the Fields of his own accord, and your father and I shall not be far. As for your brother, well... he always turns up!"
      Speaker = "Persephone"
      Event = "PersephoneTrueEnding01"
    }
    {
      Id = "MelinoeField_5160"
      InheritFrom = "BaseNarrative"
      DisplayName = "All this is going to be an adjustment, though, isn't it? Even if I'll see you all again soon."
      Speaker = "Melinoe"
      Event = "PersephoneTrueEnding01"
    }
    {
      Id = "Persephone_0142"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah, hahaha! {#Prev}An adjustment is putting it mildly. Now go make your rounds, and I'll see you off before you depart. I love you, baby girl."
      Speaker = "Persephone"
      Event = "PersephoneTrueEnding01"
    }
    {
      Id = "MelinoeField_5161"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I love you too, Mother."
      Speaker = "Melinoe"
      Event = "PersephoneTrueEnding01"
    }
    {
      Id = "Storyteller_0501"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The Infernal Beast that wrought such terror in the Mourning Fields now sits there calmly and expectantly, not for the Princess of the Underworld, but someone else."
      Speaker = "Storyteller"
      Event = "CerberusFirstMeeting"
    }
    {
      Id = "Storyteller_0125"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ferocious Cerberus yet guards his master dutifully, having discovered him within these depths."
      Speaker = "Storyteller"
      Event = "CerberusMeeting02"
    }
    {
      Id = "Storyteller_0126"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Three-headed Cerberus permits none approach, neither him nor his master."
      Speaker = "Storyteller"
      Event = "CerberusChat01"
    }
    {
      Id = "Storyteller_0127"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The monstrous Hound of Hell bares countless fangs as if to say, back off."
      Speaker = "Storyteller"
      Event = "CerberusChat02"
    }
    {
      Id = "Storyteller_0128"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Feared watch-dog Cerberus regards the Princess with his six expectant eyes."
      Speaker = "Storyteller"
      Event = "CerberusChat03"
    }
    {
      Id = "Storyteller_0242"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The multiheaded monster keeps his fury well in check beside the rightful Underworld King."
      Speaker = "Storyteller"
      Event = "CerberusChat04"
    }
    {
      Id = "Storyteller_0243"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Fierce hell-hound Cerberus has many fangs but little trust to spare."
      Speaker = "Storyteller"
      Event = "CerberusChat05"
    }
    {
      Id = "Storyteller_0244"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The resting hound of hell makes plain he wishes not to be disturbed."
      Speaker = "Storyteller"
      Event = "CerberusChat06"
    }
    {
      Id = "Storyteller_0245"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Three-headed Cerberus eyes every surface of the chamber, all at once."
      Speaker = "Storyteller"
      Event = "CerberusChat07"
    }
    {
      Id = "Storyteller_0246"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The savage watch dog looks tentatively at the Princess of the Underworld."
      Speaker = "Storyteller"
      Event = "CerberusChat08"
    }
    {
      Id = "Storyteller_0247"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Notoriously vicious Cerberus sits vigilantly by his master's side."
      Speaker = "Storyteller"
      Event = "CerberusChat09"
    }
    {
      Id = "Storyteller_0248"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The triple-headed guardian of hell does not wish to be troubled at this time."
      Speaker = "Storyteller"
      Event = "CerberusChat10"
    }
    {
      Id = "Storyteller_0505"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The brutal hound of hell by now permits the Princess of the Dead to approach."
      Speaker = "Storyteller"
      Event = "CerberusChat11"
    }
    {
      Id = "Storyteller_0506"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Where goes the lord and master of the dead, the infernal watchdog of the Underworld follows."
      Speaker = "Storyteller"
      Event = "CerberusChat12"
    }
    {
      Id = "Storyteller_0507"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The one-time guardian of the gates of hell restrains his viciousness for the Princess."
      Speaker = "Storyteller"
      Event = "CerberusChat13"
    }
    {
      Id = "Storyteller_0508"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}For unknown reasons does this savage beast decide not to devour the Princess."
      Speaker = "Storyteller"
      Event = "CerberusChat14"
    }
    {
      Id = "Storyteller_0509"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Somehow the Princess of the Underworld has worked her magick on the hound of hell."
      Speaker = "Storyteller"
      Event = "CerberusChat15"
    }
    {
      Id = "Hades_0139"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That won't earn his affection."
      Speaker = "Hades"
      Event = "NPC_Cerberus_Field_01.OnHitVoiceLines"
    }
    {
      Id = "Hades_0140"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Leave him be."
      Speaker = "Hades"
      Event = "NPC_Cerberus_Field_01.OnHitVoiceLines"
    }
    {
      Id = "Hades_0141"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Stay{#Prev}, Cerberus..."
      Speaker = "Hades"
      Event = "NPC_Cerberus_Field_01.OnHitVoiceLines"
    }
    {
      Id = "Hades_0142"
      InheritFrom = "BaseSubtitle"
      DisplayName = "He wishes to be left alone."
      Speaker = "Hades"
      Event = "NPC_Cerberus_Field_01.OnHitVoiceLines"
    }
    {
      Id = "Hades_0143"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A temperamental beast."
      Speaker = "Hades"
      Event = "NPC_Cerberus_Field_01.OnHitVoiceLines"
    }
    {
      Id = "Hades_0144"
      InheritFrom = "BaseSubtitle"
      DisplayName = "He does not wish to play."
      Speaker = "Hades"
      Event = "NPC_Cerberus_Field_01.OnHitVoiceLines"
    }
    {
      Id = "Storyteller_0449"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The notoriously fearsome triple-headed monster Cerberus rests in his favored spot, and now regards the Princess of the Dead with three expressions different than before."
      Speaker = "Storyteller"
      Event = "CerberusTrueEnding01"
    }
    {
      Id = "MelinoeField_3890"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well boy, this must be the next best thing to guarding the Underworld's gates. Say, do I have your permission to give you a scratch? The way my brother demonstrated before."
      Speaker = "Melinoe"
      Event = "CerberusTrueEnding01"
    }
    {
      Id = "MelinoeField_1681"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know you cannot hear me, but... if you have comforted my father in his plight, thank you."
      Speaker = "Melinoe"
      Event = "BouldyFirstMeeting"
    }
    {
      Id = "BouldySilent01"
      InheritFrom = "BaseNarrative"
      DisplayName = ".   .   .   ."
      Speaker = "Bouldy"
      Event = "BouldyFirstMeeting"
    }
    {
      Id = "Hades_0156"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Leave it be."
      Speaker = "Hades"
      Event = "NPC_Bouldy_01.OnHitVoiceLines"
    }
    {
      Id = "Hades_0157"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The boulder has seen punishment enough."
      Speaker = "Hades"
      Event = "NPC_Bouldy_01.OnHitVoiceLines"
    }
    {
      Id = "Hades_0158"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Cease this, Daughter."
      Speaker = "Hades"
      Event = "NPC_Bouldy_01.OnHitVoiceLines"
    }
    {
      Id = "Hades_0159"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Vent your frustrations elsewhere."
      Speaker = "Hades"
      Event = "NPC_Bouldy_01.OnHitVoiceLines"
    }
    {
      Id = "Hades_0085"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Curse you..."
      Speaker = "Hades"
      Event = "GlobalVoiceLines.HadesCurseVoiceLines"
    }
    {
      Id = "Hades_0088"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}You stay away from her...!"
      Speaker = "Hades"
