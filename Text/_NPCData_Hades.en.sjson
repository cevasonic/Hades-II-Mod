      Event = "GlobalVoiceLines.HadesCurseVoiceLines"
    }
    {
      Id = "Hades_0089"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Wretched Titan..."
      Speaker = "Hades"
      Event = "GlobalVoiceLines.HadesCurseVoiceLines"
    }
    {
      Id = "Hades_0090"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Wretched excuse for a father!"
      Speaker = "Hades"
      Event = "GlobalVoiceLines.HadesCurseVoiceLines"
    }
    {
      Id = "Hades_0092"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Get from my House!"
      Speaker = "Hades"
      Event = "GlobalVoiceLines.HadesCurseVoiceLines"
    }
    {
      Id = "Hades_0093"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Death is your only family."
      Speaker = "Hades"
      Event = "GlobalVoiceLines.HadesCurseVoiceLines"
    }
    {
      Id = "Hades_0094"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}For what you did to me!"
      Speaker = "Hades"
      Event = "GlobalVoiceLines.HadesCurseVoiceLines"
    }
    {
      Id = "Chronos_1239"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Aah! {#Prev}You are your father's daughter!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.HadesCurseVoiceLines"
    }
    {
      Id = "Chronos_1240"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Gah! {#Prev}Hades using {#Emph}you {#Prev}to get to {#Emph}me?"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.HadesCurseVoiceLines"
    }
    {
      Id = "Chronos_1241"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Rng! {#Prev}I shall remember that, my {#Emph}son!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.HadesCurseVoiceLines"
    }
    {
      Id = "Chronos_1242"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Tsch! {#Prev}Was that {#Emph}you{#Prev}, my son?"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.HadesCurseVoiceLines"
    }
    {
      Id = "Chronos_1243"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Argh! {#Prev}You overstep, Hades!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.HadesCurseVoiceLines"
    }
    {
      Id = "Hades_0152"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Why pick the refuse from this place?"
      Speaker = "Hades"
      Event = "GlobalVoiceLines.HadesHarvestReactionVoiceLines"
    }
    {
      Id = "Hades_0153"
      InheritFrom = "BaseSubtitle"
      DisplayName = "There's nothing here of use."
      Speaker = "Hades"
      Event = "GlobalVoiceLines.HadesHarvestReactionVoiceLines"
    }
    {
      Id = "Hades_0183"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just go..."
      Speaker = "Hades"
      Event = "GlobalVoiceLines.HadesHarvestReactionVoiceLines"
    }
    {
      Id = "Hades_0179"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Good riddance."
      Speaker = "Hades"
      Event = "GlobalVoiceLines.HadesPickaxeReactionVoiceLines"
    }
    {
      Id = "Hades_0180"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Marble..."
      Speaker = "Hades"
      Event = "GlobalVoiceLines.HadesPickaxeReactionVoiceLines"
    }
    {
      Id = "Hades_0181"
      InheritFrom = "BaseSubtitle"
      DisplayName = "In his own likeness..."
      Speaker = "Hades"
      Event = "GlobalVoiceLines.HadesPickaxeReactionVoiceLines"
    }
    {
      Id = "Hades_0182"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh he has more..."
      Speaker = "Hades"
      Event = "GlobalVoiceLines.HadesPickaxeReactionVoiceLines"
    }
    {
      Id = "Hades_0184"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}<Chuckle>"
      Speaker = "Hades"
      Event = "GlobalVoiceLines.HadesPickaxeReactionVoiceLines"
    }
    {
      Id = "Hades_0154"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I thought that one would never leave."
      Speaker = "Hades"
      Event = "GlobalVoiceLines.HadesExorcismReactionVoiceLines"
    }
    {
      Id = "Hades_0155"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A Shade that has a spine."
      Speaker = "Hades"
      Event = "GlobalVoiceLines.HadesExorcismReactionVoiceLines"
    }
    {
      Id = "Hades_0185"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Long had that one waited here..."
      Speaker = "Hades"
      Event = "GlobalVoiceLines.HadesExorcismReactionVoiceLines"
    }
    {
      Id = "Hades_0186"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Shades heed you at least..."
      Speaker = "Hades"
      Event = "GlobalVoiceLines.HadesExorcismReactionVoiceLines"
    }
    {
