      Event = "NPC_Nemesis_01.PlayerLostDamageContestVoiceLines[2]"
    }
    {
      Id = "NemesisField_0192"
      InheritFrom = "BaseNarrative"
      DisplayName = "That was pathetic."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.PlayerLostDamageContestVoiceLines[2]"
    }
    {
      Id = "NemesisField_0193"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh come on, that was bad."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.PlayerLostDamageContestVoiceLines[2]"
    }
    {
      Id = "NemesisField_0194"
      InheritFrom = "BaseNarrative"
      DisplayName = "That the best you can do?"
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.PlayerLostDamageContestVoiceLines[2]"
    }
    {
      Id = "NemesisField_0195"
      InheritFrom = "BaseNarrative"
      DisplayName = "That was embarrassing..."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.PlayerLostDamageContestVoiceLines[2]"
    }
    {
      Id = "NemesisField_0384"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hmm..."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.BrowsingVoiceLines"
    }
    {
      Id = "NemesisField_0385"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This one...?"
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.BrowsingVoiceLines"
    }
    {
      Id = "NemesisField_0386"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Should have enough..."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.BrowsingVoiceLines"
    }
    {
      Id = "NemesisField_0387"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How about..."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.BrowsingVoiceLines"
    }
    {
      Id = "NemesisField_0388"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Which one..."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.BrowsingVoiceLines"
    }
    {
      Id = "NemesisField_0389"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Tough call..."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.BrowsingVoiceLines"
    }
    {
      Id = "NemesisField_0390"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Sure."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.PurchasedVoiceLines"
    }
    {
      Id = "NemesisField_0391"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Bought."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.PurchasedVoiceLines"
    }
    {
      Id = "NemesisField_0392"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Paid up."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.PurchasedVoiceLines"
    }
    {
      Id = "NemesisField_0393"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It's a deal."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.PurchasedVoiceLines"
    }
    {
      Id = "NemesisField_0394"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Here's the Gold."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.PurchasedVoiceLines"
    }
    {
      Id = "NemesisField_0395"
      InheritFrom = "BaseSubtitle"
      DisplayName = "All right."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.PurchasedVoiceLines"
    }
    {
      Id = "NemesisField_0396"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Deal, Charon."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.PurchasedVoiceLines"
    }
    {
      Id = "NemesisField_0397"
      InheritFrom = "BaseSubtitle"
      DisplayName = "But I was..."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.PurchaseStolenVoiceLines"
    }
    {
      Id = "NemesisField_0398"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Damn."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.PurchaseStolenVoiceLines"
    }
    {
      Id = "NemesisField_0399"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh you little..."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.PurchaseStolenVoiceLines"
    }
    {
      Id = "NemesisField_0400"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Really now?"
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.PurchaseStolenVoiceLines"
    }
    {
      Id = "NemesisField_0401"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come on."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.PurchaseStolenVoiceLines"
    }
    {
      Id = "Nemesis_0152"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Later."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.ExitVoiceLines"
    }
    {
      Id = "Nemesis_0153"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Going."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.ExitVoiceLines"
    }
    {
      Id = "Nemesis_0154"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm out."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.ExitVoiceLines"
    }
    {
      Id = "Nemesis_0155"
      InheritFrom = "BaseSubtitle"
      DisplayName = "'Night."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.ExitVoiceLines"
    }
    {
      Id = "Nemesis_0156"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Should go."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.ExitVoiceLines"
    }
    {
      Id = "Nemesis_0157"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Better go."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.ExitVoiceLines"
    }
    {
      Id = "Nemesis_0158"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Enough."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.ExitVoiceLines"
    }
    {
      Id = "Nemesis_0159"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Bye."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.ExitVoiceLines"
    }
    {
      Id = "Nemesis_0160"
      InheritFrom = "BaseSubtitle"
      DisplayName = "See you soon."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.ExitVoiceLines"
    }
    {
      Id = "Nemesis_0161"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Don't mess this up."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.ExitVoiceLines"
    }
    {
      Id = "Nemesis_0162"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Go on."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.ExitVoiceLines"
    }
    {
      Id = "Nemesis_0165"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Go."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.ExitVoiceLines"
    }
    {
      Id = "Melinoe_2253"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Did she just...?"
      Speaker = "Melinoe"
      Event = "NPC_Nemesis_01.ExitVoiceLines"
    }
    {
      Id = "MelinoeField_1480"
      InheritFrom = "BaseSubtitle"
      DisplayName = "She used the Chaos Gate..."
      Speaker = "Melinoe"
      Event = "NPC_Nemesis_01.ExitVoiceLines"
    }
    {
      Id = "MelinoeField_1481"
      InheritFrom = "BaseSubtitle"
      DisplayName = "She went in..."
      Speaker = "Melinoe"
      Event = "NPC_Nemesis_01.ExitVoiceLines"
    }
    {
      Id = "MelinoeField_1482"
      InheritFrom = "BaseSubtitle"
      DisplayName = "She went to Chaos?"
      Speaker = "Melinoe"
      Event = "NPC_Nemesis_01.ExitVoiceLines"
    }
    {
      Id = "Melinoe_2245"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Gone."
      Speaker = "Melinoe"
      Event = "NPC_Nemesis_01.ExitVoiceLines"
    }
    {
      Id = "Melinoe_2251"
      InheritFrom = "BaseSubtitle"
      DisplayName = "She's off."
      Speaker = "Melinoe"
      Event = "NPC_Nemesis_01.ExitVoiceLines"
    }
    {
      Id = "Melinoe_2252"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well...!"
      Speaker = "Melinoe"
      Event = "NPC_Nemesis_01.ExitVoiceLines"
    }
    {
      Id = "Melinoe_2246"
      InheritFrom = "BaseSubtitle"
      DisplayName = "'Night..."
      Speaker = "Melinoe"
      Event = "NPC_Nemesis_01.ExitVoiceLines"
    }
    {
      Id = "Melinoe_2247"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Bye..."
      Speaker = "Melinoe"
      Event = "NPC_Nemesis_01.ExitVoiceLines"
    }
    {
      Id = "Melinoe_2248"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And you."
      Speaker = "Melinoe"
      Event = "NPC_Nemesis_01.ExitVoiceLines"
    }
    {
      Id = "Melinoe_2249"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Take care."
      Speaker = "Melinoe"
      Event = "NPC_Nemesis_01.ExitVoiceLines"
    }
    {
      Id = "NemesisField_0002"
      InheritFrom = "BaseNarrative"
      DisplayName = "Missed all the fun. But least you won't have to get your hands dirty this time."
      Speaker = "Nemesis"
      Event = "NemesisGetFreeItemIntro01"
    }
    {
      Id = "Melinoe_2140"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nemesis, what are you doing here? Who's standing watch at the Crossroads?"
      Speaker = "Melinoe"
      Event = "NemesisGetFreeItemIntro01"
    }
    {
      Id = "NemesisField_0422"
      InheritFrom = "BaseNarrative"
      DisplayName = "They'll manage, I'm on break. Tell Hecate you saw me, you'll regret it. And, {#Emph}you're welcome here and safe{#Prev}, seeing as I cleared the path for you."
      Speaker = "Nemesis"
      Event = "NemesisGetFreeItemIntro01"
    }
    {
      Id = "Melinoe_2141"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't need your aid in this, other than the responsibilities you've already been assigned."
      Speaker = "Melinoe"
      Event = "NemesisGetFreeItemIntro01"
    }
    {
      Id = "NemesisField_0004"
      InheritFrom = "BaseNarrative"
      DisplayName = "Really? Look like you could use all the {#Emph}aid {#Prev}you can get. Here's something for your trouble, then I suggest you move along."
      Speaker = "Nemesis"
      Event = "NemesisGetFreeItemIntro01"
    }
    {
      Id = "NemesisField_0039"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're late. Already took care of things here, though you'll still get your share, I'm sure."
      Speaker = "Nemesis"
      Event = "NemesisGetFreeItemIntro02"
    }
    {
      Id = "MelinoeField_0023"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you insist on trying to hunt Chronos down, why don't we work at it together, at least?"
      Speaker = "Melinoe"
      Event = "NemesisGetFreeItemIntro02"
    }
    {
      Id = "NemesisField_0040"
      InheritFrom = "BaseNarrative"
      DisplayName = "Can't be seen with you, and don't need your help, besides. But I get you need mine, so here. Take this, and you never saw me. Got it?"
      Speaker = "Nemesis"
      Event = "NemesisGetFreeItemIntro02"
    }
    {
      Id = "NemesisField_0045"
      InheritFrom = "BaseNarrative"
      DisplayName = "You need all the help you can get, so here! Don't need this anyway."
      Speaker = "Nemesis"
      Event = "NemesisGetFreeItem01"
    }
    {
      Id = "NemesisField_0046"
      InheritFrom = "BaseNarrative"
      DisplayName = "So much useless junk lying around. Here, ought to be {#Emph}you {#Prev}cleaning it up, not me."
      Speaker = "Nemesis"
      Event = "NemesisGetFreeItem02"
    }
    {
      Id = "NemesisField_0047"
      InheritFrom = "BaseNarrative"
      DisplayName = "Won't be needing this at all, but you look like you will."
      Speaker = "Nemesis"
      Event = "NemesisGetFreeItem03"
    }
    {
      Id = "NemesisField_0048"
      InheritFrom = "BaseNarrative"
      DisplayName = "Pretend you never saw me, and I didn't make things easier for you."
      Speaker = "Nemesis"
      Event = "NemesisGetFreeItem04"
    }
    {
      Id = "NemesisField_0049"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wow, you really showed them, didn't you. And earned a handsome prize."
      Speaker = "Nemesis"
      Event = "NemesisGetFreeItem05"
    }
    {
      Id = "NemesisField_0050"
      InheritFrom = "BaseNarrative"
      DisplayName = "Best keep your mouth shut about this next time you and Hecate catch up."
      Speaker = "Nemesis"
      Event = "NemesisGetFreeItem06"
    }
    {
      Id = "NemesisField_0051"
      InheritFrom = "BaseNarrative"
      DisplayName = "We'll see who gets there first. Here, I'll even give you a boost."
      Speaker = "Nemesis"
      Event = "NemesisGetFreeItem07"
    }
    {
      Id = "NemesisField_0052"
      InheritFrom = "BaseNarrative"
      DisplayName = "You travel lighter than me, so here, why don't we balance out the load."
      Speaker = "Nemesis"
      Event = "NemesisGetFreeItem08"
    }
    {
      Id = "NemesisField_0053"
      InheritFrom = "BaseNarrative"
      DisplayName = "Was just about to throw this out when you came along..."
      Speaker = "Nemesis"
      Event = "NemesisGetFreeItem09"
    }
    {
      Id = "NemesisField_0054"
      InheritFrom = "BaseNarrative"
      DisplayName = "No way you'll get there first. Even give you a head start."
      Speaker = "Nemesis"
      Event = "NemesisGetFreeItem10"
    }
    {
      Id = "NemesisField_0435"
      InheritFrom = "BaseNarrative"
      DisplayName = "Expecting someone else? Taking a moment to get my bearings. Was nice and quiet here till you showed up."
      Speaker = "Nemesis"
      Event = "NemesisGetFreeItemIntroBridge01"
    }
    {
      Id = "MelinoeField_1972"
      InheritFrom = "BaseNarrative"
      DisplayName = "You haven't seen a gentle-looking Nymph nearby, have you? She's often here on this bridge."
      Speaker = "Melinoe"
      Event = "NemesisGetFreeItemIntroBridge01"
    }
    {
      Id = "NemesisField_0436"
      InheritFrom = "BaseNarrative"
      DisplayName = "Might be I scared her off. Got more important things to do than chasing Nymphs. Anyway, go on. The spirits in this place won't like us making nice."
      Speaker = "Nemesis"
      Event = "NemesisGetFreeItemIntroBridge01"
    }
    {
      Id = "NemesisField_0068"
      InheritFrom = "BaseNarrative"
      DisplayName = "Always used to be Gold in the Underworld, right in its veins. But Chronos turned it into little coins! All over the damn place now."
      Speaker = "Nemesis"
      Event = "NemesisBuyItemIntro01"
    }
    {
      Id = "MelinoeField_0024"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lord Charon's going to take care of it, soon enough. I give him all the Gold I find. Trade for his wares."
      Speaker = "Melinoe"
      Event = "NemesisBuyItemIntro01"
    }
    {
      Id = "NemesisField_0069"
      InheritFrom = "BaseNarrative"
      DisplayName = "Think I can do the same, if you want to make a deal. Don't worry, any Gold I get from you, Charon gets from me."
      Speaker = "Nemesis"
      Event = "NemesisBuyItemIntro01"
    }
    {
      Id = "NemesisField_0431"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, look who! Also lost here in these Fields I guess? Trade you a map or something if I had one, but you wouldn't have been able to afford it, so I'd use it to get out of here myself."
      Speaker = "Nemesis"
      Event = "NemesisBuyItemFields01"
    }
    {
      Id = "MelinoeField_1970"
      InheritFrom = "BaseNarrative"
      DisplayName = "I doubt a map would be of any use, as these pathways seem to shift from night to night. I've been able to make use of the Golden Boughs scattered about at least. What about you?"
      Speaker = "Melinoe"
      Event = "NemesisBuyItemFields01"
    }
    {
      Id = "NemesisField_0432"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Golden Boughs. Had no idea those did anything but look all sad. Guess I should have paid better attention when the Headmistress was droning on and on over that Cauldron."
      Speaker = "Nemesis"
      Event = "NemesisBuyItemFields01"
    }
    {
      Id = "NemesisField_0070"
      InheritFrom = "BaseNarrative"
      DisplayName = "Trade you something for some Gold. Got to keep Charon fed and all."
      Speaker = "Nemesis"
      Event = "NemesisBuyItem01"
    }
    {
      Id = "NemesisField_0071"
      InheritFrom = "BaseNarrative"
      DisplayName = "Need some Gold and won't be fair if I just beat it out of you, so how about a trade."
      Speaker = "Nemesis"
      Event = "NemesisBuyItem02"
    }
    {
      Id = "NemesisField_0072"
      InheritFrom = "BaseNarrative"
      DisplayName = "What say we make a little deal if you've got the coin."
      Speaker = "Nemesis"
      Event = "NemesisBuyItem03"
    }
    {
      Id = "NemesisField_0073"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got something you could use though you're not getting it for free."
      Speaker = "Nemesis"
      Event = "NemesisBuyItem04"
    }
    {
      Id = "NemesisField_0074"
      InheritFrom = "BaseNarrative"
      DisplayName = "Can help you go farther than this, but it's not gonna come cheap."
      Speaker = "Nemesis"
      Event = "NemesisBuyItem05"
    }
    {
      Id = "NemesisField_0075"
      InheritFrom = "BaseNarrative"
      DisplayName = "Want to be the best, it's not gonna come cheap."
      Speaker = "Nemesis"
      Event = "NemesisBuyItem06"
    }
    {
      Id = "NemesisField_0076"
      InheritFrom = "BaseNarrative"
      DisplayName = "Make you a deal, but only if you've got the coin for it."
      Speaker = "Nemesis"
      Event = "NemesisBuyItem07"
    }
    {
      Id = "NemesisField_0077"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're a princess, you must have some coin to spare, don't you?"
      Speaker = "Nemesis"
      Event = "NemesisBuyItem08"
    }
    {
      Id = "NemesisField_0078"
      InheritFrom = "BaseNarrative"
      DisplayName = "How much Gold you get out there? Can make it worth your while."
      Speaker = "Nemesis"
      Event = "NemesisBuyItem09"
    }
    {
      Id = "NemesisField_0079"
      InheritFrom = "BaseNarrative"
      DisplayName = "Could shake you down for all your Gold, but wouldn't be fair."
      Speaker = "Nemesis"
      Event = "NemesisBuyItem10"
    }
    {
      Id = "NemesisField_0100"
      InheritFrom = "BaseNarrative"
      DisplayName = "These wretches were nothing. Back when we used to spar... almost never got a clean hit in on you. You'd always slip out of the way."
      Speaker = "Nemesis"
      Event = "NemesisTakeDamageForItemIntro01"
    }
    {
      Id = "MelinoeField_0025"
      InheritFrom = "BaseNarrative"
      DisplayName = "What choice did I have? One clean hit from you was more than I could take back then. But I've been practicing!"
      Speaker = "Melinoe"
      Event = "NemesisTakeDamageForItemIntro01"
    }
    {
      Id = "NemesisField_0101"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're tougher, yeah. Though by how much? How about I hit you right now, and if you can take it, you'll get this nice reward I found. Deal?"
      Speaker = "Nemesis"
      Event = "NemesisTakeDamageForItemIntro01"
    }
    {
      Id = "NemesisField_0433"
      InheritFrom = "BaseNarrative"
      DisplayName = "You following me or something? Not used to running into you this many times per night. Find your own path."
      Speaker = "Nemesis"
      Event = "NemesisTakeDamageForItemRepeatSightings01"
    }
    {
      Id = "MelinoeField_1971"
      InheritFrom = "BaseNarrative"
      DisplayName = "Find my {#Emph}own {#Prev}path? You mean {#Emph}besides {#Prev}the one our Headmistress and Master Tactician endlessly toiled to refine to maximize my chances of success?"
      Speaker = "Melinoe"
      Event = "NemesisTakeDamageForItemRepeatSightings01"
    }
    {
      Id = "NemesisField_0434"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just stay out of my way. But first, how about you let me take a good clean swing at you, since you've been mouthing off?"
      Speaker = "Nemesis"
      Event = "NemesisTakeDamageForItemRepeatSightings01"
    }
    {
      Id = "NemesisField_0102"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Urgh{#Prev}, got to hit something sometimes. You know how it is. Could make it worth your while..."
      Speaker = "Nemesis"
      Event = "NemesisTakeDamageForItem01"
    }
    {
      Id = "NemesisField_0103"
      InheritFrom = "BaseNarrative"
      DisplayName = "Blood's boiling still... got to get it out of my system. Just one clean hit, that's all."
      Speaker = "Nemesis"
      Event = "NemesisTakeDamageForItem02"
    }
    {
      Id = "NemesisField_0104"
      InheritFrom = "BaseNarrative"
      DisplayName = "Spilled some blood getting my hands on this. Spill some of yours if you want it."
      Speaker = "Nemesis"
      Event = "NemesisTakeDamageForItem03"
    }
    {
      Id = "NemesisField_0105"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're tough. Can take a hit, can't you. Worth it for both of us..."
      Speaker = "Nemesis"
      Event = "NemesisTakeDamageForItem04"
    }
    {
      Id = "NemesisField_0106"
      InheritFrom = "BaseNarrative"
      DisplayName = "You'd have taken more than one hit getting through this mess..."
      Speaker = "Nemesis"
      Event = "NemesisTakeDamageForItem05"
    }
    {
      Id = "NemesisField_0107"
      InheritFrom = "BaseNarrative"
      DisplayName = "Took a hard hit getting here, how about you take one too."
      Speaker = "Nemesis"
      Event = "NemesisTakeDamageForItem06"
    }
    {
      Id = "NemesisField_0108"
      InheritFrom = "BaseNarrative"
      DisplayName = "Want something from me, you'll pay with blood."
      Speaker = "Nemesis"
      Event = "NemesisTakeDamageForItem07"
    }
    {
      Id = "NemesisField_0109"
      InheritFrom = "BaseNarrative"
      DisplayName = "Want to see this through, better be ready to bleed."
      Speaker = "Nemesis"
      Event = "NemesisTakeDamageForItem08"
    }
    {
      Id = "NemesisField_0110"
      InheritFrom = "BaseNarrative"
      DisplayName = "Doubt you could even handle just a single hit from me."
      Speaker = "Nemesis"
      Event = "NemesisTakeDamageForItem09"
    }
    {
      Id = "NemesisField_0111"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thinking if you can't take a hit from me, you don't have a chance."
      Speaker = "Nemesis"
      Event = "NemesisTakeDamageForItem10"
    }
    {
      Id = "NemesisField_0132"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sometimes I get a little boost from Artemis, but {#Emph}you? {#Prev}Just about all Olympus backs you up, and {#Emph}even still{#Prev}, it's not enough. Some help {#Emph}they {#Prev}are."
      Speaker = "Nemesis"
      Event = "NemesisGiveTraitForItemIntro01"
    }
    {
      Id = "MelinoeField_0026"
      InheritFrom = "BaseNarrative"
      DisplayName = "Direct your criticism to the gods themselves. Now what is it you want with me?"
      Speaker = "Melinoe"
      Event = "NemesisGiveTraitForItemIntro01"
    }
    {
      Id = "NemesisField_0133"
      InheritFrom = "BaseNarrative"
      DisplayName = "Want a little taste of all that power for myself. Come on, I'll trade you..."
      Speaker = "Nemesis"
      Event = "NemesisGiveTraitForItemIntro01"
    }
    {
      Id = "NemesisField_0134"
      InheritFrom = "BaseNarrative"
      DisplayName = "All these hand-outs from your relatives... surely you don't need them {#Emph}all?"
      Speaker = "Nemesis"
      Event = "NemesisGiveTraitForItem01"
    }
    {
      Id = "NemesisField_0135"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got something here you need, but it'll cost you some of your false power from Olympus."
      Speaker = "Nemesis"
      Event = "NemesisGiveTraitForItem02"
    }
    {
      Id = "NemesisField_0136"
      InheritFrom = "BaseNarrative"
      DisplayName = "Give me some of your borrowed strength, and you'll get some of mine."
      Speaker = "Nemesis"
      Event = "NemesisGiveTraitForItem03"
    }
    {
      Id = "NemesisField_0137"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't need Olympus handing everything to you."
      Speaker = "Nemesis"
      Event = "NemesisGiveTraitForItem04"
    }
    {
      Id = "NemesisField_0138"
      InheritFrom = "BaseNarrative"
      DisplayName = "Want what I've got, got to give something up."
      Speaker = "Nemesis"
      Event = "NemesisGiveTraitForItem05"
    }
    {
      Id = "NemesisField_0139"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't have Olympus helping me, only fair neither should you."
      Speaker = "Nemesis"
      Event = "NemesisGiveTraitForItem06"
    }
    {
      Id = "NemesisField_0140"
      InheritFrom = "BaseNarrative"
      DisplayName = "The mountain gods don't offer {#Emph}me {#Prev}their aid, though what about you?"
      Speaker = "Nemesis"
      Event = "NemesisGiveTraitForItem07"
    }
    {
      Id = "NemesisField_0141"
      InheritFrom = "BaseNarrative"
      DisplayName = "Olympus isn't gonna care if you give up one little blessing, will they?"
      Speaker = "Nemesis"
      Event = "NemesisGiveTraitForItem08"
    }
    {
      Id = "NemesisField_0142"
      InheritFrom = "BaseNarrative"
      DisplayName = "What would it take for you to give up some of your Olympian muscle?"
      Speaker = "Nemesis"
      Event = "NemesisGiveTraitForItem09"
    }
    {
      Id = "NemesisField_0143"
      InheritFrom = "BaseNarrative"
      DisplayName = "Always depending on your relatives for help. How about you give it up."
      Speaker = "Nemesis"
      Event = "NemesisGiveTraitForItem10"
    }
    {
      Id = "NemesisField_0144"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got here well before you did. Cleaned up, too. Makes you mad, I know. Don't hold back... let's see how strong you really are."
      Speaker = "Nemesis"
      Event = "NemesisDamageContestIntro01"
    }
    {
      Id = "MelinoeField_0027"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't want to fight you, Nemesis. I don't even want to speak with you right now."
      Speaker = "Melinoe"
      Event = "NemesisDamageContestIntro01"
    }
    {
      Id = "NemesisField_0145"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not asking you to fight me. Asking you to {#Emph}hit {#Prev}me. See if you can even make me budge. It'll be worth your while."
      Speaker = "Nemesis"
      Event = "NemesisDamageContestIntro01"
    }
    {
      Id = "NemesisField_0146"
      InheritFrom = "BaseNarrative"
      DisplayName = "All that pent-up anger. Let it out, then. I feel anything, I'll make it worth your while."
      Speaker = "Nemesis"
      Event = "NemesisDamageContest01"
    }
    {
      Id = "NemesisField_0147"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wretches couldn't even hit me. Wasn't fair. How about you make it up to them."
      Speaker = "Nemesis"
      Event = "NemesisDamageContest02"
    }
    {
      Id = "NemesisField_0148"
      InheritFrom = "BaseNarrative"
      DisplayName = "Look at you acting tough. Go on, hit me hard as you can. Free shot."
      Speaker = "Nemesis"
      Event = "NemesisDamageContest03"
    }
    {
      Id = "NemesisField_0149"
      InheritFrom = "BaseNarrative"
      DisplayName = "Let's see how strong you really are. Hit me, and don't hold back."
      Speaker = "Nemesis"
      Event = "NemesisDamageContest04"
    }
    {
      Id = "NemesisField_0150"
      InheritFrom = "BaseNarrative"
      DisplayName = "Can tell you're angry. Then let it out and show me what you're made of."
      Speaker = "Nemesis"
      Event = "NemesisDamageContest05"
    }
    {
      Id = "NemesisField_0151"
      InheritFrom = "BaseNarrative"
      DisplayName = "Look at you, all tough and fierce. Show me how strong you really are."
      Speaker = "Nemesis"
      Event = "NemesisDamageContest06"
    }
    {
      Id = "NemesisField_0152"
      InheritFrom = "BaseNarrative"
      DisplayName = "To the victor go the spoils. So come show me what you've got."
      Speaker = "Nemesis"
      Event = "NemesisDamageContest07"
    }
    {
      Id = "NemesisField_0153"
      InheritFrom = "BaseNarrative"
      DisplayName = "None of these wretches could touch me. But you're stronger than them, right?"
      Speaker = "Nemesis"
      Event = "NemesisDamageContest08"
    }
    {
      Id = "NemesisField_0154"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't think you have what it takes, though go on and try to prove me wrong."
      Speaker = "Nemesis"
      Event = "NemesisDamageContest09"
    }
    {
      Id = "NemesisField_0155"
      InheritFrom = "BaseNarrative"
      DisplayName = "Getting stronger, but you'll never be at my level. Go on, try me."
      Speaker = "Nemesis"
      Event = "NemesisDamageContest10"
    }
    {
      Id = "NemesisField_0005"
      InheritFrom = "BaseNarrative"
      DisplayName = "One word of this to Hecate, and you're meat, got it? Now go on while I take care of things."
      Speaker = "Nemesis"
      Event = "NemesisCombatFirstIntro"
    }
    {
      Id = "MelinoeField_0014"
      InheritFrom = "BaseNarrative"
      DisplayName = "This is my task, not yours. And I'm disappointed with your dereliction of duty. Are you so desperate to prove you're superior to me?"
      Speaker = "Melinoe"
      Event = "NemesisCombatFirstIntro"
    }
    {
      Id = "NemesisField_0006"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know, maybe I am. So how about this: Got some Gold on you, right? Those wretches ought to swarm in any moment. Whoever takes more of them gets the other's coin. What do you say?"
      Speaker = "Nemesis"
      Event = "NemesisCombatFirstIntro"
    }
    {
      Id = "MelinoeField_0015"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Must it always be a wager with you?"
      Speaker = "Melinoe"
      Event = "NemesisCombatFirstIntro"
    }
    {
      Id = "NemesisField_0007"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Fair odds of winning if you shut up and fight!"
      Speaker = "Nemesis"
      Event = "NemesisCombatFirstIntro"
    }
    {
      Id = "MelinoeField_4082"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, you ready to break a sweat again, Nem?"
      Speaker = "Melinoe"
      Event = "NemesisPreCombatBecomingCloser01"
    }
    {
      Id = "NemesisField_0479"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't insult me else I'll take more than your Gold after this. Now come on."
      Speaker = "Nemesis"
      Event = "NemesisPreCombatBecomingCloser01"
    }
    {
      Id = "NemesisField_0027"
      InheritFrom = "BaseNarrative"
      DisplayName = "Going to take care of Chronos myself if you can't do it. But first things first."
      Speaker = "Nemesis"
      Event = "NemesisCombatMiscStart01"
    }
    {
      Id = "NemesisField_0028"
      InheritFrom = "BaseNarrative"
      DisplayName = "Once we're done here, one of us gets richer, and one of us gets poorer."
      Speaker = "Nemesis"
      Event = "NemesisCombatMiscStart02"
    }
    {
      Id = "NemesisField_0029"
      InheritFrom = "BaseNarrative"
      DisplayName = "How did you get here already? {#Emph}Ungh{#Prev}, anyway. It's your Gold against mine."
      Speaker = "Nemesis"
      Event = "NemesisCombatMiscStart03"
    }
    {
      Id = "NemesisField_0030"
      InheritFrom = "BaseNarrative"
      DisplayName = "Can hardly stand all this water and the singing, but this has to be done."
      Speaker = "Nemesis"
      Event = "NemesisCombatMiscStart04"
    }
    {
      Id = "NemesisField_0031"
      InheritFrom = "BaseNarrative"
      DisplayName = "Was just about to clear the way, so why don't you pitch in."
      Speaker = "Nemesis"
      Event = "NemesisCombatMiscStart05"
    }
    {
      Id = "NemesisField_0032"
      InheritFrom = "BaseNarrative"
      DisplayName = "Fates must be smiling on you, as I'm about to do {#Emph}all {#Prev}the work."
      Speaker = "Nemesis"
      Event = "NemesisCombatMiscStart06"
    }
    {
      Id = "NemesisField_0033"
      InheritFrom = "BaseNarrative"
      DisplayName = "Should be more than enough wretches for the both of us here, any moment now."
      Speaker = "Nemesis"
      Event = "NemesisCombatMiscStart07"
    }
    {
      Id = "NemesisField_0034"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't need assistance from you here, but how about we make things interesting..."
      Speaker = "Nemesis"
      Event = "NemesisCombatMiscStart08"
    }
    {
      Id = "NemesisField_0035"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll handle this, and once I'm finished with the work, I'm getting paid."
      Speaker = "Nemesis"
      Event = "NemesisCombatMiscStart09"
    }
    {
      Id = "NemesisField_0036"
      InheritFrom = "BaseNarrative"
      DisplayName = "Let's see whether the Fates are on your side or mine this time around."
      Speaker = "Nemesis"
      Event = "NemesisCombatMiscStart10"
    }
    {
      Id = "NemesisField_0037"
      InheritFrom = "BaseNarrative"
      DisplayName = "To think I could be standing there on guard duty right now."
      Speaker = "Nemesis"
      Event = "NemesisCombatMiscStart11"
    }
    {
      Id = "NemesisField_0038"
      InheritFrom = "BaseNarrative"
      DisplayName = "Remember to be extra reckless since your Gold is on the line."
      Speaker = "Nemesis"
      Event = "NemesisCombatMiscStart12"
    }
    {
      Id = "NemesisField_0437"
      InheritFrom = "BaseNarrative"
      DisplayName = "Could use more coin. How about I take yours, soon as we're finished around here."
      Speaker = "Nemesis"
      Event = "NemesisCombatMiscStart13"
    }
    {
      Id = "NemesisField_0438"
      InheritFrom = "BaseNarrative"
      DisplayName = "Get set to fight as though there's something you could buy from Charon on the line."
      Speaker = "Nemesis"
      Event = "NemesisCombatMiscStart14"
    }
    {
      Id = "NemesisField_0439"
      InheritFrom = "BaseNarrative"
      DisplayName = "Showed up just as I was about to settle up all by myself. Well you can have your share."
      Speaker = "Nemesis"
      Event = "NemesisCombatMiscStart15"
    }
    {
      Id = "NemesisField_0440"
      InheritFrom = "BaseNarrative"
      DisplayName = "Let's split the killing down the middle, give or take. As in, {#Emph}I'll {#Prev}take your Gold."
      Speaker = "Nemesis"
      Event = "NemesisCombatMiscStart16"
    }
    {
      Id = "NemesisField_0441"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't pull your weight, I'll take your Gold soon as I wrap this up."
      Speaker = "Nemesis"
      Event = "NemesisCombatMiscStart17"
    }
    {
      Id = "NemesisField_0442"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got the Blade of the Underworld. Won't be needing your help here, thanks."
      Speaker = "Nemesis"
      Event = "NemesisCombatMiscStart18"
    }
    {
      Id = "NemesisField_0443"
      InheritFrom = "BaseNarrative"
      DisplayName = "Want a bit of extra Gold, then earn it. Now heads up, they're coming."
      Speaker = "Nemesis"
      Event = "NemesisCombatMiscStart19"
    }
    {
      Id = "NemesisField_0444"
      InheritFrom = "BaseNarrative"
      DisplayName = "How about a little friendly competition there, Princess? Come on, let's see it."
      Speaker = "Nemesis"
      Event = "NemesisCombatMiscStart20"
    }
    {
      Id = "NemesisField_0499"
      InheritFrom = "BaseNarrative"
      DisplayName = "They say Chronos likes Gold, so he won't mind our little contest here."
      Speaker = "Nemesis"
      Event = "NemesisCombatMiscStart21"
    }
    {
      Id = "NemesisField_0480"
      InheritFrom = "BaseNarrative"
      DisplayName = "So this is where the {#Emph}real {#Prev}magick happens, huh. Let's see what the best of the Titan's armies have to offer."
      Speaker = "Nemesis"
      Event = "NemesisCombatMiscStart22"
    }
    {
      Id = "NemesisField_0008"
      InheritFrom = "BaseNarrative"
      DisplayName = "Surprised you didn't bail out with that return trick of yours."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatFirstMeeting"
    }
    {
      Id = "MelinoeField_0016"
      InheritFrom = "BaseNarrative"
      DisplayName = "You don't know anything about me. What are you thinking, being this far from your post, in violation of Headmistress Hecate's direct orders?"
      Speaker = "Melinoe"
      Event = "NemesisPostCombatFirstMeeting"
    }
    {
      Id = "NemesisField_0009"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm {#Emph}thinking {#Prev}you don't have what it takes to take the Titan down. {#Emph}I {#Prev}do. Now, get out of here."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatFirstMeeting"
    }
    {
      Id = "NemesisField_0010"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thought for sure when first you saw me out here, you'd go telling Hecate soon as you could. But you didn't."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutProgress01"
    }
    {
      Id = "MelinoeField_0017"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's fortunate for you Headmistress doesn't ask me to make reports. You're probably drawing some of our enemy's attention off of me, at least."
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutProgress01"
    }
    {
      Id = "NemesisField_0011"
      InheritFrom = "BaseNarrative"
      DisplayName = "Very least I could do. Wasn't going to back down no matter what you did, but {#Emph}this {#Prev}way... can stay focused. On the task at hand."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutProgress01"
    }
    {
      Id = "NemesisField_0012"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Aw{#Prev}, you brought the Evil Eye I gave to you, how sweet. Make your enemies regret messing with you."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutKeepsake01"
    }
    {
      Id = "MelinoeField_0018"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm certain our foes will get what's coming. This Eye, though; it almost looks alive. Not using it to spy on me, are you?"
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutKeepsake01"
    }
    {
      Id = "NemesisField_0013"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nah. See enough of you as it is. Now get out of here before that Eye does anything to me."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutKeepsake01"
    }
    {
      Id = "MelinoeField_0019"
      InheritFrom = "BaseNarrative"
      DisplayName = "Say, how do you get past Headmistress on your way down? She's always waiting for me at the edge of Erebus."
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutHecate01"
    }
    {
      Id = "NemesisField_0016"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just answered your own question. She's waiting for {#Emph}you{#Prev}, not me. I'm not the one still being tested and trained. And I'm good at avoiding her."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutHecate01"
    }
    {
      Id = "NemesisField_0475"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ran into Artemis back there. Between her and now me, we must have done half the heavy lifting for you tonight."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutArtemis01"
    }
    {
      Id = "MelinoeField_3632"
      InheritFrom = "BaseNarrative"
      DisplayName = "Must be what I deserve, though, right? And don't worry, there should be plenty of foes ahead whom I shall have to deal with on my own. How is the goddess of the hunt this eve?"
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutArtemis01"
    }
    {
      Id = "NemesisField_0476"
      InheritFrom = "BaseNarrative"
      DisplayName = "Seems well enough, we had a decent chat. Was beginning to think she's been avoiding me a while, though I can't imagine why she'd want to do a thing like that."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutArtemis01"
    }
    {
      Id = "MelinoeField_3633"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Nor I."
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutArtemis01"
    }
    {
      Id = "NemesisField_0472"
      InheritFrom = "BaseNarrative"
      DisplayName = "Who needs to sip Ambrosia in the Crossroads when we could be out here doing this together, right?"
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutRelationship01"
    }
    {
      Id = "MelinoeField_3629"
      InheritFrom = "BaseNarrative"
      DisplayName = "Vanquishing our foes with impunity is your idea of a good time? Although that's not to say I don't take satisfaction in a job well done either. Wait what did you mean by {#Emph}together?"
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutRelationship01"
    }
    {
      Id = "NemesisField_0473"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh shut up. We used to spar, this is the closest thing. Don't know anybody else who can keep up, let alone get ahead."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutRelationship01"
    }
    {
      Id = "MelinoeField_3630"
      InheritFrom = "BaseNarrative"
      DisplayName = "A healthy competitive rivalry is all we have between us then?"
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutRelationship01"
    }
    {
      Id = "NemesisField_0474"
      InheritFrom = "BaseNarrative"
      DisplayName = "I said shut up. What else do you want it to be."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutRelationship01"
    }
    {
      Id = "MelinoeField_3631"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...I'll get back to you."
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutRelationship01"
    }
    {
      Id = "NemesisField_0445"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I broke a sweat? I broke a sweat. That never happens, those were weaklings, I... {#Emph}oh damn..."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutRelationship02"
    }
    {
      Id = "MelinoeField_3620"
      InheritFrom = "BaseNarrative"
      DisplayName = "What's the matter, Nem, are you all right? Our foes may have resorted to using poisons and such, if I could look at any superficial wounds..."
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutRelationship02"
    }
    {
      Id = "NemesisField_0446"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't touch me! It's not that. Now get on with it."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutRelationship02"
    }
    {
      Id = "MelinoeField_3621"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hey..."
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutRelationship02"
    }
    {
      Id = "NemesisField_0447"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not quite as comfortable as being in the springs, is it, Princess? And can be solitary work at that."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatBecomingCloser01"
    }
    {
      Id = "MelinoeField_3622"
      InheritFrom = "BaseNarrative"
      DisplayName = "It needn't be, but you refused back when I suggested we could go together through these depths. Now having second thoughts?"
      Speaker = "Melinoe"
      Event = "NemesisPostCombatBecomingCloser01"
    }
    {
      Id = "NemesisField_0448"
      InheritFrom = "BaseNarrative"
      DisplayName = "Been having thoughts, but of a different kind. You got into my head. I want you out. You always tried distracting me back when we sparred and now, you made it worse."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatBecomingCloser01"
    }
    {
      Id = "MelinoeField_3623"
      InheritFrom = "BaseNarrative"
      DisplayName = "What are you talking about, what did {#Emph}I {#Prev}do...? ...Oh. By having thoughts you mean... feelings. So what now...?"
      Speaker = "Melinoe"
      Event = "NemesisPostCombatBecomingCloser01"
    }
    {
      Id = "NemesisField_0449"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't know yet, but... well we could stay here a bit, till enough is enough. Since it's quiet. Not binding you, just... too much solitude lately, and want to even it all out."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatBecomingCloser01"
    }
    {
      Id = "NemesisField_0453"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, didn't need this but maybe you do."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatBecomingCloser01"
    }
    {
      Id = "MelinoeField_3627"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Bye, Nem..."
      Speaker = "Melinoe"
      Event = "NemesisPostCombatBecomingCloser01"
    }
    {
      Id = "MelinoeField_3628"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I'm much like you in not desiring too much of a good thing. I'm supposed to be on task, you're supposed to be on duty; I just don't think my mind would be at ease. Tell me you understand?"
      Speaker = "Melinoe"
      Event = "NemesisPostCombatBecomingCloser01"
    }
    {
      Id = "NemesisField_0454"
      InheritFrom = "BaseNarrative"
      DisplayName = "I do. Forget I asked. Least we got to talk like this. Should get going, but... be seeing you around."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatBecomingCloser01"
    }
    {
      Id = "MelinoeField_3624"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Even it all out... well if we're to make ourselves comfortable and stay quiet, then your armor {#Emph}has {#Prev}to go. Why don't I lend a hand with that, and then we'll go from there?"
      Speaker = "Melinoe"
      Event = "NemesisPostCombatBecomingCloser01"
    }
    {
      Id = "MelinoeField_3625"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Well your armor's definitely harder to put back on, but we got there. You all right, Nem? The distraction gone away at least...?"
      Speaker = "Melinoe"
      Event = "NemesisPostCombatBecomingCloser01"
    }
    {
      Id = "NemesisField_0451"
      InheritFrom = "BaseNarrative"
      DisplayName = "Think so, and yeah, I'm better now. I'm good. What about you, are you... I mean..."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatBecomingCloser01"
    }
    {
      Id = "MelinoeField_3626"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm also good! This was a thrill...! We ought be on assignment, not alleviating solitude, but... you'd know better than anyone whether this was too much."
      Speaker = "Melinoe"
      Event = "NemesisPostCombatBecomingCloser01"
    }
    {
      Id = "NemesisField_0452"
      InheritFrom = "BaseNarrative"
      DisplayName = "Was just enough for now. Should get going, though could always do this again should the need arise."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatBecomingCloser01"
    }
    {
      Id = "MelinoeField_1968"
      InheritFrom = "BaseNarrative"
      DisplayName = "All of this water must be quite a nuisance in your suit. Not found another pathway down, have you?"
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutOceanus01"
    }
    {
      Id = "NemesisField_0429"
      InheritFrom = "BaseNarrative"
      DisplayName = "Only other path is through Elysium, and that's not happening for you or me. What better way for Chronos to show he's in charge than to seal off the Underworld for good?"
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutOceanus01"
    }
    {
      Id = "MelinoeField_1969"
      InheritFrom = "BaseNarrative"
      DisplayName = "Good thing he missed a spot. Although he realizes now that we're using this path. That I am using it, at least."
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutOceanus01"
    }
    {
      Id = "NemesisField_0430"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thanks for the tip! No wonder the fish are biting. Anyway, I'm off. This suit isn't supposed to rust, but just in case."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutOceanus01"
    }
    {
      Id = "MelinoeField_0020"
      InheritFrom = "BaseNarrative"
      DisplayName = "Have you been able to get past Scylla and her Siren friends? Just once I'd like to pass through and not have to hear their song..."
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutScylla01"
    }
    {
      Id = "NemesisField_0019"
      InheritFrom = "BaseNarrative"
      DisplayName = "They know better than to mess with me. Wait, you've been {#Emph}fighting {#Prev}them? How'd you make enemies with a musical act?"
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutScylla01"
    }
    {
      Id = "MelinoeField_0021"
      InheritFrom = "BaseNarrative"
      DisplayName = "I... can't entirely be sure. But they've been very hostile to me."
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutScylla01"
    }
    {
      Id = "NemesisField_0020"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Can't imagine why."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutScylla01"
    }
    {
      Id = "MelinoeField_0760"
      InheritFrom = "BaseNarrative"
      DisplayName = "Across the Fields of Mourning, where the path descends to Tartarus... the monstrous creature there... do you know what it is?"
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutCerberus01"
    }
    {
      Id = "NemesisField_0021"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's a problem. Can't always find my way to it, and even when I do, that thing forces me back. But don't worry; got my eye on it."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutCerberus01"
    }
    {
      Id = "NemesisField_0425"
      InheritFrom = "BaseNarrative"
      DisplayName = "Tell me something, and don't you dare mock me or you'll regret it: How do I... get into Tartarus. Managed to make it through the Fields, then hit a dead end. Kept hitting it."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutTartarus01"
    }
    {
      Id = "MelinoeField_1966"
      InheritFrom = "BaseNarrative"
      DisplayName = "Tartarus is sealed off. The only reason I'm able to get in is because not even Chronos can take away my birthright and divine authority over the place. Although if not for Headmistress, I wouldn't have known how to use it."
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutTartarus01"
    }
    {
      Id = "NemesisField_0426"
      InheritFrom = "BaseNarrative"
      DisplayName = "No help at all, forget I even asked. Got to be some other way inside, and if not, just have to make one I guess. For now, enjoy the lack of competition while you can."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutTartarus01"
    }
    {
      Id = "MelinoeField_3676"
      InheritFrom = "BaseNarrative"
      DisplayName = "Any progress locating a means to enter Tartarus? I'd transfer you my birthright if I could under the circumstances, though I'm reasonably certain that's not possible."
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutTartarus02"
    }
    {
      Id = "NemesisField_0455"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got my own birthright, thanks. And yeah, been making progress. Three-headed monster near the maintenance access point to Tartarus... it digs up through the ground."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutTartarus02"
    }
    {
      Id = "MelinoeField_3677"
      InheritFrom = "BaseNarrative"
      DisplayName = "You plan to get into the lowest reaches of the Underworld through the hell-hole that beast leaves behind? You know that's Cerberus, my father's dog, don't you?"
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutTartarus02"
    }
    {
      Id = "NemesisField_0456"
      InheritFrom = "BaseNarrative"
      DisplayName = "All the more reason that tunnel's going to lead me right where I need to be, one of these nights. Mark my words."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutTartarus02"
    }
    {
      Id = "MelinoeField_3678"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Consider them marked..."
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutTartarus02"
    }
    {
      Id = "NemesisField_0457"
      InheritFrom = "BaseNarrative"
      DisplayName = "Told you I'd make it all this way. Nice place your father's got. Though I guess Chronos since refurbished everything."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutTartarus03"
    }
    {
      Id = "MelinoeField_3679"
      InheritFrom = "BaseNarrative"
      DisplayName = "Congratulations on infiltrating the lowest reaches, Nemesis. And if you've been drawing out some of our enemy's forces, all the better; plenty to go around. Reached Chronos yet?"
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutTartarus03"
    }
    {
      Id = "NemesisField_0458"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got to what has to be the House of Hades, but you know what? They wouldn't let me in. Tried knocking, tried smashing down the door, no good. So Charon took me back."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutTartarus03"
    }
    {
      Id = "MelinoeField_3680"
      InheritFrom = "BaseNarrative"
      DisplayName = "You got Charon to take you on his boat? He's never once permitted me!"
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutTartarus03"
    }
    {
      Id = "NemesisField_0459"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Guess you just don't have the birthright for it, Princess."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutTartarus03"
    }
    {
      Id = "MelinoeField_3681"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}...Ah."
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutTartarus03"
    }
    {
      Id = "NemesisField_0477"
      InheritFrom = "BaseNarrative"
      DisplayName = "Knew you weren't finished, and you know what? Neither am I. Whatever it is you're doing now, I'm not being left out."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatPostTrueEnding01"
    }
    {
      Id = "MelinoeField_4081"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sure! Just have a chat with Headmistress or Grandfather Chronos and they'll fill you in on everything we're up to now."
      Speaker = "Melinoe"
      Event = "NemesisPostCombatPostTrueEnding01"
    }
    {
      Id = "NemesisField_0478"
      InheritFrom = "BaseNarrative"
      DisplayName = "Right. Meantime, anybody asks, I'm just out to stretch my legs and keep my sword arm in top form."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatPostTrueEnding01"
    }
    {
      Id = "MelinoeField_0761"
      InheritFrom = "BaseNarrative"
      DisplayName = "You must have thought you would have taken Chronos down by now. Have you even seen him? Gotten anywhere near my father's House?"
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutChronos01"
    }
    {
      Id = "NemesisField_0017"
      InheritFrom = "BaseNarrative"
      DisplayName = "Keep hitting snags along the way. The pathways down to Tartarus have changed a lot. Especially once you get to the Fields."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutChronos01"
    }
    {
      Id = "MelinoeField_0762"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have a sense for where we need to go. I'd suggest we proceed together had Headmistress not strictly forbidden it."
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutChronos01"
    }
    {
      Id = "NemesisField_0018"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not happening, no matter what she says. Doing this alone. Better odds that way anyway."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutChronos01"
    }
    {
      Id = "MelinoeField_1211"
      InheritFrom = "BaseNarrative"
      DisplayName = "Doesn't all that heavy armor slow you down? Can't be too comfortable, especially around the waist."
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutArmor01"
    }
    {
      Id = "NemesisField_0014"
      InheritFrom = "BaseNarrative"
      DisplayName = "Can't be too comfortable is right. Besides, not everybody wants to run half-naked into battle."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutArmor01"
    }
    {
      Id = "MelinoeField_1212"
      InheritFrom = "BaseNarrative"
      DisplayName = "You really ought to try running half-naked into battle. You might like it!"
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutArmor01"
    }
    {
      Id = "NemesisField_0015"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Rather be invulnerable, thanks."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutArmor01"
    }
    {
      Id = "NemesisField_0427"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Damn {#Prev}it! How many times you going to take my Gold? Rules of this wager might be too much in your favor after all."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutLosing01"
    }
    {
      Id = "MelinoeField_1967"
      InheritFrom = "BaseNarrative"
      DisplayName = "You set the rules of this wager yourself. You'd never go easy on me, would you, Nem? Though you can't bring yourself to make things overly unfair for me, either."
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutLosing01"
    }
    {
      Id = "NemesisField_0428"
      InheritFrom = "BaseNarrative"
      DisplayName = "Beginning to think it might be a weakness of mine. Well, go buy yourself something nice, Princess. Don't need to hear more metal clinking around every step I take anyway."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutLosing01"
    }
    {
      Id = "NemesisField_0022"
      InheritFrom = "BaseNarrative"
      DisplayName = "First wager in a while. Been busy up top, breathing surface air? Thought maybe you came to your senses and left things to me."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutSurface01"
    }
    {
      Id = "MelinoeField_1213"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, I'm not finished here by any means. And evidently neither are you. Still at it like before? Quite difficult, I know."
      Speaker = "Melinoe"
      Event = "NemesisPostCombatAboutSurface01"
    }
    {
      Id = "NemesisField_0023"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, shut up."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutSurface01"
    }
    {
      Id = "NemesisField_0196"
      InheritFrom = "BaseNarrative"
      DisplayName = "Quit stalling. Sooner you fail, sooner I'll get to show you how it's done."
      Speaker = "Nemesis"
      Event = "NemesisPostCombatAboutFailure01"
    }
    {
      Id = "NemesisField_0041"
      InheritFrom = "BaseNarrative"
      DisplayName = "Look at all this business you drummed up, Charon."
      Speaker = "Nemesis"
      Event = "NemesisShopping01"
    }
    {
      Id = "NemesisField_0042"
      InheritFrom = "BaseNarrative"
      DisplayName = "Can't you see my brother and I are in the middle of something?"
      Speaker = "Nemesis"
      Event = "NemesisShopping02"
    }
    {
      Id = "NemesisField_0043"
      InheritFrom = "BaseNarrative"
      DisplayName = "Leave me alone, trying to make a trade."
      Speaker = "Nemesis"
      Event = "NemesisShopping03"
    }
    {
      Id = "NemesisField_0044"
      InheritFrom = "BaseNarrative"
      DisplayName = "Get in line. I was here first."
      Speaker = "Nemesis"
      Event = "NemesisShopping04"
    }
    {
      Id = "NemesisField_0326"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Go home to Hecate, I'll handle it from here."
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisDeathReactionVoiceLines"
    }
    {
      Id = "NemesisField_0327"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Always said you don't have what it takes."
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisDeathReactionVoiceLines"
    }
    {
      Id = "NemesisField_0328"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Don't let me hear you blame the Fates for this."
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisDeathReactionVoiceLines"
    }
    {
      Id = "NemesisField_0329"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thought you'd take more punishment than that."
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisDeathReactionVoiceLines"
    }
    {
      Id = "NemesisField_0330"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Got what was coming to you; I should know."
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisDeathReactionVoiceLines"
    }
    {
      Id = "NemesisField_0331"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Was all a bit too much for you, poor thing."
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisDeathReactionVoiceLines"
    }
    {
      Id = "NemesisField_0332"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We're all supposed to be counting on you?"
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisDeathReactionVoiceLines"
    }
    {
      Id = "NemesisField_0333"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come on, you could have done better than that."
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisDeathReactionVoiceLines"
    }
    {
      Id = "NemesisField_0334"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Go, get your scrawny ass out of here."
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisDeathReactionVoiceLines"
    }
    {
      Id = "NemesisField_0335"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You never could handle the pressure you know."
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisDeathReactionVoiceLines"
    }
    {
      Id = "NemesisField_0402"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Good for you."
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisGatherReactionVoiceLines"
    }
    {
      Id = "NemesisField_0403"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thank the Fates."
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisGatherReactionVoiceLines"
    }
    {
      Id = "NemesisField_0404"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How fortunate for you."
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisGatherReactionVoiceLines"
    }
    {
      Id = "NemesisField_0405"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well deserved."
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisGatherReactionVoiceLines"
    }
    {
      Id = "NemesisField_0406"
      InheritFrom = "BaseSubtitle"
      DisplayName = "So what."
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisGatherReactionVoiceLines"
    }
    {
      Id = "NemesisField_0407"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What you need that for?"
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisGatherReactionVoiceLines"
    }
    {
      Id = "NemesisField_0418"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Lucky you."
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisGatherReactionVoiceLines"
    }
    {
      Id = "NemesisField_0419"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Great."
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisGatherReactionVoiceLines"
    }
    {
      Id = "NemesisField_0420"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Wow."
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisGatherReactionVoiceLines"
    }
    {
      Id = "NemesisField_0421"
      InheritFrom = "BaseSubtitle"
      DisplayName = "So what."
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisGatherReactionVoiceLines"
    }
    {
      Id = "NemesisField_0414"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Kidding me?"
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisGatherReactionVoiceLines"
    }
    {
      Id = "NemesisField_0415"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Get in the fight!"
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisGatherReactionVoiceLines"
    }
    {
      Id = "NemesisField_0416"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What are you doing?"
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisGatherReactionVoiceLines"
    }
    {
      Id = "NemesisField_0417"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Fight back!"
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisGatherReactionVoiceLines"
    }
    {
      Id = "NemesisField_0408"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Why bother."
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisExorcismReactionVoiceLines"
    }
    {
      Id = "NemesisField_0409"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Another Shade to watch."
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisExorcismReactionVoiceLines"
    }
    {
      Id = "NemesisField_0410"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What did you do."
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisExorcismReactionVoiceLines"
    }
    {
      Id = "NemesisField_0411"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How touching."
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisExorcismReactionVoiceLines"
    }
    {
      Id = "NemesisField_0412"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What's the use."
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisExorcismReactionVoiceLines"
    }
    {
      Id = "NemesisField_0413"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Dead weight."
      Speaker = "Nemesis"
      Event = "GlobalVoiceLines.NemesisExorcismReactionVoiceLines"
    }
  ]
}
