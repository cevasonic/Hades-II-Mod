      Event = "NPC_Nemesis_01.InteractVoiceLines"
    }
    {
      Id = "Nemesis_0124"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}<Sigh>"
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.InteractVoiceLines"
    }
    {
      Id = "Nemesis_0125"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hrm."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.InteractVoiceLines"
    }
    {
      Id = "Nemesis_0164"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Get lost."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.InteractVoiceLines"
    }
    {
      Id = "Nemesis_0471"
      InheritFrom = "BaseSubtitle"
      DisplayName = "He's gone."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.InteractVoiceLines"
    }
    {
      Id = "Nemesis_0472"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yeah, you too."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.InteractVoiceLines"
    }
    {
      Id = "Nemesis_0293"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hey."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.InteractVoiceLines"
    }
    {
      Id = "Nemesis_0295"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Leave it to me..."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.InteractVoiceLines"
    }
    {
      Id = "Nemesis_0297"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Same."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.InteractVoiceLines"
    }
    {
      Id = "Nemesis_0299"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Please."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.InteractVoiceLines"
    }
    {
      Id = "Nemesis_0473"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Might as well."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.InteractVoiceLines"
    }
    {
      Id = "MelinoeField_0037"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What's she doing here?"
      Speaker = "Melinoe"
      Event = "NPC_Nemesis_01.SpawnVoiceLines"
    }
    {
      Id = "NemesisField_0232"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Beware the evil eye."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.SpawnVoiceLines"
    }
    {
      Id = "NemesisField_0233"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just in time."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.SpawnVoiceLines"
    }
    {
      Id = "NemesisField_0234"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Gonna handle this."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.SpawnVoiceLines"
    }
    {
      Id = "NemesisField_0235"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How about a friendly wager."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.SpawnVoiceLines"
    }
    {
      Id = "NemesisField_0236"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Care for a little wager here?"
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.SpawnVoiceLines"
    }
    {
      Id = "NemesisField_0237"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Bet I'll take more of them than you."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.SpawnVoiceLines"
    }
    {
      Id = "NemesisField_0238"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Stand back or else."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.SpawnVoiceLines"
    }
    {
      Id = "NemesisField_0239"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Think you'll take more than me?"
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.SpawnVoiceLines"
    }
    {
      Id = "NemesisField_0240"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just stay out of my way."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.SpawnVoiceLines"
    }
    {
      Id = "NemesisField_0241"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Still think you can beat me?"
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.SpawnVoiceLines"
    }
    {
      Id = "NemesisField_0242"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Think you're better, prove it."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.SpawnVoiceLines"
    }
    {
      Id = "NemesisField_0243"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Beat me here, can have my Gold."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.SpawnVoiceLines"
    }
    {
      Id = "NemesisField_0244"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I slay more, I get your Gold."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.SpawnVoiceLines"
    }
    {
      Id = "NemesisField_0245"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Get set to fight, or get out of the way."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.SpawnVoiceLines"
    }
    {
      Id = "NemesisField_0246"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Good, could use more Gold."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.SpawnVoiceLines"
    }
    {
      Id = "NemesisField_0247"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Had a feeling you'd show up."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.SpawnVoiceLines"
    }
    {
      Id = "NemesisField_0537"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Surprise."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.SpawnVoiceLines"
    }
    {
      Id = "NemesisField_0248"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Heads up."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.EncounterStartVoiceLines"
    }
    {
      Id = "NemesisField_0249"
      InheritFrom = "BaseSubtitle"
      DisplayName = "There they are."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.EncounterStartVoiceLines"
    }
    {
      Id = "NemesisField_0250"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come on out..."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.EncounterStartVoiceLines"
    }
    {
      Id = "NemesisField_0251"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Here we go."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.EncounterStartVoiceLines"
    }
    {
      Id = "NemesisField_0252"
      InheritFrom = "BaseSubtitle"
      DisplayName = "About damn time."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.EncounterStartVoiceLines"
    }
    {
      Id = "NemesisField_0253"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Watch this."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.EncounterStartVoiceLines"
    }
    {
      Id = "NemesisField_0254"
      InheritFrom = "BaseSubtitle"
      DisplayName = "They're in for it."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.EncounterStartVoiceLines"
    }
    {
      Id = "NemesisField_0255"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Finally..."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.EncounterStartVoiceLines"
    }
    {
      Id = "NemesisField_0256"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Been waiting for this."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.EncounterStartVoiceLines"
    }
    {
      Id = "NemesisField_0257"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Let's get started."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.EncounterStartVoiceLines"
    }
    {
      Id = "NemesisField_0258"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Let's see how quick you are."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.EncounterStartVoiceLines"
    }
    {
      Id = "NemesisField_0259"
      InheritFrom = "BaseSubtitle"
      DisplayName = "They had this coming."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.EncounterStartVoiceLines"
    }
    {
      Id = "NemesisField_0260"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come on in."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.EncounterStartVoiceLines"
    }
    {
      Id = "NemesisField_0261"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Here comes the reckoning."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.EncounterStartVoiceLines"
    }
    {
      Id = "NemesisField_0262"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll make them come around."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.EncounterStartVoiceLines"
    }
    {
      Id = "NemesisField_0263"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Make yourself useful."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.EncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_0040"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I see them."
      Speaker = "Melinoe"
      Event = "NPC_Nemesis_01.EncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_0041"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just fight."
      Speaker = "Melinoe"
      Event = "NPC_Nemesis_01.EncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_0042"
      InheritFrom = "BaseSubtitle"
      DisplayName = "So impatient..."
      Speaker = "Melinoe"
      Event = "NPC_Nemesis_01.EncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_0043"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just watch."
      Speaker = "Melinoe"
      Event = "NPC_Nemesis_01.EncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_0044"
      InheritFrom = "BaseSubtitle"
      DisplayName = "One of us will."
      Speaker = "Melinoe"
      Event = "NPC_Nemesis_01.EncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_0045"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Focus on yourself."
      Speaker = "Melinoe"
      Event = "NPC_Nemesis_01.EncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_0046"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Then let's {#Emph}go!"
      Speaker = "Melinoe"
      Event = "NPC_Nemesis_01.EncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_0047"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come on, then!"
      Speaker = "Melinoe"
      Event = "NPC_Nemesis_01.EncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_0048"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Race you."
      Speaker = "Melinoe"
      Event = "NPC_Nemesis_01.EncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_0049"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Let's see it, Nem!"
      Speaker = "Melinoe"
      Event = "NPC_Nemesis_01.EncounterStartVoiceLines"
    }
    {
      Id = "Nemesis_0002"
      InheritFrom = "BaseNarrative"
      DisplayName = "Already hit a wall! Knocked your scrawny ass all the way back here. It's insane that she's sending you out on foot, all on your own."
      Speaker = "Nemesis"
      Event = "NemesisFirstMeeting"
    }
    {
      Id = "Melinoe_0077"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're fortunate you have even {#Emph}this {#Prev}responsibility, for all your questioning of orders and complaining."
      Speaker = "Melinoe"
      Event = "NemesisFirstMeeting"
    }
    {
      Id = "Nemesis_0458"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, shut up."
      Speaker = "Nemesis"
      Event = "NemesisFirstMeeting"
    }
    {
      Id = "Nemesis_0034"
      InheritFrom = "BaseNarrative"
      DisplayName = "They're not going to help you, you know. The Fates, I mean. They don't take pity on whoever asks. If anything, you'll make things even worse."
      Speaker = "Nemesis"
      Event = "NemesisAboutFates01"
    }
    {
      Id = "Melinoe_1541"
      InheritFrom = "BaseNarrative"
      DisplayName = "Maybe you just don't give your sisters enough credit. If they once aided my brother, then there has to be a chance they'll aid us. They have a stake in this, too."
      Speaker = "Melinoe"
      Event = "NemesisAboutFates01"
    }
    {
      Id = "Nemesis_0035"
      InheritFrom = "BaseNarrative"
      DisplayName = "What, you mean their {#Emph}family? {#Prev}They couldn't care less. Too busy messing with everybody's lives, making it look like an accident."
      Speaker = "Nemesis"
      Event = "NemesisAboutFates01"
    }
    {
      Id = "Melinoe_1542"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You mustn't speak of them that way."
      Speaker = "Melinoe"
      Event = "NemesisAboutFates01"
    }
    {
      Id = "Nemesis_0036"
      InheritFrom = "BaseNarrative"
      DisplayName = "Can't believe sucking up to the Fates actually worked. That big scroll over there... that's really from them?"
      Speaker = "Nemesis"
      Event = "NemesisAboutMoros01"
    }
    {
      Id = "Melinoe_1543"
      InheritFrom = "BaseNarrative"
      DisplayName = "Personally delivered by Lord Moros, no less. He seemed a little pressed for time, so we didn't get to talk much. Are the two of you close?"
      Speaker = "Melinoe"
      Event = "NemesisAboutMoros01"
    }
    {
      Id = "Nemesis_0037"
      InheritFrom = "BaseNarrative"
      DisplayName = "We're children of Nyx; none of us are close. But we crossed paths. When certain mortals get what they deserve, it involves us both."
      Speaker = "Nemesis"
      Event = "NemesisAboutMoros01"
    }
    {
      Id = "Melinoe_1544"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I can only imagine."
      Speaker = "Melinoe"
      Event = "NemesisAboutMoros01"
    }
    {
      Id = "Nemesis_0038"
      InheritFrom = "BaseNarrative"
      DisplayName = "Never thought I'd see Moros here of all places. But then again, it only makes sense Doom would come to the Crossroads sooner or later."
      Speaker = "Nemesis"
      Event = "NemesisAboutMoros02"
    }
    {
      Id = "Melinoe_1545"
      InheritFrom = "BaseNarrative"
      DisplayName = "You make it sound like it's a {#Emph}bad {#Prev}thing. All Nyx's kin are welcome here. Headmistress gave her word."
      Speaker = "Melinoe"
      Event = "NemesisAboutMoros02"
    }
    {
      Id = "Nemesis_0039"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Whatever. Guess I better go say hello..."
      Speaker = "Nemesis"
      Event = "NemesisAboutMoros02"
    }
    {
      Id = "Melinoe_2234"
      InheritFrom = "BaseNarrative"
      DisplayName = "Strictly business between you and Lord Charon, isn't it? Never seen you speak except about his wares. At least you're providing him with Gold."
      Speaker = "Melinoe"
      Event = "NemesisAboutCharon01"
    }
    {
      Id = "Nemesis_0133"
      InheritFrom = "BaseNarrative"
      DisplayName = "You might technically have a brother, but you don't know what it's like having one around. Charon doesn't like to talk; I respect that."
      Speaker = "Nemesis"
      Event = "NemesisAboutCharon01"
    }
    {
      Id = "Melinoe_2235"
      InheritFrom = "BaseNarrative"
      DisplayName = "Truly? He never seems to mind speaking with me, in his way."
      Speaker = "Melinoe"
      Event = "NemesisAboutCharon01"
    }
    {
      Id = "Nemesis_0134"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Maybe it's 'cause you're {#Emph}special."
      Speaker = "Nemesis"
      Event = "NemesisAboutCharon01"
    }
    {
      Id = "Nemesis_0258"
      InheritFrom = "BaseNarrative"
      DisplayName = "So you've been chatting it up with Chaos, of all beings... trying to get the oldest force in the world to take sides? A fundamentally {#Emph}impartial {#Prev}force. Smart."
      Speaker = "Nemesis"
      Event = "NemesisAboutChaos01"
    }
    {
      Id = "Melinoe_3228"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sounds like you've been chatting it up yourself! I saw you plunge into a Chaos Gate, as though you knew exactly where it led. Not your first time?"
      Speaker = "Melinoe"
      Event = "NemesisAboutChaos01"
    }
    {
      Id = "Nemesis_0259"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not your business. Just don't go thinking Chaos is going to help {#Emph}you {#Prev}and no one else. Seeing as that wouldn't be fair."
      Speaker = "Nemesis"
      Event = "NemesisAboutChaos01"
    }
    {
      Id = "Melinoe_3229"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I suppose not."
      Speaker = "Melinoe"
      Event = "NemesisAboutChaos01"
    }
    {
      Id = "Nemesis_0042"
      InheritFrom = "BaseNarrative"
      DisplayName = "Let me guess. The Fates have nothing but a bunch of busywork laid out for you. No grand revelations, just odd jobs."
      Speaker = "Nemesis"
      Event = "NemesisAboutQuestLog01"
    }
    {
      Id = "Melinoe_1546"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know better than to question their designs. A minor prophecy fulfilled may result in a greater one coming to pass."
      Speaker = "Melinoe"
      Event = "NemesisAboutQuestLog01"
    }
    {
      Id = "Nemesis_0043"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just keep telling yourself that."
      Speaker = "Nemesis"
      Event = "NemesisAboutQuestLog01"
    }
    {
      Id = "Nemesis_0044"
      InheritFrom = "BaseNarrative"
      DisplayName = "We're getting nowhere. I should be out there fighting! Not standing watch over a place nobody comes to uninvited. Damn it..."
      Speaker = "Nemesis"
      Event = "NemesisAboutTask01"
    }
    {
      Id = "Melinoe_0679"
      InheritFrom = "BaseNarrative"
      DisplayName = "I think the circumstances justify heightened security around here. But if you don't, go take it up with the Headmistress, not me."
      Speaker = "Melinoe"
      Event = "NemesisAboutTask01"
    }
    {
      Id = "Nemesis_0045"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ugh..."
      Speaker = "Nemesis"
      Event = "NemesisAboutTask01"
    }
    {
      Id = "Nemesis_0048"
      InheritFrom = "BaseNarrative"
      DisplayName = "You don't deserve this. Any of this. It's unfair. But you're stuck with it. So the only question is, what are you going to do about it now?"
      Speaker = "Nemesis"
      Event = "NemesisAboutTask02"
    }
    {
      Id = "Melinoe_3930"
      InheritFrom = "BaseNarrative"
      DisplayName = "You'll soon find out! Though, how can you be so sure I don't deserve what's happening or that it isn't fair?"
      Speaker = "Melinoe"
      Event = "NemesisAboutTask02"
    }
    {
      Id = "Nemesis_0049"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hah! {#Prev}You almost had me going there."
      Speaker = "Nemesis"
      Event = "NemesisAboutTask02"
    }
    {
      Id = "Nemesis_0050"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't worry, you didn't miss much while you were out. Lot of standing around, chanting prayers for your victory and protection. How'd those work out for you, by the way?"
      Speaker = "Nemesis"
      Event = "NemesisAboutTask03"
    }
    {
      Id = "Melinoe_1549"
      InheritFrom = "BaseNarrative"
      DisplayName = "Fine, thanks. And your own lack of support is a more significant motivator than you realize."
      Speaker = "Melinoe"
      Event = "NemesisAboutTask03"
    }
    {
      Id = "Nemesis_0051"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You know all about lack of support..."
      Speaker = "Nemesis"
      Event = "NemesisAboutTask03"
    }
    {
      Id = "Nemesis_0081"
      InheritFrom = "BaseNarrative"
      DisplayName = "How many attempts was that now? Good thing our Titan friend's too busy with your topside relatives to pay you much attention."
      Speaker = "Nemesis"
      Event = "NemesisAboutTask04"
    }
    {
      Id = "Melinoe_1568"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sorry, not been keeping count. I'll get there when I get there. Though surely {#Emph}you {#Prev}would have vanquished the Titan Lord on your very first go?"
      Speaker = "Melinoe"
      Event = "NemesisAboutTask04"
    }
    {
      Id = "Nemesis_0082"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Guess we'll never know, will we?"
      Speaker = "Nemesis"
      Event = "NemesisAboutTask04"
    }
    {
      Id = "Nemesis_0046"
      InheritFrom = "BaseNarrative"
      DisplayName = "I always thought... if I could just train harder than you, she'd reconsider. And give the task to me. Worked my ass off. But it didn't matter."
      Speaker = "Nemesis"
      Event = "NemesisAboutTraining01"
    }
    {
      Id = "Melinoe_1547"
      InheritFrom = "BaseNarrative"
      DisplayName = "I worked, too. And Headmistress always made herself clear about our roles. You can't change your birthright, nor can I change mine."
      Speaker = "Melinoe"
      Event = "NemesisAboutTraining01"
    }
    {
      Id = "Nemesis_0047"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It isn't fair..."
      Speaker = "Nemesis"
      Event = "NemesisAboutTraining01"
    }
    {
      Id = "Nemesis_0077"
      InheritFrom = "BaseNarrative"
      DisplayName = "The hell are you doing talking to me? You get your scrawny ass back {#Emph}out {#Prev}there, and get that Titan! What are you waiting for?"
      Speaker = "Nemesis"
      Event = "NemesisAboutWaiting01"
    }
    {
      Id = "Melinoe_1567"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Rude!"
      Speaker = "Melinoe"
      Event = "NemesisAboutWaiting01"
    }
    {
      Id = "Nemesis_0052"
      InheritFrom = "BaseNarrative"
      DisplayName = "Another failed attempt. About ready to give in? You don't have the fire. This isn't personal enough for you."
      Speaker = "Nemesis"
      Event = "NemesisAboutFamily01"
    }
    {
      Id = "Melinoe_1550"
      InheritFrom = "BaseNarrative"
      DisplayName = "Isn't {#Emph}personal? {#Prev}You don't see my mother around, either, do you, Nem? Nor my father, nor my brother. Chronos took them all!"
      Speaker = "Melinoe"
      Event = "NemesisAboutFamily01"
    }
    {
      Id = "Nemesis_0053"
      InheritFrom = "BaseNarrative"
      DisplayName = "I lost more than my mother, too. And I {#Emph}knew {#Prev}mine. What's yours to {#Emph}you? {#Prev}All you ever did was fall out of her womb."
      Speaker = "Nemesis"
      Event = "NemesisAboutFamily01"
    }
    {
      Id = "Melinoe_1551"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Silence."
      Speaker = "Melinoe"
      Event = "NemesisAboutFamily01"
    }
    {
      Id = "Melinoe_0602"
      InheritFrom = "BaseNarrative"
      DisplayName = "What you said to me before, about my mother. That was very cruel."
      Speaker = "Melinoe"
      Event = "NemesisAboutFamily02"
    }
    {
      Id = "Nemesis_0054"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hm{#Prev}. Fair enough. Can't kill each other here, but we can use our words. If we were fighting for real I wouldn't have held back, either."
      Speaker = "Nemesis"
      Event = "NemesisAboutFamily02"
    }
    {
      Id = "Melinoe_0603"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I figured not."
      Speaker = "Melinoe"
      Event = "NemesisAboutFamily02"
    }
    {
      Id = "Nemesis_0412"
      InheritFrom = "BaseNarrative"
      DisplayName = "How were they, anyway? Your family. Persephone the Queen, Prince Zagreus, whoever else. He doesn't want this blade back yet, does he?"
      Speaker = "Nemesis"
      Event = "NemesisAboutFamily03"
    }
    {
      Id = "Melinoe_5251"
      InheritFrom = "BaseNarrative"
      DisplayName = "He hasn't mentioned it, he's... I don't know, I like him quite a bit. Perhaps since I haven't been around him for aeons as with siblings from certain other families I've met. And my mother and father, they're... all that I imagined, I suppose."
      Speaker = "Melinoe"
      Event = "NemesisAboutFamily03"
    }
    {
      Id = "Nemesis_0413"
      InheritFrom = "BaseNarrative"
      DisplayName = "Right. Probably because your imagination's filling in a lot of blanks. But, least you found them, and it's off to a good start. Not to be taken for granted."
      Speaker = "Nemesis"
      Event = "NemesisAboutFamily03"
    }
    {
      Id = "Melinoe_5252"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not at all."
      Speaker = "Melinoe"
      Event = "NemesisAboutFamily03"
    }
    {
      Id = "Nemesis_0249"
      InheritFrom = "BaseNarrative"
      DisplayName = "They're saying you got all the way to Tartarus before. How far'd you get? Make it all the way back to your {#Emph}rightful home?"
      Speaker = "Nemesis"
      Event = "NemesisAboutChronosBossL02"
    }
    {
      Id = "Melinoe_3223"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you're referring to the House of Hades, then yes, I did make it there. Though you could best describe it as the House of {#Emph}Chronos{#Prev}, at this point. He was waiting within, just as expected, and... was strong, just as expected, too."
      Speaker = "Melinoe"
      Event = "NemesisAboutChronosBossL02"
    }
    {
      Id = "Nemesis_0250"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Too {#Prev}strong, you mean. Well, can't fault you for trying. So what's the plan now, keep throwing yourself at him till you're totally demoralized? If that hasn't happened already?"
      Speaker = "Nemesis"
      Event = "NemesisAboutChronosBossL02"
    }
    {
      Id = "Melinoe_3224"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The task remains the same."
      Speaker = "Melinoe"
      Event = "NemesisAboutChronosBossL02"
    }
    {
      Id = "Nemesis_0251"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Fair enough!"
      Speaker = "Nemesis"
      Event = "NemesisAboutChronosBossL02"
    }
    {
      Id = "Nemesis_0224"
      InheritFrom = "BaseNarrative"
      DisplayName = "Can't believe you got to Chronos before me. Knew you stood no chance against him, but... didn't think you'd get there at all anytime soon."
      Speaker = "Nemesis"
      Event = "NemesisAboutChronosBossL01"
    }
    {
      Id = "Melinoe_3098"
      InheritFrom = "BaseNarrative"
      DisplayName = "Is that supposed to be some sort of compliment? Or an apology, perhaps?"
      Speaker = "Melinoe"
      Event = "NemesisAboutChronosBossL01"
    }
    {
      Id = "Nemesis_0225"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No."
      Speaker = "Nemesis"
      Event = "NemesisAboutChronosBossL01"
    }
    {
      Id = "Nemesis_0226"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come here to gloat, {#Emph}huh. I beat him! I beat the Titan! {#Prev}Well, hardly matters. He's still alive, you realize, don't you?"
      Speaker = "Nemesis"
      Event = "NemesisAboutChronosBossW01"
    }
    {
      Id = "Melinoe_2965"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wasn't coming here to gloat, and yes, I realize. But this is still a step. If I could vanquish Chronos once, I can do it again. And one of these nights... he's not going to come back."
      Speaker = "Melinoe"
      Event = "NemesisAboutChronosBossW01"
    }
    {
      Id = "Nemesis_0227"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yeah. 'Cause one of these nights, I'll get my hands on him myself."
      Speaker = "Nemesis"
      Event = "NemesisAboutChronosBossW01"
    }
    {
      Id = "Melinoe_2966"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Then you can do the gloating, right?"
      Speaker = "Melinoe"
      Event = "NemesisAboutChronosBossW01"
    }
    {
      Id = "Nemesis_0252"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ought to admit it when I'm wrong. Never thought you'd get to Chronos in the first place, before I did anyway. Much less beat him down, repeatedly. So — I was wrong. Sorry."
      Speaker = "Nemesis"
      Event = "NemesisAboutChronosBossFights01"
    }
    {
      Id = "Melinoe_3225"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nemesis, I want you to know it was astonishing to hear those words coming from you just now. It seems we're each more than capable of surprising the other. But mainly... thank you."
      Speaker = "Melinoe"
      Event = "NemesisAboutChronosBossFights01"
    }
    {
      Id = "Nemesis_0253"
      InheritFrom = "BaseNarrative"
      DisplayName = "No need. Fair is fair. Had my chances to catch up with you, but couldn't get through all the pitfalls in the way. Might be I could have taken Chronos, too. But now I'm not so sure."
      Speaker = "Nemesis"
      Event = "NemesisAboutChronosBossFights01"
    }
    {
      Id = "Melinoe_3226"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now don't lose heart! There's much left to be done, and we need all your strength and vigilance. We're the Unseen; together we prevail, or we fail."
      Speaker = "Melinoe"
      Event = "NemesisAboutChronosBossFights01"
    }
    {
      Id = "Nemesis_0254"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Couldn't resist giving one of your pep talks, huh."
      Speaker = "Nemesis"
      Event = "NemesisAboutChronosBossFights01"
    }
    {
      Id = "Melinoe_3227"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...No."
      Speaker = "Melinoe"
      Event = "NemesisAboutChronosBossFights01"
    }
    {
      Id = "Nemesis_0308"
      InheritFrom = "BaseNarrative"
      DisplayName = "Can't kill Chronos, can't kill Typhon, so what now? Keep doing this till somebody gives up? Thought we had a better plan."
      Speaker = "Nemesis"
      Event = "NemesisAboutUltimateProgress01"
    }
    {
      Id = "Melinoe_4428"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Titan thinks he took the upper hand by awakening that monster. But we'll turn that setback into our gain. Typhon is immensely powerful; a power we can use."
      Speaker = "Melinoe"
      Event = "NemesisAboutUltimateProgress01"
    }
    {
      Id = "Nemesis_0309"
      InheritFrom = "BaseNarrative"
      DisplayName = "You really think the Titan would just offer up the key to his own undoing like that? Doesn't sound particularly smart."
      Speaker = "Nemesis"
      Event = "NemesisAboutUltimateProgress01"
    }
    {
      Id = "Melinoe_4429"
      InheritFrom = "BaseNarrative"
      DisplayName = "The plan was always to exploit what he doesn't know."
      Speaker = "Melinoe"
      Event = "NemesisAboutUltimateProgress01"
    }
    {
      Id = "Nemesis_0310"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Think he knows a lot more than you."
      Speaker = "Nemesis"
      Event = "NemesisAboutUltimateProgress01"
    }
    {
      Id = "Melinoe_1570"
      InheritFrom = "BaseNarrative"
      DisplayName = "Had one of my dreams, Nem. Your mother was there, and my father. He showed concern for her, she... was under the Titan's spell."
      Speaker = "Melinoe"
      Event = "NemesisAboutChronosNightmare01"
    }
    {
      Id = "Nemesis_0090"
      InheritFrom = "BaseNarrative"
      DisplayName = "Mother Nyx made a mistake entrusting Hades with so much of the Underworld. This realm was never his by right, not till the Fates decided otherwise. Mother worked hard. They were probably just trying to send her help."
      Speaker = "Nemesis"
      Event = "NemesisAboutChronosNightmare01"
    }
    {
      Id = "Melinoe_0621"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're saying the Fates granted my father authority over the realm of the dead just to give Nyx a hand with all her responsibilities?"
      Speaker = "Melinoe"
      Event = "NemesisAboutChronosNightmare01"
    }
    {
      Id = "Nemesis_0091"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's right."
      Speaker = "Nemesis"
      Event = "NemesisAboutChronosNightmare01"
    }
    {
      Id = "Melinoe_0622"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Huh."
      Speaker = "Melinoe"
      Event = "NemesisAboutChronosNightmare01"
    }
    {
      Id = "Melinoe_0623"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nemesis, about the dream I had... Chronos, he... demanded that my father tell him where the Fates reside."
      Speaker = "Melinoe"
      Event = "NemesisAboutChronosNightmare02"
    }
    {
      Id = "Nemesis_0092"
      InheritFrom = "BaseNarrative"
      DisplayName = "Smart. Mother Nyx never would have told him. The Fates may be my sisters but even I have no idea where they are. Long as they're hidden, no one can mess with their designs."
      Speaker = "Nemesis"
      Event = "NemesisAboutChronosNightmare02"
    }
    {
      Id = "Melinoe_1571"
      InheritFrom = "BaseNarrative"
      DisplayName = "You don't sound especially concerned that Chronos apparently found the three weavers of destiny and may be forcing their plans for the future."
      Speaker = "Melinoe"
      Event = "NemesisAboutChronosNightmare02"
    }
    {
      Id = "Nemesis_0093"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Really? {#Prev}I ever give you the impression I had any hope this would end well?"
      Speaker = "Nemesis"
      Event = "NemesisAboutChronosNightmare02"
    }
    {
      Id = "Melinoe_1572"
      InheritFrom = "BaseNarrative"
      DisplayName = "How could he have found them? Wouldn't the Fates see the threat coming?"
      Speaker = "Melinoe"
      Event = "NemesisAboutChronosNightmare02"
    }
    {
      Id = "Nemesis_0094"
      InheritFrom = "BaseNarrative"
      DisplayName = "They're always weaving. That means even they know only so much in advance. Chronos is Time. {#Emph}Time {#Prev}moves faster than expected."
      Speaker = "Nemesis"
      Event = "NemesisAboutChronosNightmare02"
    }
    {
      Id = "Melinoe_5278"
      InheritFrom = "BaseNarrative"
      DisplayName = "You don't sound especially concerned that Chronos somehow found the three weavers of destiny and cast them into exile. And can no longer find them."
      Speaker = "Melinoe"
      Event = "NemesisAboutChronosNightmare02_B"
    }
    {
      Id = "Melinoe_5279"
      InheritFrom = "BaseNarrative"
      DisplayName = "How did he do it...? Wouldn't the Fates see the threat coming?"
      Speaker = "Melinoe"
      Event = "NemesisAboutChronosNightmare02_B"
    }
    {
      Id = "Nemesis_0086"
      InheritFrom = "BaseNarrative"
      DisplayName = "Even Mother Nyx's weapons favor you. Always thought the Nocturnal Arms would wake for me first. Guess the Fates had other ideas."
      Speaker = "Nemesis"
      Event = "NemesisAboutWeapons01"
    }
    {
      Id = "Melinoe_1569"
      InheritFrom = "BaseNarrative"
      DisplayName = "I think the Fates had you covered. You're the bearer of Stygius! Vanquisher of heroes, gods, and Titans."
      Speaker = "Melinoe"
      Event = "NemesisAboutWeapons01"
    }
    {
      Id = "Nemesis_0087"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Seems it was due for a long break."
      Speaker = "Nemesis"
      Event = "NemesisAboutWeapons01"
    }
    {
      Id = "Melinoe_0613"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nem. You care so much for mortal justice. Where's your passion for ours? Chronos took {#Emph}everything {#Prev}from us! You said we all should get what we deserve, right?"
      Speaker = "Melinoe"
      Event = "NemesisAboutGoldenAge01"
    }
    {
      Id = "Nemesis_0083"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Khh. {#Prev}Well, that's the thing. If you knew anything about mortals, they had it better once. When Chronos ruled. Called it the {#Emph}Golden Age."
      Speaker = "Nemesis"
      Event = "NemesisAboutGoldenAge01"
    }
    {
      Id = "Melinoe_2749"
      InheritFrom = "BaseNarrative"
      DisplayName = "How splendid that must have been for them! If only Chronos could have been so generous with his sons and foster-children. You think him being somewhat nice to some mortals makes up for what he did?"
      Speaker = "Melinoe"
      Event = "NemesisAboutGoldenAge01"
    }
    {
      Id = "Nemesis_0084"
      InheritFrom = "BaseNarrative"
      DisplayName = "No. Look. What if... what if this {#Emph}is {#Prev}what we deserve?"
      Speaker = "Nemesis"
      Event = "NemesisAboutGoldenAge01"
    }
    {
      Id = "Melinoe_0615"
      InheritFrom = "BaseNarrative"
      DisplayName = "We deserve better than this, Nemesis. Living in shadows. Denied our families. Don't you want justice for {#Emph}them?"
      Speaker = "Melinoe"
      Event = "NemesisAboutGoldenAge01"
    }
    {
      Id = "Nemesis_0085"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hah."
      Speaker = "Nemesis"
      Event = "NemesisAboutGoldenAge01"
    }
    {
      Id = "Melinoe_0616"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Fine."
      Speaker = "Melinoe"
      Event = "NemesisAboutGoldenAge01"
    }
    {
      Id = "Melinoe_1561"
      InheritFrom = "BaseNarrative"
      DisplayName = "...How long has it been since you've visited the surface?"
      Speaker = "Melinoe"
      Event = "NemesisAboutSurface01"
    }
    {
      Id = "Nemesis_0070"
      InheritFrom = "BaseNarrative"
      DisplayName = "Too long. Cooped up here now in case you hadn't noticed. But, it's a lost cause anyway. Why do you ask?"
      Speaker = "Nemesis"
      Event = "NemesisAboutSurface01"
    }
    {
      Id = "Melinoe_1562"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hermes requested that I pay a visit when I can. Wanted to know what to expect."
      Speaker = "Melinoe"
      Event = "NemesisAboutSurface01"
    }
    {
      Id = "Nemesis_0071"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's like I said. The dead are out and about up there thanks to our Titan friend. You'll feel right at home."
      Speaker = "Nemesis"
      Event = "NemesisAboutSurface01"
    }
    {
      Id = "Melinoe_1563"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Sounds great."
      Speaker = "Melinoe"
      Event = "NemesisAboutSurface01"
    }
    {
      Id = "Melinoe_3211"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hermes requested that I pay a visit when I can. Figured I should ask if you had any notes."
      Speaker = "Melinoe"
      Event = "NemesisAboutSurface01_B"
    }
    {
      Id = "Nemesis_0166"
      InheritFrom = "BaseNarrative"
      DisplayName = "You really went up there. They could have called for somebody with experience, but I guess I don't deserve it as much as I thought."
      Speaker = "Nemesis"
      Event = "NemesisAboutSurface02"
    }
    {
      Id = "Melinoe_1575"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm needed there as part of my task. Though, they must miss you on the surface. So much suffering..."
      Speaker = "Melinoe"
      Event = "NemesisAboutSurface02"
    }
    {
      Id = "Nemesis_0167"
      InheritFrom = "BaseNarrative"
      DisplayName = "Justice doesn't matter anymore. The mortals had it coming. Maybe we all did."
      Speaker = "Nemesis"
      Event = "NemesisAboutSurface02"
    }
    {
      Id = "Melinoe_1576"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Don't say that..."
      Speaker = "Melinoe"
      Event = "NemesisAboutSurface02"
    }
    {
      Id = "Nemesis_0168"
      InheritFrom = "BaseNarrative"
      DisplayName = "You keep heading up when you ought to be heading down, toward your objective. Forget about the mountain. Not your fight."
      Speaker = "Nemesis"
      Event = "NemesisAboutSurface03"
    }
    {
      Id = "Melinoe_0618"
      InheritFrom = "BaseNarrative"
      DisplayName = "My family on Olympus is under assault by the legions of Chronos, and it's not my fight?"
      Speaker = "Melinoe"
      Event = "NemesisAboutSurface03"
    }
    {
      Id = "Nemesis_0169"
      InheritFrom = "BaseNarrative"
      DisplayName = "No. He's down below, all comfy on your father's throne. And you don't have anything to worry about besides him."
      Speaker = "Nemesis"
      Event = "NemesisAboutSurface03"
    }
    {
      Id = "Melinoe_0619"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Sure I don't."
      Speaker = "Melinoe"
      Event = "NemesisAboutSurface03"
    }
    {
      Id = "Melinoe_4424"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why don't I ever see you on the surface, Nem? Surely we have foes deserving your attention there."
      Speaker = "Melinoe"
      Event = "NemesisAboutSurface04"
    }
    {
      Id = "Nemesis_0303"
      InheritFrom = "BaseNarrative"
      DisplayName = "Death to Chronos is the only task. Won't get caught up in the details like you. Each night you spend up in the mountains, the Titan secures his foothold below."
      Speaker = "Nemesis"
      Event = "NemesisAboutSurface04"
    }
    {
      Id = "Melinoe_4425"
      InheritFrom = "BaseNarrative"
      DisplayName = "You don't see how Typhon's reemergence complicates matters? He's not exactly the sort of problem one can ignore for long."
      Speaker = "Melinoe"
      Event = "NemesisAboutSurface04"
    }
    {
      Id = "Nemesis_0304"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Really? Watch me."
      Speaker = "Nemesis"
      Event = "NemesisAboutSurface04"
    }
    {
      Id = "Nemesis_0228"
      InheritFrom = "BaseNarrative"
      DisplayName = "Eris is back. What did you do? Did you summon her? I saw you talking."
      Speaker = "Nemesis"
      Event = "NemesisAboutEris01"
    }
    {
      Id = "Melinoe_3099"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're not remotely pleased to see your sister again? I don't have any more control over her than you do. Headmistress still is giving her the silent treatment, though."
      Speaker = "Melinoe"
      Event = "NemesisAboutEris01"
    }
    {
      Id = "Nemesis_0229"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ideally, Eris should be somewhere very far from here. Good thing this place is impossible to find, otherwise I'd half expect she would have led Chronos straight to us by now."
      Speaker = "Nemesis"
      Event = "NemesisAboutEris01"
    }
    {
      Id = "Melinoe_3100"
      InheritFrom = "BaseNarrative"
      DisplayName = "You truly think a daughter of Nyx would betray us? I know Eris is a different sort, but still."
      Speaker = "Melinoe"
      Event = "NemesisAboutEris01"
    }
    {
      Id = "Nemesis_0230"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your father is a son of Chronos. How'd {#Emph}they {#Prev}get on?"
      Speaker = "Nemesis"
      Event = "NemesisAboutEris01"
    }
    {
      Id = "Melinoe_3101"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...That's fair."
      Speaker = "Melinoe"
      Event = "NemesisAboutEris01"
    }
    {
      Id = "Melinoe_3102"
      InheritFrom = "BaseNarrative"
      DisplayName = "Eris stands against us. Just as I neared my destination on the surface, she was there. Let the Adamant Rail do much of the talking."
      Speaker = "Melinoe"
      Event = "NemesisAboutErisFight01"
    }
    {
      Id = "Nemesis_0231"
      InheritFrom = "BaseNarrative"
      DisplayName = "Imagine my surprise. So what to do? Can't kick her out, since {#Emph}all children of Nyx are welcome here{#Prev}, whosever bright idea that was. Maybe give her some {#Emph}more {#Prev}second chances?"
      Speaker = "Nemesis"
      Event = "NemesisAboutErisFight01"
    }
    {
      Id = "Melinoe_3103"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You've made your point."
      Speaker = "Melinoe"
      Event = "NemesisAboutErisFight01"
    }
    {
      Id = "Melinoe_3220"
      InheritFrom = "BaseNarrative"
      DisplayName = "Isn't there something you can do to talk some sense into Eris? Get her out of my blasted way to Olympus. Or failing that, pin her in an arm bar or leg lock, perhaps?"
      Speaker = "Melinoe"
      Event = "NemesisAboutErisFight02"
    }
    {
      Id = "Nemesis_0247"
      InheritFrom = "BaseNarrative"
      DisplayName = "Won't waste my time with her at all, though the arm bar or leg lock do have a certain appeal. Not seen her flying through the Underworld lately, have you."
      Speaker = "Nemesis"
      Event = "NemesisAboutErisFight02"
    }
    {
      Id = "Melinoe_3221"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not other than these Crossroads. Though what's your point, that I should stay out of her way as well as focus solely on Chronos below? It's not so simple for me anymore."
      Speaker = "Melinoe"
      Event = "NemesisAboutErisFight02"
    }
    {
      Id = "Nemesis_0248"
      InheritFrom = "BaseNarrative"
      DisplayName = "Didn't say it was. But if you don't want to deal with {#Emph}Eris{#Prev}, you could always stick to your main objective. Or just leave it to {#Emph}me{#Prev}, like you should have in the first place."
      Speaker = "Nemesis"
      Event = "NemesisAboutErisFight02"
    }
    {
      Id = "Melinoe_3222"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Duly noted."
      Speaker = "Melinoe"
      Event = "NemesisAboutErisFight02"
    }
    {
      Id = "Nemesis_0244"
      InheritFrom = "BaseNarrative"
      DisplayName = "Showed Eris didn't you. Could hear her crying practically from here. Been far too long since last I kicked her ass myself. At least {#Emph}somebody{#Prev}'s picked up the slack."
      Speaker = "Nemesis"
      Event = "NemesisAboutErisFightW01"
    }
    {
      Id = "Melinoe_3218"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps all of those savage fights between you two contributed to her disagreeable nature. Or yours, for that matter. Unless you're certain neither one of you has changed a bit, in which case, what was all the fighting even for?"
      Speaker = "Melinoe"
      Event = "NemesisAboutErisFightW01"
    }
    {
      Id = "Nemesis_0245"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've met her. She always liked picking fights. And you've met {#Emph}me. {#Prev}I've never liked backing down from them. As for you, go learn to take a compliment next time."
      Speaker = "Nemesis"
      Event = "NemesisAboutErisFightW01"
    }
    {
      Id = "Melinoe_3219"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...I must have missed it."
      Speaker = "Melinoe"
      Event = "NemesisAboutErisFightW01"
    }
    {
      Id = "Nemesis_0246"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Sure did."
      Speaker = "Nemesis"
      Event = "NemesisAboutErisFightW01"
    }
    {
      Id = "Melinoe_5260"
      InheritFrom = "BaseNarrative"
      DisplayName = "Has anyone ever told you you look a bit like your mother, Nemesis? Having met her I can see the resemblance. In fact, when I first saw her, I... well, anyway."
      Speaker = "Melinoe"
      Event = "NemesisAboutNyx01"
    }
    {
      Id = "Nemesis_0425"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, finish that thought. When you first saw her, you what?"
      Speaker = "Nemesis"
      Event = "NemesisAboutNyx01"
    }
    {
      Id = "Melinoe_5261"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Erm{#Prev}, when I first saw her, I... look, I was taken aback by her appearance! In a positive way. She was like if you wore an elegant gown, and gave your brow muscles a rest."
      Speaker = "Melinoe"
      Event = "NemesisAboutNyx01"
    }
    {
      Id = "Nemesis_0426"
      InheritFrom = "BaseNarrative"
      DisplayName = "Was your idea of a compliment. Nobody wants to look like their mother. Don't look anything like mine anyway. Except maybe the hair."
      Speaker = "Nemesis"
      Event = "NemesisAboutNyx01"
    }
    {
      Id = "Melinoe_5262"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lady Demeter said I look just like my mother, which I thought was very kind of her! Queen Persephone is striking."
      Speaker = "Melinoe"
      Event = "NemesisAboutNyx01"
    }
    {
      Id = "Nemesis_0427"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Think she and Nyx get on as well as we do?"
      Speaker = "Nemesis"
      Event = "NemesisAboutNyx01"
    }
    {
      Id = "Melinoe_5263"
      InheritFrom = "BaseSubtitle"
      DisplayName = "They couldn't possibly."
      Speaker = "Melinoe"
      Event = "NemesisAboutNyx01"
    }
    {
      Id = "Nemesis_0423"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ran into Nyx last night. So whenever she's had her fill of being around Hades and Persephone, she goes off to Chaos for a little quiet time. I can see the appeal."
      Speaker = "Nemesis"
      Event = "NemesisAboutNyx02"
    }
    {
      Id = "Melinoe_5258"
      InheritFrom = "BaseNarrative"
      DisplayName = "She's not doing it to get away from my parents! With all that the Underworld's gone through, don't you think Night and Chaos might have a lot to discuss?"
      Speaker = "Melinoe"
      Event = "NemesisAboutNyx02"
    }
    {
      Id = "Nemesis_0424"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sure. Trying to imagine what they even talk about. {#Emph}It continues to be very dark here, Chaos. Yes, it does, Nyx."
      Speaker = "Nemesis"
      Event = "NemesisAboutNyx02"
    }
    {
      Id = "Melinoe_5259"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}<Laugh> {#Prev}Sorry."
      Speaker = "Melinoe"
      Event = "NemesisAboutNyx02"
    }
    {
      Id = "Melinoe_5255"
      InheritFrom = "BaseNarrative"
      DisplayName = "How has it been having your mother back? I'm still growing accustomed to the part where my own birthmother is in my life, even if I may not see her every night."
      Speaker = "Melinoe"
      Event = "NemesisAboutNyxRescue01"
    }
    {
      Id = "Nemesis_0421"
      InheritFrom = "BaseNarrative"
      DisplayName = "Doubt Mother Nyx will be coming around much either. Never did. But she was never really gone. Night's been around since before Time. Nobody messes with her."
      Speaker = "Nemesis"
      Event = "NemesisAboutNyxRescue01"
    }
    {
      Id = "Melinoe_5256"
      InheritFrom = "BaseNarrative"
      DisplayName = "Speaking of that, sounds like you have free rein to dole out Retribution once again, not that you weren't doling it out before. No need to keep pursuing Chronos now!"
      Speaker = "Melinoe"
      Event = "NemesisAboutNyxRescue01"
    }
    {
      Id = "Nemesis_0422"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh I'm not finished there."
      Speaker = "Nemesis"
      Event = "NemesisAboutNyxRescue01"
    }
    {
      Id = "Melinoe_5257"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Somehow I'm not surprised!"
      Speaker = "Melinoe"
      Event = "NemesisAboutNyxRescue01"
    }
    {
      Id = "Melinoe_1552"
      InheritFrom = "BaseNarrative"
      DisplayName = "So, just how much trouble are you in for mouthing off to Headmistress, Nem? That was utterly disrespectful, even for you."
      Speaker = "Melinoe"
      Event = "NemesisAboutHecate01"
    }
    {
      Id = "Nemesis_0057"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Heh! {#Prev}Well, looks like I've got a lot more guard duty ahead of me. But it was worth it. Help balance out you sucking up to her all the time."
      Speaker = "Nemesis"
      Event = "NemesisAboutHecate01"
    }
    {
      Id = "Melinoe_1553"
      InheritFrom = "BaseNarrative"
      DisplayName = "It figures you have no ability to distinguish between basic courtesy, and what you call sucking up."
      Speaker = "Melinoe"
      Event = "NemesisAboutHecate01"
    }
    {
      Id = "Nemesis_0058"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're just a tool to her, you know."
      Speaker = "Nemesis"
      Event = "NemesisAboutHecate01"
    }
    {
      Id = "Melinoe_1554"
      InheritFrom = "BaseNarrative"
      DisplayName = "Was it always like this, between you and Headmistress? I used to think it was {#Emph}me {#Prev}you hated most of all."
      Speaker = "Melinoe"
      Event = "NemesisAboutHecate02"
    }
    {
      Id = "Nemesis_0059"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've always been naive, Princess. As for Hecate, I liked her better before she decided {#Emph}this {#Prev}right here was the best use of my talents."
      Speaker = "Nemesis"
      Event = "NemesisAboutHecate02"
    }
    {
      Id = "Melinoe_1555"
      InheritFrom = "BaseNarrative"
      DisplayName = "She made that decision long ago. So you're going to resent her forever? Or are you going to do something about it?"
      Speaker = "Melinoe"
      Event = "NemesisAboutHecate02"
    }
    {
      Id = "Nemesis_0060"
      InheritFrom = "BaseNarrative"
      DisplayName = "I {#Emph}am {#Prev}doing something about it! I'm honoring my vow to Mother Nyx. Else I'd be long gone, much to your disappointment, I'm sure."
      Speaker = "Nemesis"
      Event = "NemesisAboutHecate02"
    }
    {
      Id = "Melinoe_1556"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I would be very disappointed, yes."
      Speaker = "Melinoe"
      Event = "NemesisAboutHecate02"
    }
    {
      Id = "Nemesis_0061"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wondered why Hecate took off all of a sudden. Was just to get in your way! Send you crying home. Guess she doesn't want you to succeed."
      Speaker = "Nemesis"
      Event = "NemesisAboutLosingToHecate01"
    }
    {
      Id = "Melinoe_1557"
      InheritFrom = "BaseNarrative"
      DisplayName = "She expects me to be prepared for whatever lies ahead."
      Speaker = "Melinoe"
      Event = "NemesisAboutLosingToHecate01"
    }
    {
      Id = "Nemesis_0062"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're such a pushover sometimes."
      Speaker = "Nemesis"
      Event = "NemesisAboutLosingToHecate01"
    }
    {
      Id = "Nemesis_0063"
      InheritFrom = "BaseNarrative"
      DisplayName = "You passed her little test that time. Must have felt so good beating her ass to the ground. Don't get to spar with her, so I can only imagine."
      Speaker = "Nemesis"
      Event = "NemesisAboutDefeatingHecate01"
    }
    {
      Id = "Melinoe_1558"
      InheritFrom = "BaseNarrative"
      DisplayName = "We're not just sparring. You don't know our craft."
      Speaker = "Melinoe"
      Event = "NemesisAboutDefeatingHecate01"
    }
    {
      Id = "Nemesis_0064"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I know I could take her..."
      Speaker = "Nemesis"
      Event = "NemesisAboutDefeatingHecate01"
    }
    {
      Id = "Nemesis_0137"
      InheritFrom = "BaseNarrative"
      DisplayName = "Next time you got something to say about me, you come say it to my face. Know you witches would much rather sneak around, though."
      Speaker = "Nemesis"
      Event = "NemesisAboutOdysseus01"
    }
    {
      Id = "Melinoe_2236"
      InheritFrom = "BaseNarrative"
      DisplayName = "What are you even talking about? I think you're being accusatory and abrasive. There! I said {#Emph}that {#Prev}to your face."
      Speaker = "Melinoe"
      Event = "NemesisAboutOdysseus01"
    }
    {
      Id = "Nemesis_0138"
      InheritFrom = "BaseNarrative"
      DisplayName = "Odysseus tried giving me one of his talks. Telling me you didn't go complaining to him?"
      Speaker = "Nemesis"
      Event = "NemesisAboutOdysseus01"
    }
    {
      Id = "Melinoe_2237"
      InheritFrom = "BaseNarrative"
      DisplayName = "He was concerned with how we're getting on. You're not exactly being subtle, and he's quite perceptive in case you hadn't noticed."
      Speaker = "Melinoe"
      Event = "NemesisAboutOdysseus01"
    }
    {
      Id = "Nemesis_0139"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Be. Quiet."
      Speaker = "Nemesis"
      Event = "NemesisAboutOdysseus01"
    }
    {
      Id = "Melinoe_1559"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ran into Artemis out there, at long last. Did she pass through and say hello at least?"
      Speaker = "Melinoe"
      Event = "NemesisAboutArtemis01"
    }
    {
      Id = "Nemesis_0069"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, she didn't. So she's been skulking around in these woods? Thought she was busy rallying your aunts and uncles for you. Wait, you couldn't go the distance even with {#Emph}her {#Prev}help?"
      Speaker = "Nemesis"
      Event = "NemesisAboutArtemis01"
    }
    {
      Id = "Melinoe_1560"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It's not that simple...!"
      Speaker = "Melinoe"
      Event = "NemesisAboutArtemis01"
    }
    {
      Id = "Melinoe_2242"
      InheritFrom = "BaseNarrative"
      DisplayName = "Have you met Artemis out there? I suppose it may be worth repeatedly disobeying orders for the chance to see her."
      Speaker = "Melinoe"
      Event = "NemesisAboutArtemis02"
    }
    {
      Id = "Nemesis_0143"
      InheritFrom = "BaseNarrative"
      DisplayName = "What would you know of it. You really think I'm sneaking out into those woods just to fool around?"
      Speaker = "Nemesis"
      Event = "NemesisAboutArtemis02"
    }
    {
      Id = "Melinoe_2243"
      InheritFrom = "BaseNarrative"
      DisplayName = "Is everything all right between the two of you, at least?"
      Speaker = "Melinoe"
      Event = "NemesisAboutArtemis02"
    }
    {
      Id = "Nemesis_0144"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It's fine."
      Speaker = "Nemesis"
      Event = "NemesisAboutArtemis02"
    }
    {
      Id = "Nemesis_0342"
      InheritFrom = "BaseNarrative"
      DisplayName = "Singing, {#Emph}eugh. {#Prev}The goddess of the hunt apparently is looking for her brother's job. Surprised you're not still over there yourself. Something else you could be practicing."
      Speaker = "Nemesis"
      Event = "NemesisAboutArtemisSinging01"
    }
    {
      Id = "Melinoe_4460"
      InheritFrom = "BaseNarrative"
      DisplayName = "It may seem frivolous though we don't sing merely for lack of things to do here, Nemesis. It has a cleansing quality."
      Speaker = "Melinoe"
      Event = "NemesisAboutArtemisSinging01"
    }
    {
      Id = "Nemesis_0343"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, right. Artemis told me all about what you mean when you talk about cleansing. Least I'm just about out of earshot over here."
      Speaker = "Nemesis"
      Event = "NemesisAboutArtemisSinging01"
    }
    {
      Id = "Melinoe_4461"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We'll have to sing louder for you."
      Speaker = "Melinoe"
      Event = "NemesisAboutArtemisSinging01"
    }
    {
      Id = "Nemesis_0065"
      InheritFrom = "BaseNarrative"
      DisplayName = "Been talking to Hypnos again? He can't hear you, you know. Kind of what happens when somebody's fast asleep."
      Speaker = "Nemesis"
      Event = "NemesisAboutHypnos01"
    }
    {
      Id = "Melinoe_0686"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sleep is not as simple as you make it out to be. I think he can sense my words and intentions."
      Speaker = "Melinoe"
      Event = "NemesisAboutHypnos01"
    }
    {
      Id = "Nemesis_0066"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sensing words and intentions, yeah... sounds exactly like the Hypnos I knew."
      Speaker = "Nemesis"
      Event = "NemesisAboutHypnos01"
    }
    {
      Id = "Nemesis_0455"
      InheritFrom = "BaseNarrative"
      DisplayName = "Can't believe it! You finally woke Hypnos up, and {#Emph}I {#Prev}slept through the whole thing? He everything you dreamed of?"
      Speaker = "Nemesis"
      Event = "NemesisAboutHypnosWakeUp01"
    }
    {
      Id = "Melinoe_5276"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, {#Emph}erm... {#Prev}his manner wasn't what I expected, and he was not especially appreciative. Although I too am prone to moodiness after sleeping in. Then, he left in a hurry..."
      Speaker = "Melinoe"
      Event = "NemesisAboutHypnosWakeUp01"
    }
    {
      Id = "Nemesis_0456"
      InheritFrom = "BaseNarrative"
      DisplayName = "Tough break I guess! Always thought he really was your type. Well if you do end up working in your father's House, you'll meet again. For now, least we don't have to listen to him snoring {#Emph}every single night."
      Speaker = "Nemesis"
      Event = "NemesisAboutHypnosWakeUp01"
    }
    {
      Id = "Melinoe_5277"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I do suppose there's that..."
      Speaker = "Melinoe"
      Event = "NemesisAboutHypnosWakeUp01"
    }
    {
      Id = "Melinoe_2238"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why all the rancor toward Narcissus, by the way? I see how he could be a little irritating, but he doesn't seem all that bad."
      Speaker = "Melinoe"
      Event = "NemesisAboutNarcissus01"
    }
    {
      Id = "Nemesis_0140"
      InheritFrom = "BaseNarrative"
      DisplayName = "Should have seen what he did to this poor Nymph. Absolutely broke her heart. Didn't even notice, or care."
      Speaker = "Nemesis"
      Event = "NemesisAboutNarcissus01"
    }
    {
      Id = "Melinoe_2239"
      InheritFrom = "BaseNarrative"
      DisplayName = "Didn't take you for the sentimental type. I thought you concerned yourself with worse than lovers' quarrels."
      Speaker = "Melinoe"
      Event = "NemesisAboutNarcissus01"
    }
    {
      Id = "Nemesis_0141"
      InheritFrom = "BaseNarrative"
      DisplayName = "Narcissus cared only for himself, not for anyone around him. Had to make an example of him. He wound up madly in love. With his own reflection. Till the day he died."
      Speaker = "Nemesis"
      Event = "NemesisAboutNarcissus01"
    }
    {
      Id = "Melinoe_2240"
      InheritFrom = "BaseNarrative"
      DisplayName = "So now he's a Shade in the Underworld. And still staring longingly into his own eyes."
      Speaker = "Melinoe"
      Event = "NemesisAboutNarcissus01"
    }
    {
      Id = "Nemesis_0142"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, you're the witch, not me. You know how it is with curses."
      Speaker = "Nemesis"
      Event = "NemesisAboutNarcissus01"
    }
    {
      Id = "Melinoe_2241"
      InheritFrom = "BaseSubtitle"
      DisplayName = "They're easily misused."
      Speaker = "Melinoe"
      Event = "NemesisAboutNarcissus01"
    }
    {
      Id = "Melinoe_3232"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, about Narcissus. I won't undo the curse you put on him, even if I could. He seems to be rather content, and besides... I can tell you truly believe he deserved it. Only problem is, that curse did nothing to aid Echo in her plight."
      Speaker = "Melinoe"
      Event = "NemesisAboutNarcissus02"
    }
    {
      Id = "Nemesis_0267"
      InheritFrom = "BaseNarrative"
      DisplayName = "Echo... that was the Nymph who put Narcissus on my list of things to do. You're telling me getting divine retribution with no strings attached wasn't enough to put her mind at peace?"
      Speaker = "Nemesis"
      Event = "NemesisAboutNarcissus02"
    }
    {
      Id = "Melinoe_3233"
      InheritFrom = "BaseNarrative"
      DisplayName = "Correct. You evened the score between them, though you didn't set things right for either one. They had to set things right for themselves."
      Speaker = "Melinoe"
      Event = "NemesisAboutNarcissus02"
    }
    {
      Id = "Nemesis_0268"
      InheritFrom = "BaseNarrative"
      DisplayName = "With your help and encouragement, I guess? {#Emph}Eh{#Prev}, same difference to me long as neither one ends up much better off. Sounds like you lectured both of them, so I'm sure it's close."
      Speaker = "Nemesis"
      Event = "NemesisAboutNarcissus02"
    }
    {
      Id = "Melinoe_3234"
      InheritFrom = "BaseNarrative"
      DisplayName = "So you don't care how they end up, as long as they're even."
      Speaker = "Melinoe"
      Event = "NemesisAboutNarcissus02"
    }
    {
      Id = "Nemesis_0269"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're catching on."
      Speaker = "Nemesis"
      Event = "NemesisAboutNarcissus02"
    }
    {
      Id = "Nemesis_0262"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got yet another Titan up against us, huh? {#Emph}Prometheus! {#Prev}One of the smart ones, so they say. And now, an enemy. Could have been on our side had your family not... you know."
      Speaker = "Nemesis"
      Event = "NemesisAboutPrometheus01"
    }
    {
      Id = "Melinoe_3604"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes, the whole {#Emph}chain-him-to-a-mountain-so-an-eagle-could- eat-his-regenerating-liver-for-aeons {#Prev}thing. Not one of the proudest moments on Olympus, I have to imagine."
      Speaker = "Melinoe"
      Event = "NemesisAboutPrometheus01"
    }
    {
      Id = "Nemesis_0263"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come ask me whether he deserves his vengeance if ever you want to feel any worse about that whole mess."
      Speaker = "Nemesis"
      Event = "NemesisAboutPrometheus01"
    }
    {
      Id = "Melinoe_3605"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Watch with the treason, Nem."
      Speaker = "Melinoe"
      Event = "NemesisAboutPrometheus01"
    }
    {
      Id = "Nemesis_0264"
      InheritFrom = "BaseNarrative"
      DisplayName = "So now Olympus has to deal with Typhon, huh? Wonder if Chronos made a deal with him or just revived and set him loose. Either way, plan like that takes a lot of guts."
      Speaker = "Nemesis"
      Event = "NemesisAboutTyphon01"
    }
    {
      Id = "Melinoe_3927"
      InheritFrom = "BaseNarrative"
      DisplayName = "You sound rather impressed! I'm certain Chronos would welcome you into his ranks as well if you just tell him how you really feel."
      Speaker = "Melinoe"
      Event = "NemesisAboutTyphon01"
    }
    {
      Id = "Nemesis_0265"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hit a nerve? Fine. Doesn't change the fact our enemy outsmarted us. So, no need to keep wasting your time up top... wait, you're not going to try and {#Emph}fight {#Prev}that thing, are you?"
      Speaker = "Nemesis"
      Event = "NemesisAboutTyphon01"
    }
    {
      Id = "Melinoe_3928"
      InheritFrom = "BaseNarrative"
      DisplayName = "You really think I'm going to leave my family on Olympus to face that monster on their own? You don't know me at all."
      Speaker = "Melinoe"
      Event = "NemesisAboutTyphon01"
    }
    {
      Id = "Nemesis_0266"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Nice knowing you, anyway."
      Speaker = "Nemesis"
      Event = "NemesisAboutTyphon01"
    }
    {
      Id = "Melinoe_3929"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A real pleasure."
      Speaker = "Melinoe"
      Event = "NemesisAboutTyphon01"
    }
    {
      Id = "Nemesis_0300"
      InheritFrom = "BaseNarrative"
      DisplayName = "Must have got a lot of help, knocking Typhon from his perch. Oh, we all heard. You got a dozen family members all up there, some of them strong. So what do they need you for?"
      Speaker = "Nemesis"
      Event = "NemesisAboutTyphonW01"
    }
    {
      Id = "Melinoe_4422"
      InheritFrom = "BaseNarrative"
      DisplayName = "They certainly are capable, but they're backed into a corner on Olympus. What matters is our latest battle was victorious, and I did what I could to see it through."
      Speaker = "Melinoe"
      Event = "NemesisAboutTyphonW01"
    }
    {
      Id = "Nemesis_0301"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sharing in your success, or just trying to appease me? Main reason you won is that monster had it coming anyway. But, it'll all even out."
      Speaker = "Nemesis"
      Event = "NemesisAboutTyphonW01"
    }
    {
      Id = "Melinoe_4423"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What's that supposed to mean?"
      Speaker = "Melinoe"
      Event = "NemesisAboutTyphonW01"
    }
    {
      Id = "Nemesis_0302"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You'll see."
      Speaker = "Nemesis"
      Event = "NemesisAboutTyphonW01"
    }
    {
      Id = "Nemesis_0305"
      InheritFrom = "BaseNarrative"
      DisplayName = "Really must be making Typhon mad. What's the plan there besides that? Get so caught up in all the glory that you lose sight of our real enemy?"
      Speaker = "Nemesis"
      Event = "NemesisAboutTyphonW02"
    }
    {
      Id = "Melinoe_4426"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Father of All Monsters represents an urgent threat; you'd know it if you saw him for yourself. If Olympus is laid to ruin, Chronos prevails. We wouldn't be able to stop him."
      Speaker = "Melinoe"
      Event = "NemesisAboutTyphonW02"
    }
    {
      Id = "Nemesis_0306"
      InheritFrom = "BaseNarrative"
      DisplayName = "Speak for yourself. The Underworld never needed any of those gods. Chronos wouldn't even be here if not for them."
      Speaker = "Nemesis"
      Event = "NemesisAboutTyphonW02"
    }
    {
      Id = "Melinoe_4427"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thank the Fates we have you to deal with him."
      Speaker = "Melinoe"
      Event = "NemesisAboutTyphonW02"
    }
    {
      Id = "Nemesis_0307"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thank the Fates."
      Speaker = "Nemesis"
      Event = "NemesisAboutTyphonW02"
    }
    {
      Id = "Nemesis_0088"
      InheritFrom = "BaseNarrative"
      DisplayName = "Been hunched over that cauldron so much, least your craft is finally doing something around here. So much toiling with no results..."
      Speaker = "Nemesis"
      Event = "NemesisAboutCauldron01"
    }
    {
      Id = "Melinoe_0691"
      InheritFrom = "BaseNarrative"
      DisplayName = "Our craft is typically about the self, and such results tend not to be immediate. Though, I appreciate you noticing."
      Speaker = "Melinoe"
      Event = "NemesisAboutCauldron01"
    }
    {
      Id = "Nemesis_0089"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yeah, well..."
      Speaker = "Nemesis"
      Event = "NemesisAboutCauldron01"
    }
    {
      Id = "Melinoe_3235"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why don't I ever see you in the training grounds anymore? You used to let all your aggression out over there, but now it's like you're saving it for {#Emph}me."
      Speaker = "Melinoe"
      Event = "NemesisAboutTrainingGrounds01"
    }
    {
      Id = "Nemesis_0270"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't flatter yourself. Saving it for {#Emph}Chronos. {#Prev}And the training grounds increasingly are custom-fit for {#Emph}you{#Prev}, in case you haven't noticed. From that Altar, to the weapons display."
      Speaker = "Nemesis"
      Event = "NemesisAboutTrainingGrounds01"
    }
    {
      Id = "Melinoe_3236"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm the only one who uses it..."
      Speaker = "Melinoe"
      Event = "NemesisAboutTrainingGrounds01"
    }
    {
      Id = "Nemesis_0271"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Need my space."
      Speaker = "Nemesis"
      Event = "NemesisAboutTrainingGrounds01"
    }
    {
      Id = "Melinoe_1564"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nemesis, for all the time you used to spend on the surface... surely there was something there that made it worth your while?"
      Speaker = "Melinoe"
      Event = "NemesisAboutEvil01"
    }
    {
      Id = "Nemesis_0072"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, {#Emph}there was. {#Prev}Mortals like to reach beyond their means, thinking they're just like us. I'd sniff them out, and put them back in their place."
      Speaker = "Nemesis"
      Event = "NemesisAboutEvil01"
    }
    {
      Id = "Melinoe_1565"
      InheritFrom = "BaseNarrative"
      DisplayName = "Put them back in their place... by punishing them in some inventive fashion, I suppose?"
      Speaker = "Melinoe"
      Event = "NemesisAboutEvil01"
    }
    {
      Id = "Nemesis_0073"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's right. We all should get what we deserve, no more, no less."
      Speaker = "Nemesis"
      Event = "NemesisAboutEvil01"
    }
    {
      Id = "Melinoe_0608"
      InheritFrom = "BaseNarrative"
      DisplayName = "But don't mortals already have ways to ensure justice is served, like my father did?"
      Speaker = "Melinoe"
      Event = "NemesisAboutEvil01"
    }
    {
      Id = "Nemesis_0074"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hah! {#Prev}Sure they do."
      Speaker = "Nemesis"
      Event = "NemesisAboutEvil01"
    }
    {
      Id = "Melinoe_0680"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey. You miss being up there, don't you? Among the mortals and all that."
      Speaker = "Melinoe"
      Event = "NemesisAboutEvil02"
    }
    {
      Id = "Nemesis_0075"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know, mortals have a word for deliberate cruelty or callous negligence: They call it evil. I could always catch wind of it. I'd go to the source. And whoever it was, I'd make them pay."
      Speaker = "Nemesis"
      Event = "NemesisAboutEvil02"
    }
    {
      Id = "Melinoe_1566"
      InheritFrom = "BaseNarrative"
      DisplayName = "But now you're stuck here, and the evil goes unchecked..."
      Speaker = "Melinoe"
      Event = "NemesisAboutEvil02"
    }
    {
      Id = "Nemesis_0076"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A lot of it, I'm sure."
      Speaker = "Nemesis"
      Event = "NemesisAboutEvil02"
    }
    {
      Id = "Nemesis_0078"
      InheritFrom = "BaseNarrative"
      DisplayName = "That Nectar you've been passing around? Don't see why you bother. Not everybody deserves it, anyhow."
      Speaker = "Nemesis"
      Event = "NemesisAboutNectar01"
    }
    {
      Id = "Melinoe_0611"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Deserves? {#Prev}And I suppose you think {#Emph}you're {#Prev}fit to be the judge of that?"
      Speaker = "Melinoe"
      Event = "NemesisAboutNectar01"
    }
    {
      Id = "Nemesis_0079"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yeah. Who do you think I {#Emph}am? {#Prev}If everybody just magickally got what they deserved, I'd have no reason to exist."
      Speaker = "Nemesis"
      Event = "NemesisAboutNectar01"
    }
    {
      Id = "Melinoe_0612"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's awful..."
      Speaker = "Melinoe"
      Event = "NemesisAboutNectar01"
    }
    {
      Id = "Nemesis_0080"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's life."
      Speaker = "Nemesis"
      Event = "NemesisAboutNectar01"
    }
    {
      Id = "Melinoe_1573"
      InheritFrom = "BaseNarrative"
      DisplayName = "I didn't mean to make you uncomfortable, with the Nectar from before. It's just, I've always looked up to you, and... I'm doing the best I can."
      Speaker = "Melinoe"
      Event = "NemesisAboutNectar02"
    }
    {
      Id = "Nemesis_0100"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't sweat it. Had myself a little drink the other night, and it didn't poison me as far as I know. So we're clear."
      Speaker = "Nemesis"
      Event = "NemesisAboutNectar02"
    }
    {
      Id = "Melinoe_1574"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Want any more?"
      Speaker = "Melinoe"
      Event = "NemesisAboutNectar02"
    }
    {
      Id = "Nemesis_0101"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Eh..."
      Speaker = "Nemesis"
      Event = "NemesisAboutNectar02"
    }
    {
      Id = "Nemesis_0126"
      InheritFrom = "BaseNarrative"
      DisplayName = "Back on your feet again there, Princess? All's well in the Crossroads, nothing to report."
      Speaker = "Nemesis"
      Event = "NemesisAboutFieldMeeting01"
    }
    {
      Id = "Melinoe_2229"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's fortunate we have you vigilantly keeping watch here, Nemesis...! Oh come on, drop the act. What happened, when did you return?"
      Speaker = "Melinoe"
      Event = "NemesisAboutFieldMeeting01"
    }
    {
      Id = "Nemesis_0127"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't know what you're talking about, and it's not your business anyway. Fates help you on your {#Emph}task."
      Speaker = "Nemesis"
      Event = "NemesisAboutFieldMeeting01"
    }
    {
      Id = "Melinoe_2230"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not quite as easy as you imagined, is it? To think that the embodiment of Retribution could be so arrogant."
      Speaker = "Melinoe"
      Event = "NemesisAboutFieldMeeting01"
    }
    {
      Id = "Nemesis_0128"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Shut up."
      Speaker = "Nemesis"
      Event = "NemesisAboutFieldMeeting01"
    }
    {
      Id = "Melinoe_2231"
      InheritFrom = "BaseNarrative"
      DisplayName = "Does Headmistress know yet of your little excursions? Not much escapes her notice, last I checked."
      Speaker = "Melinoe"
      Event = "NemesisAboutFieldMeeting02"
    }
    {
      Id = "Nemesis_0129"
      InheritFrom = "BaseNarrative"
      DisplayName = "Strongly advise you mind your own responsibilities. Hecate doesn't control me, and {#Emph}you {#Prev}should show a little gratitude."
      Speaker = "Nemesis"
      Event = "NemesisAboutFieldMeeting02"
    }
    {
      Id = "Melinoe_2232"
      InheritFrom = "BaseNarrative"
      DisplayName = "For what, endangering us all? I didn't ask for your assistance, Nemesis."
      Speaker = "Melinoe"
      Event = "NemesisAboutFieldMeeting02"
    }
    {
      Id = "Nemesis_0130"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Because you're weak."
      Speaker = "Nemesis"
      Event = "NemesisAboutFieldMeeting02"
    }
    {
      Id = "Melinoe_3230"
      InheritFrom = "BaseNarrative"
      DisplayName = "The first few times I saw you out there, I figured you were just venting your anger. But you keep heading out night after night. You're determined, but you're going to get caught."
      Speaker = "Melinoe"
      Event = "NemesisAboutFieldMeeting03"
    }
    {
      Id = "Nemesis_0260"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not if no one says anything. Besides, Hecate likely already knows. She isn't dense. Just letting me learn whatever she thinks I stand to learn the hard way. Works out for both of us."
      Speaker = "Nemesis"
      Event = "NemesisAboutFieldMeeting03"
    }
    {
      Id = "Melinoe_3231"
      InheritFrom = "BaseNarrative"
      DisplayName = "Fine. We're both learning a lot I think. But I don't intend to let up on any of my responsibilities, just because you're trying to achieve what I've been tasked to do."
      Speaker = "Melinoe"
      Event = "NemesisAboutFieldMeeting03"
    }
    {
      Id = "Nemesis_0261"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Somebody's got to do it."
      Speaker = "Nemesis"
      Event = "NemesisAboutFieldMeeting03"
    }
    {
      Id = "Nemesis_0131"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got careless. All because of a little wager. You want to show me up that bad?"
      Speaker = "Nemesis"
      Event = "NemesisAboutCombatFailure01"
    }
    {
      Id = "Melinoe_2233"
      InheritFrom = "BaseNarrative"
      DisplayName = "I could ask you the same thing. What are you doing back already? You couldn't have gone much farther."
      Speaker = "Melinoe"
      Event = "NemesisAboutCombatFailure01"
    }
    {
      Id = "Nemesis_0132"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yeah. I got careless, too..."
      Speaker = "Nemesis"
      Event = "NemesisAboutCombatFailure01"
    }
    {
      Id = "Nemesis_0344"
      InheritFrom = "BaseNarrative"
      DisplayName = "Getting some use out of that Evil Eye. Anything or anyone out there force you to call it a night early, next night you go do the same to them. Old tradition, but it works."
      Speaker = "Nemesis"
      Event = "NemesisAboutKeepsake01"
    }
    {
      Id = "Melinoe_4462"
      InheritFrom = "BaseNarrative"
      DisplayName = "Appreciate the gift. The Eye has certainly been instrumental in some cases where I got the better of my foes. Though whether I'm delivering retribution or merely taking vengeance, I'm not always sure."
      Speaker = "Melinoe"
      Event = "NemesisAboutKeepsake01"
    }
    {
      Id = "Nemesis_0345"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sorting out each act of vengeance does take a while. But don't sweat the technicalities too much. You're clear."
      Speaker = "Nemesis"
      Event = "NemesisAboutKeepsake01"
    }
    {
      Id = "Melinoe_4463"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Every act of vengeance gets sorted out?"
      Speaker = "Melinoe"
      Event = "NemesisAboutKeepsake01"
    }
    {
      Id = "Nemesis_0346"
      InheritFrom = "BaseSubtitle"
      DisplayName = "They're supposed to be."
      Speaker = "Nemesis"
      Event = "NemesisAboutKeepsake01"
    }
    {
      Id = "Nemesis_0347"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're more conceited than Narcissus. Saw those statues of you in the Training Grounds. You'll have to work a whole lot harder to look like that."
      Speaker = "Nemesis"
      Event = "NemesisAboutTrophyQuest01"
    }
    {
      Id = "Melinoe_4464"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, I... I had nothing to do with those. Well, I did earn them, they're the Gifts of the Veil bestowed upon Night's Champion...! Oh, that does sound quite conceited..."
      Speaker = "Melinoe"
      Event = "NemesisAboutTrophyQuest01"
    }
    {
      Id = "Nemesis_0348"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't sweat it. They're something all right. Always said you'd never be bigger than me. That's what I get."
      Speaker = "Nemesis"
      Event = "NemesisAboutTrophyQuest01"
    }
    {
      Id = "Melinoe_4465"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Retribution..."
      Speaker = "Melinoe"
      Event = "NemesisAboutTrophyQuest01"
    }
    {
      Id = "Nemesis_0339"
      InheritFrom = "BaseNarrative"
      DisplayName = "What's with that throne conspicuously near my post. Just a temptation. Never once seen {#Emph}you {#Prev}sit down on the job; you ever seen me?"
      Speaker = "Nemesis"
      Event = "NemesisAboutThrone01"
    }
    {
      Id = "Melinoe_4458"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, it's just... I thought perhaps you'd like the option there at least. Nothing in excess, right? And you {#Emph}do {#Prev}have to stand an awful lot."
      Speaker = "Melinoe"
      Event = "NemesisAboutThrone01"
    }
    {
      Id = "Nemesis_0340"
      InheritFrom = "BaseNarrative"
      DisplayName = "My rules, not yours. I start sitting down, won't want to get back up. Especially wearing all {#Emph}this. {#Prev}Besides, half the point of guard duty is having to stay standing {#Emph}the whole time."
      Speaker = "Nemesis"
      Event = "NemesisAboutThrone01"
    }
    {
      Id = "Melinoe_4459"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The throne could go away if you prefer."
      Speaker = "Melinoe"
      Event = "NemesisAboutThrone01"
    }
    {
      Id = "Nemesis_0341"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just leave it there for now."
      Speaker = "Nemesis"
      Event = "NemesisAboutThrone01"
    }
    {
      Id = "Melinoe_4447"
      InheritFrom = "BaseNarrative"
      DisplayName = "When we were together out there, it seems almost like a dream. Especially since it was rather unlike either one of us to have set all our responsibilities aside that way..."
      Speaker = "Melinoe"
      Event = "NemesisAboutRelationship01"
    }
    {
      Id = "Nemesis_0327"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're saying you regret it, fine; I don't. Not like we've made a habit of it, and besides... got you out of my head, just as I wanted."
      Speaker = "Nemesis"
      Event = "NemesisAboutRelationship01"
    }
    {
      Id = "Melinoe_4448"
      InheritFrom = "BaseNarrative"
      DisplayName = "You did? That isn't how it worked for me at all. I've only thought about you {#Emph}more {#Prev}since then. And I do {#Emph}not {#Prev}regret it!"
      Speaker = "Melinoe"
      Event = "NemesisAboutRelationship01"
    }
    {
      Id = "Nemesis_0328"
      InheritFrom = "BaseNarrative"
      DisplayName = "No? Well, that's Retribution for you. Some win, some lose, nobody gets it all. Though maybe over time, we can... even things out. Shouldn't be one-sided between us."
      Speaker = "Nemesis"
      Event = "NemesisAboutRelationship01"
    }
    {
      Id = "Melinoe_4449"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll hold you to that."
      Speaker = "Melinoe"
      Event = "NemesisAboutRelationship01"
    }
    {
      Id = "Nemesis_0329"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Same."
      Speaker = "Nemesis"
      Event = "NemesisAboutRelationship01"
    }
    {
      Id = "Melinoe_4450"
      InheritFrom = "BaseNarrative"
      DisplayName = "When we were together out there, Nem... I wanted to make sure you weren't angry with me. No more than usual at least. You said I was distracting you and that's not what I want."
      Speaker = "Melinoe"
      Event = "NemesisAboutRelationship01_B"
    }
    {
      Id = "Nemesis_0330"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know, it's fine, we're good. Unless you keep making too big a deal. I think we get each other now, and we both like it when we're sure. Anyway, be seeing you out there."
      Speaker = "Nemesis"
      Event = "NemesisAboutRelationship01_B"
    }
    {
      Id = "Melinoe_4451"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Be seeing you."
      Speaker = "Melinoe"
      Event = "NemesisAboutRelationship01_B"
    }
    {
      Id = "Nemesis_0331"
      InheritFrom = "BaseNarrative"
      DisplayName = "When did it start. You couldn't even stand looking at me. Couldn't stand your scrawny ass either. Then something happened. Trying to pinpoint it."
      Speaker = "Nemesis"
      Event = "NemesisAboutRelationship02"
    }
    {
      Id = "Melinoe_4452"
      InheritFrom = "BaseNarrative"
      DisplayName = "My feelings for you gradually strengthened over time. The anger you brought out in me... I started to like it. I just never thought you would reciprocate."
      Speaker = "Melinoe"
      Event = "NemesisAboutRelationship02"
    }
    {
      Id = "Nemesis_0332"
      InheritFrom = "BaseNarrative"
      DisplayName = "Took you for a showoff. Never realized how strong you are, and not just physically. And you don't overdo it anymore."
      Speaker = "Nemesis"
      Event = "NemesisAboutRelationship02"
    }
    {
      Id = "Melinoe_4453"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That was a compliment."
      Speaker = "Melinoe"
      Event = "NemesisAboutRelationship02"
    }
    {
      Id = "Nemesis_0333"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yeah."
      Speaker = "Nemesis"
      Event = "NemesisAboutRelationship02"
    }
    {
      Id = "Melinoe_4471"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know I can read you sometimes, Nem, and something's wrong, so what is it? If you don't mind telling me..."
      Speaker = "Melinoe"
      Event = "NemesisAboutRelationship03"
    }
    {
      Id = "Nemesis_0397"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Eugh{#Prev}, it's... look, I've not been close with anyone for very long. Just how it goes. So, been wondering where things are going with us, and not liking where it leads."
      Speaker = "Nemesis"
      Event = "NemesisAboutRelationship03"
    }
    {
      Id = "Melinoe_4472"
      InheritFrom = "BaseNarrative"
      DisplayName = "You truly think we're on some fixed path? The Fates may be your sisters but you needn't {#Emph}all {#Prev}be caught up in self-fulfilling prophecies."
      Speaker = "Melinoe"
      Event = "NemesisAboutRelationship03"
    }
    {
      Id = "Nemesis_0398"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, but... problem I'm having is I'm starting to like being around you more than not. If it keeps on that way, I'll be..."
      Speaker = "Nemesis"
      Event = "NemesisAboutRelationship03"
    }
    {
      Id = "Melinoe_4473"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I know. Too much of a good thing. But, must we concern ourselves about the future constantly? We could just appreciate being together when we can. No pressure."
      Speaker = "Melinoe"
      Event = "NemesisAboutRelationship03"
    }
    {
      Id = "Nemesis_0399"
      InheritFrom = "BaseNarrative"
      DisplayName = "...No pressure, huh... maybe you're right. Could always find a way to balance it out without messing it up."
      Speaker = "Nemesis"
      Event = "NemesisAboutRelationship03"
    }
    {
      Id = "Melinoe_4474"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A worthwhile pursuit."
      Speaker = "Melinoe"
      Event = "NemesisAboutRelationship03"
    }
    {
      Id = "Nemesis_0334"
      InheritFrom = "BaseNarrative"
      DisplayName = "What's with you and Eris, anyway? Thought you'd have the sense to stay away from her, least when you have a choice."
      Speaker = "Nemesis"
      Event = "NemesisAboutErisRelationship01"
    }
    {
      Id = "Melinoe_4454"
      InheritFrom = "BaseNarrative"
      DisplayName = "I may lack proper judgment when it comes to choosing comrades, Nemesis. She and I have little in common, but... she makes it difficult to be completely rational."
      Speaker = "Melinoe"
      Event = "NemesisAboutErisRelationship01"
    }
    {
      Id = "Nemesis_0335"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, you'll get what's coming to you when it comes to her. Or me, for that matter but in a different way. Maybe that's the appeal. Anyway, just don't go bringing her around."
      Speaker = "Nemesis"
      Event = "NemesisAboutErisRelationship01"
    }
    {
      Id = "Melinoe_4455"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Wasn't planning on it."
      Speaker = "Melinoe"
      Event = "NemesisAboutErisRelationship01"
    }
    {
      Id = "Nemesis_0336"
      InheritFrom = "BaseNarrative"
      DisplayName = "Makes sense you and Doom would get along. First I figured he'd put you off like everybody else, but you both like following orders so much. Means you have a lot in common."
      Speaker = "Nemesis"
      Event = "NemesisAboutMorosRelationship01"
    }
    {
      Id = "Melinoe_4456"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't believe we've had a single conversation about how much we love following orders, though we do get on, I think. It doesn't trouble you, does it? You'd tell me if it did."
      Speaker = "Melinoe"
      Event = "NemesisAboutMorosRelationship01"
    }
    {
      Id = "Nemesis_0337"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd tell you if it did. Moros never was a happy sort, not that any of us really are; but when he's better off, it probably bodes well for everyone else. Given his connections and all."
      Speaker = "Nemesis"
      Event = "NemesisAboutMorosRelationship01"
    }
    {
      Id = "Melinoe_4457"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Has he seemed happier to you?"
      Speaker = "Melinoe"
      Event = "NemesisAboutMorosRelationship01"
    }
    {
      Id = "Nemesis_0338"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Maybe just me."
      Speaker = "Nemesis"
      Event = "NemesisAboutMorosRelationship01"
    }
    {
      Id = "Nemesis_0400"
      InheritFrom = "BaseNarrative"
      DisplayName = "They're saying you got rid of Typhon for good. Don't believe a word of it. What really happened up there?"
      Speaker = "Nemesis"
      Event = "NemesisAboutTyphonDeath01"
    }
    {
      Id = "Melinoe_5006"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got rid of Typhon for good is a concise way to put it. Involved a rather complex incantation called {#Emph}Disintegration of Monstrosity {#Prev}and some other details best left unspoken. But yes, I do believe he's gone."
      Speaker = "Melinoe"
      Event = "NemesisAboutTyphonDeath01"
    }
    {
      Id = "Nemesis_0401"
      InheritFrom = "BaseNarrative"
      DisplayName = "He's immortal... he can't just {#Emph}be {#Prev}gone, and if he is, why not just do the same to Chronos? Or to anybody who stays on your bad side long enough?"
      Speaker = "Nemesis"
      Event = "NemesisAboutTyphonDeath01"
    }
    {
      Id = "Melinoe_5007"
      InheritFrom = "BaseNarrative"
      DisplayName = "We've something else in store for Chronos. As for everybody else, they haven't crossed me quite as much just yet."
      Speaker = "Melinoe"
      Event = "NemesisAboutTyphonDeath01"
    }
    {
      Id = "Nemesis_0402"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yet? {#Emph}Huh."
      Speaker = "Nemesis"
      Event = "NemesisAboutTyphonDeath01"
    }
    {
      Id = "Melinoe_5008"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do you know Headmistress is gone? Chronos took her right before my eyes! If you were on watch like you ought have been, she... {#Emph}augh!"
      Speaker = "Melinoe"
      Event = "NemesisAboutHecateKidnapped01"
    }
    {
      Id = "Nemesis_0403"
      InheritFrom = "BaseNarrative"
      DisplayName = "What are you talking about, {#Emph}Chronos took her. {#Prev}Saw her just the other night. Though, where is she...?"
      Speaker = "Nemesis"
      Event = "NemesisAboutHecateKidnapped01"
    }
    {
      Id = "Melinoe_5009"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}I just said! {#Prev}She's probably there in the House somewhere with the rest, but I... I've not been able to locate her yet. How could this happen, what could we have done?"
      Speaker = "Melinoe"
      Event = "NemesisAboutHecateKidnapped01"
    }
    {
      Id = "Nemesis_0404"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're serious. Wait, why didn't you {#Emph}do {#Prev}something about it if you saw the whole thing? {#Emph}I {#Prev}wasn't even there!"
      Speaker = "Nemesis"
      Event = "NemesisAboutHecateKidnapped01"
    }
    {
      Id = "Melinoe_5010"
      InheritFrom = "BaseNarrative"
      DisplayName = "I was too late! What's your excuse? You could have at least identified the possibility of such a threat!"
      Speaker = "Melinoe"
      Event = "NemesisAboutHecateKidnapped01"
    }
    {
      Id = "Nemesis_0405"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not even all-seeing Selene saw it coming, how could {#Emph}I? {#Prev}Although... keep this quiet. Get her back, or I will."
      Speaker = "Nemesis"
      Event = "NemesisAboutHecateKidnapped01"
    }
    {
      Id = "Melinoe_5011"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}I {#Prev}will."
      Speaker = "Melinoe"
      Event = "NemesisAboutHecateKidnapped01"
    }
    {
      Id = "Nemesis_0407"
      InheritFrom = "BaseNarrative"
      DisplayName = "Finally back from your father's House. Was Hecate all right? After the Titan got her, I... ought to have taken guard duty more seriously, and... won't soon forgive myself, is all."
      Speaker = "Nemesis"
      Event = "NemesisPostTrueEnding01"
    }
    {
      Id = "Melinoe_5012"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress would only want for you to learn from it. I half-wonder if she let herself be taken just to get closer to our mark. Perhaps go speak with her...?"
      Speaker = "Melinoe"
      Event = "NemesisPostTrueEnding01"
    }
    {
      Id = "Nemesis_0408"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yeah. And what of Chronos, heard he isn't really dead and gone. How come everybody's cheering for you then?"
      Speaker = "Nemesis"
      Event = "NemesisPostTrueEnding01"
    }
    {
      Id = "Melinoe_5013"
      InheritFrom = "BaseNarrative"
      DisplayName = "He's dead and gone in the sense that we have neutralized the threat he posed. I now shall have to grow accustomed to having him as a grandfather, rather than a hated foe."
      Speaker = "Melinoe"
      Event = "NemesisPostTrueEnding01"
    }
    {
      Id = "Nemesis_0409"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't see why he can't be both. This was never part of the task, and not like you to stray from the objective. We sure this supposedly-neutralized Titan of Time is to be trusted?"
      Speaker = "Nemesis"
      Event = "NemesisPostTrueEnding01"
    }
    {
      Id = "Melinoe_5763"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress sealed his strongest powers just in case. At any rate... we did it, Nem!"
      Speaker = "Melinoe"
      Event = "NemesisPostTrueEnding01"
    }
    {
      Id = "Nemesis_0410"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then how come you look like you're headed out again? Heard there's still more Time-related business to sort out."
      Speaker = "Nemesis"
      Event = "NemesisPostTrueEnding01"
    }
    {
      Id = "Melinoe_5015"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well, yes, but..."
      Speaker = "Melinoe"
      Event = "NemesisPostTrueEnding01"
    }
    {
      Id = "Nemesis_0411"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Then we're {#Emph}not {#Prev}done."
      Speaker = "Nemesis"
      Event = "NemesisPostTrueEnding01"
    }
    {
      Id = "Nemesis_0414"
      InheritFrom = "BaseNarrative"
      DisplayName = "So you're still fighting Chronos, and you're still fighting Typhon... though, not just a matter of where, but a matter of {#Emph}when{#Prev}. Something like that?"
      Speaker = "Nemesis"
      Event = "NemesisPostTrueEnding02"
    }
    {
      Id = "Melinoe_5253"
      InheritFrom = "BaseNarrative"
      DisplayName = "Something like that. {#Emph}Our {#Prev}Chronos, who had let's say a spiritual awakening of sorts, is seeing to it that {#Emph}time flows freely forth{#Prev}, to use his expression. We wish to prevent even the possibility of what happened before."
      Speaker = "Melinoe"
      Event = "NemesisPostTrueEnding02"
    }
    {
      Id = "Nemesis_0415"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I don't get it. What happened before happened {#Emph}already. {#Prev}Time is a simple concept; keeps everything moving forward for {#Emph}everybody {#Prev}at the {#Emph}same exact rate."
      Speaker = "Nemesis"
      Event = "NemesisPostTrueEnding02"
    }
    {
      Id = "Melinoe_5254"
      InheritFrom = "BaseSubtitle"
      DisplayName = "There may be more to it than that, apparently."
      Speaker = "Melinoe"
      Event = "NemesisPostTrueEnding02"
    }
    {
      Id = "Nemesis_0416"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Everything's gotten so complicated..."
      Speaker = "Nemesis"
      Event = "NemesisPostTrueEnding02"
    }
    {
      Id = "Melinoe_5273"
      InheritFrom = "BaseNarrative"
      DisplayName = "Still sticking to the Underworld even with the task complete? There must be lots of catching up to do on the surface."
      Speaker = "Melinoe"
      Event = "NemesisPostTrueEnding03"
    }
    {
      Id = "Nemesis_0453"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hecate says conditions have to be {#Emph}just right {#Prev}for whatever it is you're trying to do now. Wouldn't want to throw anything off."
      Speaker = "Nemesis"
      Event = "NemesisPostTrueEnding03"
    }
    {
      Id = "Melinoe_5274"
      InheritFrom = "BaseNarrative"
      DisplayName = "Appreciate the help. It's just I thought you missed being up there, and mortalkind must miss you, too. A lot of undeservedness to be addressed."
      Speaker = "Melinoe"
      Event = "NemesisPostTrueEnding03"
    }
    {
      Id = "Nemesis_0454"
      InheritFrom = "BaseNarrative"
      DisplayName = "Keenly aware, thanks. I'll get back to it after the Underworld's in a better spot. Besides, I think your family's paying close attention to what's going on up there."
      Speaker = "Nemesis"
      Event = "NemesisPostTrueEnding03"
    }
    {
      Id = "Melinoe_5275"
      InheritFrom = "BaseSubtitle"
      DisplayName = "They probably are."
      Speaker = "Melinoe"
      Event = "NemesisPostTrueEnding03"
    }
    {
      Id = "Nemesis_0444"
      InheritFrom = "BaseNarrative"
      DisplayName = "Heard you snuffed another Typhon out last night. Well done, Princess. Things are handled in the Underworld, too, when it comes to {#Emph}time flowing freely forth {#Prev}and all that."
      Speaker = "Nemesis"
      Event = "NemesisPostTrueEndingTimeStopped01"
    }
    {
      Id = "Melinoe_5445"
      InheritFrom = "BaseNarrative"
      DisplayName = "Things are handled in the Underworld, {#Emph}how? {#Prev}Wait, you've been speaking with Grandfather Chronos, haven't you? Which means... no..."
      Speaker = "Melinoe"
      Event = "NemesisPostTrueEndingTimeStopped01"
    }
    {
      Id = "Nemesis_0445"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your grandfather did what you never could, and got me in the House of Hades. A remnant one of them, containing the old Chronos we were after all along. And I got him."
      Speaker = "Nemesis"
      Event = "NemesisPostTrueEndingTimeStopped01"
    }
    {
      Id = "Melinoe_5265"
      InheritFrom = "BaseNarrative"
      DisplayName = "You {#Emph}got {#Prev}him? Vanquished Chronos on your very first attempt? Impossible... even if you did prevail you'd most likely end up trapped for all eternity in a temporal rift..."
      Speaker = "Melinoe"
      Event = "NemesisPostTrueEndingTimeStopped01"
    }
    {
      Id = "Nemesis_0446"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Go ask your grandfather yourself sometime."
      Speaker = "Nemesis"
      Event = "NemesisPostTrueEndingTimeStopped01"
    }
    {
      Id = "Melinoe_5266"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're serious...!"
      Speaker = "Melinoe"
      Event = "NemesisPostTrueEndingTimeStopped01"
    }
    {
      Id = "Melinoe_5267"
      InheritFrom = "BaseNarrative"
      DisplayName = "You really did eliminate one of the Chronos remnants, Grandfather confirmed. That's... {#Emph}amazing{#Prev}, Nemesis. So then, if I focus my efforts on the Typhon remnants on Olympus..."
      Speaker = "Melinoe"
      Event = "NemesisPostTrueEndingTimeStopped02"
    }
    {
      Id = "Nemesis_0447"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I can deal with the Chronos remnants in the Underworld. Was planning on keeping that up no matter what. Hecate even gave me the all-clear."
      Speaker = "Nemesis"
      Event = "NemesisPostTrueEndingTimeStopped02"
    }
    {
      Id = "Melinoe_5268"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just, unbelievable. Though I still do reserve the right to deal with Chronos remnants on my own. If nothing else, that route gives me an opportunity to see my family."
      Speaker = "Melinoe"
      Event = "NemesisPostTrueEndingTimeStopped02"
    }
    {
      Id = "Nemesis_0448"
      InheritFrom = "BaseNarrative"
      DisplayName = "Knock yourself out. I get the impression there are more than enough of those {#Emph}potential Chronos remnants {#Prev}out there for the both of us."
      Speaker = "Nemesis"
      Event = "NemesisPostTrueEndingTimeStopped02"
    }
    {
      Id = "Melinoe_5269"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well let's go get them."
      Speaker = "Melinoe"
      Event = "NemesisPostTrueEndingTimeStopped02"
    }
    {
      Id = "Nemesis_0449"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Let's."
      Speaker = "Nemesis"
      Event = "NemesisPostTrueEndingTimeStopped02"
    }
    {
      Id = "Nemesis_0450"
      InheritFrom = "BaseNarrative"
      DisplayName = "Heard you found the Three Fates. Don't believe that's how it happened. Probably weren't even looking. They found {#Emph}you."
      Speaker = "Nemesis"
      Event = "NemesisPostEpilogue01"
    }
    {
      Id = "Melinoe_5270"
      InheritFrom = "BaseNarrative"
      DisplayName = "That is a distinct possibility. Perhaps when Chronos thought he sent them into exile, they merely played along. And now decided to check in after the troubles with him passed."
      Speaker = "Melinoe"
      Event = "NemesisPostEpilogue01"
    }
    {
      Id = "Nemesis_0451"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sure sounds like something they'd do. But no use speculating, right? And what now, we're all back to having no will of our own? Maybe we never did."
      Speaker = "Nemesis"
      Event = "NemesisPostEpilogue01"
    }
    {
      Id = "Melinoe_5271"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps they don't want us to be certain either way. Nor do they seem to desire all the credit for the actions we take."
      Speaker = "Melinoe"
      Event = "NemesisPostEpilogue01"
    }
    {
      Id = "Nemesis_0452"
      InheritFrom = "BaseNarrative"
      DisplayName = "Guess we'd better act like we have everything under control."
      Speaker = "Nemesis"
      Event = "NemesisPostEpilogue01"
    }
    {
      Id = "Melinoe_5272"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What else can we do?"
      Speaker = "Melinoe"
      Event = "NemesisPostEpilogue01"
    }
    {
      Id = "Nemesis_0067"
      InheritFrom = "BaseNarrative"
      DisplayName = "Look at him, all peaceful. Not a care in the world. Could you imagine?"
      Speaker = "Nemesis"
      Event = "NemesisWithHypnos01"
    }
    {
      Id = "Melinoe_0681"
      InheritFrom = "BaseNarrative"
      DisplayName = "He's beautiful. He has this wisdom about him, even asleep. Nyx must have taught you all so much."
      Speaker = "Melinoe"
      Event = "NemesisWithHypnos01"
    }
    {
      Id = "Nemesis_0068"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not really. Hypnos served in the House of Hades under Mother's care. Ran into him now and then, though. He ever wakes up, hope I can be there when you finally meet."
      Speaker = "Nemesis"
      Event = "NemesisWithHypnos01"
    }
    {
      Id = "Melinoe_0682_B"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thank you, Nem..."
      Speaker = "Melinoe"
      Event = "NemesisWithHypnos01"
    }
    {
      Id = "Hecate_0205"
      InheritFrom = "BaseNarrative"
      DisplayName = "You are required at your post, Nemesis. Or shall you take to openly defying me just as your sister does? I shudder to think what your mother would say of you two."
      Speaker = "Hecate"
      Event = "NemesisWithHecate01"
    }
    {
      Id = "Nemesis_0055"
      InheritFrom = "BaseNarrative"
      DisplayName = "...You have no right to invoke my mother. None of this would be happening had you fulfilled your role as Handmaiden, and warned her an attack was imminent."
      Speaker = "Nemesis"
      Event = "NemesisWithHecate01"
    }
    {
      Id = "Hecate_0206"
      InheritFrom = "BaseNarrative"
      DisplayName = "Best watch your mouth or I shall seal it shut! You may continue dwelling on a past you were not witness to, or you may do what is expected of Nyx's daughters. Or whatever Eris is up to! Your choice."
      Speaker = "Hecate"
      Event = "NemesisWithHecate01"
    }
    {
      Id = "Nemesis_0056"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}<Sigh>"
      Speaker = "Nemesis"
      Event = "NemesisWithHecate01"
    }
    {
      Id = "Hecate_0868"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Insubordination, dereliction of duty, falsehood, intimidation, obstinance, simply setting a negative example for the Shades... anything else, would you say?"
      Speaker = "Hecate"
      Event = "NemesisWithHecate02"
    }
    {
      Id = "Nemesis_0417"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Indulgence, callousness, negligence. Hecate, I... Headmistress, I accept your judgment, and I have no excuses for my deeds."
      Speaker = "Nemesis"
      Event = "NemesisWithHecate02"
    }
    {
      Id = "Hecate_0869"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well thank the Fates that you would spare me that, at least. Now then, with Nyx returned I ought petition her to take you back. Surely the House of Hades could use another hand?"
      Speaker = "Hecate"
      Event = "NemesisWithHecate02"
    }
    {
      Id = "Nemesis_0418"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Don't. You know as well as I my place is here. But I'm Retribution Incarnate... I'm not here only to stand guard."
      Speaker = "Nemesis"
      Event = "NemesisWithHecate02"
    }
    {
      Id = "Hecate_0870"
      InheritFrom = "BaseNarrative"
      DisplayName = "Clearly. Much retribution is to come, both above and below in these changing times... and you shall administer it in accordance with Night's will, when and wheresoever you see fit."
      Speaker = "Hecate"
      Event = "NemesisWithHecate02"
    }
    {
      Id = "Nemesis_0419"
      InheritFrom = "BaseNarrative"
      DisplayName = "Retribution whenever and wherever I see fit... you're letting me proceed? What have I done to deserve that?"
      Speaker = "Nemesis"
      Event = "NemesisWithHecate02"
    }
    {
      Id = "Hecate_0871"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nemesis, you hold such answers, not I. Now go, and see to our collective charge that time flows freely forth."
      Speaker = "Hecate"
      Event = "NemesisWithHecate02"
    }
    {
      Id = "Nemesis_0420"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Consider it done, Headmistress."
      Speaker = "Nemesis"
      Event = "NemesisWithHecate02"
    }
    {
      Id = "Nemesis_0040"
      InheritFrom = "BaseNarrative"
      DisplayName = "...And there she is! Shouldn't you be halfway down to Tartarus by now?"
      Speaker = "Nemesis"
      Event = "NemesisWithMoros01"
    }
    {
      Id = "Moros_0065"
      InheritFrom = "BaseNarrative"
      DisplayName = "Princess. Thank the Fates you're well. Nemesis and I, we were just catching up. She's told me a lot about you."
      Speaker = "Moros"
      Event = "NemesisWithMoros01"
    }
    {
      Id = "Melinoe_0906"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, great. I can imagine! Though, you never told me about your brother, Nemesis..."
      Speaker = "Melinoe"
      Event = "NemesisWithMoros01"
    }
    {
      Id = "Nemesis_0041"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got a lot of brothers. What's to tell? Never a good sign when he shows up."
      Speaker = "Nemesis"
      Event = "NemesisWithMoros01"
    }
    {
      Id = "Moros_0066"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm afraid she's right."
      Speaker = "Moros"
      Event = "NemesisWithMoros01"
    }
    {
      Id = "Nemesis_0232"
      InheritFrom = "BaseNarrative"
      DisplayName = "...It's my job, Moros. Simple as that. No one else wants to do it. No one else {#Emph}can {#Prev}do it."
      Speaker = "Nemesis"
      Event = "NemesisWithMoros02"
    }
    {
      Id = "Moros_0331"
      InheritFrom = "BaseNarrative"
      DisplayName = "But the retribution you see fit to dole out... how can you be so certain that decisions about such consequences are yours alone? {#Emph}The Fates {#Prev}have quite a bit of say in it as well."
      Speaker = "Moros"
      Event = "NemesisWithMoros02"
    }
    {
      Id = "Nemesis_0233"
      InheritFrom = "BaseNarrative"
      DisplayName = "What, you think I'm just another mindless puppet our sisters are pushing around? Come on! Their prophecies are vague because they don't really know what's coming."
      Speaker = "Nemesis"
      Event = "NemesisWithMoros02"
    }
    {
      Id = "Moros_0332"
      InheritFrom = "BaseNarrative"
      DisplayName = "Even if that were true, the burden of choosing who deserves what... I wouldn't want to bear it on my own. Otherwise my judgment would have to be perfect at all times; yet we are fallible beings."
      Speaker = "Moros"
      Event = "NemesisWithMoros02"
    }
    {
      Id = "Nemesis_0234"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Speak for yourself."
      Speaker = "Nemesis"
      Event = "NemesisWithMoros02"
    }
    {
      Id = "Moros_0333"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I was..."
      Speaker = "Moros"
      Event = "NemesisWithMoros02"
    }
    {
      Id = "Moros_0334"
      InheritFrom = "BaseNarrative"
      DisplayName = "Quite a predicament we find ourselves in, Sister. Certainly not one I could have anticipated when first I arrived. How odd... so what are we to do? It's not my wish to interfere."
      Speaker = "Moros"
      Event = "NemesisWithMorosAboutRelationships01"
    }
    {
      Id = "Nemesis_0235"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't worry about that, worry about keeping your mouth shut when she's walking up on us. All casual like she doesn't know what's going on."
      Speaker = "Nemesis"
      Event = "NemesisWithMorosAboutRelationships01"
    }
    {
      Id = "Melinoe_3241"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wait, what {#Emph}is {#Prev}going on? What are you two talking about, if I may ask?"
      Speaker = "Melinoe"
      Event = "NemesisWithMorosAboutRelationships01"
    }
    {
      Id = "Nemesis_0236"
      InheritFrom = "BaseNarrative"
      DisplayName = "Talking about {#Emph}you{#Prev}, Princess, though it's nothing you need to worry your {#Emph}pretty little head {#Prev}about. You've got enough going on, and... we can sort this out ourselves. If you'll excuse us?"
      Speaker = "Nemesis"
      Event = "NemesisWithMorosAboutRelationships01"
    }
    {
      Id = "Moros_0335"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wait. No, I would prefer to be forthright. Princess, the issue is we each developed certain feelings for you that, in some cases, can manifest as the kind of envy that Nemesis is committed to punishing. An outcome we are trying to avoid."
      Speaker = "Moros"
      Event = "NemesisWithMorosAboutRelationships01"
    }
    {
      Id = "Melinoe_3242"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh! {#Prev}I... I see. Thank you for letting me know. I would never want to hurt either of you. Well maybe {#Emph}you{#Prev}, Nemesis, but only when we spar. How do we resolve this? Our feelings mustn't get in our way."
      Speaker = "Melinoe"
      Event = "NemesisWithMorosAboutRelationships01"
    }
    {
      Id = "Nemesis_0237"
      InheritFrom = "BaseNarrative"
      DisplayName = "They won't get in our way. And besides, you're busy, not like you were going to devote yourself to one of us, body and soul. Like some mortal that doesn't know any better."
      Speaker = "Nemesis"
      Event = "NemesisWithMorosAboutRelationships01"
    }
    {
      Id = "Melinoe_3243"
      InheritFrom = "BaseNarrative"
      DisplayName = "Certainly not... why should I or any of us have to choose? We're gods. If you wish to know me better, wonderful. But please accept that I won't let myself be bound to anyone, nor would I expect any different from you. Are we clear?"
      Speaker = "Melinoe"
      Event = "NemesisWithMorosAboutRelationships01"
    }
    {
      Id = "Nemesis_0238"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Yeah."
      Speaker = "Nemesis"
      Event = "NemesisWithMorosAboutRelationships01"
    }
    {
      Id = "Moros_0336"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yes, we are."
      Speaker = "Moros"
      Event = "NemesisWithMorosAboutRelationships01"
    }
    {
      Id = "Nemesis_0239"
      InheritFrom = "BaseNarrative"
      DisplayName = "...No. One last thing, Eris. Hecate might have promised Mother she'd look after you, but I did no such thing. So get out of here before I get upset."
      Speaker = "Nemesis"
      Event = "NemesisWithEris01"
    }
    {
      Id = "Eris_0108"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh please, Nemmie, you're already upset! And I'll come and go as I like, thanks. So damn boring here I can't stand it for long anyways."
      Speaker = "Eris"
      Event = "NemesisWithEris01"
    }
    {
      Id = "Nemesis_0240"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Come and go as you like? {#Prev}You're jeopardizing the task. Don't be such a child."
      Speaker = "Nemesis"
      Event = "NemesisWithEris01"
    }
    {
      Id = "Eris_0109"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Don't be such a child. {#Prev}Waitwaitwait... does that make you my {#Emph}mom? {#Prev}I never answered to Nyx. Think I'm about to start with {#Emph}you?"
      Speaker = "Eris"
      Event = "NemesisWithEris01"
    }
    {
      Id = "Nemesis_0241"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You'll get what's coming to you either way."
      Speaker = "Nemesis"
      Event = "NemesisWithEris01"
    }
    {
      Id = "Eris_0110"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ooh! {#Prev}A threat!"
      Speaker = "Eris"
      Event = "NemesisWithEris01"
    }
    {
      Id = "Eris_0111"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}...Yeah? {#Prev}And just what do you think you're gonna do about it, there, Nemmie? Can't just have it out with me in the middle of your little {#Emph}Crossroads."
      Speaker = "Eris"
      Event = "NemesisWithEris02"
    }
    {
      Id = "Nemesis_0242"
      InheritFrom = "BaseNarrative"
      DisplayName = "Can't do anything about it {#Emph}here. {#Prev}But might run into you out there, snooping around. And then you won't get any special treatment. Just another target."
      Speaker = "Nemesis"
      Event = "NemesisWithEris02"
    }
    {
      Id = "Eris_0112"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Heh! {#Prev}Nemesis, how could you be so cruel? You're my {#Emph}sister! {#Prev}We don't have to {#Emph}fight! {#Prev}And besides, what makes you think you'd ever {#Emph}catch {#Prev}me? You're too {#Emph}slow."
      Speaker = "Eris"
      Event = "NemesisWithEris02"
    }
    {
      Id = "Nemesis_0243"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We'll see."
      Speaker = "Nemesis"
      Event = "NemesisWithEris02"
    }
    {
      Id = "Eris_0113"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}You'll {#Prev}see."
      Speaker = "Eris"
      Event = "NemesisWithEris02"
    }
    {
      Id = "Nemesis_0437"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I know these things, kid. As mortal lives go, yours was in one of the bottom categories. A lot shorter and more miserable than average. So you're making up for it a bit."
      Speaker = "Nemesis"
      Event = "NemesisWithIcarus01"
    }
    {
      Id = "Icarus_0478"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Erm{#Prev}, so you're saying, Goddess, that I'm to have a better life after death because my life {#Emph}before {#Prev}death was in {#Emph}one of the bottom categories {#Prev}according to some ranking system that you have... hey?"
      Speaker = "Icarus"
      Event = "NemesisWithIcarus01"
    }
    {
      Id = "Nemesis_0438"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's right. Don't waste it, don't get greedy, you'll be fine. Just keep doing what you're doing."
      Speaker = "Nemesis"
      Event = "NemesisWithIcarus01"
    }
    {
      Id = "Icarus_0479"
      InheritFrom = "BaseNarrative"
      DisplayName = "But... I'm so fortunate to be here with you all. A short life in exchange for a good eternity, by your reasoning that isn't a fair trade. What have I done to deserve {#Emph}this...?"
      Speaker = "Icarus"
      Event = "NemesisWithIcarus01"
    }
    {
      Id = "Nemesis_0439"
      InheritFrom = "BaseNarrative"
      DisplayName = "You haven't asked too many questions, for one thing. And don't take eternity for granted."
      Speaker = "Nemesis"
      Event = "NemesisWithIcarus01"
    }
    {
      Id = "Icarus_0480"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I won't. I swear."
      Speaker = "Icarus"
      Event = "NemesisWithIcarus01"
    }
    {
      Id = "Nemesis_0003"
      InheritFrom = "BaseNarrative"
      DisplayName = "Mortals must be thinking they can get away with anything lately..."
      Speaker = "Nemesis"
      Event = "NemesisChat01"
    }
    {
      Id = "Nemesis_0006"
      InheritFrom = "BaseNarrative"
      DisplayName = "Awful busy standing guard as you can see."
      Speaker = "Nemesis"
      Event = "NemesisChat02"
    }
    {
      Id = "Nemesis_0004"
      InheritFrom = "BaseNarrative"
      DisplayName = "So much evil happening out there, unchecked..."
      Speaker = "Nemesis"
      Event = "NemesisChat03"
    }
    {
      Id = "Nemesis_0010"
      InheritFrom = "BaseNarrative"
      DisplayName = "Go on. That task of yours isn't going to complete itself."
      Speaker = "Nemesis"
      Event = "NemesisChat04"
    }
    {
      Id = "Nemesis_0005"
      InheritFrom = "BaseNarrative"
      DisplayName = "Could've been topside right now, bringing down what's rightfully deserved..."
      Speaker = "Nemesis"
      Event = "NemesisChat05"
    }
    {
      Id = "Nemesis_0007"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not going anywhere, so go on and do your {#Emph}task."
      Speaker = "Nemesis"
      Event = "NemesisChat06"
    }
    {
      Id = "Nemesis_0008"
      InheritFrom = "BaseNarrative"
      DisplayName = "We all get what we deserve. No more, no less."
      Speaker = "Nemesis"
      Event = "NemesisChat07"
    }
    {
      Id = "Nemesis_0009"
      InheritFrom = "BaseNarrative"
      DisplayName = "Missed all the excitement while you were out."
      Speaker = "Nemesis"
      Event = "NemesisChat08"
    }
    {
      Id = "Nemesis_0012"
      InheritFrom = "BaseNarrative"
      DisplayName = "Go knock yourself out. I'll be right here."
      Speaker = "Nemesis"
      Event = "NemesisChat09"
    }
    {
      Id = "Nemesis_0013"
      InheritFrom = "BaseNarrative"
      DisplayName = "Excuse me, I'm on duty still, as you can see."
      Speaker = "Nemesis"
      Event = "NemesisChat10"
    }
    {
      Id = "Nemesis_0014"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ungh, {#Prev}what did I ever do to deserve this..."
      Speaker = "Nemesis"
      Event = "NemesisChat11"
    }
    {
      Id = "Nemesis_0015"
      InheritFrom = "BaseNarrative"
      DisplayName = "Back on the beat again already there, Princess?"
      Speaker = "Nemesis"
      Event = "NemesisChat12"
    }
    {
      Id = "Nemesis_0016"
      InheritFrom = "BaseNarrative"
      DisplayName = "Go crack some skulls for me, they have it coming."
      Speaker = "Nemesis"
      Event = "NemesisChat13"
    }
    {
      Id = "Nemesis_0017"
      InheritFrom = "BaseNarrative"
      DisplayName = "Can only imagine what you've been up to out there."
      Speaker = "Nemesis"
      Event = "NemesisChat14"
    }
    {
      Id = "Nemesis_0018"
      InheritFrom = "BaseNarrative"
      DisplayName = "Counting on you not to get too greedy out there."
      Speaker = "Nemesis"
      Event = "NemesisChat15"
    }
    {
      Id = "Nemesis_0019"
      InheritFrom = "BaseNarrative"
      DisplayName = "Better get your scrawny ass back out there huh?"
      Speaker = "Nemesis"
      Event = "NemesisChat16"
    }
    {
      Id = "Nemesis_0020"
      InheritFrom = "BaseNarrative"
      DisplayName = "Go cry to your Headmistress Hecate. She's right there."
      Speaker = "Nemesis"
      Event = "NemesisChat17"
    }
    {
      Id = "Nemesis_0021"
      InheritFrom = "BaseNarrative"
      DisplayName = "The ways of the Witch of the Crossroads can only take you so far."
      Speaker = "Nemesis"
      Event = "NemesisChat18"
    }
    {
      Id = "Nemesis_0022"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sooner or later, everything always comes full circle, Princess."
      Speaker = "Nemesis"
      Event = "NemesisChat19"
    }
    {
      Id = "Nemesis_0023"
      InheritFrom = "BaseNarrative"
      DisplayName = "You were topside for a while there, huh..."
      Speaker = "Nemesis"
      Event = "NemesisChat20"
    }
    {
      Id = "Nemesis_0024"
      InheritFrom = "BaseNarrative"
      DisplayName = "Gone so long that time, figured you lost your way."
      Speaker = "Nemesis"
      Event = "NemesisChat21"
    }
    {
      Id = "Nemesis_0025"
      InheritFrom = "BaseNarrative"
      DisplayName = "All the way back, just to lick your wounds and go again?"
      Speaker = "Nemesis"
      Event = "NemesisChat22"
    }
    {
      Id = "Nemesis_0026"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thought for sure you would have given up by now."
      Speaker = "Nemesis"
      Event = "NemesisChat23"
    }
    {
      Id = "Nemesis_0027"
      InheritFrom = "BaseNarrative"
      DisplayName = "All's quiet in the Crossroads, for the thousandth time..."
      Speaker = "Nemesis"
      Event = "NemesisChat24"
    }
    {
      Id = "Nemesis_0028"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just going to keep putting yourself through this, huh."
      Speaker = "Nemesis"
      Event = "NemesisChat25"
    }
    {
      Id = "Nemesis_0029"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got the pointless guard duty well under control."
      Speaker = "Nemesis"
      Event = "NemesisChat26"
    }
    {
      Id = "Nemesis_0030"
      InheritFrom = "BaseNarrative"
      DisplayName = "Go on, you've got more important things to do than talk to me."
      Speaker = "Nemesis"
      Event = "NemesisChat27"
    }
    {
      Id = "Nemesis_0031"
      InheritFrom = "BaseNarrative"
      DisplayName = "Want to take over for me, go right ahead."
      Speaker = "Nemesis"
      Event = "NemesisChat28"
    }
    {
      Id = "Nemesis_0032"
      InheritFrom = "BaseNarrative"
      DisplayName = "Find Chronos, kill Chronos. Go."
      Speaker = "Nemesis"
      Event = "NemesisChat29"
    }
    {
      Id = "Nemesis_0033"
      InheritFrom = "BaseNarrative"
      DisplayName = "Death to Chronos, Princess."
      Speaker = "Nemesis"
      Event = "NemesisChat30"
    }
    {
      Id = "Nemesis_0011"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ready to give up, tell Hecate I'm still available."
      Speaker = "Nemesis"
      Event = "NemesisChat31"
    }
    {
      Id = "MelinoeField_0022"
      InheritFrom = "BaseNarrative"
      DisplayName = "Here, Nemesis! To your willful disobedience. May those instincts of yours never lead you astray."
      Speaker = "Melinoe"
      Event = "NemesisGiftDecline01"
    }
    {
      Id = "NemesisField_0024"
      InheritFrom = "BaseNarrative"
      DisplayName = "Really think this is the perfect time for us to just kick back and have a few laughs over a nice bottle? Like I got nothing better to do right now."
      Speaker = "Nemesis"
      Event = "NemesisGiftDecline01"
    }
    {
      Id = "Melinoe_0685"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nemesis? Maybe we could start again. Here, I got you something..."
      Speaker = "Melinoe"
      Event = "NemesisGift01"
    }
    {
      Id = "Nemesis_0095"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't need your charity, Princess, or temptations while I'm on duty or off. You're doing this because you want something from me anyway, so here! Knock yourself out."
      Speaker = "Nemesis"
      Event = "NemesisGift01"
    }
    {
      Id = "Nemesis_0096"
      InheritFrom = "BaseNarrative"
      DisplayName = "You trying to get me in trouble with Hecate or something? Why don't you take your bottle before I smash it, and get your scrawny ass out of here."
      Speaker = "Nemesis"
      Event = "NemesisGift02"
    }
    {
      Id = "Melinoe_0627"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wasn't trying to get you in trouble, Nem, I was just... {#Emph}ungh{#Prev}. You know what, forget it."
      Speaker = "Melinoe"
      Event = "NemesisGift02"
    }
    {
      Id = "Nemesis_0097"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, for me? Can't find another way to test one of your poisons, I guess. You witches aren't as subtle as you think."
      Speaker = "Nemesis"
      Event = "NemesisGift03"
    }
    {
      Id = "Melinoe_0628"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's exactly what someone who was unknowingly poisoned by a witch might say, you know."
      Speaker = "Melinoe"
      Event = "NemesisGift03"
    }
    {
      Id = "Nemesis_0163"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ugh."
      Speaker = "Nemesis"
      Event = "NemesisGift03"
    }
    {
      Id = "Nemesis_0145"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh no, not this again. Look, I forgave you for last time. Didn't mean it as an invitation to get me more of this stuff. Don't like owing anybody any favors."
      Speaker = "Nemesis"
      Event = "NemesisGift04"
    }
    {
      Id = "Melinoe_2097"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just take it and enjoy it, Nem. Besides, I heard you were looking for some more of our witches' poison. Nobody seems to appreciate it quite like you."
      Speaker = "Melinoe"
      Event = "NemesisGift04"
    }
    {
      Id = "Nemesis_0098"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why do you keep doing this? You won, OK? You beat me. Before you even started. Last thing I need now is your sympathy."
      Speaker = "Nemesis"
      Event = "NemesisGift05"
    }
    {
      Id = "Melinoe_0629"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nemesis... I don't know what I'm supposed to do. We're surrounded by enemies out there. Do we really need more?"
      Speaker = "Melinoe"
      Event = "NemesisGift05"
    }
    {
      Id = "Nemesis_0099"
      InheritFrom = "BaseNarrative"
      DisplayName = "...You're not my enemy, Melinoë. I just... Just go."
      Speaker = "Nemesis"
      Event = "NemesisGift05"
    }
    {
      Id = "Melinoe_2250"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Bye, Nem..."
      Speaker = "Melinoe"
      Event = "NemesisGift05"
    }
    {
      Id = "Nemesis_0311"
      InheritFrom = "BaseNarrative"
      DisplayName = "Suggest you quit it with these Nectars soon. Can't have too much of a good thing. Should know that about me by now."
      Speaker = "Nemesis"
      Event = "NemesisGift06"
    }
    {
      Id = "Melinoe_4430"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sure, you can't have too much of a good thing anymore than anybody else. Though, what would happen if you did? You'd need to punish yourself?"
      Speaker = "Melinoe"
      Event = "NemesisGift06"
    }
    {
      Id = "Nemesis_0312"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yeah. And don't you dare act like you wouldn't do the same. One thing I'll grant Hecate is she does value discipline. Sometimes we have to discipline ourselves."
      Speaker = "Nemesis"
      Event = "NemesisGift06"
    }
    {
      Id = "Melinoe_4431"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We have to take care of ourselves, too."
      Speaker = "Melinoe"
      Event = "NemesisGift06"
    }
    {
      Id = "Melinoe_4432"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know you dislike excesses of any kind, though I don't think one more Ambrosia bottle's going to tip the scales for you, is it, Nem?"
      Speaker = "Melinoe"
      Event = "NemesisGift07"
    }
    {
      Id = "Nemesis_0313"
      InheritFrom = "BaseNarrative"
      DisplayName = "It might. Won't go to the taverna to find out, so why don't you take it back. Not really the time for luxuries."
      Speaker = "Nemesis"
      Event = "NemesisGift07"
    }
    {
      Id = "Melinoe_4433"
      InheritFrom = "BaseNarrative"
      DisplayName = "How about you hold onto it until whenever you feel it's deserved. If you're not indulging, you don't need to be concerned about it, right?"
      Speaker = "Melinoe"
      Event = "NemesisGift07"
    }
    {
      Id = "Nemesis_0314"
      InheritFrom = "BaseNarrative"
      DisplayName = "Want to waste something like this, fine. But it's just going in a stash, and probably will never see what little light we get. Long as you're good with that."
      Speaker = "Nemesis"
      Event = "NemesisGift07"
    }
    {
      Id = "Melinoe_4434"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I am."
      Speaker = "Melinoe"
      Event = "NemesisGift07"
    }
    {
      Id = "Melinoe_4435"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thought I'd bring you something extra for your never-to-be-used stash, Nemesis. Because you might deserve it at some point, you never know."
      Speaker = "Melinoe"
      Event = "NemesisGift08"
    }
    {
      Id = "Nemesis_0315"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}You {#Prev}never know. What makes you even think I might deserve something like this? Not exactly been at the top of my field lately."
      Speaker = "Nemesis"
      Event = "NemesisGift08"
    }
    {
      Id = "Melinoe_4436"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well I am not the arbiter of such matters of course, but I think you {#Emph}do {#Prev}deserve it. You must be harder on yourself than anyone. If only you could see yourself as I do sometime."
      Speaker = "Melinoe"
      Event = "NemesisGift08"
    }
    {
      Id = "Nemesis_0316"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't know what {#Emph}that's {#Prev}supposed to mean. We were going for the same result, and both pushed hard. So what. But anyway, into the stash this goes."
      Speaker = "Nemesis"
      Event = "NemesisGift08"
    }
    {
      Id = "Melinoe_4437"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Where it belongs."
      Speaker = "Melinoe"
      Event = "NemesisGift08"
    }
    {
      Id = "Nemesis_0317"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ambrosia. Look, you should know my never-to-be-used stash is just about full. Wouldn't want for it to overflow."
      Speaker = "Nemesis"
      Event = "NemesisGift09"
    }
    {
      Id = "Melinoe_4438"
      InheritFrom = "BaseNarrative"
      DisplayName = "You could always invite me to the taverna where we might cut into that stash of yours a bit. Why hoard it forever? Besides the reasons that you previously said."
      Speaker = "Melinoe"
      Event = "NemesisGift09"
    }
    {
      Id = "Nemesis_0318"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not going to invite you anywhere long as you keep this up. And I don't appreciate you making light of the subject of avoiding excess. My area of expertise. Not yours."
      Speaker = "Nemesis"
      Event = "NemesisGift09"
    }
    {
      Id = "Melinoe_4439"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm sorry, Nemesis, I wasn't aiming to be rude; words I cannot entirely believe I'm saying, much less feeling, since we used to trade barbs all the time."
      Speaker = "Melinoe"
      Event = "NemesisGift09"
    }
    {
      Id = "Nemesis_0319"
      InheritFrom = "BaseNarrative"
      DisplayName = "Things sure were nice and simple then, weren't they. But now we're stuck in whatever pattern this is, till we break free, and we're doing that now. No more Ambrosia. Ever."
      Speaker = "Nemesis"
      Event = "NemesisGift09"
    }
    {
      Id = "Melinoe_4440"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Ever? What about Bath Salts?"
      Speaker = "Melinoe"
      Event = "NemesisGift09"
    }
    {
      Id = "Nemesis_0320"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}<Chuckle>"
      Speaker = "Nemesis"
      Event = "NemesisGift09"
    }
    {
      Id = "Melinoe_3354"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, I know there's an extraordinary likelihood you're going to say {#Emph}no{#Prev}, but... I've an extra-special poison bottle here, and thought maybe we could split it at the taverna, you and I?"
      Speaker = "Melinoe"
      Event = "NemesisTaverna01"
    }
    {
      Id = "Nemesis_0146"
      InheritFrom = "BaseNarrative"
      DisplayName = "So damn polite! Well, it's less excessive if we split the bottle, I guess... {#Emph}ungh{#Prev}, you know what? Whatever, sure."
      Speaker = "Nemesis"
      Event = "NemesisTaverna01"
    }
    {
      Id = "Nemesis_0147"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Come on, say it: Got your ass kicked. By me. Think that was when I first thought I had a chance. That Hecate would pick me. If I could take you just like that a few more times."
      Speaker = "Nemesis"
      Event = "NemesisTaverna01"
    }
    {
      Id = "Melinoe_2099"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're a monster, Nem! I practically started to fear having to spar with you. But, the best way to get stronger is to train against a stronger opponent."
      Speaker = "Melinoe"
      Event = "NemesisTaverna01"
    }
    {
      Id = "Nemesis_0148"
      InheritFrom = "BaseNarrative"
      DisplayName = "Maybe that's why I've been stagnating. We don't get to fight like we used to. Makes me sick even thinking about it."
      Speaker = "Nemesis"
      Event = "NemesisTaverna01"
    }
    {
      Id = "Melinoe_2100"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wait... you stand around thinking about how we used to spar? Should I be flattered or afraid?"
      Speaker = "Melinoe"
      Event = "NemesisTaverna01"
    }
    {
      Id = "Nemesis_0149"
      InheritFrom = "BaseNarrative"
      DisplayName = "Finish your half of the damn poison already! Don't have all night to sit around and stroke your ego. I swear, mortals take after our worst qualities."
      Speaker = "Nemesis"
      Event = "NemesisTaverna01"
    }
    {
      Id = "Melinoe_2101"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wasn't being serious. Though, maybe I'm more self-centered than I realize. I {#Emph}am {#Prev}part-mortal on my mother's side..."
      Speaker = "Melinoe"
      Event = "NemesisTaverna01"
    }
    {
      Id = "Nemesis_0150"
      InheritFrom = "BaseNarrative"
      DisplayName = "Makes you different, I will give you that. Now come on, I got to get back. Else Hecate might catch us making nice and then neither one of us will hear the end of it."
      Speaker = "Nemesis"
      Event = "NemesisTaverna01"
    }
    {
      Id = "Nemesis_0151"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Can feel the poison starting to kick in. You'd better get your ass out of here before I keel over."
      Speaker = "Nemesis"
      Event = "NemesisTaverna01"
    }
    {
      Id = "Melinoe_2102"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It'll be our secret."
      Speaker = "Melinoe"
      Event = "NemesisTaverna01"
    }
    {
      Id = "Melinoe_3104"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nemesis, we've been going on like this a while, and I wondered if you'd be up to take a break. Over at the Springs."
      Speaker = "Melinoe"
      Event = "NemesisBathHouse01"
    }
    {
      Id = "Nemesis_0203"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hm. {#Prev}Come to think, could really use a bath. {#Emph}You{#Prev}, I mean. But I could too, I guess, so... why not."
      Speaker = "Nemesis"
      Event = "NemesisBathHouse01"
    }
    {
      Id = "Melinoe_3105"
      InheritFrom = "BaseNarrative"
      DisplayName = "How long has it been since you last took off the armor?"
      Speaker = "Melinoe"
      Event = "NemesisBathHouse01"
    }
    {
      Id = "Nemesis_0213"
      InheritFrom = "BaseNarrative"
      DisplayName = "A while. Not been much incentive. You saw how much of a pain it is to undo the lacing, and the straps. Feels strange without, like I'm... I... I don't know."
      Speaker = "Nemesis"
      Event = "NemesisBathHouse01"
    }
    {
      Id = "Melinoe_3106"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Unburdened? Or more comfortable at least?"
      Speaker = "Melinoe"
      Event = "NemesisBathHouse01"
    }
    {
      Id = "Nemesis_0214"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Heh. {#Prev}Good letting off some steam sometimes, I guess. But there's a fine line between rest and complacency."
      Speaker = "Nemesis"
      Event = "NemesisBathHouse01"
    }
    {
      Id = "Melinoe_3107"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't know that we're at risk of becoming complacent here, Nem."
      Speaker = "Melinoe"
      Event = "NemesisBathHouse01"
    }
    {
      Id = "Nemesis_0215"
      InheritFrom = "BaseNarrative"
      DisplayName = "The risk is greater than you think. We're lounging in a bath while who-knows-what is going on out there..."
      Speaker = "Nemesis"
      Event = "NemesisBathHouse01"
    }
    {
      Id = "Melinoe_3108"
      InheritFrom = "BaseNarrative"
      DisplayName = "We're not lounging. We'll be better equipped to deal with the who-knows-what out there if our muscles aren't all knotted up."
      Speaker = "Melinoe"
      Event = "NemesisBathHouse01"
    }
    {
      Id = "Nemesis_0217"
      InheritFrom = "BaseNarrative"
      DisplayName = "All right, got to get back to work. Though, this suit does feel a little lighter now..."
      Speaker = "Nemesis"
      Event = "NemesisBathHouse01"
    }
    {
      Id = "Melinoe_3109"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Take care, Nem."
      Speaker = "Melinoe"
      Event = "NemesisBathHouse01"
    }
    {
      Id = "Melinoe_3110"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey Nem, are you available to make another visit to the springs? Take a load off, come back to our senses a bit..."
      Speaker = "Melinoe"
      Event = "NemesisBathHouse02"
    }
    {
      Id = "Nemesis_0204"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Eh. {#Prev}Shoulder's been acting up again, could be it helps with that. Don't like having to take the suit off, but that's the trade."
      Speaker = "Nemesis"
      Event = "NemesisBathHouse02"
    }
    {
      Id = "Nemesis_0218"
      InheritFrom = "BaseNarrative"
      DisplayName = "First time you beat me in a fight? {#Emph}Sparring match{#Prev}, whatever. Got me right in the back of the neck. Took advantage of our height difference. Was a surprise."
      Speaker = "Nemesis"
      Event = "NemesisBathHouse02"
    }
    {
      Id = "Melinoe_3111"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd lost to you so often, at some point I figured I could lull you into overconfidence. That even you could be susceptible to such a thing."
      Speaker = "Melinoe"
      Event = "NemesisBathHouse02"
    }
    {
      Id = "Nemesis_0219"
      InheritFrom = "BaseNarrative"
      DisplayName = "You weren't wrong. Made me so {#Emph}angry. {#Prev}Swore I'd never underestimate my opponent again. Then proceeded to convince myself you'd never beat me at the task. {#Emph}Our {#Prev}task."
      Speaker = "Nemesis"
      Event = "NemesisBathHouse02"
    }
    {
      Id = "Melinoe_3112"
      InheritFrom = "BaseNarrative"
      DisplayName = "So you've a bit of pride. You're not trying to stamp it out completely, right? Just keep it in check. Besides, I'd like to think we're not at odds in what we're trying to achieve."
      Speaker = "Melinoe"
      Event = "NemesisBathHouse02"
    }
    {
      Id = "Nemesis_0220"
      InheritFrom = "BaseNarrative"
      DisplayName = "We're not. But I can only push myself so hard. Seeing you getting stronger, getting closer... gives me the extra push I need."
      Speaker = "Nemesis"
      Event = "NemesisBathHouse02"
    }
    {
      Id = "Melinoe_3113"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd no idea. I always thought I got my competitive spirit from {#Emph}you. {#Prev}Anyway... do let me know if you need anything else. Such as lending a hand putting on that suit of yours."
      Speaker = "Melinoe"
      Event = "NemesisBathHouse02"
    }
    {
      Id = "Nemesis_0221"
      InheritFrom = "BaseNarrative"
      DisplayName = "Or taking it off, yeah. Though, can't let myself become too used to this."
      Speaker = "Nemesis"
      Event = "NemesisBathHouse02"
    }
    {
      Id = "Nemesis_0222"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, enough sitting around. Time for some standing around to balance it out."
      Speaker = "Nemesis"
      Event = "NemesisBathHouse02"
    }
    {
      Id = "Melinoe_3115"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Off we go, then."
      Speaker = "Melinoe"
      Event = "NemesisBathHouse02"
    }
    {
      Id = "Melinoe_4441"
      InheritFrom = "BaseNarrative"
      DisplayName = "You never did say no to Bath Salts, Nemesis, so how about it? As long as you feel we've earned at least a short break."
      Speaker = "Melinoe"
      Event = "NemesisBathHouse03"
    }
    {
      Id = "Nemesis_0321"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't know that we have. Though I've accumulated enough knots in my muscles that it's gotten in the way. So why not."
      Speaker = "Nemesis"
      Event = "NemesisBathHouse03"
    }
    {
      Id = "Nemesis_0322"
      InheritFrom = "BaseNarrative"
      DisplayName = "Can't believe I'm sitting here with you. Couldn't stand the sight of you for the longest time. Wanted to snap you like a twig. Now I got you helping me unstrap my suit."
      Speaker = "Nemesis"
      Event = "NemesisBathHouse03"
    }
    {
      Id = "Melinoe_4442"
      InheritFrom = "BaseNarrative"
      DisplayName = "We're capable of change, aren't we? You must believe that yourself, otherwise what's the use of all the retribution you dole out? It can't be for the sake of punishment entirely."
      Speaker = "Melinoe"
      Event = "NemesisBathHouse03"
    }
    {
      Id = "Nemesis_0323"
      InheritFrom = "BaseNarrative"
      DisplayName = "The punishment is half of it. But yeah. Important to learn, if not from our own failures then those occurring constantly around us. Still I don't think I've changed at all; you have."
      Speaker = "Nemesis"
      Event = "NemesisBathHouse03"
    }
    {
      Id = "Melinoe_4443"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have? I'm still hell-bent on all my responsibilities. Counting the moments before I can get back to what I'm meant to be doing... rather than enjoying being here with you."
      Speaker = "Melinoe"
      Event = "NemesisBathHouse03"
    }
    {
      Id = "Nemesis_0324"
      InheritFrom = "BaseNarrative"
      DisplayName = "Except we're only here because you worked up the guts to ask. But fine, maybe you haven't changed a lot. Maybe I just like who you are more than I used to for some reason."
      Speaker = "Nemesis"
      Event = "NemesisBathHouse03"
    }
    {
      Id = "Melinoe_4444"
      InheritFrom = "BaseNarrative"
      DisplayName = "I feel much the same. Though, I've admired you since training. It gladdens me to be with you like this... and how we've been fighting on the same side, recently."
      Speaker = "Melinoe"
      Event = "NemesisBathHouse03"
    }
    {
      Id = "Nemesis_0325"
      InheritFrom = "BaseNarrative"
      DisplayName = "Always wanted the same thing, just didn't think there was enough to go around. Now, enough talk. Going to get these knots out of my back or what?"
      Speaker = "Nemesis"
      Event = "NemesisBathHouse03"
    }
    {
      Id = "Nemesis_0326"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Feels better than before, I'll give you that. Though don't go thinking I'll let up on you out there. We're calling this even."
      Speaker = "Nemesis"
      Event = "NemesisBathHouse03"
    }
    {
      Id = "Melinoe_4446"
      InheritFrom = "BaseSubtitle"
      DisplayName = "As it should be."
      Speaker = "Melinoe"
      Event = "NemesisBathHouse03"
    }
    {
      Id = "Melinoe_0683"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, {#Emph}erm{#Prev}, I suspect I know the answer, though I don't suppose you want to pay a visit to the springs? Clear our heads?"
      Speaker = "Melinoe"
      Event = "NemesisBathHouseDecline01"
    }
    {
      Id = "Nemesis_0170"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, {#Emph}uh... {#Prev}Appreciate the invite, but I'm on guard duty right now, probably until Time claims us all. And this suit takes forever to get on or off..."
      Speaker = "Nemesis"
      Event = "NemesisBathHouseDecline01"
    }
    {
      Id = "Melinoe_0684"
      InheritFrom = "BaseNarrative"
      DisplayName = "Say, would you accompany me to the riverbank a bit? Blow off some steam, or... maybe I could push you in or something?"
      Speaker = "Melinoe"
      Event = "NemesisFishingDecline01"
    }
    {
      Id = "Nemesis_0171"
      InheritFrom = "BaseNarrative"
      DisplayName = "Could be going after perpetrators of unspeakable evil across the surface, but you're asking me to go after some poor fish? Uh, no."
      Speaker = "Nemesis"
      Event = "NemesisFishingDecline01"
    }
    {
      Id = "Melinoe_3487"
      InheritFrom = "BaseNarrative"
      DisplayName = "I thought I saw some movement by the fishing pier. A thorough investigation is probably in order, right?"
      Speaker = "Melinoe"
      Event = "NemesisFishing01"
    }
    {
      Id = "Nemesis_0172"
      InheritFrom = "BaseNarrative"
      DisplayName = "Either that or rot here standing guard, right? Know what, fine, I'll bite. Doubt anything else will."
      Speaker = "Nemesis"
      Event = "NemesisFishing01"
    }
    {
      Id = "Nemesis_0255"
      InheritFrom = "BaseNarrative"
      DisplayName = "To have been born a fish. A life spent mucking about in the River of Lamentation, only to be plucked out by {#Emph}you. {#Prev}What did they do to deserve this?"
      Speaker = "Nemesis"
      Event = "NemesisFishing01"
    }
    {
      Id = "Melinoe_3237"
      InheritFrom = "BaseNarrative"
      DisplayName = "Shouldn't you be the one to know the answer to that? Perhaps it's the will of the Fates that determines how we're born. Then you ensure we get our dues based on the choices that we make."
      Speaker = "Melinoe"
      Event = "NemesisFishing01"
    }
    {
      Id = "Nemesis_0256"
      InheritFrom = "BaseNarrative"
      DisplayName = "Be a lot easier if everyone was born on equal footing. But no one in my family thinks life's meant to be fair, other than me."
      Speaker = "Nemesis"
      Event = "NemesisFishing01"
    }
    {
      Id = "Melinoe_3238"
      InheritFrom = "BaseNarrative"
      DisplayName = "How can life possibly be fair, knowing there are creatures of all sorts, such as those dwelling in these waters?"
      Speaker = "Melinoe"
      Event = "NemesisFishing01"
    }
    {
      Id = "Nemesis_0257"
      InheritFrom = "BaseNarrative"
      DisplayName = "We'd have to put a bit more structure into who decides how mortals are born. Or how their souls come back to life. Topic for a different time. Think I saw a bit of movement over there."
      Speaker = "Nemesis"
      Event = "NemesisFishing01"
    }
    {
      Id = "Nemesis_0202"
      InheritFrom = "BaseNarrative"
      DisplayName = "Gave them a fair shot, didn't we. Real battle of wits back there."
      Speaker = "Nemesis"
      Event = "NemesisFishing01"
    }
    {
      Id = "Melinoe_2308"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Nemesis must have a head start..."
      Speaker = "Melinoe"
      Event = "NPC_Nemesis_01.MissingDistanceTrigger.VoiceLines"
    }
    {
      Id = "Melinoe_2309"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Nem's still out there I guess..."
      Speaker = "Melinoe"
      Event = "NPC_Nemesis_01.MissingDistanceTrigger.VoiceLines"
    }
    {
      Id = "Melinoe_1152"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Nemesis on break I guess..."
      Speaker = "Melinoe"
      Event = "NPC_Nemesis_01.MissingDistanceTrigger.VoiceLines"
    }
    {
      Id = "Melinoe_1153"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Where'd Nemesis go?"
      Speaker = "Melinoe"
      Event = "NPC_Nemesis_01.MissingDistanceTrigger.VoiceLines"
    }
    {
      Id = "Melinoe_0682"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thank you, Nem..."
      Speaker = "Melinoe"
      Event = "NPC_Nemesis_01.GiftGivenVoiceLines"
    }
    {
      Id = "NemesisField_0308"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What's the matter?"
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.PlayerInjuredReactionVoiceLines"
    }
    {
      Id = "NemesisField_0309"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Must have hurt."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.PlayerInjuredReactionVoiceLines"
    }
    {
      Id = "NemesisField_0310"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You had it coming."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.PlayerInjuredReactionVoiceLines"
    }
    {
      Id = "NemesisField_0311"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Too slow."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.PlayerInjuredReactionVoiceLines"
    }
    {
      Id = "NemesisField_0312"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh come on."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.PlayerInjuredReactionVoiceLines"
    }
    {
      Id = "NemesisField_0313"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Wake up."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.PlayerInjuredReactionVoiceLines"
    }
    {
      Id = "NemesisField_0314"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Still going?"
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.LastStandReactionVoiceLines"
    }
    {
      Id = "NemesisField_0315"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Made you mad."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.LastStandReactionVoiceLines"
    }
    {
      Id = "NemesisField_0316"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Tougher than you look."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.LastStandReactionVoiceLines"
    }
    {
      Id = "NemesisField_0317"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Give up."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.LastStandReactionVoiceLines"
    }
    {
      Id = "NemesisField_0318"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not bad..."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.LastStandReactionVoiceLines"
    }
    {
      Id = "NemesisField_0319"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come on, fight!"
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.LastStandReactionVoiceLines"
    }
    {
      Id = "NemesisField_0264"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Stygius take you."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.KillingEnemyVoiceLines"
    }
    {
      Id = "NemesisField_0265"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Souls for Stygius."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.KillingEnemyVoiceLines"
    }
    {
      Id = "NemesisField_0266"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Comeuppance."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.KillingEnemyVoiceLines"
    }
    {
      Id = "NemesisField_0267"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Deliverance."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.KillingEnemyVoiceLines"
    }
    {
      Id = "NemesisField_0268"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Retribution."
      Speaker = "Nemesis"
      Event = "NPC_Nemesis_01.KillingEnemyVoiceLines"
    }
    {
      Id = "NemesisField_0269"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's what you get."
      Speaker = "Nemesis"
