  lang = "en"
  Texts = [
    {
      Id = "Melinoe_1884"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Lord Hermes, go unseen."
      Speaker = "Melinoe"
      Event = "HermesUpgrade.InteractVoiceLines"
    }
    {
      Id = "Hermes_0128"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You too!"
      Speaker = "Hermes"
      Event = "HermesUpgrade.InteractVoiceLines"
    }
    {
      Id = "Hermes_0129"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hey hey!"
      Speaker = "Hermes"
      Event = "HermesUpgrade.InteractVoiceLines"
    }
    {
      Id = "Hermes_0130"
      InheritFrom = "BaseSubtitle"
