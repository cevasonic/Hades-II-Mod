  lang = "en"
  Texts = [
    {
      Id = "MelinoeField_0719"
      InheritFrom = "BaseSubtitle"
      DisplayName = "May these waters run clear."
      Speaker = "Melinoe"
      Event = "NPC_Narcissus_01.InteractVoiceLines"
    }
    {
      Id = "MelinoeField_0720"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Peace, Narcissus."
