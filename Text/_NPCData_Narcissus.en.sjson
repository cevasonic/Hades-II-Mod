      InheritFrom = "BaseNarrative"
      DisplayName = "All the best."
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.MiscEndVoiceLines_Narcissus"
    }
    {
      Id = "Narcissus_0133"
      InheritFrom = "BaseNarrative"
      DisplayName = "Warm wishes."
