    {
      Id = "Narcissus_0108"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Sniff> {#Prev}Oh man... like... damn... I mean... what am I gonna do? It's just, like..."
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusMutteringLines"
    }
    {
      Id = "Narcissus_0109"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ungh... {#Prev}I just can't... like... I mean, I can't even... {#Emph}<Sniff> {#Prev}What happened to us, man? I..."
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusMutteringLines"
    }
    {
      Id = "Narcissus_0110"
      InheritFrom = "BaseNarrative"
      DisplayName = "So... muddy... {#Emph}augh{#Prev}, can't quite... make out... an eye? A nose? {#Emph}Ungh..."
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusMutteringLines"
    }
    {
      Id = "Narcissus_0111"
      InheritFrom = "BaseNarrative"
      DisplayName = "So, {#Emph}um... {#Prev}yeah, I guess... like... anyway... let me see here..."
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusMutteringLines"
    }
    {
      Id = "Narcissus_0207"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Sigh> {#Prev}It's like... I still remember how you used to look, just... I {#Emph}miss {#Prev}you, man..."
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusMutteringLines"
    }
    {
      Id = "Narcissus_0208"
      InheritFrom = "BaseNarrative"
      DisplayName = "Maybe I should... like, {#Emph}go? {#Prev}Like, somewhere {#Emph}else? {#Prev}But I can't {#Emph}leave {#Prev}you, man...!"
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusMutteringLines"
    }
    {
      Id = "Narcissus_0019"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wow... {#Emph}tsk... {#Prev}I mean, come on, just... {#Emph}augh...!"
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusMutteringLines"
    }
    {
      Id = "Narcissus_0020"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just... {#Emph}yeah! {#Prev}I'm so... {#Emph}ungh{#Prev}, I mean... {#Emph}huh{#Prev}, right...?"
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusMutteringLines"
    }
    {
      Id = "Narcissus_0021"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Man... just, you are so... {#Emph}ungh! {#Prev}Know what I mean...?"
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusMutteringLines"
    }
    {
      Id = "Narcissus_0022"
      InheritFrom = "BaseNarrative"
      DisplayName = "...{#Emph}Whew{#Prev}, like... {#Emph}yeah...! {#Prev}Just, {#Emph}totally{#Prev}, I mean... right?"
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusMutteringLines"
    }
    {
      Id = "Narcissus_0098"
      InheritFrom = "BaseNarrative"
      DisplayName = "So like... I mean... {#Emph}yeah{#Prev}, just... {#Emph}ungh! {#Prev}You know? {#Emph}You {#Prev}know, {#Emph}huh! {#Prev}You {#Emph}know..."
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusMutteringLines"
    }
    {
      Id = "Narcissus_0099"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Mm, {#Prev}yeah, that's... nice, yeah, definitely, {#Emph}so, {#Prev}like... {#Emph}ungh...! {#Prev}I mean, for real..."
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusMutteringLines"
    }
    {
      Id = "Narcissus_0100"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yeah, looking good, man. You... are looking {#Emph}good. {#Prev}Like you don't know! Don't even know, right?"
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusMutteringLines"
    }
    {
      Id = "Narcissus_0102"
      InheritFrom = "BaseNarrative"
      DisplayName = "How did you get so... {#Emph}ungh{#Prev}, the hair, the lips, the eyes. Those {#Emph}eyes{#Prev}, man! Know what I mean?"
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusMutteringLines"
    }
    {
      Id = "Narcissus_0103"
      InheritFrom = "BaseNarrative"
      DisplayName = "Love you, man. I ever tell you that? {#Emph}Haha{#Prev}, oh yeah, I did. You {#Emph}know {#Prev}I did. You know I do."
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusMutteringLines"
    }
    {
      Id = "Narcissus_0104"
      InheritFrom = "BaseNarrative"
      DisplayName = "So, like, yeah... just, all of it, it's, {#Emph}ungh. {#Prev}It's too {#Emph}much! {#Prev}It's never enough. {#Emph}Haha{#Prev}, you know?"
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusMutteringLines"
    }
    {
      Id = "Narcissus_0105"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey you look... you look {#Emph}great{#Prev}, man. Thought I'd mention it. Because I'm {#Emph}thinking {#Prev}it, you know?"
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusMutteringLines"
    }
    {
      Id = "Narcissus_0106"
      InheritFrom = "BaseNarrative"
      DisplayName = "What else is going on, though, man? Got to be something on your mind, right? No...?"
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusMutteringLines"
    }
    {
      Id = "Narcissus_0107"
      InheritFrom = "BaseNarrative"
      DisplayName = "So I was like, {#Emph}no way. {#Prev}But then I go, wait... {#Emph}what if...? {#Prev}Remember that one, man? I know you do!"
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusMutteringLines"
    }
    {
      Id = "Narcissus_0203"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey man, tell me something, can you keep a secret? Because I can't: {#Emph}I love you. {#Prev}Yeah. You got that right..."
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusMutteringLines"
    }
    {
      Id = "Narcissus_0206"
      InheritFrom = "BaseNarrative"
      DisplayName = "I mean, look at you, it's like, {#Emph}just... wow. {#Prev}You know? Don't even have the words..."
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusMutteringLines"
    }
    {
      Id = "Narcissus_0101"
      InheritFrom = "BaseNarrative"
      DisplayName = "That her again? That's her. Don't worry, man, this won't take long. This won't take long at all."
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusMutteringLines"
    }
    {
      Id = "Narcissus_0204"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Eh{#Prev}, probably just Laurel coming back to fawn all over you again, right man...?"
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusMutteringLines"
    }
    {
      Id = "Narcissus_0205"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wonder how Echo's doing, man. Down in the Fields! It's nice and airy over there. Yeah..."
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusMutteringLines"
    }
    {
      Id = "Narcissus_0179"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Sounds like you found your match."
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusExorcismReactionVoiceLines"
    }
    {
      Id = "Narcissus_0180"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Whew{#Prev}, I owe you one."
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusExorcismReactionVoiceLines"
    }
    {
      Id = "Narcissus_0181"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Get 'em out of here."
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusExorcismReactionVoiceLines"
    }
    {
      Id = "Narcissus_0182"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Didn't like that one."
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusExorcismReactionVoiceLines"
    }
    {
      Id = "Narcissus_0183"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Buh-{#Emph}bye!"
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusExorcismReactionVoiceLines"
    }
    {
      Id = "Narcissus_0184"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thought they'd never leave."
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusExorcismReactionVoiceLines"
    }
    {
      Id = "Narcissus_0185"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Finally!"
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.NarcissusExorcismReactionVoiceLines"
    }
    {
      Id = "Narcissus_0027"
      InheritFrom = "BaseNarrative"
      DisplayName = "Knock yourself out."
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.MiscEndVoiceLines_Narcissus"
    }
    {
      Id = "Narcissus_0028"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now if you'll excuse me."
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.MiscEndVoiceLines_Narcissus"
    }
    {
      Id = "Narcissus_0029"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now you may go."
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.MiscEndVoiceLines_Narcissus"
    }
    {
      Id = "Narcissus_0030"
      InheritFrom = "BaseNarrative"
      DisplayName = "All yours."
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.MiscEndVoiceLines_Narcissus"
    }
    {
      Id = "Narcissus_0032"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now leave, OK?"
      Speaker = "Narcissus"
      Event = "GlobalVoiceLines.MiscEndVoiceLines_Narcissus"
    }
    {
