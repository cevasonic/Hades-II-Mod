{
  /*
  This file was autogenerated on 10/9/2025 at 6:51 PM
  by the BuildText tool.
  */
  lang = "en"
  Texts = [
    {
      Id = "Melinoe_1708"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Death to Chronos, Commander."
      Speaker = "Melinoe"
      Event = "NPC_Skelly_01.InteractVoiceLines"
    }
    {
      Id = "Skelly_0155"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Heya."
      Speaker = "Skelly"
      Event = "NPC_Skelly_01.InteractVoiceLines"
    }
    {
      Id = "Skelly_0156"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Good evening, young one."
      Speaker = "Skelly"
      Event = "NPC_Skelly_01.InteractVoiceLines"
    }
    {
      Id = "Skelly_0158"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Same to you."
      Speaker = "Skelly"
      Event = "NPC_Skelly_01.InteractVoiceLines"
    }
    {
      Id = "Skelly_0160"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It better!"
      Speaker = "Skelly"
      Event = "NPC_Skelly_01.InteractVoiceLines"
    }
    {
      Id = "Skelly_0161"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Seriously."
      Speaker = "Skelly"
      Event = "NPC_Skelly_01.InteractVoiceLines"
    }
    {
      Id = "Skelly_0162"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Moonlight, yeah."
      Speaker = "Skelly"
      Event = "NPC_Skelly_01.InteractVoiceLines"
    }
    {
      Id = "Skelly_0163"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Knock 'im dead, kiddo."
      Speaker = "Skelly"
      Event = "NPC_Skelly_01.InteractVoiceLines"
    }
    {
      Id = "Skelly_0164"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yeah, kill 'im!"
      Speaker = "Skelly"
      Event = "NPC_Skelly_01.InteractVoiceLines"
    }
    {
      Id = "Melinoe_3273"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The deed is done...!"
      Speaker = "Melinoe"
      Event = "NPC_Skelly_01.TrophyUnlockedVoiceLines"
    }
    {
      Id = "Skelly_0309"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And now... unto the Champion of Night, {#Emph}the spoils..."
      Speaker = "Skelly"
      Event = "NPC_Skelly_01.TrophyUnlockedVoiceLines"
    }
    {
      Id = "Melinoe_3274"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh..."
      Speaker = "Melinoe"
      Event = "NPC_Skelly_01.TrophyUnlockedVoiceLines"
    }
    {
      Id = "Skelly_0314"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Now, young one: Avert your eyes, lest you be smitten by the {#Emph}glory {#Prev}over here!"
      Speaker = "Skelly"
      Event = "NPC_Skelly_01.TrophyUnlockedVoiceLines"
    }
    {
      Id = "Skelly_0319"
      InheritFrom = "BaseSubtitle"
      DisplayName = "For your {#Emph}extraordinary {#Prev}feat, the most {#Emph}extraordinary Gift of all!"
      Speaker = "Skelly"
      Event = "NPC_Skelly_01.TrophyUnlockedVoiceLines"
    }
    {
      Id = "Skelly_0229"
      InheritFrom = "BaseNarrative"
      DisplayName = "A battle lost. But this is {#Emph}war{#Prev}, young one, and you have many battles yet to come! The only question is, are you prepared to {#Emph}win? {#Prev}I'm not so sure here, so let's see you {#DialogLegendaryFormat}give me {#Prev}{#EmphLegendary}twenty!"
      Speaker = "Skelly"
      Event = "SkellyFirstMeeting"
    }
    {
      Id = "Melinoe_0018"
      InheritFrom = "BaseNarrative"
      DisplayName = "Commander Schelemeus, sir. You're certain it's acceptable for me to strike you twenty times in front of all your students?"
      Speaker = "Melinoe"
      Event = "SkellyFirstMeeting"
    }
    {
      Id = "Skelly_0452"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Dead certain. {#Prev}Now hit me with everything you got!"
      Speaker = "Skelly"
      Event = "SkellyFirstMeeting"
    }
    {
      Id = "Melinoe_0019_V3"
      InheritFrom = "BaseSubtitle"
      DisplayName = "As you will, sir!"
      Speaker = "Melinoe"
      Event = "SkellyFirstMeeting"
    }
    {
      Id = "Skelly_0470"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh hey, young one, just minding my own business over here... for what knowledge could I possibly impart to she who vanquished the {#DialogLegendaryFormat}Titan of Time {#Prev}like it was nothin'?"
      Speaker = "Skelly"
      Event = "SkellyAboutEarlyRunClear01"
    }
    {
      Id = "Melinoe_4159"
      InheritFrom = "BaseNarrative"
      DisplayName = "Commander, I merely wished to thank you. Were it not for all your teachings in the past, I wouldn't have prevailed."
      Speaker = "Melinoe"
      Event = "SkellyAboutEarlyRunClear01"
    }
    {
      Id = "Skelly_0471"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ah, yes! I almost forgot my teachings in the past! In turn, I congratulate you on achieving that which I wagered was impossible to my disciples here..."
      Speaker = "Skelly"
      Event = "SkellyAboutEarlyRunClear01"
    }
    {
      Id = "Melinoe_4160"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Wait you {#Emph}wagered...?"
      Speaker = "Melinoe"
      Event = "SkellyAboutEarlyRunClear01"
    }
    {
      Id = "Skelly_0472"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}No!"
      Speaker = "Skelly"
      Event = "SkellyAboutEarlyRunClear01"
    }
    {
      Id = "Skelly_0072"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your path is fraught, young one. Know that I'm {#Emph}always {#Prev}here to let you vent {#Emph}all {#Prev}your anger and frustrations upon, as well as to train with."
      Speaker = "Skelly"
      Event = "SkellyAboutTask01"
    }
    {
      Id = "Melinoe_0072"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The greatest teacher is out there..."
      Speaker = "Melinoe"
      Event = "SkellyAboutTask01"
    }
    {
      Id = "Skelly_0441"
      InheritFrom = "BaseNarrative"
      DisplayName = "While I do not wish to insinuate you're some kind of {#DialogLegendaryFormat}slacker{#Prev}, nonetheless I can't help but observe it's been more than a few nights since last you vanquished me, young one."
      Speaker = "Skelly"
      Event = "SkellyAboutBeatings01"
    }
    {
      Id = "Melinoe_4052"
      InheritFrom = "BaseNarrative"
      DisplayName = "I thought my training here was more or less complete, Commander. All the Nocturnal Arms are at my disposal, and I know them well. Am I to keep reducing you to dust?"
      Speaker = "Melinoe"
      Event = "SkellyAboutBeatings01"
    }
    {
      Id = "Skelly_0442"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, the choice {#Emph}is {#Prev}ultimately yours, of course, but lest you forget: There's always more for you to learn, and only one way to learn it!"
      Speaker = "Skelly"
      Event = "SkellyAboutBeatings01"
    }
    {
      Id = "Melinoe_4053"
      InheritFrom = "BaseSubtitle"
      DisplayName = "By hitting you repeatedly."
      Speaker = "Melinoe"
      Event = "SkellyAboutBeatings01"
    }
    {
      Id = "Skelly_0443"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And often, now come {#Emph}on!"
      Speaker = "Skelly"
      Event = "SkellyAboutBeatings01"
    }
    {
      Id = "Skelly_0073"
      InheritFrom = "BaseNarrative"
      DisplayName = "One must at times hold fast to one's emotions, and at others, know to let 'em loose. And when you want to let 'em loose, or try out one of them {#DialogLegendaryFormat}Nocturnal Arms{#Prev}, know that I'm here."
      Speaker = "Skelly"
      Event = "SkellyAboutEmotions01"
    }
    {
      Id = "Melinoe_0075"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This anger is for Chronos, sir."
      Speaker = "Melinoe"
      Event = "SkellyAboutEmotions01"
    }
    {
      Id = "Skelly_0153"
      InheritFrom = "BaseNarrative"
      DisplayName = "Observe how patient my disciples are, studying your every move! If ever you're inclined to give them a demonstration of your prowess, or just want to blow off some steam, do not hesitate to {#DialogLegendaryFormat}whale upon me{#Prev}."
      Speaker = "Skelly"
      Event = "SkellyAboutTraining01"
    }
    {
      Id = "Melinoe_2256"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Whale upon{#Prev}, sir...?"
      Speaker = "Melinoe"
      Event = "SkellyAboutTraining01"
    }
    {
      Id = "Skelly_0044"
      InheritFrom = "BaseNarrative"
      DisplayName = "Remember you are training with an unarmed opponent here, young one. Out there, the skeletons can {#Emph}move{#Prev}... and they'd cut you to ribbons, given half a chance! You won't learn to handle that kind of pressure sparring with me."
      Speaker = "Skelly"
      Event = "SkellyAboutTraining02"
    }
    {
      Id = "Melinoe_0053"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I understand."
      Speaker = "Melinoe"
      Event = "SkellyAboutTraining02"
    }
    {
      Id = "Skelly_0154"
      InheritFrom = "BaseNarrative"
      DisplayName = "You getting a handle on that walking stick of yours? There's other stuff you might like better in the {#DialogLegendaryFormat}Puddle {#Prev}back there, if you've got the {#DialogLegendaryFormat}Silver {#Prev}for it. Just be sure to try it all out on me!"
      Speaker = "Skelly"
      Event = "SkellyAboutStaff01"
    }
    {
      Id = "Melinoe_2257"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You mustn't speak ill of Descura, sir."
      Speaker = "Melinoe"
      Event = "SkellyAboutStaff01"
    }
    {
      Id = "Skelly_0393"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're eager to get out there and start dishing out some good old fashioned punishment, young one! Well then you need not stop for me. {#DialogLegendaryFormat}Just go!"
      Speaker = "Skelly"
      Event = "SkellyAboutChatting01"
    }
    {
      Id = "Melinoe_3803"
      InheritFrom = "BaseNarrative"
      DisplayName = "It doesn't feel right to rush through these Crossroads without so much as a word. Besides, you surely have some vital wisdom to impart."
      Speaker = "Melinoe"
      Event = "SkellyAboutChatting01"
    }
    {
      Id = "Skelly_0394"
      InheritFrom = "BaseNarrative"
      DisplayName = "That I do, and it is this: Even if you see a sign over my head or anybody's that's like {#Emph}c'mere talk to me{#Prev}, remember... no need to chat if you're not in a conversating mood, OK?"
      Speaker = "Skelly"
      Event = "SkellyAboutChatting01"
    }
    {
      Id = "Melinoe_3804"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just ignore anybody I don't want to talk to, then."
      Speaker = "Melinoe"
      Event = "SkellyAboutChatting01"
    }
    {
      Id = "Skelly_0395"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yeah, who needs 'em!"
      Speaker = "Skelly"
      Event = "SkellyAboutChatting01"
    }
    {
      Id = "Melinoe_4161"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've always wondered something, Commander. Where do you go when you're not here? I mean, sometimes you only arrive after I switch between Nocturnal Arms..."
      Speaker = "Melinoe"
      Event = "SkellyAboutDying01"
    }
    {
      Id = "Skelly_0473"
      InheritFrom = "BaseNarrative"
      DisplayName = "That isn't anybody's business but mine own, young one! Do we not, each of us, require solitude? A locale where we might collect our bearings and our thoughts?"
      Speaker = "Skelly"
      Event = "SkellyAboutDying01"
    }
    {
      Id = "Melinoe_4162"
      InheritFrom = "BaseNarrative"
      DisplayName = "Of course, sir... I apologize for overstepping. We are the Unseen; we dwell in obscurity and guard our secrets."
      Speaker = "Melinoe"
      Event = "SkellyAboutDying01"
    }
    {
      Id = "Skelly_0474"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And we don't go pryin' in each other's personal affairs."
      Speaker = "Skelly"
      Event = "SkellyAboutDying01"
    }
    {
      Id = "Skelly_0361"
      InheritFrom = "BaseNarrative"
      DisplayName = "Something's changed about that {#DialogLegendaryFormat}Altar {#Prev}of yours recently, and you have been at it more and {#Emph}more{#Prev}, young one! Mayhaps awakened newfound power there, or what?"
      Speaker = "Skelly"
      Event = "SkellyAboutCardUpgradeSystem01"
    }
    {
      Id = "Melinoe_3364"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've consecrated the Ashes and gained insight into the potential of the Arcana, Commander. Requires a little Moon Dust, and a lot of focus... perhaps the other way around."
      Speaker = "Melinoe"
      Event = "SkellyAboutCardUpgradeSystem01"
    }
    {
      Id = "Skelly_0362"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#DialogLegendaryFormat}Moon Dust? {#Prev}Think the old {#DialogLegendaryFormat}Broker {#Prev}started pawning off that stuff, though I {#Emph}have {#Prev}heard it's possible a witch like you could brew it up herself. Sounds like you better stock up!"
      Speaker = "Skelly"
      Event = "SkellyAboutCardUpgradeSystem01"
    }
    {
      Id = "Melinoe_3365"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I probably should..."
      Speaker = "Melinoe"
      Event = "SkellyAboutCardUpgradeSystem01"
    }
    {
      Id = "Skelly_0185"
      InheritFrom = "BaseNarrative"
      DisplayName = "Something transpired with the {#DialogLegendaryFormat}Silver Puddle {#Prev}back there, I could tell, young one! Your doing, or perchance that of the Fates themselves?"
      Speaker = "Skelly"
      Event = "SkellyAboutAspects01"
    }
    {
      Id = "Melinoe_2529"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've revealed in the Pool the Aspects of the Nocturnal Arms. Not their true forms, exactly... but different ones, with their own great power."
      Speaker = "Melinoe"
      Event = "SkellyAboutAspects01"
    }
    {
      Id = "Skelly_0186"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ah, the {#DialogLegendaryFormat}Nocturnal Arms{#Prev}! Your brother, he once used their counterparts, and those ones too turned into other stuff. Well if you need to test your newfound strength, I'm here."
      Speaker = "Skelly"
      Event = "SkellyAboutAspects01"
    }
    {
      Id = "Melinoe_2530"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I know it, Commander."
      Speaker = "Melinoe"
      Event = "SkellyAboutAspects01"
    }
    {
      Id = "Skelly_0189"
      InheritFrom = "BaseNarrative"
      DisplayName = "I trust that the enchanted {#DialogLegendaryFormat}Tooth {#Prev}I proffered you has proved invaluable? Although, since you're already back, perhaps it wasn't quite invaluable enough..."
      Speaker = "Skelly"
      Event = "SkellyAboutKeepsake01"
    }
    {
      Id = "Melinoe_2586"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd surely not have gone as far without your Keepsake, Commander. Though, why is it known as the {#Emph}Luckier {#Prev}Tooth? Was there another of its kind?"
      Speaker = "Melinoe"
      Event = "SkellyAboutKeepsake01"
    }
    {
      Id = "Skelly_0190"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, no! It is truly a unique artifact procured in my travails. An artifact with which you'll cling to life as might a sailor on a sinking ship."
      Speaker = "Skelly"
      Event = "SkellyAboutKeepsake01"
    }
    {
      Id = "Melinoe_2587"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's very vivid..."
      Speaker = "Melinoe"
      Event = "SkellyAboutKeepsake01"
    }
    {
      Id = "Melinoe_0073"
      InheritFrom = "BaseNarrative"
      DisplayName = "Commander... there must be something you could tell me of my brother. The stronger my connection, the better our chances. You knew him, didn't you?"
      Speaker = "Melinoe"
      Event = "SkellyAboutZagreus01"
    }
    {
      Id = "Skelly_0007"
      InheritFrom = "BaseNarrative"
      DisplayName = "I knew your brother, yeah. Good kid, most of the time. He wouldn't want you to be so hung up about him. What he'd want... more than anything, I think... is for you... to {#DialogLegendaryFormat}hit me{#Prev}. As hard as you can, repeatedly and often, and {#Emph}that's {#Prev}what I would want for you as well!"
      Speaker = "Skelly"
      Event = "SkellyAboutZagreus01"
    }
    {
      Id = "Melinoe_0074"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ungh{#Prev}, very well."
      Speaker = "Melinoe"
      Event = "SkellyAboutZagreus01"
    }
    {
      Id = "Melinoe_4171"
      InheritFrom = "BaseNarrative"
      DisplayName = "My brother must have been immensely strong, if he could sometimes even take my father when they sparred. Is there some favorite technique of his that you could pass along?"
      Speaker = "Melinoe"
      Event = "SkellyAboutZagreus02"
    }
    {
      Id = "Skelly_0487"
      InheritFrom = "BaseNarrative"
      DisplayName = "No there is {#Emph}not! {#Prev}My disciples must each follow their own path. Keep following yours, and mayhaps you {#Emph}too {#Prev}shall become powerful enough to beat your papa up."
      Speaker = "Skelly"
      Event = "SkellyAboutZagreus02"
    }
    {
      Id = "Melinoe_4172"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Commander! My father is bound in chains in Tartarus!"
      Speaker = "Melinoe"
      Event = "SkellyAboutZagreus02"
    }
    {
      Id = "Skelly_0488"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Then it ought to be easy!"
      Speaker = "Skelly"
      Event = "SkellyAboutZagreus02"
    }
    {
      Id = "Melinoe_4946"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Commander, we have no reason to fight!"
      Speaker = "Melinoe"
      Event = "SkellyAboutZagreus02"
    }
    {
      Id = "Skelly_0582"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Mayhaps not {#Emph}yet!"
      Speaker = "Skelly"
      Event = "SkellyAboutZagreus02"
    }
    {
      Id = "Skelly_0749"
      InheritFrom = "BaseNarrative"
      DisplayName = "My disciples here claim that you clashed with none other than the {#DialogLegendaryFormat}Prince of the Underworld {#Prev}himself, and you fought with the fury of a daemon, to which I said, {#Emph}c'mon."
      Speaker = "Skelly"
      Event = "SkellyAboutZagreusFight01"
    }
    {
      Id = "Melinoe_5673"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's true, sir! I found myself in some competition-chamber in what looked to be Elysium. There Zagreus and I engaged in a full-contact battle for the hearts of our spectators!"
      Speaker = "Melinoe"
      Event = "SkellyAboutZagreusFight01"
    }
    {
      Id = "Skelly_0750"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well that seems pretty pointless to me, kiddo, seeing as I trained you both! You are {#Emph}equally matched! {#Prev}I don't see what comparisons are even to be drawn!"
      Speaker = "Skelly"
      Event = "SkellyAboutZagreusFight01"
    }
    {
      Id = "Melinoe_5674"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Commander, we're nothing alike."
      Speaker = "Melinoe"
      Event = "SkellyAboutZagreusFight01"
    }
    {
      Id = "Skelly_0751"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's exactly what he'd say."
      Speaker = "Skelly"
      Event = "SkellyAboutZagreusFight01"
    }
    {
      Id = "Melinoe_4156"
      InheritFrom = "BaseNarrative"
      DisplayName = "I saw my father recently, Commander... bound in chains in deepest Tartarus, a prisoner of Time. After all he's been through, though... he couldn't even remember you by name!"
      Speaker = "Melinoe"
      Event = "SkellyAboutHades01"
    }
    {
      Id = "Skelly_0468"
      InheritFrom = "BaseNarrative"
      DisplayName = "How, {#Emph}uh{#Prev}, how terrible that is, young one! Your papa and I, we couldn't have been closer. Perchance he merely has forgotten 'cause of everything he's going through."
      Speaker = "Skelly"
      Event = "SkellyAboutHades01"
    }
    {
      Id = "Melinoe_4157"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can't believe he'd just entirely forget one of his most trusted advisors. There must be some way to help him recall."
      Speaker = "Melinoe"
      Event = "SkellyAboutHades01"
    }
    {
      Id = "Skelly_0469"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}No! {#Prev}You gotta let him come around on his own."
      Speaker = "Skelly"
      Event = "SkellyAboutHades01"
    }
    {
      Id = "Melinoe_4169"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do you ever miss it, Commander? Your time in service to the House of Hades. Training my brother. Holding a position of high honor there."
      Speaker = "Melinoe"
      Event = "SkellyAboutHouse01"
    }
    {
      Id = "Skelly_0485"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, 'twas a glorious time for sure. But, I would not have earned my post if I kept crying about the past like a {#DialogLegendaryFormat}little baby{#Prev}. I'm all about the here-and-now!"
      Speaker = "Skelly"
      Event = "SkellyAboutHouse01"
    }
    {
      Id = "Melinoe_4170"
      InheritFrom = "BaseNarrative"
      DisplayName = "But all of what you used to have is gone. The other servants of the House... you must have some concern for {#Emph}them {#Prev}at least?"
      Speaker = "Melinoe"
      Event = "SkellyAboutHouse01"
    }
    {
      Id = "Skelly_0486"
      InheritFrom = "BaseSubtitle"
      DisplayName = "C'mon, they're {#Emph}gods! {#Prev}They'll probably be fine!"
      Speaker = "Skelly"
      Event = "SkellyAboutHouse01"
    }
    {
      Id = "Melinoe_4173"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know I've always wondered about all those commendations that you wear... which was the first you earned? Which means the most?"
      Speaker = "Melinoe"
      Event = "SkellyAboutPast01"
    }
    {
      Id = "Skelly_0489"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh you mean these little numbers here? One of these I've had since, {#Emph}um{#Prev}, the {#DialogLegendaryFormat}Siege of Ilium{#Prev}! Speared many a guy for {#Emph}that {#Prev}one! The others are from campaigns 'cross the land."
      Speaker = "Skelly"
      Event = "SkellyAboutPast01"
    }
    {
      Id = "Melinoe_4174"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Which sorts of campaigns?"
      Speaker = "Melinoe"
      Event = "SkellyAboutPast01"
    }
    {
      Id = "Skelly_0490"
      InheritFrom = "BaseSubtitle"
      DisplayName = "'Cross the land, I said!"
      Speaker = "Skelly"
      Event = "SkellyAboutPast01"
    }
    {
      Id = "Skelly_0497"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why are you looking at me with that consternated face, young one? Mayhaps in search of wisdom you would like me to impart?"
      Speaker = "Skelly"
      Event = "SkellyAboutPast02"
    }
    {
      Id = "Melinoe_4178"
      InheritFrom = "BaseNarrative"
      DisplayName = "...It's just, even now, I know so little of your past. I have to admit, Commander... there are such times when I begin to feel as though you're not being candid with me."
      Speaker = "Melinoe"
      Event = "SkellyAboutPast02"
    }
    {
      Id = "Skelly_0498"
      InheritFrom = "BaseNarrative"
      DisplayName = "What?! No. Look, I'm here to focus on your martial expertise, rather than prattle on about the way things used to be! But fine. What is it you really wish to know?"
      Speaker = "Skelly"
      Event = "SkellyAboutPast02"
    }
    {
      Id = "Melinoe_4179"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I wish to know exactly who you truly are."
      Speaker = "Melinoe"
      Event = "SkellyAboutPast02"
    }
    {
      Id = "Skelly_0499"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Well I'm not telling you."
      Speaker = "Skelly"
      Event = "SkellyAboutPast02"
    }
    {
      Id = "Melinoe_4180"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Fine."
      Speaker = "Melinoe"
      Event = "SkellyAboutPast02"
    }
    {
      Id = "Skelly_0500"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey look, I know we kinda had a little spat last time, and I don't want things going sideways with you here, so let me give it to you straight."
      Speaker = "Skelly"
      Event = "SkellyAboutPast03"
    }
    {
      Id = "Melinoe_4181"
      InheritFrom = "BaseNarrative"
      DisplayName = "Very well, Commander. You always have my full attention."
      Speaker = "Melinoe"
      Event = "SkellyAboutPast03"
    }
    {
      Id = "Skelly_0501"
      InheritFrom = "BaseNarrative"
      DisplayName = "The thing is, kiddo, and it's something that could get me into lots of trouble: Not only do I not want to, but I'm not even {#Emph}supposed {#Prev}to tell you what you want to know."
      Speaker = "Skelly"
      Event = "SkellyAboutPast03"
    }
    {
      Id = "Melinoe_4182"
      InheritFrom = "BaseNarrative"
      DisplayName = "And I suppose you can't tell me why not. Is somebody coercing you to keep me ignorant?"
      Speaker = "Melinoe"
      Event = "SkellyAboutPast03"
    }
    {
      Id = "Skelly_0502"
      InheritFrom = "BaseNarrative"
      DisplayName = "Look, just trust me on this one, OK? You've got your part to play, and I got mine."
      Speaker = "Skelly"
      Event = "SkellyAboutPast03"
    }
    {
      Id = "Melinoe_4183"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...This isn't over."
      Speaker = "Melinoe"
      Event = "SkellyAboutPast03"
    }
    {
      Id = "Melinoe_4997"
      InheritFrom = "BaseNarrative"
      DisplayName = "Commander, if I'm to trust you as I always have, then I need to know that you are not concealing anything from me. If you fear reprisal, I swear to vouch for you and protect you."
      Speaker = "Melinoe"
      Event = "SkellyAboutPast04"
    }
    {
      Id = "Skelly_0638"
      InheritFrom = "BaseNarrative"
      DisplayName = "My fear, young one, is that if I share the knowledge you desire, you shall never again look upon me in the same way! Which may not be so good for either one of us."
      Speaker = "Skelly"
      Event = "SkellyAboutPast04"
    }
    {
      Id = "Melinoe_4998"
      InheritFrom = "BaseNarrative"
      DisplayName = "I would rather look upon you knowing you are honest with me. And for my part, I shall not betray your confidentiality."
      Speaker = "Melinoe"
      Event = "SkellyAboutPast04"
    }
    {
      Id = "Skelly_0639"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Well all right... I am not exactly the Commander whom you take me for, {#Emph}nay! {#Prev}I was much {#Emph}more {#Prev}than that... {#Emph}King Schelememnon{#Prev}, I was called! But I was even more than {#Emph}that, as well! {#Prev}For your own papa hand-selected me as one of his {#DialogLegendaryFormat}Three Judges of the Dead{#Prev}!"
      Speaker = "Skelly"
      Event = "SkellyAboutPast04"
    }
    {
      Id = "Melinoe_4999"
      InheritFrom = "BaseNarrative"
      DisplayName = "Commander, that's... that's incredible! So then... after the Underworld fell, you went into hiding here?"
      Speaker = "Melinoe"
      Event = "SkellyAboutPast04"
    }
    {
      Id = "Skelly_0640"
      InheritFrom = "BaseNarrative"
      DisplayName = "I, {#Emph}uh, heheh. {#Prev}Yes, that is correct. And our enemies, they have pursued me ever since! No one must know my whereabouts! Not your father, your brother... {#Emph}nobody."
      Speaker = "Skelly"
      Event = "SkellyAboutPast04"
    }
    {
      Id = "Melinoe_5000"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why can't my father or my brother know? Surely they'd want to hear you're safe!"
      Speaker = "Melinoe"
      Event = "SkellyAboutPast04"
    }
    {
      Id = "Skelly_0641"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}No! {#Prev}Leave the clandestine communications to me."
      Speaker = "Skelly"
      Event = "SkellyAboutPast04"
    }
    {
      Id = "Melinoe_5001"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...I always thought my father did the judging on his own."
      Speaker = "Melinoe"
      Event = "SkellyAboutPast04"
    }
    {
      Id = "Skelly_0642"
      InheritFrom = "BaseSubtitle"
      DisplayName = "He did a good amount."
      Speaker = "Skelly"
      Event = "SkellyAboutPast04"
    }
    {
      Id = "Melinoe_2924"
      InheritFrom = "BaseNarrative"
      DisplayName = "Have you seen, Commander? Lord Charon's come to visit us! At last our supply lines are secure, and our counter-assault begins."
      Speaker = "Melinoe"
      Event = "SkellyAboutCharon01"
    }
    {
      Id = "Skelly_0244"
      InheritFrom = "BaseNarrative"
      DisplayName = "Uh, {#Emph}yeah! {#Prev}It's been quite some time since good Lord Charon visited us last. We'd better all be on our best behavior around him! But, {#Emph}uh... {#Prev}where'd you get all that supply-lines stuff?"
      Speaker = "Skelly"
      Event = "SkellyAboutCharon01"
    }
    {
      Id = "Melinoe_2925"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Why, he told me himself, sir! In his way."
      Speaker = "Melinoe"
      Event = "SkellyAboutCharon01"
    }
    {
      Id = "Skelly_0245"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh..."
      Speaker = "Skelly"
      Event = "SkellyAboutCharon01"
    }
    {
      Id = "Skelly_0246"
      InheritFrom = "BaseNarrative"
      DisplayName = "Say, young one? I'd ask of you a question that pertains to good Lord Charon, if you please. Seems like you understand him pretty good! Has he, {#Emph}uh{#Prev}, said anything of late regarding {#Emph}me...?"
      Speaker = "Skelly"
      Event = "SkellyAboutCharon02"
    }
    {
      Id = "Melinoe_2926"
      InheritFrom = "BaseNarrative"
      DisplayName = "Commander, I... I'm sorry, no. But I'll be certain to put in a good word! You've been indispensable, and Lord Charon ought to be aware."
      Speaker = "Melinoe"
      Event = "SkellyAboutCharon02"
    }
    {
      Id = "Skelly_0247"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}No! {#Prev}I mean, {#Emph}um, no{#Prev}, just... don't go doing anything like that! You need not burden more the Boatman with such trivialities, amid such turbulent times...! Don't bother him, OK?"
      Speaker = "Skelly"
      Event = "SkellyAboutCharon02"
    }
    {
      Id = "Melinoe_2927"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Erm{#Prev}, OK!"
      Speaker = "Melinoe"
      Event = "SkellyAboutCharon02"
    }
    {
      Id = "Melinoe_2996"
      InheritFrom = "BaseNarrative"
      DisplayName = "Commander. You once held a place of honor in my father's House, so you must know Cerberus? I think I found him in the Mourning Fields, coated in Miasma, heads to paws. Was he always prone to uncontrolled fits of rage?"
      Speaker = "Melinoe"
      Event = "SkellyAboutCerberus01"
    }
    {
      Id = "Skelly_0240"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, no, he mostly sat around. We go way back, it's just... I kept strategically afar, seeing as he's kind of like a {#Emph}dog{#Prev}, and I'm kind of like a {#Emph}bone. {#Prev}So now he's giving you some trouble, huh?"
      Speaker = "Skelly"
      Event = "SkellyAboutCerberus01"
    }
    {
      Id = "Melinoe_2795"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's not his fault. Chronos must have cast him from the House and put him out to pasture. But if I can just break through all that grime, I'm certain I can calm him down."
      Speaker = "Melinoe"
      Event = "SkellyAboutCerberus01"
    }
    {
      Id = "Skelly_0241"
      InheritFrom = "BaseSubtitle"
      DisplayName = "He never did like baths, just so you know..."
      Speaker = "Skelly"
      Event = "SkellyAboutCerberus01"
    }
    {
      Id = "Melinoe_2995"
      InheritFrom = "BaseNarrative"
      DisplayName = "Commander, you once held a place of honor in my father's House. So, you must know Cerberus, right? I found him in the Mourning Fields, coated in Miasma, heads to paws. Was he always prone to uncontrolled fits of rage?"
      Speaker = "Melinoe"
      Event = "SkellyAboutCerberus01B"
    }
    {
      Id = "Melinoe_2997"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's not his fault. Chronos must have cast him from the House, put him out to pasture. I broke through all the grime, and calmed him down. But he may need another cleansing soon."
      Speaker = "Melinoe"
      Event = "SkellyAboutCerberus01B"
    }
    {
      Id = "Skelly_0626"
      InheritFrom = "BaseNarrative"
      DisplayName = "So how's it going with that giant mutt? Still up to no good in the Mourning Fields? He's probably just {#Emph}bored."
      Speaker = "Skelly"
      Event = "SkellyAboutCerberus02"
    }
    {
      Id = "Melinoe_4987"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've been able to break him free of whatever's taken hold of him there, though the affliction seems to keep coming back."
      Speaker = "Melinoe"
      Event = "SkellyAboutCerberus02"
    }
    {
      Id = "Skelly_0627"
      InheritFrom = "BaseNarrative"
      DisplayName = "That figures. He was the dreaded {#DialogLegendaryFormat}Guardian of the Gates{#Prev}! What, you think he'd let you pass just the one time, then never try to block you again?"
      Speaker = "Skelly"
      Event = "SkellyAboutCerberus02"
    }
    {
      Id = "Melinoe_4988"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I was hoping he would, yes."
      Speaker = "Melinoe"
      Event = "SkellyAboutCerberus02"
    }
    {
      Id = "Skelly_0628"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well, too bad."
      Speaker = "Skelly"
      Event = "SkellyAboutCerberus02"
    }
    {
      Id = "Skelly_0238"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, by the way, I meant to say {#Emph}nice going{#Prev}, on occasion of achieving your objective and all that! You did achieve it, right...? Showed {#DialogLegendaryFormat}Chronos {#Prev}the what-for?"
      Speaker = "Skelly"
      Event = "SkellyAboutChronosBossW01"
    }
    {
      Id = "Melinoe_2920"
      InheritFrom = "BaseNarrative"
      DisplayName = "I was able to defeat him, yes, Commander. But, my ultimate objective is far from complete."
      Speaker = "Melinoe"
      Event = "SkellyAboutChronosBossW01"
    }
    {
      Id = "Skelly_0239"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah, well{#Prev}, that's objectives for you! Soon as one's complete, along comes another... but you are gonna {#Emph}keep {#Prev}knocking 'em dead!"
      Speaker = "Skelly"
      Event = "SkellyAboutChronosBossW01"
    }
    {
      Id = "Melinoe_2921"
      InheritFrom = "BaseSubtitle"
      DisplayName = "By your leave."
      Speaker = "Melinoe"
      Event = "SkellyAboutChronosBossW01"
    }
    {
      Id = "Skelly_0369"
      InheritFrom = "BaseNarrative"
      DisplayName = "Word reached me that this past night, you achieved what you set out to do, young one! Major congrats on that, all my disciples and myself salute you on a job well done."
      Speaker = "Skelly"
      Event = "SkellyAboutChronosBossW02"
    }
    {
      Id = "Melinoe_3371"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thank you, Commander! Though, this was a step toward victory I never could have achieved if not for all the training and counsel from Headmistress, Odysseus, and yourself."
      Speaker = "Melinoe"
      Event = "SkellyAboutChronosBossW02"
    }
    {
      Id = "Skelly_0370"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And she even gives credit where credit is due!"
      Speaker = "Skelly"
      Event = "SkellyAboutChronosBossW02"
    }
    {
      Id = "Skelly_0543"
      InheritFrom = "BaseNarrative"
      DisplayName = "So you smacked Chronos good a couple of times now! Remind these Shades and me what is to happen next: How are you gonna kill that which continues coming back?"
      Speaker = "Skelly"
      Event = "SkellyAboutChronosBossW03"
    }
    {
      Id = "Melinoe_4353"
      InheritFrom = "BaseNarrative"
      DisplayName = "Commander, though it's tempting to share all my latest progress, we both know I'm never to divulge the details of my task. Not even to you."
      Speaker = "Melinoe"
      Event = "SkellyAboutChronosBossW03"
    }
    {
      Id = "Skelly_0544"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Not even to me. {#Prev}But can you say at least, your brother, is he gonna be all right? Been worrying about the guy is all..."
      Speaker = "Skelly"
      Event = "SkellyAboutChronosBossW03"
    }
    {
      Id = "Melinoe_4354"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Nice try, sir."
      Speaker = "Melinoe"
      Event = "SkellyAboutChronosBossW03"
    }
    {
      Id = "Skelly_0629"
      InheritFrom = "BaseNarrative"
      DisplayName = "My disciples indicate you reached your destination but you choked a little right there at the end. Well, that's rough. To have come {#Emph}that {#Prev}far only to wind up {#Emph}all {#Prev}the way back here..."
      Speaker = "Skelly"
      Event = "SkellyAboutChronosBossL01"
    }
    {
      Id = "Melinoe_4989"
      InheritFrom = "BaseNarrative"
      DisplayName = "Commander, this is not the type of encouragement that's of benefit right now. I had Chronos cornered, but he overpowered me. And now I've lost the element of surprise!"
      Speaker = "Melinoe"
      Event = "SkellyAboutChronosBossL01"
    }
    {
      Id = "Skelly_0630"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ooh, {#Emph}yeah{#Prev}, that's bad. Look, I hate to say this but I'd probably {#DialogLegendaryFormat}hang it up {#Prev}if I was you. Blowin' a chance like that?"
      Speaker = "Skelly"
      Event = "SkellyAboutChronosBossL01"
    }
    {
      Id = "Melinoe_4990"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Commander...!"
      Speaker = "Melinoe"
      Event = "SkellyAboutChronosBossL01"
    }
    {
      Id = "Melinoe_3807"
      InheritFrom = "BaseNarrative"
      DisplayName = "Commander, what is the consensus here about Prometheus? If some mortals venerated him, perhaps you and your disciples feel conflicted that he now opposes us."
      Speaker = "Melinoe"
      Event = "SkellyAboutPrometheus01"
    }
    {
      Id = "Skelly_0399"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Titan who brought fire, reason, good eats, and the arts and stuff to mortalkind... then faced the vengeance of the gods for all of that. Can't stand the guy! Let him have it!"
      Speaker = "Skelly"
      Event = "SkellyAboutPrometheus01"
    }
    {
      Id = "Melinoe_3808"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wait, you can't stand him even though he did so much for you? Though mortals can be difficult to please..."
      Speaker = "Melinoe"
      Event = "SkellyAboutPrometheus01"
    }
    {
      Id = "Skelly_0400"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well let's see, has he been nice to you, or has he tried to kill you? So what if he buttered us up way back when! Not like he's done much for us lately."
      Speaker = "Skelly"
      Event = "SkellyAboutPrometheus01"
    }
    {
      Id = "Melinoe_3809"
      InheritFrom = "BaseSubtitle"
      DisplayName = "He {#Emph}has {#Prev}tried to kill me..."
      Speaker = "Melinoe"
      Event = "SkellyAboutPrometheus01"
    }
    {
      Id = "Skelly_0454"
      InheritFrom = "BaseNarrative"
      DisplayName = "Mind telling all these Shades that {#Emph}no{#Prev}, the {#DialogLegendaryFormat}Father of All Monsters {#Prev}{#Emph}isn't {#Prev}back? Because they're so caught up with this outrageous rumor, they don't buy it when {#Emph}I {#Prev}tell 'em!"
      Speaker = "Skelly"
      Event = "SkellyAboutTyphon01"
    }
    {
      Id = "Melinoe_4059"
      InheritFrom = "BaseNarrative"
      DisplayName = "Commander, the thing is... I confronted Typhon himself just last night. While Chronos schemes from the Underworld, that monstrosity attacks Olympus."
      Speaker = "Melinoe"
      Event = "SkellyAboutTyphon01"
    }
    {
      Id = "Skelly_0455"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh! I, {#Emph}uh{#Prev}, I... {#Emph}knew {#Prev}all that, it's just... I was checking to see if my disciples had the nerve to stand up for that which they truly believed! And they did. Nice going, everyone!"
      Speaker = "Skelly"
      Event = "SkellyAboutTyphon01"
    }
    {
      Id = "Melinoe_4060"
      InheritFrom = "BaseSubtitle"
      DisplayName = "So you knew of Typhon's return?"
      Speaker = "Melinoe"
      Event = "SkellyAboutTyphon01"
    }
    {
      Id = "Skelly_0456"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yeah! Yeah..."
      Speaker = "Skelly"
      Event = "SkellyAboutTyphon01"
    }
    {
      Id = "Skelly_0457"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, {#Emph}uh{#Prev}, would you attest to my disciples that I've taught you a great deal when it comes to fighting {#DialogLegendaryFormat}Typhon{#Prev}? They've been getting a little unruly and, {#Emph}uh{#Prev}, you'd be doing me a favor!"
      Speaker = "Skelly"
      Event = "SkellyAboutTyphon02"
    }
    {
      Id = "Melinoe_4061"
      InheritFrom = "BaseNarrative"
      DisplayName = "But Commander, you've not told me anything about him... {#Emph}ah{#Prev}, I know what this is. You wish to see if I would stoop to speaking falsehoods merely because I was asked!"
      Speaker = "Melinoe"
      Event = "SkellyAboutTyphon02"
    }
    {
      Id = "Skelly_0458"
      InheritFrom = "BaseNarrative"
      DisplayName = "Um, {#Emph}yeah! {#Prev}Yeah that's right. And I'm asking real nicely, c—come on, young one, would you just do this for me here...?"
      Speaker = "Skelly"
      Event = "SkellyAboutTyphon02"
    }
    {
      Id = "Melinoe_4062"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll not bring shame upon us both."
      Speaker = "Melinoe"
      Event = "SkellyAboutTyphon02"
    }
    {
      Id = "Skelly_0459"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}...Dammit."
      Speaker = "Skelly"
      Event = "SkellyAboutTyphon02"
    }
    {
      Id = "Melinoe_4228"
      InheritFrom = "BaseNarrative"
      DisplayName = "Commander, how am I to overcome a foe whose life-force is completely undetectable? Typhon the Bringer of Storms conceals his strength from me... but it must have its limits."
      Speaker = "Melinoe"
      Event = "SkellyAboutTyphon03"
    }
    {
      Id = "Skelly_0541"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know, young one, most of us can't sense another's life-force quite like you. We just hit each other till somebody ends up dead! Maybe there's signs, like {#DialogLegendaryFormat}cuts {#Prev}and {#DialogLegendaryFormat}bruises {#Prev}and whatnot?"
      Speaker = "Skelly"
      Event = "SkellyAboutTyphon03"
    }
    {
      Id = "Melinoe_4229"
      InheritFrom = "BaseNarrative"
      DisplayName = "He's not impervious. The gods have vanquished him before using sheer force..."
      Speaker = "Melinoe"
      Event = "SkellyAboutTyphon03"
    }
    {
      Id = "Skelly_0542"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just let him have it! Works with everybody {#Emph}else!"
      Speaker = "Skelly"
      Event = "SkellyAboutTyphon03"
    }
    {
      Id = "Skelly_0460"
      InheritFrom = "BaseNarrative"
      DisplayName = "Settle a little wager here, young one. These Shades are making claims {#Emph}you {#Prev}felled the {#DialogLegendaryFormat}Father of All Monsters{#Prev}! I, however, am the voice of reason, and I say {#Emph}come onnn."
      Speaker = "Skelly"
      Event = "SkellyAboutTyphonW01"
    }
    {
      Id = "Melinoe_4063"
      InheritFrom = "BaseNarrative"
      DisplayName = "Typhon's recent defeat certainly wasn't my doing alone, Commander. We have Olympus on our side, and more!"
      Speaker = "Melinoe"
      Event = "SkellyAboutTyphonW01"
    }
    {
      Id = "Skelly_0461"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh! Right, {#Emph}um{#Prev}, yeah, that's what I said: Technically, it wasn't just {#Emph}you{#Prev}. Hear that, disciples?! She had a bunch of those fancy {#DialogLegendaryFormat}Boons {#Prev}and who only knows what else!"
      Speaker = "Skelly"
      Event = "SkellyAboutTyphonW01"
    }
    {
      Id = "Melinoe_4064"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Then you win the wager?"
      Speaker = "Melinoe"
      Event = "SkellyAboutTyphonW01"
    }
    {
      Id = "Skelly_0462"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Damn right!"
      Speaker = "Skelly"
      Event = "SkellyAboutTyphonW01"
    }
    {
      Id = "Skelly_0478"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have repeatedly knocked {#DialogLegendaryFormat}Typhon {#Prev}from his perch! Mayhaps {#Emph}the bigger they are... the harder they fall."
      Speaker = "Skelly"
      Event = "SkellyAboutTyphonW02"
    }
    {
      Id = "Melinoe_4165"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've never thought of it that way before, Commander, but you're right! The Cyclops Polyphemus also falls quite hard."
      Speaker = "Melinoe"
      Event = "SkellyAboutTyphonW02"
    }
    {
      Id = "Skelly_0479"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Because of his size, you see!"
      Speaker = "Skelly"
      Event = "SkellyAboutTyphonW02"
    }
    {
      Id = "Melinoe_4065"
      InheritFrom = "BaseNarrative"
      DisplayName = "How is the morale amongst all your disciples recently, Commander? Prometheus and Typhon present imposing threats that may shake even the greatest resolve."
      Speaker = "Melinoe"
      Event = "SkellyAboutCatastrophe01"
    }
    {
      Id = "Skelly_0463"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Eh {#Prev}they're {#Emph}fine! {#Prev}Just look at 'em, brave as you're gonna get. No matter what catastrophe should come to pass, it's just another night to us here!"
      Speaker = "Skelly"
      Event = "SkellyAboutCatastrophe01"
    }
    {
      Id = "Melinoe_4066"
      InheritFrom = "BaseNarrative"
      DisplayName = "We're trying to {#Emph}prevent {#Prev}catastrophe, not let it become the norm. Well, please let me know if anything changes. We need you all at your best."
      Speaker = "Melinoe"
      Event = "SkellyAboutCatastrophe01"
    }
    {
      Id = "Skelly_0464"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hear that, you slackers? Better bring your best, or {#Emph}else!"
      Speaker = "Skelly"
      Event = "SkellyAboutCatastrophe01"
    }
    {
      Id = "Skelly_0144"
      InheritFrom = "BaseNarrative"
      DisplayName = "I sense a great weight bearing down on you, young one. Not quite as bad as what old Atlas got, but still!"
      Speaker = "Skelly"
      Event = "SkellyAboutRouteChoice01"
    }
    {
      Id = "Melinoe_1580"
      InheritFrom = "BaseNarrative"
      DisplayName = "What do you advise as my next move, Commander: to pursue our enemy in the Underworld, or come to the aid of Olympus?"
      Speaker = "Melinoe"
      Event = "SkellyAboutRouteChoice01"
    }
    {
      Id = "Skelly_0145"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well not to be all greedy here, {#Emph}but{#Prev}... I say go wherever you can get the stuff you need the most, right {#Emph}now! {#Prev}We got some stuff down here they don't got up there, and so on, right?"
      Speaker = "Skelly"
      Event = "SkellyAboutRouteChoice01"
    }
    {
      Id = "Melinoe_1581"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...I suppose..."
      Speaker = "Melinoe"
      Event = "SkellyAboutRouteChoice01"
    }
    {
      Id = "Skelly_0494"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're brave to venture through that previously-warded gateway, but come {#Emph}on! {#Prev}You Underworld types aren't cut out for surface life! Unless perchance there is an {#DialogLegendaryFormat}Incantation {#Prev}that could help..."
      Speaker = "Skelly"
      Event = "SkellyAboutSurface01"
    }
    {
      Id = "Melinoe_3366"
      InheritFrom = "BaseNarrative"
      DisplayName = "I think there is, Commander, except... it calls for reagents that can only be found up {#Emph}there... {#Prev}but, how am I supposed to gather them before the incantation is complete?"
      Speaker = "Melinoe"
      Event = "SkellyAboutSurface01"
    }
    {
      Id = "Skelly_0363"
      InheritFrom = "BaseNarrative"
      DisplayName = "Mayhaps just {#DialogLegendaryFormat}make a run for it{#Prev}, I don't know. So what if you can't stay long, just grab what you need and get out of there!"
      Speaker = "Skelly"
      Event = "SkellyAboutSurface01"
    }
    {
      Id = "Melinoe_3367"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It's not ideal, but..."
      Speaker = "Melinoe"
      Event = "SkellyAboutSurface01"
    }
    {
      Id = "Skelly_0142"
      InheritFrom = "BaseNarrative"
      DisplayName = "You remained upon the surface for considerably longer than before. How was it, any good?"
      Speaker = "Skelly"
      Event = "SkellyAboutSurface02"
    }
    {
      Id = "Melinoe_1578"
      InheritFrom = "BaseNarrative"
      DisplayName = "War rages above. The Olympians sent Heracles himself to contain the damage. Shades of the dead linger everywhere. So... {#Emph}not {#Prev}good, all in all."
      Speaker = "Melinoe"
      Event = "SkellyAboutSurface02"
    }
    {
      Id = "Skelly_0143"
      InheritFrom = "BaseNarrative"
      DisplayName = "Shades of the dead! Sure sounds like more disciples we can use. {#Emph}Eh{#Prev}, {#DialogLegendaryFormat}sprint into 'em{#Prev}, will you?"
      Speaker = "Skelly"
      Event = "SkellyAboutSurface02"
    }
    {
      Id = "Melinoe_1579"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yes, sir."
      Speaker = "Melinoe"
      Event = "SkellyAboutSurface02"
    }
    {
      Id = "Skelly_0495"
      InheritFrom = "BaseNarrative"
      DisplayName = "I understand your recent journey to the surface didn't last so long, young one. Life's hard up there, and always gonna be! Not like your cushy Underworld."
      Speaker = "Skelly"
      Event = "SkellyAboutSurface03"
    }
    {
      Id = "Melinoe_4177"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm not accustomed to it yet. Everything's intensified... whenever I fail to evade a foe, I feel it even more."
      Speaker = "Melinoe"
      Event = "SkellyAboutSurface03"
    }
    {
      Id = "Skelly_0496"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh you're not gonna have an easy time."
      Speaker = "Skelly"
      Event = "SkellyAboutSurface03"
    }
    {
      Id = "Skelly_0077"
      InheritFrom = "BaseNarrative"
      DisplayName = "I understand you ventured to the bottom of the sea. I, too, have been there in those depths, young one! But once, awhile back, and briefly, I might add!"
      Speaker = "Skelly"
      Event = "SkellyAboutOceanus01"
    }
    {
      Id = "Melinoe_1044"
      InheritFrom = "BaseNarrative"
      DisplayName = "Of course...! You were a famous mariner in your mortal days! But, then you finally met your end beneath the waters upon which you sailed?"
      Speaker = "Melinoe"
      Event = "SkellyAboutOceanus01"
    }
    {
      Id = "Skelly_0078"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Nah! 'Twas way more glorious than that."
      Speaker = "Skelly"
      Event = "SkellyAboutOceanus01"
    }
    {
      Id = "Skelly_0187"
      InheritFrom = "BaseNarrative"
      DisplayName = "How have you lately fared against the Lurkers and the Serpents all that way down in the watery depths? Knowing of 'em and squaring off against 'em are two very different things."
      Speaker = "Skelly"
      Event = "SkellyAboutOceanus02"
    }
    {
      Id = "Melinoe_2531"
      InheritFrom = "BaseNarrative"
      DisplayName = "They're significantly stronger than the Lost Souls lingering around here. And they have no sense of fear at all, attacking without any hesitation."
      Speaker = "Melinoe"
      Event = "SkellyAboutOceanus02"
    }
    {
      Id = "Skelly_0188"
      InheritFrom = "BaseNarrative"
      DisplayName = "They're basically just walking fish, young one. Not much for conversating, but they'll stick you with a trident just fine! Don't you let 'em."
      Speaker = "Skelly"
      Event = "SkellyAboutOceanus02"
    }
    {
      Id = "Melinoe_2532"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I won't."
      Speaker = "Melinoe"
      Event = "SkellyAboutOceanus02"
    }
    {
      Id = "Skelly_0079"
      InheritFrom = "BaseNarrative"
      DisplayName = "How fared your recent surface sea-journey, young one? I still remember well the boundless waters there. How blue and tranquil they were!"
      Speaker = "Skelly"
      Event = "SkellyAboutThessaly01"
    }
    {
      Id = "Melinoe_1045"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Tranquil? {#Prev}My experience was not exactly that."
      Speaker = "Melinoe"
      Event = "SkellyAboutThessaly01"
    }
    {
      Id = "Skelly_0080"
      InheritFrom = "BaseSubtitle"
      DisplayName = "They were tranquil, damn it..."
      Speaker = "Skelly"
      Event = "SkellyAboutThessaly01"
    }
    {
      Id = "Skelly_0396"
      InheritFrom = "BaseNarrative"
      DisplayName = "My disciples and I all salute you on account of having made it up to the big mountain, young one! Back when we drew breath, we could only dream of those hallowed heights..."
      Speaker = "Skelly"
      Event = "SkellyAboutOlympus01"
    }
    {
      Id = "Melinoe_3805"
      InheritFrom = "BaseNarrative"
      DisplayName = "I appreciate the encouragement, Commander, but I've got a bit of a climb still. The legions of Chronos are there in droves... and the mountain's defenses can't tell us apart."
      Speaker = "Melinoe"
      Event = "SkellyAboutOlympus01"
    }
    {
      Id = "Skelly_0397"
      InheritFrom = "BaseNarrative"
      DisplayName = "Surely you jest! The mechanical marvels wrought by the gods themselves turned their deadly appendages on {#Emph}you? {#Prev}When you went all that way to help 'em out?"
      Speaker = "Skelly"
      Event = "SkellyAboutOlympus01"
    }
    {
      Id = "Melinoe_3806"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Basically yes."
      Speaker = "Melinoe"
      Event = "SkellyAboutOlympus01"
    }
    {
      Id = "Skelly_0398"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Eh {#Prev}that's too bad."
      Speaker = "Skelly"
      Event = "SkellyAboutOlympus01"
    }
    {
      Id = "Melinoe_1046"
      InheritFrom = "BaseNarrative"
      DisplayName = "The old storage case... so, it's an heirloom from my family."
      Speaker = "Melinoe"
      Event = "SkellyAboutGiftRack01"
    }
    {
      Id = "Skelly_0083"
      InheritFrom = "BaseNarrative"
      DisplayName = "That it is, and for as long as I can recollect. Look upon it knowing that the burden which you bear, you need not bear alone. Plus it'll keep your {#DialogLegendaryFormat}Keepsakes {#Prev}all in one handy spot!"
      Speaker = "Skelly"
      Event = "SkellyAboutGiftRack01"
    }
    {
      Id = "Melinoe_1047"
      InheritFrom = "BaseNarrative"
      DisplayName = "A symbol of the gift-giving custom of Olympus, then. A tradition that now falls to us."
      Speaker = "Melinoe"
      Event = "SkellyAboutGiftRack01"
    }
    {
      Id = "Skelly_0084"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yep."
      Speaker = "Skelly"
      Event = "SkellyAboutGiftRack01"
    }
    {
      Id = "Skelly_0085"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're beginning to fill out that {#DialogLegendaryFormat}Keepsake {#Prev}storage case, young one. Fine work, yet I must caution you not to collect just for collecting's sake..."
      Speaker = "Skelly"
      Event = "SkellyAboutGiftRack02"
    }
    {
      Id = "Melinoe_1048"
      InheritFrom = "BaseNarrative"
      DisplayName = "The act of giving is its own intangible reward. Nectar sours when it's offered with impure intent."
      Speaker = "Melinoe"
      Event = "SkellyAboutGiftRack02"
    }
    {
      Id = "Skelly_0086"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Won't have impure intent on my damn training grounds."
      Speaker = "Skelly"
      Event = "SkellyAboutGiftRack02"
    }
    {
      Id = "Skelly_0174"
      InheritFrom = "BaseNarrative"
      DisplayName = "There's something up with those Nocturnal Arms of yours... a certain {#Emph}aura {#Prev}that's surrounding one of them. The {#DialogLegendaryFormat}Grave Thirst{#Prev}..."
      Speaker = "Skelly"
      Event = "SkellyAboutUnusedWeaponBonus01"
    }
    {
      Id = "Melinoe_2490"
      InheritFrom = "BaseNarrative"
      DisplayName = "A relatively simple incantation. I expected there was more to the connection between Night's weapons and the dead. No wonder you can see it, too."
      Speaker = "Melinoe"
      Event = "SkellyAboutUnusedWeaponBonus01"
    }
    {
      Id = "Skelly_0343"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come, now... not like I need eyes on the back of my cranium! But I can feel it in my bones! Want more {#DialogLegendaryFormat}Bones {#Prev}yourself, just {#DialogLegendaryFormat}use the weapon with the Thirst{#Prev}!"
      Speaker = "Skelly"
      Event = "SkellyAboutUnusedWeaponBonus01"
    }
    {
      Id = "Melinoe_2491"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Whenever possible."
      Speaker = "Melinoe"
      Event = "SkellyAboutUnusedWeaponBonus01"
    }
    {
      Id = "Skelly_0226"
      InheritFrom = "BaseNarrative"
      DisplayName = "Way to go with that {#DialogLegendaryFormat}Tablet of Peace{#Prev}, young one! Our ranks are beginning to swell with Shades who may yet find great purpose in their immortal coil!"
      Speaker = "Skelly"
      Event = "SkellyAboutExorcismBook01"
    }
    {
      Id = "Melinoe_2495"
      InheritFrom = "BaseNarrative"
      DisplayName = "Their lives, such as they are, will only improve once my father is restored to his rightful throne."
      Speaker = "Melinoe"
      Event = "SkellyAboutExorcismBook01"
    }
    {
      Id = "Skelly_0184"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh there's no doubt of that! But first, we fight!"
      Speaker = "Skelly"
      Event = "SkellyAboutExorcismBook01"
    }
    {
      Id = "Skelly_0089"
      InheritFrom = "BaseNarrative"
      DisplayName = "My disciples, they were given quite a fright when that {#DialogLegendaryFormat}Pitch-Black Stone {#Prev}there suddenly lit up. You know what it is, do you not?"
      Speaker = "Skelly"
      Event = "SkellyAboutBountyBoard01"
    }
    {
      Id = "Melinoe_2818"
      InheritFrom = "BaseNarrative"
      DisplayName = "A shard of purest darkness from the depths of Chaos... in its countless facets, countless outcomes. Perhaps none of which the Fates have preordained."
      Speaker = "Melinoe"
      Event = "SkellyAboutBountyBoard01"
    }
    {
      Id = "Skelly_0090"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Uhh{#Prev}, yep."
      Speaker = "Skelly"
      Event = "SkellyAboutBountyBoard01"
    }
    {
      Id = "Skelly_0248"
      InheritFrom = "BaseNarrative"
      DisplayName = "We all saw you disappear into that {#DialogLegendaryFormat}Pitch-Black Stone{#Prev}. Another means by which you may spring into action, retaining the element of surprise! {#Emph}Pretty nice!"
      Speaker = "Skelly"
      Event = "SkellyAboutBounties01"
    }
    {
      Id = "Melinoe_2928"
      InheritFrom = "BaseNarrative"
      DisplayName = "That Stone has been here all this time. It's so much more than a monument to Night, and its origins, even more ancient. But I never considered it a weapon in our arsenal..."
      Speaker = "Melinoe"
      Event = "SkellyAboutBounties01"
    }
    {
      Id = "Skelly_0249"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, not like you can crack me over the head with it, but {#Emph}yeah!"
      Speaker = "Skelly"
      Event = "SkellyAboutBounties01"
    }
    {
      Id = "Skelly_0465"
      InheritFrom = "BaseNarrative"
      DisplayName = "You keep on vanishing into the {#DialogLegendaryFormat}Pitch-Black Stone{#Prev}, young one. My disciples and I, we've been thinking must be something pretty good in there!"
      Speaker = "Skelly"
      Event = "SkellyAboutBountyBoard02"
    }
    {
      Id = "Melinoe_4154"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well Commander, it's not exactly a feast on the other side. Whenever I use the Stone, in many ways it's just like any other night, except... I really shouldn't say."
      Speaker = "Melinoe"
      Event = "SkellyAboutBountyBoard02"
    }
    {
      Id = "Skelly_0466"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Aw {#Prev}c'mon why not? Not like somebody's gonna tell on you, I mean, have we not earned your trust, or what?"
      Speaker = "Skelly"
      Event = "SkellyAboutBountyBoard02"
    }
    {
      Id = "Melinoe_4155"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Stone reveals its own secrets, not I."
      Speaker = "Melinoe"
      Event = "SkellyAboutBountyBoard02"
    }
    {
      Id = "Skelly_0467"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Seriously?"
      Speaker = "Skelly"
      Event = "SkellyAboutBountyBoard02"
    }
    {
      Id = "Skelly_0231"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your eyes do not deceive! Near the gateways outta here you'll find none other than the {#DialogLegendaryFormat}Oath of the Unseen{#Prev}, I think it's called. Ask me not whence it came... instead ask just how {#Emph}tough {#Prev}you really are!"
      Speaker = "Skelly"
      Event = "SkellyAboutShrine01"
    }
    {
      Id = "Melinoe_2813"
      InheritFrom = "BaseNarrative"
      DisplayName = "I earned the right to look upon the Oath... the Testaments of Night. Do I dare speak the vows? And thereby spread the Fear that darkness brings...?"
      Speaker = "Melinoe"
      Event = "SkellyAboutShrine01"
    }
    {
      Id = "Skelly_0232"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come on, what are you, {#Emph}scared? {#Prev}Those Nocturnal Arms you got, they probably are gonna love that {#DialogLegendaryFormat}Fear {#Prev}and {#DialogLegendaryFormat}Testament {#Prev}type stuff. I say give it a shot! What's the worst that could happen?"
      Speaker = "Skelly"
      Event = "SkellyAboutShrine01"
    }
    {
      Id = "Melinoe_2814"
      InheritFrom = "BaseNarrative"
      DisplayName = "All mortalkind condemned to never-ending torment and despair...?"
      Speaker = "Melinoe"
      Event = "SkellyAboutShrine01"
    }
    {
      Id = "Skelly_0233"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It's gonna be {#Emph}fine!"
      Speaker = "Skelly"
      Event = "SkellyAboutShrine01"
    }
    {
      Id = "Skelly_0234"
      InheritFrom = "BaseNarrative"
      DisplayName = "How goes it with the never-ending torment stuff, now that you've got that {#DialogLegendaryFormat}Oath {#Prev}thing over there? Those {#DialogLegendaryFormat}Nocturnal Arms {#Prev}of yours, they must be having a {#Emph}great {#Prev}time!"
      Speaker = "Skelly"
      Event = "SkellyAboutShrine02"
    }
    {
      Id = "Melinoe_2815"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Arms of Night... they're reacting to the Oath, I think. Growing stronger as her Testaments are carried out. Drinking the very Nightmares born of mortals' fear of the dark."
      Speaker = "Melinoe"
      Event = "SkellyAboutShrine02"
    }
    {
      Id = "Skelly_0235"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Now {#Emph}that {#Prev}is what I like to hear!"
      Speaker = "Skelly"
      Event = "SkellyAboutShrine02"
    }
    {
      Id = "Melinoe_2816"
      InheritFrom = "BaseNarrative"
      DisplayName = "Even in all your wisdom, Commander... how is it that you know so much about the Oath of the Unseen? As far as I know it pre-dates even my father's rule within the Underworld."
      Speaker = "Melinoe"
      Event = "SkellyAboutShrine03"
    }
    {
      Id = "Skelly_0236"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh yeah, your papa took a different tack. Was all about his Pacts of Punishment! He even served your brother with 'em once, when they were really on the outs. But boyo just went for it, and then things {#Emph}really {#Prev}heated up!"
      Speaker = "Skelly"
      Event = "SkellyAboutShrine03"
    }
    {
      Id = "Melinoe_2817"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You didn't answer my question."
      Speaker = "Melinoe"
      Event = "SkellyAboutShrine03"
    }
    {
      Id = "Skelly_0237"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And I'm not gonna! For I made certain Vows myself."
      Speaker = "Skelly"
      Event = "SkellyAboutShrine03"
    }
    {
      Id = "Skelly_0491"
      InheritFrom = "BaseNarrative"
      DisplayName = "We feared the worst on such a terrifying night. Not so easy out there with that {#DialogLegendaryFormat}Oath of the Unseen {#Prev}doing its thing!"
      Speaker = "Skelly"
      Event = "SkellyAboutShrine04"
    }
    {
      Id = "Melinoe_4175"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Vows do make my task more difficult; but they make me grow stronger, little by little. Are you suggesting I let up?"
      Speaker = "Melinoe"
      Event = "SkellyAboutShrine04"
    }
    {
      Id = "Skelly_0492"
      InheritFrom = "BaseNarrative"
      DisplayName = "I mean I'm only saying if it's all too much you ought to turn that thing back down, nobody's judging over here! I'd rather you {#Emph}let {#Prev}up than {#Emph}give {#Prev}up."
      Speaker = "Skelly"
      Event = "SkellyAboutShrine04"
    }
    {
      Id = "Melinoe_4176"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Neither is best."
      Speaker = "Melinoe"
      Event = "SkellyAboutShrine04"
    }
    {
      Id = "Skelly_0475"
      InheritFrom = "BaseNarrative"
      DisplayName = "Must think you're pretty tough by now, don't you, beating Chronos or whoever down again and again! But are you pushing yourself to the fullest? Or taking it {#DialogLegendaryFormat}easy{#Prev}?"
      Speaker = "Skelly"
      Event = "SkellyAboutNotUsingShrine01"
    }
    {
      Id = "Melinoe_4163"
      InheritFrom = "BaseNarrative"
      DisplayName = "Few would consider the task of vanquishing the Titan of Time to be an easy one, Commander. Though I take your meaning. The Oath of the Unseen beckons..."
      Speaker = "Melinoe"
      Event = "SkellyAboutNotUsingShrine01"
    }
    {
      Id = "Skelly_0476"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come on, {#Emph}use it{#Prev}, my disciples and I are practically daring you! {#Emph}You'll {#Prev}get to spruce up your {#DialogLegendaryFormat}Nocturnal Arms{#Prev}, {#Emph}we'll {#Prev}get to see what happens! {#Emph}Win-win!"
      Speaker = "Skelly"
      Event = "SkellyAboutNotUsingShrine01"
    }
    {
      Id = "Melinoe_4164"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Unless I fail."
      Speaker = "Melinoe"
      Event = "SkellyAboutNotUsingShrine01"
    }
    {
      Id = "Skelly_0477"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}You? {#Prev}C'mon."
      Speaker = "Skelly"
      Event = "SkellyAboutNotUsingShrine01"
    }
    {
      Id = "Skelly_0191"
      InheritFrom = "BaseNarrative"
      DisplayName = "The incense and the smoke and stuff from that {#DialogLegendaryFormat}Altar of Ashes {#Prev}over there, it's energized the Shades about this place! And me, as well."
      Speaker = "Skelly"
      Event = "SkellyAboutAltar01"
    }
    {
      Id = "Melinoe_2588"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm pleased to hear it, Commander. Even a brief visit to the Altar on a given night helps make me feel more prepared."
      Speaker = "Melinoe"
      Event = "SkellyAboutAltar01"
    }
    {
      Id = "Skelly_0192"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Keep doing what you're doing over there!"
      Speaker = "Skelly"
      Event = "SkellyAboutAltar01"
    }
    {
      Id = "Skelly_0242"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your struggles never are in vain, young one! You're no mere mortal; with each passing night, you grow in knowledge and in strength! 'Specially if you throw on that {#DialogLegendaryFormat}God Mode{#Prev}, then there won't be any stopping you!"
      Speaker = "Skelly"
      Event = "SkellyAboutGodMode01"
    }
    {
      Id = "Melinoe_2922"
      InheritFrom = "BaseNarrative"
      DisplayName = "Would that godhood was enough, Commander. Though, the last thing you said... {#Emph}erm{#Prev}, what exactly did you mean?"
      Speaker = "Melinoe"
      Event = "SkellyAboutGodMode01"
    }
    {
      Id = "Skelly_0243"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, {#DialogLegendaryFormat}God Mode{#Prev}? Well, it's this {#Emph}mode{#Prev}, you see. One which you're able to {#Emph}throw on! {#Prev}Or to throw off, entirely at whim! It's just an option's all I'm trying to say, so use it if you please!"
      Speaker = "Skelly"
      Event = "SkellyAboutGodMode01"
    }
    {
      Id = "Melinoe_2923"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just an option..."
      Speaker = "Melinoe"
      Event = "SkellyAboutGodMode01"
    }
    {
      Id = "Skelly_0081"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have an {#DialogLegendaryFormat}Animal Familiar {#Prev}now! Well, your disciples are my disciples, young one. They shall be trained and cared for here while you're away, and they can fight me also if they like?"
      Speaker = "Skelly"
      Event = "SkellyAboutFamiliars01"
    }
    {
      Id = "Melinoe_3552_B"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yes, sir."
      Speaker = "Melinoe"
      Event = "SkellyAboutFamiliars01"
    }
    {
      Id = "Skelly_0401"
      InheritFrom = "BaseNarrative"
      DisplayName = "My disciples are appreciative for all of the improvements to these training grounds, young one! Soon we shall have a proper war camp here!"
      Speaker = "Skelly"
      Event = "SkellyAboutCosmetics01"
    }
    {
      Id = "Melinoe_3810"
      InheritFrom = "BaseNarrative"
      DisplayName = "Anything we can do to raise morale is worth our while. Are there other improvements that you'd like to see?"
      Speaker = "Melinoe"
      Event = "SkellyAboutCosmetics01"
    }
    {
      Id = "Skelly_0402"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ah well, as you know I have but modest needs! A good smack in the head now and again is all that I require."
      Speaker = "Skelly"
      Event = "SkellyAboutCosmetics01"
    }
    {
      Id = "Melinoe_3811"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just let me know if there's anything else."
      Speaker = "Melinoe"
      Event = "SkellyAboutCosmetics01"
    }
    {
      Id = "Skelly_0176"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, to have felt the deadly sting of the {#DialogLegendaryFormat}Sister Blades{#Prev}! Mayhaps these are the {#Emph}sharpest {#Prev}blades with which I've ever been {#Emph}sliced!"
      Speaker = "Skelly"
      Event = "SkellyAboutDagger01"
    }
    {
      Id = "Melinoe_2492"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm honored to bear them."
      Speaker = "Melinoe"
      Event = "SkellyAboutDagger01"
    }
    {
      Id = "Skelly_0503"
      InheritFrom = "BaseNarrative"
      DisplayName = "So you've awakened newfound power in those Blades of yours. I figured they could pull a fancy trick like that! Your brother, his old weapons all worked pretty much the same!"
      Speaker = "Skelly"
      Event = "SkellyAboutHiddenDaggerAspect01"
    }
    {
      Id = "Melinoe_4273"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Infernal Arms had hidden Aspects, too... though whose, I wonder. Perhaps one of your own, Commander! The Fates bestowed their weapons to heroes, as well as gods..."
      Speaker = "Melinoe"
      Event = "SkellyAboutHiddenDaggerAspect01"
    }
    {
      Id = "Skelly_0504"
      InheritFrom = "BaseNarrative"
      DisplayName = "Careful there, young one! The secrets of the Arms are never to be loudly blabbed about..."
      Speaker = "Skelly"
      Event = "SkellyAboutHiddenDaggerAspect01"
    }
    {
      Id = "Melinoe_4274"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Of course. Apologies."
      Speaker = "Melinoe"
      Event = "SkellyAboutHiddenDaggerAspect01"
    }
    {
      Id = "Skelly_0177"
      InheritFrom = "BaseNarrative"
      DisplayName = "The monstrous power of the {#DialogLegendaryFormat}Moonstone Axe {#Prev}is yours! There isn't much out there it couldn't chop clean through, including {#Emph}me!"
      Speaker = "Skelly"
      Event = "SkellyAboutAxe01"
    }
    {
      Id = "Melinoe_2493"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It's got some heft."
      Speaker = "Melinoe"
      Event = "SkellyAboutAxe01"
    }
    {
      Id = "Skelly_0180"
      InheritFrom = "BaseNarrative"
      DisplayName = "The {#DialogLegendaryFormat}Umbral Flames{#Prev}, young one! You're the spitting image of the big lady herself with those in hand. May they ever light your way, and light up anybody you don't like."
      Speaker = "Skelly"
      Event = "SkellyAboutTorch01"
    }
    {
      Id = "Melinoe_2494"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll fight like Headmistress herself."
      Speaker = "Melinoe"
      Event = "SkellyAboutTorch01"
    }
    {
      Id = "Skelly_0403"
      InheritFrom = "BaseNarrative"
      DisplayName = "I must salute the bearer of the {#DialogLegendaryFormat}Argent Skull{#Prev}! Would that my own cranium were thusly reinforced with silver and could explode with such spectacular results!"
      Speaker = "Skelly"
      Event = "SkellyAboutLob01"
    }
    {
      Id = "Melinoe_3812"
      InheritFrom = "BaseSubtitle"
      DisplayName = "One good skull deserves another."
      Speaker = "Melinoe"
      Event = "SkellyAboutLob01"
    }
    {
      Id = "Skelly_0404"
      InheritFrom = "BaseNarrative"
      DisplayName = "So {#Emph}this {#Prev}is the {#DialogLegendaryFormat}Black Coat{#Prev}! An armament such as the world has never before seen! Probably because that thing can punch or blow up anybody fool enough to cross your path!"
      Speaker = "Skelly"
      Event = "SkellyAboutSuit01"
    }
    {
      Id = "Melinoe_3813"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It fits like it was made for me..."
      Speaker = "Melinoe"
      Event = "SkellyAboutSuit01"
    }
    {
      Id = "Skelly_0303"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your myriad accomplishments thus far are nothing in comparison to that which you now stand to gain, young one! {#DialogLegendaryFormat}Eternal glory {#Prev}can be yours, if you but prove your worth!"
      Speaker = "Skelly"
      Event = "SkellyAboutTrophyQuest01"
    }
    {
      Id = "Melinoe_3269"
      InheritFrom = "BaseNarrative"
      DisplayName = "The patterns on that drapery... the secret Gifts of the Veil, bestowed on Night's most dedicated servants...! Commander, what are they doing here? Shades are never to look upon them!"
      Speaker = "Melinoe"
      Event = "SkellyAboutTrophyQuest01"
    }
    {
      Id = "Skelly_0304"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well let's just say the rules have lately changed! Those {#Emph}Gifts{#Prev}, as you refer to them, are yours to earn... provided you can do the stuff the {#DialogLegendaryFormat}Oath of the Unseen {#Prev}would ask of you! Which, as you probably surmised, shall be no simple feat."
      Speaker = "Skelly"
      Event = "SkellyAboutTrophyQuest01"
    }
    {
      Id = "Melinoe_3270"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps a test merely of greed and arrogance... to overextend with the Oath may put my task in jeopardy."
      Speaker = "Melinoe"
      Event = "SkellyAboutTrophyQuest01"
    }
    {
      Id = "Skelly_0305"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}C'mon{#Prev}, don't be such a {#Emph}baby!"
      Speaker = "Skelly"
      Event = "SkellyAboutTrophyQuest01"
    }
    {
      Id = "Skelly_0306"
      InheritFrom = "BaseNarrative"
      DisplayName = "So are you gonna earn the Gifts of the Veil over there? Or squander your chance to get some of that {#DialogLegendaryFormat}eternal glory{#Prev}?"
      Speaker = "Skelly"
      Event = "SkellyAboutTrophyQuest02"
    }
    {
      Id = "Melinoe_3271"
      InheritFrom = "BaseNarrative"
      DisplayName = "Eternal glory... if such a thing may come to those who manage to achieve extraordinary feats, so be it. But to chase glory as a goal unto itself? That can't be right... at least, it's never been our way."
      Speaker = "Melinoe"
      Event = "SkellyAboutTrophyQuest02"
    }
    {
      Id = "Skelly_0307"
      InheritFrom = "BaseNarrative"
      DisplayName = "But our ways can {#Emph}change{#Prev}, wouldn't you say? We mustn't become mired in the olden ways of doing things! Though I don't mean to pressure you, kiddo, it's just... I think you ought to get what's yours, is all."
      Speaker = "Skelly"
      Event = "SkellyAboutTrophyQuest02"
    }
    {
      Id = "Melinoe_3272"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...I'll think about it."
      Speaker = "Melinoe"
      Event = "SkellyAboutTrophyQuest02"
    }
    {
      Id = "Skelly_0358_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "Halfway to victory, kiddo! But to earn the Gifts of the Veil, one must conquer the Underworld {#Emph}and {#Prev}the surface realms upon a {#DialogLegendaryFormat}Fear{#Prev}-ful night, each in turn. You up for it?"
      Speaker = "Skelly"
      Event = "SkellyAboutTrophyQuestProgress01_A"
    }
    {
      Id = "Melinoe_3362"
      InheritFrom = "BaseNarrative"
      DisplayName = "For the glory of the Underworld and the everlasting rule of Night, I would do everything in my ability. Whether that makes me worthy of the Gifts of the Veil, I know not."
      Speaker = "Melinoe"
      Event = "SkellyAboutTrophyQuestProgress01_A"
    }
    {
      Id = "Skelly_0359"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}C'mon{#Prev}, what kind of attitude is {#Emph}that? {#Prev}You did the Underworld already, now you just got to do the surface, and the Gifts are {#Emph}yours! {#Prev}First one of 'em at least. Come on, do it!"
      Speaker = "Skelly"
      Event = "SkellyAboutTrophyQuestProgress01_A"
    }
    {
      Id = "Melinoe_3363"
      InheritFrom = "BaseSubtitle"
      DisplayName = "OK...!"
      Speaker = "Melinoe"
      Event = "SkellyAboutTrophyQuestProgress01_A"
    }
    {
      Id = "Skelly_0358"
      InheritFrom = "BaseNarrative"
      DisplayName = "Halfway to victory, young one! But to earn the Gifts of the Veil, one must conquer the Underworld {#Emph}and {#Prev}the surface realms upon a {#DialogLegendaryFormat}Fear{#Prev}-ful night each in turn. You up for it?"
      Speaker = "Skelly"
      Event = "SkellyAboutTrophyQuestProgress01_B"
    }
    {
      Id = "Skelly_0360"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}C'mon{#Prev}, what kind of attitude is {#Emph}that? {#Prev}You did the surface already, now you just got to do the Underworld, and the Gifts are {#Emph}yours! {#Prev}First one of 'em at least. Come on, do it!"
      Speaker = "Skelly"
      Event = "SkellyAboutTrophyQuestProgress01_B"
    }
    {
      Id = "Skelly_0372"
      InheritFrom = "BaseNarrative"
      DisplayName = "The second {#DialogLegendaryFormat}Gift of the Veil {#Prev}is {#Emph}almost {#Prev}within reach! Could actually just go right up and touch it, b-but anyway a-are you prepared to use the {#DialogLegendaryFormat}Oath {#Prev}and go the other way?"
      Speaker = "Skelly"
      Event = "SkellyAboutTrophyQuestProgress02_A"
    }
    {
      Id = "Melinoe_3485"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't mean to leave you in suspense, Commander, but we'll just have to see."
      Speaker = "Melinoe"
      Event = "SkellyAboutTrophyQuestProgress02_A"
    }
    {
      Id = "Skelly_0373"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I shall be waiting here with the equivalent of bated breath!"
      Speaker = "Skelly"
      Event = "SkellyAboutTrophyQuestProgress02_A"
    }
    {
      Id = "Skelly_0374"
      InheritFrom = "BaseNarrative"
      DisplayName = "The final and most monumental {#DialogLegendaryFormat}Gift of the Veil {#Prev}is so close at hand! If you can get through {#Emph}one {#Prev}of your two routes under the Oath, then surely the rest is but a walk in the park!"
      Speaker = "Skelly"
      Event = "SkellyAboutTrophyQuestProgress03_A"
    }
    {
      Id = "Melinoe_3486"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can only assume a walk in this {#Emph}park {#Prev}you cite must be an absolutely grueling experience."
      Speaker = "Melinoe"
      Event = "SkellyAboutTrophyQuestProgress03_A"
    }
    {
      Id = "Skelly_0375"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Some parts of town? {#Emph}Ohh {#Prev}yeah."
      Speaker = "Skelly"
      Event = "SkellyAboutTrophyQuestProgress03_A"
    }
    {
      Id = "Melinoe_3288"
      InheritFrom = "BaseNarrative"
      DisplayName = "To think the Gifts of the Veil were those statues... I always thought it was the Veils themselves... the draperies, sewn with the finest fabric of the Fates. Where are they anyway?"
      Speaker = "Melinoe"
      Event = "SkellyAboutTrophyQuest03"
    }
    {
      Id = "Skelly_0322"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, those? We, {#Emph}uh{#Prev}, we sent 'em back into the shadows whence they came. They were just packing materials, you know? You got the {#DialogLegendaryFormat}real deal{#Prev}, I swear!"
      Speaker = "Skelly"
      Event = "SkellyAboutTrophyQuest03"
    }
    {
      Id = "Melinoe_3289"
      InheritFrom = "BaseNarrative"
      DisplayName = "I still cannot entirely believe that Night would honor me with such an ostentatious display. Although, perhaps these Gifts are less for {#Emph}me {#Prev}and more for those who serve our cause..."
      Speaker = "Melinoe"
      Event = "SkellyAboutTrophyQuest03"
    }
    {
      Id = "Skelly_0323"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now that you mention it, the Shades {#Emph}do {#Prev}like to gawk at 'em when you're not here. You get to inspire them even if you're not around! If that's not {#DialogLegendaryFormat}eternal glory{#Prev}... what is?"
      Speaker = "Skelly"
      Event = "SkellyAboutTrophyQuest03"
    }
    {
      Id = "Melinoe_3290"
      InheritFrom = "BaseNarrative"
      DisplayName = "These Shades are inspired because I went out of my way to use the Oath of the Unseen purely for personal gain?"
      Speaker = "Melinoe"
      Event = "SkellyAboutTrophyQuest03"
    }
    {
      Id = "Skelly_0324_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Yeah! {#Prev}They're easy to please! But not you, apparently. I didn't know Night's Champion was gonna have so many questions all the time! You want the statues, or don't you?"
      Speaker = "Skelly"
      Event = "SkellyAboutTrophyQuest03"
    }
    {
      Id = "Melinoe_3291"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...I... I do!"
      Speaker = "Melinoe"
      Event = "SkellyAboutTrophyQuest03"
    }
    {
      Id = "Skelly_0325"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Good! {#Prev}'Cause we can't send 'em back now that you opened 'em up."
      Speaker = "Skelly"
      Event = "SkellyAboutTrophyQuest03"
    }
    {
      Id = "Melinoe_3292"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...What?"
      Speaker = "Melinoe"
      Event = "SkellyAboutTrophyQuest03"
    }
    {
      Id = "Skelly_0326"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What!"
      Speaker = "Skelly"
      Event = "SkellyAboutTrophyQuest03"
    }
    {
      Id = "Melinoe_3275"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Commander, is that supposed to be... {#Emph}me?"
      Speaker = "Melinoe"
      Event = "TrophyQuestComplete01"
    }
    {
      Id = "Skelly_0310"
      InheritFrom = "BaseNarrative"
      DisplayName = "It is {#DialogLegendaryFormat}Night's Champion {#Prev}foretold by Fate! She who shall strike {#DialogLegendaryFormat}Fear {#Prev}into the hearts of those who stand against the realm and stuff like that! I can see you're at a loss for words, such is the splendor of her likeness! And this is just the first of 'em!"
      Speaker = "Skelly"
      Event = "TrophyQuestComplete01"
    }
    {
      Id = "Melinoe_3276"
      InheritFrom = "BaseNarrative"
      DisplayName = "Indeed. And are the other Gifts just as, {#Emph}erm... {#Prev}detailed? Either way, I'm not so certain I can handle twice let alone three times the glory, when my task is difficult enough as it is..."
      Speaker = "Melinoe"
      Event = "TrophyQuestComplete01"
    }
    {
      Id = "Skelly_0311"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ahh{#Prev}, so then the {#DialogLegendaryFormat}Fear {#Prev}is getting to you. Do not give in to it, young one! Instead, give in to {#DialogLegendaryFormat}Curiosity {#Prev}about those other glorious Gifts! Think of the {#Emph}prestige! {#Prev}Now you can be a little scaredy quitter, or {#DialogLegendaryFormat}Night's Champion{#Prev}, which is it gonna be?"
      Speaker = "Skelly"
      Event = "TrophyQuestComplete01"
    }
    {
      Id = "Melinoe_3277"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Do I have to decide this instant?"
      Speaker = "Melinoe"
      Event = "TrophyQuestComplete01"
    }
    {
      Id = "Skelly_0312"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Nah {#Prev}you take however long you need."
      Speaker = "Skelly"
      Event = "TrophyQuestComplete01"
    }
    {
      Id = "Melinoe_3280"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Commander, I... I'm rather at a loss for words, I think! Though I am honored, truly."
      Speaker = "Melinoe"
      Event = "TrophyQuestComplete02"
    }
    {
      Id = "Skelly_0315"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh you {#Emph}better {#Prev}be! You got any idea what I — I mean the {#Emph}Fates {#Prev}must have gone through to put these things together? But {#DialogLegendaryFormat}Night's Champion {#Prev}deserves only the best... which is that {#Emph}last {#Prev}one you haven't seen just yet!"
      Speaker = "Skelly"
      Event = "TrophyQuestComplete02"
    }
    {
      Id = "Melinoe_3281"
      InheritFrom = "BaseNarrative"
      DisplayName = "My mind reels at the thought of a sculpture in excess of those. It's covered in Night's drapery... what's to stop me from merely taking a look? Apparently {#Emph}you've {#Prev}already seen it."
      Speaker = "Melinoe"
      Event = "TrophyQuestComplete02"
    }
    {
      Id = "Skelly_0316"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sounds like {#Emph}you {#Prev}might not be {#DialogLegendaryFormat}Night's Champion {#Prev}after all, suggesting underhanded tactics such as that! You want to win top honors, you gotta {#Emph}have {#Prev}honor. And that means no peeking! Now you gonna use the {#DialogLegendaryFormat}Oath {#Prev}again, or what?"
      Speaker = "Skelly"
      Event = "TrophyQuestComplete02"
    }
    {
      Id = "Melinoe_3282"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I don't know. All this still strikes me as a bit unwise. While I value your encouragement and am inspired by your words of validation, perhaps I shouldn't be so quick to pin my sense of self-worth on accumulating material possessions."
      Speaker = "Melinoe"
      Event = "TrophyQuestComplete02"
    }
    {
      Id = "Skelly_0317"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come {#Emph}on{#Prev}, young one, you mustn't {#Emph}speak {#Prev}that way!"
      Speaker = "Skelly"
      Event = "TrophyQuestComplete02"
    }
    {
      Id = "Melinoe_3285"
      InheritFrom = "BaseNarrative"
      DisplayName = "I... I'm deeply honored, Commander. To be in service to the realm, and to have earned such... provocative sculptures. I thought art was about the expression of beauty; I never realized that it could inspire so many... complicated emotions."
      Speaker = "Melinoe"
      Event = "TrophyQuestComplete03"
    }
    {
      Id = "Skelly_0320"
      InheritFrom = "BaseNarrative"
      DisplayName = "I got a lot of complicated emotions just thinking about what it took to get those things in here without you noticing! But anyway, {#DialogLegendaryFormat}congrats{#Prev}. We'd have a feast in your honor or something, but... {#Emph}eh{#Prev}, nobody's supposed to know about this stuff. So it's gonna have to be our secret and all that."
      Speaker = "Skelly"
      Event = "TrophyQuestComplete03"
    }
    {
      Id = "Melinoe_3286"
      InheritFrom = "BaseNarrative"
      DisplayName = "So, does this mean I truly am Night's Champion? And eternal glory is mine?"
      Speaker = "Melinoe"
      Event = "TrophyQuestComplete03"
    }
    {
      Id = "Skelly_0321"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You better believe it."
      Speaker = "Skelly"
      Event = "TrophyQuestComplete03"
    }
    {
      Id = "Melinoe_3287"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...OK."
      Speaker = "Melinoe"
      Event = "TrophyQuestComplete03"
    }
    {
      Id = "Skelly_0450"
      InheritFrom = "BaseNarrative"
      DisplayName = "All of those {#DialogLegendaryFormat}Nocturnal Arms {#Prev}of yours got their own different moves! Do not dwell upon which one of 'em is strongest; rather, choose whichever one really speaks to you."
      Speaker = "Skelly"
      Event = "SkellyHintWeapons01"
    }
    {
      Id = "Melinoe_4054"
      InheritFrom = "BaseNarrative"
      DisplayName = "And what if they all speak to me? Faintly, but still."
      Speaker = "Melinoe"
      Event = "SkellyHintWeapons01"
    }
    {
      Id = "Skelly_0451"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Then pick the one that gives you extra Bones!"
      Speaker = "Skelly"
      Event = "SkellyHintWeapons01"
    }
    {
      Id = "Skelly_0482"
      InheritFrom = "BaseNarrative"
      DisplayName = "Take heed whensoever you observe some bozo with what looks to be a {#DialogLegendaryFormat}yellow barrier {#Prev}around 'em! Ere you punch through their armored protection, they can punch right back!"
      Speaker = "Skelly"
      Event = "SkellyHintArmor01"
    }
    {
      Id = "Melinoe_4167"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've never been able to make an armored foe so much as flinch from one of my strikes."
      Speaker = "Melinoe"
      Event = "SkellyHintArmor01"
    }
    {
      Id = "Skelly_0483"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's perfectly normal, happens to all of us."
      Speaker = "Skelly"
      Event = "SkellyHintArmor01"
    }
    {
      Id = "Skelly_0480"
      InheritFrom = "BaseNarrative"
      DisplayName = "Make sure you're nabbing all the {#DialogLegendaryFormat}Ashes {#Prev}you can find out there, kiddo. Then you can smudge 'em on your Altar to unlock those fancy {#DialogLegendaryFormat}Cards{#Prev}! You'll be brawnier in no time."
      Speaker = "Skelly"
      Event = "SkellyHintMetaCardPoints01"
    }
    {
      Id = "Melinoe_4166"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Arcana reveal my fullest potential... from the Ashes of the past, a possibility for the future."
      Speaker = "Melinoe"
      Event = "SkellyHintMetaCardPoints01"
    }
    {
      Id = "Skelly_0481_B"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A possibility to smack some bozos harder than before!"
      Speaker = "Skelly"
      Event = "SkellyHintMetaCardPoints01"
    }
    {
      Id = "Skelly_0146"
      InheritFrom = "BaseNarrative"
      DisplayName = "All your training's gonna be for naught if you don't use it in a fight. Say I'm chasing after you with a club and you want to get me to stay put. Let's see you cast a {#DialogLegendaryFormat}Circle of Binding {#Prev}over here!"
      Speaker = "Skelly"
      Event = "SkellyHintCast01"
    }
    {
      Id = "Skelly_0484"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't forget to use that {#DialogLegendaryFormat}Cast {#Prev}of yours. Stops any bozos in their tracks! And if you give 'em the {#DialogLegendaryFormat}Omega {#Prev}version... {#Emph}wham!"
      Speaker = "Skelly"
      Event = "SkellyHintCast02"
    }
    {
      Id = "Melinoe_4168"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A Binding Circle has its many uses to be sure..."
      Speaker = "Melinoe"
      Event = "SkellyHintCast02"
    }
    {
      Id = "Skelly_0075"
      InheritFrom = "BaseNarrative"
      DisplayName = "The craft you seek to master takes its toll. But not for long, your magick power's gonna come right back by the time you get to the next place you're going. So {#Emph}use it{#Prev}, no point bottling it up!"
      Speaker = "Skelly"
      Event = "SkellyHintMana01"
    }
    {
      Id = "Skelly_0444"
      InheritFrom = "BaseNarrative"
      DisplayName = "Some of those bozos whom you run into out there are pretty tough! But your fancy {#DialogLegendaryFormat}Omega Moves {#Prev}ought to cut right through 'em as might a hot knife through butter. {#Emph}Battle getting old? {#Prev}{#DialogLegendaryItalicFormat}Press and hold."
      Speaker = "Skelly"
      Event = "SkellyHintDamage01"
    }
    {
      Id = "Melinoe_4055"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Magick is to be used sparingly, in times of need."
      Speaker = "Melinoe"
      Event = "SkellyHintDamage01"
    }
    {
      Id = "Skelly_0445"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And you {#Emph}need {#Prev}to win!"
      Speaker = "Skelly"
      Event = "SkellyHintDamage01"
    }
    {
      Id = "Skelly_0341"
      InheritFrom = "BaseNarrative"
      DisplayName = "I understand that Great Selene graced you with one of them {#DialogLegendaryFormat}Hexes {#Prev}that she's got. A powerful effect, but you must use a bunch of magick first to charge it up! {#Emph}Eh{#Prev}, like charging a crystal!"
      Speaker = "Skelly"
      Event = "SkellyHintSpellDrop01"
    }
    {
      Id = "Melinoe_3359"
      InheritFrom = "BaseNarrative"
      DisplayName = "Commander, I thought most of your experience was in the martial ways. But you know the intricacies of magick as well?"
      Speaker = "Melinoe"
      Event = "SkellyHintSpellDrop01"
    }
    {
      Id = "Skelly_0342"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh yeah."
      Speaker = "Skelly"
      Event = "SkellyHintSpellDrop01"
    }
    {
      Id = "Skelly_0339"
      InheritFrom = "BaseNarrative"
      DisplayName = "Being a shadowy denizen of the Underworld comes with certain perks, young one! Take, for instance, how {#DialogLegendaryFormat}when you Dash, nothing can touch you{#Prev}!"
      Speaker = "Skelly"
      Event = "SkellyHintDash01"
    }
    {
      Id = "Melinoe_3357"
      InheritFrom = "BaseNarrative"
      DisplayName = "We are the Unseen... at one with the darkness and the dead. I can evade anything, yes. But only for a moment, and even then... I can't prevail by dodging all night long."
      Speaker = "Melinoe"
      Event = "SkellyHintDash01"
    }
    {
      Id = "Skelly_0340"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Eh{#Prev}, I'd do it all the time if I was you! See the {#DialogLegendaryFormat}little trail {#Prev}when you Dash? Once it snaps back, you're good to go {#Emph}again!"
      Speaker = "Skelly"
      Event = "SkellyHintDash01"
    }
    {
      Id = "Melinoe_3358"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}The shadow follows..."
      Speaker = "Melinoe"
      Event = "SkellyHintDash01"
    }
    {
      Id = "Skelly_0076"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have grown quick, young one. Real quick! Would that I, too, could {#DialogLegendaryFormat}dash {#Prev}so fast as {#DialogLegendaryFormat}to become untouchable{#Prev}, or sprint as fleetly as a... she-wolf, or something? Give me a couple of laps!"
      Speaker = "Skelly"
      Event = "SkellyHintSprint01"
    }
    {
      Id = "Skelly_0140"
      InheritFrom = "BaseNarrative"
      DisplayName = "Could always use some new disciples here. See any Shades of the dead out there just loitering around, remember your training and {#DialogLegendaryFormat}sprint right into them{#Prev}! They'll come around."
      Speaker = "Skelly"
      Event = "SkellyHintShadeMercs01"
    }
    {
      Id = "Melinoe_1577"
      InheritFrom = "BaseNarrative"
      DisplayName = "They'll more than come around, sir. They're prepared to join our fight. By now they know exactly who I am, and what we stand for here."
      Speaker = "Melinoe"
      Event = "SkellyHintShadeMercs01"
    }
    {
      Id = "Skelly_0141"
      InheritFrom = "BaseSubtitle"
      DisplayName = "May you keep running into lots of them."
      Speaker = "Skelly"
      Event = "SkellyHintShadeMercs01"
    }
    {
      Id = "Skelly_0151"
      InheritFrom = "BaseNarrative"
      DisplayName = "My days of running around taking stuff may be over, but yours are only beginning, kiddo! Keep your eyes peeled for stuff you can use out there, and be sure to pack the best {#DialogLegendaryFormat}Tool {#Prev}for the job."
      Speaker = "Skelly"
      Event = "SkellyHintResources01"
    }
    {
      Id = "Melinoe_2254"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You used to run around and... take stuff?"
      Speaker = "Melinoe"
      Event = "SkellyHintResources01"
    }
    {
      Id = "Skelly_0364"
      InheritFrom = "BaseNarrative"
      DisplayName = "What ails you, young one? You have a look of consternation, which mayhaps my breadth of experience could alleviate. Go on, just spit it out!"
      Speaker = "Skelly"
      Event = "SkellyHintResources02"
    }
    {
      Id = "Melinoe_3368"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, Commander... I was just thinking about all the reagents I still need. Some grow in different regions, or require different tools... it's a lot to keep in mind."
      Speaker = "Melinoe"
      Event = "SkellyHintResources02"
    }
    {
      Id = "Skelly_0365"
      InheritFrom = "BaseNarrative"
      DisplayName = "But you don't gotta keep it all in mind! That {#DialogLegendaryFormat}Purple Pack {#Prev}you carry all of your stuff in, somehow... don't you got all your notes in there too? So if you don't remember where to nab something, check {#Emph}there! {#Prev}In fact, why don't you do it now?"
      Speaker = "Skelly"
      Event = "SkellyHintResources02"
    }
    {
      Id = "Melinoe_3369"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I do have notes on everything in there..."
      Speaker = "Melinoe"
      Event = "SkellyHintResources02"
    }
    {
      Id = "Skelly_0446"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your connection to the realm means you must have a sense of what's ahead at every turn. Like a window to the future at each threshold! You might not know what all the little symbols mean but you'll figure 'em all out eventually."
      Speaker = "Skelly"
      Event = "SkellyHintRoomRewards01"
    }
    {
      Id = "Melinoe_4056"
      InheritFrom = "BaseNarrative"
      DisplayName = "Windows to the future... and at a branching path I simply choose whichever one looks best."
      Speaker = "Melinoe"
      Event = "SkellyHintRoomRewards01"
    }
    {
      Id = "Skelly_0447"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I surely would if I were in your stead."
      Speaker = "Skelly"
      Event = "SkellyHintRoomRewards01"
    }
    {
      Id = "Skelly_0376"
      InheritFrom = "BaseNarrative"
      DisplayName = "With experience, one develops knacks for certain things, and one of {#Emph}my {#Prev}knacks is detecting {#DialogLegendaryFormat}Bones{#Prev}, all shapes and sizes and in varied quantities, and kiddo: {#Emph}You {#Prev}have got {#Emph}a lot."
      Speaker = "Skelly"
      Event = "SkellyHintBones01"
    }
    {
      Id = "Melinoe_3480"
      InheritFrom = "BaseNarrative"
      DisplayName = "We're in the realm of the dead, Commander. Bones aren't difficult to come by, especially this close to the surface. Though... the Broker may have better use for them."
      Speaker = "Melinoe"
      Event = "SkellyHintBones01"
    }
    {
      Id = "Skelly_0377"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's basically what {#Emph}I {#Prev}was gonna say! Sure maybe you could use a couple for an incantation here or there but the old {#DialogLegendaryFormat}Broker{#Prev}'s really gonna eat 'em up."
      Speaker = "Skelly"
      Event = "SkellyHintBones01"
    }
    {
      Id = "Melinoe_3481"
      InheritFrom = "BaseSubtitle"
      DisplayName = "But I like hoarding them..."
      Speaker = "Melinoe"
      Event = "SkellyHintBones01"
    }
    {
      Id = "Skelly_0453"
      InheritFrom = "BaseNarrative"
      DisplayName = "Choose wisely, young one, ere you set forth each night! There's your {#DialogLegendaryFormat}Arcana {#Prev}at the Altar, your choice of {#DialogLegendaryFormat}Nocturnal Arms{#Prev}, your {#DialogLegendaryFormat}Keepsake{#Prev}, your {#DialogLegendaryFormat}Animal Familiar{#Prev}, I mean {#Emph}dang..."
      Speaker = "Skelly"
      Event = "SkellyHintChoices01"
    }
    {
      Id = "Melinoe_3370"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's a lot to consider when you put it that way, Commander. But my objective is always clear: {#Emph}Find the Titan, slay the Titan. Free my family, free Olympus."
      Speaker = "Melinoe"
      Event = "SkellyHintChoices01"
    }
    {
      Id = "Skelly_0368"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well that was like four different things right there..."
      Speaker = "Skelly"
      Event = "SkellyHintChoices01"
    }
    {
      Id = "Skelly_0152"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now don't lose heart just 'cause you're getting whacked, all right? Between your {#DialogLegendaryFormat}Altar {#Prev}and that {#DialogLegendaryFormat}Silver Puddle {#Prev}back there, you're going to get tougher and tougher, till {#Emph}you're {#Prev}the one doing all the whacking!"
      Speaker = "Skelly"
      Event = "SkellyHintDying01"
    }
    {
      Id = "Melinoe_2255"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You mean the Silver Pool, sir."
      Speaker = "Melinoe"
      Event = "SkellyHintDying01"
    }
    {
      Id = "Skelly_0337"
      InheritFrom = "BaseNarrative"
      DisplayName = "So you have reached the limits of your {#DialogLegendaryFormat}Grasp of the Arcana{#Prev}. Happens to everyone! Just need some more of that {#DialogLegendaryFormat}Psyche {#Prev}and you'll soon be grasping for more of them Cards you got!"
      Speaker = "Skelly"
      Event = "SkellyHintGrasp01"
    }
    {
      Id = "Melinoe_3355"
      InheritFrom = "BaseNarrative"
      DisplayName = "My connection to the dead, my connection to the past... and the Altar is the conduit! Commander, are you able to draw from the Arcana yourself?"
      Speaker = "Melinoe"
      Event = "SkellyHintGrasp01"
    }
    {
      Id = "Skelly_0338"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well used to be I could draw pretty good, but {#Emph}eh{#Prev}, maybe not as good as the pictures on those Cards."
      Speaker = "Skelly"
      Event = "SkellyHintGrasp01"
    }
    {
      Id = "Melinoe_3356"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You draw {#Emph}pictures{#Prev}, sir...?"
      Speaker = "Melinoe"
      Event = "SkellyHintGrasp01"
    }
    {
      Id = "Skelly_0448"
      InheritFrom = "BaseNarrative"
      DisplayName = "What gives, young one, you feeling stuck? I mean you {#Emph}are {#Prev}stuck, but you're getting somewhere in the spiritual sense!"
      Speaker = "Skelly"
      Event = "SkellyHintProgress01"
    }
    {
      Id = "Melinoe_4057"
      InheritFrom = "BaseNarrative"
      DisplayName = "And where might that be, Commander...? I'm nowhere near my goal of vanquishing the Titan yet. I need to go farther."
      Speaker = "Melinoe"
      Event = "SkellyHintProgress01"
    }
    {
      Id = "Skelly_0449"
      InheritFrom = "BaseNarrative"
      DisplayName = "Probably just need to {#DialogLegendaryFormat}Dash {#Prev}instead of getting hit so much, and get some more of those {#DialogLegendaryFormat}Arcana Cards{#Prev}, they'll toughen you right up! Each night is gonna go a little different, too."
      Speaker = "Skelly"
      Event = "SkellyHintProgress01"
    }
    {
      Id = "Melinoe_4058"
      InheritFrom = "BaseSubtitle"
      DisplayName = "May this one go a little better."
      Speaker = "Melinoe"
      Event = "SkellyHintProgress01"
    }
    {
      Id = "Skelly_0583"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, {#Emph}curse {#Prev}these brittle old bones, that they cannot withstand as much punishment from you as once they did! Used to be I could really take a hit, but lately? I don't know."
      Speaker = "Skelly"
      Event = "SkellyAboutHealthQuest01"
    }
    {
      Id = "Melinoe_4947"
      InheritFrom = "BaseNarrative"
      DisplayName = "Commander, what has gotten into you? I thought you longed to be struck by whichever armament I had available, the more savagely the better. Should I be holding back?"
      Speaker = "Melinoe"
      Event = "SkellyAboutHealthQuest01"
    }
    {
      Id = "Skelly_0584"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Never! {#Prev}I long merely to absorb more punishment ere I fall to pieces and have to put myself back together. You are way stronger now, but I'm {#Emph}not! {#Prev}Just doesn't seem right! But there {#Emph}is {#Prev}something you can do..."
      Speaker = "Skelly"
      Event = "SkellyAboutHealthQuest01"
    }
    {
      Id = "Melinoe_4948"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What's this? An incantation to augment {#Emph}bone density?"
      Speaker = "Melinoe"
      Event = "SkellyAboutHealthQuest01"
    }
    {
      Id = "Skelly_0585"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just think about it, all right?"
      Speaker = "Skelly"
      Event = "SkellyAboutHealthQuest01"
    }
    {
      Id = "Melinoe_4949"
      InheritFrom = "BaseNarrative"
      DisplayName = "Commander, the Augmentation of Bone Density you taught me... it's a costly incantation. Are you certain you're prepared? If we proceed, there's no undoing the effect."
      Speaker = "Melinoe"
      Event = "SkellyAboutHealthQuest02"
    }
    {
      Id = "Skelly_0586"
      InheritFrom = "BaseNarrative"
      DisplayName = "Young one, I was {#Emph}born {#Prev}prepared. Put yourself in my place: Wouldn't you want to be able to take a real beatin'?"
      Speaker = "Skelly"
      Event = "SkellyAboutHealthQuest02"
    }
    {
      Id = "Melinoe_4950"
      InheritFrom = "BaseNarrative"
      DisplayName = "I prefer to avoid beatings altogether, but can see the appeal from your perspective. Your bones would become much more durable... as long as falling to pieces is not the best part for you."
      Speaker = "Melinoe"
      Event = "SkellyAboutHealthQuest02"
    }
    {
      Id = "Skelly_0587"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's really not, because when I'm in pieces, I'm not getting hit, and {#Emph}that's {#Prev}the good stuff, let me tell {#Emph}you. {#Prev}So you gonna cast this thing or what?"
      Speaker = "Skelly"
      Event = "SkellyAboutHealthQuest02"
    }
    {
      Id = "Melinoe_4951"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm looking into it..."
      Speaker = "Melinoe"
      Event = "SkellyAboutHealthQuest02"
    }
    {
      Id = "Skelly_0589"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah, hahaha, fools! {#Prev}I am now entirely {#DialogLegendaryFormat}invincible{#Prev}, and {#Emph}soon? {#Prev}Real soon, you all shall dearly pay for that which you've said behind my back... vengeance shall finally be {#Emph}mine!"
      Speaker = "Skelly"
      Event = "SkellyAboutHealthQuest03"
    }
    {
      Id = "Melinoe_4955"
      InheritFrom = "BaseNarrative"
      DisplayName = "Commander, what is the meaning of this? You're not yourself! I merely cast the Augmentation of Bone Density!"
      Speaker = "Melinoe"
      Event = "SkellyAboutHealthQuest03"
    }
    {
      Id = "Skelly_0590"
      InheritFrom = "BaseNarrative"
      DisplayName = "And you played right into my fingerbones. For now I cannot {#Emph}possibly {#Prev}be slain! Just you try it and see what occurs!"
      Speaker = "Skelly"
      Event = "SkellyAboutHealthQuest03"
    }
    {
      Id = "Skelly_0591"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ah, hahahahahaha!"
      Speaker = "Skelly"
      Event = "SkellyAboutHealthQuest03"
    }
    {
      Id = "Skelly_0596"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well I hope you learned your lesson, kiddo! You thought I had become more powerful than any foe you'd ever faced, only to discover your {#DialogLegendaryFormat}Augmentation of Bone Density {#Prev}did not do all that much..."
      Speaker = "Skelly"
      Event = "SkellyAboutHealthQuest04"
    }
    {
      Id = "Melinoe_4959"
      InheritFrom = "BaseNarrative"
      DisplayName = "Commander, I feared the worst when you acted as though were, well, drunk with newfound power. I'd never seen that side of you before."
      Speaker = "Melinoe"
      Event = "SkellyAboutHealthQuest04"
    }
    {
      Id = "Skelly_0597"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nor shall you see that side of me {#Emph}again! {#Prev}Provided you don't make a habit of casting incantations you get from strangers!"
      Speaker = "Skelly"
      Event = "SkellyAboutHealthQuest04"
    }
    {
      Id = "Melinoe_4960"
      InheritFrom = "BaseNarrative"
      DisplayName = "But you're not a stranger. You're a trusted ally! Aren't you...?"
      Speaker = "Melinoe"
      Event = "SkellyAboutHealthQuest04"
    }
    {
      Id = "Skelly_0598"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, {#Emph}yeah{#Prev}, but... look forget it, all right? Just hit me like you used to, I don't even care."
      Speaker = "Skelly"
      Event = "SkellyAboutHealthQuest04"
    }
    {
      Id = "Melinoe_4961"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Very well..."
      Speaker = "Melinoe"
      Event = "SkellyAboutHealthQuest04"
    }
    {
      Id = "Melinoe_4962"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's a relief you're not a vengeful adversary who deceived me into casting a spell that awakened his true and terrifying might, Commander, but... do you feel any different after the Augmentation of Bone Density, or not?"
      Speaker = "Melinoe"
      Event = "SkellyAboutHealthQuest05"
    }
    {
      Id = "Skelly_0599"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, you know, I {#Emph}do {#Prev}feel somewhat tougher than before, young one, so thanks! That's really all I figured your incantation was gonna do, but I had you going, didn't I?"
      Speaker = "Skelly"
      Event = "SkellyAboutHealthQuest05"
    }
    {
      Id = "Melinoe_4963"
      InheritFrom = "BaseNarrative"
      DisplayName = "I suppose, but... mostly you just made me realize that I'd be very sad if some evening you did not come back. You're not just our Commander... you're my friend."
      Speaker = "Melinoe"
      Event = "SkellyAboutHealthQuest05"
    }
    {
      Id = "Skelly_0600"
      InheritFrom = "BaseNarrative"
      DisplayName = "What, you really mean that, kiddo? 'Cause let's face it, sometimes all I do is {#Emph}stand {#Prev}here. And not even {#Emph}sometimes!"
      Speaker = "Skelly"
      Event = "SkellyAboutHealthQuest05"
    }
    {
      Id = "Melinoe_4964"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Of course I mean it, sir."
      Speaker = "Melinoe"
      Event = "SkellyAboutHealthQuest05"
    }
    {
      Id = "Skelly_0601"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Aw{#Prev}, now come {#Emph}on..."
      Speaker = "Skelly"
      Event = "SkellyAboutHealthQuest05"
    }
    {
      Id = "Melinoe_4977"
      InheritFrom = "BaseNarrative"
      DisplayName = "I try not to dwell on what shall happen if and when all this is finally over, Commander. I know I ought to be completely focused on the task, but... as we near a potential end, I cannot help but think ahead."
      Speaker = "Melinoe"
      Event = "SkellyAboutUltimateProgress01"
    }
    {
      Id = "Skelly_0614"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well {#Emph}stop {#Prev}it! How many times have I told you, {#EmphLegendary}never think ahead{#Prev}, kiddo. No good is ever gonna come of {#Emph}that. {#Prev}The here-and-now is all that counts!"
      Speaker = "Skelly"
      Event = "SkellyAboutUltimateProgress01"
    }
    {
      Id = "Melinoe_4978"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're truly saying one should never plan? But you're a {#Emph}Commander... {#Prev}anticipation and strategy are integral to martial leadership...!"
      Speaker = "Melinoe"
      Event = "SkellyAboutUltimateProgress01"
    }
    {
      Id = "Skelly_0615"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you're always doing good right {#Emph}now{#Prev}, you're always doing good later, that's all there is to it! Now quit with your worryin'."
      Speaker = "Skelly"
      Event = "SkellyAboutUltimateProgress01"
    }
    {
      Id = "Melinoe_4979"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Erm... {#Prev}OK."
      Speaker = "Melinoe"
      Event = "SkellyAboutUltimateProgress01"
    }
    {
      Id = "Skelly_0644"
      InheritFrom = "BaseNarrative"
      DisplayName = "The rousing tales of your great accomplishment preceded you, young one! And I am here to heap still-further praise: Great job back there with all the Chronos stuff."
      Speaker = "Skelly"
      Event = "SkellyPostTrueEnding01"
    }
    {
      Id = "Melinoe_5002"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thank you very much, Commander, though... what are you still doing here? I kept expecting you'd return to your honorary post at the House, but eventually I had to depart."
      Speaker = "Melinoe"
      Event = "SkellyPostTrueEnding01"
    }
    {
      Id = "Skelly_0645"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well you are not exactly done with everything, {#Emph}are {#Prev}you? I see you eyeballing the gateways out, wondering what's gonna happen now. So as long as {#Emph}you're {#Prev}here... so am I!"
      Speaker = "Skelly"
      Event = "SkellyPostTrueEnding01"
    }
    {
      Id = "Melinoe_5003"
      InheritFrom = "BaseNarrative"
      DisplayName = "So then you're sworn to us... to me."
      Speaker = "Melinoe"
      Event = "SkellyPostTrueEnding01"
    }
    {
      Id = "Skelly_0646"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yeah I'm not going anywhere."
      Speaker = "Skelly"
      Event = "SkellyPostTrueEnding01"
    }
    {
      Id = "Melinoe_5760"
      InheritFrom = "BaseNarrative"
      DisplayName = "I meant to note... I had an unusual experience at the House of Hades. I heard no mention of you there, despite your distinguished status. Only of a skeleton who would stand watch outside... {#Emph}Schele... Schelae... {#Prev}perhaps akin to that?"
      Speaker = "Melinoe"
      Event = "SkellyPostTrueEnding02"
    }
    {
      Id = "Skelly_0756"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Wha?! {#Prev}Kiddo. You think we skeletons are all the same? That's {#Emph}way {#Prev}over the line, pal! Come on, I would have thought... {#Emph}Bwuh! {#Prev}Unbelievable!"
      Speaker = "Skelly"
      Event = "SkellyPostTrueEnding02"
    }
    {
      Id = "Melinoe_5761"
      InheritFrom = "BaseNarrative"
      DisplayName = "What, I... I didn't mean to suggest... {#Emph}eugh{#Prev}, I apologize."
      Speaker = "Melinoe"
      Event = "SkellyPostTrueEnding02"
    }
    {
      Id = "Skelly_0757"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Psh. {#Prev}I mean, I swear..."
      Speaker = "Skelly"
      Event = "SkellyPostTrueEnding02"
    }
    {
      Id = "Melinoe_5675"
      InheritFrom = "BaseNarrative"
      DisplayName = "Commander, what say all your disciples of the reappearance of the Fates? I take it you've already heard."
      Speaker = "Melinoe"
      Event = "SkellyPostEpilogue01"
    }
    {
      Id = "Skelly_0752"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, yes, I've heard all right... {#DialogLegendaryItalicFormat}Fates, Shmates {#Prev}is what they say, if you must know."
      Speaker = "Skelly"
      Event = "SkellyPostEpilogue01"
    }
    {
      Id = "Melinoe_5676"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Fates, Shmates{#Prev}, what is {#Emph}that {#Prev}supposed to mean? It sounds rather disrespectful on initial impression."
      Speaker = "Melinoe"
      Event = "SkellyPostEpilogue01"
    }
    {
      Id = "Skelly_0753"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Disrespectful? {#Prev}Oh {#Emph}far {#Prev}be that from {#Emph}me! {#Prev}I merely say {#DialogLegendaryItalicFormat}Fates, Shmates {#Prev}and ask that you consider the weight of my words."
      Speaker = "Skelly"
      Event = "SkellyPostEpilogue01"
    }
    {
      Id = "Melinoe_5677"
      InheritFrom = "BaseNarrative"
      DisplayName = "You don't care that a new age may dawn... that the rule of gods may end."
      Speaker = "Melinoe"
      Event = "SkellyPostEpilogue01"
    }
    {
      Id = "Skelly_0754"
      InheritFrom = "BaseNarrative"
      DisplayName = "Kiddo, I'll believe it when it happens. We'll probably all be dead by then."
      Speaker = "Skelly"
      Event = "SkellyPostEpilogue01"
    }
    {
      Id = "Melinoe_5678"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm immortal and the rest of you already {#Emph}are {#Prev}dead!"
      Speaker = "Melinoe"
      Event = "SkellyPostEpilogue01"
    }
    {
      Id = "Skelly_0755"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just sayin' don't hold your breath."
      Speaker = "Skelly"
      Event = "SkellyPostEpilogue01"
    }
    {
      Id = "Skelly_0647"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well we did it, kiddo! Or at least {#Emph}I {#Prev}did. This whole experience... it has given me a lot to think about."
      Speaker = "Skelly"
      Event = "SkellyAboutSayingLittle01"
    }
    {
      Id = "Melinoe_5004"
      InheritFrom = "BaseNarrative"
      DisplayName = "At least you should have time to think about it now, Commander. Tell me if you have any epiphanies?"
      Speaker = "Melinoe"
      Event = "SkellyAboutSayingLittle01"
    }
    {
      Id = "Skelly_0648"
      InheritFrom = "BaseNarrative"
      DisplayName = "You bet. But I will probably just not have much to say, I mean, I'm {#Emph}beat! {#Prev}Not beat enough by {#Emph}you{#Prev}, of course, can't ever get enough of {#Emph}that."
      Speaker = "Skelly"
      Event = "SkellyAboutSayingLittle01"
    }
    {
      Id = "Melinoe_5005"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thanks again, Commander."
      Speaker = "Melinoe"
      Event = "SkellyAboutSayingLittle01"
    }
    {
      Id = "Skelly_0012"
      InheritFrom = "BaseNarrative"
      DisplayName = "Mayhaps you could give my disciples a little demonstration, huh?"
      Speaker = "Skelly"
      Event = "SkellyChat01"
    }
    {
      Id = "Skelly_0013"
      InheritFrom = "BaseNarrative"
      DisplayName = "Less discussion, more concussion here, kiddo!"
      Speaker = "Skelly"
      Event = "SkellyChat02"
    }
    {
      Id = "Skelly_0048"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come, young one, let's see you deliver your best shot already."
      Speaker = "Skelly"
      Event = "SkellyChat03"
    }
    {
      Id = "Skelly_0049"
      InheritFrom = "BaseNarrative"
      DisplayName = "Speak not, but concentrate, and strike repeatedly at me!"
      Speaker = "Skelly"
      Event = "SkellyChat04"
    }
    {
      Id = "Skelly_0050"
      InheritFrom = "BaseNarrative"
      DisplayName = "Patience, young one! You shall... probably get through this whole thing."
      Speaker = "Skelly"
      Event = "SkellyChat05"
    }
    {
      Id = "Skelly_0051"
      InheritFrom = "BaseNarrative"
      DisplayName = "Have you come to train with me, perchance? Or merely passing through?"
      Speaker = "Skelly"
      Event = "SkellyChat06"
    }
    {
      Id = "Skelly_0052"
      InheritFrom = "BaseNarrative"
      DisplayName = "Less greeting, more beating, if you would be so kind?"
      Speaker = "Skelly"
      Event = "SkellyChat07"
    }
    {
      Id = "Skelly_0092"
      InheritFrom = "BaseNarrative"
      DisplayName = "I trust you have some damage to impart?"
      Speaker = "Skelly"
      Event = "SkellyChat08"
    }
    {
      Id = "Skelly_0093"
      InheritFrom = "BaseNarrative"
      DisplayName = "Pray strike me down, young one, lest I be sad."
      Speaker = "Skelly"
      Event = "SkellyChat09"
    }
    {
      Id = "Skelly_0094"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hold fast your questions and {#Emph}attack{#Prev}, young one!"
      Speaker = "Skelly"
      Event = "SkellyChat10"
    }
    {
      Id = "Skelly_0095"
      InheritFrom = "BaseNarrative"
      DisplayName = "Let us not conversate unnecessarily, though you can hit me if you want!"
      Speaker = "Skelly"
      Event = "SkellyChat11"
    }
    {
      Id = "Skelly_0096"
      InheritFrom = "BaseNarrative"
      DisplayName = "Have you not more important interactions to perform?"
      Speaker = "Skelly"
      Event = "SkellyChat12"
    }
    {
      Id = "Skelly_0097"
      InheritFrom = "BaseNarrative"
      DisplayName = "Each one of your attempts is but a step along your path. And so is hitting me."
      Speaker = "Skelly"
      Event = "SkellyChat13"
    }
    {
      Id = "Skelly_0098"
      InheritFrom = "BaseNarrative"
      DisplayName = "Pray focus on your path, or mayhaps beat me up a little first."
      Speaker = "Skelly"
      Event = "SkellyChat14"
    }
    {
      Id = "Skelly_0099"
      InheritFrom = "BaseNarrative"
      DisplayName = "My disciples all believe in you and stuff."
      Speaker = "Skelly"
      Event = "SkellyChat15"
    }
    {
      Id = "Skelly_0100"
      InheritFrom = "BaseNarrative"
      DisplayName = "Go forth, young one, and we shall keep vigil here ere you return."
      Speaker = "Skelly"
      Event = "SkellyChat16"
    }
    {
      Id = "Skelly_0101"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, these old bones are more resilient than they appear, see for yourself."
      Speaker = "Skelly"
      Event = "SkellyChat17"
    }
    {
      Id = "Skelly_0102"
      InheritFrom = "BaseNarrative"
      DisplayName = "There shall be time enough for idle chat when victory is ours!"
      Speaker = "Skelly"
      Event = "SkellyChat18"
    }
    {
      Id = "Skelly_0103"
      InheritFrom = "BaseNarrative"
      DisplayName = "Speak with your {#Emph}weapons{#Prev}, young one, not your words!"
      Speaker = "Skelly"
      Event = "SkellyChat19"
    }
    {
      Id = "Melinoe_1050"
      InheritFrom = "BaseNarrative"
      DisplayName = "Commander, though it falls to us to keep the old traditions alive, may you partake of this Nectar unburdened by the weight of its significance."
      Speaker = "Melinoe"
      Event = "SkellyGift01"
    }
    {
      Id = "Skelly_0091"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm most appreciative of both the offering and of the sentiment. And I summarily shall do my part: {#Emph}Behold! {#Prev}The luckiest of my possessions is in {#Emph}your {#Prev}possession now!"
      Speaker = "Skelly"
      Event = "SkellyGift01"
    }
    {
      Id = "Skelly_0046"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, the memories, young one... your brother thusly used to favor me. And for his sake and yours, I shall accept this. Now, please accept {#Emph}my {#Prev}gratitude: {#Emph}Hey, thanks!"
      Speaker = "Skelly"
      Event = "SkellyGift02"
    }
    {
      Id = "Melinoe_1051"
      InheritFrom = "BaseNarrative"
      DisplayName = "You are most welcome, Commander! And {#Emph}hey thanks {#Prev}to you in turn, for your peerless insight and steadfast presence."
      Speaker = "Melinoe"
      Event = "SkellyGift02"
    }
    {
      Id = "Skelly_0047"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm most appreciative of your generosity. Would that I had more to give you in return besides the wisdom of my vast experience..."
      Speaker = "Skelly"
      Event = "SkellyGift03"
    }
    {
      Id = "Melinoe_1052"
      InheritFrom = "BaseNarrative"
      DisplayName = "Please, sir, that is more than enough. Your disciples and I are fortunate to study under you."
      Speaker = "Melinoe"
      Event = "SkellyGift03"
    }
    {
      Id = "Skelly_0371"
      InheritFrom = "BaseNarrative"
      DisplayName = "I must not partake in such extravagances! For my disciples are counting on my clear-eyed counsel and undivided attention. But tell you what I'm gonna save this one for later when I'm off, OK?"
      Speaker = "Skelly"
      Event = "SkellyGift04"
    }
    {
      Id = "Melinoe_3484"
      InheritFrom = "BaseNarrative"
      DisplayName = "What you call an extravagance... it must be nothing compared to the luxuries of my father's House. Yet you never want for anything. Besides the occasional hit or two."
      Speaker = "Melinoe"
      Event = "SkellyGift04"
    }
    {
      Id = "Skelly_0389"
      InheritFrom = "BaseNarrative"
      DisplayName = "Many a time have I been regaled with the most exquisite beverages and snacks, but never before from such a disciplined and honorable disciple such as yourself! Rest of you slackers hear {#Emph}that? {#Prev}More offerings, come on!"
      Speaker = "Skelly"
      Event = "SkellyGift05"
    }
    {
      Id = "Melinoe_3372"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Nectar's yours to do with as you please, sir! May it lighten the burden of responsibility you bear to all the Shades and others counting on your skill and knowledge."
      Speaker = "Melinoe"
      Event = "SkellyGift05"
    }
    {
      Id = "Skelly_0390"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh I'll give 'em skill and knowledge."
      Speaker = "Skelly"
      Event = "SkellyGift05"
    }
    {
      Id = "Skelly_0391"
      InheritFrom = "BaseNarrative"
      DisplayName = "Look kiddo... I got to level with you. Got kind of a drinking problem over here. Stuff goes right through me! I just don't want you wasting this when you could give it to one of those other guys out there."
      Speaker = "Skelly"
      Event = "SkellyGift06"
    }
    {
      Id = "Melinoe_3551"
      InheritFrom = "BaseNarrative"
      DisplayName = "Commander, thank you for your honesty with me... I hate to think all that Nectar only served to make you ill-at-ease. You do know you don't need to drink it, right? It can be a collector's item... a reminder of your friends, and the affection that they have for you."
      Speaker = "Melinoe"
      Event = "SkellyGift06"
    }
    {
      Id = "Skelly_0392"
      InheritFrom = "BaseNarrative"
      DisplayName = "Affection, shmuffection, look I'm gonna keep it just this {#Emph}sixth {#Prev}time... but don't go giving any more to me, OK?"
      Speaker = "Skelly"
      Event = "SkellyGift06"
    }
    {
      Id = "Melinoe_3552"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yes, sir."
      Speaker = "Melinoe"
      Event = "SkellyGift06"
    }
    {
      Id = "Melinoe_4965"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know you don't want Nectar at this point, but what if I were to offer you Ambrosia, sir? In fact it's not even a hypothetical, so here!"
      Speaker = "Melinoe"
      Event = "SkellyGift07"
    }
    {
      Id = "Skelly_0602"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well this is a most-handsome gift, and it has left me speechless, for I have not received such {#DialogLegendaryFormat}Kudos {#Prev}since your own brother gave to me a similar reward {#Emph}long ago..."
      Speaker = "Skelly"
      Event = "SkellyGift07"
    }
    {
      Id = "Melinoe_4966"
      InheritFrom = "BaseNarrative"
      DisplayName = "Truly? What was the circumstance then? Though this is no reward, merely a mark of our long-standing camaraderie."
      Speaker = "Melinoe"
      Event = "SkellyGift07"
    }
    {
      Id = "Skelly_0603"
      InheritFrom = "BaseNarrative"
      DisplayName = "The circumstance was that the boyo had repeatedly made use of me for target practice at around that time, so the Ambrosia was in recompense."
      Speaker = "Skelly"
      Event = "SkellyGift07"
    }
    {
      Id = "Melinoe_4967"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I see..."
      Speaker = "Melinoe"
      Event = "SkellyGift07"
    }
    {
      Id = "Melinoe_4968"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've served as target practice for me far more times than I can easily recall, sir. So I wish for you to have this Ambrosia as a token of my gratitude. No one else would be so willing!"
      Speaker = "Melinoe"
      Event = "SkellyGift08"
    }
    {
      Id = "Skelly_0604"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Damn right {#Prev}no one else would be so willing! I've been in this profession longer than anybody, you've never seen me so much as move a {#Emph}muscle{#Prev}, have you?"
      Speaker = "Skelly"
      Event = "SkellyGift08"
    }
    {
      Id = "Melinoe_4969"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well you {#Emph}have {#Prev}no muscle, as far as I can see, Commander. But I know you've long served my family with honor, and such loyalty is never to be taken for granted."
      Speaker = "Melinoe"
      Event = "SkellyGift08"
    }
    {
      Id = "Skelly_0605"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll tell you what, not everybody thinks like {#Emph}you{#Prev}, kiddo. A lot of guys I've met, they pay you for a job, and that's the end of it, no {#Emph}loyalty{#Prev}, no long-term prospects, or stability..."
      Speaker = "Skelly"
      Event = "SkellyGift08"
    }
    {
      Id = "Melinoe_4970"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Mere mercenary work."
      Speaker = "Melinoe"
      Event = "SkellyGift08"
    }
    {
      Id = "Skelly_0606"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Totally."
      Speaker = "Skelly"
      Event = "SkellyGift08"
    }
    {
      Id = "Melinoe_4971"
      InheritFrom = "BaseNarrative"
      DisplayName = "To the honorable Commander Schelemeus, ward of the bloodline of Hades, the Fate-appointed regent of the Underworld: May this Ambrosia forever guarantee your service, for as long as you are willing to provide it!"
      Speaker = "Melinoe"
      Event = "SkellyGift09"
    }
    {
      Id = "Skelly_0607"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey wait did you just grant me {#DialogLegendaryFormat}tenure {#Prev}in the family's name, kiddo? Can you even {#Emph}do {#Prev}that, and also... {#Emph}why?"
      Speaker = "Skelly"
      Event = "SkellyGift09"
    }
    {
      Id = "Melinoe_4972"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm Princess of the Underworld; I'm well within my right. And as for why, I said before that I do not take loyalty for granted. I wanted you to know I meant it."
      Speaker = "Melinoe"
      Event = "SkellyGift09"
    }
    {
      Id = "Skelly_0608"
      InheritFrom = "BaseNarrative"
      DisplayName = "Look I didn't really think you were gonna replace me or anything, but... it means a lot you'd do all that for me. I know I helped teach you to hit real hard, kiddo... but I never thought you'd get me right in the heart..."
      Speaker = "Skelly"
      Event = "SkellyGift09"
    }
    {
      Id = "Melinoe_4973"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thank you for everything, Commander."
      Speaker = "Melinoe"
      Event = "SkellyGift09"
    }
    {
      Id = "Skelly_0609"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just doing what they pay me for."
      Speaker = "Skelly"
      Event = "SkellyGift09"
    }
    {
      Id = "Melinoe_4974"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're being paid for this?"
      Speaker = "Melinoe"
      Event = "SkellyGift09"
    }
    {
      Id = "Skelly_0610"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}...No."
      Speaker = "Skelly"
      Event = "SkellyGift09"
    }
    {
      Id = "Melinoe_3361"
      InheritFrom = "BaseNarrative"
      DisplayName = "Commander, would you be willing to accompany me to the Springs sometime? We could rest our weary bones a bit."
      Speaker = "Melinoe"
      Event = "SkellyBathHouseDecline01"
    }
    {
      Id = "Skelly_0345"
      InheritFrom = "BaseNarrative"
      DisplayName = "What are you gonna do, carry me? I'm required {#Emph}here{#Prev}, young one, for these Shades still require discipline! Mayhaps some other age, when all we hold dear isn't at stake..."
      Speaker = "Skelly"
      Event = "SkellyBathHouseDecline01"
    }
    {
      Id = "Melinoe_3360"
      InheritFrom = "BaseNarrative"
      DisplayName = "Commander, we've restored our fishing pier! Would you mind joining me there, given all your nautical experience?"
      Speaker = "Melinoe"
      Event = "SkellyFishingDecline01"
    }
    {
      Id = "Skelly_0344"
      InheritFrom = "BaseNarrative"
      DisplayName = "My days amongst the fishes are long gone, young one. And besides, my place is here... right in this particular spot. Though, thanks!"
      Speaker = "Skelly"
      Event = "SkellyFishingDecline01"
    }
    {
      Id = "Melinoe_1053"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You honor me, Commander."
      Speaker = "Melinoe"
      Event = "NPC_Skelly_01.GiftGivenVoiceLines"
    }
    {
      Id = "Skelly_0172"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Close enough..."
      Speaker = "Skelly"
      Event = "NPC_Skelly_01.OnDeathVoiceLines"
    }
    {
      Id = "Skelly_0021"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I shall return..."
      Speaker = "Skelly"
      Event = "NPC_Skelly_01.OnDeathVoiceLines"
    }
    {
      Id = "Melinoe_0076"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Forgive me, sir..."
      Speaker = "Melinoe"
      Event = "NPC_Skelly_01.OnDeathVoiceLines"
    }
    {
      Id = "Skelly_0593"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Aw{#Prev}, dang it!"
      Speaker = "Skelly"
      Event = "NPC_Skelly_01.OnDeathVoiceLines"
    }
    {
      Id = "Melinoe_4956"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Commander...? {#Emph}Commander!"
      Speaker = "Melinoe"
      Event = "NPC_Skelly_01.OnDeathVoiceLines"
    }
    {
      Id = "Melinoe_5704"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Commander, please, come back..."
      Speaker = "Melinoe"
      Event = "NPC_Skelly_01.OnDeathVoiceLines"
    }
    {
      Id = "Melinoe_4957"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Gods, he's gone..."
      Speaker = "Melinoe"
      Event = "NPC_Skelly_01.OnDeathVoiceLines"
    }
    {
      Id = "Skelly_0020"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A fatal blow..."
      Speaker = "Skelly"
      Event = "NPC_Skelly_01.OnDeathVoiceLines"
    }
    {
      Id = "Skelly_0061"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I... must... go..."
      Speaker = "Skelly"
      Event = "NPC_Skelly_01.OnDeathVoiceLines"
    }
    {
      Id = "Skelly_0062"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Curse these old bones!"
      Speaker = "Skelly"
      Event = "NPC_Skelly_01.OnDeathVoiceLines"
    }
    {
      Id = "Skelly_0064"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well struck!"
      Speaker = "Skelly"
      Event = "NPC_Skelly_01.OnDeathVoiceLines"
    }
    {
      Id = "Skelly_0065"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I fall..."
      Speaker = "Skelly"
      Event = "NPC_Skelly_01.OnDeathVoiceLines"
    }
    {
      Id = "Skelly_0280"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's... the... stuff..."
      Speaker = "Skelly"
      Event = "NPC_Skelly_01.OnDeathVoiceLines"
    }
    {
      Id = "Skelly_0281"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Got... me... good..."
      Speaker = "Skelly"
      Event = "NPC_Skelly_01.OnDeathVoiceLines"
    }
    {
      Id = "Skelly_0282"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Ah, the memories..."
      Speaker = "Skelly"
      Event = "NPC_Skelly_01.OnDeathVoiceLines"
    }
    {
      Id = "Skelly_0283"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That did the trick..."
      Speaker = "Skelly"
      Event = "NPC_Skelly_01.OnDeathVoiceLines"
    }
    {
      Id = "Skelly_0284"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm... outta here..."
      Speaker = "Skelly"
      Event = "NPC_Skelly_01.OnDeathVoiceLines"
    }
    {
      Id = "Skelly_0285"
      InheritFrom = "BaseSubtitle"
      DisplayName = "There goes my body parts..."
      Speaker = "Skelly"
      Event = "NPC_Skelly_01.OnDeathVoiceLines"
    }
    {
      Id = "Skelly_0681"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Avenge... me..."
      Speaker = "Skelly"
      Event = "NPC_Skelly_01.OnDeathVoiceLines"
    }
    {
      Id = "Skelly_0682"
      InheritFrom = "BaseSubtitle"
      DisplayName = "For... the cause..."
      Speaker = "Skelly"
      Event = "NPC_Skelly_01.OnDeathVoiceLines"
    }
    {
