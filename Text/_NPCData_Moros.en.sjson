  lang = "en"
  Texts = [
    {
      Id = "Melinoe_1879"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Peace, Lord Moros."
      Speaker = "Melinoe"
      Event = "NPC_Moros_01.InteractVoiceLines"
    }
    {
      Id = "Moros_0198"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Salutations, Princess."
      Speaker = "Moros"
      Event = "NPC_Moros_01.InteractVoiceLines"
    }
    {
      Id = "Moros_0199"
      InheritFrom = "BaseSubtitle"
      DisplayName = "To you as well!"
      Speaker = "Moros"
      Event = "NPC_Moros_01.InteractVoiceLines"
    }
    {
      Id = "Moros_0200"
      InheritFrom = "BaseSubtitle"
      DisplayName = "So it is Fated."
      Speaker = "Moros"
      Event = "NPC_Moros_01.InteractVoiceLines"
    }
    {
      Id = "Moros_0201"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Such is his Doom."
      Speaker = "Moros"
      Event = "NPC_Moros_01.InteractVoiceLines"
    }
    {
      Id = "Moros_0203"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Night protect you."
      Speaker = "Moros"
      Event = "NPC_Moros_01.InteractVoiceLines"
    }
    {
      Id = "Moros_0205"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And Night protect us."
      Speaker = "Moros"
      Event = "NPC_Moros_01.InteractVoiceLines"
    }
    {
      Id = "Moros_0206"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Indeed."
      Speaker = "Moros"
      Event = "NPC_Moros_01.InteractVoiceLines"
    }
    {
      Id = "Moros_0090"
      InheritFrom = "BaseSubtitle"
      DisplayName = "To your success."
      Speaker = "Moros"
      Event = "NPC_Moros_01.InteractVoiceLines"
    }
    {
      Id = "Moros_0091"
      InheritFrom = "BaseSubtitle"
      DisplayName = "To victory."
      Speaker = "Moros"
      Event = "NPC_Moros_01.InteractVoiceLines"
    }
    {
      Id = "Moros_0207"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Proceed with care."
      Speaker = "Moros"
      Event = "NPC_Moros_01.InteractVoiceLines"
    }
    {
      Id = "MelinoeField_4072"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This feeling... hello...? Lord Moros, is that you...? {#Emph}<Gasp>"
      Speaker = "Melinoe"
      Event = "NPC_Moros_01.EntranceVoiceLines"
    }
    {
      Id = "Moros_1001"
      InheritFrom = "BaseSubtitle"
      DisplayName = "All right, all right, all right, we're {#Emph}here{#Prev}, we're here..."
      Speaker = "Moros"
      Event = "NPC_Moros_01.EntranceVoiceLines"
    }
    {
      Id = "Moros_0404"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Forgive me, Princess..."
      Speaker = "Moros"
      Event = "NPC_Moros_01.EntranceVoiceLines"
    }
    {
      Id = "Moros_0127"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Found you at last."
      Speaker = "Moros"
      Event = "NPC_Moros_01.EntranceVoiceLines"
    }
    {
      Id = "Moros_0131"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I heed your call once more."
      Speaker = "Moros"
      Event = "NPC_Moros_01.EntranceVoiceLines"
    }
    {
      Id = "Moros_0296"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just a moment...!"
      Speaker = "Moros"
      Event = "NPC_Moros_01.EntranceVoiceLines"
    }
    {
      Id = "Moros_0096"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Princess!"
      Speaker = "Moros"
      Event = "NPC_Moros_01.EntranceVoiceLines"
    }
    {
      Id = "Moros_0128"
      InheritFrom = "BaseNarrative"
      DisplayName = "Princess of the Underworld: I regret having to contact you at such a time. It's not my custom to intervene during moments of Doom, only to observe."
      Speaker = "Moros"
      Event = "MorosGrantsQuestLog"
    }
    {
      Id = "Melinoe_1582"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Moments of Doom.... {#Prev}You're Lord Moros, emissary of the Three Fates! So your sisters heard me after all!"
      Speaker = "Melinoe"
      Event = "MorosGrantsQuestLog"
    }
    {
      Id = "Moros_0129"
      InheritFrom = "BaseNarrative"
      DisplayName = "They expected me to find you, for there's something they intend for you to have. Wherever you're going, look for it when you arrive. I'm uncertain if we'll meet again; farewell."
      Speaker = "Moros"
      Event = "MorosGrantsQuestLog"
    }
    {
      Id = "Moros_0130"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It's been an honor..."
      Speaker = "Moros"
      Event = "MorosGrantsQuestLog"
    }
    {
      Id = "Melinoe_1583"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Wait...!"
      Speaker = "Melinoe"
      Event = "MorosGrantsQuestLog"
    }
    {
      Id = "Moros_0132"
      InheritFrom = "BaseNarrative"
      DisplayName = "Again our journeys intertwine. Why did you call upon me, Princess? Did you not receive the artifact I brought you from the Fates?"
      Speaker = "Moros"
      Event = "MorosSecondAppearance"
    }
    {
      Id = "MelinoeField_1694"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lord Moros...! I did receive the Fated List, and summoned you once more as it ordained. All children of Nyx are welcome where I reside. Might we speak further there...? I've many questions."
      Speaker = "Melinoe"
      Event = "MorosSecondAppearance"
    }
    {
      Id = "Moros_0133"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't know whether I can answer them, as my own search for truth has not been going well of late. But I'll not decline your cordial invitation. Please lead the way."
      Speaker = "Moros"
      Event = "MorosSecondAppearance"
    }
    {
      Id = "Melinoe_1588"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Then follow me."
      Speaker = "Melinoe"
      Event = "MorosSecondAppearance"
    }
    {
      Id = "Moros_0134"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I shall."
      Speaker = "Moros"
      Event = "MorosSecondAppearance"
    }
    {
      Id = "Moros_0297"
      InheritFrom = "BaseNarrative"
      DisplayName = "...You traveled to the surface. Knowing full well the Fates decided long ago that those of your line could not survive there, and would always be forced back to the Underworld."
      Speaker = "Moros"
      Event = "MorosGrantsSurfacePenaltyCure01"
    }
    {
      Id = "MelinoeField_0812"
      InheritFrom = "BaseNarrative"
      DisplayName = "Their curse was... palpable. I never intended to stay for long. Just long enough to lend my relatives support. But it seems your sisters insist that I do no such thing."
      Speaker = "Melinoe"
      Event = "MorosGrantsSurfacePenaltyCure01"
    }
    {
      Id = "Moros_0298"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well... I don't see them around right now, do you? Incidentally, there was once an incantation that I happened upon, which was not intended for my eyes. But I now choose to think that it was intended for yours."
      Speaker = "Moros"
      Event = "MorosGrantsSurfacePenaltyCure01"
    }
    {
      Id = "MelinoeField_0813"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Unraveling a Fateful Bond..."
      Speaker = "Melinoe"
      Event = "MorosGrantsSurfacePenaltyCure01"
    }
    {
      Id = "Moros_0405"
      InheritFrom = "BaseNarrative"
      DisplayName = "I apologize for the abruptness of my approach. My mind... told me not to appear before you without good cause, but my heart demanded otherwise. Is this... not a good time?"
      Speaker = "Moros"
      Event = "MorosBecomingCloser01"
    }
    {
      Id = "MelinoeField_3730_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, you know, Lord Moros, I... was just in the middle of evading my latest brush with death. Why are you here? {#Emph}<Scoff> {#Prev}I must look like hell..."
      Speaker = "Melinoe"
      Event = "MorosBecomingCloser01"
    }
    {
      Id = "Moros_0406"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, you look... well, I am truly at a loss for words... I should have rehearsed what I sought to say more thoroughly."
      Speaker = "Moros"
      Event = "MorosBecomingCloser01"
    }
    {
      Id = "MelinoeField_3731"
      InheritFrom = "BaseNarrative"
      DisplayName = "You don't need to be so nervous around me, or so formal for that matter. And it's nice to see you here as well, in one of my many moments of wretched failure. How long can we stay here, anyway? It's so peaceful..."
      Speaker = "Melinoe"
      Event = "MorosBecomingCloser01"
    }
    {
      Id = "Moros_0407"
      InheritFrom = "BaseNarrative"
      DisplayName = "We can stay for... I don't exactly know. A while, that to others shall seem merely an instant, so... I sought to see you here again, in the off chance... you sought to see me...?"
      Speaker = "Moros"
      Event = "MorosBecomingCloser01"
    }
    {
      Id = "MelinoeField_3734"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Farewell..."
      Speaker = "Melinoe"
      Event = "MorosBecomingCloser01"
    }
    {
      Id = "MelinoeField_3738"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}<Sigh> {#Prev}Return to shadow, now..."
      Speaker = "Melinoe"
      Event = "MorosBecomingCloser01"
    }
    {
      Id = "MelinoeField_3732"
      InheritFrom = "BaseNarrative"
      DisplayName = "It is the height of flattery that you would feel this way, Lord Moros. But... in listening to my own heart once again... it's not my wish to risk or change what we already have. I know you must be disappointed, but I hope you understand."
      Speaker = "Melinoe"
      Event = "MorosBecomingCloser01"
    }
    {
      Id = "Moros_0408"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, not disappointed in the least, Princess. And I do understand. Forgive me, once again, this outburst of feeling... I don't wish to pretend I never asked, but... may we perhaps still carry on as close acquaintances?"
      Speaker = "Moros"
      Event = "MorosBecomingCloser01"
    }
    {
      Id = "MelinoeField_3733"
      InheritFrom = "BaseNarrative"
      DisplayName = "If it were any other way, I'd never forgive myself, nor you."
      Speaker = "Melinoe"
      Event = "MorosBecomingCloser01"
    }
    {
      Id = "Moros_0409"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hah! {#Prev}Well then, may you recover as swiftly as ever, and I shall see you shortly on the other side. Farewell for now."
      Speaker = "Moros"
      Event = "MorosBecomingCloser01"
    }
    {
      Id = "MelinoeField_3735"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Chance has nothing to do with it, Lord Moros. Most nights I have a brush with death, but not with you. I {#Emph}have {#Prev}wanted this, yes."
      Speaker = "Melinoe"
      Event = "MorosBecomingCloser01"
    }
    {
      Id = "MelinoeField_3736"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Lord Moros, are... are you certain this shall only seem an instant by the time we return? Because..."
      Speaker = "Melinoe"
      Event = "MorosBecomingCloser01"
    }
    {
      Id = "Moros_0411"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have my word. As for your own sense of time, {#Emph}that {#Prev}I cannot change. So, as much as I would like remaining here with you eternally... we should probably be getting back."
      Speaker = "Moros"
      Event = "MorosBecomingCloser01"
    }
    {
      Id = "Melinoe_4158"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're probably right."
      Speaker = "Melinoe"
      Event = "MorosBecomingCloser01"
    }
    {
      Id = "Moros_0412"
      InheritFrom = "BaseNarrative"
      DisplayName = "On that you'll hear no arguments from me either."
      Speaker = "Moros"
      Event = "MorosBecomingCloser01"
    }
    {
      Id = "Moros_1002"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, whaddaya know, we got ourselves a visitor, ladies! Who woulda thought? You found us, sweetie! You get, I don't know, three questions? Three of us, three questions, sounds reasonable, right?"
      Speaker = "Moros"
      Event = "FatesEpilogue01"
    }
    {
      Id = "MelinoeField_4073"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're... you're the Fates, you're... really here! Are you safe, in any distress? Your brother Lord Moros, he's searched everywhere for you, and not just him!"
      Speaker = "Melinoe"
      Event = "FatesEpilogue01"
    }
    {
      Id = "Moros_1003"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Are you safe, in any distress? Whew! {#Prev}What do you think, ladies, we count that as {#Emph}one {#Prev}question or {#Emph}two? {#Prev}I say go easy on her, seems like a nice girl. {#Emph}Count it just as one, OK?"
      Speaker = "Moros"
      Event = "FatesEpilogue01"
    }
    {
      Id = "Moros_1004_C"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh yeah, nice girl, you're right, count it as one! {#Emph}OK!"
      Speaker = "Moros"
      Event = "FatesEpilogue01"
    }
    {
      Id = "Moros_1006"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}OK! {#Prev}We're {#Emph}fine{#Prev}, sweetie, least {#Emph}now {#Prev}we are! Your grandpa got us, yeah, we were a little miffed, you know? Cause we'd been {#Emph}weaving{#Prev}, and {#Emph}weaving{#Prev}, and {#Emph}weaving{#Prev}, so then we figured: What's a better time to take a break?"
      Speaker = "Moros"
      Event = "FatesEpilogue01"
    }
    {
      Id = "MelinoeField_4074"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Take a break... {#Prev}shouldn't you have sent word to Lord Moros, much less anybody else? He's been very concerned!"
      Speaker = "Melinoe"
      Event = "FatesEpilogue01"
    }
    {
      Id = "Moros_1007"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's question {#Emph}two! {#Prev}We {#Emph}did {#Prev}send word, that's why {#Emph}you're {#Prev}here! Moros, he's a {#Emph}real {#Prev}sweetheart. We figured he could use a little alone time... OK, last question!"
      Speaker = "Moros"
      Event = "FatesEpilogue01"
    }
    {
      Id = "MelinoeField_4075"
      InheritFrom = "BaseNarrative"
      DisplayName = "Last question, I... what do you all intend to do, now that Chronos no longer seems to be a threat? How do we prevent something like this from happening again?"
      Speaker = "Melinoe"
      Event = "FatesEpilogue01"
    }
    {
      Id = "Moros_1008"
      InheritFrom = "BaseNarrative"
      DisplayName = "OK now {#Emph}that {#Prev}I'm counting as {#Emph}two {#Prev}questions so I'm only gonna give you the first one, or maybe it was the second, I'm getting mixed up, point is: {#Emph}We're not gonna do a thing...! {#Prev}This has been nice."
      Speaker = "Moros"
      Event = "FatesEpilogue01"
    }
    {
      Id = "MelinoeField_4076"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not going to do a thing, and I'm unable to ask further questions, so... perhaps you're going to elaborate..."
      Speaker = "Melinoe"
      Event = "FatesEpilogue01"
    }
    {
      Id = "Moros_1011"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, who knows what's gonna happen, you or me? Look, all you gods, you got yourselves into this. I know, {#Emph}I know{#Prev}, you think it's 'cause of us, well, we don't {#Emph}like {#Prev}that kind of pressure! And you've been doing OK on your own, so..."
      Speaker = "Moros"
      Event = "FatesEpilogue01"
    }
    {
      Id = "Moros_1012_C"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yeah you've been doing OK, {#Emph}haha! {#Prev}So we are gonna let ya {#Emph}keep this up!"
      Speaker = "Moros"
      Event = "FatesEpilogue01"
    }
    {
      Id = "Moros_1014"
      InheritFrom = "BaseNarrative"
      DisplayName = "We're gonna let you keep this up. And once you've had your fill, being without us for a while, you're gonna hand it over to mortals. Just like {#Emph}we're {#Prev}handing it over to {#Emph}you!"
      Speaker = "Moros"
      Event = "FatesEpilogue01"
    }
    {
      Id = "MelinoeField_4077"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hand {#Emph}what {#Prev}over to mortals... which is to say... I don't know how I can respond to that without another question."
      Speaker = "Melinoe"
      Event = "FatesEpilogue01"
    }
    {
      Id = "Moros_1015"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}That's {#Prev}all right, sweetie! Think of it like, {#Emph}uh... {#Prev}you gods can do your {#Emph}own {#Prev}thing for a while, then mortals can do {#Emph}theirs! {#Prev}It'll be a brand new age! Been a while since the last one of {#Emph}those."
      Speaker = "Moros"
      Event = "FatesEpilogue01"
    }
    {
      Id = "MelinoeField_4078"
      InheritFrom = "BaseNarrative"
      DisplayName = "So you're retiring... all three of you. No more weavings... we're to keep fending for ourselves, come what may."
      Speaker = "Melinoe"
      Event = "FatesEpilogue01"
    }
    {
      Id = "Moros_1016"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh {#Emph}come on{#Prev}, don't make it sound like such a big deal! Not like you're gonna do anything different anyway. But you {#Emph}could! {#Prev}Just ask your old teacher sometime. Now {#Emph}she's {#Prev}pulled some strings, let me tell {#Emph}you!"
      Speaker = "Moros"
      Event = "FatesEpilogue01"
    }
    {
      Id = "Moros_1017_C"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh {#Prev}yeah Teach has {#Emph}definitely {#Prev}pulled some strings all right, {#Emph}huhuh!"
      Speaker = "Moros"
      Event = "FatesEpilogue01"
    }
    {
      Id = "MelinoeField_4079"
      InheritFrom = "BaseNarrative"
      DisplayName = "You mean Headmistress. So you're saying... I don't know what you're saying, but I'll ask. As you well know, I couldn't have done any of this without her."
      Speaker = "Melinoe"
      Event = "FatesEpilogue01"
    }
    {
      Id = "Moros_1018_C"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Guuuhhhhh, ngghhh..."
      Speaker = "Moros"
      Event = "FatesEpilogue01"
    }
    {
      Id = "Moros_1019"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ohh, {#Emph}yeah{#Prev}, we know. Well anyway, sweetie, we're gonna cut ya loose, as we've got other things to do! But {#Emph}not {#Prev}weaving! {#Emph}Not for the foreseeable future{#Prev}, as they say, {#Emph}heh. {#Prev}So nice to finally meet ya. {#Emph}Bye!"
      Speaker = "Moros"
      Event = "FatesEpilogue01"
    }
    {
      Id = "MelinoeField_4080"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Erm{#Prev}, bye...! And, thank you all!"
      Speaker = "Melinoe"
      Event = "FatesEpilogue01"
    }
    {
      Id = "Moros_0135"
      InheritFrom = "BaseNarrative"
      DisplayName = "Princess! We've not met formally. I'm the Official Bearer of Bad News. The Witch of the Crossroads apprised me of the situation here, and... was gracious to invite me to stay for now."
      Speaker = "Moros"
      Event = "MorosFirstMeeting"
    }
    {
      Id = "Moros_0703"
      InheritFrom = "BaseNarrative"
      DisplayName = "Princess, we've not met formally. I'm called Moros, Doom, or the official Bearer of Bad News. The Witch of the Crossroads apprised me of the situation here, and was gracious to invite me to stay for now."
      Speaker = "Moros"
      Event = "MorosFirstMeeting"
    }
    {
      Id = "Melinoe_1589"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're welcome here and safe, Lord Moros. So then, you know of my task."
      Speaker = "Melinoe"
      Event = "MorosFirstMeeting"
    }
    {
      Id = "Moros_0136"
      InheritFrom = "BaseNarrative"
      DisplayName = "To vanquish the usurper of the House of Hades seems more than a task. I regret this burden is yours to bear, and much sooner than expected."
      Speaker = "Moros"
      Event = "MorosFirstMeeting"
    }
    {
      Id = "Melinoe_0872"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It's all right. I was born for this."
      Speaker = "Melinoe"
      Event = "MorosFirstMeeting"
    }
    {
      Id = "Moros_0145"
      InheritFrom = "BaseNarrative"
      DisplayName = "Are you all right, Princess? I'm realizing that whenever you return, it's likely due to some unfortunate result. One I might have easily anticipated in the past, but not anymore..."
      Speaker = "Moros"
      Event = "MorosAboutReturning01"
    }
    {
      Id = "Melinoe_2057"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm fine, Lord Moros, thank you for asking. I'm fairly accustomed to such outcomes at this point. It's interesting to know the Fates are not forcing it along... that it's all in my control. And all my fault."
      Speaker = "Melinoe"
      Event = "MorosAboutReturning01"
    }
    {
      Id = "Moros_0146"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well... now that you mention it, I can't entirely be sure the Fates have no more influence at all. How frustrating, not knowing whether our actions have been preordained or not..."
      Speaker = "Moros"
      Event = "MorosAboutReturning01"
    }
    {
      Id = "Melinoe_2058"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I try not to think on it too much."
      Speaker = "Melinoe"
      Event = "MorosAboutReturning01"
    }
    {
      Id = "Melinoe_1803"
      InheritFrom = "BaseNarrative"
      DisplayName = "You must know what I'm about to ask, Lord Moros... especially since I promised many questions. You mentioned you were on a fruitless search. What was it that you sought?"
      Speaker = "Melinoe"
      Event = "MorosAboutSearch01"
    }
    {
      Id = "Moros_0138"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh! Well, the Fates do like to send me off to fetch them this or that, now and again. My search in some respects was similar. Though, I'm beginning to think they tricked me..."
      Speaker = "Moros"
      Event = "MorosAboutSearch01"
    }
    {
      Id = "Melinoe_1804"
      InheritFrom = "BaseNarrative"
      DisplayName = "They sent you to find something that couldn't be found... and you can't just tell me what it is, can you."
      Speaker = "Melinoe"
      Event = "MorosAboutSearch01"
    }
    {
      Id = "Moros_0139"
      InheritFrom = "BaseNarrative"
      DisplayName = "I think they simply wanted me out of the way. Although, I shouldn't speculate, or further speak of this at all... apologies."
      Speaker = "Moros"
      Event = "MorosAboutSearch01"
    }
    {
      Id = "Melinoe_1959"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I understand..."
      Speaker = "Melinoe"
      Event = "MorosAboutSearch01"
    }
    {
      Id = "Melinoe_2055"
      InheritFrom = "BaseNarrative"
      DisplayName = "When you and I first met, you were searching for the Fates. But you discovered {#Emph}me {#Prev}among the shadows. I can navigate back to the Crossroads that way... but you can go farther?"
      Speaker = "Melinoe"
      Event = "MorosAboutSearch02"
    }
    {
      Id = "Moros_0143"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can, yes. I'm from the deepest reaches of the Underworld, where there exists no light at all. The chasm from which all creation sprang a while back."
      Speaker = "Moros"
      Event = "MorosAboutSearch02"
    }
    {
      Id = "Melinoe_2056"
      InheritFrom = "BaseNarrative"
      DisplayName = "I suppose even if one knew the Fates resided in such a place, they might still prove difficult to find..."
      Speaker = "Melinoe"
      Event = "MorosAboutSearch02"
    }
    {
      Id = "Moros_0144"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Difficult, though not impossible, as we now know..."
      Speaker = "Moros"
      Event = "MorosAboutSearch02"
    }
    {
      Id = "Melinoe_0873"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have to ask you something, Lord Moros, though I think I may already have the answer. Has the war with Chronos and Olympus taken some new turn?"
      Speaker = "Melinoe"
      Event = "MorosAboutTask01"
    }
    {
      Id = "Moros_0034"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm sorry I can't answer you, Princess. I'm bound never to speak of matters in connection to the weavings of the Fates. If you knew more right now, it could unduly influence your path."
      Speaker = "Moros"
      Event = "MorosAboutTask01"
    }
    {
      Id = "Melinoe_0874"
      InheritFrom = "BaseNarrative"
      DisplayName = "And...? Knowledge is preparation. It seems strictly to our benefit for me to know as much as possible about what I'm getting myself into."
      Speaker = "Melinoe"
      Event = "MorosAboutTask01"
    }
    {
      Id = "Moros_0035"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps. Nevertheless, I cannot break my oath. I trust, though, that you'll learn the truth of it when the time is right."
      Speaker = "Moros"
      Event = "MorosAboutTask01"
    }
    {
      Id = "Melinoe_0875"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll be waiting."
      Speaker = "Melinoe"
      Event = "MorosAboutTask01"
    }
    {
      Id = "Moros_0140"
      InheritFrom = "BaseNarrative"
      DisplayName = "If I may, Princess? The Fated List of Minor Prophecies... have you been able to make use of it?"
      Speaker = "Moros"
      Event = "MorosAboutQuestLog01"
    }
    {
      Id = "Melinoe_1805"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have. Thank you for bringing it to me. So then, the Fates already know what's going to happen in all this? Everything I'm going to do?"
      Speaker = "Melinoe"
      Event = "MorosAboutQuestLog01"
    }
    {
      Id = "Moros_0039"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, yes and no. The Fated List says as little of your future as necessary. I briefly was its host myself, and saw there but a single prophecy... that I would pass it on to you."
      Speaker = "Moros"
      Event = "MorosAboutQuestLog01"
    }
    {
      Id = "Melinoe_0877"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Then that's a prophecy fulfilled."
      Speaker = "Melinoe"
      Event = "MorosAboutQuestLog01"
    }
    {
      Id = "Moros_0141"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Fated List continues to unfold, so thank you. While the Fates often let events unfold naturally, at times they value an additional degree of certainty. And are willing to make it worthwhile."
      Speaker = "Moros"
      Event = "MorosAboutQuestLog02"
    }
    {
      Id = "Melinoe_0878"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've seen a number of the listed prophecies already come to pass. Still others are foretold in their place. The magick in that scroll, it's beyond anything I've learned..."
      Speaker = "Melinoe"
      Event = "MorosAboutQuestLog02"
    }
    {
      Id = "Moros_0142"
      InheritFrom = "BaseNarrative"
      DisplayName = "You must have your doubts; the Fates are rather famous for their sense of irony. But, no matter the outcome, I'm grateful for your willingness to discover their design. Our families are at stake."
      Speaker = "Moros"
      Event = "MorosAboutQuestLog02"
    }
    {
      Id = "Melinoe_0879"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Our families, and more..."
      Speaker = "Melinoe"
      Event = "MorosAboutQuestLog02"
    }
    {
      Id = "Melinoe_2059"
      InheritFrom = "BaseNarrative"
      DisplayName = "I confess I feel a bit self-conscious that the Fated List is there for you and all to see. Some of the matters it describes are rather personal."
      Speaker = "Melinoe"
      Event = "MorosAboutQuestLog03"
    }
    {
      Id = "Moros_0147"
      InheritFrom = "BaseNarrative"
      DisplayName = "If it's any comfort, the prophecies appear only to you. We see there only what's meant for us. Although, when you fulfill a prophecy... I can usually tell. It's like a sudden realization."
      Speaker = "Moros"
      Event = "MorosAboutQuestLog03"
    }
    {
      Id = "Melinoe_2060"
      InheritFrom = "BaseNarrative"
      DisplayName = "We know our paths are intertwined to an extent... well, may your sudden realizations connected to my actions not be {#Emph}too {#Prev}embarrassing."
      Speaker = "Melinoe"
      Event = "MorosAboutQuestLog03"
    }
    {
      Id = "Moros_0148"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm certain that they won't."
      Speaker = "Moros"
      Event = "MorosAboutQuestLog03"
    }
    {
      Id = "Melinoe_2061"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know, some of these Fated prophecies are rather substantial. I shudder to think what might be on a list of {#Emph}major {#Prev}prophecies..."
      Speaker = "Melinoe"
      Event = "MorosAboutQuestLog04"
    }
    {
      Id = "Moros_0149"
      InheritFrom = "BaseNarrative"
      DisplayName = "I trust this doesn't make you feel as though your service hasn't been of value, because certainly it has. However, the prophecies listed there are indeed minor, in the grand scheme of things."
      Speaker = "Moros"
      Event = "MorosAboutQuestLog04"
    }
    {
      Id = "Melinoe_2062"
      InheritFrom = "BaseNarrative"
      DisplayName = "The grand scheme of things... as in all existence, the unfathomable past, unknowable future... that sort of grandeur, you mean?"
      Speaker = "Melinoe"
      Event = "MorosAboutQuestLog04"
    }
    {
      Id = "Moros_0150"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes. The Fates preside over the smallest minutiae and the greatest of patterns. So don't take the idea of minor prophecies the wrong way. A small ripple can become a great wave."
      Speaker = "Moros"
      Event = "MorosAboutQuestLog04"
    }
    {
      Id = "Melinoe_2063"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Now you sound like Poseidon."
      Speaker = "Melinoe"
      Event = "MorosAboutQuestLog04"
    }
    {
      Id = "Moros_0154"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your father once was bearer of the Fated List, you know. A {#Emph}House-warming {#Prev}gift, my sisters said. But Hades put it away... until your brother unearthed it from the archives, and started using it himself."
      Speaker = "Moros"
      Event = "MorosAboutQuestLog05"
    }
    {
      Id = "Melinoe_2067"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know Zagreus sought our mother... perhaps the Fated List helped him succeed. Come to think, I wouldn't have even been born if he hadn't. Wait... how did you end up with the List after that?"
      Speaker = "Melinoe"
      Event = "MorosAboutQuestLog05"
    }
    {
      Id = "Moros_0155"
      InheritFrom = "BaseNarrative"
      DisplayName = "It wasn't until rather recently. The Fates sent me to retrieve the List from your father's House. Chronos would be absent, they said. And they were right; for when I returned, they were gone."
      Speaker = "Moros"
      Event = "MorosAboutQuestLog05"
    }
    {
      Id = "Melinoe_2068"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's when he got them..."
      Speaker = "Melinoe"
      Event = "MorosAboutQuestLog05"
    }
    {
      Id = "Moros_0156"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yes."
      Speaker = "Moros"
      Event = "MorosAboutQuestLog05"
    }
    {
      Id = "Melinoe_4750"
      InheritFrom = "BaseNarrative"
      DisplayName = "Some nights I'm on the surface, I remember I'm defying the will of the Fates simply by being there. Yet the Fated List has certain prophecies that cannot be fulfilled anywhere else. Your sisters, they... must have anticipated this."
      Speaker = "Melinoe"
      Event = "MorosAboutQuestLog06"
    }
    {
      Id = "Moros_0436"
      InheritFrom = "BaseNarrative"
      DisplayName = "It certainly is possible, even probable. Yet, historically, my sisters have had little patience for those who disregard their prophecies. Perhaps they're making an exception."
      Speaker = "Moros"
      Event = "MorosAboutQuestLog06"
    }
    {
      Id = "Melinoe_4751"
      InheritFrom = "BaseNarrative"
      DisplayName = "Or perhaps I'm inviting some terrible consequence. Although if Chronos didn't disobey their prophecies, I wouldn't have either."
      Speaker = "Melinoe"
      Event = "MorosAboutQuestLog06"
    }
    {
      Id = "Moros_0437"
      InheritFrom = "BaseNarrative"
      DisplayName = "In my experience it's best to avoid dwelling on such subject matter. Not even I can always see the pattern in my sisters' reasoning, and I think that's their preference."
      Speaker = "Moros"
      Event = "MorosAboutQuestLog06"
    }
    {
      Id = "Melinoe_4752"
      InheritFrom = "BaseSubtitle"
      DisplayName = "To make our heads ache?"
      Speaker = "Melinoe"
      Event = "MorosAboutQuestLog06"
    }
    {
      Id = "Moros_0438"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Quite likely, yes."
      Speaker = "Moros"
      Event = "MorosAboutQuestLog06"
    }
    {
      Id = "Moros_0439"
      InheritFrom = "BaseNarrative"
      DisplayName = "You... haven't often looked upon the Fated List of late. For many nights, I would anticipate your safe return, then watch as you fulfilled one prophecy after another. Now you brush right by it to come speak with me."
      Speaker = "Moros"
      Event = "MorosAboutQuestLog07"
    }
    {
      Id = "Melinoe_4760"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lord Moros, at the risk of profoundly disrespecting your sisters, I find you wholly more interesting than a bunch of minor prophecies. Well, most of them... I also don't have many left at the moment."
      Speaker = "Melinoe"
      Event = "MorosAboutQuestLog07"
    }
    {
      Id = "Moros_0440"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have done very well. Or rather you have done what would inevitably come to pass... although I choose to think that this result required much intention on your part."
      Speaker = "Moros"
      Event = "MorosAboutQuestLog07"
    }
    {
      Id = "Melinoe_4761"
      InheritFrom = "BaseNarrative"
      DisplayName = "What happens if I have no further prophecies I can fulfill?"
      Speaker = "Melinoe"
      Event = "MorosAboutQuestLog07"
    }
    {
      Id = "Moros_0441"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps then there shall be another prophecy for me... to pass the Fated List along to someone else."
      Speaker = "Moros"
      Event = "MorosAboutQuestLog07"
    }
    {
      Id = "Melinoe_4762"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You'd have to leave?"
      Speaker = "Melinoe"
      Event = "MorosAboutQuestLog07"
    }
    {
      Id = "Moros_0442"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I do not know."
      Speaker = "Moros"
      Event = "MorosAboutQuestLog07"
    }
    {
      Id = "Melinoe_4783"
      InheritFrom = "BaseNarrative"
      DisplayName = "No minor prophecies remain for me that have not come to pass. I've not seen new ones show up in a while, and... sounds like I shouldn't be expecting more anytime soon..."
      Speaker = "Melinoe"
      Event = "MorosAboutQuestLog08"
    }
    {
      Id = "Moros_0443"
      InheritFrom = "BaseNarrative"
      DisplayName = "If that is true, then my own purpose for arriving at these Crossroads is achieved. But now I do not know how to proceed, with neither my sisters nor the List to direct me."
      Speaker = "Moros"
      Event = "MorosAboutQuestLog08"
    }
    {
      Id = "Melinoe_4784"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your sisters did suggest you may have had another purpose here, beyond ensuring that the Fated List is safe and everything within it gets checked off."
      Speaker = "Melinoe"
      Event = "MorosAboutQuestLog08"
    }
    {
      Id = "Moros_0444"
      InheritFrom = "BaseNarrative"
      DisplayName = "And what might that have been, to violate their will repeatedly while growing close to you? My sisters like to scheme, but not to that extent."
      Speaker = "Moros"
      Event = "MorosAboutQuestLog08"
    }
    {
      Id = "Melinoe_4785"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're not in any rush to leave, are you?"
      Speaker = "Melinoe"
      Event = "MorosAboutQuestLog08"
    }
    {
      Id = "Moros_0445"
      InheritFrom = "BaseSubtitle"
      DisplayName = "On the contrary, I would be with you here as long as I can."
      Speaker = "Moros"
      Event = "MorosAboutQuestLog08"
    }
    {
      Id = "Moros_0180"
      InheritFrom = "BaseNarrative"
      DisplayName = "A Pitch-Black Stone has been here this entire time, and I failed to detect it. I fear I'm beginning to slip up more often than acceptable."
      Speaker = "Moros"
      Event = "MorosAboutBountyBoard01"
    }
    {
      Id = "Melinoe_3119"
      InheritFrom = "BaseNarrative"
      DisplayName = "It was inert just recently, Lord Moros. Until your grandparent gave me an idea for how to see the possibilities within. Though, perhaps I ought have checked with you first. You're troubled..."
      Speaker = "Melinoe"
      Event = "MorosAboutBountyBoard01"
    }
    {
      Id = "Moros_0311"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, it's just... Chaos and my sisters didn't always get along. Chaos wanted everything to be possible... while the Fates, their desire is for things a certain way. But, they would all agree that you should use the Stone as you see fit."
      Speaker = "Moros"
      Event = "MorosAboutBountyBoard01"
    }
    {
      Id = "Melinoe_3120"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nothing like a Pitch-Black Stone to bring the family together, right?"
      Speaker = "Melinoe"
      Event = "MorosAboutBountyBoard01"
    }
    {
      Id = "Moros_0312"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Right."
      Speaker = "Moros"
      Event = "MorosAboutBountyBoard01"
    }
    {
      Id = "Moros_0313"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Oath of the Unseen is somewhere here, isn't that so, Princess...? The aura that it emanates... I haven't felt it since before all this. I thought the Oath was lost with Mother Nyx, but it was in the care of Lady Hecate."
      Speaker = "Moros"
      Event = "MorosAboutShrine01"
    }
    {
      Id = "Melinoe_3121"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's in my own care now. The will of Night shall be done no matter what, isn't that so? You're here among the Unseen; you know our charge."
      Speaker = "Melinoe"
      Event = "MorosAboutShrine01"
    }
    {
      Id = "Moros_0314"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Oath is clearly in good hands."
      Speaker = "Moros"
      Event = "MorosAboutShrine01"
    }
    {
      Id = "Melinoe_0880"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hail, Lord Moros. How have you been acclimating so far? Is there something we can do to make your stay more comfortable?"
      Speaker = "Melinoe"
      Event = "MorosAboutCrossroads01"
    }
    {
      Id = "Moros_0042"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, Princess, I'm well, and acclimating, as you say. I've never been to such a place as this! And making every effort not to be a nuisance here."
      Speaker = "Moros"
      Event = "MorosAboutCrossroads01"
    }
    {
      Id = "Melinoe_0693"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're welcome here and safe."
      Speaker = "Melinoe"
      Event = "MorosAboutCrossroads01"
    }
    {
      Id = "Melinoe_0881"
      InheritFrom = "BaseNarrative"
      DisplayName = "What did you use to do, Lord Moros? I mean before all this. I have only the vaguest sense of it."
      Speaker = "Melinoe"
      Event = "MorosAboutDoom01"
    }
    {
      Id = "Moros_0043"
      InheritFrom = "BaseNarrative"
      DisplayName = "I served my sisters the Three Fates, both as their advocate, and as their guardian. The Fates determine when mortal lives draw to a close, and also sometimes {#Emph}how. {#Prev}I would bear witness to these more-specific weavings..."
      Speaker = "Moros"
      Event = "MorosAboutDoom01"
    }
    {
      Id = "Melinoe_0882"
      InheritFrom = "BaseNarrative"
      DisplayName = "The mortals must have appreciated your diligence. Has somebody else since taken over your responsibilities?"
      Speaker = "Melinoe"
      Event = "MorosAboutDoom01"
    }
    {
      Id = "Moros_0044"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Heh! {#Prev}You could say that, I suppose."
      Speaker = "Moros"
      Event = "MorosAboutDoom01"
    }
    {
      Id = "Melinoe_0883"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Shades around here... I know they've been avoiding you, Lord Moros. Some are filled with fear. Others with contempt. You ended their lives?"
      Speaker = "Melinoe"
      Event = "MorosAboutDoom02"
    }
    {
      Id = "Moros_0045"
      InheritFrom = "BaseNarrative"
      DisplayName = "It never was for me to decide why a mortal's life should suddenly be cut short. But, I did get to choose the {#Emph}how {#Prev}of it. Knowing the future could be monotonous work, so my sisters and I tried to keep things... interesting."
      Speaker = "Moros"
      Event = "MorosAboutDoom02"
    }
    {
      Id = "Melinoe_0884"
      InheritFrom = "BaseNarrative"
      DisplayName = "You brought misery to mortals because you were bored?"
      Speaker = "Melinoe"
      Event = "MorosAboutDoom02"
    }
    {
      Id = "Moros_0046"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm not proud of it. Especially not when you put it {#Emph}that {#Prev}way. And I regret I've caused dissension in your ranks."
      Speaker = "Moros"
      Event = "MorosAboutDoom02"
    }
    {
      Id = "Melinoe_0885"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll handle it."
      Speaker = "Melinoe"
      Event = "MorosAboutDoom02"
    }
    {
      Id = "Moros_0047"
      InheritFrom = "BaseNarrative"
      DisplayName = "You said something before to me, Princess. Concerning mortalkind. That surely they {#Emph}appreciate my diligence{#Prev}, because I'm with them in the final moments of their lives. The truth of it, however, is they hate me; most of them. In life, as well as death."
      Speaker = "Moros"
      Event = "MorosAboutDoom03"
    }
    {
      Id = "Melinoe_0886"
      InheritFrom = "BaseNarrative"
      DisplayName = "I appreciate your candor. What you say aligns with some of the rumblings I've heard from Shades loyal to us. Though it's strange, Lord Moros. Your reputation is one thing; but {#Emph}you{#Prev}, it seems, are entirely another."
      Speaker = "Melinoe"
      Event = "MorosAboutDoom03"
    }
    {
      Id = "Moros_0048"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Heh! {#Prev}From you, Princess, I'll take that as a compliment."
      Speaker = "Moros"
      Event = "MorosAboutDoom03"
    }
    {
      Id = "Melinoe_0887"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It {#Emph}was {#Prev}a compliment."
      Speaker = "Melinoe"
      Event = "MorosAboutDoom03"
    }
    {
      Id = "Melinoe_4772"
      InheritFrom = "BaseNarrative"
      DisplayName = "What were some of your favorite examples of the work you and your sisters did? Particularly inventive ends delivered with theatrics, anything like that?"
      Speaker = "Melinoe"
      Event = "MorosAboutDoom04"
    }
    {
      Id = "Moros_0679"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, where to start? Children slaughtering their parents was an old standby of ours; I'm reluctant to choose our best. There also was the war from which I first took notice of Master Odysseus. That had some good ones."
      Speaker = "Moros"
      Event = "MorosAboutDoom04"
    }
    {
      Id = "Melinoe_4773"
      InheritFrom = "BaseNarrative"
      DisplayName = "The part where mortals perished in the throes of agony and terror, leaving behind loved ones to bitterly mourn their loss... you were unmoved by all of that?"
      Speaker = "Melinoe"
      Event = "MorosAboutDoom04"
    }
    {
      Id = "Moros_0680"
      InheritFrom = "BaseNarrative"
      DisplayName = "We have a responsibility to the realm that takes precedence. And besides, mortals don't realize that everything ends up all right for most of them."
      Speaker = "Moros"
      Event = "MorosAboutDoom04"
    }
    {
      Id = "Melinoe_4774"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps we haven't done enough to promote the way the Underworld operates. Or used to."
      Speaker = "Melinoe"
      Event = "MorosAboutDoom04"
    }
    {
      Id = "Moros_0681"
      InheritFrom = "BaseSubtitle"
      DisplayName = "As long as mortals fear us still."
      Speaker = "Moros"
      Event = "MorosAboutDoom04"
    }
    {
      Id = "Moros_0493"
      InheritFrom = "BaseNarrative"
      DisplayName = "You sing beautifully, Princess. One of the Three Fates likes to hum while she weaves, but sounds nothing like you."
      Speaker = "Moros"
      Event = "MorosAboutArtemisSinging01"
    }
    {
      Id = "Melinoe_4755"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's mostly Artemis whose voice carries so strongly through this clearing, though thank you. We sometimes sing like this in preparation for the night."
      Speaker = "Melinoe"
      Event = "MorosAboutArtemisSinging01"
    }
    {
      Id = "Moros_0494"
      InheritFrom = "BaseNarrative"
      DisplayName = "The goddess of the hunt and you seem rather close. The other Olympians less so, true?"
      Speaker = "Moros"
      Event = "MorosAboutArtemisSinging01"
    }
    {
      Id = "Melinoe_4756"
      InheritFrom = "BaseNarrative"
      DisplayName = "Besides Lord Hermes, I met most of the others one by one around the time you first showed up."
      Speaker = "Melinoe"
      Event = "MorosAboutArtemisSinging01"
    }
    {
      Id = "Moros_0495"
      InheritFrom = "BaseSubtitle"
      DisplayName = "So many new acquaintances."
      Speaker = "Moros"
      Event = "MorosAboutArtemisSinging01"
    }
    {
      Id = "Melinoe_0899"
      InheritFrom = "BaseNarrative"
      DisplayName = "You used to know everything that was going to occur, didn't you, Lord Moros? Up until recently, from what I gathered. I can't imagine..."
      Speaker = "Melinoe"
      Event = "MorosAboutForesight01"
    }
    {
      Id = "Moros_0057"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, imagine it being rather dull, always knowing what's to come. But now I'm no different than you. How do you... get by like this? Many surprises are unwelcome, yet there also can be pleasant ones, true?"
      Speaker = "Moros"
      Event = "MorosAboutForesight01"
    }
    {
      Id = "Melinoe_0900"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm sure it helps that I don't know it any other way. This must be very difficult for you."
      Speaker = "Melinoe"
      Event = "MorosAboutForesight01"
    }
    {
      Id = "Moros_0058"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hah! {#Prev}Yes."
      Speaker = "Moros"
      Event = "MorosAboutForesight01"
    }
    {
      Id = "Melinoe_0901"
      InheritFrom = "BaseNarrative"
      DisplayName = "Something the matter, Lord Moros? You seem more ill-at-ease than usual. If there's additional bad news you're at liberty to share, I'm listening."
      Speaker = "Melinoe"
      Event = "MorosAboutForesight02"
    }
    {
      Id = "Moros_0059"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, {#Emph}haha! {#Prev}It's nothing of the sort, at least for now, Princess. It's just... this sensation of uncertainty. Not just in the grander scheme, but even from one evening to the next... I'm still unused to it."
      Speaker = "Moros"
      Event = "MorosAboutForesight02"
    }
    {
      Id = "Melinoe_0902"
      InheritFrom = "BaseNarrative"
      DisplayName = "There can be pleasure in the unexpected. But even those of us who never had the gift of foresight struggle in the way that you describe. For me, it helps to focus on a present state of mind. In being here right now."
      Speaker = "Melinoe"
      Event = "MorosAboutForesight02"
    }
    {
      Id = "Moros_0060"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The now... thank you, Princess..."
      Speaker = "Moros"
      Event = "MorosAboutForesight02"
    }
    {
      Id = "Moros_0061"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've been attempting what you said before, to focus on a present state of mind. It's proving difficult, because... my mind invariably drifts to many possibilities of negative outcomes."
      Speaker = "Moros"
      Event = "MorosAboutForesight03"
    }
    {
      Id = "Melinoe_0903"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm familiar with that feeling. We have to consider favorable outcomes side-by-side, and plan for them. Then, at a certain point, all we can do is hope..."
      Speaker = "Melinoe"
      Event = "MorosAboutForesight03"
    }
    {
      Id = "Moros_0062"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hope... I much prefer a sense of certainty. It's odd to think that my sisters the Fates, to others, represent sheer chance. Matters beyond one's control. Yet to me, they made everything so clear... I'd rather trust than hope."
      Speaker = "Moros"
      Event = "MorosAboutForesight03"
    }
    {
      Id = "Melinoe_0904"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You can do both."
      Speaker = "Melinoe"
      Event = "MorosAboutForesight03"
    }
    {
      Id = "Moros_0063"
      InheritFrom = "BaseNarrative"
      DisplayName = "There's so much here for me to learn! Lady Hecate has been generous enough to teach me something of the herbal ways and of your craft. An everlasting pursuit! I'm getting a late start."
      Speaker = "Moros"
      Event = "MorosAboutWitchcraft01"
    }
    {
      Id = "Melinoe_0905"
      InheritFrom = "BaseNarrative"
      DisplayName = "You wish to become a witch, Lord Moros? Maybe I can give you some pointers sometime."
      Speaker = "Melinoe"
      Event = "MorosAboutWitchcraft01"
    }
    {
      Id = "Moros_0064"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh I would welcome that."
      Speaker = "Moros"
      Event = "MorosAboutWitchcraft01"
    }
    {
      Id = "Moros_0165"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you don't mind me asking, Princess: Have you ever died before? Not in the mortal sense, it's just... you seem to have exceptional tenacity in moments most gods couldn't endure."
      Speaker = "Moros"
      Event = "MorosAboutDeath01"
    }
    {
      Id = "Melinoe_2076"
      InheritFrom = "BaseNarrative"
      DisplayName = "I cannot afford to lose my grip on consciousness out there. Headmistress taught me always to return to shadows with my final bit of strength. I learned the hard way, but I learned."
      Speaker = "Melinoe"
      Event = "MorosAboutDeath01"
    }
    {
      Id = "Moros_0166"
      InheritFrom = "BaseNarrative"
      DisplayName = "It shows. Remarkable, to have met someone equally as comfortable with death as well as life. I practically see it in your eyes."
      Speaker = "Moros"
      Event = "MorosAboutDeath01"
    }
    {
      Id = "Melinoe_2077"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It's not a big concern."
      Speaker = "Melinoe"
      Event = "MorosAboutDeath01"
    }
    {
      Id = "Melinoe_2087"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lord Moros, you must know something of the Nocturnal Arms. So, your mother and sisters collaborated on these weapons to be used only in dire need? And entrusted them to Headmistress?"
      Speaker = "Melinoe"
      Event = "MorosAboutWeapons01"
    }
    {
      Id = "Moros_0176"
      InheritFrom = "BaseNarrative"
      DisplayName = "Mother Nyx knew the fickle nature of the Olympians and the Fate-forged weapons that they used to seal away the Titans. She desired a set of counterparts that would awaken only if the realm itself was in upheaval."
      Speaker = "Moros"
      Event = "MorosAboutWeapons01"
    }
    {
      Id = "Melinoe_2088"
      InheritFrom = "BaseNarrative"
      DisplayName = "I suppose there ought to be another set of weapons forged to keep these in check. And another for {#Emph}those{#Prev}, and so on."
      Speaker = "Melinoe"
      Event = "MorosAboutWeapons01"
    }
    {
      Id = "Moros_0177"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Now you are being humorous, Princess."
      Speaker = "Moros"
      Event = "MorosAboutWeapons01"
    }
    {
      Id = "Melinoe_2089"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I wasn't."
      Speaker = "Melinoe"
      Event = "MorosAboutWeapons01"
    }
    {
      Id = "Melinoe_3155"
      InheritFrom = "BaseNarrative"
      DisplayName = "I figured that you knew something of the Nocturnal Arms, Lord Moros. But your connection to Ygnium, I'd not have guessed. You once wielded the Umbral Flames yourself! I revealed an Aspect of them that could only be your own."
      Speaker = "Melinoe"
      Event = "MorosAboutMorosAspect01"
    }
    {
      Id = "Moros_0432"
      InheritFrom = "BaseNarrative"
      DisplayName = "Princess, I take it you're not saying this for sake of jest, so please believe in turn that I have never used the Flames before; I know them only by reputation. Can you be certain that this Aspect is my own? I've many relatives..."
      Speaker = "Moros"
      Event = "MorosAboutMorosAspect01"
    }
    {
      Id = "Melinoe_3156"
      InheritFrom = "BaseNarrative"
      DisplayName = "I... yes, I think it is! The Nocturnal Arms bond with their bearers in such a way that their connections to other bearers become almost like shared memories. Although..."
      Speaker = "Melinoe"
      Event = "MorosAboutMorosAspect01"
    }
    {
      Id = "Moros_0316"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Although, these glimpses can be both of bearers past, and still to come, true? So it may be that I shall bear those Flames in some other age in which the realm's in need. I... trust the Fates must have wanted me to know in advance."
      Speaker = "Moros"
      Event = "MorosAboutMorosAspect01"
    }
    {
      Id = "Melinoe_3157"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well, {#Emph}erm... {#Prev}surprise...!"
      Speaker = "Melinoe"
      Event = "MorosAboutMorosAspect01"
    }
    {
      Id = "Moros_0178"
      InheritFrom = "BaseNarrative"
      DisplayName = "The artifact I gave to you... it can forestall the inevitable. Almost like a {#Emph}Doom Repellant{#Prev}... except, it works in the opposite way. Such technicalities aside, I trust it shall be of some benefit."
      Speaker = "Moros"
      Event = "MorosAboutKeepsake01"
    }
    {
      Id = "Melinoe_2090"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm certain it shall. Sometimes all I need is a few moments more. So if I use your Pin, you get to accompany me on my evenings out?"
      Speaker = "Melinoe"
      Event = "MorosAboutKeepsake01"
    }
    {
      Id = "Moros_0179"
      InheritFrom = "BaseNarrative"
      DisplayName = "Only in the final moments of your evenings, I'm afraid. Of course, we also have the evenings here..."
      Speaker = "Moros"
      Event = "MorosAboutKeepsake01"
    }
    {
      Id = "Melinoe_2091"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Then I'll be seeing you around."
      Speaker = "Melinoe"
      Event = "MorosAboutKeepsake01"
    }
    {
      Id = "Moros_0380"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've come to value our companionship, Princess, so there's something you should know about me in case it becomes pertinent to us... I'm promised to another, by the Fates."
      Speaker = "Moros"
      Event = "MorosAboutArrangement01"
    }
    {
      Id = "Melinoe_4597"
      InheritFrom = "BaseNarrative"
      DisplayName = "Promised to another, as in, you are betrothed? Well then, congratulations are in order I should think! Though to whom, if I may ask...? If the Fates even let on."
      Speaker = "Melinoe"
      Event = "MorosAboutArrangement01"
    }
    {
      Id = "Moros_0381"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, at the risk of being overly direct, I've concluded that she isn't you. The Fates described her as the morning light, whose luminance breaks through the darkness and reveals the beauty of the world. You're... well, different than that."
      Speaker = "Moros"
      Event = "MorosAboutArrangement01"
    }
    {
      Id = "Melinoe_4598"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh... that could be Eos, I suppose. I know her sister Selene the Moon rather well, but am not very familiar with Dawn. Are you supposed to seek her out?"
      Speaker = "Melinoe"
      Event = "MorosAboutArrangement01"
    }
    {
      Id = "Moros_0382"
      InheritFrom = "BaseNarrative"
      DisplayName = "I fear I do not know. She and I are to meet at some point, but apparently not yet. When first you and I met, I thought perhaps... that I might find her in this place."
      Speaker = "Moros"
      Event = "MorosAboutArrangement01"
    }
    {
      Id = "Melinoe_4599"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It's dark here; I don't think you shall."
      Speaker = "Melinoe"
      Event = "MorosAboutArrangement01"
    }
    {
      Id = "Moros_0383"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I realize that now."
      Speaker = "Moros"
      Event = "MorosAboutArrangement01"
    }
    {
      Id = "Melinoe_4627"
      InheritFrom = "BaseNarrative"
      DisplayName = "About this goddess to whom you're betrothed. If she really is Eos the incarnate of Dawn, perhaps I could facilitate an introduction through her sister, if you like?"
      Speaker = "Melinoe"
      Event = "MorosAboutArrangement02"
    }
    {
      Id = "Moros_0420"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, {#Emph}um{#Prev}, well, I wouldn't want for you to go out of your way, or for Selene, for that matter. You have a vital task, and I know that the Moon herself is aiding you."
      Speaker = "Moros"
      Event = "MorosAboutArrangement02"
    }
    {
      Id = "Melinoe_4628"
      InheritFrom = "BaseNarrative"
      DisplayName = "But, you said you thought you might find her here. Perhaps the Three Fates knew you'd come to us eventually, and that I'd set you on the path to meet your love?"
      Speaker = "Melinoe"
      Event = "MorosAboutArrangement02"
    }
    {
      Id = "Moros_0421"
      InheritFrom = "BaseNarrative"
      DisplayName = "Princess, if this prophecy concerning me and the one to whom I have been promised hasn't appeared on the Fated List, then there truly is no need for you to intervene."
      Speaker = "Moros"
      Event = "MorosAboutArrangement02"
    }
    {
      Id = "Melinoe_4629"
      InheritFrom = "BaseNarrative"
      DisplayName = "You don't sound all that enthusiastic about it. Do you not want to meet this goddess at some point?"
      Speaker = "Melinoe"
      Event = "MorosAboutArrangement02"
    }
    {
      Id = "Moros_0422"
      InheritFrom = "BaseNarrative"
      DisplayName = "We are {#Emph}bound {#Prev}to meet; whether I want to or not is irrelevant."
      Speaker = "Moros"
      Event = "MorosAboutArrangement02"
    }
    {
      Id = "Melinoe_4630"
      InheritFrom = "BaseSubtitle"
      DisplayName = "But... suit yourself."
      Speaker = "Melinoe"
      Event = "MorosAboutArrangement02"
    }
    {
      Id = "Moros_0423"
      InheritFrom = "BaseNarrative"
      DisplayName = "You took some interest in this goddess to whom I am said to be bound, presuming she is Eos, the incarnate of Dawn. The truth is, when the Fates first told me about her, I grew rather frustrated."
      Speaker = "Moros"
      Event = "MorosAboutArrangement03"
    }
    {
      Id = "Melinoe_4631"
      InheritFrom = "BaseNarrative"
      DisplayName = "I would have probably been frustrated as well. Did your sisters foresee this union, or arrange it? Perhaps they sought to unite your powerful family with that of a Titaness."
      Speaker = "Melinoe"
      Event = "MorosAboutArrangement03"
    }
    {
      Id = "Moros_0424"
      InheritFrom = "BaseNarrative"
      DisplayName = "In typical fashion, they revealed little. But the way in which they kept describing this goddess, or Titaness, and telling me how contented I would be... it was the first time I questioned their wisdom. Not {#Emph}outwardly{#Prev}, of course."
      Speaker = "Moros"
      Event = "MorosAboutArrangement03"
    }
    {
      Id = "Melinoe_4632"
      InheritFrom = "BaseNarrative"
      DisplayName = "They probably meant well, but... what is it you intend to do?"
      Speaker = "Melinoe"
      Event = "MorosAboutArrangement03"
    }
    {
      Id = "Moros_0425"
      InheritFrom = "BaseNarrative"
      DisplayName = "If I am doomed to be with Dawn, then so be it. But I shall not be forcing that outcome along. I would much prefer to remain here... if you'll have me."
      Speaker = "Moros"
      Event = "MorosAboutArrangement03"
    }
    {
      Id = "Melinoe_4633"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The choice ought to be yours."
      Speaker = "Melinoe"
      Event = "MorosAboutArrangement03"
    }
    {
      Id = "Moros_0417"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hello Princess, I, {#Emph}um. {#Prev}I trust that when we spoke quite recently that I did not make you, {#Emph}uh{#Prev}, well..."
      Speaker = "Moros"
      Event = "MorosAboutRelationship00"
    }
    {
      Id = "Melinoe_4624"
      InheritFrom = "BaseNarrative"
      DisplayName = "What is it, Lord Moros? I've enjoyed our conversations lately, so you needn't fear. I'd tell you if I thought something was wrong. I'd ask you do the same."
      Speaker = "Melinoe"
      Event = "MorosAboutRelationship00"
    }
    {
      Id = "Moros_0418"
      InheritFrom = "BaseNarrative"
      DisplayName = "And I shall... except, in this case, I believe I misconstrued something... I thought {#Emph}you {#Prev}may have thought, because, admittedly I am a little new at all of this."
      Speaker = "Moros"
      Event = "MorosAboutRelationship00"
    }
    {
      Id = "Melinoe_4625"
      InheritFrom = "BaseNarrative"
      DisplayName = "My own experience in such matters is significantly lacking, too. As long as we stumble together, I suppose."
      Speaker = "Melinoe"
      Event = "MorosAboutRelationship00"
    }
    {
      Id = "Moros_0419"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I, too, suppose. {#Emph}Um{#Prev}, you be well tonight."
      Speaker = "Moros"
      Event = "MorosAboutRelationship00"
    }
    {
      Id = "Melinoe_4626"
      InheritFrom = "BaseSubtitle"
      DisplayName = "OK."
      Speaker = "Melinoe"
      Event = "MorosAboutRelationship00"
    }
    {
      Id = "Moros_0430"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have been thinking more about what you said at the taverna, Princess. About finding one's source of motivation, whether through encouraging results or through adversity. Or more Ambrosia."
      Speaker = "Moros"
      Event = "MorosAboutRelationship01"
    }
    {
      Id = "Melinoe_4634"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh {#Prev}I wasn't being serious about the Ambrosia part. It's just, I find it remarkable sometimes that adversity and negativity spur me more than expressions of faith and support."
      Speaker = "Melinoe"
      Event = "MorosAboutRelationship01"
    }
    {
      Id = "Moros_0431"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hah! {#Prev}As a force of adversity and negativity myself, I appreciate your open-mindedness. But I wanted to say that Ambrosia's quite a motivator, too. I trust we can share some again sometime."
      Speaker = "Moros"
      Event = "MorosAboutRelationship01"
    }
    {
      Id = "Melinoe_2073"
      InheritFrom = "BaseSubtitle"
      DisplayName = "For certain."
      Speaker = "Melinoe"
      Event = "MorosAboutRelationship01"
    }
    {
      Id = "Moros_0163"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have a bit of an awkward question, Princess... what is the custom here for making declarations of affection? I did try asking Dora first, but she didn't give me practical advice."
      Speaker = "Moros"
      Event = "MorosAboutRelationship02"
    }
    {
      Id = "Melinoe_2074"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Erm... {#Prev}declarations of affection... I'm afraid I have bad news in that there is no custom for that here. You just choose the moment to express yourself, and hope your feelings are reciprocated."
      Speaker = "Melinoe"
      Event = "MorosAboutRelationship02"
    }
    {
      Id = "Moros_0164"
      InheritFrom = "BaseNarrative"
      DisplayName = "I see. Well then, I'll have to choose a moment very carefully. I appreciate the information and your patience."
      Speaker = "Moros"
      Event = "MorosAboutRelationship02"
    }
    {
      Id = "Melinoe_2075"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh. Anytime!"
      Speaker = "Melinoe"
      Event = "MorosAboutRelationship02"
    }
    {
      Id = "Melinoe_4619"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lord Moros... {#Emph}erm{#Prev}, so how are you this eve?"
      Speaker = "Melinoe"
      Event = "MorosAboutRelationship03"
    }
    {
      Id = "Moros_0413"
      InheritFrom = "BaseNarrative"
      DisplayName = "Princess, I... was going to ask you the same. As for me, it's... well, it's as though I'm in a dream. The wonderful kind I've sometimes heard described. But, what of you...?"
      Speaker = "Moros"
      Event = "MorosAboutRelationship03"
    }
    {
      Id = "Melinoe_4620"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm very well, yes. My dreams... have often haunted me. Though I've experienced the good kind, too. And you're right, it's kind of like this... except the feeling never lasts."
      Speaker = "Melinoe"
      Event = "MorosAboutRelationship03"
    }
    {
      Id = "Moros_0414"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps that shall be the difference in what we have; that it {#Emph}can {#Prev}last. If you would like, of course."
      Speaker = "Moros"
      Event = "MorosAboutRelationship03"
    }
    {
      Id = "Melinoe_4621"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We'll just have to find out."
      Speaker = "Melinoe"
      Event = "MorosAboutRelationship03"
    }
    {
      Id = "Moros_0415"
      InheritFrom = "BaseNarrative"
      DisplayName = "Princess! I... was going to ask you the same thing. As for me... I'm doing well, pending your response to the same question. In any case, I'm grateful that we had a chance to speak the way we did."
      Speaker = "Moros"
      Event = "MorosAboutRelationship03_B"
    }
    {
      Id = "Melinoe_4622"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm grateful, too. So... we remain close acquaintances then, right?"
      Speaker = "Melinoe"
      Event = "MorosAboutRelationship03_B"
    }
    {
      Id = "Moros_0416"
      InheritFrom = "BaseNarrative"
      DisplayName = "Of course. Although, I haven't had a lot of close acquaintances given my work, so... forgive me if I stumble."
      Speaker = "Moros"
      Event = "MorosAboutRelationship03_B"
    }
    {
      Id = "Melinoe_4623"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We'll do our best."
      Speaker = "Melinoe"
      Event = "MorosAboutRelationship03_B"
    }
    {
      Id = "Melinoe_4694"
      InheritFrom = "BaseNarrative"
      DisplayName = "You said before your sister Clotho revealed to you that we would meet, though you already knew you were promised to another. I suppose I've complicated things for you..."
      Speaker = "Melinoe"
      Event = "MorosAboutRelationship04"
    }
    {
      Id = "Moros_0426"
      InheritFrom = "BaseNarrative"
      DisplayName = "And I am grateful that you did. I had no expectations for our meeting, but the truth is, I was drawn to you quite early on. Certainly in fewer than, say... five Nectar bottles."
      Speaker = "Moros"
      Event = "MorosAboutRelationship04"
    }
    {
      Id = "Melinoe_4695"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just because you're drawn to me, doesn't mean you won't also be drawn to Eos if and when you finally meet. From all I've heard, the break of Dawn is very beautiful."
      Speaker = "Melinoe"
      Event = "MorosAboutRelationship04"
    }
    {
      Id = "Moros_0427"
      InheritFrom = "BaseNarrative"
      DisplayName = "Princess, let us never speak of Dawn again. Perhaps my sisters know what shall become of me, but I increasingly suspect that they do not. They certainly did not prepare me for {#Emph}your {#Prev}beauty, for one."
      Speaker = "Moros"
      Event = "MorosAboutRelationship04"
    }
    {
      Id = "Melinoe_4696"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hah{#Prev}, surprise!"
      Speaker = "Melinoe"
      Event = "MorosAboutRelationship04"
    }
    {
      Id = "Moros_0428"
      InheritFrom = "BaseNarrative"
      DisplayName = "Princess, I ought to mention, I know there are others whom you're close with, all of whom I think you've known longer than me. I, on the other hand, have no one else. Living with my sisters, I had little opportunity."
      Speaker = "Moros"
      Event = "MorosAboutRelationships01"
    }
    {
      Id = "Melinoe_4749"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can think of no other explanation. Many different goddesses or gods would surely be delighted if they had you in their lives, Moros. But if I'm to have you to myself for now, that's certainly all right."
      Speaker = "Melinoe"
      Event = "MorosAboutRelationships01"
    }
    {
      Id = "Moros_0429"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm pleased you do not mind."
      Speaker = "Moros"
      Event = "MorosAboutRelationships01"
    }
    {
      Id = "Melinoe_3146"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thank you for visiting me last night, Lord Moros. So, hypothetically, if I were to complete a certain incantation that somehow loosened the grip the Three Fates have on my birthright... how angry would they be?"
      Speaker = "Melinoe"
      Event = "MorosAboutSurfacePenaltyCure01"
    }
    {
      Id = "Moros_0299"
      InheritFrom = "BaseNarrative"
      DisplayName = "Please understand, Princess, that I am not at liberty to give advice on matters such as that, not even hypothetically. I trust I've been sufficiently direct in putting it this way?"
      Speaker = "Moros"
      Event = "MorosAboutSurfacePenaltyCure01"
    }
    {
      Id = "Melinoe_3147"
      InheritFrom = "BaseNarrative"
      DisplayName = "In other words, we shouldn't be talking about this at all, and I assume all risk for my actions related to any potentially forbidden incantations that I've learned."
      Speaker = "Melinoe"
      Event = "MorosAboutSurfacePenaltyCure01"
    }
    {
      Id = "Moros_0300"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yes, that covers it."
      Speaker = "Moros"
      Event = "MorosAboutSurfacePenaltyCure01"
    }
    {
      Id = "Moros_0301"
      InheritFrom = "BaseNarrative"
      DisplayName = "Princess, officially I cannot condone your actions. Your visits to the surface violate the terms the Fates set for your father's lineage, and you invite whichever consequences they see fit."
      Speaker = "Moros"
      Event = "MorosAboutSurfacePenaltyCure02"
    }
    {
      Id = "Melinoe_3148"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes, but {#Emph}un{#Prev}officially, Lord Moros? If you'll permit yourself to speak of it this once. Or are we limited to candid conversations only when I'm on the verge of death?"
      Speaker = "Melinoe"
      Event = "MorosAboutSurfacePenaltyCure02"
    }
    {
      Id = "Moros_0302"
      InheritFrom = "BaseNarrative"
      DisplayName = "Our conversations are most definitely more secure that way, but {#Emph}un{#Prev}officially... I am amazed by your accomplishment. Perhaps living so close to the surface predisposed you, but still... I was uncertain it was possible."
      Speaker = "Moros"
      Event = "MorosAboutSurfacePenaltyCure02"
    }
    {
      Id = "Melinoe_3149"
      InheritFrom = "BaseSubtitle"
      DisplayName = "May the Fates forgive my transgressions."
      Speaker = "Melinoe"
      Event = "MorosAboutSurfacePenaltyCure02"
    }
    {
      Id = "Moros_0303"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Likewise..."
      Speaker = "Moros"
      Event = "MorosAboutSurfacePenaltyCure02"
    }
    {
      Id = "Moros_0306"
      InheritFrom = "BaseNarrative"
      DisplayName = "How far were you able to go last night, Princess? You were gone for some time. I sensed the growing fear and excitement in the air, even heard some of the rumblings."
      Speaker = "Moros"
      Event = "MorosAboutChronosBossW01"
    }
    {
      Id = "Melinoe_3150"
      InheritFrom = "BaseNarrative"
      DisplayName = "If the rumblings were that I reached the depths of Tartarus, broke into my father's stolen House, confronted Chronos there, and outfought him, then you heard correctly. Hardly a final victory, but still."
      Speaker = "Melinoe"
      Event = "MorosAboutChronosBossW01"
    }
    {
      Id = "Moros_0307"
      InheritFrom = "BaseNarrative"
      DisplayName = "I would object to anyone but you diminishing such a victory. Is this not a vitally important component of the task you've been entrusted to complete?"
      Speaker = "Moros"
      Event = "MorosAboutChronosBossW01"
    }
    {
      Id = "Melinoe_3151"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well, yes it is, but..."
      Speaker = "Melinoe"
      Event = "MorosAboutChronosBossW01"
    }
    {
      Id = "Moros_0308"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Then congratulations, and may the Fates avail your next move."
      Speaker = "Moros"
      Event = "MorosAboutChronosBossW01"
    }
    {
      Id = "Moros_0433"
      InheritFrom = "BaseNarrative"
      DisplayName = "Chronos fell to you once more, that much I heard. It's an impressive feat, although... you mean to bring him death, yet he is deathless. This seems to be a paradox."
      Speaker = "Moros"
      Event = "MorosAboutChronosBossW02"
    }
    {
      Id = "Melinoe_4697"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's right. Mortal death is not the end, but mortals often think it is. When we say {#Emph}Death to Chronos{#Prev}, we mean it in that absolute way. As impossible as it may seem."
      Speaker = "Melinoe"
      Event = "MorosAboutChronosBossW02"
    }
    {
      Id = "Moros_0434"
      InheritFrom = "BaseNarrative"
      DisplayName = "So then, to vanquish him must be at least a step toward that end. What shall become of everything if you succeed and Time is truly killed? A world without Time..."
      Speaker = "Moros"
      Event = "MorosAboutChronosBossW02"
    }
    {
      Id = "Melinoe_4698"
      InheritFrom = "BaseNarrative"
      DisplayName = "...A world without ruin and decay; our world existed before Time and can exist without."
      Speaker = "Melinoe"
      Event = "MorosAboutChronosBossW02"
    }
    {
      Id = "Moros_0435"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Another paradox, yet one that must be true."
      Speaker = "Moros"
      Event = "MorosAboutChronosBossW02"
    }
    {
      Id = "Moros_0469"
      InheritFrom = "BaseNarrative"
      DisplayName = "Another victory within the depths of Tartarus... except now, your fight requires you to transcend space and time, with assistance from your grandfather, of course. True...?"
      Speaker = "Moros"
      Event = "MorosAboutPostEndingChronosBossW01"
    }
    {
      Id = "Melinoe_4808"
      InheritFrom = "BaseNarrative"
      DisplayName = "True, as far as I can understand, Lord Moros. Headmistress notified you of these new details, then? You don't sound terribly surprised."
      Speaker = "Melinoe"
      Event = "MorosAboutPostEndingChronosBossW01"
    }
    {
      Id = "Moros_0470"
      InheritFrom = "BaseNarrative"
      DisplayName = "I assure you that my inability to sound terribly surprised does not prevent my feeling so. You have many such battles left to fight?"
      Speaker = "Moros"
      Event = "MorosAboutPostEndingChronosBossW01"
    }
    {
      Id = "Melinoe_4809"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Whenever time permits."
      Speaker = "Melinoe"
      Event = "MorosAboutPostEndingChronosBossW01"
    }
    {
      Id = "Moros_0471"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Then to your many victories to come."
      Speaker = "Moros"
      Event = "MorosAboutPostEndingChronosBossW01"
    }
    {
      Id = "Melinoe_0891"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lord Moros... I understand you can't reveal the weavings of the Fates. But, could you just tell me what the three of them are like?"
      Speaker = "Melinoe"
      Event = "MorosAboutFates01"
    }
    {
      Id = "Moros_0051"
      InheritFrom = "BaseNarrative"
      DisplayName = "My sisters. They... well each is her own goddess, I suppose. Clotho the spinstress is the talkative one, the decisive one. Lachesis is a little more agreeable; she apportions the thread. And Atropos, she sticks to the cutting."
      Speaker = "Moros"
      Event = "MorosAboutFates01"
    }
    {
      Id = "Melinoe_0892"
      InheritFrom = "BaseNarrative"
      DisplayName = "It must be a little imposing, knowing your sisters determine the course of every life. Even your own?"
      Speaker = "Melinoe"
      Event = "MorosAboutFates01"
    }
    {
      Id = "Moros_0052"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Even my own."
      Speaker = "Moros"
      Event = "MorosAboutFates01"
    }
    {
      Id = "Melinoe_2998"
      InheritFrom = "BaseNarrative"
      DisplayName = "...My task began immediately following reports that Chronos found a way to gain the upper hand against Olympus. We just didn't know which sort of way. But, now I think I do: your sisters the Three Fates... he got them, didn't he? Is that why you're here?"
      Speaker = "Melinoe"
      Event = "MorosAboutFates02"
    }
    {
      Id = "Moros_0157"
      InheritFrom = "BaseNarrative"
      DisplayName = "...You ask while making clear to me that you already know. I ought to have been there when it happened. Perhaps the Fates knew I lacked the strength to protect them; so they protected me."
      Speaker = "Moros"
      Event = "MorosAboutFates02"
    }
    {
      Id = "Melinoe_0894"
      InheritFrom = "BaseNarrative"
      DisplayName = "How did he find them? What does he want from them?"
      Speaker = "Melinoe"
      Event = "MorosAboutFates02"
    }
    {
      Id = "Moros_0054"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't know how he found them. Few beings with knowledge of their whereabouts exist. As to what he wants from them... and this is a conjecture of my own... surely he'll try to influence their weavings from here on."
      Speaker = "Moros"
      Event = "MorosAboutFates02"
    }
    {
      Id = "Melinoe_0895"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh..."
      Speaker = "Melinoe"
      Event = "MorosAboutFates02"
    }
    {
      Id = "Melinoe_0896"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lord Moros, you said before you think Chronos is going to influence the weavings of the Fates. You mean he's going to try to change the future? Force a favorable outcome?"
      Speaker = "Melinoe"
      Event = "MorosAboutFates03"
    }
    {
      Id = "Moros_0055"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes. I think he's already trying to do just that. Unfortunately for him, the Three Fates can be a bit headstrong. I trust they may be quite resistant as captives."
      Speaker = "Moros"
      Event = "MorosAboutFates03"
    }
    {
      Id = "Melinoe_0897"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can't imagine Chronos tolerating insolence, whether from your sisters or anybody else. How he must hate them! When he was overthrown before, that was the outcome of a fated prophecy..."
      Speaker = "Melinoe"
      Event = "MorosAboutFates03"
    }
    {
      Id = "Moros_0056"
      InheritFrom = "BaseNarrative"
      DisplayName = "Indeed. As for now, I sense there are no weavings happening at all. No new futures foretold. Chronos believes he has no prophecy to fear. Yet, I believe this is an opportunity for you. To make a better future for us all."
      Speaker = "Moros"
      Event = "MorosAboutFates03"
    }
    {
      Id = "Moros_0151"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your family has been of keen interest to the Fates for some time, hasn't it? Ever since Chronos learned he was doomed to be usurped by his own children."
      Speaker = "Moros"
      Event = "MorosAboutFates04"
    }
    {
      Id = "Melinoe_2064"
      InheritFrom = "BaseNarrative"
      DisplayName = "A prophecy that was only fulfilled because Chronos learned of it, and desperately tried to prevent it from coming to pass. Perhaps I'd have an easier time with the Fated List if I try to thwart it at every turn."
      Speaker = "Melinoe"
      Event = "MorosAboutFates04"
    }
    {
      Id = "Moros_0152"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wouldn't second-guess too much. Later your father and uncles drew lots to divide up their rule of the world. By {#Emph}chance{#Prev}, your father wound up with the least desirable part, didn't he?"
      Speaker = "Moros"
      Event = "MorosAboutFates04"
    }
    {
      Id = "Melinoe_2065"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps the Underworld best suited him. So now it's {#Emph}my {#Prev}turn to see that the will of the Fates is done? If they even planned this far ahead."
      Speaker = "Melinoe"
      Event = "MorosAboutFates04"
    }
    {
      Id = "Moros_0153"
      InheritFrom = "BaseNarrative"
      DisplayName = "They {#Emph}were {#Prev}captured, so this can't all be according to their plan. But they are counting on your aid."
      Speaker = "Moros"
      Event = "MorosAboutFates04"
    }
    {
      Id = "Melinoe_2066"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I appreciate their confidence."
      Speaker = "Melinoe"
      Event = "MorosAboutFates04"
    }
    {
      Id = "Melinoe_2069"
      InheritFrom = "BaseNarrative"
      DisplayName = "How can you be so certain that there are no more weavings taking place? That rather than the Fates setting the course of our lives, there's no pattern anymore... only sheer, mindless chance?"
      Speaker = "Melinoe"
      Event = "MorosAboutFates05"
    }
    {
      Id = "Moros_0158"
      InheritFrom = "BaseNarrative"
      DisplayName = "I never said I was certain... only that I no longer sensed my sisters' work, and it's a relatively well-honed sense. But, I've also never been apart from my sisters like this. I feel... unmoored."
      Speaker = "Moros"
      Event = "MorosAboutFates05"
    }
    {
      Id = "Melinoe_2070"
      InheritFrom = "BaseNarrative"
      DisplayName = "As though you don't know where you're going. To me, everything feels the same as ever. Present circumstances notwithstanding. How much control did the Fates truly have?"
      Speaker = "Melinoe"
      Event = "MorosAboutFates05"
    }
    {
      Id = "Moros_0159"
      InheritFrom = "BaseNarrative"
      DisplayName = "They are highly influential, I can tell you that. But can they force your every action, every thought? Of course not. You are conscious. It was your choice to speak with me just now."
      Speaker = "Moros"
      Event = "MorosAboutFates05"
    }
    {
      Id = "Melinoe_2071"
      InheritFrom = "BaseSubtitle"
      DisplayName = "But the Fates knew we'd meet."
      Speaker = "Melinoe"
      Event = "MorosAboutFates05"
    }
    {
      Id = "Moros_0160"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Precisely."
      Speaker = "Moros"
      Event = "MorosAboutFates05"
    }
    {
      Id = "Melinoe_4820"
      InheritFrom = "BaseNarrative"
      DisplayName = "Always wanted to ask this about the Fates, Lord Moros... why the {#Emph}weaving? {#Prev}Of all the ways one could foretell what's to come... I mean why not compose ballads, paint vases?"
      Speaker = "Melinoe"
      Event = "MorosAboutWeaving01"
    }
    {
      Id = "Moros_0693"
      InheritFrom = "BaseNarrative"
      DisplayName = "You'd think I'd know the answer, Princess, but it pains me to admit... I never once stopped to consider that. Weaving is just what they did. There aren't too many activities fit for exactly three. Perhaps {#Emph}that's {#Prev}it."
      Speaker = "Moros"
      Event = "MorosAboutWeaving01"
    }
    {
      Id = "Melinoe_4821"
      InheritFrom = "BaseNarrative"
      DisplayName = "It just seems like they could make their prophecies much faster if they chose a simpler craft."
      Speaker = "Melinoe"
      Event = "MorosAboutWeaving01"
    }
    {
      Id = "Moros_0694"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Best not to give them any ideas."
      Speaker = "Moros"
      Event = "MorosAboutWeaving01"
    }
    {
      Id = "Melinoe_0888"
      InheritFrom = "BaseNarrative"
      DisplayName = "You must know the Three Fates better than anyone, besides maybe Nyx, herself! {#Emph}Erm{#Prev}, though, forgive me for invoking her..."
      Speaker = "Melinoe"
      Event = "MorosAboutNyx01"
    }
    {
      Id = "Moros_0049"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's quite all right. The Fates, I know full well, but Mother Nyx...? We saw her seldomly. The nature of our work was such that even she would almost never get involved. Besides, she'd many other children to attend to."
      Speaker = "Moros"
      Event = "MorosAboutNyx01"
    }
    {
      Id = "Melinoe_0889"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm sorry to hear that. My mother's the Queen. We've never even met since I was an infant. Nobody around here seems to know their blasted mothers, come to think!"
      Speaker = "Melinoe"
      Event = "MorosAboutNyx01"
    }
    {
      Id = "Moros_0050"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come now, the mothers can't be blamed. We children {#Emph}are {#Prev}insufferable at times."
      Speaker = "Moros"
      Event = "MorosAboutNyx01"
    }
    {
      Id = "Melinoe_0890"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Heh. {#Prev}True."
      Speaker = "Melinoe"
      Event = "MorosAboutNyx01"
    }
    {
      Id = "Melinoe_3116"
      InheritFrom = "BaseNarrative"
      DisplayName = "How well would you say you know your grandparent, Lord Moros? I'd not expected to meet Primordial Chaos of all beings. But they summoned me to their domain, and... I don't quite know what they want from me."
      Speaker = "Melinoe"
      Event = "MorosAboutChaos01"
    }
    {
      Id = "Moros_0304"
      InheritFrom = "BaseNarrative"
      DisplayName = "Chaos summoned you...? That is unusual, though not entirely without precedent. And in this case, I can imagine why. Chaos and Mother Nyx were rather close, after all."
      Speaker = "Moros"
      Event = "MorosAboutChaos01"
    }
    {
      Id = "Melinoe_3117"
      InheritFrom = "BaseNarrative"
      DisplayName = "So Chaos seeks their daughter. They did mention something about a quandary."
      Speaker = "Melinoe"
      Event = "MorosAboutChaos01"
    }
    {
      Id = "Moros_0305"
      InheritFrom = "BaseNarrative"
      DisplayName = "This isn't the first time they took an interest in your family. Or took action that the Fates themselves likely never preordained. I choose to think you've made a new ally."
      Speaker = "Moros"
      Event = "MorosAboutChaos01"
    }
    {
      Id = "Melinoe_3118"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I hope you're right."
      Speaker = "Melinoe"
      Event = "MorosAboutChaos01"
    }
    {
      Id = "Melinoe_3152"
      InheritFrom = "BaseNarrative"
      DisplayName = "I learned what happened to the Fates, Lord Moros. Or rather, how Chronos discovered where they were. It was Chaos who led Chronos to them. Chaos, of course, seems to regret this now, and I don't think had any ill intent..."
      Speaker = "Melinoe"
      Event = "MorosAboutChaos02"
    }
    {
      Id = "Moros_0309"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh. That is a lot of information to take in. It does make some amount of sense. Chronos, having free reign in your father's House, eventually found his way to Chaos, then coaxed this vital information out of them. Then, he ambushed the Fates, as part of his plans for conquest."
      Speaker = "Moros"
      Event = "MorosAboutChaos02"
    }
    {
      Id = "Melinoe_3153"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're taking all this better than I would have. Come to think of it, I've never seen you angry."
      Speaker = "Melinoe"
      Event = "MorosAboutChaos02"
    }
    {
      Id = "Moros_0310"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're seeing me right now. It's just, my anger changes nothing, typically. So Chaos now is working to undo some of the damage caused? Chronos removed one threat in the Fates, but created another. Perhaps an unwise trade."
      Speaker = "Moros"
      Event = "MorosAboutChaos02"
    }
    {
      Id = "Melinoe_3154"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Making a mockery of Chaos seems unwise to me!"
      Speaker = "Melinoe"
      Event = "MorosAboutChaos02"
    }
    {
      Id = "Moros_0120"
      InheritFrom = "BaseNarrative"
      DisplayName = "Forgive me if I overstep, Princess. It's just... it seems to me that you and Nemesis don't always get along..."
      Speaker = "Moros"
      Event = "MorosAboutNemesis01"
    }
    {
      Id = "Melinoe_0931"
      InheritFrom = "BaseNarrative"
      DisplayName = "Whatever could have given you such an impression, Lord Moros? Perhaps all our incessant squabbles over petty things?"
      Speaker = "Melinoe"
      Event = "MorosAboutNemesis01"
    }
    {
      Id = "Moros_0121"
      InheritFrom = "BaseNarrative"
      DisplayName = "They can't be petty things if they're of your concern, or for that matter, hers. I understand there's some dispute about your task. You were chosen for it, she was not. True?"
      Speaker = "Moros"
      Event = "MorosAboutNemesis01"
    }
    {
      Id = "Melinoe_0932"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's true. Nemesis trained hard, but so have I. The choice was never mine, yet she blames me."
      Speaker = "Melinoe"
      Event = "MorosAboutNemesis01"
    }
    {
      Id = "Moros_0122"
      InheritFrom = "BaseNarrative"
      DisplayName = "If I know Nemesis, she blames herself. Although, she takes it out on you, that I can see. If anyone, she ought to blame the Fates..."
      Speaker = "Moros"
      Event = "MorosAboutNemesis01"
    }
    {
      Id = "Melinoe_0933"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I know, right?"
      Speaker = "Melinoe"
      Event = "MorosAboutNemesis01"
    }
    {
      Id = "Moros_0171"
      InheritFrom = "BaseNarrative"
      DisplayName = "You and Nemesis appear to have been interacting in a more productive way of late. If I may ask, what changed between you two?"
      Speaker = "Moros"
      Event = "MorosAboutNemesis02"
    }
    {
      Id = "Melinoe_2082"
      InheritFrom = "BaseNarrative"
      DisplayName = "I think we're becoming more comfortable with our respective roles in all of this. And perhaps Nemesis has finally gained a modicum of faith in my ability."
      Speaker = "Melinoe"
      Event = "MorosAboutNemesis02"
    }
    {
      Id = "Moros_0172"
      InheritFrom = "BaseNarrative"
      DisplayName = "I see... although I think there's something more. Her respect for you doesn't seem newly formed."
      Speaker = "Moros"
      Event = "MorosAboutNemesis02"
    }
    {
      Id = "Melinoe_2083"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Could have fooled me."
      Speaker = "Melinoe"
      Event = "MorosAboutNemesis02"
    }
    {
      Id = "Moros_0317"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd ask what my sister Eris is doing here, but then they say {#Emph}wheresoever goes Doom, Strife follows. {#Prev}Or the other way around, whether I like it or not. Has she been here long?"
      Speaker = "Moros"
      Event = "MorosAboutEris01"
    }
    {
      Id = "Melinoe_3158"
      InheritFrom = "BaseNarrative"
      DisplayName = "She comes and goes from time to time, typically after some bloody battle between the forces of Chronos and Olympus. We first met a while back. Briefly trained together though Headmistress soon gave up on her, as patient as she is."
      Speaker = "Melinoe"
      Event = "MorosAboutEris01"
    }
    {
      Id = "Moros_0318"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Fates gave up on her as well. Ordered that we never interact, that I not clean her messes anymore; although sometimes she'll goad a conversation out of me. I trust she hasn't made your lives too difficult?"
      Speaker = "Moros"
      Event = "MorosAboutEris01"
    }
    {
      Id = "Melinoe_3159"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We've managed."
      Speaker = "Melinoe"
      Event = "MorosAboutEris01"
    }
    {
      Id = "Melinoe_3160"
      InheritFrom = "BaseNarrative"
      DisplayName = "Eris outright attacked me, just as I was approaching Mount Olympus. Who gave her the Adamant Rail, anyway? A weapon once used to slay Titans, turned against the gods..."
      Speaker = "Melinoe"
      Event = "MorosAboutEris02"
    }
    {
      Id = "Moros_0319"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Rail {#Emph}has {#Prev}turned against the gods before. Only the Fates know its true and final purpose... but Eris has it by {#Emph}their {#Prev}own decree. Perhaps as a plaything to keep her occupied."
      Speaker = "Moros"
      Event = "MorosAboutEris02"
    }
    {
      Id = "Melinoe_3161"
      InheritFrom = "BaseNarrative"
      DisplayName = "To keep {#Emph}me {#Prev}occupied, apparently. Makes me wonder if the Fates want Chronos stopped, or not. Did you and Eris ever fight like this?"
      Speaker = "Melinoe"
      Event = "MorosAboutEris02"
    }
    {
      Id = "Moros_0320"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, yes. Much as I tried to avoid it."
      Speaker = "Moros"
      Event = "MorosAboutEris02"
    }
    {
      Id = "Moros_0475"
      InheritFrom = "BaseNarrative"
      DisplayName = "I noticed Hypnos was no longer in his spot, though for how long, I couldn't say. Perhaps Odysseus had him relocated someplace where the snoring would be less of a distraction."
      Speaker = "Moros"
      Event = "MorosAboutHypnos01"
    }
    {
      Id = "Melinoe_4812"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh no, I woke him up. Required a series of increasingly complex alchemical processes and dreamwalks, but still. He immediately left for the House of Hades in a bit of a panic."
      Speaker = "Melinoe"
      Event = "MorosAboutHypnos01"
    }
    {
      Id = "Moros_0476"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm sorry I missed him! From what I know about your father, he does value punctuality. And from what I know about my brother Sleep, he must have greeted you enthusiastically."
      Speaker = "Moros"
      Event = "MorosAboutHypnos01"
    }
    {
      Id = "Melinoe_4813"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You could say that."
      Speaker = "Melinoe"
      Event = "MorosAboutHypnos01"
    }
    {
      Id = "Moros_0173"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm attempting to contain my enthusiasm for the venerable hero of mortalkind over there, Princess. Our adversary may be crafty, but Odysseus is renowned for his wiles above all!"
      Speaker = "Moros"
      Event = "MorosAboutOdysseus01"
    }
    {
      Id = "Melinoe_2084"
      InheritFrom = "BaseNarrative"
      DisplayName = "It figures you would be familiar with the Great Tactician! Likely he evaded you at least once or twice in his life, if his many tales are to be believed."
      Speaker = "Melinoe"
      Event = "MorosAboutOdysseus01"
    }
    {
      Id = "Moros_0174"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, they're to be believed, I can attest."
      Speaker = "Moros"
      Event = "MorosAboutOdysseus01"
    }
    {
      Id = "Moros_0167"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your companion Dora... she's a lively one. Especially for her age. Most of the dead grow quite lethargic over time. Although I suppose things have been more eventful recently."
      Speaker = "Moros"
      Event = "MorosAboutDora01"
    }
    {
      Id = "Melinoe_2078"
      InheritFrom = "BaseNarrative"
      DisplayName = "Dora seems to be quite intrigued by you, Lord Moros. Call it a morbid fascination. You mention her age... she doesn't seem to have any recollection of such details. But, you can just tell?"
      Speaker = "Melinoe"
      Event = "MorosAboutDora01"
    }
    {
      Id = "Moros_0168"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have my ways. Dora is... well, she's not the eldest one here, though she's been around longer than most. That much is safe for me to divulge."
      Speaker = "Moros"
      Event = "MorosAboutDora01"
    }
    {
      Id = "Melinoe_2079"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Huh."
      Speaker = "Melinoe"
      Event = "MorosAboutDora01"
    }
    {
      Id = "Moros_0490"
      InheritFrom = "BaseNarrative"
      DisplayName = "Something seems to have occurred with your companion Dora. She hasn't been as keen to make her remarks or possess my belongings. Is she all right?"
      Speaker = "Moros"
      Event = "MorosAboutDoraMemories01"
    }
    {
      Id = "Melinoe_4753"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes, I think so. Something's been nagging at her for a while that she's finally started to sort out. She may well tell you more about it at some point."
      Speaker = "Melinoe"
      Event = "MorosAboutDoraMemories01"
    }
    {
      Id = "Moros_0491"
      InheritFrom = "BaseNarrative"
      DisplayName = "I think I may already know. Well, she's an old soul but a strong one. And fortunate to have you as a friend. Do you suppose there's something I may do to help?"
      Speaker = "Moros"
      Event = "MorosAboutDoraMemories01"
    }
    {
      Id = "Melinoe_4754"
      InheritFrom = "BaseNarrative"
      DisplayName = "Act frightened from her hauntings. She loves that."
      Speaker = "Melinoe"
      Event = "MorosAboutDoraMemories01"
    }
    {
      Id = "Moros_0492"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Certainly she's startled me before..."
      Speaker = "Moros"
      Event = "MorosAboutDoraMemories01"
    }
    {
      Id = "Melinoe_2085"
      InheritFrom = "BaseNarrative"
      DisplayName = "Considering how well you seem to know Odysseus, surely you know brave Commander Schelemeus, do you not? Brave and humble, for I scarce know anything about his past."
      Speaker = "Melinoe"
      Event = "MorosAboutSkelly01"
    }
    {
      Id = "Moros_0175"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Schelemeus{#Prev}, you say...? I know of no one by that name. And my recollection is infallible. Perhaps he hails from a distant land, presided over by its own strange gods..."
      Speaker = "Moros"
      Event = "MorosAboutSkelly01"
    }
    {
      Id = "Melinoe_2086"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No, that can't be..."
      Speaker = "Melinoe"
      Event = "MorosAboutSkelly01"
    }
    {
      Id = "Melinoe_2080"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lord Moros, I've a friend who lives in the woods called Arachne. Long story, but she was on the receiving end of a powerful curse that... changed her into a spider. Do you deal in curses at all?"
      Speaker = "Melinoe"
      Event = "MorosAboutArachne01"
    }
    {
      Id = "Moros_0169"
      InheritFrom = "BaseNarrative"
      DisplayName = "I remember the case of Arachne. I didn't know what became of her after her metamorphosis, so... it's interesting to learn that you are friends. But no... I'm afraid curses aren't my specialty."
      Speaker = "Moros"
      Event = "MorosAboutArachne01"
    }
    {
      Id = "Melinoe_2081"
      InheritFrom = "BaseNarrative"
      DisplayName = "You called it {#Emph}the case of Arachne. {#Prev}She was thought to be the greatest weaver in the world, greater than the gods... greater even than the {#Emph}Fates? {#Prev}Unwelcome competition, perhaps...?"
      Speaker = "Melinoe"
      Event = "MorosAboutArachne01"
    }
    {
      Id = "Moros_0170"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Perhaps."
      Speaker = "Moros"
      Event = "MorosAboutArachne01"
    }
    {
      Id = "Melinoe_3599"
      InheritFrom = "BaseNarrative"
      DisplayName = "You must know the Titan Prometheus. I faced him on Olympus. Little wonder he now fights against the gods, having met his doom and lived... unlike the mortals he supposedly cares for so much."
      Speaker = "Melinoe"
      Event = "MorosAboutPrometheus01"
    }
    {
      Id = "Moros_0337_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "Prometheus... I took no pleasure in his plight. The gods certainly know how to make an example of someone. Now he seeks vengeance? A favored pattern in the weavings of the Fates."
      Speaker = "Moros"
      Event = "MorosAboutPrometheus01"
    }
    {
      Id = "Melinoe_3600"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now that you mention it, his knowledge of the future seems similar to that of your sisters. Do you suppose he's sided with Chronos because he knows Chronos will ultimately win?"
      Speaker = "Melinoe"
      Event = "MorosAboutPrometheus01"
    }
    {
      Id = "Moros_0338"
      InheritFrom = "BaseNarrative"
      DisplayName = "I do not wish to speculate, Princess. All I know is the Titan of Foresight never was the violent sort. His experience in captivity... must have changed him."
      Speaker = "Moros"
      Event = "MorosAboutPrometheus01"
    }
    {
      Id = "Melinoe_3601"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll have to change him some more."
      Speaker = "Melinoe"
      Event = "MorosAboutPrometheus01"
    }
    {
      Id = "Moros_0339"
      InheritFrom = "BaseNarrative"
      DisplayName = "In my weakest moments... I used to envy Prometheus, even knowing his plight. For he was loved by mortals, having given them the gift of fire from Olympus. {#Emph}I{#Prev}, on the other hand, was {#Emph}hated. {#Prev}It should not have mattered to me... but it did."
      Speaker = "Moros"
      Event = "MorosAboutPrometheus02"
    }
    {
      Id = "Melinoe_3602"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come on, Lord Moros. What mortals think of us is of no consequence. Even if it were, better to be hated than a traitor. Prometheus thinks only of mortals and himself. I'm surprised Chronos would entrust anything to him."
      Speaker = "Melinoe"
      Event = "MorosAboutPrometheus02"
    }
    {
      Id = "Moros_0340"
      InheritFrom = "BaseNarrative"
      DisplayName = "Although I said I didn't wish to speculate, I... cannot shake the sense that Chronos values him {#Emph}because {#Prev}so many mortals do. The new Golden Age he seeks to bring about... an age for mortals, not for gods..."
      Speaker = "Moros"
      Event = "MorosAboutPrometheus02"
    }
    {
      Id = "Melinoe_3603"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Doubtless all the mortals' problems would be solved..."
      Speaker = "Melinoe"
      Event = "MorosAboutPrometheus02"
    }
    {
      Id = "Moros_0341"
      InheritFrom = "BaseNarrative"
      DisplayName = "My sisters told me of a certain prophecy even I thought would never come to pass... that Olympus would once again face the fury of the Father of All Monsters, and their conflict would shake the world to its core. And now it's happening..."
      Speaker = "Moros"
      Event = "MorosAboutTyphon01"
    }
    {
      Id = "Melinoe_3924"
      InheritFrom = "BaseNarrative"
      DisplayName = "You mean you {#Emph}knew {#Prev}Typhon's attack was a real possibility? Why didn't you warn us? We could have prepared!"
      Speaker = "Melinoe"
      Event = "MorosAboutTyphon01"
    }
    {
      Id = "Moros_0342"
      InheritFrom = "BaseNarrative"
      DisplayName = "I... was not permitted to warn you. Had I done so, it merely would have expedited an outcome I now realize was bound to happen anyway. Though perhaps your implication is correct, and this {#Emph}is {#Prev}all my fault..."
      Speaker = "Moros"
      Event = "MorosAboutTyphon01"
    }
    {
      Id = "Melinoe_3925"
      InheritFrom = "BaseNarrative"
      DisplayName = "What? How is this all your fault? Unless you aided Chronos in awakening the most notorious fiend the gods ever faced, I don't see how {#Emph}you {#Prev}had anything to do with this."
      Speaker = "Melinoe"
      Event = "MorosAboutTyphon01"
    }
    {
      Id = "Moros_0343"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Unraveling a Fateful Bond. {#Prev}I abetted your plans to gain the surface. The awakening of Typhon... perhaps it's a punishment... and a reminder never to defy the Fates. Princess, please forgive me."
      Speaker = "Moros"
      Event = "MorosAboutTyphon01"
    }
    {
      Id = "Melinoe_3926"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Nonsense. {#Emph}Chronos {#Prev}did this, not you."
      Speaker = "Melinoe"
      Event = "MorosAboutTyphon01"
    }
    {
      Id = "Melinoe_4589"
      InheritFrom = "BaseNarrative"
      DisplayName = "The prophecy concerning Typhon's reawakening... what made you think it would never come to pass? I thought the weavings of your sisters were always certain to come true."
      Speaker = "Melinoe"
      Event = "MorosAboutTyphon02"
    }
    {
      Id = "Moros_0375"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Fates are not always straightforward. Their prophecies are represented visually, not written in detail... at least the major ones. I thought my interpretation of Typhon's return was likely misguided."
      Speaker = "Moros"
      Event = "MorosAboutTyphon02"
    }
    {
      Id = "Melinoe_4590"
      InheritFrom = "BaseNarrative"
      DisplayName = "So the Fates wove the image of some terrible monstrosity climbing Olympus and the gods all desperately trying to fight back, and you thought it meant what?"
      Speaker = "Melinoe"
      Event = "MorosAboutTyphon02"
    }
    {
      Id = "Moros_0376"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well it wasn't that, exactly, though I didn't take it quite as literally as I should have in hindsight. I thought it prophesized that the Olympians would have to stand against some sort of existential threat..."
      Speaker = "Moros"
      Event = "MorosAboutTyphon02"
    }
    {
      Id = "Melinoe_4591"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well you weren't wrong!"
      Speaker = "Melinoe"
      Event = "MorosAboutTyphon02"
    }
    {
      Id = "Melinoe_4594"
      InheritFrom = "BaseNarrative"
      DisplayName = "The prophecy of Typhon's return... was your interpretation that the gods were going to prevail or not? Or was there any detail you recall that we might use to our advantage?"
      Speaker = "Melinoe"
      Event = "MorosAboutTyphon03"
    }
    {
      Id = "Moros_0379"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well there was lightning, which I took to represent Zeus; the earth seemed to shake, recalling Poseidon; and a red spear reminiscent of your father's, piercing the storm. But even these specifics don't seem to pertain to the matter at hand."
      Speaker = "Moros"
      Event = "MorosAboutTyphon03"
    }
    {
      Id = "Melinoe_4595"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No, I suppose not..."
      Speaker = "Melinoe"
      Event = "MorosAboutTyphon03"
    }
    {
      Id = "Melinoe_4596"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A red spear, huh...?"
      Speaker = "Melinoe"
      Event = "MorosAboutTyphon03"
    }
    {
      Id = "Melinoe_4592"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wonder, did the weavings of the Fates foretell that I would knock the Father of All Monsters down the mountain last night? He didn't see it coming at least."
      Speaker = "Melinoe"
      Event = "MorosAboutTyphonW01"
    }
    {
      Id = "Moros_0377"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, not as such. The weavings of the Fates tend not to be precise in their detail, which I know can make them a bit confounding. But I salute your victory, Princess! I'd like to think that I foretold it, even if the Fates did not."
      Speaker = "Moros"
      Event = "MorosAboutTyphonW01"
    }
    {
      Id = "Melinoe_4593"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You knew I'd vanquish Typhon?"
      Speaker = "Melinoe"
      Event = "MorosAboutTyphonW01"
    }
    {
      Id = "Moros_0378"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I had a feeling."
      Speaker = "Moros"
      Event = "MorosAboutTyphonW01"
    }
    {
      Id = "Moros_0472"
      InheritFrom = "BaseNarrative"
      DisplayName = "Are your attempts to scale the mountain of the gods less difficult at least, now than before? The war with Chronos having ended surely must bring some relief."
      Speaker = "Moros"
      Event = "MorosAboutPostEndingTyphonW01"
    }
    {
      Id = "Melinoe_4810"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well on that front, not too much has changed as yet. Apparently it's important for the stalemate between the Titan's legions and Olympus to persist, for sake of our clean-up efforts."
      Speaker = "Melinoe"
      Event = "MorosAboutPostEndingTyphonW01"
    }
    {
      Id = "Moros_0473"
      InheritFrom = "BaseNarrative"
      DisplayName = "So then your fight continues as before, except without a burning vengeance for your family to compel you. What is the motivating factor now?"
      Speaker = "Moros"
      Event = "MorosAboutPostEndingTyphonW01"
    }
    {
      Id = "Melinoe_4811"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, where to start... I have some matters that I wish to see resolved. And, just to see what happens, I suppose!"
      Speaker = "Melinoe"
      Event = "MorosAboutPostEndingTyphonW01"
    }
    {
      Id = "Moros_0474"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I, too, increasingly have the desire to see that."
      Speaker = "Moros"
      Event = "MorosAboutPostEndingTyphonW01"
    }
    {
      Id = "Moros_0446"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's true, isn't it? You scoured Typhon from this world. The prophecy I saw must have... not merely been about his reawakening, but his {#Emph}eradication. {#Prev}How did you manage this, if I may ask?"
      Speaker = "Moros"
      Event = "MorosAboutTyphonDeath01"
    }
    {
      Id = "Melinoe_4786"
      InheritFrom = "BaseNarrative"
      DisplayName = "A complicated incantation from Headmistress, alongside the essence of Gigaros, my father's spear he took up after Chronos first was overthrown. It all worked out."
      Speaker = "Melinoe"
      Event = "MorosAboutTyphonDeath01"
    }
    {
      Id = "Moros_0447"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your father's spear... in what I saw, a spear could be seen piercing through the storm. Then that must have been {#Emph}you. {#Prev}And so, the Fates truly {#Emph}did {#Prev}anticipate that you'd prevail."
      Speaker = "Moros"
      Event = "MorosAboutTyphonDeath01"
    }
    {
      Id = "Melinoe_4787"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Do they anticipate I shall slay Chronos next?"
      Speaker = "Melinoe"
      Event = "MorosAboutTyphonDeath01"
    }
    {
      Id = "Moros_0448"
      InheritFrom = "BaseSubtitle"
      DisplayName = "If I but knew..."
      Speaker = "Moros"
      Event = "MorosAboutTyphonDeath01"
    }
    {
      Id = "Moros_0369"
      InheritFrom = "BaseNarrative"
      DisplayName = "Something unusual occurred, Princess. The Fated List scrolled to a point that caught my eye. What it said made little sense to me though I'm implored to tell you: {#Emph}I see your spirits glimmer as the metals underneath the Earth."
      Speaker = "Moros"
      Event = "MorosGrantsHiddenAspect01"
    }
    {
      Id = "Melinoe_4370"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}I see your spirits glimmer as the metals underneath the Earth. {#Prev}That sounds much like a waking-phrase! Headmistress told me of them when she lent me the Nocturnal Arms. When you think on it, what do you see...?"
      Speaker = "Melinoe"
      Event = "MorosGrantsHiddenAspect01"
    }
    {
      Id = "Moros_0370"
      InheritFrom = "BaseNarrative"
      DisplayName = "A daemon of some sort. A mask-like face, in shadow, some nocturnal realm, not necessarily our own. Who is this?"
      Speaker = "Moros"
      Event = "MorosGrantsHiddenAspect01"
    }
    {
      Id = "Melinoe_4371"
      InheritFrom = "BaseNarrative"
      DisplayName = "We'll soon find out I think. Likely a bearer of the Arms of Night, but whether past or future, I can't say."
      Speaker = "Melinoe"
      Event = "MorosGrantsHiddenAspect01"
    }
    {
      Id = "Moros_0371"
      InheritFrom = "BaseNarrative"
      DisplayName = "I may have just fulfilled part of a prophecy in relaying those words. I trust they'll be of benefit, not harm?"
      Speaker = "Moros"
      Event = "MorosGrantsHiddenAspect01"
    }
    {
      Id = "Melinoe_4372"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I think so. {#Emph}I see your spirits glimmer as the metals underneath the Earth..."
      Speaker = "Melinoe"
      Event = "MorosGrantsHiddenAspect01"
    }
    {
      Id = "Melinoe_4586"
      InheritFrom = "BaseNarrative"
      DisplayName = "The phrase you told me ended up revealing a new Aspect of the Umbral Flames, of a dark god known as Supay. Is that name at all familiar to you?"
      Speaker = "Melinoe"
      Event = "MorosAboutHiddenAspect01"
    }
    {
      Id = "Moros_0372_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not until now. The Fates presumably chose each and every bearer of the Arms of Night. Those bearers may not be bound by blood, but are connected still. And it seems I was to be your link to this Supay..."
      Speaker = "Moros"
      Event = "MorosAboutHiddenAspect01"
    }
    {
      Id = "Melinoe_4587"
      InheritFrom = "BaseNarrative"
      DisplayName = "How can it be that there are Underworld gods that neither of us know? Most of them must be your mother's side."
      Speaker = "Melinoe"
      Event = "MorosAboutHiddenAspect01"
    }
    {
      Id = "Moros_0373"
      InheritFrom = "BaseNarrative"
      DisplayName = "I couldn't say. Perhaps there shall be other Underworlds besides our own. Or there already are."
      Speaker = "Moros"
      Event = "MorosAboutHiddenAspect01"
    }
    {
      Id = "Melinoe_4588"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's quite far-fetched."
      Speaker = "Melinoe"
      Event = "MorosAboutHiddenAspect01"
    }
    {
      Id = "Moros_0374"
      InheritFrom = "BaseSubtitle"
      DisplayName = "True."
      Speaker = "Moros"
      Event = "MorosAboutHiddenAspect01"
    }
    {
      Id = "Moros_0503"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have something for you, Princess. Where I reside, such Darkness was quite commonplace, but perhaps not anymore. Here, in case you need it."
      Speaker = "Moros"
      Event = "MorosGrantsMixer6Common"
    }
    {
      Id = "Melinoe_4635"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, thank you, Lord Moros! Here in the Crossroads we get {#Emph}just {#Prev}enough moonlight that Darkness such as this is almost never seen. {#Emph}Wait... {#Prev}did you fulfill a prophecy just now?"
      Speaker = "Melinoe"
      Event = "MorosGrantsMixer6Common"
    }
    {
      Id = "Moros_0504"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I would have given it to you even if not."
      Speaker = "Moros"
      Event = "MorosGrantsMixer6Common"
    }
    {
      Id = "Moros_0449"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've not seen the Witch of the Crossroads recently, Princess. Do you know where she may be?"
      Speaker = "Moros"
      Event = "MorosAboutHecateKidnapped01"
    }
    {
      Id = "Melinoe_4788"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I have an idea, yes. I have to go."
      Speaker = "Melinoe"
      Event = "MorosAboutHecateKidnapped01"
    }
    {
      Id = "Moros_0451"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your task is finally complete...! Perhaps the Fates knew you'd succeed, but I couldn't always be certain. Although I held to what could be considered hope."
      Speaker = "Moros"
      Event = "MorosPostTrueEnding01"
    }
    {
      Id = "Melinoe_4789"
      InheritFrom = "BaseNarrative"
      DisplayName = "And your support made it possible, Lord Moros. For one thing, if you hadn't intervened when I was trying to reach the surface, Typhon might have reduced Olympus to ruin."
      Speaker = "Melinoe"
      Event = "MorosPostTrueEnding01"
    }
    {
      Id = "Moros_0452"
      InheritFrom = "BaseNarrative"
      DisplayName = "Doom averted...! We children of Nyx have already heard that Mother is no longer bound in Tartarus; you have our deepest gratitude, certainly mine. Well then... what happens now?"
      Speaker = "Moros"
      Event = "MorosPostTrueEnding01"
    }
    {
      Id = "Melinoe_4790"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I suppose I ought to go make certain everything's in order. My father started renovations to the Underworld, and I've volunteered to help clean up. The surface needs it too."
      Speaker = "Melinoe"
      Event = "MorosPostTrueEnding01"
    }
    {
      Id = "Moros_0453"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Then it sounds like I may see you again soon?"
      Speaker = "Moros"
      Event = "MorosPostTrueEnding01"
    }
    {
      Id = "Melinoe_4791"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Absolutely."
      Speaker = "Melinoe"
      Event = "MorosPostTrueEnding01"
    }
    {
      Id = "Moros_0454"
      InheritFrom = "BaseNarrative"
      DisplayName = "How fares your effort to cleanse all of the disorder Chronos wrought? I trust this new task doesn't fall solely to you."
      Speaker = "Moros"
      Event = "MorosPostTrueEnding02"
    }
    {
      Id = "Melinoe_4792"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, everybody's pitching in, even Chronos... my grandfather. You heard what happened to him, right? His new self seems more tolerable than before."
      Speaker = "Melinoe"
      Event = "MorosPostTrueEnding02"
    }
    {
      Id = "Moros_0455"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Death to Chronos... {#Prev}to his old self. I don't know how you managed it, Princess. Perhaps not even my sisters could know such a thing, wherever they may be."
      Speaker = "Moros"
      Event = "MorosPostTrueEnding02"
    }
    {
      Id = "Melinoe_4793"
      InheritFrom = "BaseNarrative"
      DisplayName = "We ought to find where they've been exiled, and I don't think Chronos can simply tell us. What about you, perhaps enough has changed that you can locate them somehow?"
      Speaker = "Melinoe"
      Event = "MorosPostTrueEnding02"
    }
    {
      Id = "Moros_0456"
      InheritFrom = "BaseNarrative"
      DisplayName = "I often search the void where you and I first met, since the Fates would sometimes go there, too. But it's a vast place..."
      Speaker = "Moros"
      Event = "MorosPostTrueEnding02"
    }
    {
      Id = "Melinoe_4794"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We'll keep searching."
      Speaker = "Melinoe"
      Event = "MorosPostTrueEnding02"
    }
    {
      Id = "Moros_0457"
      InheritFrom = "BaseNarrative"
      DisplayName = "While you were out, the Fated List... it started shaking, and scrolled over to a prophecy I'd never seen, and already fulfilled. I think there may be more to it, but..."
      Speaker = "Moros"
      Event = "MorosAboutEpilogueProgress01"
    }
    {
      Id = "Melinoe_4796"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're not supposed to tell me any more than that, I know. I think I have an idea of what that prophecy concerned, as the Fated List revealed some more to me as well."
      Speaker = "Melinoe"
      Event = "MorosAboutEpilogueProgress01"
    }
    {
      Id = "Moros_0458"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm attempting to understand what could have prompted such a change. You'll follow where the List is leading, yes?"
      Speaker = "Moros"
      Event = "MorosAboutEpilogueProgress01"
    }
    {
      Id = "Melinoe_4797"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You have my word."
      Speaker = "Melinoe"
      Event = "MorosAboutEpilogueProgress01"
    }
    {
      Id = "Moros_0460"
      InheritFrom = "BaseNarrative"
      DisplayName = "My sisters... they're all right! I was about to say {#Emph}thank the Fates{#Prev}, but in this case, Princess? I can only say {#Emph}thank you. {#Prev}While you'd best not tell me how you did it, please do tell how it was to meet them finally..."
      Speaker = "Moros"
      Event = "MorosPostEpilogue01"
    }
    {
      Id = "Melinoe_4798"
      InheritFrom = "BaseNarrative"
      DisplayName = "It was an interesting conversation! And they seem to be doing well, that much I can say. And you're probably aware of the new major prophecy that they foretold."
      Speaker = "Melinoe"
      Event = "MorosPostEpilogue01"
    }
    {
      Id = "Moros_0461"
      InheritFrom = "BaseNarrative"
      DisplayName = "The advent of another age! They notified me, yes. Perhaps it's their way of preventing any further attempts to circumvent their will. Assuming this age {#Emph}does {#Prev}arrive."
      Speaker = "Moros"
      Event = "MorosPostEpilogue01"
    }
    {
      Id = "Melinoe_4799"
      InheritFrom = "BaseNarrative"
      DisplayName = "What does this mean for you, though, Moros? I got the sense your sisters have no immediate plans to resume their customary weavings."
      Speaker = "Melinoe"
      Event = "MorosPostEpilogue01"
    }
    {
      Id = "Moros_0462"
      InheritFrom = "BaseNarrative"
      DisplayName = "I think it means that mortals shall be having a reprieve from me, potentially for quite some time. And that I'll have to find something to do..."
      Speaker = "Moros"
      Event = "MorosPostEpilogue01"
    }
    {
      Id = "Melinoe_4800"
      InheritFrom = "BaseNarrative"
      DisplayName = "You could remain here with us. Help tend the Crossroads. Learn our craft."
      Speaker = "Melinoe"
      Event = "MorosPostEpilogue01"
    }
    {
      Id = "Moros_0463"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...I'd like that very much."
      Speaker = "Moros"
      Event = "MorosPostEpilogue01"
    }
    {
      Id = "Melinoe_4801"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Same."
      Speaker = "Melinoe"
      Event = "MorosPostEpilogue01"
    }
    {
      Id = "Melinoe_4802"
      InheritFrom = "BaseNarrative"
      DisplayName = "This advent of another age your sisters have described... do you think it's possible Prometheus anticipated it? When I think back on things he said..."
      Speaker = "Melinoe"
      Event = "MorosPostEpilogue02"
    }
    {
      Id = "Moros_0464"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're asking if the Titan of Foresight knew the Fates would eventually make this choice, before even {#Emph}they {#Prev}knew it. {#Emph}Hm. {#Prev}Perhaps the lot of them conspired to achieve a shared goal..."
      Speaker = "Moros"
      Event = "MorosPostEpilogue02"
    }
    {
      Id = "Melinoe_4803"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Lord Moros! {#Prev}I'm surprised you would even suggest such things! To have conspired against the gods, {#Emph}and {#Prev}Chronos for that matter!"
      Speaker = "Melinoe"
      Event = "MorosPostEpilogue02"
    }
    {
      Id = "Moros_0465"
      InheritFrom = "BaseNarrative"
      DisplayName = "I merely seek alternatives to the suggestion that my sisters may not be the first to know. So then Prometheus prevailed on behalf of mortals after all. Or shall, when comes this age."
      Speaker = "Moros"
      Event = "MorosPostEpilogue02"
    }
    {
      Id = "Melinoe_4804"
      InheritFrom = "BaseSubtitle"
      DisplayName = "To think that far ahead..."
      Speaker = "Melinoe"
      Event = "MorosPostEpilogue02"
    }
    {
      Id = "Moros_0466"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sometimes I don't know what to do with myself anymore, Princess. I thought if you succeeded in your task that I'd return to my responsibilities. But now it seems I won't."
      Speaker = "Moros"
      Event = "MorosPostEpilogue03"
    }
    {
      Id = "Melinoe_4805"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm familiar with that feeling. I've been so fixated on my goal that I hadn't really thought about what's next... but here we are still, right? The task wasn't the end."
      Speaker = "Melinoe"
      Event = "MorosPostEpilogue03"
    }
    {
      Id = "Moros_0467"
      InheritFrom = "BaseNarrative"
      DisplayName = "So what {#Emph}are {#Prev}we supposed to do? I'm Doom Incarnate; I'll never be known for my fishing, for instance. I fear... perhaps my best work is behind me."
      Speaker = "Moros"
      Event = "MorosPostEpilogue03"
    }
    {
      Id = "Melinoe_4806"
      InheritFrom = "BaseNarrative"
      DisplayName = "I fear that too, though it's nonsense. We have the rest of our existence ahead of us. Mortals have but the blink of an eye."
      Speaker = "Melinoe"
      Event = "MorosPostEpilogue03"
    }
    {
      Id = "Moros_0468"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We have it easier than mortals, certainly."
      Speaker = "Moros"
      Event = "MorosPostEpilogue03"
    }
    {
      Id = "Melinoe_4807"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Poor things."
      Speaker = "Melinoe"
      Event = "MorosPostEpilogue03"
    }
    {
      Id = "Melinoe_4780"
      InheritFrom = "BaseNarrative"
      DisplayName = "How many of your other siblings do you know? Besides the ones I've met. I've heard of so many others... Momus, the Keres, Oizys... she sounds like a lot."
      Speaker = "Melinoe"
      Event = "MorosAboutRelatives01"
    }
    {
      Id = "Moros_0701"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've met most of them, I think, at one time or another. We very seldomly have family get-togethers, something Mother Nyx decided to {#Emph}try {#Prev}after Olympus and your father tried to make a similar tradition out of it. But that did not go well."
      Speaker = "Moros"
      Event = "MorosAboutRelatives01"
    }
    {
      Id = "Melinoe_4781"
      InheritFrom = "BaseNarrative"
      DisplayName = "How come? Wait, I know the answer to that. So, tell me this: Who was the worst behaved {#Emph}other {#Prev}than Strife?"
      Speaker = "Melinoe"
      Event = "MorosAboutRelatives01"
    }
    {
      Id = "Moros_0702"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well... you named several top contenders already."
      Speaker = "Moros"
      Event = "MorosAboutRelatives01"
    }
    {
      Id = "Melinoe_4782"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ooh..."
      Speaker = "Melinoe"
      Event = "MorosAboutRelatives01"
    }
    {
      Id = "Moros_0192"
      InheritFrom = "BaseNarrative"
      DisplayName = "To be direct with you, Master Odysseus, I am what you might call an admirer. At first, I found you {#Emph}extraordinarily {#Prev}frustrating, so adept were you at avoiding certain Doom. But gradually, perhaps grudgingly, I grew very impressed."
      Speaker = "Moros"
      Event = "MorosWithOdysseus01"
    }
    {
      Id = "Odysseus_0166"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, {#Emph}hah{#Prev}, I'm... flattered and relieved to hear it, very kind of you to let me know, particularly after... all this time..."
      Speaker = "Odysseus"
      Event = "MorosWithOdysseus01"
    }
    {
      Id = "Moros_0193"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's quite humorous, in fact. While you drew breath, I never once had opportunity to tell you!"
      Speaker = "Moros"
      Event = "MorosWithOdysseus01"
    }
    {
      Id = "Odysseus_0167"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Erm, {#Prev}quite humorous indeed, milord! I intended no offense by avoiding you, you know that, of course? A mortal impulse, whilst in mortal peril."
      Speaker = "Odysseus"
      Event = "MorosWithOdysseus01"
    }
    {
      Id = "Moros_0194"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, you were a wonder to behold! There were the Laestrygonian giants, Charybdis, and, lest we forget... the war of Ilium...!"
      Speaker = "Moros"
      Event = "MorosWithOdysseus01"
    }
    {
      Id = "Odysseus_0168"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I never do...!"
      Speaker = "Odysseus"
      Event = "MorosWithOdysseus01"
    }
    {
      Id = "Moros_0195"
      InheritFrom = "BaseNarrative"
      DisplayName = "...So then... were you ever certain you had finally met your Doom? Or did you truly think there was always a plan of escape to be discovered, no matter how dire the circumstance?"
      Speaker = "Moros"
      Event = "MorosWithOdysseus02"
    }
    {
      Id = "Odysseus_0169"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, to be quite frank with you, Moros — may we be informal thus? I had the hardest time untangling myself not from near-fatal situations, but the arms of certain goddesses... my greatest weakness, looking back..."
      Speaker = "Odysseus"
      Event = "MorosWithOdysseus02"
    }
    {
      Id = "Moros_0196_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, indeed... but how was this a weakness? As I understand, your wife Penelope stood by your side... I trust I do not overstep; I know this can be a sensitive topic with those from the surface."
      Speaker = "Moros"
      Event = "MorosWithOdysseus02"
    }
    {
      Id = "Odysseus_0701"
      InheritFrom = "BaseNarrative"
      DisplayName = "Aye, Penelope stood by my side, having spent her best years awaiting a man who was not always in a hurry to return. After we each lived out our days, we reunited in the Underworld, but... we needed a break."
      Speaker = "Odysseus"
      Event = "MorosWithOdysseus02"
    }
    {
      Id = "Moros_0197"
      InheritFrom = "BaseNarrative"
      DisplayName = "I see. After everything you'd been through, did your relationship end in an amicable way, at least?"
      Speaker = "Moros"
      Event = "MorosWithOdysseus02"
    }
    {
      Id = "Odysseus_0702"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It didn't end so much as {#Emph}changed{#Prev}, but... aye."
      Speaker = "Odysseus"
      Event = "MorosWithOdysseus02"
    }
    {
      Id = "Moros_0329"
      InheritFrom = "BaseNarrative"
      DisplayName = "...The wooden horse was an exquisite trick. Your own inevitable Doom, misdirected toward your unsuspecting foes! A masterstroke. But my personal favorite had to be the Polyphemus incident..."
      Speaker = "Moros"
      Event = "MorosWithOdysseus03"
    }
    {
      Id = "Odysseus_0226"
      InheritFrom = "BaseNarrative"
      DisplayName = "You speak of it like an old action yarn. Big bastard massacred my crew. My heart threatened to burst from my chest getting past him, and {#Emph}now {#Prev}he's up to his old antics with the Goddess there."
      Speaker = "Odysseus"
      Event = "MorosWithOdysseus03"
    }
    {
      Id = "Moros_0330"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, but I have no doubt that with your guidance, the Princess shall outsmart the Cyclops {#Emph}again {#Prev}and {#Emph}again. {#Prev}As recompense for the trouble that he caused you!"
      Speaker = "Moros"
      Event = "MorosWithOdysseus03"
    }
    {
      Id = "Odysseus_0227"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hear that, Goddess?"
      Speaker = "Odysseus"
      Event = "MorosWithOdysseus03"
    }
    {
      Id = "Moros_0188"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Nevertheless, I feel as though I ought have been there, Brother. Perhaps I could have protected them as was my charge. To think the Fates themselves may have denied me the attempt. It's discomforting that I may never know."
      Speaker = "Moros"
      Event = "MorosWithCharon01"
    }
    {
      Id = "Charon_0083"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Keeehhhh, hraaauuggghhh...!"
      Speaker = "Charon"
      Event = "MorosWithCharon01"
    }
    {
      Id = "Moros_0189"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have every reason to be angry. I'm angry, too. Nonetheless, I'm grateful that our paths have intertwined again. Be safe, Charon."
      Speaker = "Moros"
      Event = "MorosWithCharon01"
    }
    {
      Id = "Moros_0190"
      InheritFrom = "BaseNarrative"
      DisplayName = "Charon... you, Nemesis, even Hypnos. Who else, Eris? It seems I was one of the last to know of these Crossroads among the children of Nyx. Perhaps I ought have stayed in better contact."
      Speaker = "Moros"
      Event = "MorosWithCharon02"
    }
    {
      Id = "Charon_0084"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Mrrnngggghhh, hnnnn..."
      Speaker = "Charon"
      Event = "MorosWithCharon02"
    }
    {
      Id = "Melinoe_2096"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come, Lord Charon, your brother is our guest. And even if you did all drift apart, you're here together now. Moving forward."
      Speaker = "Melinoe"
      Event = "MorosWithCharon02"
    }
    {
      Id = "Moros_0191"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Wait, how did you...? No matter."
      Speaker = "Moros"
      Event = "MorosWithCharon02"
    }
    {
      Id = "Hypnos_0006_C"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Zzzzz, zzzz{#Prev}..."
      Speaker = "Hypnos"
      Event = "MorosWithHypnos01"
    }
    {
      Id = "Moros_0067"
      InheritFrom = "BaseNarrative"
      DisplayName = "How strange to be encountering this brother of mine here. So then he truly hasn't stirred at all?"
      Speaker = "Moros"
      Event = "MorosWithHypnos01"
    }
    {
      Id = "Melinoe_0907"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not once. Headmistress Hecate says Hypnos was already fast asleep when she recovered him from my father's House. You never visited him there before?"
      Speaker = "Melinoe"
      Event = "MorosWithHypnos01"
    }
    {
      Id = "Moros_0068"
      InheritFrom = "BaseNarrative"
      DisplayName = "It wasn't my place. We each come from big families, don't we? Odd families. You know how it is."
      Speaker = "Moros"
      Event = "MorosWithHypnos01"
    }
    {
      Id = "Melinoe_0908"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm beginning to, yes."
      Speaker = "Melinoe"
      Event = "MorosWithHypnos01"
    }
    {
      Id = "Moros_0327"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come to your senses, Eris. You're not doing yourself any favors by impeding the will of the Fates. Have you heard of even a single incident where that turned out for the best?"
      Speaker = "Moros"
      Event = "MorosWithEris01"
    }
    {
      Id = "Eris_0174"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}No! {#Prev}But there's a first time for everything, and I'm not interested in hearing veiled threats from them through {#Emph}you. {#Prev}If they care so much about what I'm up to, why don't they contact me {#Emph}themselves?"
      Speaker = "Eris"
      Event = "MorosWithEris01"
    }
    {
      Id = "Moros_0328"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know that isn't how it works. Have you truly made up your mind, to side against... well, {#Emph}everyone? Eugh{#Prev}, even {#Emph}I'm {#Prev}not supposed to be speaking to you..."
      Speaker = "Moros"
      Event = "MorosWithEris01"
    }
    {
      Id = "Eris_0175"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I do what I want, {#Emph}Moros."
      Speaker = "Eris"
      Event = "MorosWithEris01"
    }
    {
      Id = "Eris_0114"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Come on{#Prev}, man! Gotta tell me why you're really {#Emph}here! {#Prev}The Three don't just send you out on long {#Emph}assignments {#Prev}like this! Wait... is it because of {#Emph}her?"
      Speaker = "Eris"
      Event = "MorosWithEris02"
    }
    {
      Id = "Moros_0324"
      InheritFrom = "BaseNarrative"
      DisplayName = "Please, Eris. The Princess ought to be addressed as such. And lest you forget, the details of my arrival are not for me to divulge. There must be something else we can discuss."
      Speaker = "Moros"
      Event = "MorosWithEris02"
    }
    {
      Id = "Eris_0115"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, I can think of {#Emph}lots {#Prev}of things. I want to know what's going on with you two. I see the way you look up at her as she trots by. Maybe the Three sent you here to {#Emph}set the two of you up...?"
      Speaker = "Eris"
      Event = "MorosWithEris02"
    }
    {
      Id = "Moros_0325"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're trying to embarrass me... it isn't going to work. And besides, we both know the Fates have better uses of their weaving-time than things like that."
      Speaker = "Moros"
      Event = "MorosWithEris02"
    }
    {
      Id = "Eris_0116"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do they {#Emph}really? {#Prev}Thought they were all about meddling with the smallest details of everybody's lives! {#Emph}But{#Prev}, you'd know better than me."
      Speaker = "Eris"
      Event = "MorosWithEris02"
    }
    {
      Id = "Moros_0326"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I know better than to be provoked like this..."
      Speaker = "Moros"
      Event = "MorosWithEris02"
    }
    {
      Id = "Eris_0163"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hm!"
      Speaker = "Eris"
      Event = "MorosWithEris02"
    }
    {
      Id = "Moros_0477"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Oh yes, I certainly remember you. Would it be any consolation knowing that the Fates had already decided that your wings would fail you, and you would fall?"
      Speaker = "Moros"
      Event = "MorosWithIcarus01"
    }
    {
      Id = "Icarus_0472"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Erm{#Prev}, not exactly, no. For one thing, that would make the Three Fates seem a little, well, you know... {#Emph}mean. {#Prev}I was just some kid, and an {#Emph}imprisoned {#Prev}kid! Why pick on {#Emph}me? {#Prev}And for another, are you saying that I had no real choice?"
      Speaker = "Icarus"
      Event = "MorosWithIcarus01"
    }
    {
      Id = "Moros_0478"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well first, my sisters have to be impartial, to keep a healthy distance from their work. Rarely is it ever personal. As for the choice you made... it was still yours, except... the outcome would have likely happened either way."
      Speaker = "Moros"
      Event = "MorosWithIcarus01"
    }
    {
      Id = "Icarus_0473"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're saying if I didn't fly up like a dolt and melt my wings, they would have simply broken or something later on, and I'd have plunged into the water anyway...?"
      Speaker = "Icarus"
      Event = "MorosWithIcarus01"
    }
    {
      Id = "Moros_0479"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not necessarily exactly that... but yes."
      Speaker = "Moros"
      Event = "MorosWithIcarus01"
    }
    {
      Id = "Icarus_0474"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well {#Emph}that's {#Prev}reassuring!"
      Speaker = "Icarus"
      Event = "MorosWithIcarus01"
    }
    {
      Id = "Moros_0482"
      InheritFrom = "BaseNarrative"
      DisplayName = "...As long as it is not an imposition, Lady Hecate. I know you have far greater responsibilities than looking after yet another child of Nyx. Especially when Nyx herself is back."
      Speaker = "Moros"
      Event = "MorosWithHecate01"
    }
    {
      Id = "Hecate_0879"
      InheritFrom = "BaseNarrative"
      DisplayName = "When Melinoë first summoned you I said that you could stay for now, and it continues to {#Emph}be {#Prev}now, does it not? You seem the sort to make yourself useful without getting underfoot. 'Tis all that I require."
      Speaker = "Hecate"
      Event = "MorosWithHecate01"
    }
    {
      Id = "Moros_0483"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then I shall do so to the best of my ability. Please notify me if you deem my performance unsatisfactory in any way."
      Speaker = "Moros"
      Event = "MorosWithHecate01"
    }
    {
      Id = "Hecate_0880"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Oh {#Prev}gods, you're just like her."
      Speaker = "Hecate"
      Event = "MorosWithHecate01"
    }
    {
      Id = "Moros_0484"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Like who...?"
      Speaker = "Moros"
      Event = "MorosWithHecate01"
    }
    {
      Id = "Moros_0004"
      InheritFrom = "BaseNarrative"
      DisplayName = "I thank the Fates you're safe with us, Princess."
      Speaker = "Moros"
      Event = "MorosChat01"
    }
    {
      Id = "Moros_0005"
      InheritFrom = "BaseNarrative"
      DisplayName = "You'll be pleased to know I've no additional bad news to share, for now."
      Speaker = "Moros"
      Event = "MorosChat02"
    }
    {
      Id = "Moros_0006"
      InheritFrom = "BaseNarrative"
      DisplayName = "May the Fates be favorable on your next attempt."
      Speaker = "Moros"
      Event = "MorosChat03"
    }
    {
      Id = "Moros_0007"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm beginning to acclimate to these Crossroads, I think!"
      Speaker = "Moros"
      Event = "MorosChat04"
    }
    {
      Id = "Moros_0008"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm managing, Princess, though this is very strange for me."
      Speaker = "Moros"
      Event = "MorosChat05"
    }
    {
      Id = "Moros_0009"
      InheritFrom = "BaseNarrative"
      DisplayName = "Who can say what the Fates have in store for any of us now..."
      Speaker = "Moros"
      Event = "MorosChat06"
    }
    {
      Id = "Moros_0010"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Fates entrusted you with so much, Princess..."
      Speaker = "Moros"
      Event = "MorosChat07"
    }
    {
      Id = "Moros_0011"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll do my best to make myself useful around here."
      Speaker = "Moros"
      Event = "MorosChat08"
    }
    {
      Id = "Moros_0012"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's a pleasure to see you again, as always, Princess."
      Speaker = "Moros"
      Event = "MorosChat09"
    }
    {
      Id = "Moros_0013"
      InheritFrom = "BaseNarrative"
      DisplayName = "I regret the setbacks you've encountered, though at least you're here."
      Speaker = "Moros"
      Event = "MorosChat10"
    }
    {
      Id = "Moros_0014"
      InheritFrom = "BaseNarrative"
      DisplayName = "Please don't hesitate to let me know if I can be of service in some way."
      Speaker = "Moros"
      Event = "MorosChat11"
    }
    {
      Id = "Moros_0015"
      InheritFrom = "BaseNarrative"
      DisplayName = "May you be well-prepared for whatever is to come."
      Speaker = "Moros"
      Event = "MorosChat12"
    }
    {
      Id = "Moros_0016"
      InheritFrom = "BaseNarrative"
      DisplayName = "Remember that the future is yet to be woven, Princess."
      Speaker = "Moros"
      Event = "MorosChat13"
    }
    {
      Id = "Moros_0017"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've so much left to learn about this way of life..."
      Speaker = "Moros"
      Event = "MorosChat14"
    }
    {
      Id = "Moros_0018"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do let me know if there's something I could do to ease your burden even for a bit."
      Speaker = "Moros"
      Event = "MorosChat15"
    }
    {
      Id = "Moros_0019"
      InheritFrom = "BaseNarrative"
      DisplayName = "I trust your task is growing ever closer to completion, Princess."
      Speaker = "Moros"
      Event = "MorosChat16"
    }
    {
      Id = "Moros_0020"
      InheritFrom = "BaseNarrative"
      DisplayName = "Some of the Shades here still don't seem particularly fond of me, I'm afraid..."
      Speaker = "Moros"
      Event = "MorosChat17"
    }
    {
      Id = "Moros_0021"
      InheritFrom = "BaseNarrative"
      DisplayName = "What would the Fates have me do next, I wonder..."
      Speaker = "Moros"
      Event = "MorosChat18"
    }
    {
      Id = "Moros_0022"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thank you for making me feel welcome here, Princess."
      Speaker = "Moros"
      Event = "MorosChat19"
    }
    {
      Id = "Moros_0023"
      InheritFrom = "BaseNarrative"
      DisplayName = "If the Fates have taught me anything, it's that our lives can take the strangest turns..."
      Speaker = "Moros"
      Event = "MorosChat20"
    }
    {
      Id = "Moros_0024"
      InheritFrom = "BaseNarrative"
      DisplayName = "Be well, Princess Melinoë, and may my sisters always favor you."
      Speaker = "Moros"
      Event = "MorosChat21"
    }
    {
      Id = "Moros_0025"
      InheritFrom = "BaseNarrative"
      DisplayName = "Always a pleasure, Princess. Though, please... don't let me keep you."
      Speaker = "Moros"
      Event = "MorosChat22"
    }
    {
      Id = "Moros_0026"
      InheritFrom = "BaseNarrative"
      DisplayName = "Take heart knowing the Fates themselves believe that you'll succeed."
      Speaker = "Moros"
      Event = "MorosChat23"
    }
    {
      Id = "Moros_0027"
      InheritFrom = "BaseNarrative"
      DisplayName = "Go bring those foes of ours some more bad news for me."
      Speaker = "Moros"
      Event = "MorosChat24"
    }
    {
      Id = "Moros_0028"
      InheritFrom = "BaseNarrative"
      DisplayName = "Princess Melinoë. May doom befall your foes."
      Speaker = "Moros"
      Event = "MorosChat25"
    }
    {
      Id = "Moros_0029"
      InheritFrom = "BaseNarrative"
      DisplayName = "I seldom get to say {#Emph}we meet again{#Prev}, yet here we are, Princess."
      Speaker = "Moros"
      Event = "MorosChat26"
    }
    {
      Id = "Moros_0030"
      InheritFrom = "BaseNarrative"
      DisplayName = "To think that we were fated to meet under such circumstances..."
      Speaker = "Moros"
      Event = "MorosChat27"
    }
    {
      Id = "Moros_0031"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm certain you've more urgent matters to attend to than keeping company with me."
      Speaker = "Moros"
      Event = "MorosChat28"
    }
    {
      Id = "Moros_0032"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Forgive me, Princess. I... I need some time to think."
      Speaker = "Moros"
      Event = "MorosChat29"
    }
    {
      Id = "Moros_0033"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've no additional bad news for now, I'm pleased to say, Princess."
      Speaker = "Moros"
      Event = "MorosChat30"
    }
    {
      Id = "Melinoe_0909"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lord Moros, as our honored guest, {#Emph}erm{#Prev}, we wanted you to have this. To make your stay a bit more comfortable."
      Speaker = "Melinoe"
      Event = "MorosGift01"
    }
    {
      Id = "Moros_0069"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Nectar of the gods! Thank you, Princess. I've... not received an offering before. Though I do like to come prepared. So here! From me to you."
      Speaker = "Moros"
      Event = "MorosGift01"
    }
    {
      Id = "Moros_0070"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Huh! {#Prev}I must admit I'm unaccustomed to displays of flattery. Forgive me, I don't quite know what to say, except... thank you."
      Speaker = "Moros"
      Event = "MorosGift02"
    }
    {
      Id = "Melinoe_0910"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're very welcome! Though, I'd not intended it as {#Emph}flattery{#Prev}, it's just.... Don't even mention it, all right?"
      Speaker = "Melinoe"
      Event = "MorosGift02"
    }
    {
      Id = "Moros_0071"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're very kind to me, Princess. I arrived at these Crossroads in a desperate state. I didn't expect to be made welcome here."
      Speaker = "Moros"
      Event = "MorosGift03"
    }
    {
      Id = "Melinoe_0911"
      InheritFrom = "BaseNarrative"
      DisplayName = "And I didn't expect to meet Doom face-to-face, much less for him to be rather agreeable. Yet here we are!"
      Speaker = "Melinoe"
      Event = "MorosGift03"
    }
    {
      Id = "Moros_0072"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why, thank you for this, truly, though you needn't go out of your way for me. You've been so generous. Forgive my asking, but... this isn't due to some sort of prophecy in the Fated List, is it?"
      Speaker = "Moros"
      Event = "MorosGift04"
    }
    {
      Id = "Melinoe_0912"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}No! {#Prev}No, of course not, Lord Moros! Although, even if it was, I would be duty-bound not to inform you, wouldn't I?"
      Speaker = "Melinoe"
      Event = "MorosGift04"
    }
    {
      Id = "Moros_0073"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Heh! {#Prev}That's true."
      Speaker = "Moros"
      Event = "MorosGift04"
    }
    {
      Id = "Moros_0074"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm honored to accept this, Princess Melinoë. When the Fates first indicated that we'd meet, I asked them what I should expect; what you were like. Clotho smiled and simply said, {#Emph}you'll see. {#Prev}I felt certain they were playing a prank!"
      Speaker = "Moros"
      Event = "MorosGift05"
    }
    {
      Id = "Melinoe_0913"
      InheritFrom = "BaseNarrative"
      DisplayName = "You make me glad I don't have any sisters, Lord Moros. So what would you have said in Clotho's place?"
      Speaker = "Melinoe"
      Event = "MorosGift05"
    }
    {
      Id = "Moros_0075"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh! Perhaps I would have said... she's a great witch and enchantress. The Princess of the Underworld, daughter to the goddess of spring and the lord of the dead. Though whatever you imagine her to be... she's more."
      Speaker = "Moros"
      Event = "MorosGift05"
    }
    {
      Id = "Melinoe_0914"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...That's not bad."
      Speaker = "Melinoe"
      Event = "MorosGift05"
    }
    {
      Id = "Moros_0387"
      InheritFrom = "BaseNarrative"
      DisplayName = "This Nectar of the gods, it's... such a luxury. With my sisters, I led a relatively simple life. Now to find myself in such a place, much less with you... no prophecy could have prepared me."
      Speaker = "Moros"
      Event = "MorosGift06"
    }
    {
      Id = "Melinoe_4601"
      InheritFrom = "BaseNarrative"
      DisplayName = "You seem to truly like it here. I think we have our needs fulfilled, though I've not often heard anything in the Crossroads described as luxurious. Are things so different where you're from?"
      Speaker = "Melinoe"
      Event = "MorosGift06"
    }
    {
      Id = "Moros_0388"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, it was an excellent place to be a weaver. But there was not a lot of other recreational activity, or other company. I fear I may become quite self-indulgent with all this..."
      Speaker = "Moros"
      Event = "MorosGift06"
    }
    {
      Id = "Melinoe_4602"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I don't think you're at any risk of that just yet."
      Speaker = "Melinoe"
      Event = "MorosGift06"
    }
    {
      Id = "Melinoe_4603"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wanted you to have this, Lord Moros, since you seemed to enjoy it last time. Ambrosia may flow freely on Olympus, but we chthonic gods should get our share as well, wouldn't you say?"
      Speaker = "Melinoe"
      Event = "MorosGift07"
    }
    {
      Id = "Moros_0389"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh! {#Prev}I think that's a better question for Nemesis. It's not for me to say whether we {#Emph}deserve {#Prev}such things. And the Fates did not advise me as to whether I should accept such gifts. Nor did I ever think to ask..."
      Speaker = "Moros"
      Event = "MorosGift07"
    }
    {
      Id = "Melinoe_4604"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can't believe I'm saying this, though there's no need to overthink it so much. Since the Fates aren't here to tell you, you could always listen to your heart in such a situation...?"
      Speaker = "Melinoe"
      Event = "MorosGift07"
    }
    {
      Id = "Moros_0390"
      InheritFrom = "BaseNarrative"
      DisplayName = "My heart... it isn't saying anything, Princess. But it is... beating faster than I'm accustomed, even though I'm at rest, and comfortable, mostly. {#Emph}Very {#Prev}comfortable! {#Emph}Ah{#Prev}, I don't wish to be so rude, so thank you very much."
      Speaker = "Moros"
      Event = "MorosGift07"
    }
    {
      Id = "Melinoe_4605"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're very welcome."
      Speaker = "Melinoe"
      Event = "MorosGift07"
    }
    {
      Id = "Melinoe_4606"
      InheritFrom = "BaseNarrative"
      DisplayName = "If I've learned anything it's that with practice comes perfection, or as close as we can ever get. So, what do you say we practice listening to our hearts a little more? Here, this is for you."
      Speaker = "Melinoe"
      Event = "MorosGift08"
    }
    {
      Id = "Moros_0391"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm... I'm attempting to listen to my heart right now, Princess. But if truly it can speak, I'm afraid it's speaking a bit rapidly, such that I can't entirely understand or know what to do... as though I'm in one of your binding spells."
      Speaker = "Moros"
      Event = "MorosGift08"
    }
    {
      Id = "Melinoe_4607"
      InheritFrom = "BaseNarrative"
      DisplayName = "How about I go first, and next I offer you Ambrosia, you can be prepared. For now, my heart says... I feel comfortable around you. Even though you make me feel like royalty, which come to think of it, I do not mind at all."
      Speaker = "Melinoe"
      Event = "MorosGift08"
    }
    {
      Id = "Moros_0392"
      InheritFrom = "BaseNarrative"
      DisplayName = "I... thank you very much for that, Princess. I'm pleased that you approve of me this way. And, next time, as you say, I'll... be better prepared to express my sentiment, in turn."
      Speaker = "Moros"
      Event = "MorosGift08"
    }
    {
      Id = "Melinoe_4759"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Looking forward to it."
      Speaker = "Melinoe"
      Event = "MorosGift08"
    }
    {
      Id = "Melinoe_4608"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, Lord Moros, ready to let your heart do the talking this time? Because here's something that I wanted you to have. Your calm and considerate presence in these Crossroads has meant a lot to me, so thank you."
      Speaker = "Melinoe"
      Event = "MorosGift09"
    }
    {
      Id = "Moros_0393"
      InheritFrom = "BaseNarrative"
      DisplayName = "I should be thanking you instead, Princess. Not merely for this gift, which is beautiful... but also because you've given me something else to strive for, besides the Fate-appointed calling that I've known."
      Speaker = "Moros"
      Event = "MorosGift09"
    }
    {
      Id = "Melinoe_4609"
      InheritFrom = "BaseNarrative"
      DisplayName = "Something to strive for? You mean the Nectar and Ambrosia? Good, isn't it? I should be able to get more!"
      Speaker = "Melinoe"
      Event = "MorosGift09"
    }
    {
      Id = "Moros_0394"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd welcome that, although it isn't what I meant, which is... knowing you could spend your time with anyone, I'll strive to make the time you spend with me worthwhile. As fulfilling for you as it is for me."
      Speaker = "Moros"
      Event = "MorosGift09"
    }
    {
      Id = "Melinoe_4610"
      InheritFrom = "BaseNarrative"
      DisplayName = "But I already find the time we share fulfilling. I wouldn't want you thinking otherwise, or changing how you are with me. I like the way I feel when I'm with you."
      Speaker = "Melinoe"
      Event = "MorosGift09"
    }
    {
      Id = "Moros_0395"
      InheritFrom = "BaseNarrative"
      DisplayName = "And you don't know how glad I am to hear it. Well, I've relayed what I believe my heart has said, after a closer listening. Perhaps I ought have kept its message to myself..."
      Speaker = "Moros"
      Event = "MorosGift09"
    }
    {
      Id = "Melinoe_4611"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No, of course not. I'm glad."
      Speaker = "Melinoe"
      Event = "MorosGift09"
    }
    {
      Id = "Melinoe_0915"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lord Moros? I wanted you to have this either way, though if you're not too busy at the moment, would you care to share it with me at the taverna? I know this is sudden, it's just... I'm past due for a little break..."
      Speaker = "Melinoe"
      Event = "MorosTaverna01"
    }
    {
      Id = "Moros_0076"
      InheritFrom = "BaseNarrative"
      DisplayName = "Princess Melinoë, it would be my pleasure. Would you please lead the way?"
      Speaker = "Moros"
      Event = "MorosTaverna01"
    }
    {
      Id = "Melinoe_0916"
      InheritFrom = "BaseNarrative"
      DisplayName = "...So, it {#Emph}can {#Prev}be a lot, of course. I don't know what's the better source of motivation, those completely certain I'll succeed in everything, or those completely certain that I'll fail."
      Speaker = "Melinoe"
      Event = "MorosTaverna01"
    }
    {
      Id = "Moros_0077"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hah! {#Prev}I have the same thought pattern frequently. The Fates, they could anticipate the outcomes of my efforts and would chastise me sometimes for small mistakes I'd yet to make. It wasn't always as encouraging as intended."
      Speaker = "Moros"
      Event = "MorosTaverna01"
    }
    {
      Id = "Melinoe_0917"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then, where did you find the strength? Your responsibilities sound like they must have been a lot."
      Speaker = "Melinoe"
      Event = "MorosTaverna01"
    }
    {
      Id = "Moros_0078"
      InheritFrom = "BaseNarrative"
      DisplayName = "It all simply became a force of habit at some point. You practice a skill to a level of proficiency, then fear letting it go... fear you'll never be as capable at other things..."
      Speaker = "Moros"
      Event = "MorosTaverna01"
    }
    {
      Id = "Melinoe_0918"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wouldn't have expected Doom himself to harbor such misgivings."
      Speaker = "Melinoe"
      Event = "MorosTaverna01"
    }
    {
      Id = "Moros_0079"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well! Perhaps I should have been born as {#Emph}Fear! {#Prev}So then where do {#Emph}you {#Prev}think it comes from? Your source of motivation for your task."
      Speaker = "Moros"
      Event = "MorosTaverna01"
    }
    {
      Id = "Melinoe_3353"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've decided it comes from the thought of finding more of this Ambrosia out there; this is {#Emph}good!"
      Speaker = "Melinoe"
      Event = "MorosTaverna01"
    }
    {
      Id = "Moros_0081"
      InheritFrom = "BaseNarrative"
      DisplayName = "I very much enjoyed your company, Princess, and thank you for the drink. I trust we'll have more opportunities like this?"
      Speaker = "Moros"
      Event = "MorosTaverna01"
    }
    {
      Id = "Melinoe_0920"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I trust so too."
      Speaker = "Melinoe"
      Event = "MorosTaverna01"
    }
    {
      Id = "Melinoe_4612"
      InheritFrom = "BaseNarrative"
      DisplayName = "Forgive me for presuming, though you seem a little tense of late, Lord Moros. What would you say if we shared one of these bottles together at the taverna? It's been a while."
      Speaker = "Melinoe"
      Event = "MorosTaverna02"
    }
    {
      Id = "Moros_0396"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nothing would please me more, Princess... except, it's not my wish to burden you, and I regret that I've permitted my concerns, which are slight, to become apparent. So please, don't go out of your way on my account."
      Speaker = "Moros"
      Event = "MorosTaverna02"
    }
    {
      Id = "Melinoe_4613"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm not going out of my way. And if it's truly your wish for the time we share to be fulfilling, then you can start by taking the opportunities that present themselves."
      Speaker = "Melinoe"
      Event = "MorosTaverna02"
    }
    {
      Id = "Moros_0397"
      InheritFrom = "BaseNarrative"
      DisplayName = "You make a strong case. It would be my honor to accompany you, then. Shall we head down?"
      Speaker = "Moros"
      Event = "MorosTaverna02"
    }
    {
      Id = "Moros_0398"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I have been drawn to others on occasion, yes. But, I knew better than to let myself become attached. If my heart started to speak to me, I always could make it quiet down."
      Speaker = "Moros"
      Event = "MorosTaverna02"
    }
    {
      Id = "Melinoe_4614"
      InheritFrom = "BaseNarrative"
      DisplayName = "In that, at least, we're quite alike... skilled at quieting our hearts. Though if the Lady Aphrodite's taught me anything, it's that our passions needn't always be suppressed."
      Speaker = "Melinoe"
      Event = "MorosTaverna02"
    }
    {
      Id = "Moros_0399"
      InheritFrom = "BaseNarrative"
      DisplayName = "What do you mean, Princess? What passions could you have possibly suppressed, given all that you've achieved?"
      Speaker = "Moros"
      Event = "MorosTaverna02"
    }
    {
      Id = "Melinoe_4615"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, for one thing, even being here with you... the past me never would have had the clarity of mind to ask, I think. My mind would have talked my heart out of it."
      Speaker = "Melinoe"
      Event = "MorosTaverna02"
    }
    {
      Id = "Moros_0400"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then I'm very grateful that your heart is beginning to prevail in more of these debates. I think it only makes you stronger, and... perhaps it's the Ambrosia, but... I'm very fond of that. Of you in your entirety, truly."
      Speaker = "Moros"
      Event = "MorosTaverna02"
    }
    {
      Id = "Melinoe_4616"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh...! While we're being candid, then... I've become rather fond of you as well... but, if you're promised to another, I don't wish to interfere."
      Speaker = "Melinoe"
      Event = "MorosTaverna02"
    }
    {
      Id = "Moros_0401"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't know this other goddess to whom I've been promised, nor do I want to. And I've violated the will of the Fates already; we both have. Wherever all this leads, I would have {#Emph}you {#Prev}by my side."
      Speaker = "Moros"
      Event = "MorosTaverna02"
    }
    {
      Id = "Moros_0403"
      InheritFrom = "BaseNarrative"
      DisplayName = "I very much enjoyed our time, Princess, and will anticipate when we can be together next. Soon, I trust."
      Speaker = "Moros"
      Event = "MorosTaverna02"
    }
    {
      Id = "Melinoe_4618"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I feel the same way."
      Speaker = "Melinoe"
      Event = "MorosTaverna02"
    }
    {
      Id = "Melinoe_3555"
      InheritFrom = "BaseNarrative"
      DisplayName = "I was thinking about a visit to the hot springs and thought you might be interested, my lord."
      Speaker = "Melinoe"
      Event = "MorosBathHouseDecline01"
    }
    {
      Id = "Moros_0344"
      InheritFrom = "BaseNarrative"
      DisplayName = "Respectfully, Princess, I've past events to document so I had better not. Some other time, perhaps?"
      Speaker = "Moros"
      Event = "MorosBathHouseDecline01"
    }
    {
      Id = "Melinoe_0921"
      InheritFrom = "BaseNarrative"
      DisplayName = "Have you experienced our hot springs yet, Lord Moros? The waters cleanse the body and the mind. I'm headed over if you'd care to join me?"
      Speaker = "Melinoe"
      Event = "MorosBathHouse01"
    }
    {
      Id = "Moros_0101"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why, I... I don't see why not! I've seen and heard about such springs as these, though never been."
      Speaker = "Moros"
      Event = "MorosBathHouse01"
    }
    {
      Id = "Moros_0105"
      InheritFrom = "BaseNarrative"
      DisplayName = "...To think that such a place is hidden here..."
      Speaker = "Moros"
      Event = "MorosBathHouse01"
    }
    {
      Id = "Melinoe_0923"
      InheritFrom = "BaseNarrative"
      DisplayName = "So, what did you and the Fates do for recreation where you're from, anyhow?"
      Speaker = "Melinoe"
      Event = "MorosBathHouse01"
    }
    {
      Id = "Moros_0111"
      InheritFrom = "BaseNarrative"
      DisplayName = "Have I mentioned that they liked to weave? Their weaving was their occupation and their {#Emph}passion. {#Prev}I never got too good at it myself, and all they needed was the three of them, so..."
      Speaker = "Moros"
      Event = "MorosBathHouse01"
    }
    {
      Id = "Melinoe_0924"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know an excellent spinstress who could maybe help with your technique. What did you do while they were busy spinning away?"
      Speaker = "Melinoe"
      Event = "MorosBathHouse01"
    }
    {
      Id = "Moros_0112"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, I would travel the world! To witness mortals in their final moments. Look them square in the face as they perished... often in horror..."
      Speaker = "Moros"
      Event = "MorosBathHouse01"
    }
    {
      Id = "Melinoe_0925"
      InheritFrom = "BaseNarrative"
      DisplayName = "...You do this for recreation's sake?"
      Speaker = "Melinoe"
      Event = "MorosBathHouse01"
    }
    {
      Id = "Moros_0113"
      InheritFrom = "BaseNarrative"
      DisplayName = "The nature of the role leaves little time for recreation. And it's all I could do to make those final moments dignified... though I don't think the gesture always comes across."
      Speaker = "Moros"
      Event = "MorosBathHouse01"
    }
    {
      Id = "Moros_0117"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've not felt so refreshed in... well, it's been a while now. Thank you again."
      Speaker = "Moros"
      Event = "MorosBathHouse01"
    }
    {
      Id = "Melinoe_0922"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lord Moros, would you accompany me to the springs again sometime? And by sometime I mean... are you busy now?"
      Speaker = "Melinoe"
      Event = "MorosBathHouse02"
    }
    {
      Id = "Moros_0102"
      InheritFrom = "BaseNarrative"
      DisplayName = "I feared you'd never ask again, Princess! I've longed for the warmth of the springs since last we visited."
      Speaker = "Moros"
      Event = "MorosBathHouse02"
    }
    {
      Id = "Moros_0104"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I surely can get used to this..."
      Speaker = "Moros"
      Event = "MorosBathHouse02"
    }
    {
      Id = "Melinoe_0927"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your relationship with the Fates sounds like it must have been a complicated one. You've never been on your own, have you?"
      Speaker = "Melinoe"
      Event = "MorosBathHouse02"
    }
    {
      Id = "Moros_0114"
      InheritFrom = "BaseNarrative"
      DisplayName = "I haven't. They're my sisters, and my elders. I grew up under their watchful eye, and I'm more than their brother; I was their guardian. But I couldn't protect them, in the end. Perhaps they always knew I'd fail them, and loved me anyway."
      Speaker = "Moros"
      Event = "MorosBathHouse02"
    }
    {
      Id = "Melinoe_0928"
      InheritFrom = "BaseNarrative"
      DisplayName = "You can't go thinking like that. You had one of the most important responsibilities in the world. The Fates are as all-knowing as they come, aren't they? Then it stands to reason there wasn't anybody better suited for the task than you."
      Speaker = "Melinoe"
      Event = "MorosBathHouse02"
    }
    {
      Id = "Moros_0115"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Princess? Would you just let me wallow in my misery a bit? {#Emph}Ah... {#Prev}no, wait. Forget it. It's gone. A mighty incantation on your part just now."
      Speaker = "Moros"
      Event = "MorosBathHouse02"
    }
    {
      Id = "Melinoe_0929"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Heh{#Prev}, anyway. I know you love your sisters, but... the circumstances being what they are, perhaps some distance will be good for you."
      Speaker = "Melinoe"
      Event = "MorosBathHouse02"
    }
    {
      Id = "Moros_0116"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps.... These springs are good for me, of that I have no doubt."
      Speaker = "Moros"
      Event = "MorosBathHouse02"
    }
    {
      Id = "Moros_0118"
      InheritFrom = "BaseNarrative"
      DisplayName = "I think I really needed that. And always wonderful to have your company."
      Speaker = "Moros"
      Event = "MorosBathHouse02"
    }
    {
      Id = "Melinoe_4814"
      InheritFrom = "BaseNarrative"
      DisplayName = "How about a visit to the springs again, Moros? I'm not in any hurry at the moment if you're not either."
      Speaker = "Melinoe"
      Event = "MorosBathHouse03"
    }
    {
      Id = "Moros_0682"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd like that very much. It's very peaceful there... almost like when we meet during the moment you return."
      Speaker = "Moros"
      Event = "MorosBathHouse03"
    }
    {
      Id = "Melinoe_4815"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I think it's possible the Fates arranged all this. Between the two of us. And I mean {#Emph}all {#Prev}of it. Has that occurred to you?"
      Speaker = "Melinoe"
      Event = "MorosBathHouse03"
    }
    {
      Id = "Moros_0684"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps a little, but it's something I refuse to believe. Why would the Fates have promised me to another if they wanted me to be with you? That makes very little sense."
      Speaker = "Moros"
      Event = "MorosBathHouse03"
    }
    {
      Id = "Melinoe_4816"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know, it's just... sometimes to get someone to do something, it's best to compel them to do some opposite thing they {#Emph}don't {#Prev}want to do. They'll do what you truly want in defiance. A simple bit of psychic manipulation."
      Speaker = "Melinoe"
      Event = "MorosBathHouse03"
    }
    {
      Id = "Moros_0685"
      InheritFrom = "BaseNarrative"
      DisplayName = "But I always was obedient. They had no reason to think I'd defy them... no, I just can't accept we were tricked into this somehow. We may not have met by chance, but still. My sisters had more important things to do."
      Speaker = "Moros"
      Event = "MorosBathHouse03"
    }
    {
      Id = "Melinoe_4817"
      InheritFrom = "BaseNarrative"
      DisplayName = "I suppose it doesn't really matter. But if they did determine you and I should meet, I'm grateful. They could have chosen someone far less suitable."
      Speaker = "Melinoe"
      Event = "MorosBathHouse03"
    }
    {
      Id = "Moros_0686"
      InheritFrom = "BaseNarrative"
      DisplayName = "They certainly have their way. And I have never felt more grateful to them, or to you."
      Speaker = "Moros"
      Event = "MorosBathHouse03"
    }
    {
      Id = "Moros_0687"
      InheritFrom = "BaseNarrative"
      DisplayName = "...{#Emph}Whew! {#Prev}I think I'm ready for whatever else the Fates may have in store. See you, Melinoë."
      Speaker = "Moros"
      Event = "MorosBathHouse03"
    }
    {
      Id = "Melinoe_4819"
      InheritFrom = "BaseSubtitle"
      DisplayName = "See you, Moros."
      Speaker = "Melinoe"
      Event = "MorosBathHouse03"
    }
    {
      Id = "Melinoe_3501"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't suppose you'd join me for a little while at the fishing pier, Lord Moros? Thought we could use these Twin Lures."
      Speaker = "Melinoe"
      Event = "MorosFishingDecline01"
    }
    {
      Id = "Moros_0119"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah! {#Prev}I fear the river denizens will not approach this evening if I'm there, for they can sense me every now and then. Apologies."
      Speaker = "Moros"
      Event = "MorosFishingDecline01"
    }
    {
      Id = "Melinoe_0937"
      InheritFrom = "BaseNarrative"
      DisplayName = "Say, Lord Moros, would you accompany me to the riverside? I've a feeling your mere presence may help with the evening's catch."
      Speaker = "Melinoe"
      Event = "MorosFishing01"
    }
    {
      Id = "Moros_0123"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have a way with mortal creatures of all sorts, so I'll accompany you, yes."
      Speaker = "Moros"
      Event = "MorosFishing01"
    }
    {
      Id = "Moros_0321"
      InheritFrom = "BaseNarrative"
      DisplayName = "Forgive me, though I never have quite understood the compulsion to extract water-creatures from their natural environs. I know for mortals it is sometimes necessary sustenance, though others do it for the sake of sport. Why?"
      Speaker = "Moros"
      Event = "MorosFishing01"
    }
    {
      Id = "Melinoe_3239"
      InheritFrom = "BaseNarrative"
      DisplayName = "For mortals, it seems to be an opportunity to assert themselves over the natural world. Though I would take no pride in outsmarting such creatures if I were them. In our case... we safeguard habitats for all the species that we find."
      Speaker = "Melinoe"
      Event = "MorosFishing01"
    }
    {
      Id = "Moros_0322"
      InheritFrom = "BaseNarrative"
      DisplayName = "That seems like a burdensome responsibility for creatures that ought to take better care of themselves."
      Speaker = "Moros"
      Event = "MorosFishing01"
    }
    {
      Id = "Melinoe_3240"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, there's more to it, I suppose. For one thing it sets a contemplative mood, right? Means we can talk a little about matters unrelated to our {#Emph}own {#Prev}burdensome responsibilities."
      Speaker = "Melinoe"
      Event = "MorosFishing01"
    }
    {
      Id = "Moros_0323"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can certainly appreciate that part. And now we wait..."
      Speaker = "Moros"
      Event = "MorosFishing01"
    }
    {
      Id = "Moros_0361"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps it's good to let the mind wander a bit to such pursuits, every once in a while."
      Speaker = "Moros"
      Event = "MorosFishing01"
    }
    {
      Id = "Melinoe_1150"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Lord Moros is away..."
      Speaker = "Melinoe"
      Event = "NPC_Moros_01.MissingDistanceTrigger.VoiceLines"
    }
    {
      Id = "Melinoe_1151"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Where's Lord Moros?"
      Speaker = "Melinoe"
      Event = "NPC_Moros_01.MissingDistanceTrigger.VoiceLines"
    }
    {
      Id = "Melinoe_1149"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How thoughtful, I accept!"
      Speaker = "Melinoe"
      Event = "NPC_Moros_01.GiftGivenVoiceLines"
    }
    {
      Id = "Moros_0649"
      InheritFrom = "BaseNarrative"
      DisplayName = "Doom averted."
      Speaker = "Moros"
      Event = "GlobalVoiceLines.MorosLastStandSurvivedLines"
    }
    {
      Id = "Moros_0650"
      InheritFrom = "BaseNarrative"
      DisplayName = "Keep going."
      Speaker = "Moros"
      Event = "GlobalVoiceLines.MorosLastStandSurvivedLines"
    }
    {
      Id = "Moros_0651"
      InheritFrom = "BaseNarrative"
      DisplayName = "Impressive."
      Speaker = "Moros"
      Event = "GlobalVoiceLines.MorosLastStandSurvivedLines"
    }
    {
      Id = "Moros_0652"
      InheritFrom = "BaseNarrative"
      DisplayName = "Such tenacity."
      Speaker = "Moros"
      Event = "GlobalVoiceLines.MorosLastStandSurvivedLines"
    }
    {
      Id = "Moros_0653"
      InheritFrom = "BaseNarrative"
      DisplayName = "Fight on."
      Speaker = "Moros"
      Event = "GlobalVoiceLines.MorosLastStandSurvivedLines"
    }
    {
      Id = "Moros_0654"
      InheritFrom = "BaseNarrative"
      DisplayName = "Proceed."
      Speaker = "Moros"
      Event = "GlobalVoiceLines.MorosLastStandSurvivedLines"
    }
    {
      Id = "Moros_0655"
      InheritFrom = "BaseNarrative"
      DisplayName = "Unexpected..."
      Speaker = "Moros"
      Event = "GlobalVoiceLines.MorosLastStandSurvivedLines"
    }
    {
      Id = "Moros_0656"
      InheritFrom = "BaseNarrative"
      DisplayName = "Close call."
      Speaker = "Moros"
      Event = "GlobalVoiceLines.MorosLastStandSurvivedLines"
    }
    {
      Id = "Moros_0657"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well done."
      Speaker = "Moros"
      Event = "GlobalVoiceLines.MorosLastStandSurvivedLines"
    }
    {
      Id = "Moros_0658"
      InheritFrom = "BaseNarrative"
      DisplayName = "Survived again."
      Speaker = "Moros"
      Event = "GlobalVoiceLines.MorosLastStandSurvivedLines"
    }
  ]
}
