{
/* Boot Sequence / Announcement Screen / Main Menu / Start Screen / Announcement Screen / Roadmap */

  lang = "en"
  Texts = [
    {
      Id = "MainMenuScreen_BootAnnouncement_UpdateWarning"
      DisplayName = "Please Update"
      Description = """
			Welcome to {#AlertHeaderFormat}Hades II{#Prev}.

			{#AlertBoldFormat}Note: {#Prev}This message appears if we detect that you are running an older version of this game. There are likely various significant additions and improvements you will be missing out on if you continue. @GUI\\Icons\\GhostEmote\\OhBoy

			{#AlertHighlightFormat}Please exit the game and make sure you have downloaded the latest update. {#Prev}From all of us at Supergiant Games, thank you for playing.
		"""
    }
    {
      Id = "MainMenuScreen_BootAnnouncement_EarlyAccess"
      DisplayName = "SALUTATIONS!"
      Description = """
      After more than four years of development, it's our pleasure to present {#AlertHighlightFormat}v1.0 {#Prev}of {#AlertHeaderFormat}Hades II{#Prev}. As one of our {#AlertHighlightFormat}Early Access {#Prev}players, you're seeing this special message {#AlertItalicFormat}for the first and last time!

      Your support in {#AlertHighlightFormat}Early Access {#Prev}was essential to the making of this game. We hope you enjoy experiencing the {#AlertBoldFormat}true ending {#Prev}of the story as well as the finishing touches we added to our biggest project in more than 15 years, and our first-ever sequel.

      The conclusion of {#AlertHighlightFormat}Early Access {#Prev}also means we expect to wind down on updates to {#AlertHeaderFormat}Hades II {#Prev}once we ensure our launch is as problem-free as possible. Then, we'll return to shadows for a while and plan our next move.

      For now, and forevermore, good luck killing Time,
      """
    }
    {
      Id = "MainMenuScreen_BootAnnouncement_EarlyAccess_Loc"
      DisplayName = "EARLY ACCESS"
      Description = """
      Welcome to {#AlertHeaderFormat}Hades II{#Prev}. This game is in {#AlertHighlightFormat}Early Access{#Prev}, which means we're actively working on it based on our plans and your feedback.

      As with the first game, we have been using this process to expand and improve the overall experience. We now are focused on the true ending of the story and other finishing touches.

      {#AlertBoldFormat}How to Report Bugs: {#Prev}While we hope you have a good experience exploring the Underworld and beyond, if you encounter bugs during gameplay, please report them to us by pressing the {#AlertBoldFormat}F10 {#Prev}key.

      Thank you for playing, and good luck killing Time,
      """
    }
    {
      Id = "MainMenuScreen_BootAnnouncement_EarlyAccess_LocAlt"
      DisplayName = "EARLY ACCESS"
      Description = """
      Welcome to {#AlertHeaderFormat}Hades II{#Prev}. This game is in {#AlertHighlightFormat}Early Access{#Prev}, which means we're actively working on it based on our plans and your feedback.

      As with the first game, we have been using this process to expand and improve the overall experience. We now are focused on the true ending of the story and other finishing touches.

      {#AlertHighlightFormat}Translation in Progress: {#Prev}Some text recently added to the game is still being translated, and may temporarily appear in English. We apologize for the inconvenience and appreciate your patience.

      Thank you for playing, and good luck killing Time,
      """
    }

    /* Main Menu - Additional Content */
    {
      Id = "LastUpdate"
      DisplayName = "updated: "
    }
