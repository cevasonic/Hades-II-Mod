      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.BountyEarnedVoiceLines"
    }
    {
      Id = "Melinoe_1424"
      InheritFrom = "BaseSubtitle"
      DisplayName = "For the will of Night."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.BountyEarnedVoiceLines"
    }
    {
      Id = "Melinoe_0981"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thank you, Nyx."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.BountyEarnedVoiceLines"
    }
    {
      Id = "Melinoe_0982"
      InheritFrom = "BaseSubtitle"
      DisplayName = "For the realm."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.BountyEarnedVoiceLines"
    }
    {
      Id = "Melinoe_1087"
      InheritFrom = "BaseSubtitle"
      DisplayName = "For the realm."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.BountyEarnedVoiceLines"
    }
    {
      Id = "Melinoe_1089"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The realm grows stronger."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.BountyEarnedVoiceLines"
    }
    {
      Id = "Melinoe_1090"
      InheritFrom = "BaseSubtitle"
      DisplayName = "For the Underworld."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.BountyEarnedVoiceLines"
    }
    {
      Id = "MelinoeField_2042"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I did as Chaos asked."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.PackagedBountyClearedVoiceLines"
    }
    {
      Id = "MelinoeField_2040"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Experiment complete?"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.PackagedBountyClearedVoiceLines"
    }
    {
      Id = "MelinoeField_2041"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Did you see that, Chaos...?"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.PackagedBountyClearedVoiceLines"
    }
    {
      Id = "MelinoeField_2043"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Return to shadow, now...?"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.PackagedBountyClearedVoiceLines"
    }
    {
      Id = "Melinoe_0978"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Mission complete."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.PackagedBountyClearedVoiceLines"
    }
    {
      Id = "Melinoe_0979"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Mission complete..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.PackagedBountyClearedVoiceLines"
    }
    {
      Id = "Melinoe_0980"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Mission complete...!"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.PackagedBountyClearedVoiceLines"
    }
    {
      Id = "Melinoe_1083"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Done."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.PackagedBountyClearedVoiceLines"
    }
    {
      Id = "Melinoe_1084"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And, done."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.PackagedBountyClearedVoiceLines"
    }
    {
      Id = "Melinoe_1085"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Check."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.PackagedBountyClearedVoiceLines"
    }
    {
      Id = "Melinoe_1086"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And, check."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.PackagedBountyClearedVoiceLines"
    }
    {
      Id = "MelinoeField_3739"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Erm{#Prev}, what's going on...?"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.PackagedBountyClearedVoiceLines"
    }
    {
      Id = "Melinoe_2284"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Right on time."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ReceivedSupplyDropVoiceLines"
    }
    {
      Id = "Melinoe_2285"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Perfect condition."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ReceivedSupplyDropVoiceLines"
    }
    {
      Id = "Melinoe_2286"
      InheritFrom = "BaseSubtitle"
      DisplayName = "As promised."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ReceivedSupplyDropVoiceLines"
    }
    {
      Id = "Melinoe_2287"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It's all here."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ReceivedSupplyDropVoiceLines"
    }
    {
      Id = "Storyteller_0481"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Thus did Melinoë, the Unseen Princess of the Underworld, prevent the very possibility that Time could turn so cruelly against the gods again..."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_PostTrueEnding01.VoiceLines"
    }
    {
      Id = "Storyteller_0482"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}At least one possibility, of which there may be many, many more. For Time flows like a river, and its passage and its currents take strange turns."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_PostTrueEnding01.VoiceLines"
    }
    {
      Id = "Storyteller_0483"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}The Princess never did see the true House of Hades again; not on this night at least. But it is still entirely a mess from all which the Titan wrought, so she did not miss much."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_PostTrueEnding01.VoiceLines"
    }
    {
      Id = "Storyteller_0484"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}The Princess never did return to the Palace of Zeus; not on this night at least. And neither did she truly mind, because the air and light up there were not quite to her taste."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_PostTrueEnding01_B.VoiceLines"
    }
    {
      Id = "Storyteller_0485"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Once more has the fierce Princess of the Underworld ensured that time flows freely forth; and in so doing, vanquished a foul remnant of her foe."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_PostTrueEnding02.VoiceLines"
    }
    {
      Id = "Storyteller_0486"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}The work itself can be quite rigorous, having to cross to other possibilities out of the singular reality we know. Thus the Princess now feels ready for a nap."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_PostTrueEnding02.VoiceLines"
    }
    {
      Id = "Storyteller_0487"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}A figment of the monstrous Typhon is destroyed, yet none perhaps shall know of it, save for the Princess of the Dead and her grandfather, Time. And you, and I, and whosoever else shall hear my tale, I suppose..."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_PostTrueEnding_Surface01.VoiceLines"
    }
    {
      Id = "Storyteller_0488"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}The only Time that we experience is now. We have the Princess of the Dead to thank for it, through all her tireless endeavors, such as what transpired on this very night."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_PostTrueEnding03.VoiceLines"
    }
    {
      Id = "Storyteller_0475"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Thus did the Three reclusive and feared Fates, whose often-unpredictable weavings determine all that is to come, even for gods, declare the dawning of another age..."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_Epilogue01.VoiceLines"
    }
    {
      Id = "Storyteller_0476"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}...an age in which both mortals and immortals shall be free to choose their path, so long as they believe the choice exists..."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_Epilogue01.VoiceLines"
    }
    {
      Id = "Storyteller_0477"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}...a golden age, during which mortalkind shall not be ruled entirely by divine right, but by itself."
      DisplayNameMaxLength = 310
      Speaker = "Storyteller"
      Event = "Outro_Epilogue01.VoiceLines"
    }
    {
      Id = "Storyteller_0478"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Word quickly spreads, from the heights of Olympus to the depths of the Underworld, foretelling of this perhaps very very distant future filled with possibility and the unknown."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_Epilogue01.VoiceLines"
    }
    {
      Id = "Storyteller_0479"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Many rejoice; but others know that gods do not go quietly, and history repeats."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_Epilogue01.VoiceLines"
    }
    {
      Id = "Storyteller_0480"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}For now, we can but use the Time we have; both to prepare, and, to the best of our ability, to live."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_Epilogue01.VoiceLines"
    }
    {
      Id = "Storyteller_0528"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Few tales are told of Hades, especially whilst he is bound in chains, in Tartarus... a prisoner of Time, no longer ruler of the Underworld."
      Speaker = "Storyteller"
      Event = "Outro_StoryReset01.VoiceLines"
    }
    {
      Id = "Storyteller_0530"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}His sole salvation, and our own, is the fierce Princess of the Dead. She has at last confronted both of her great foes..."
      Speaker = "Storyteller"
      Event = "Outro_StoryReset01.VoiceLines"
    }
    {
      Id = "Storyteller_0531"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}...scheming Chronos, the Titan of Time; and colossal Typhon, the Father of All Monsters — confronted, but not vanquished either one. Yet."
      Speaker = "Storyteller"
      Event = "Outro_StoryReset01.VoiceLines"
    }
    {
      Id = "Storyteller_0275"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Having passed a test of her ability, the witch Melinoë prepares for the true test of both her training and resolve. But since this also is a Test, no more from that is to be shared for now."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_TechTest02.VoiceLines"
    }
    {
      Id = "Storyteller_0277"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Born in shadow, the nightmare-bringing Princess of the Underworld shall return now whence she came."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_TechTest04.VoiceLines"
    }
    {
      Id = "Storyteller_0278"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}What is life but a series of tests and trials? One of which the shadow-stepping Princess has completed, whilst another looms on the horizon, coming soon."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_TechTest05.VoiceLines"
    }
    {
      Id = "Storyteller_0100"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Surely from there the Princess of the Underworld vanquished hateful Chronos utterly, restoring peace wherever it was lost, and then lived joyfully for all eternity?"
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd13.VoiceLines"
    }
    {
      Id = "Storyteller_0183"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}The vengeful Princess and the hateful Titan fought and fought. That is until the Titan, with the Princess at his mercy, took the opportunity to give a speech... during which the Princess slew him after all."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Titan.VoiceLines"
    }
    {
      Id = "Storyteller_0226"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}And what do you suppose the Princess found within that unassuming chamber in her father's former House? Naught but suggestive wall-scrolls, or a gaming-table, long unused? Eh... we shall eventually find out..."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Mystery.VoiceLines"
    }
    {
      Id = "Storyteller_0227"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Just as the Princess walks defiantly away, something begins to slightly stir behind her... is it the Titan Chronos, scythe in hand?! Oh gods, Melinoë, watch out!"
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Horror.VoiceLines"
    }
    {
      Id = "Storyteller_0228"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Another victory, and yet, an adversary such as Time has proven a most-stubborn one indeed. If I myself were Time, why, I would simply turn back the sun-dial, assuming that I could, so that this night would never come to pass."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Adversary.VoiceLines"
    }
    {
      Id = "Storyteller_0229"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Having resolved her family's blood-feud, now the Princess has scarce anything to do, except to call this one a night; and on the next, give the rekindled blood-feud yet another go."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Feud.VoiceLines"
    }
    {
      Id = "Storyteller_0231"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Returned now to her long-abandoned home, fearsome Melinoë there finds too many curiosities; a leading cause of death for cats, and she likes cats, so exercises prudence and restraint."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Home.VoiceLines"
    }
    {
      Id = "Storyteller_0232"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}What would become of us if Time could utterly be stopped... destroyed outright? It is unpleasant, frankly, just to think about, so we had best not dwell upon such things at all."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Unpleasant.VoiceLines"
    }
    {
      Id = "Storyteller_0163"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}And so, conniving Chronos was never heard from again, and young Melinoë and all her comrades lived happily ever after. {#Prev}Or did they...?"
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Chronos.VoiceLines"
    }
    {
      Id = "Storyteller_0466"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Time itself is every mortal's enemy; and enemy to some immortals, too. So let us all be thankful that the Princess of the Dead has really throttled him again."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Immortals.VoiceLines"
    }
    {
      Id = "Storyteller_0085"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Thus the ever-ready Princess of the Underworld gained the very heights of Mount Olympus, to confront an unspeakable horror that awaits."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Typhon01.VoiceLines"
    }
    {
      Id = "Storyteller_0319"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}It is no secret to which horror I refer; no secret now to its enormity, its boundless anger, or its many, many eyes."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Typhon01.VoiceLines"
    }
    {
      Id = "Storyteller_0319_B"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Such horrors cannot truly be destroyed... unless the Princess can come up with something at a Future Time."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Typhon01.VoiceLines"
    }
    {
      Id = "Storyteller_0320"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Another night, another massive undulating monster brought to heel; and for the Princess of the Dead, such victories are to be savored. But only for a bit."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Typhon02.VoiceLines"
    }
    {
      Id = "Storyteller_0321"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}After a grueling confrontation with the father of monstrosity, the Princess of the Dead yet stands, whilst the monstrosity does not. But since the hour now grows late, the sleepy Princess figures she ought to retire for the night."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Typhon03.VoiceLines"
    }
    {
      Id = "Storyteller_0322"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}This world is filled with monsters large and small. And for the most part, they are not unstoppable, as evidenced by our dark Princess of the Dead, who thus decides to take a little break."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Typhon04.VoiceLines"
    }
    {
      Id = "Storyteller_0323"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}It is most-natural to wonder, now that our Princess of the Underworld withstood the terrifying fury of the Father of All Monsters, what comes next? So please, go right ahead and wonder that."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Typhon05.VoiceLines"
    }
    {
      Id = "Storyteller_0324"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Much is required to subdue the hulking, furious progenitor of all the world's monstrosities: courage, strength, agility, a lifelong training regimen from a great witch; perhaps even a stroke of Fate. This night, at least, the Princess has it all."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Typhon06.VoiceLines"
    }
    {
      Id = "Storyteller_0325"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Beyond that besieged precipice, the Princess of the Dead discovers all the splendors for which Mount Olympus is well known... and she partakes of them, including an express trip back to her more-modest home."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Typhon07.VoiceLines"
    }
    {
      Id = "Storyteller_0326"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Upon the mountain of the gods, one's mortal senses surely would be overwhelmed; so if you are unable now to see or hear or smell or touch or taste it, that is surely for the best."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Typhon08.VoiceLines"
    }
    {
      Id = "Storyteller_0327"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}If one is of the Underworld, having to battle at extraordinarily high altitudes is ill-advised. There must be some more down-to-earth approach."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Typhon09.VoiceLines"
    }
    {
      Id = "Storyteller_0328"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}It takes practically all night for the hard-toiling Princess of the Dead to clamber to the highest point upon Olympus. But as often is the case, her return trip flies by in no time at all."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Typhon10.VoiceLines"
    }
    {
      Id = "Storyteller_0284"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}The summit of Olympus looms so close, and yet... try as she might, the surface-scouring Princess can climb no closer for the time. Although it never hurts to try."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Olympus01.VoiceLines"
    }
    {
      Id = "Storyteller_0251"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Once fearsome witch Melinoë surpasses all the many foes standing between her and the summit of Olympus, a most extraordinary thing occurs! But all those in attendance made a promise not to tell a soul."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Foes.VoiceLines"
    }
    {
      Id = "Storyteller_0252"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}The summit of Olympus is a hallowed yet precarious locale. And so the Underworld Princess, unaccustomed to such rarified terrain, decides to take the last leg of her journey very, very slow..."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Precarious.VoiceLines"
    }
    {
      Id = "Storyteller_0253"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Such unimaginable sights await the surface-voyaging Princess as she ascends the heights of Mount Olympus that, to our mortal minds and senses, why... they simply cannot be described."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Unimaginable.VoiceLines"
    }
    {
      Id = "Storyteller_0254"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}From the summit of Olympus, Titan-slaying witch Melinoë regards the world to which the gods lay claim; and she decides this precious world which we all share is perfect, just the way it is."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Summit.VoiceLines"
    }
    {
      Id = "Storyteller_0463"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}After vanquishing the abomination that is Typhon for the umpteenth time, the Princess of the Dead backtracks a bit to revel with the mirthful Dionysus, but retains no memory of that at all."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Dionysus.VoiceLines"
    }
    {
      Id = "Storyteller_0464"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}It is said that the Father of All Monsters possesses countless snaking limbs and peering eyes; so if the Princess of the Dead took out a few this night, perhaps it was of little consequence."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Countless.VoiceLines"
    }
    {
      Id = "Storyteller_0465"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Again the Fate-defying Princess braves the dangers of the mountain of the gods, and stands defiantly upon its tallest peak; but then the moment passes, \n {#Emph}and she calls it a night."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Dangers.VoiceLines"
    }
    {
      Id = "Storyteller_0467"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}The frightful-fast Princess Melinoë made such short work of her great foe this night, that Time itself seems to be on her side. But that cannot be possible, can it?"
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Frightful.VoiceLines"
    }
    {
      Id = "Storyteller_0255"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Whereupon the torch-bearing Melinoë ascends the mountain of the gods, she realizes that she left her heart within the Crossroads, which she calls her home; and thus decides to go and pick it up."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Heart.VoiceLines"
    }
    {
      Id = "Storyteller_0256"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Night-wandering Melinoë by now has traveled very far indeed, accomplishing her goal such as she can. Strangely enough, however, her return trip truly takes no time at all."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Goal.VoiceLines"
    }
    {
      Id = "Storyteller_0257"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}The Underworld's guardian Melinoë belongs not high above the surface, but below. Thus having taken care of family business for the night, she vanishes before the break of dawn."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Guardian.VoiceLines"
    }
    {
      Id = "Storyteller_0258"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}And so, under the watchful Eye of Night, unseen Melinoë gains the very top of Mount Olympus, where such revelry occurs that subsequent events this night are rather murky still."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Night.VoiceLines"
    }
    {
      Id = "Storyteller_0286"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}So violent is the clash that then ensues upon the summit of Olympus that I cannot even find the words to speak of it. Although I mean to find them... soon enough."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Olympus02.VoiceLines"
    }
    {
      Id = "Storyteller_0287"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Imagine knowing everything that shall transpire, much like the fierce Titan of Foresight can. Amongst the many questionable benefits, you would not need for me to say what happens next."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Foresight01.VoiceLines"
    }
    {
      Id = "Storyteller_0292"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Beyond lies the Palace of Zeus, stronghold of the gods, in all its awesome glory. But, it is undergoing renovations at this time... so imagining those luxurious-yet-stately halls shall have to do for now."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Palace01.VoiceLines"
    }
    {
      Id = "Storyteller_0088"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}So numerous are the travails of dread Melinoë that one can scarce begin to fathom them; but on some evening, fathom them we shall."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd01b.VoiceLines"
    }
    {
      Id = "Storyteller_0094"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}From shadow sprang the peerless witch Melinoë, and back to shadow she returns, for now. We shall resume her tale at another time."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd07.VoiceLines"
    }
    {
      Id = "Storyteller_0097"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}One rightly may imagine that this tale has a very thrilling end; although I am afraid for now, that we are out of Time."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd10.VoiceLines"
    }
    {
      Id = "Storyteller_0091"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}What then became of sorcerous Melinoë, you ask? This I would surely tell you, if I could. Alas that, for the moment, I cannot."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd04.VoiceLines"
    }
    {
      Id = "Storyteller_0093"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Of all great feats achieved by mortals or by gods, the nightmare-bringing Princess would achieve perhaps the greatest of them all. It's just, I cannot tell you of it yet..."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd06.VoiceLines"
    }
    {
      Id = "Storyteller_0095"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}So incomparable is the tale of the Princess of the Underworld that, why, I cannot even find the words. Though, by the gods, eventually, I shall!"
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd08.VoiceLines"
    }
    {
      Id = "Storyteller_0096"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}The sheer wrath of fire-tempered witch Melinoë is such that to describe how she confronted her remaining prey would be to sorely limit the appeal of this tale..."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd09.VoiceLines"
    }
    {
      Id = "Storyteller_0099"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}With victory at hand, the oft-feared Princess of the Dead achieved her life's ambition, and lived happily thenceforth for all eternity... or so I choose to think?"
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd12.VoiceLines"
    }
    {
      Id = "Storyteller_0101"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Thenceforth, all of the effort and hard work put in by studious Melinoë converted to a suitable reward; a life of pleasure and of luxury, perhaps! For what is life if not completely fair?"
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd14.VoiceLines"
    }
    {
      Id = "Storyteller_0102"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Surely a pleasant outcome of some sort awaits? Perhaps the Princess is invited to a regal ball, and therein meets her heart's desire, all whilst dancing to a catchy tune..."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd15.VoiceLines"
    }
    {
      Id = "Storyteller_0161"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}And after all of that, the Princess of the Dead and all the gods above the surface and below, they set aside their differences and lived from there on out contentedly."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Gods.VoiceLines"
    }
    {
      Id = "Storyteller_0162"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Thus young and spirited Melinoë found true love: the sport known as the discus-throw. And whilst she did not win the championship, she won over our hearts."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Love.VoiceLines"
    }
    {
      Id = "Storyteller_0164"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}With the forces of her enemy in ruin at her fiery feet, Princess Melinoë decided to return whence she came, for she could always devastate them more some other night."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Fiery.VoiceLines"
    }
    {
      Id = "Storyteller_0165"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Only after all of that did normally-diligent Melinoë discover she forgot something at home. Forgot her keys! So she turned toward the darkness and she said..."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Forgot.VoiceLines"
    }
    {
      Id = "Storyteller_0180"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}So lifelike was the nightmare tormenting the Princess of the Dead that she was very much surprised to learn that it was all a dream! Merely a dream, from which she shall awaken any moment now..."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Dream.VoiceLines"
    }
    {
      Id = "Storyteller_0181"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}The Dark Princess had always felt a strong connection with the dead, yet never quite knew why. That is until she realized that she was dead herself, and had been, all this time..."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Dead.VoiceLines"
    }
    {
      Id = "Storyteller_0182"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Thus having satisfied her heart's desire, the Princess felt such jubilation that she burst into a mirthful dance. And so infectious was this celebration that her friends as well as foes all soon joined in."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Dance.VoiceLines"
    }
    {
      Id = "Storyteller_0184"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}And ever since that time, the peoples of the surface and the Underworld sought to live in peace and harmony, knowing that only together would they make the world a better place."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Peace.VoiceLines"
    }
    {
      Id = "Storyteller_0185"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}That was the last we ever heard of the Princess. Her tale was forgotten, it is true. Yet were it not for her great sacrifices, none of us would be here now, would we?"
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Forgotten.VoiceLines"
    }
    {
      Id = "Storyteller_0186"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}So far beyond the scope of reasoning were the events that happened next, that committing them to words would be such folly as to not be worthy even of attempt."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Reasoning.VoiceLines"
    }
    {
      Id = "Storyteller_0187"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}The subsequent events were fraught with ambiguity; the tale's theme as obscure as its setting. Whether the Princess truly found that which she sought remains contested to this day."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Ambiguity.VoiceLines"
    }
    {
      Id = "Storyteller_0230"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Imagine now a tale which has such an epic scope, that the conclusion to the whole affair is nowhere to be found. For each great challenge that the heroine surmounts, another slightly different one awaits."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Epic.VoiceLines"
    }
    {
      Id = "Storyteller_0288"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}What does the future hold? Only the Fates themselves and perhaps Prometheus the Titan of Foresight know full well. Unfortunately, all of them are rather indisposed right now."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Future01.VoiceLines"
    }
    {
      Id = "Storyteller_0293"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}The future is uncertain, but one certainty is this: Time marches ever onward, often faster than one might presume, until we find ourselves wherever the Fates mean for us to be... which in the Princess of the Dead's case is right here..."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Future02.VoiceLines"
    }
    {
      Id = "Storyteller_0289"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}After accomplishing a truly monumental feat, the ever-modest Princess of the Dead respectfully requests for there to be no boasting or exaggerated tales of her ultimate result; merely a brief acknowledgement, like this."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Modesty.VoiceLines"
    }
    {
      Id = "Storyteller_0290"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Again Princess Melinoë prevails in her climactic confrontation, and again, I shall say nothing of what happens next; for I am under Oath to speak no more."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_Oath.VoiceLines"
    }
    {
      Id = "Storyteller_0291"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Perhaps after this point the Three Fates suddenly appear and say, {#Prev}Well done, Melinoë! But we shall now take care of everything. {#Emph}And then they do. How happy of an outcome that would be!"
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_EarlyEnd_DeusExMachina.VoiceLines"
    }
    {
      Id = "Storyteller_0500"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}So many different possibilities exist in which the Princess of the Dead prevails or fails... and this is but one more. Certainly, no two such possibilities are quite alike; nor ever have occurred before, nor ever again shall..."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "Outro_PostTrueEnding_Loop01.VoiceLines"
    }
  ]
}
