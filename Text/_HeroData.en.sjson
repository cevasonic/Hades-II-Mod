      Event = "HeroData.HeroVoiceLines.BountyEarnedVoiceLines"
    }
    {
      Id = "MelinoeField_2038"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Fear of the realm spreads."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.BountyEarnedVoiceLines"
    }
    {
      Id = "MelinoeField_2039"
      InheritFrom = "BaseSubtitle"
      DisplayName = "In shadow, I serve."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.BountyEarnedVoiceLines"
    }
    {
      Id = "Melinoe_1088"
      InheritFrom = "BaseSubtitle"
