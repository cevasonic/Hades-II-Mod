    }
    {
      Id = "Melinoe_4011"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Good Shade, you made it here!"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_2321"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hold fast to hope, good Shade."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_2322"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Moonlight guide you, good Shade."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_2323"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Listen well to the Commander, all right?"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_2324"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We shall prevail; I swear it."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_5519"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thank you for having faith in him and me."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_5520"
      InheritFrom = "BaseSubtitle"
      DisplayName = "For always believing in us."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_5521"
      InheritFrom = "BaseSubtitle"
      DisplayName = "He's safe and sound."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_5522"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You'll never guess whom I ran into in Elysium..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_2320"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Have faith in him for me."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_2319"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We're going to find him. I swear it."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_1713"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I see you found your way from Erebus."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_1714"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You found us after all."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_1715"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm pleased to see you made it here."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_1716"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Welcome to your new abode."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_2433"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I see you found your way."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_2434"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I knew you'd make it here."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_2435"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Welcome to your new home."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_2436"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hey I remember you...!"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_2437"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You made it safe and sound."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_2438"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Please make yourself at home."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_4268"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We meet again, and welcome."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_4269"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Welcome, everyone, to the Unseen."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_4270"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Greetings, and heed well the Commander."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_4261"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I see you're getting acclimated to this place."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_3557"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not quite as damp as Oceanus here, is it?"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_3558"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You made it from Oceanus, good...!"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_3559"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Much better off here than the Mourning Fields."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_3560"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You found your way here from the Fields..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_3561"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm glad you're out of Tartarus at last."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_3562"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I think you'll like it better here than Tartarus..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_4265"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This must be quite a change from Thessaly."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_4266"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You made it from Olympus all this way..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_4267"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You were all the way up at the summit, weren't you."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_3563"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hail, Shades. Our fight is just getting started."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_0342"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Shades of the Crossroads, greetings."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_0344"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hail, Shades!"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_0345"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hail, O Spirits!"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_0346"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Stay strong, my friends."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_0348"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Welcome to the Crossroads, Shade."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_1702"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Moonlight guide you, Shades."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_4257"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How fare you all tonight?"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_4260"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thank you for having faith in me."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_4262"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Do let me know if anything's amiss."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_4263"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Salutations to the Shades of the Unseen."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_4264"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It's good to see you all again."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_5517"
      InheritFrom = "BaseSubtitle"
      DisplayName = "There's more still to be done."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_5518"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We'll see this realm restored."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_0349"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You are welcome here and you are safe."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.ShadeEavesdropVoiceLines"
    }
    {
      Id = "Melinoe_4258"
      InheritFrom = "BaseSubtitle"
      DisplayName = "To further victories!"
