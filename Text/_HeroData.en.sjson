      Event = "HeroData.HeroVoiceLines.BiomeTimerAboutToExpireVoiceLines"
    }
    {
      Id = "Chronos_0848"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You had best hurry up..."
      Speaker = "Chronos"
      Event = "HeroData.HeroVoiceLines.BiomeTimerAboutToExpireVoiceLines"
    }
    {
      Id = "Chronos_0849"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Time {#Prev}is of the essence...!"
      Speaker = "Chronos"
      Event = "HeroData.HeroVoiceLines.BiomeTimerAboutToExpireVoiceLines"
    }
    {
      Id = "MelinoeField_1668"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Time's running out..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.BiomeTimerAboutToExpireVoiceLines"
    }
    {
      Id = "MelinoeField_1669"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hurry, Mel..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.BiomeTimerAboutToExpireVoiceLines"
    }
    {
      Id = "MelinoeField_1670"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not much time left..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.BiomeTimerAboutToExpireVoiceLines"
    }
    {
      Id = "MelinoeField_1671"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Time's almost up..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.BiomeTimerAboutToExpireVoiceLines"
    }
    {
      Id = "MelinoeField_1672"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Don't have much time..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.BiomeTimerAboutToExpireVoiceLines"
    }
    {
      Id = "MelinoeField_1673"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Nearly out of time..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.BiomeTimerAboutToExpireVoiceLines"
    }
    {
      Id = "MelinoeField_2249"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Got to move...!"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.BiomeTimerAboutToExpireVoiceLines"
    }
    {
      Id = "Chronos_0850"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Oh {#Prev}that it is."
      Speaker = "Chronos"
      Event = "HeroData.HeroVoiceLines.BiomeTimerAboutToExpireVoiceLines"
    }
    {
      Id = "Chronos_0851"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Please do."
      Speaker = "Chronos"
      Event = "HeroData.HeroVoiceLines.BiomeTimerAboutToExpireVoiceLines"
    }
    {
      Id = "Chronos_0852"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I am right here!"
      Speaker = "Chronos"
      Event = "HeroData.HeroVoiceLines.BiomeTimerAboutToExpireVoiceLines"
    }
    {
      Id = "Chronos_0853"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I am quite well thank you!"
      Speaker = "Chronos"
      Event = "HeroData.HeroVoiceLines.BiomeTimerAboutToExpireVoiceLines"
    }
    {
      Id = "Chronos_0854"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No you do not."
      Speaker = "Chronos"
      Event = "HeroData.HeroVoiceLines.BiomeTimerAboutToExpireVoiceLines"
    }
    {
      Id = "Chronos_0855"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yes, that you are."
      Speaker = "Chronos"
      Event = "HeroData.HeroVoiceLines.BiomeTimerAboutToExpireVoiceLines"
    }
    {
      Id = "MelinoeField_2195"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, no."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.BiomeTimerExpiredVoiceLines"
    }
    {
      Id = "MelinoeField_2196"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Out of time..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.BiomeTimerExpiredVoiceLines"
    }
    {
      Id = "MelinoeField_2197"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No time to spare...!"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.BiomeTimerExpiredVoiceLines"
    }
    {
      Id = "MelinoeField_2198"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Time's up...!"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.BiomeTimerExpiredVoiceLines"
    }
    {
      Id = "Chronos_0856"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Bye now."
      Speaker = "Chronos"
      Event = "HeroData.HeroVoiceLines.BiomeTimerExpiredVoiceLines"
    }
    {
      Id = "Chronos_0857"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And, {#Emph}Time."
      Speaker = "Chronos"
      Event = "HeroData.HeroVoiceLines.BiomeTimerExpiredVoiceLines"
    }
    {
      Id = "Chronos_0858"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Time is up..."
      Speaker = "Chronos"
      Event = "HeroData.HeroVoiceLines.BiomeTimerExpiredVoiceLines"
    }
    {
      Id = "Chronos_0859"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That is that."
      Speaker = "Chronos"
      Event = "HeroData.HeroVoiceLines.BiomeTimerExpiredVoiceLines"
    }
    {
      Id = "MelinoeField_0354"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Through... all... that..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_0355"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...It's... too... far..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "Melinoe_1336"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Have to get out of this damned city..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "Melinoe_1337"
      InheritFrom = "BaseSubtitle"
      DisplayName = "From the docks I can find a ship to cross the rift..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "Melinoe_1338"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Should be able to reach Olympus from there."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_0356"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No way around the city... have to get through..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_0357"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}...Follow the River Acheron, beyond the necropolis..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_0360"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Looks almost peaceful from afar..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_0361"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Can't quite see the docks from here..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_0358"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What horrors lurk within Ephyra on this night..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_0359"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just another night on the town..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_1739"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Warships risen from the depths... all headed for Olympus."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_1740"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Beyond this rift, the mountain of the gods..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_1741"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just a little night sea journey... what's to fear?"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_1742"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Too far to swim... but all those ships out there are swift..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_2059"
      InheritFrom = "BaseSubtitle"
      DisplayName = "As soon as one ship sinks, another rises from the depths..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_2060"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Such a strange and awful fleet that Chronos has..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_2714"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Deep breath, Mel..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_2715"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Made it this far and yet... the real climb is just about to start."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_2716"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The family may be much too proud to ask for help, but it's their time of need."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_2717"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Together, we can all prevail."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_2480"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just have to get from here to... all the way up there..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_2482"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No wonder mortals made their sacrifices to the gods here..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_2483"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A natural stronghold... no easy way up, not during this siege."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_2484"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You know I'm here, don't you, Prometheus...?"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_2485"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Why does my family live in the most inconvenient places..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_2481"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Concern yourself with each next step... and make it to the top..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_3357"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Out there, is that...? Something's inside those clouds.... Oh, gods..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_2932"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Can't see a blasted thing out there..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_2933"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...The elements themselves, turning against the gods..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_2953"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Something's out there..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_2934"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Typhon brought this storm upon the gods..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_2935"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...The Father of All Monsters, the Bringer of Storms..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_2936"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...You'll find I'm just as stubborn as you are, Typhon..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_2937"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...You can't hide from me out there, monster..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_5018"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hermes probably already spread the news..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_3463"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}<Gasp> {#Prev}It's..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_3466"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...That's... the Sun..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_3465"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Daybreak..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_3464"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Beautiful..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_3467"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Dawn..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_0135"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Beyond lies Uncle Poseidon's realm..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_0136"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Countless dead ends... one way through..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_0137"
      InheritFrom = "BaseSubtitle"
      DisplayName = "All that metal holds the very sea at bay..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_0138"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Each chamber here leads to a deeper one..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_0139"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Wonder what other terrors lurk within the sea..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_0140"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The peerless work of Master Daedalus..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_0141"
      InheritFrom = "BaseSubtitle"
      DisplayName = "To think this is a safer path than through Elysium..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_0842"
      InheritFrom = "BaseSubtitle"
      DisplayName = "So many mortal lives left unfulfilled..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_0843"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Across the Fields, beyond the bridge, seek there a pathway down..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_0844"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Lost loves... failed dreams... regrets..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_0845"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hopelessness... failure... despair..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_0846"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Don't give in... don't give in..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_0847"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come on, Mel... what are you waiting for..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_0848"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This horrid feeling... just a trick of the mind..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_0849"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I won't wind up like all these wretches here..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_1285"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The ever-shifting halls of Tartarus..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_1286"
      InheritFrom = "BaseSubtitle"
      DisplayName = "All this... machinery. For what...?"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_1287"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Did Chronos build all this...?"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_1288"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This must be how the chambers rearrange..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_1289"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Chronos and his wheels of change..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_1290"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Such an infernal racket around here..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "Melinoe_0865"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Death to Chronos. I'll see to that. No one is more prepared."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "Melinoe_0866"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Beyond the mists of Erebus there should be a way down."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "Melinoe_0867"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Too risky heading through Elysium. And too risky to stay."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "Melinoe_0868"
      InheritFrom = "BaseSubtitle"
      DisplayName = "All right. It's time."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "Melinoe_0869"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll get through all that gloom somehow."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "Melinoe_4301"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Few places such as this where two realms meet..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "Melinoe_4298"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Chronos on my father's throne far below... Typhon threatening Olympus far above."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "Melinoe_4299"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Whichever way I choose, I can prevail... but where to focus next..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "Melinoe_4300"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Each time I head toward Olympus, I defy the Fates themselves..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "Melinoe_0870"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Below, the path to Tartarus. Above, the way to Olympus."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "Melinoe_1321"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Moon is full..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "Melinoe_1327"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Moon is beautiful..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "Melinoe_1323"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Moon's waning..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "Melinoe_1328"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Moon's at half-strength..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "Melinoe_1324"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Moon wanes..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "Melinoe_1322"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Moon is new..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "Melinoe_1325"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Moon is waxing..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "Melinoe_1329"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Eye of Night..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "Melinoe_1326"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Moon waxes..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookVoiceLines"
    }
    {
      Id = "MelinoeField_5227"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Does Chronos truly wish for such a place to be destroyed...?"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookLeaveVoiceLines"
    }
    {
      Id = "MelinoeField_5228"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I did tell Zagreus preparing Gigaros may take a little while..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookLeaveVoiceLines"
    }
    {
      Id = "MelinoeField_5229"
      InheritFrom = "BaseSubtitle"
      DisplayName = "First we settle things here, then Chronos last..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookLeaveVoiceLines"
    }
    {
      Id = "MelinoeField_5230"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Zagreus... if only you could see this for yourself..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.OverlookLeaveVoiceLines"
    }
    {
      Id = "Storyteller_0450"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Thus was Hades, feared ruler of the dead, restored to his rightful throne alongside splendorous Persephone the Queen."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Storyteller_0451"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}The attacks upon Olympus finally ceased, and ever since, the gods governed our world with newfound care."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Storyteller_0452"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}As for the Princess of the Dead, Melinoë, she stayed in steady touch with all her family from the dark comfort of the shadows that had long since been her home."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Storyteller_0453"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}And she and the Silver Sisters kept their secret vigil over all the realms forevermore."
      DisplayNameMaxLength = 300
      Speaker = "Storyteller"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_2932"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This old unfinished painting... don't look away. Don't forget all that the Titan took from you."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_3989"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You'll find them. And you'll have so much to talk about. Let the longing for them spur you on for now."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_3988"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Are you growing more motivated to find your family? Or merely growing more despondent...?"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_2936"
      InheritFrom = "BaseSubtitle"
      DisplayName = "They were all so happy together, weren't they? And oblivious to the Titan's threat..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_5190"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Chronos threatened that you'd never see your family again, the wretch. But you have, and shall."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_2935"
      InheritFrom = "BaseSubtitle"
      DisplayName = "One of these nights you ought to ask Headmistress how she got this from the House."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_2938"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Father... he was so happy then, but now...? Don't let the Titan break his spirit..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_2939"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Brother... you don't remember him at all, and yet... you miss him. Somehow you do."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_2940"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Mother... you have her hair, at least. She seems so different from Headmistress, doesn't she..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_2943"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You don't remember them, besides this painting and your dreams. But still you fight for them..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_5779"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Chronos... is this what he wants? His family back? Odd way of showing it."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_5780"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The power to destroy a member of your family... it can't be the only way."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_2934"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This memory of all you lost... it stokes your want for vengeance even now."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_2937"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Titan has your family in his thrall, or worse... what has he done with them?"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_2933"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Father... Mother... Brother... please be safe. Please..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_2941"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}All that you lost is all that you are{#Prev}, as Headmistress would say..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_2942"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This family... lost to you since you were born. They deserve their vengeance, and so do you."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_1607"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Vengeance for my family."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_0347"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Vengeance for my father."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_5715"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Mother and Father... we'll see each other again soon."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_5714"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How happy we all seem... and in that moment in time, we truly were..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_5717"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Good evening, everyone... be well all right?"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_5719"
      InheritFrom = "BaseSubtitle"
      DisplayName = "May the Underworld renovations go smoothly..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_5179"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Your family... you may not be living under the same roof, though you're together still."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_5180"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The memory of your reunion, committed to canvas in such a beautiful way..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_5181"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Don't know how they managed to get Cerberus to sit still long enough for this..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_5182"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You won't forget them, {#Emph}ever... {#Prev}and with {#Emph}this{#Prev}, perhaps Dora won't forget them either."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_5185"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The House of Hades was so luxurious... nice to have your own space though."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_5187"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The old painting's safely tucked away. That memory isn't going anywhere."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_5184"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Such a beautiful dress they fashioned for me... though not as soft as Arachne's silk."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_5189"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You'll see them again soon. Perhaps tonight."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_5186"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Brother... he's so different, yet... it's like part of you was missing till you met."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_5188"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Mother... Father... Brother... Cerberus... you."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_5716"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We've all the time in the world..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_5718"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Take care, all of you... till next we meet."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.UsedFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_3990"
      InheritFrom = "BaseSubtitle"
      DisplayName = "See you all again in a few nights..."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.CoveredFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_3991"
      InheritFrom = "BaseSubtitle"
      DisplayName = "See you later."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.CoveredFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_3992"
      InheritFrom = "BaseSubtitle"
      DisplayName = "See you all."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.CoveredFamilyPortraitVoiceLines"
    }
    {
      Id = "Melinoe_5754"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}I shall return!"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.StoryResetStartVoiceLines"
    }
    {
      Id = "Melinoe_5755"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ungh... {#Prev}head hurts... {#Emph}Death to Chronos."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.StoryResetEndVoiceLines"
    }
    {
      Id = "Melinoe_5696"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Don't mind me, everyone."
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.TavernaVictoryVoiceLines"
    }
    {
      Id = "Melinoe_5697"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You all enjoy yourselves!"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.TavernaVictoryVoiceLines"
    }
    {
      Id = "Melinoe_5698"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Another victory for the Unseen!"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.TavernaVictoryVoiceLines"
    }
    {
      Id = "Melinoe_5699"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The night is ours, Shades!"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.TavernaVictoryVoiceLines"
    }
    {
      Id = "Melinoe_5700"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Another victory!"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.TavernaVictoryVoiceLines"
    }
    {
      Id = "Melinoe_5701"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This night is ours!"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.TavernaVictoryVoiceLines"
    }
    {
      Id = "Melinoe_5702"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I salute you, Shades!"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.TavernaVictoryVoiceLines"
    }
    {
      Id = "Melinoe_5703"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Good evening, Shades!"
      Speaker = "Melinoe"
      Event = "HeroData.HeroVoiceLines.TavernaVictoryVoiceLines"
    }
    {
      Id = "Melinoe_1356"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hermes must be in the area."
