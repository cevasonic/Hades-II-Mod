    }
    {
      Id = "Icarus_0534"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Augh..."
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.KillStolenVoiceLines"
    }
    {
      Id = "Icarus_0535"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not quite..."
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.KillStolenVoiceLines"
    }
    {
      Id = "Icarus_0062"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's really you. Before you say anything, I know I'm not supposed to be here, but I spotted this ship and had to drop in for a closer look. And now I'm going to take off! So let's pretend this never happened, hey?"
      Speaker = "Icarus"
      Event = "IcarusFirstMeeting"
    }
    {
      Id = "MelinoeField_1930"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hold it right there, Icarus! I'm not about to let you just fly out on me again without a chat at least. To start with, what are you doing in the middle of this blasted war?"
      Speaker = "Melinoe"
      Event = "IcarusFirstMeeting"
    }
    {
      Id = "Icarus_0003"
      InheritFrom = "BaseNarrative"
      DisplayName = "The same thing I've {#Emph}been {#Prev}doing: slowing these bastards down. If everyone like me pitched in a little bit, this war would have been well over by now."
      Speaker = "Icarus"
      Event = "IcarusFirstMeeting"
    }
    {
      Id = "MelinoeField_1931"
      InheritFrom = "BaseNarrative"
      DisplayName = "That may be so. But this is a matter between gods and Titans. I wouldn't want you to get hurt."
      Speaker = "Melinoe"
      Event = "IcarusFirstMeeting"
    }
    {
      Id = "Icarus_0004"
      InheritFrom = "BaseNarrative"
      DisplayName = "Bit late for that, Meli! Anyway, I've kept you for too long, but let me give you something I've been working on before I go — and these all work. I swear!"
      Speaker = "Icarus"
      Event = "IcarusFirstMeeting"
    }
    {
      Id = "Icarus_0025_D"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your arm...! Never got better, did it? I'm really sorry, I should never have put you on the spot."
      Speaker = "Icarus"
      Event = "IcarusAboutMelinoe01"
    }
    {
      Id = "MelinoeField_2010"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not your fault. I had... grown very confident in my abilities. Headmistress always said there was no way to make Shades whole again, but I thought otherwise. Overextended, learned a lesson I'm not going to forget."
      Speaker = "Melinoe"
      Event = "IcarusAboutMelinoe01"
    }
    {
      Id = "Icarus_0026"
      InheritFrom = "BaseNarrative"
      DisplayName = "I felt so bad... couldn't look at anybody in the Crossroads anymore. Thought I'd never see you again. That it'd be for the best. I... had a lot I needed to sort out."
      Speaker = "Icarus"
      Event = "IcarusAboutMelinoe01"
    }
    {
      Id = "MelinoeField_2011"
      InheritFrom = "BaseNarrative"
      DisplayName = "And how did it go? You learned to fly, at least! Top of your list of fears, conquered. With your father's wings, no less!"
      Speaker = "Melinoe"
      Event = "IcarusAboutMelinoe01"
    }
    {
      Id = "Icarus_0027"
      InheritFrom = "BaseNarrative"
      DisplayName = "These wings are mine, Meli. That was all part of it. Had to learn to do things for myself, like you did. And for what it's worth, I think your arm looks amazing. Now, here."
      Speaker = "Icarus"
      Event = "IcarusAboutMelinoe01"
    }
    {
      Id = "Icarus_0028"
      InheritFrom = "BaseNarrative"
      DisplayName = "Been flying for a while now! At first, it brought me back to the terror I felt as a kid. Those final moments... I wanted to put myself through them, again and again. Don't know why."
      Speaker = "Icarus"
      Event = "IcarusAboutFlying01"
    }
    {
      Id = "MelinoeField_2012"
      InheritFrom = "BaseNarrative"
      DisplayName = "Icarus, you were young and you made a mistake. What's the use torturing yourself for it for all eternity? I thought you wanted to learn to fly to prove yourself to your father."
      Speaker = "Melinoe"
      Event = "IcarusAboutFlying01"
    }
    {
      Id = "Icarus_0029"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come on, Meli. I'm never going to prove myself to him. But something happened as I kept trying to use my wings... I, I started to like it! Seeing from a different point of view."
      Speaker = "Icarus"
      Event = "IcarusAboutFlying01"
    }
    {
      Id = "MelinoeField_2013"
      InheritFrom = "BaseNarrative"
      DisplayName = "You look so in your element up there! I always believed, if I could make you whole again, perhaps some night we'd learn to fly together. I still want to feel what it's like."
      Speaker = "Melinoe"
      Event = "IcarusAboutFlying01"
    }
    {
      Id = "Icarus_0030"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've no idea know how much I wanted that too. But, it was something I had to do on my own. I'd offer to take you up with me now, but... yeah, Shades and goddesses don't mix."
      Speaker = "Icarus"
      Event = "IcarusAboutFlying01"
    }
    {
      Id = "MelinoeField_2013_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "You look so in your element up there! I always believed, if I could make you whole again, perhaps some night we'd fly together..."
      Speaker = "Melinoe"
      Event = "IcarusAboutFlying01_B"
    }
    {
      Id = "MelinoeField_2015"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know, you've changed. You seem... more full of life. I catch these glimpses of your face while you're in flight, and... it's like there's a joy in you I never saw before."
      Speaker = "Melinoe"
      Event = "IcarusAboutFlying02"
    }
    {
      Id = "Icarus_0032"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Heh{#Prev}, well... there's the flying, which admittedly doesn't get old... and then there's seeing you, taking on the legions of Chronos single-handedly. Using all your training. {#Emph}Wow..."
      Speaker = "Icarus"
      Event = "IcarusAboutFlying02"
    }
    {
      Id = "MelinoeField_2016"
      InheritFrom = "BaseNarrative"
      DisplayName = "I didn't take them on single-handedly, Icarus, but... it's good to know about the flying! It must be exhilarating."
      Speaker = "Melinoe"
      Event = "IcarusAboutFlying02"
    }
    {
      Id = "Icarus_0033"
      InheritFrom = "BaseNarrative"
      DisplayName = "It is, Meli. You could always see right through me so no point in trying to sell it short. I hope some night you'll get a shot at it and tell me what you think."
      Speaker = "Icarus"
      Event = "IcarusAboutFlying02"
    }
    {
      Id = "Icarus_0033_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "It is, Meli. You could always see right through me so no point in trying to sell it short."
      Speaker = "Icarus"
      Event = "IcarusAboutFlying02_B"
    }
    {
      Id = "MelinoeField_2150"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you love flying so much, why do you keep helping me? Once my father's throne is restored, the gates of the Underworld will shut, and you'll be forced to return."
      Speaker = "Melinoe"
      Event = "IcarusAboutFlying03"
    }
    {
      Id = "Icarus_0063"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know. I would miss flying, sure. But, I think I could live without it if I had to — {#Emph}exist {#Prev}without it, you know what I mean. My plan is just to make the most of it, for now. We mortals are taught to believe nothing lasts forever anyway."
      Speaker = "Icarus"
      Event = "IcarusAboutFlying03"
    }
    {
      Id = "Icarus_0076"
      InheritFrom = "BaseNarrative"
      DisplayName = "You brought along the little Hammer from me, hey? First one I ever made! First that was any good, at least. Sort of a funny process, making things for making things..."
      Speaker = "Icarus"
      Event = "IcarusAboutKeepsake01"
    }
    {
      Id = "MelinoeField_2158"
      InheritFrom = "BaseNarrative"
      DisplayName = "Icarus, how could you give me this? You should hold onto it, as a reminder of how far you've come as a creator. I would have figured this to be one of your father's masterworks...!"
      Speaker = "Melinoe"
      Event = "IcarusAboutKeepsake01"
    }
    {
      Id = "Icarus_0077"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's much more special in your care than mine. Creating tools that others can use to reach new heights... that's how I reach them myself. You're doing me a solid here, Meli!"
      Speaker = "Icarus"
      Event = "IcarusAboutKeepsake01"
    }
    {
      Id = "Icarus_0397"
      InheritFrom = "BaseNarrative"
      DisplayName = "Been getting use from that old Hammer of mine, hey? I thought maybe you'd stash it somewhere it would gather dust. It's earned a break from everything I put it through!"
      Speaker = "Icarus"
      Event = "IcarusAboutKeepsake02"
    }
    {
      Id = "MelinoeField_4033"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wait you {#Emph}don't {#Prev}want me using it like this? If your intent was that it gather dust from the environment, then I think some sort of fur-lined surface would make it much more effective."
      Speaker = "Melinoe"
      Event = "IcarusAboutKeepsake02"
    }
    {
      Id = "Icarus_0398"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, no, I think the way you're using it is great. Seems like the charm on it is even stronger than it used to be! I'm just glad it's been of any help."
      Speaker = "Icarus"
      Event = "IcarusAboutKeepsake02"
    }
    {
      Id = "MelinoeField_2014"
      InheritFrom = "BaseNarrative"
      DisplayName = "You said yourself you're not supposed to be here, Icarus. Chronos may have flung open the Underworld gates, but your place is still below with us. Come back."
      Speaker = "Melinoe"
      Event = "IcarusAboutReturning01"
    }
    {
      Id = "Icarus_0031"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I always messed everything up, you know. I just want to be useful to someone, for once! So please... let me stay here. Let me have this!"
      Speaker = "Icarus"
      Event = "IcarusAboutReturning01"
    }
    {
      Id = "Icarus_0072"
      InheritFrom = "BaseNarrative"
      DisplayName = "The wretches on these ships don't have their wits, but they hit hard. I, I know you're good and everything, {#Emph}better {#Prev}than good, it's just... if things go bad... what happens to you then?"
      Speaker = "Icarus"
      Event = "IcarusAboutReturning02"
    }
    {
      Id = "MelinoeField_2156"
      InheritFrom = "BaseNarrative"
      DisplayName = "The first thing Headmistress taught me was how not to give in. If my strength is failing me, I use it to return to shadow whence I came. Almost a reflex at this point."
      Speaker = "Melinoe"
      Event = "IcarusAboutReturning02"
    }
    {
      Id = "Icarus_0073"
      InheritFrom = "BaseNarrative"
      DisplayName = "And then at the Crossroads, you're up and about by the following night, raring to go? Too bad you can't return-to-shadow back to where you left off..."
      Speaker = "Icarus"
      Event = "IcarusAboutReturning02"
    }
    {
      Id = "Icarus_0066"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wait, what are you even {#Emph}doing {#Prev}here? I thought you were supposed to be bound to the Underworld, but here you are, commandeering warships and whatnot!"
      Speaker = "Icarus"
      Event = "IcarusAboutSurfaceCurse01"
    }
    {
      Id = "MelinoeField_2152"
      InheritFrom = "BaseNarrative"
      DisplayName = "I am still bound there, I just loosened the bindings a bit. Though I feel absolutely wretched now, so if the legions of Chronos don't stop me soon, my blood-curse surely will."
      Speaker = "Melinoe"
      Event = "IcarusAboutSurfaceCurse01"
    }
    {
      Id = "Icarus_0067"
      InheritFrom = "BaseNarrative"
      DisplayName = "Really? Because you look great! {#Emph}Erm{#Prev}, you look... you look {#Emph}well{#Prev}, I mean. Unafflicted by a curse of any sort. Maybe a little seasick is all! Just... take one of these, hey?"
      Speaker = "Icarus"
      Event = "IcarusAboutSurfaceCurse01"
    }
    {
      Id = "Icarus_0162"
      InheritFrom = "BaseNarrative"
      DisplayName = "Been some nights since we last did this hasn't it, Meli? I figured you'd show up soon enough, though... unless maybe Chronos finally got you or something terrible like that?"
      Speaker = "Icarus"
      Event = "IcarusAboutTimePassing01"
    }
    {
      Id = "MelinoeField_3100"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you were truly worried for me, thank you, Icarus... but also don't do that. The concern does us no good; if you're distracted, you can't fight the Titan's legions to the fullest."
      Speaker = "Melinoe"
      Event = "IcarusAboutTimePassing01"
    }
    {
      Id = "Icarus_0163"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, it's all right, I get distracted all the time! Except when I'm at work, or in the sky. Which, not coincidentally, are the two things that keep me busy recently!"
      Speaker = "Icarus"
      Event = "IcarusAboutTimePassing01"
    }
    {
      Id = "MelinoeField_2147"
      InheritFrom = "BaseNarrative"
      DisplayName = "How fares your father, by the way? You've no idea how happy I am to find Daedalus Hammers out there... I never see him around, so can never thank him in person."
      Speaker = "Melinoe"
      Event = "IcarusAboutDaedalus01"
    }
    {
      Id = "Icarus_0034"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Heh! {#Prev}I'll be sure to send him your regards when next I happen to run into him, though it's been a little while. I'm glad his Hammers have been of some use. Have another?"
      Speaker = "Icarus"
      Event = "IcarusAboutDaedalus01"
    }
    {
      Id = "Icarus_0035"
      InheritFrom = "BaseNarrative"
      DisplayName = "You asked about my father the other night... and truth is, though you probably already know, I never see him around either. I think he might have retired!"
      Speaker = "Icarus"
      Event = "IcarusAboutDaedalus02"
    }
    {
      Id = "MelinoeField_2148"
      InheritFrom = "BaseNarrative"
      DisplayName = "Daedalus, {#Emph}retired? {#Prev}I just found one of his Hammers earlier! He's been of constant help to me since all this started, he... wait... {#Emph}what...?"
      Speaker = "Melinoe"
      Event = "IcarusAboutDaedalus02"
    }
    {
      Id = "Icarus_0036"
      InheritFrom = "BaseNarrative"
      DisplayName = "Meli, I'm his apprentice! He'd been building for a long time and needed a break. I'm nowhere near him but it's not like there was anybody else.... The Hammers come in handy though?"
      Speaker = "Icarus"
      Event = "IcarusAboutDaedalus02"
    }
    {
      Id = "MelinoeField_2149"
      InheritFrom = "BaseNarrative"
      DisplayName = "Stop, you're hurting my head. The {#Emph}Daedalus Hammers {#Prev}I've been finding are from {#Emph}you? {#Prev}Shouldn't they be {#Emph}Icarus {#Prev}Hammers then?"
      Speaker = "Melinoe"
      Event = "IcarusAboutDaedalus02"
    }
    {
      Id = "Icarus_0037"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Erm{#Prev}, we have a certain reputation to uphold. Not sure slapping my name on my father's designs would do us any good. Please... don't go telling anyone about this, hey?"
      Speaker = "Icarus"
      Event = "IcarusAboutDaedalus02"
    }
    {
      Id = "MelinoeField_2154"
      InheritFrom = "BaseNarrative"
      DisplayName = "You made your own wings, munitions, apparently the latest Daedalus Hammers... you've become quite the craftsman!"
      Speaker = "Melinoe"
      Event = "IcarusAboutDaedalus03"
    }
    {
      Id = "Icarus_0070"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come on, Meli. My father was a master by the time he was my age, even before I died. I'll never surpass him."
      Speaker = "Icarus"
      Event = "IcarusAboutDaedalus03"
    }
    {
      Id = "MelinoeField_2155"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's not what I've said. Your work is your own, and it's good! Better than good. When are you finally going to step out from your father's shadow?"
      Speaker = "Melinoe"
      Event = "IcarusAboutDaedalus03"
    }
    {
      Id = "Icarus_0071"
      InheritFrom = "BaseNarrative"
      DisplayName = "Funny question coming from you! My father may not be a god... but he's probably the greatest artist and inventor that ever lived. He'd be the first to say I'll never reach his level. Anyway, I'm through trying to prove myself to him."
      Speaker = "Icarus"
      Event = "IcarusAboutDaedalus03"
    }
    {
      Id = "MelinoeField_3098"
      InheritFrom = "BaseNarrative"
      DisplayName = "How is it that you know so much about all the Nocturnal Arms, to have devised so many custom Hammer tune-ups you've conveniently left for me? The Arms of Night are a closely guarded secret with little room for improvement."
      Speaker = "Melinoe"
      Event = "IcarusAboutDaedalus04"
    }
    {
      Id = "Icarus_0160"
      InheritFrom = "BaseNarrative"
      DisplayName = "My father worked for yours, remember? Came up with the interlocking chambers of the Underworld and so on? He must have earned a lot of trust... and learned a lot of secrets."
      Speaker = "Icarus"
      Event = "IcarusAboutDaedalus04"
    }
    {
      Id = "MelinoeField_3099"
      InheritFrom = "BaseNarrative"
      DisplayName = "And then he shared those secrets with his apprentice who supposedly can never live up to his lofty expectations?"
      Speaker = "Melinoe"
      Event = "IcarusAboutDaedalus04"
    }
    {
      Id = "Icarus_0161"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you're insinuating that I likewise earned my father's trust... fear not! When it comes to the Nocturnal Arms, I {#Emph}may {#Prev}have snooped around his notes and blueprints just a bit..."
      Speaker = "Icarus"
      Event = "IcarusAboutDaedalus04"
    }
    {
      Id = "MelinoeField_4042"
      InheritFrom = "BaseNarrative"
      DisplayName = "I only met my father rather recently in all of this... I thought Headmistress could be stern, but so is he. No big surprise considering the tales, but still. Perhaps your father took some inspiration from him."
      Speaker = "Melinoe"
      Event = "IcarusAboutDaedalus05"
    }
    {
      Id = "Icarus_0456"
      InheritFrom = "BaseNarrative"
      DisplayName = "I almost envy you, not having known your father for too long. Once I was working with a Hammer of my father's, broke it like a dolt, called it a failed experiment. {#Emph}No, you're the failed experiment{#Prev}, he said. He was always so calm."
      Speaker = "Icarus"
      Event = "IcarusAboutDaedalus05"
    }
    {
      Id = "MelinoeField_4043"
      InheritFrom = "BaseNarrative"
      DisplayName = "Icarus, that's horrid. And he clearly couldn't have meant it. You're his apprentice! Your work bears the Daedalus name."
      Speaker = "Melinoe"
      Event = "IcarusAboutDaedalus05"
    }
    {
      Id = "Icarus_0457"
      InheritFrom = "BaseNarrative"
      DisplayName = "I think my father loves me, in his way, he's just better with inventions than words. I'm sure yours is different. {#Emph}The god of the dead! {#Prev}He must be tough, hey?"
      Speaker = "Icarus"
      Event = "IcarusAboutDaedalus05"
    }
    {
      Id = "Icarus_0074"
      InheritFrom = "BaseNarrative"
      DisplayName = "How's everybody back at the Crossroads lately, hey? Master Odysseus putting all his plans to action at long last?"
      Speaker = "Icarus"
      Event = "IcarusAboutOdysseus01"
    }
    {
      Id = "MelinoeField_2157"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, yes. My route through here is thanks only to him. Say, he didn't put you up to this, did he? Deploying Shades with makeshift wings and explosives seems like something the Great Tactician would do..."
      Speaker = "Melinoe"
      Event = "IcarusAboutOdysseus01"
    }
    {
      Id = "Icarus_0075"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm acting on my own. Although maybe we're all part of the Great Tactician's plan and just don't realize it yet. He always said we'll have to improvise... might be I finally took it to heart."
      Speaker = "Icarus"
      Event = "IcarusAboutOdysseus01"
    }
    {
      Id = "MelinoeField_3634"
      InheritFrom = "BaseNarrative"
      DisplayName = "Icarus, I want you to come back. To the Crossroads. You want to aid our efforts here, you'll do an even better job of it if you're in contact with Odysseus and all our Shades."
      Speaker = "Melinoe"
      Event = "IcarusAboutCrossroads01"
    }
    {
      Id = "Icarus_0390"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not sure that everybody feels the same, Meli. I've been able to make do here on my own, and don't do well in crowds. Maybe from living in a prison tower all my life."
      Speaker = "Icarus"
      Event = "IcarusAboutCrossroads01"
    }
    {
      Id = "MelinoeField_3635"
      InheritFrom = "BaseNarrative"
      DisplayName = "But we could see each other more? And it's really not that crowded there, is it? Just give the possibility some thought..."
      Speaker = "Melinoe"
      Event = "IcarusAboutCrossroads01"
    }
    {
      Id = "Icarus_0391"
      InheritFrom = "BaseNarrative"
      DisplayName = "All right, all right, I will. Give it some thought, that is. But if I show up and the Witch of the Crossroads turns me into the Shade of a newt or something, it'll be on your conscience."
      Speaker = "Icarus"
      Event = "IcarusAboutCrossroads01"
    }
    {
      Id = "MelinoeField_3636"
      InheritFrom = "BaseNarrative"
      DisplayName = "I was so pleased to see that you decided to come back! How was it at the Crossroads after all this time?"
      Speaker = "Melinoe"
      Event = "IcarusAboutCrossroads02"
    }
    {
      Id = "Icarus_0392"
      InheritFrom = "BaseNarrative"
      DisplayName = "A bit uncomfortable at first, but then you showed up. And it was great to see Master Odysseus again, gave me a few flight path ideas. I didn't overstay did I...?"
      Speaker = "Icarus"
      Event = "IcarusAboutCrossroads02"
    }
    {
      Id = "MelinoeField_3637"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, not at all! Well, if you didn't mind it there, then I hope you'll return. And perhaps start to think of it again as a place to stay, not just a place to go."
      Speaker = "Melinoe"
      Event = "IcarusAboutCrossroads02"
    }
    {
      Id = "Icarus_0393"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's called the Crossroads, Meli, I never considered it could be a place to stay! Hey... cheers for giving me a push."
      Speaker = "Icarus"
      Event = "IcarusAboutCrossroads02"
    }
    {
      Id = "Icarus_0154"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, you've {#Emph}erm, uh... {#Prev}grown! A bit... I mean... I'm not imagining it, am I, hey? Since normally I don't quite have to crane my neck this much to look at you."
      Speaker = "Icarus"
      Event = "IcarusAboutCirce01"
    }
    {
      Id = "MelinoeField_3095"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just a bit of magick, courtesy of Circe the Enchantress. A temporary boost of strength, though with what seems to be a noticeable side effect..."
      Speaker = "Melinoe"
      Event = "IcarusAboutCirce01"
    }
    {
      Id = "Icarus_0155"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's not a bad thing, I just couldn't help but notice...! And now I'm staring... and now, I'm going to stop. Here you go."
      Speaker = "Icarus"
      Event = "IcarusAboutCirce01"
    }
    {
      Id = "Icarus_0156"
      InheritFrom = "BaseNarrative"
      DisplayName = "What happened to you, Meli, you're so {#Emph}small! {#Prev}Not that you're usually {#Emph}big{#Prev}, I mean, I mean... you've always been just right, but normally you're... just forget I spoke?"
      Speaker = "Icarus"
      Event = "IcarusAboutCirce02"
    }
    {
      Id = "MelinoeField_3096"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's all right, Icarus. You must be noticing the work of Circe the Enchantress, who provided one of her protective blessings for the night. Is the effect really that noticeable?"
      Speaker = "Melinoe"
      Event = "IcarusAboutCirce02"
    }
    {
      Id = "Icarus_0157"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}No! {#Prev}No, it really isn't! {#Emph}Erm{#Prev}, I just... tend to notice the little things, I mean I notice details — of all sizes! Anyway, I like it. Not that that matters. Here! Let me get you on your way."
      Speaker = "Icarus"
      Event = "IcarusAboutCirce02"
    }
    {
      Id = "Icarus_0068"
      InheritFrom = "BaseNarrative"
      DisplayName = "The other night, I saw these huge black wings on the horizon; definitely {#Emph}not {#Prev}a Harpy. Could have sworn it was bloody Eris... but, wasn't she still at the Crossroads, with you?"
      Speaker = "Icarus"
      Event = "IcarusAboutEris01"
    }
    {
      Id = "MelinoeField_2153"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, I'm not at the Crossroads either, but... unfortunately Strife Incarnate has been getting in my way. So she showed up around the time I did?"
      Speaker = "Melinoe"
      Event = "IcarusAboutEris01"
    }
    {
      Id = "Icarus_0069"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come to think of it, yes! {#Emph}Ah! {#Prev}I was beginning to worry she was here because of something {#Emph}I {#Prev}did! Never occurred to me she was just following {#Emph}you {#Prev}around, same as ever."
      Speaker = "Icarus"
      Event = "IcarusAboutEris01"
    }
    {
      Id = "MelinoeField_4031"
      InheritFrom = "BaseNarrative"
      DisplayName = "You shouldn't let Eris boss you around, you know. I overheard you chatting at the Crossroads. She's all talk... especially {#Emph}there{#Prev}, where her Rail of Adamant won't work."
      Speaker = "Melinoe"
      Event = "IcarusAboutEris02"
    }
    {
      Id = "Icarus_0395"
      InheritFrom = "BaseNarrative"
      DisplayName = "Easy for you to say, you're immortal like she is. We Shades know better than to stand up to the deathless gods."
      Speaker = "Icarus"
      Event = "IcarusAboutEris02"
    }
    {
      Id = "MelinoeField_4032"
      InheritFrom = "BaseNarrative"
      DisplayName = "You don't shrivel up in {#Emph}my {#Prev}presence. You're not a coward, Icarus. So why let Strife get the better of you?"
      Speaker = "Melinoe"
      Event = "IcarusAboutEris02"
    }
    {
      Id = "Icarus_0396"
      InheritFrom = "BaseNarrative"
      DisplayName = "I figure there's already enough conflict at the moment. Eris doesn't really get to me. I just don't mind letting her think she does. Not like she's the goddess of wisdom, hey?"
      Speaker = "Icarus"
      Event = "IcarusAboutEris02"
    }
    {
      Id = "Icarus_0146"
      InheritFrom = "BaseNarrative"
      DisplayName = "I saw huge plumes of fire shooting from the summit of Olympus recently. Thought the whole mountain was erupting! But on closer inspection, it was you! Fighting someone. And then some deranged eagle chased me off."
      Speaker = "Icarus"
      Event = "IcarusAboutPrometheus01"
    }
    {
      Id = "MelinoeField_3091"
      InheritFrom = "BaseNarrative"
      DisplayName = "That was Prometheus the Titan and his pet. He's turned against the gods, and is personally leading the siege of Olympus. Claims to know the future, and to fight for mortalkind... using the flames he stole from my family."
      Speaker = "Melinoe"
      Event = "IcarusAboutPrometheus01"
    }
    {
      Id = "Icarus_0147"
      InheritFrom = "BaseNarrative"
      DisplayName = "I didn't realize he'd broken free. What do mortals have to do with this whole feud with Chronos, anyhow? I thought all he wanted was his vengeance! Probably Prometheus as well..."
      Speaker = "Icarus"
      Event = "IcarusAboutPrometheus01"
    }
    {
      Id = "Icarus_0150"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sorry I'm late! Had a run-in with an eagle on the way. Maybe if I had a liver still I could offer it a bite and we'd become fast friends... worked for Prometheus apparently."
      Speaker = "Icarus"
      Event = "IcarusAboutPrometheus02"
    }
    {
      Id = "MelinoeField_3093"
      InheritFrom = "BaseNarrative"
      DisplayName = "Beloved by birds as well as mortals. Though you don't seem to have much fondness for Prometheus yourself. Perhaps his affection for mortals isn't always reciprocated."
      Speaker = "Melinoe"
      Event = "IcarusAboutPrometheus02"
    }
    {
      Id = "Icarus_0151"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, I mean... we've never met! When I was whole, we worshiped gods, not Titans. And Prometheus angered the gods, so... look, if you don't like him, that's enough for me."
      Speaker = "Icarus"
      Event = "IcarusAboutPrometheus02"
    }
    {
      Id = "Icarus_0401"
      InheritFrom = "BaseNarrative"
      DisplayName = "Some Shades back at the Crossroads, they were going on about Prometheus lately. Some of them seem to like him, more than Chronos anyway. Must be real charming, hey?"
      Speaker = "Icarus"
      Event = "IcarusAboutPrometheus03"
    }
    {
      Id = "MelinoeField_4048"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wouldn't say that, but he's very caught up in his cause. To let himself be tortured for the sake of mortalkind... full knowing that most mortals would never realize or care."
      Speaker = "Melinoe"
      Event = "IcarusAboutPrometheus03"
    }
    {
      Id = "Icarus_0402"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sounds a bit like a sob story to me. If he knew everything how come he let himself get caught? The gods probably would have given mortals fire anyway!"
      Speaker = "Icarus"
      Event = "IcarusAboutPrometheus03"
    }
    {
      Id = "Icarus_0403"
      InheritFrom = "BaseNarrative"
      DisplayName = "I could have sworn I saw the hero Heracles the other night...! Launching himself from one ship to the next, crushing deathless sailors with his club! I flew well clear of {#Emph}him."
      Speaker = "Icarus"
      Event = "IcarusAboutHeracles01"
    }
    {
      Id = "MelinoeField_4035"
      InheritFrom = "BaseNarrative"
      DisplayName = "You probably saw true. Olympus has him fighting back the Titan's legions and his fleet. We've worked together on occasion but he's kept me at arm's length..."
      Speaker = "Melinoe"
      Event = "IcarusAboutHeracles01"
    }
    {
      Id = "Icarus_0404"
      InheritFrom = "BaseNarrative"
      DisplayName = "You worked with {#Emph}Heracles? Oh{#Prev}, if only I could meet him for myself sometime...! But I don't even know what I would say. {#Emph}Hey! I'm like everybody else who thinks you're great!"
      Speaker = "Icarus"
      Event = "IcarusAboutHeracles01"
    }
    {
      Id = "MelinoeField_4036"
      InheritFrom = "BaseNarrative"
      DisplayName = "I had a passing chance to mention you to Heracles. Unfortunately he's not keen on meeting anyone unless he's out to kill them for the gods, but... he seemed to know of you."
      Speaker = "Melinoe"
      Event = "IcarusAboutHeracles02"
    }
    {
      Id = "Icarus_0405"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}What? {#Prev}How could he possibly...? {#Emph}He's {#Prev}the famous one! You sure he didn't mention Daedalus instead of me?"
      Speaker = "Icarus"
      Event = "IcarusAboutHeracles02"
    }
    {
      Id = "MelinoeField_4037"
      InheritFrom = "BaseNarrative"
      DisplayName = "He mentioned Daedalus, too, because... apparently he saw your final moments when you fell. I think, from what he said... he dove into the sea to find your body. To bury you."
      Speaker = "Melinoe"
      Event = "IcarusAboutHeracles02"
    }
    {
      Id = "Icarus_0406"
      InheritFrom = "BaseNarrative"
      DisplayName = "To {#Emph}bury {#Prev}me, but I... always wondered how I got here, as my memory is murky then. But I was buried by great Heracles himself! {#Emph}Incredible! {#Prev}Tell him I, I said {#Emph}cheers{#Prev}, hey?"
      Speaker = "Icarus"
      Event = "IcarusAboutHeracles02"
    }
    {
      Id = "Icarus_0407"
      InheritFrom = "BaseNarrative"
      DisplayName = "So how is the mighty Heracles lately? I'm half surprised the legions of the Titan got as far as they did knowing he's out there fighting for the gods."
      Speaker = "Icarus"
      Event = "IcarusAboutHeracles03"
    }
    {
      Id = "MelinoeField_4038"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}How is Heracles{#Prev}, that's difficult for me to say. I've never seen so fierce a warrior, but he's very guarded, too. When I told him you said cheers, he grunted; that was it."
      Speaker = "Melinoe"
      Event = "IcarusAboutHeracles03"
    }
    {
      Id = "Icarus_0408"
      InheritFrom = "BaseNarrative"
      DisplayName = "He grunted... about {#Emph}me. {#Prev}And he knows who I am! {#Emph}Ah{#Prev}, thank you, Meli, that's amazing news! I'm sure all he needs is a little rest, hey?"
      Speaker = "Icarus"
      Event = "IcarusAboutHeracles03"
    }
    {
      Id = "Icarus_0139"
      InheritFrom = "BaseNarrative"
      DisplayName = "There's some catastrophic storm brewing at the top of Olympus. Can't get anywhere near it. What's happening up there...?"
      Speaker = "Icarus"
      Event = "IcarusAboutTyphon01"
    }
    {
      Id = "MelinoeField_3087"
      InheritFrom = "BaseNarrative"
      DisplayName = "That storm conceals the real threat. Chronos awakened the Father of All Monsters and set him loose. These forces we're fighting... they're just a stalling tactic and a feint."
      Speaker = "Melinoe"
      Event = "IcarusAboutTyphon01"
    }
    {
      Id = "Icarus_0140"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're saying that's bloody {#Emph}Typhon? {#Prev}Oh, gods... since I was young I'd pray to all of you for safety and good fortune from my tower. Now it's you yourselves who'd better pray..."
      Speaker = "Icarus"
      Event = "IcarusAboutTyphon01"
    }
    {
      Id = "MelinoeField_3088"
      InheritFrom = "BaseNarrative"
      DisplayName = "No; we're going to {#Emph}destroy {#Prev}that thing. I don't yet know all that requires, though prayer most likely won't be necessary."
      Speaker = "Melinoe"
      Event = "IcarusAboutTyphon01"
    }
    {
      Id = "Icarus_0141"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well then I'll pray just in case! Figure it couldn't hurt. Just please be careful, Meli. And before you go... take one of these."
      Speaker = "Icarus"
      Event = "IcarusAboutTyphon01"
    }
    {
      Id = "Icarus_0142"
      InheritFrom = "BaseNarrative"
      DisplayName = "You really went and took on Typhon, hey? I caught a glimpse of him! As close as I dared fly to that huge storm. He could have squished you like a bug! Although I guess bugs can't use magick to escape..."
      Speaker = "Icarus"
      Event = "IcarusAboutTyphon02"
    }
    {
      Id = "MelinoeField_3089"
      InheritFrom = "BaseNarrative"
      DisplayName = "And bugs have wings, kind of like you! But yes, I can attest to Typhon's size and strength. Fortunately, I'm quicker... and have every god and goddess on Olympus backing me."
      Speaker = "Melinoe"
      Event = "IcarusAboutTyphon02"
    }
    {
      Id = "Icarus_0143"
      InheritFrom = "BaseNarrative"
      DisplayName = "But their might {#Emph}pales {#Prev}in comparison to my inventions here...! {#Emph}Erm{#Prev}, I, I, I shouldn't even jest... like that. You don't suppose they heard...? Don't tell them I said anything."
      Speaker = "Icarus"
      Event = "IcarusAboutTyphon02"
    }
    {
      Id = "Icarus_0144"
      InheritFrom = "BaseNarrative"
      DisplayName = "The other night I thought I saw you launch yourself toward the Olympus summit... right into that awful storm. I couldn't even get close! What was it like up there?"
      Speaker = "Icarus"
      Event = "IcarusAboutTyphon03"
    }
    {
      Id = "MelinoeField_3090"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh it was awful... I normally like rain, but not like that. Typhon is drawn to the Fortress of the Gods, as it's the last defense before the Palace of Zeus... likely his real goal."
      Speaker = "Melinoe"
      Event = "IcarusAboutTyphon03"
    }
    {
      Id = "Icarus_0145"
      InheritFrom = "BaseNarrative"
      DisplayName = "So the gods keep knocking him down, but he keeps getting back up, trying over and over to accomplish the same thing? A {#Emph}battle of wills! {#Prev}A battle of wits would have been easier, I guess."
      Speaker = "Icarus"
      Event = "IcarusAboutTyphon03"
    }
    {
      Id = "Icarus_0064"
      InheritFrom = "BaseNarrative"
      DisplayName = "Something happened since the last time you were here... these ships, one after another they all {#Emph}sank! {#Prev}Never seen these waters so calm. {#Emph}Did you...?"
      Speaker = "Icarus"
      Event = "IcarusAboutChronosBossW01"
    }
    {
      Id = "MelinoeField_2151"
      InheritFrom = "BaseNarrative"
      DisplayName = "Did I reach Chronos in my father's House and slay him? Yes. And, did he then reconstitute himself, perhaps entirely negating whatever I achieved? Also, yes."
      Speaker = "Melinoe"
      Event = "IcarusAboutChronosBossW01"
    }
    {
      Id = "Icarus_0065"
      InheritFrom = "BaseNarrative"
      DisplayName = "I always knew you'd get him, Meli. Well as you can see, his risen fleet has risen once again! Though, sounds to me like you've found one of its weaknesses!"
      Speaker = "Icarus"
      Event = "IcarusAboutChronosBossW01"
    }
    {
      Id = "Icarus_0399"
      InheritFrom = "BaseNarrative"
      DisplayName = "You must have seen Charybdis out there, massive whirlpool-nightmare-octopus-type thing? I've seen it swallow ships like {#Emph}this. {#Prev}I don't fly anywhere close!"
      Speaker = "Icarus"
      Event = "IcarusAboutCharybdis01"
    }
    {
      Id = "MelinoeField_4034"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm not so fortunate to have that option, and some nights, I've little choice but to confront Charybdis face-to... probably a face? Could use your aid if you decide to take the risk."
      Speaker = "Melinoe"
      Event = "IcarusAboutCharybdis01"
    }
    {
      Id = "Icarus_0400"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, {#Emph}absolutely {#Prev}not. I said I'd follow you into the sun, Meli, but Charybdis, no. My fear of flying was one thing, my fear of octopuses is another."
      Speaker = "Icarus"
      Event = "IcarusAboutCharybdis01"
    }
    {
      Id = "Icarus_0158"
      InheritFrom = "BaseNarrative"
      DisplayName = "Is that...? {#Emph}No. {#Prev}That's really Frinos with you, isn't it? All he used to do was sit there happily! Or sadly, I could never tell. And now he's in the middle of all this..."
      Speaker = "Icarus"
      Event = "IcarusAboutFrogFamiliar01"
    }
    {
      Id = "MelinoeField_3097"
      InheritFrom = "BaseNarrative"
      DisplayName = "This is indeed the one and only! I never knew he had it in him either, till Headmistress let me in on more of her secrets to working with Familiars."
      Speaker = "Melinoe"
      Event = "IcarusAboutFrogFamiliar01"
    }
    {
      Id = "Icarus_0159"
      InheritFrom = "BaseNarrative"
      DisplayName = "I always thought Familiars were just pets! Well, Frinos? It's good to see you again, mate. {#Emph}Keep Meli safe, will you...?"
      Speaker = "Icarus"
      Event = "IcarusAboutFrogFamiliar01"
    }
    {
      Id = "Icarus_0413"
      InheritFrom = "BaseNarrative"
      DisplayName = "Going to introduce me to your other winged companion over there? Looks like a raven though I've never seen one {#Emph}quite {#Prev}like that before..."
      Speaker = "Icarus"
      Event = "IcarusAboutRavenFamiliar01"
    }
    {
      Id = "MelinoeField_4041"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, right, pardon my rudeness both of you! Icarus, this is Raki, my Familiar. Raki, this is Icarus, my friend! You two are birds of a feather."
      Speaker = "Melinoe"
      Event = "IcarusAboutRavenFamiliar01"
    }
    {
      Id = "Icarus_0414"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well! Pleased to meet you, then, Raki. Know that I'll be studying your flight technique, since I'm always finding mine can still improve."
      Speaker = "Icarus"
      Event = "IcarusAboutRavenFamiliar01"
    }
    {
      Id = "Icarus_0152"
      InheritFrom = "BaseNarrative"
      DisplayName = "Look what they did to you, those... {#Emph}augh! {#Prev}I'm sorry I didn't get here sooner, Meli.... Do you ever just turn back? I mean if you're {#Emph}this {#Prev}hurt already, why go on...."
      Speaker = "Icarus"
      Event = "IcarusLowHealth01"
    }
    {
      Id = "MelinoeField_3094"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm not as hurt as you may think, and know my limits, Icarus. Though I appreciate the show of concern."
      Speaker = "Melinoe"
      Event = "IcarusLowHealth01"
    }
    {
      Id = "Icarus_0153"
      InheritFrom = "BaseNarrative"
      DisplayName = "I just — It's hard to see you put yourself through this. Even if your wounds heal by tomorrow, what matters is right now. Anyway... I might have something to help keep you going."
      Speaker = "Icarus"
      Event = "IcarusLowHealth01"
    }
    {
      Id = "Icarus_0409"
      InheritFrom = "BaseNarrative"
      DisplayName = "You should see how many inventions of mine don't work out even the slightest bit. I know some are better than others, but {#Emph}these {#Prev}are the best of the best. You have my guarantee."
      Speaker = "Icarus"
      Event = "IcarusAboutHammers01"
    }
    {
      Id = "MelinoeField_4039"
      InheritFrom = "BaseNarrative"
      DisplayName = "I suppose it must be helpful to have someone such as me willing to test them out for you. No way of knowing if they're any good until they're put to real use, presumably?"
      Speaker = "Melinoe"
      Event = "IcarusAboutHammers01"
    }
    {
      Id = "Icarus_0410"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Scoff> {#Prev}You're not testing them, Meli! My Hammers all go through {#Emph}extremely {#Prev}rigorous evaluation to earn the Daedalus name. But if you have any notes, let me know."
      Speaker = "Icarus"
      Event = "IcarusAboutHammers01"
    }
    {
      Id = "Icarus_0411"
      InheritFrom = "BaseNarrative"
      DisplayName = "Been working on something for quite a while here, and didn't want to say till it was ready, but I put it through more testing recently and think it's good to go."
      Speaker = "Icarus"
      Event = "IcarusGrantsReward01"
    }
    {
      Id = "MelinoeField_4040"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh that's exciting. Your inventions must take quite a while to make ready and produce. What's this one all about?"
      Speaker = "Melinoe"
      Event = "IcarusGrantsReward01"
    }
    {
      Id = "Icarus_0412"
      InheritFrom = "BaseNarrative"
      DisplayName = "You'll see, but it makes just about everything better, kind of like, well, {#Emph}you. {#Prev}Don't have to try it if you don't want!"
      Speaker = "Icarus"
      Event = "IcarusGrantsReward01"
    }
    {
      Id = "Icarus_0415"
      InheritFrom = "BaseNarrative"
      DisplayName = "I knew the Nocturnal Arms could take on many different forms, but to see them like {#Emph}this... {#Prev}you must have done something to earn their favor, hey?"
      Speaker = "Icarus"
      Event = "IcarusAboutHiddenAspects01"
    }
    {
      Id = "MelinoeField_4030"
      InheritFrom = "BaseNarrative"
      DisplayName = "I suppose? Either that or the Arms just want me to keep using them for now, in one Aspect or another. Say, how can your Hammers still work even if the Arms change shape?"
      Speaker = "Melinoe"
      Event = "IcarusAboutHiddenAspects01"
    }
    {
      Id = "Icarus_0416"
      InheritFrom = "BaseNarrative"
      DisplayName = "I make sure of it, that's why! And seeing different Aspects put to use always gives me plenty of ideas."
      Speaker = "Icarus"
      Event = "IcarusAboutHiddenAspects01"
    }
    {
      Id = "Icarus_0148"
      InheritFrom = "BaseNarrative"
      DisplayName = "Fancy meeting you up here! I used to never fly anywhere near this place but noticed somewhat fewer Harpies and Automaton defenses... and, well, {#Emph}you. {#Prev}Going all right so far?"
      Speaker = "Icarus"
      Event = "IcarusAboutOlympus01"
    }
    {
      Id = "MelinoeField_3092"
      InheritFrom = "BaseNarrative"
      DisplayName = "Going better than before now thanks to you. So what do you think? Does the mountain of the gods live up to everything you imagined?"
      Speaker = "Melinoe"
      Event = "IcarusAboutOlympus01"
    }
    {
      Id = "Icarus_0149"
      InheritFrom = "BaseNarrative"
      DisplayName = "Mostly, yes... considering mortals living or otherwise were never meant to see Olympus in all its glory. I'd rather see you anyway, Meli. Here, something for the rest of your climb."
      Speaker = "Icarus"
      Event = "IcarusAboutOlympus01"
    }
    {
      Id = "Icarus_0434"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not been as stormy on this mountain anymore, but is your family {#Emph}really {#Prev}going to tolerate all these Satyrs and things continuing to desecrate their home? Seems unlike them..."
      Speaker = "Icarus"
      Event = "IcarusAboutOlympus02"
    }
    {
      Id = "MelinoeField_4054"
      InheritFrom = "BaseNarrative"
      DisplayName = "They're leading me to Typhon, Icarus... some scattered remnant of him beyond time. We're working with Grandfather on a cleanup effort, you could say."
      Speaker = "Melinoe"
      Event = "IcarusAboutOlympus02"
    }
    {
      Id = "Icarus_0435"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Grandfather{#Prev}, y-you mean bloody {#Emph}Chronos? {#Prev}And, you're saying Typhon still {#Emph}exists? {#Prev}What happened to him being gone, I mean, I've seen no sign of him. This must be one of those things that's beyond mortal understanding, hey?"
      Speaker = "Icarus"
      Event = "IcarusAboutOlympus02"
    }
    {
      Id = "MelinoeField_4055"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't yet entirely understand it either... there's a lot we don't know about time and how it works, though we're learning, slowly."
      Speaker = "Melinoe"
      Event = "IcarusAboutOlympus02"
    }
    {
      Id = "Icarus_0436"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't see what's so complicated about it. Time drags on when things are bad, goes too quick when things are good. Though I'm still learning how to deal with that myself."
      Speaker = "Icarus"
      Event = "IcarusAboutOlympus02"
    }
    {
      Id = "MelinoeField_4044"
      InheritFrom = "BaseNarrative"
      DisplayName = "So did you get a chance to feel the wind and sea using the Ectoplasmic Draught? I wasn't sure how long it was going to last, and wanted you to make the most of it."
      Speaker = "Melinoe"
      Event = "IcarusAboutBecomingCloser01"
    }
    {
      Id = "Icarus_0385"
      InheritFrom = "BaseNarrative"
      DisplayName = "That was the greatest night of my existence, by a lot. Feeling the wind and sea was the perfect end to it! At first I thought the cold was making me numb, but it was just the Draught wearing off."
      Speaker = "Icarus"
      Event = "IcarusAboutBecomingCloser01"
    }
    {
      Id = "MelinoeField_4045"
      InheritFrom = "BaseNarrative"
      DisplayName = "That night was special for me, too. Apparently my grandmother Demeter was with a mortal once... and had my mother after that, who then had me! So I'm not a true goddess, and always had an interest in my mortal roots."
      Speaker = "Melinoe"
      Event = "IcarusAboutBecomingCloser01"
    }
    {
      Id = "Icarus_0386"
      InheritFrom = "BaseNarrative"
      DisplayName = "You are a true goddess, Meli. If you've a bit of mortal blood, so much the better. Anyway, that was an amazing time... but now that it's over, at least I have the memory!"
      Speaker = "Icarus"
      Event = "IcarusAboutBecomingCloser01"
    }
    {
      Id = "MelinoeField_4046"
      InheritFrom = "BaseNarrative"
      DisplayName = "We could make more sometime, perhaps. Memories that is. Because considering the Ectoplasmic Draught worked like it did... I may look into replicating it."
      Speaker = "Melinoe"
      Event = "IcarusAboutBecomingCloser01"
    }
    {
      Id = "Icarus_0387"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Gasp> {#Prev}Well if my heart were beating still it likely would have burst! I'd give anything to be with you again... but unlike last time, I'll be patient about it. I swear."
      Speaker = "Icarus"
      Event = "IcarusAboutBecomingCloser01"
    }
    {
      Id = "Icarus_0388"
      InheritFrom = "BaseNarrative"
      DisplayName = "That was the greatest night of my existence. It was so wonderful to feel alive with you, and then the wind and the sea! At first I thought the cold was making me numb, but it was just the Draught wearing off."
      Speaker = "Icarus"
      Event = "IcarusAboutBecomingCloser01_B"
    }
    {
      Id = "MelinoeField_4047"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm glad. I was concerned I may have hurt you once again. What we have... may not be everything you want. But it means a lot to me, and it's all I can give."
      Speaker = "Melinoe"
      Event = "IcarusAboutBecomingCloser01_B"
    }
    {
      Id = "Icarus_0389"
      InheritFrom = "BaseNarrative"
      DisplayName = "It means a lot to me, too. And you've given me more than I ever could have dreamed... so how about a nice Hammer as a means of making it up to you, hey?"
      Speaker = "Icarus"
      Event = "IcarusAboutBecomingCloser01_B"
    }
    {
      Id = "Icarus_0417"
      InheritFrom = "BaseNarrative"
      DisplayName = "Where have you {#Emph}been{#Prev}, Meli? Not seen you here or {#Emph}anywhere {#Prev}in far too many nights. Something's off, I don't know what but I think Chronos might be up to something new. His forces have been acting {#Emph}very {#Prev}strange...!"
      Speaker = "Icarus"
      Event = "IcarusPostTrueEnding01"
    }
    {
      Id = "MelinoeField_4049"
      InheritFrom = "BaseNarrative"
      DisplayName = "His forces have been acting very strange because Chronos {#Emph}abandoned his campaign! {#Prev}Icarus... our war is won! The House of Hades is restored! You'd not believe me if I told you how, but it's {#Emph}true!"
      Speaker = "Melinoe"
      Event = "IcarusPostTrueEnding01"
    }
    {
      Id = "Icarus_0418"
      InheritFrom = "BaseNarrative"
      DisplayName = "Chronos has given up, wait, {#Emph}what...? No! {#Prev}But we just fought more of his forces {#Emph}here! {#Prev}You're really serious..."
      Speaker = "Icarus"
      Event = "IcarusPostTrueEnding01"
    }
    {
      Id = "MelinoeField_4050"
      InheritFrom = "BaseNarrative"
      DisplayName = "When am I not? The Titan of Time is {#Emph}changed. {#Prev}We were able to get through to him finally, in the moment when his continued existence was on the line. I'm off to Olympus now, to make certain things are stable over there."
      Speaker = "Melinoe"
      Event = "IcarusPostTrueEnding01"
    }
    {
      Id = "Icarus_0419"
      InheritFrom = "BaseNarrative"
      DisplayName = "I just, I can't {#Emph}believe {#Prev}it! Well, I mean, of course I can. {#Emph}Heh! {#Prev}You got him, {#Emph}finally! {#Prev}You did get him, didn't you? I, {#Emph}erm{#Prev}, I don't know what to say... have one of these?"
      Speaker = "Icarus"
      Event = "IcarusPostTrueEnding01"
    }
    {
      Id = "MelinoeField_4050_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "When am I not? The Titan of Time is {#Emph}changed. {#Prev}We were able to get through to him finally, in the moment when his continued existence was on the line."
      Speaker = "Melinoe"
      Event = "IcarusPostTrueEnding01_B"
    }
    {
      Id = "Icarus_0437"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, last we spoke in the Crossroads, I... didn't mean to upset you, Meli. It's just... I didn't realize you'd have to keep fighting like this."
      Speaker = "Icarus"
      Event = "IcarusPostTrueEnding02"
    }
    {
      Id = "MelinoeField_4056"
      InheritFrom = "BaseNarrative"
      DisplayName = "You asked me what I was going to do with the rest of my existence, and it set me off. I've not thought that far ahead."
      Speaker = "Melinoe"
      Event = "IcarusPostTrueEnding02"
    }
    {
      Id = "Icarus_0438"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, it seems you don't need an answer anyway if you still have to keep heading up here. And probably down to the Underworld as well."
      Speaker = "Icarus"
      Event = "IcarusPostTrueEnding02"
    }
    {
      Id = "MelinoeField_4057"
      InheritFrom = "BaseNarrative"
      DisplayName = "There's certainly a comfort in routine. But, I have to accept that this may be all I'm meant to do. All I'm proficient at."
      Speaker = "Melinoe"
      Event = "IcarusPostTrueEnding02"
    }
    {
      Id = "Icarus_0439"
      InheritFrom = "BaseNarrative"
      DisplayName = "You don't have to accept {#Emph}any {#Prev}such thing, Meli. All my father ever did was work. Felt it was his calling! But you're not like him. Anyway... the rest of existence can wait! Let's make {#Emph}this {#Prev}night a good one and go from there, hey?"
      Speaker = "Icarus"
      Event = "IcarusPostTrueEnding02"
    }
    {
      Id = "MelinoeField_4051"
      InheritFrom = "BaseNarrative"
      DisplayName = "I meant to tell you, Icarus, I finally got to fly! With great Selene and her moonlit steeds. I certainly see the appeal, and I didn't even get to steer the chariot."
      Speaker = "Melinoe"
      Event = "IcarusAboutFlying04"
    }
    {
      Id = "Icarus_0430"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wait you were all the way up {#Emph}there? {#Prev}That's {#Emph}amazing! {#Prev}The Moon herself, giving you a ride across the sky. I've thought maybe if {#Emph}I {#Prev}could just fly a bit higher, I could reach her myself, but, {#Emph}erm... {#Prev}I talked myself down."
      Speaker = "Icarus"
      Event = "IcarusAboutFlying04"
    }
    {
      Id = "Icarus_0431"
      InheritFrom = "BaseNarrative"
      DisplayName = "There really is more to be done then, hey? If the war with Chronos truly ended, it sure doesn't look that way from all these ships. The Harpies don't seem any friendlier, either."
      Speaker = "Icarus"
      Event = "IcarusPostTrueEnding03"
    }
    {
      Id = "MelinoeField_4052"
      InheritFrom = "BaseNarrative"
      DisplayName = "Some must be zealots still believing that the Titan of Time shall rise again. But we're seeing to it that the threat of Chronos and Typhon can never recur. Just have to retrace my steps to Olympus as part of that process."
      Speaker = "Melinoe"
      Event = "IcarusPostTrueEnding03"
    }
    {
      Id = "Icarus_0432"
      InheritFrom = "BaseNarrative"
      DisplayName = "So then... all right. Because if what you're saying is I get to keep on flying, and I get to keep on seeing {#Emph}you {#Prev}up {#Emph}here... {#Prev}that doesn't sound so bad to me."
      Speaker = "Icarus"
      Event = "IcarusPostTrueEnding03"
    }
    {
      Id = "MelinoeField_4053"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, right! We thought the war ending would mean you'd have to put away your wings. But, my father's Underworld renovations seem like they'll be going on a long, long time."
      Speaker = "Melinoe"
      Event = "IcarusPostTrueEnding03"
    }
    {
      Id = "Icarus_0433"
      InheritFrom = "BaseNarrative"
      DisplayName = "Guess I may need to head back to my designated spot eventually. But for now, I'd like to make the most of this."
      Speaker = "Icarus"
      Event = "IcarusPostTrueEnding03"
    }
    {
      Id = "Icarus_0440"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not seen you out here in a bit! Been busy in the Underworld, or relaxing in the hot springs with a bottle of Ambrosia or two?"
      Speaker = "Icarus"
      Event = "IcarusAboutUnderworld01"
    }
    {
      Id = "MelinoeField_4059"
      InheritFrom = "BaseNarrative"
      DisplayName = "I won't confess so easily. Though I suppose you're right, it has been a while since we saw each other here. Anything new to report?"
      Speaker = "Melinoe"
      Event = "IcarusAboutUnderworld01"
    }
    {
      Id = "Icarus_0441"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd report I'm pleased to see you though that's nothing new, I guess. Your grandfather is also {#Emph}very good {#Prev}at reviving his slain followers, if that's part of your plan. It's been packed!"
      Speaker = "Icarus"
      Event = "IcarusAboutUnderworld01"
    }
    {
      Id = "Icarus_0481"
      InheritFrom = "BaseNarrative"
      DisplayName = "I like this routine we've got going here, Meli! I feel like I could keep doing this forever. We've become ruthlessly efficient... don't even need to chitchat anymore."
      Speaker = "Icarus"
      Event = "IcarusAboutSayingLittle01"
    }
    {
      Id = "Icarus_0005"
      InheritFrom = "BaseNarrative"
      DisplayName = "Was just out for a little jaunt is all and figured I'd stop in. Was good seeing you, Meli."
      Speaker = "Icarus"
      Event = "IcarusChat01"
    }
    {
      Id = "Icarus_0006"
      InheritFrom = "BaseNarrative"
      DisplayName = "Rough waters this evening, though the skies above aren't bad. You take care of yourself, hey?"
      Speaker = "Icarus"
      Event = "IcarusChat02"
    }
    {
      Id = "Icarus_0007"
      InheritFrom = "BaseNarrative"
      DisplayName = "Think I saw Eris further up the coast. How about you bring her a little surprise?"
      Speaker = "Icarus"
      Event = "IcarusChat03"
    }
    {
      Id = "Icarus_0008"
      InheritFrom = "BaseNarrative"
      DisplayName = "What I wouldn't give to stay here longer and catch up, but I know it's not the time or place."
      Speaker = "Icarus"
      Event = "IcarusChat04"
    }
    {
      Id = "Icarus_0009"
      InheritFrom = "BaseNarrative"
      DisplayName = "You were amazing, Meli. I saw everything up there! Keep going, hey?"
      Speaker = "Icarus"
      Event = "IcarusChat05"
    }
    {
      Id = "Icarus_0010"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got places to be, I know. Fortunately, I've got just the thing to help you get there."
      Speaker = "Icarus"
      Event = "IcarusChat06"
    }
    {
      Id = "Icarus_0011"
      InheritFrom = "BaseNarrative"
      DisplayName = "Think we'll look back someday on all of this and miss it, hey?"
      Speaker = "Icarus"
      Event = "IcarusChat07"
    }
    {
      Id = "Icarus_0012"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't know how you handle this night after night, though I am glad you do."
      Speaker = "Icarus"
      Event = "IcarusChat08"
    }
    {
      Id = "Icarus_0013"
      InheritFrom = "BaseNarrative"
      DisplayName = "Always good to see you, Meli, even for a bit. Nobody else will test this stuff for me!"
      Speaker = "Icarus"
      Event = "IcarusChat09"
    }
    {
      Id = "Icarus_0014"
      InheritFrom = "BaseNarrative"
      DisplayName = "The coast is clear for now! Though, past this point, no guarantees."
      Speaker = "Icarus"
      Event = "IcarusChat10"
    }
    {
      Id = "Icarus_0015"
      InheritFrom = "BaseNarrative"
      DisplayName = "Think I took care of one or two of them back there. Better than nothing, hey?"
      Speaker = "Icarus"
      Event = "IcarusChat11"
    }
    {
      Id = "Icarus_0016"
      InheritFrom = "BaseNarrative"
      DisplayName = "Been tinkering around with these. Take whichever one you want!"
      Speaker = "Icarus"
      Event = "IcarusChat12"
    }
    {
      Id = "Icarus_0017"
      InheritFrom = "BaseNarrative"
      DisplayName = "Whichever one of these you choose comes with a total satisfaction guarantee."
      Speaker = "Icarus"
      Event = "IcarusChat13"
    }
    {
      Id = "Icarus_0018"
      InheritFrom = "BaseNarrative"
      DisplayName = "The mountain isn't far from here. Maybe these will help you make the climb."
      Speaker = "Icarus"
      Event = "IcarusChat14"
    }
    {
      Id = "Icarus_0019"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know that you don't have a lot of time, so here. For the road ahead."
      Speaker = "Icarus"
      Event = "IcarusChat15"
    }
    {
      Id = "Icarus_0020"
      InheritFrom = "BaseNarrative"
      DisplayName = "Still perfectly all right...! Had me a little worried for a moment there."
      Speaker = "Icarus"
      Event = "IcarusChat16"
    }
    {
      Id = "Icarus_0021"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd fly you right up to the palace of the gods right now, if only I could..."
      Speaker = "Icarus"
      Event = "IcarusChat17"
    }
    {
      Id = "Icarus_0022"
      InheritFrom = "BaseNarrative"
      DisplayName = "Anything you need, just say the word. Though right now, this is all I've got."
      Speaker = "Icarus"
      Event = "IcarusChat18"
    }
    {
      Id = "Icarus_0023"
      InheritFrom = "BaseNarrative"
      DisplayName = "Even the gods themselves need somebody to fight for them, don't they...?"
      Speaker = "Icarus"
      Event = "IcarusChat19"
    }
    {
      Id = "Icarus_0024"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're more than halfway there, Meli... or pretty close, I think. No stopping now!"
      Speaker = "Icarus"
      Event = "IcarusChat20"
    }
    {
      Id = "Icarus_0081"
      InheritFrom = "BaseNarrative"
      DisplayName = "We'll have to catch up when you're free. No rush! Got all the time in the world."
      Speaker = "Icarus"
      Event = "IcarusChat21"
    }
    {
      Id = "Icarus_0082"
      InheritFrom = "BaseNarrative"
      DisplayName = "Only so much I can do to help! But then it's something, hey? So here."
      Speaker = "Icarus"
      Event = "IcarusChat22"
    }
    {
      Id = "Icarus_0083"
      InheritFrom = "BaseNarrative"
      DisplayName = "This ship feels like it's going to sink at any moment, so let's not stick around..."
      Speaker = "Icarus"
      Event = "IcarusChat23"
    }
    {
      Id = "Icarus_0084"
      InheritFrom = "BaseNarrative"
      DisplayName = "Maybe you'll find some use in one of these. They're all I've got tonight."
      Speaker = "Icarus"
      Event = "IcarusChat24"
    }
    {
      Id = "Icarus_0085"
      InheritFrom = "BaseNarrative"
      DisplayName = "These aren't up to my father's standard, but they're not too bad I think..."
      Speaker = "Icarus"
      Event = "IcarusChat25"
    }
    {
      Id = "Icarus_0086"
      InheritFrom = "BaseNarrative"
      DisplayName = "Keep thinking how I've never felt so alive as when I'm here with you..."
      Speaker = "Icarus"
      Event = "IcarusChat26"
    }
    {
      Id = "Icarus_0087"
      InheritFrom = "BaseNarrative"
      DisplayName = "Olympus isn't too much farther. I'll fly on ahead and draw some of the heat."
      Speaker = "Icarus"
      Event = "IcarusChat27"
    }
    {
      Id = "Icarus_0088"
      InheritFrom = "BaseNarrative"
      DisplayName = "A lot of Shades out there believe in you and what you're working to achieve."
      Speaker = "Icarus"
      Event = "IcarusChat28"
    }
    {
      Id = "Icarus_0089"
      InheritFrom = "BaseNarrative"
      DisplayName = "Can I just say, these wings hold up {#Emph}much {#Prev}better than the ones my father made?"
      Speaker = "Icarus"
      Event = "IcarusChat29"
    }
    {
      Id = "Icarus_0090"
      InheritFrom = "BaseNarrative"
      DisplayName = "Safe to say I never imagined my afterlife would turn out anything like this."
      Speaker = "Icarus"
      Event = "IcarusChat30"
    }
    {
      Id = "Icarus_0091"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know you can handle yourself, but let me see what I can do to help here. Please."
      Speaker = "Icarus"
      Event = "IcarusChat31"
    }
    {
      Id = "Icarus_0092"
      InheritFrom = "BaseNarrative"
      DisplayName = "Always a pleasure, Meli... I'm back on my feet but still feel like I'm flying...!"
      Speaker = "Icarus"
      Event = "IcarusChat32"
    }
    {
      Id = "Melinoe_3264"
      InheritFrom = "BaseNarrative"
      DisplayName = "You can fly wherever you want now! But, I'm glad you didn't go so far I couldn't catch up. Here! In light of your godlike wings, a little gift."
      Speaker = "Melinoe"
      Event = "IcarusGift01"
    }
    {
      Id = "Icarus_0038"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh come on, just because I've been flying around near Olympus, doesn't mean I get to feast like I'm from there! Maybe with your permission, hey? Know what, I got something for you, too."
      Speaker = "Icarus"
      Event = "IcarusGift01"
    }
    {
      Id = "Icarus_0039"
      InheritFrom = "BaseNarrative"
      DisplayName = "The last Nectar you got me was {#Emph}so {#Prev}good, can't even imagine what it would have been like while I was still alive. Wasn't going to ask for another, but... since you're offering!"
      Speaker = "Icarus"
      Event = "IcarusGift02"
    }
    {
      Id = "Melinoe_3266"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm offering, so here! Maybe it's even better now that you're a Shade. You mortals had to eat and drink out of necessity. But Nectar helps fulfill a different kind of need."
      Speaker = "Melinoe"
      Event = "IcarusGift02"
    }
    {
      Id = "Icarus_0078"
      InheritFrom = "BaseNarrative"
      DisplayName = "As a mortal kid confined to a tower, I was relatively well provided for, but {#Emph}this? {#Prev}I know better than to envy the gods, especially with what they're going through lately... but they definitely know their drink."
      Speaker = "Icarus"
      Event = "IcarusGift03"
    }
    {
      Id = "Melinoe_3499"
      InheritFrom = "BaseNarrative"
      DisplayName = "The gods have always lived well... but your own life was so short and difficult. You must still have a lot of making up to do, and I thought maybe this could help!"
      Speaker = "Melinoe"
      Event = "IcarusGift03"
    }
    {
      Id = "Icarus_0176"
      InheritFrom = "BaseNarrative"
      DisplayName = "Way back when, I always wanted to find you the best bottle of Nectar I could... but I never did. Adding to the list of things I perhaps should have approached differently."
      Speaker = "Icarus"
      Event = "IcarusGift04"
    }
    {
      Id = "Melinoe_3500"
      InheritFrom = "BaseNarrative"
      DisplayName = "Please don't dwell on the past so much. You thought you'd never see me again, but I'm here, now. I appreciate this moment that we have."
      Speaker = "Melinoe"
      Event = "IcarusGift04"
    }
    {
      Id = "Icarus_0080"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I won't forget it."
      Speaker = "Icarus"
      Event = "IcarusGift04"
    }
    {
      Id = "Icarus_0177"
      InheritFrom = "BaseNarrative"
      DisplayName = "Can hardly feel this bottle... just its weight. Though I still have fond memories to fill the gaps. It's funny, I've lost track of how long I've been dead, but still not used to it entirely."
      Speaker = "Icarus"
      Event = "IcarusGift05"
    }
    {
      Id = "Melinoe_4529"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps it's impossible to become entirely accustomed to the way we are. Though, I'm surprised you have any nostalgia for a time when you were young."
      Speaker = "Melinoe"
      Event = "IcarusGift05"
    }
    {
      Id = "Icarus_0178"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}You're {#Prev}one to talk! How many times have you reminisced about your quiet evenings listening to the river and the frogs? Sometimes we forget the pain, and sometimes it's all we remember. Though I'll remember this too."
      Speaker = "Icarus"
      Event = "IcarusGift05"
    }
    {
      Id = "Icarus_0179"
      InheritFrom = "BaseNarrative"
      DisplayName = "I was so reckless when I was a kid. My father always told me to be careful, but I was stuck in a bloody tower... couldn't do anything to hurt myself if I tried. But now... I just don't want to mess things up."
      Speaker = "Icarus"
      Event = "IcarusGift06"
    }
    {
      Id = "Melinoe_4530"
      InheritFrom = "BaseNarrative"
      DisplayName = "For someone who spends so much time up in the clouds, you're far too stuck in your own head at times. This isn't a test, Icarus. It's me. And I simply like it when you're you."
      Speaker = "Melinoe"
      Event = "IcarusGift06"
    }
    {
      Id = "Icarus_0180"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come on, Meli, look at us...! You're the immortal Princess of the Underworld; I'm a Shade of a failed apprentice who couldn't follow one simple instruction from his father and got dead ahead of schedule. {#Emph}This {#Prev}is what you like?"
      Speaker = "Icarus"
      Event = "IcarusGift06"
    }
    {
      Id = "Melinoe_4531"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, because that isn't who you are. I have no pity for you; why do you have so much for yourself? Cast it aside. But your true feelings, you should never hide from me."
      Speaker = "Melinoe"
      Event = "IcarusGift06"
    }
    {
      Id = "Icarus_0181"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll try... I'll definitely try, I'd be a fool not to. So, then...! Onward toward whatever comes our way?"
      Speaker = "Icarus"
      Event = "IcarusGift06"
    }
    {
      Id = "Melinoe_4532"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Though still appreciate the moment, yes."
      Speaker = "Melinoe"
      Event = "IcarusGift06"
    }
    {
      Id = "Melinoe_4558"
      InheritFrom = "BaseNarrative"
      DisplayName = "You seemed to enjoy your first taste of Ambrosia, so I want you to have a bottle for yourself. For when the occasion warrants it."
      Speaker = "Melinoe"
      Event = "IcarusGift07"
    }
    {
      Id = "Icarus_0246"
      InheritFrom = "BaseNarrative"
      DisplayName = "A bottle for myself, when the occasion warrants it... {#Emph}wow, what? {#Prev}Oh, come on, Meli, this is really too much! I've nothing {#Emph}near {#Prev}this good to give {#Emph}you!"
      Speaker = "Icarus"
      Event = "IcarusGift07"
    }
    {
      Id = "Melinoe_4559"
      InheritFrom = "BaseNarrative"
      DisplayName = "I beg to differ! You have given me {#Emph}much {#Prev}more. And I don't just mean the hammers you've been busy working on."
      Speaker = "Melinoe"
      Event = "IcarusGift07"
    }
    {
      Id = "Icarus_0247"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've not done anything that scores of Shade admirers of yours wouldn't have done in a heartbeat, if they still had one."
      Speaker = "Icarus"
      Event = "IcarusGift07"
    }
    {
      Id = "Melinoe_4560"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Wait, you're a Shade admirer of mine?"
      Speaker = "Melinoe"
      Event = "IcarusGift07"
    }
    {
      Id = "Icarus_0248"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, stop. And, give me that."
      Speaker = "Icarus"
      Event = "IcarusGift07"
    }
    {
      Id = "Melinoe_4561"
      InheritFrom = "BaseNarrative"
      DisplayName = "How about we try this whole Ambrosia thing again, but {#Emph}this {#Prev}time, no pretending you are just another Shade. You're more than that. And more than a friend."
      Speaker = "Melinoe"
      Event = "IcarusGift08"
    }
    {
      Id = "Icarus_0249"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Fine, but... don't you think this wasn't meant to be, hey? When I try to touch you it's barely a breeze, like I'm not even here..."
      Speaker = "Icarus"
      Event = "IcarusGift08"
    }
    {
      Id = "Melinoe_4562"
      InheritFrom = "BaseNarrative"
      DisplayName = "You {#Emph}are {#Prev}here. I don't want to get hurt again either but each night I set out like this, I can't accomplish what I need to do without inviting the possibility... even the inevitability. Sometimes it's worth it."
      Speaker = "Melinoe"
      Event = "IcarusGift08"
    }
    {
      Id = "Icarus_0250"
      InheritFrom = "BaseNarrative"
      DisplayName = "My pain I can handle fine, who cares? {#Emph}Yours{#Prev}, I don't think I could live with... {#Emph}exist {#Prev}with, you know what I mean. But... {#Emph}argh! {#Prev}I can't believe I'm {#Emph}arguing {#Prev}with you, Meli, I'm happy more than {#Emph}anything {#Prev}right now! But I'm {#Emph}afraid..."
      Speaker = "Icarus"
      Event = "IcarusGift08"
    }
    {
      Id = "Melinoe_4563"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A fear we can face together."
      Speaker = "Melinoe"
      Event = "IcarusGift08"
    }
    {
      Id = "Melinoe_4564"
      InheritFrom = "BaseNarrative"
      DisplayName = "How about one more Ambrosia, as a bit of an experiment, because a substance known for bringing warmth and pleasure seems somehow to bring you misery."
      Speaker = "Melinoe"
      Event = "IcarusGift09"
    }
    {
      Id = "Icarus_0251"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, excellent, I was just thinking I could use more misery and here we are. You do know why, don't you? We tried all this before, and it didn't work. I really wish it did, but hey."
      Speaker = "Icarus"
      Event = "IcarusGift09"
    }
    {
      Id = "Melinoe_4565"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm more experienced now. Sometimes when things don't work, you have to try again. Over, and over, and over, if that's what it takes."
      Speaker = "Melinoe"
      Event = "IcarusGift09"
    }
    {
      Id = "Icarus_0252"
      InheritFrom = "BaseNarrative"
      DisplayName = "Meli, I agree with you... provided that the cost of trying isn't way too high! In your case, well... you've got another arm, there, sure. A couple legs. You're willing to put all those on the line, for me? To make me {#Emph}whole?"
      Speaker = "Icarus"
      Event = "IcarusGift09"
    }
    {
      Id = "Melinoe_4566"
      InheritFrom = "BaseNarrative"
      DisplayName = "Look, I know I can't just permanently bring your body back. But this connection we have... that we've always had... I'm willing to go where it leads. I'd {#Emph}like {#Prev}to go, if you would too."
      Speaker = "Melinoe"
      Event = "IcarusGift09"
    }
    {
      Id = "Icarus_0253"
      InheritFrom = "BaseNarrative"
      DisplayName = "I would, of course. I'd follow you into the sun, Meli. Or anywhere you'd rather be."
      Speaker = "Icarus"
      Event = "IcarusGift09"
    }
    {
      Id = "Melinoe_4567"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Then I have an idea."
      Speaker = "Melinoe"
      Event = "IcarusGift09"
    }
    {
      Id = "Melinoe_4570"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't worry, this isn't more Ambrosia. It's called an Ectoplasmic Draught. Not as potent as the incantation I once tried, but this one works, I think."
      Speaker = "Melinoe"
      Event = "IcarusGift10"
    }
    {
      Id = "Icarus_0254"
      InheritFrom = "BaseNarrative"
      DisplayName = "What are you saying, Meli, wait... this draught can make me {#Emph}whole? {#Prev}Or maybe partially, an arm or something, hey?"
      Speaker = "Icarus"
      Event = "IcarusGift10"
    }
    {
      Id = "Melinoe_4571"
      InheritFrom = "BaseNarrative"
      DisplayName = "It may be able to restore your sense of self as though you lived and breathed. But the effect won't last particularly long, perhaps a night at best. That was the compromise."
      Speaker = "Melinoe"
      Event = "IcarusGift10"
    }
    {
      Id = "Icarus_0255"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're kidding, so... I could be {#Emph}me {#Prev}again... feel the cold wind and the spray of the sea and all that! For just one night. C-Can you make more?"
      Speaker = "Icarus"
      Event = "IcarusGift10"
    }
    {
      Id = "Melinoe_4572"
      InheritFrom = "BaseNarrative"
      DisplayName = "Let's not get ahead of ourselves. These things can carry side effects if you don't take them slow. Swear that you will."
      Speaker = "Melinoe"
      Event = "IcarusGift10"
    }
    {
      Id = "Icarus_0256"
      InheritFrom = "BaseNarrative"
      DisplayName = "I swear I'll take it slow using the Ectoplasmic Draught. I've ignored perfectly reasonable guidance to my peril at least once before and I don't intend to do it again."
      Speaker = "Icarus"
      Event = "IcarusGift10"
    }
    {
      Id = "Melinoe_4573"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then please use this whenever you see fit, perhaps on some particularly special night. And treat it as one-of-a-kind."
      Speaker = "Melinoe"
      Event = "IcarusGift10"
    }
    {
      Id = "Icarus_0257"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thank you... thank you so much..."
      Speaker = "Icarus"
      Event = "IcarusGift10"
    }
    {
      Id = "Melinoe_4533"
      InheritFrom = "BaseNarrative"
      DisplayName = "By the way have you seen what we did with the springs? Good place to shed any lingering pains if you want to go?"
      Speaker = "Melinoe"
      Event = "IcarusBathHouse01"
    }
    {
      Id = "Icarus_0187"
      InheritFrom = "BaseNarrative"
      DisplayName = "With you? Right now? All right! Though, don't expect the spring-water to be much good for my complexion, hey?"
      Speaker = "Icarus"
      Event = "IcarusBathHouse01"
    }
    {
      Id = "Icarus_0192"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Funny how utterly beyond belief life is sometimes. While I was living I could never have imagined {#Emph}anything {#Prev}like this."
      Speaker = "Icarus"
      Event = "IcarusBathHouse01"
    }
    {
      Id = "Melinoe_4535"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's just a hot spring, Icarus. A purified and heavily enchanted one, but nonetheless. You've been flying over fleets of risen warships... how is this any stranger than that?"
      Speaker = "Melinoe"
      Event = "IcarusBathHouse01"
    }
    {
      Id = "Icarus_0193"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Heh. {#Prev}It's mostly that I'm here with you. You're so beautiful, Meli. Not that you need us Shades and mortals to know it! Aphrodite herself must have told you, hey?"
      Speaker = "Icarus"
      Event = "IcarusBathHouse01"
    }
    {
      Id = "Melinoe_4536"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, stop, Aphrodite has been a steadfast ally. If she was envious of me, I doubt she'd be as forthcoming with all of her most potent blessings as she has been."
      Speaker = "Melinoe"
      Event = "IcarusBathHouse01"
    }
    {
      Id = "Icarus_0194"
      InheritFrom = "BaseNarrative"
      DisplayName = "That isn't really what I meant. We mortals... tend to have a certain shame. Our bodies can be so vulnerable, and ugly, sometimes... but not gods and goddesses."
      Speaker = "Icarus"
      Event = "IcarusBathHouse01"
    }
    {
      Id = "Melinoe_4537"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't see what's to be ashamed of. I've known Shades such as you, and Odysseus... you're close enough to gods!"
      Speaker = "Melinoe"
      Event = "IcarusBathHouse01"
    }
    {
      Id = "Icarus_0195"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hah{#Prev}, well, that's kind of you to say. And you were right about my burdens and this place! I'm really glad we're here."
      Speaker = "Icarus"
      Event = "IcarusBathHouse01"
    }
    {
      Id = "Icarus_0196"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I only wish we could have stayed longer. Though that was great. Thank you for bringing me along."
      Speaker = "Icarus"
      Event = "IcarusBathHouse01"
    }
    {
      Id = "Melinoe_4539"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It was nice..."
      Speaker = "Melinoe"
      Event = "IcarusBathHouse01"
    }
    {
      Id = "Melinoe_4540"
      InheritFrom = "BaseNarrative"
      DisplayName = "I enjoyed our prior outing at the springs, and thought you might be open to another sometime soon. Perhaps even right now?"
      Speaker = "Melinoe"
      Event = "IcarusBathHouse02"
    }
    {
      Id = "Icarus_0197"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh! {#Prev}Well, these wings, they need further maintenance but... what am I even saying. They can definitely wait. Let's go?"
      Speaker = "Icarus"
      Event = "IcarusBathHouse02"
    }
    {
      Id = "Melinoe_4541"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're quiet, Icarus. What's on your mind? Besides the further maintenance of the magnificent wings you've built."
      Speaker = "Melinoe"
      Event = "IcarusBathHouse02"
    }
    {
      Id = "Icarus_0198"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Heh{#Prev}, it's just... most of my evenings are substantially less pleasant. I want to make this last. As well as fix the bloody wings! If they were {#Emph}so {#Prev}magnificent, they wouldn't break."
      Speaker = "Icarus"
      Event = "IcarusBathHouse02"
    }
    {
      Id = "Melinoe_4542"
      InheritFrom = "BaseNarrative"
      DisplayName = "I think magnificent things are often fragile things. Though they seem sturdier than you let on! You had to solve the problems that caused the famous wings of Daedalus to fail."
      Speaker = "Melinoe"
      Event = "IcarusBathHouse02"
    }
    {
      Id = "Icarus_0199"
      InheritFrom = "BaseNarrative"
      DisplayName = "That failure was mine. The wings my father made were built with feathers and wax, which was all he had to work with at the time. The wax had to stay cool, but {#Emph}I {#Prev}flew off into the blazing sun. Probably should have gone out at night, in retrospect..."
      Speaker = "Icarus"
      Event = "IcarusBathHouse02"
    }
    {
      Id = "Melinoe_4543"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps you didn't have the luxury of choice, since you were captives then. So what happened? The wings melted on you?"
      Speaker = "Melinoe"
      Event = "IcarusBathHouse02"
    }
    {
      Id = "Icarus_0200"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, yes. Using them was such a thrill that I pushed them too hard. So I fell. These new ones use a fiber like the bones of a bird, so they don't split as easily. Though let's not talk about the past, all right? I much prefer the present."
      Speaker = "Icarus"
      Event = "IcarusBathHouse02"
    }
    {
      Id = "Icarus_0201"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}...Whew! {#Prev}They tell the dead to rest in peace but I've not had a break like that in {#Emph}far {#Prev}too long. Cheers, hey?"
      Speaker = "Icarus"
      Event = "IcarusBathHouse02"
    }
    {
      Id = "Melinoe_4545"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Cheers!"
      Speaker = "Melinoe"
      Event = "IcarusBathHouse02"
    }
    {
      Id = "Melinoe_4555"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey if you're not too busy, would you care to join me for a visit to the hot springs for a bit?"
      Speaker = "Melinoe"
      Event = "IcarusBathHouseDecline01"
    }
    {
      Id = "Icarus_0241"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've no idea how much I want to, but I really can't right now... I told Master Odysseus I'd soon be heading out."
      Speaker = "Icarus"
      Event = "IcarusBathHouseDecline01"
    }
    {
      Id = "Melinoe_4546"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey if you don't have to fly off just yet, how about a visit to the fishing pier with me? It's nice and quiet over there."
      Speaker = "Melinoe"
      Event = "IcarusFishing01"
    }
    {
      Id = "Icarus_0202"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sure, that sounds great! Though I should note I've never learned to fish, so fair warning I will not be any good."
      Speaker = "Icarus"
      Event = "IcarusFishing01"
    }
    {
      Id = "Icarus_0203"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Where I was from, fish were a major source of sustenance. It's strange, I... I never really thought that they were living creatures, same as me. Well, not {#Emph}same {#Prev}as me, but you get the idea. I was a kid! What did I know."
      Speaker = "Icarus"
      Event = "IcarusFishing01"
    }
    {
      Id = "Melinoe_4547"
      InheritFrom = "BaseNarrative"
      DisplayName = "Everything you mortals eat is living, or once was. I'm glad I have no need of sustenance... I've always found it quite distasteful, the idea of having to consume lives just to prolong one's own."
      Speaker = "Melinoe"
      Event = "IcarusFishing01"
    }
    {
      Id = "Icarus_0204"
      InheritFrom = "BaseNarrative"
      DisplayName = "We mortals are all about having to do distasteful things. That's one of the main differences between us and you, along with us being so easy to kill off. What choice do we have but to try and survive?"
      Speaker = "Icarus"
      Event = "IcarusFishing01"
    }
    {
      Id = "Melinoe_4548"
      InheritFrom = "BaseNarrative"
      DisplayName = "No choice at all, perhaps. Much in nature struggles to survive, from the flower yearning for a bit of light, to you, trying to figure out how to ask me to teach you to fish!"
      Speaker = "Melinoe"
      Event = "IcarusFishing01"
    }
    {
      Id = "Icarus_0205"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Haha. {#Prev}Well I understand it's necessary to be silent... so, why don't you provide a demonstration and I'll carefully observe."
      Speaker = "Icarus"
      Event = "IcarusFishing01"
    }
    {
      Id = "Icarus_0206"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know, I really did enjoy that, even just the quiet-waiting part. Thanks for bringing me along."
      Speaker = "Icarus"
      Event = "IcarusFishing01"
    }
    {
      Id = "Melinoe_0768"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're welcome."
      Speaker = "Melinoe"
      Event = "IcarusFishing01"
    }
    {
      Id = "Melinoe_4556"
      InheritFrom = "BaseNarrative"
      DisplayName = "I was thinking maybe you could join me by the fishing pier again, if you don't mind?"
      Speaker = "Melinoe"
      Event = "IcarusFishingDecline01"
    }
    {
      Id = "Icarus_0242"
      InheritFrom = "BaseNarrative"
      DisplayName = "As much as I would like that, I can't stick around much longer here tonight. Some other time though, hey?"
      Speaker = "Icarus"
      Event = "IcarusFishingDecline01"
    }
    {
      Id = "Melinoe_4549"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, ever tried Ambrosia, Icarus? Because if not, you're about to. Given your inclination and availability, of course."
      Speaker = "Melinoe"
      Event = "IcarusTaverna01"
    }
    {
      Id = "Icarus_0235"
      InheritFrom = "BaseNarrative"
      DisplayName = "As a matter of fact, {#Emph}no{#Prev}, I've not tried Ambrosia before, and I've {#Emph}never {#Prev}had the inclination till you asked me just now. You sure it'd be all right...?"
      Speaker = "Icarus"
      Event = "IcarusTaverna01"
    }
    {
      Id = "Icarus_0236"
      InheritFrom = "BaseNarrative"
      DisplayName = "...The other Shades are watching us, Meli. They admire you so much, and probably would wish I was dead if I wasn't already."
      Speaker = "Icarus"
      Event = "IcarusTaverna01"
    }
    {
      Id = "Melinoe_4550"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh don't worry. If any of those Shades get too envious, the only attention they'll end up getting is from Nemesis. Why would they even care? I see {#Emph}them {#Prev}more than you."
      Speaker = "Melinoe"
      Event = "IcarusTaverna01"
    }
    {
      Id = "Icarus_0237"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, it's just... as mortals many of us could get jealous. Especially when we'd see someone we cared for with somebody else. Hard to explain, but I think it all stems from our instinctively knowing how little time we have."
      Speaker = "Icarus"
      Event = "IcarusTaverna01"
    }
    {
      Id = "Melinoe_4551"
      InheritFrom = "BaseNarrative"
      DisplayName = "But you all have eternity now that you're here. Provided Chronos hasn't yet irreparably ruined everything. Though I suppose we gods can also have those types of feelings."
      Speaker = "Melinoe"
      Event = "IcarusTaverna01"
    }
    {
      Id = "Icarus_0238"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Really? {#Prev}Come on, name {#Emph}one {#Prev}thing that's ever made you envious, Meli. You seem so comfortable the way you are, and with everything you have... I've never seen you want for anything that isn't yours."
      Speaker = "Icarus"
      Event = "IcarusTaverna01"
    }
    {
      Id = "Melinoe_4552"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then you haven't been paying attention. I'm envious of Headmistress, for one. I'll never be half the witch she is. Nor look nearly as elegant in hats."
      Speaker = "Melinoe"
      Event = "IcarusTaverna01"
    }
    {
      Id = "Icarus_0239"
      InheritFrom = "BaseNarrative"
      DisplayName = "All right, I stand corrected! You're envious of the {#Emph}hat {#Prev}of the Witch of the Crossroads. Now {#Emph}can {#Prev}we try the drink already, hey? Could always spare some for the other Shades!"
      Speaker = "Icarus"
      Event = "IcarusTaverna01"
    }
    {
      Id = "Icarus_0240"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Wow. I have never had something like that in my {#Emph}entire {#Prev}life. Or death. The gods just regularly drink this stuff...?"
      Speaker = "Icarus"
      Event = "IcarusTaverna01"
    }
    {
      Id = "Melinoe_4554"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Some of them anyway!"
      Speaker = "Melinoe"
      Event = "IcarusTaverna01"
    }
    {
      Id = "Melinoe_4557"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got another bottle of Ambrosia we could split at the taverna if you're up for it?"
      Speaker = "Melinoe"
      Event = "IcarusTavernaDecline01"
    }
    {
      Id = "Icarus_0243"
      InheritFrom = "BaseNarrative"
      DisplayName = "I would genuinely love to, though... we've had reports of a new fleet appearing in the Rift, and I'd best pay them a visit first."
      Speaker = "Icarus"
      Event = "IcarusTavernaDecline01"
    }
    {
      Id = "Icarus_0394"
      InheritFrom = "BaseNarrative"
      DisplayName = "How about we try this at the Crossroads sometime, hey? Harder to concentrate here what with all the sunken ships and deathless crewmates and whatnot."
      Speaker = "Icarus"
      Event = "IcarusFieldGiftDecline01"
    }
    {
      Id = "MelinoeField_3638"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I see your point."
      Speaker = "Melinoe"
      Event = "IcarusFieldGiftDecline01"
    }
    {
      Id = "Melinoe_5161"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Icarus flew off..."
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.MissingDistanceTrigger.VoiceLines"
    }
    {
      Id = "Melinoe_5162"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No Icarus tonight..."
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.MissingDistanceTrigger.VoiceLines"
    }
    {
      Id = "Melinoe_3265"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Is this one of your inventions? Amazing! Thank you...!"
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.GiftGivenVoiceLines"
    }
    {
      Id = "MelinoeField_4058"
      InheritFrom = "BaseSubtitle"
      DisplayName = "One night at a time..."
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.UpgradeMenuOpenVoiceLines"
    }
    {
      Id = "Icarus_0285"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Here's what I've got..."
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.UpgradeMenuOpenVoiceLines"
    }
    {
      Id = "Icarus_0284"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Take your pick."
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.UpgradeMenuOpenVoiceLines"
    }
    {
      Id = "Icarus_0286"
      InheritFrom = "BaseSubtitle"
      DisplayName = "My latest work..."
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.UpgradeMenuOpenVoiceLines"
    }
    {
      Id = "Icarus_0287"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Any of these."
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.UpgradeMenuOpenVoiceLines"
    }
    {
      Id = "Icarus_0288"
      InheritFrom = "BaseSubtitle"
      DisplayName = "These should work."
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.UpgradeMenuOpenVoiceLines"
    }
    {
      Id = "Icarus_0289"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Whichever you want..."
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.UpgradeMenuOpenVoiceLines"
    }
    {
      Id = "Icarus_0279"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Already dead. Sorry."
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.OnHitVoiceLines"
    }
    {
      Id = "Icarus_0278"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come on, Meli."
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.OnHitVoiceLines"
    }
    {
      Id = "Icarus_0282"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Missed me...!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.OnHitVoiceLines"
    }
    {
      Id = "Icarus_0283"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm angry too."
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.OnHitVoiceLines"
    }
    {
      Id = "Icarus_0280"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Didn't hurt."
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.OnHitVoiceLines"
    }
    {
      Id = "Icarus_0281"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Didn't hurt...!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.OnHitVoiceLines"
    }
    {
      Id = "Icarus_0040"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Mind if I swoop in?"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "Icarus_0041"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Incoming!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "Icarus_0042"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Heads up, Meli!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "Icarus_0043"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hey, what's going on?"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "Icarus_0044"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Death from above!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "Icarus_0045"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thought I'd drop in!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "Icarus_0046"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You get away from her!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "Icarus_0047"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Brought some for everyone!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "Icarus_0048"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Fight on, I'll back you up!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "Icarus_0093"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You have this, Meli!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "Icarus_0094"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How's your evening going?"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "Icarus_0095"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Bunch 'em up for me, hey?"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "Icarus_0096"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Beginning attack run."
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "Icarus_0097"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Engaging!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "Icarus_0542"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I see 'em there, hold on!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "Icarus_0543"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Keep 'em busy for me, hey?"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "Icarus_0544"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You call for air support?"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "Icarus_0545"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll back you up, Meli!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "Icarus_0546"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Bombs primed, here we go."
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "Icarus_0547"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thought that was you, hang on!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "Icarus_0540"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Be right there!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "Icarus_0536"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Target spotted!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "Icarus_0491"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It's been too long!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "Icarus_0492"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Missed you here, Meli!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "Icarus_0548"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ooh{#Prev}, it's cold up here!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "Icarus_0549"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I {#Emph}hate {#Prev}flying through snow!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_1932"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What? {#Emph}Icarus...?"
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_1933"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What are you doing here?!"
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2213"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Icarus!"
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2211"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Icarus...!"
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2212"
      InheritFrom = "BaseSubtitle"
      DisplayName = "He's back...!"
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2214"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hi!"
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2215"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I see you!"
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2223"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Here, Icarus!"
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2224"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Right here!"
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2216"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not much, you?"
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2217"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're very welcome!"
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2218"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Even for me?"
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2219"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Let's do it!"
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2220"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We have this!"
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.EncounterStartVoiceLines"
    }
    {
      Id = "Icarus_0050"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Evening...!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterEndVoiceLines"
    }
    {
      Id = "Icarus_0051"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hey, Meli!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterEndVoiceLines"
    }
    {
      Id = "Icarus_0052"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Aaand{#Prev}, done."
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterEndVoiceLines"
    }
    {
      Id = "Icarus_0120"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Got you something...!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterEndVoiceLines"
    }
    {
      Id = "Icarus_0121"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How goes it?"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterEndVoiceLines"
    }
    {
      Id = "Icarus_0122"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You all right...?"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterEndVoiceLines"
    }
    {
      Id = "Icarus_0123"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What's new?"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterEndVoiceLines"
    }
    {
      Id = "Icarus_0124"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You did it..."
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterEndVoiceLines"
    }
    {
      Id = "Icarus_0125"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Rough waters..."
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterEndVoiceLines"
    }
    {
      Id = "Icarus_0126"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Sorry to interrupt..."
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterEndVoiceLines"
    }
    {
      Id = "Icarus_0127"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That was ugly..."
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterEndVoiceLines"
    }
    {
      Id = "Icarus_0128"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Nice night...!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterEndVoiceLines"
    }
    {
      Id = "Icarus_0129"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That was amazing."
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterEndVoiceLines"
    }
    {
      Id = "Icarus_0130"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not too bad..."
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterEndVoiceLines"
    }
    {
      Id = "Icarus_0520"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Takes care of {#Emph}that."
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterEndVoiceLines"
    }
    {
      Id = "Icarus_0521"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No problem."
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterEndVoiceLines"
    }
    {
      Id = "Icarus_0522"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Nice place."
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterEndVoiceLines"
    }
    {
      Id = "Icarus_0523"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Alone at last."
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.EncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_2229"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hello..."
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.EncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_2230"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hi."
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.EncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_2231"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hey..."
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.EncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_2232"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Good work."
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.EncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_2233"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Nicely done."
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.EncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_2234"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We made it."
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.EncounterEndVoiceLines"
    }
    {
      Id = "Icarus_0057"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Bye for now...!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.ExitVoiceLines"
    }
    {
      Id = "Icarus_0058"
      InheritFrom = "BaseSubtitle"
      DisplayName = "See you again...?"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.ExitVoiceLines"
    }
    {
      Id = "Icarus_0112"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Nice seeing you...!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.ExitVoiceLines"
    }
    {
      Id = "Icarus_0113"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Be safe...!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.ExitVoiceLines"
    }
    {
      Id = "Icarus_0114"
      InheritFrom = "BaseSubtitle"
      DisplayName = "All right I'm off...!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.ExitVoiceLines"
    }
    {
      Id = "Icarus_0115"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll be in touch...!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.ExitVoiceLines"
    }
    {
      Id = "Icarus_0116"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Good night...!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.ExitVoiceLines"
    }
    {
      Id = "Icarus_0117"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Till next time...!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.ExitVoiceLines"
    }
    {
      Id = "Icarus_0118"
      InheritFrom = "BaseSubtitle"
      DisplayName = "See you..."
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.ExitVoiceLines"
    }
    {
      Id = "Icarus_0119"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I better go..."
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.ExitVoiceLines"
    }
    {
      Id = "Icarus_0528"
      InheritFrom = "BaseSubtitle"
      DisplayName = "See you Meli!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.ExitVoiceLines"
    }
    {
      Id = "Icarus_0529"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You take care!"
      Speaker = "Icarus"
      Event = "NPC_Icarus_01.ExitVoiceLines"
    }
    {
      Id = "MelinoeField_2235"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Bye..."
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.ExitVoiceLines"
    }
    {
      Id = "MelinoeField_2237"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Off he goes."
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.ExitVoiceLines"
    }
    {
      Id = "MelinoeField_2238"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Careful out there..."
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.ExitVoiceLines"
    }
    {
      Id = "MelinoeField_2239"
      InheritFrom = "BaseSubtitle"
      DisplayName = "See you..."
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.ExitVoiceLines"
    }
    {
      Id = "MelinoeField_2240"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}<Sigh>"
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.ExitVoiceLines"
    }
    {
      Id = "MelinoeField_2590"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Keep up the good work...!"
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.ExitVoiceLines"
    }
    {
      Id = "MelinoeField_2236"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yes..."
      Speaker = "Melinoe"
      Event = "NPC_Icarus_01.ExitVoiceLines"
    }
    {
      Id = "Icarus_0164"
      InheritFrom = "BaseNarrative"
      DisplayName = "Didn't think I'd feel this way, though it's good to be back, Meli! Oh, {#Emph}erm{#Prev}, Your Grace. This place feels different, think it's... {#Emph}warmer {#Prev}than it used to be or something, hey?"
      Speaker = "Icarus"
      Event = "IcarusHomeFirstMeeting"
    }
    {
      Id = "Melinoe_4520"
      InheritFrom = "BaseNarrative"
      DisplayName = "You found your way back! You're welcome here and safe as ever, Icarus. I trust the wings made the return trip relatively swift and trouble-free?"
      Speaker = "Melinoe"
      Event = "IcarusHomeFirstMeeting"
    }
    {
      Id = "Icarus_0165"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, flying past the city of Ephyra sure beats having to trudge through. I still have to check in with Master Odysseus, though I'll try not be such a stranger around here."
      Speaker = "Icarus"
      Event = "IcarusHomeFirstMeeting"
    }
    {
      Id = "Melinoe_4521"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Do see to that."
      Speaker = "Melinoe"
      Event = "IcarusHomeFirstMeeting"
    }
    {
      Id = "Icarus_0166"
      InheritFrom = "BaseNarrative"
      DisplayName = "This place has changed so much since I took off. If you told me half this stuff was here, you'd have had a way easier time persuading me to come back."
      Speaker = "Icarus"
      Event = "IcarusHomeAboutCrossroads01"
    }
    {
      Id = "Melinoe_4522"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wanted to see if you'd do it of your own accord. And also, surprise! You still remember the trick to locating the place?"
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutCrossroads01"
    }
    {
      Id = "Icarus_0167"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hard to forget it once you know the way. Though, finding a good landing spot, I'm out of practice on that front. I nearly crashed into the cauldron!"
      Speaker = "Icarus"
      Event = "IcarusHomeAboutCrossroads01"
    }
    {
      Id = "Melinoe_4523"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No, what happened?"
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutCrossroads01"
    }
    {
      Id = "Icarus_0168"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...I crashed into Master Odysseus instead!"
      Speaker = "Icarus"
      Event = "IcarusHomeAboutCrossroads01"
    }
    {
      Id = "Icarus_0169"
      InheritFrom = "BaseNarrative"
      DisplayName = "So you really do wake up each night back there, entirely refreshed? And with a newfound resolve to achieve your life's ambition, that sort of thing?"
      Speaker = "Icarus"
      Event = "IcarusHomeAboutCrossroads02"
    }
    {
      Id = "Melinoe_4524"
      InheritFrom = "BaseNarrative"
      DisplayName = "You make it sound so automatic. My physical recovery may be mostly second-nature by now, but my motivation certainly is not. You think I never get discouraged?"
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutCrossroads02"
    }
    {
      Id = "Icarus_0170"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've {#Emph}never {#Prev}seen you discouraged. Though maybe you just hide it well. What'll you do if you succeed, hey? Pursue some other hopes and dreams?"
      Speaker = "Icarus"
      Event = "IcarusHomeAboutCrossroads02"
    }
    {
      Id = "Melinoe_4525"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's not something I've given any thought."
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutCrossroads02"
    }
    {
      Id = "Icarus_0171"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I get it. First things first."
      Speaker = "Icarus"
      Event = "IcarusHomeAboutCrossroads02"
    }
    {
      Id = "Icarus_0170_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've {#Emph}never {#Prev}seen you discouraged. Though maybe you just hide it well."
      Speaker = "Icarus"
      Event = "IcarusHomeAboutCrossroads02_B"
    }
    {
      Id = "Melinoe_4870"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A gift I never knew I had!"
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutCrossroads02_B"
    }
    {
      Id = "Icarus_0172"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, you're up! I almost missed you, was about to fly on back to Thessaly. Hope you rested well. Sounds like you had quite an eventful night!"
      Speaker = "Icarus"
      Event = "IcarusHomeAboutCrossroads03"
    }
    {
      Id = "Melinoe_4526"
      InheritFrom = "BaseNarrative"
      DisplayName = "It {#Emph}was {#Prev}productive, yes. Though if you're on assignment, I don't wish to keep you. We'll catch up some other time...! Or were you waiting here for me?"
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutCrossroads03"
    }
    {
      Id = "Icarus_0173"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}No! {#Prev}I mean, it's good to see you, {#Emph}yes{#Prev}, but... I'm not {#Emph}late. {#Prev}I can make up the time during my flight, you know, air currents and the like. So... well, back to it for the both of us then, hey?"
      Speaker = "Icarus"
      Event = "IcarusHomeAboutCrossroads03"
    }
    {
      Id = "Melinoe_4527"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Back to it, yes."
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutCrossroads03"
    }
    {
      Id = "Icarus_0458"
      InheritFrom = "BaseNarrative"
      DisplayName = "It never rains like {#Emph}this {#Prev}over the Rift. It's funny, growing up, I'd sometimes hear the sound of rain outside, but never got to feel it even once."
      Speaker = "Icarus"
      Event = "IcarusHomeAboutRain01"
    }
    {
      Id = "Melinoe_4861"
      InheritFrom = "BaseNarrative"
      DisplayName = "Odysseus would say you didn't miss much there, though he probably got rained on more than any mortal that ever lived. I quite like it, myself."
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutRain01"
    }
    {
      Id = "Icarus_0459"
      InheritFrom = "BaseNarrative"
      DisplayName = "I do, too. Even got a taste of it thanks to your Ectoplasmic Draught. And even now, I still enjoy the look and sound of it... what it does to your hair and all that."
      Speaker = "Icarus"
      Event = "IcarusHomeAboutRain01"
    }
    {
      Id = "Melinoe_4862"
      InheritFrom = "BaseNarrative"
      DisplayName = "My hair must look like dying branches, Icarus."
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutRain01"
    }
    {
      Id = "Icarus_0460"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not to me."
      Speaker = "Icarus"
      Event = "IcarusHomeAboutRain01"
    }
    {
      Id = "Icarus_0461"
      InheritFrom = "BaseNarrative"
      DisplayName = "I never thought the goddess of the hunt would be {#Emph}here {#Prev}in the middle of all this. Figured they'd have her busy sniping targets on Olympus! She sings nice."
      Speaker = "Icarus"
      Event = "IcarusHomeAboutArtemisSinging01"
    }
    {
      Id = "Melinoe_4863"
      InheritFrom = "BaseNarrative"
      DisplayName = "She does. Artemis is supposed to be keeping an eye on us, but she helps watch my back. I don't know how I even would have met the other gods if not for her."
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutArtemisSinging01"
    }
    {
      Id = "Icarus_0462"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're cousins but you're more like sisters, hey? Must be reassuring to have someone like that looking out for you."
      Speaker = "Icarus"
      Event = "IcarusHomeAboutArtemisSinging01"
    }
    {
      Id = "Melinoe_4864"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Was that a trace of {#Emph}jealousy?"
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutArtemisSinging01"
    }
    {
      Id = "Icarus_0463"
      InheritFrom = "BaseSubtitle"
      DisplayName = "More like inadequacy. But it's gone!"
      Speaker = "Icarus"
      Event = "IcarusHomeAboutArtemisSinging01"
    }
    {
      Id = "Icarus_0449"
      InheritFrom = "BaseNarrative"
      DisplayName = "Pleased to see you well again, Your Grace. Don't know about you, but last night was hard-fought for me! Those Chronos warship crews don't seem to tire out."
      Speaker = "Icarus"
      Event = "IcarusHomeAboutGrace01"
    }
    {
      Id = "Melinoe_4584"
      InheritFrom = "BaseNarrative"
      DisplayName = "Icarus, I thought I told you that I'm not {#Emph}Your Grace{#Prev}. I may be Princess of the Underworld by birth, but here I serve the Unseen, the same as you."
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutGrace01"
    }
    {
      Id = "Icarus_0450"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know, it's just I don't want any special treatment here. Other Shades all seem to be polite with you. And, I {#Emph}like {#Prev}calling you Your Grace! As long as you don't mind."
      Speaker = "Icarus"
      Event = "IcarusHomeAboutGrace01"
    }
    {
      Id = "Melinoe_4585"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just not too often, then."
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutGrace01"
    }
    {
      Id = "Icarus_0451"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yes your— yes."
      Speaker = "Icarus"
      Event = "IcarusHomeAboutGrace01"
    }
    {
      Id = "Icarus_0554"
      InheritFrom = "BaseNarrative"
      DisplayName = "That toolset there, is it really for me? Everything there looks so shiny. Where did we even {#Emph}get {#Prev}those from?"
      Speaker = "Icarus"
      Event = "IcarusHomeAboutTools01"
    }
    {
      Id = "Melinoe_4868"
      InheritFrom = "BaseNarrative"
      DisplayName = "Consider it a gift from the Crossroads, Icarus. You shape the bounties of the Earth into wondrous things, so you might as well have the finest equipment."
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutTools01"
    }
    {
      Id = "Icarus_0555"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll have to try them out, thank you so much. I'm quite partial to the worn set I've been using for a while, but those are probably due for a break."
      Speaker = "Icarus"
      Event = "IcarusHomeAboutTools01"
    }
    {
      Id = "Melinoe_4869"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Aren't we all!"
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutTools01"
    }
    {
      Id = "Icarus_0464"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, do you know where Master Odysseus could have gone? I was supposed to report in tonight, though I haven't seen him in a little while..."
      Speaker = "Icarus"
      Event = "IcarusHomeAboutOdysseusWandering01"
    }
    {
      Id = "Melinoe_4865"
      InheritFrom = "BaseNarrative"
      DisplayName = "I think he had some personal matters that he needed to take care of. I'm uncertain when he'll return. Did your report contain anything urgent?"
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutOdysseusWandering01"
    }
    {
      Id = "Icarus_0465"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, it's just... I don't know. When he isn't there, I have this worry that he won't come back. He seems a wanderer at heart, and... isn't his own family someplace else?"
      Speaker = "Icarus"
      Event = "IcarusHomeAboutOdysseusWandering01"
    }
    {
      Id = "Melinoe_4866"
      InheritFrom = "BaseNarrative"
      DisplayName = "Depends which family you mean! He isn't bound to the Crossroads any more than you. You may always return as long as you're welcome here, and I think he shall."
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutOdysseusWandering01"
    }
    {
      Id = "Icarus_0466"
      InheritFrom = "BaseNarrative"
      DisplayName = "Like how you visited your family and still returned..."
      Speaker = "Icarus"
      Event = "IcarusHomeAboutOdysseusWandering01"
    }
    {
      Id = "Melinoe_4867"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Exactly right."
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutOdysseusWandering01"
    }
    {
      Id = "Icarus_0174"
      InheritFrom = "BaseNarrative"
      DisplayName = "Tall fellow over there by that big tapestry type thing... isn't that {#Emph}Doom? {#Prev}Seems friendlier than I imagined, judging by the way the two of you were getting on."
      Speaker = "Icarus"
      Event = "IcarusHomeAboutMoros01"
    }
    {
      Id = "Melinoe_4528"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lord Moros is our guest, and that tapestry beside him holds the will of the Three Fates. His family's in a similar predicament to mine. Would you like to meet him?"
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutMoros01"
    }
    {
      Id = "Icarus_0175"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, {#Emph}no{#Prev}, we, {#Emph}erm{#Prev}... we've met before. Though I don't think he would remember me. It's for the best! I just didn't expect to see him again... let alone here. I'm glad he's all right!"
      Speaker = "Icarus"
      Event = "IcarusHomeAboutMoros01"
    }
    {
      Id = "Melinoe_0061_B"
      InheritFrom = "BaseSubtitle"
      DisplayName = "He is."
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutMoros01"
    }
    {
      Id = "Melinoe_4528_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lord Moros is our guest, and that tapestry beside him holds the will of the Three Fates. Would you like to meet him?"
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutMoros01_B"
    }
    {
      Id = "Icarus_0452"
      InheritFrom = "BaseNarrative"
      DisplayName = "I sometimes think of what it's like being a god. Ever wonder what your life would have been like if you were mortal, hey? You probably would have wound up in Elysium."
      Speaker = "Icarus"
      Event = "IcarusHomeAboutMortality01"
    }
    {
      Id = "Melinoe_4858"
      InheritFrom = "BaseNarrative"
      DisplayName = "Among the greatest heroes of your kind? I'm not so certain about that. If I were born mortal, I suppose... I would have worked at something all my life. Attempted to excel beyond my means and those of anybody else."
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutMortality01"
    }
    {
      Id = "Icarus_0453"
      InheritFrom = "BaseNarrative"
      DisplayName = "Meli, that's almost as depressing as my life, and I didn't get to choose. Most mortals work only to earn their keep... but it's the pleasures that we want, not the toil."
      Speaker = "Icarus"
      Event = "IcarusHomeAboutMortality01"
    }
    {
      Id = "Melinoe_4859"
      InheritFrom = "BaseNarrative"
      DisplayName = "Truly? Yet here you are as a Shade, seeking to outdo your own master-artisan father at his craft, while battling against the Titan's legions. To earn your keep?"
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutMortality01"
    }
    {
      Id = "Icarus_0454"
      InheritFrom = "BaseNarrative"
      DisplayName = "All right I see your point, sorry. That was the mortal impulse to tell others how to live. But we rarely find our own sense of purpose, much less anyone else's. I wonder what you would have excelled at..."
      Speaker = "Icarus"
      Event = "IcarusHomeAboutMortality01"
    }
    {
      Id = "Melinoe_4860"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Arguing, perhaps? As lawyer or a judge."
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutMortality01"
    }
    {
      Id = "Icarus_0455"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...That's... terrifying."
      Speaker = "Icarus"
      Event = "IcarusHomeAboutMortality01"
    }
    {
      Id = "Icarus_0442"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's funny... we mortals go through life searching for that one other soul with whom we want to spend the rest of our nights; a love that lasts forever, but... we're really talking maybe thirty, forty years. Must be so different for the gods."
      Speaker = "Icarus"
      Event = "IcarusHomeAboutRelationships01"
    }
    {
      Id = "Melinoe_4850"
      InheritFrom = "BaseNarrative"
      DisplayName = "To want for all of someone's love... it seems so selfish. Nemesis would surely disapprove. My understanding is we all have varying capacity for different types of love. In fact I think I've quite a bit for you now, Icarus."
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutRelationships01"
    }
    {
      Id = "Icarus_0443"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've quite a bit, wait you mean {#Emph}love{#Prev}, for {#Emph}me? {#Prev}Even though there must be others whom you fancy around here, in that primary-type-of-love sort of way. But what if... I have all this love for {#Emph}you{#Prev}, and no one else...?"
      Speaker = "Icarus"
      Event = "IcarusHomeAboutRelationships01"
    }
    {
      Id = "Melinoe_4851"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then I am very fortunate, though also I think you must have much more to give. And you've eternity to find all those who deserve it. I alone shall have to do for now."
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutRelationships01"
    }
    {
      Id = "Icarus_0444"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're more than enough for me, Meli."
      Speaker = "Icarus"
      Event = "IcarusHomeAboutRelationships01"
    }
    {
      Id = "Melinoe_4852"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Perhaps."
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutRelationships01"
    }
    {
      Id = "Icarus_0420"
      InheritFrom = "BaseNarrative"
      DisplayName = "The storm that had been covering the top of Mount Olympus cleared up...! I figured I'd finally get to see Typhon, but {#Emph}no! {#Prev}What happened there?"
      Speaker = "Icarus"
      Event = "IcarusHomeAboutTyphonDeath01"
    }
    {
      Id = "Melinoe_4844"
      InheritFrom = "BaseNarrative"
      DisplayName = "The storm is gone because Typhon himself is gone. He seemed to be growing angrier each passing night. It was either him, or my family and their home."
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutTyphonDeath01"
    }
    {
      Id = "Icarus_0421"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're kidding me! He's gone as in, he's gone? Not hiding, dormant, nothing of the sort? {#Emph}Well! {#Prev}That's {#Emph}great! {#Prev}What are you doing here, though? You ought to be feasting with the rest of the Olympians right now!"
      Speaker = "Icarus"
      Event = "IcarusHomeAboutTyphonDeath01"
    }
    {
      Id = "Melinoe_4845"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Need to take care of a few things."
      Speaker = "Melinoe"
      Event = "IcarusHomeAboutTyphonDeath01"
    }
    {
      Id = "Icarus_0422"
      InheritFrom = "BaseNarrative"
      DisplayName = "The war with Chronos, it's really {#Emph}over{#Prev}, hey? The energy about this place is different, tension's gone, the other Shades practically bouncing up and down! You {#Emph}did {#Prev}it...!"
      Speaker = "Icarus"
      Event = "IcarusHomePostTrueEnding01"
    }
    {
      Id = "Melinoe_4846"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps, but... there's still more to be done. Preventative measures to ensure what happened never can occur again."
      Speaker = "Melinoe"
      Event = "IcarusHomePostTrueEnding01"
    }
    {
      Id = "Icarus_0423"
      InheritFrom = "BaseNarrative"
      DisplayName = "Meli, can't you give yourself a break? Your task is finally complete! What are you going to do now, with the whole rest of your existence ahead of you?"
      Speaker = "Icarus"
      Event = "IcarusHomePostTrueEnding01"
    }
    {
      Id = "Melinoe_4847"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I said there's still more to be done."
      Speaker = "Melinoe"
      Event = "IcarusHomePostTrueEnding01"
    }
    {
      Id = "Icarus_0424"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I didn't mean... sorry."
      Speaker = "Icarus"
      Event = "IcarusHomePostTrueEnding01"
    }
    {
      Id = "Icarus_0427"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know, I thought that once Chronos was out and the Underworld King and Queen were back, you'd have to join them in the House of Hades. Be the princess you were always meant to be."
      Speaker = "Icarus"
      Event = "IcarusHomePostTrueEnding02"
    }
    {
      Id = "Melinoe_4848"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd like to think I already am that. My father's House is truly something to behold, but {#Emph}this {#Prev}is home, not there. And I'll be seeing my parents and brother frequently enough, I think."
      Speaker = "Melinoe"
      Event = "IcarusHomePostTrueEnding02"
    }
    {
      Id = "Icarus_0428"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, {#Emph}right! {#Prev}How was it meeting Zagreus? He live up to all the hushed tales of his prowess and all that?"
      Speaker = "Icarus"
      Event = "IcarusHomePostTrueEnding02"
    }
    {
      Id = "Melinoe_4849"
      InheritFrom = "BaseSubtitle"
      DisplayName = "If I told you, I'd have to slay you."
      Speaker = "Melinoe"
      Event = "IcarusHomePostTrueEnding02"
    }
    {
      Id = "Icarus_0429"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hah! {#Prev}Well, all right!"
      Speaker = "Icarus"
      Event = "IcarusHomePostTrueEnding02"
    }
    {
      Id = "Icarus_0447"
      InheritFrom = "BaseNarrative"
      DisplayName = "Been hearing Shades say something's changing on Olympus... that the Fates themselves decided that the gods will soon be ruling with a lighter touch? That sounds... {#Emph}different."
      Speaker = "Icarus"
      Event = "IcarusHomePostEpilogue01"
    }
    {
      Id = "Melinoe_4856"
      InheritFrom = "BaseNarrative"
      DisplayName = "I think {#Emph}soon {#Prev}there may be relative to gods not mortals, but... what I've heard is much the same. At the dawn of the new age, mortals are to choose their paths themselves."
      Speaker = "Melinoe"
      Event = "IcarusHomePostEpilogue01"
    }
    {
      Id = "Icarus_0448"
      InheritFrom = "BaseNarrative"
      DisplayName = "An age where neither the gods nor the Fates are dictating each moment of our lives, or deaths. Hard to imagine. Who would we even blame if things went wrong then, hey?"
      Speaker = "Icarus"
      Event = "IcarusHomePostEpilogue01"
    }
    {
      Id = "Melinoe_4857"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You'll find someone I'm sure!"
      Speaker = "Melinoe"
      Event = "IcarusHomePostEpilogue01"
    }
    {
      Id = "Melinoe_4853"
      InheritFrom = "BaseNarrative"
      DisplayName = "Icarus, when did you realize your father wasn't who you thought? Sounds like you grew up always wanting to live up to his idea of you, though at some point you stopped."
      Speaker = "Melinoe"
      Event = "IcarusHomePostEpilogue02"
    }
    {
      Id = "Icarus_0445"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, it was probably when I found him after I died. He looked {#Emph}so {#Prev}disappointed; I genuinely thought he was upset I broke his precious wings. Kept working for him, though."
      Speaker = "Icarus"
      Event = "IcarusHomePostEpilogue02"
    }
    {
      Id = "Melinoe_4854"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I see. Headmistress, she was like a mother to me, but... she always went out of her way to tell me she was not. I never really understood why."
      Speaker = "Melinoe"
      Event = "IcarusHomePostEpilogue02"
    }
    {
      Id = "Icarus_0446"
      InheritFrom = "BaseNarrative"
      DisplayName = "You love her, I know that. And she put you through a lot, I know that too! If somebody is such a big part of your life for long enough, eventually it gets a bit complicated, hey?"
      Speaker = "Icarus"
      Event = "IcarusHomePostEpilogue02"
    }
    {
      Id = "Melinoe_4855"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well, I suppose..."
      Speaker = "Melinoe"
      Event = "IcarusHomePostEpilogue02"
    }
    {
      Id = "Melinoe_4574"
      InheritFrom = "BaseNarrative"
      DisplayName = "Icarus, you look... the Ectoplasmic Draught. You used it, and it worked...! Can I... is it all right if I...?"
      Speaker = "Melinoe"
      Event = "IcarusBecomingCloser01"
    }
    {
      Id = "Icarus_0356"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I was about to ask you the same thing. This is like {#Emph}nothing {#Prev}I've experienced since I was alive! And not even {#Emph}then! {#Prev}I took it all for granted then..."
      Speaker = "Icarus"
      Event = "IcarusBecomingCloser01"
    }
    {
      Id = "Melinoe_4576"
      InheritFrom = "BaseNarrative"
      DisplayName = "What makes tonight so special anyhow? I thought you were going to save the Draught for some sort of once-in-an-eternity occasion."
      Speaker = "Melinoe"
      Event = "IcarusBecomingCloser01"
    }
    {
      Id = "Icarus_0357"
      InheritFrom = "BaseNarrative"
      DisplayName = "I thought about that. And then I thought about how if I could just {#Emph}touch {#Prev}you, that would make for such an occasion for me. And then I realized, I didn't want to wait. I drank the Draught once I knew you were here. It wasn't bad!"
      Speaker = "Icarus"
      Event = "IcarusBecomingCloser01"
    }
    {
      Id = "Melinoe_4577"
      InheritFrom = "BaseNarrative"
      DisplayName = "You swore you'd take this slow. What if I couldn't speak to you tonight? The Draught would have gone to waste!"
      Speaker = "Melinoe"
      Event = "IcarusBecomingCloser01"
    }
    {
      Id = "Icarus_0358"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're right, you're right, it's just... you're {#Emph}here{#Prev}, and... I can feel my racing heart. Meli, may I... hold you in my arms?"
      Speaker = "Icarus"
      Event = "IcarusBecomingCloser01"
    }
    {
      Id = "Melinoe_4579"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Goodbye..."
      Speaker = "Melinoe"
      Event = "IcarusBecomingCloser01"
    }
    {
      Id = "Melinoe_4583"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Fly free and live, Icarus."
      Speaker = "Melinoe"
      Event = "IcarusBecomingCloser01"
    }
    {
      Id = "Melinoe_4578"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I just don't want to go too far, as we each have before. The side effects could be exacerbated, and... like you, I couldn't bear the thought. I think it may be best if you experienced the cold wind and the spray of the sea while you still can."
      Speaker = "Melinoe"
      Event = "IcarusBecomingCloser01"
    }
    {
      Id = "Icarus_0359"
      InheritFrom = "BaseNarrative"
      DisplayName = "I do want to get to that. And I did get to take you by the hand. I'd stay here forever if I could but I had better make the most of this since it won't last. So bye for now, Meli."
      Speaker = "Icarus"
      Event = "IcarusBecomingCloser01"
    }
    {
      Id = "Melinoe_4580"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I'd like for you to do that very much. You may experience strange sensations but I'll be as gentle as I can. Please let me know if you start having discomfort of any kind."
      Speaker = "Melinoe"
      Event = "IcarusBecomingCloser01"
    }
    {
      Id = "Melinoe_4581"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Sigh> {#Prev}It's nice, the beating of your heart. And you're still very warm, you know. If not for that, I might take you for dead! You've not moved, not spoken... you all right?"
      Speaker = "Melinoe"
      Event = "IcarusBecomingCloser01"
    }
    {
      Id = "Icarus_0361"
      InheritFrom = "BaseNarrative"
      DisplayName = "...This must be what Elysium is like... Meli, I'm {#Emph}far {#Prev}more than all right, I'm — I'm just taking in each moment as I can. What about you? That you're still here I think is a good sign...?"
      Speaker = "Icarus"
      Event = "IcarusBecomingCloser01"
    }
    {
      Id = "Melinoe_4582"
      InheritFrom = "BaseNarrative"
      DisplayName = "You may take it as such. But, {#Emph}oh{#Prev}, you're getting colder now, and... the pallor of your skin is starting to change. The Draught is losing its effect. If you hurry, you still could feel that cold wind and the spray of the sea!"
      Speaker = "Melinoe"
      Event = "IcarusBecomingCloser01"
    }
    {
      Id = "Icarus_0362"
      InheritFrom = "BaseNarrative"
      DisplayName = "I would much rather stay with you right here... but I don't wish to keep you, and I'll probably regret not taking flight like this while I still can. You're wonderful, Meli."
      Speaker = "Icarus"
      Event = "IcarusBecomingCloser01"
    }
    {
      Id = "Icarus_0244"
      InheritFrom = "BaseNarrative"
      DisplayName = "As far as I can tell, the number of warships headed for Olympus has remained roughly the same night after night. Their mission doesn't seem to be affected in the slightest."
      Speaker = "Icarus"
      Event = "IcarusWithOdysseus01"
    }
    {
      Id = "Odysseus_0436"
      InheritFrom = "BaseNarrative"
      DisplayName = "Their aim is to cut off the waterways and spread the limited attention of Olympus thin. Continue to disrupt them as you can, my lad. Though if the Harpies flock too thick, fall back."
      Speaker = "Odysseus"
      Event = "IcarusWithOdysseus01"
    }
    {
      Id = "Icarus_0245"
      InheritFrom = "BaseNarrative"
      DisplayName = "You got it, sir! Those ships are ill-equipped against attackers from the sky, and the Harpies haven't caught up with me yet. All right, I'm off!"
      Speaker = "Icarus"
      Event = "IcarusWithOdysseus01"
    }
    {
      Id = "Odysseus_0437"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Good hunting out there!"
      Speaker = "Odysseus"
      Event = "IcarusWithOdysseus01"
    }
    {
      Id = "Odysseus_0705"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Anyhow, my lad, you're doing fine. You can't always know where you're going, but you {#Emph}can {#Prev}have a sense for whether you're headed in the general direction you desire. And don't be in such a hurry to get there if you can help it."
      Speaker = "Odysseus"
      Event = "IcarusWithOdysseus02"
    }
    {
      Id = "Icarus_0467"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've not gone anywhere, though, sir. I thought if I could just learn how to fly, I'd finally be able to go wherever I pleased. But the farther away I got, the more I wanted to come back! What was the use? I'm still not sure."
      Speaker = "Icarus"
      Event = "IcarusWithOdysseus02"
    }
    {
      Id = "Odysseus_0706"
      InheritFrom = "BaseNarrative"
      DisplayName = "The use was to find where you belonged. If you never left, you would have always wondered what else was out there for you. You returned with the wisdom of that experience."
      Speaker = "Odysseus"
      Event = "IcarusWithOdysseus02"
    }
    {
      Id = "Icarus_0468"
      InheritFrom = "BaseNarrative"
      DisplayName = "So the more we wander, the wiser we get, hey? Except I'm speaking to the Great Tactician. I hardly think I've learned more flying about out {#Emph}there {#Prev}than I could have from {#Emph}you."
      Speaker = "Icarus"
      Event = "IcarusWithOdysseus02"
    }
    {
      Id = "Odysseus_0707"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll take the wings if you don't want them, lad."
      Speaker = "Odysseus"
      Event = "IcarusWithOdysseus02"
    }
    {
      Id = "Icarus_0469"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No chance, sir!"
      Speaker = "Icarus"
      Event = "IcarusWithOdysseus02"
    }
    {
      Id = "Icarus_0470"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I was just, {#Emph}eh{#Prev}, picking up a bit. Didn't mean to bother you, Goddess, {#Emph}erm... {#Prev}Hey! I like your wings! Mine aren't real. Though, I had an earlier pair made with real feathers, more like yours... but not nearly as good."
      Speaker = "Icarus"
      Event = "IcarusWithEris01"
    }
    {
      Id = "Eris_0363"
      InheritFrom = "BaseNarrative"
      DisplayName = "How 'bout next time you see my stuff, you leave it be, all right there, baby bird? Now get out of my face and don't go tripping on your tongue on your way up!"
      Speaker = "Eris"
      Event = "IcarusWithEris01"
    }
    {
      Id = "Icarus_0471"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Sounds good! I'm off. {#Emph}Goodbye!"
      Speaker = "Icarus"
      Event = "IcarusWithEris01"
    }
    {
      Id = "Eris_0364"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Bye now!"
      Speaker = "Eris"
      Event = "IcarusWithEris01"
    }
    {
      Id = "Icarus_0475"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Also, I wanted to give thanks to you, Madam. For taking me in and letting me return; and for entrusting anything to me! Most Shades are not so fortunate."
      Speaker = "Icarus"
      Event = "IcarusWithHecate01"
    }
    {
      Id = "Hecate_0877"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, do not grovel, Icarus, lest I cast you out. These are the Crossroads, not Elysium! A Shade's existence here may be comparatively difficult... and few remain for long."
      Speaker = "Hecate"
      Event = "IcarusWithHecate01"
    }
    {
      Id = "Icarus_0476"
      InheritFrom = "BaseNarrative"
      DisplayName = "I appreciate having the work to do, and being a part of this. Although, sometimes just after taking off, I fear I won't be able to find my way back..."
      Speaker = "Icarus"
      Event = "IcarusWithHecate01"
    }
    {
      Id = "Hecate_0878"
      InheritFrom = "BaseNarrative"
      DisplayName = "Discard that fear. Those with the need or who remain in our good graces always shall be welcome here and safe."
      Speaker = "Hecate"
      Event = "IcarusWithHecate01"
    }
    {
      Id = "Icarus_0477"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm grateful. And, I'll be going! Cheers, Madam!"
      Speaker = "Icarus"
      Event = "IcarusWithHecate01"
    }
    {
      Id = "Icarus_0182"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nice seeing you again, Meli. I'm taking off, though I'll be sure to keep an eye out for you up there."
      Speaker = "Icarus"
      Event = "IcarusHomeChat01"
    }
    {
      Id = "Icarus_0183"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you decide to head up to the surface tonight, maybe I'll see you, hey?"
      Speaker = "Icarus"
      Event = "IcarusHomeChat02"
    }
    {
      Id = "Icarus_0184"
      InheritFrom = "BaseNarrative"
      DisplayName = "Cheers to you all for welcoming me back, and always nice to see {#Emph}you {#Prev}here."
      Speaker = "Icarus"
      Event = "IcarusHomeChat03"
    }
    {
      Id = "Icarus_0185"
      InheritFrom = "BaseNarrative"
      DisplayName = "Time to get back into the fight, hey Meli? I'll go on ahead and see what I can do."
      Speaker = "Icarus"
      Event = "IcarusHomeChat04"
    }
    {
      Id = "Icarus_0186"
      InheritFrom = "BaseNarrative"
      DisplayName = "At least I'm getting better at my landings and takeoffs here. Want to see?"
      Speaker = "Icarus"
      Event = "IcarusHomeChat05"
    }
    {
      Id = "Icarus_0258"
      InheritFrom = "BaseNarrative"
      DisplayName = "I had to stop in for additional supplies, and possibly to say hello. And now I'm off!"
      Speaker = "Icarus"
      Event = "IcarusHomeChat06"
    }
    {
      Id = "Icarus_0259"
      InheritFrom = "BaseNarrative"
      DisplayName = "Be on the lookout for my Hammers out there, hey? I hope they've been of help."
      Speaker = "Icarus"
      Event = "IcarusHomeChat07"
    }
    {
      Id = "Icarus_0260"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know it's not the time to chat for long, though even just a little like this helps."
      Speaker = "Icarus"
      Event = "IcarusHomeChat08"
    }
    {
      Id = "Icarus_0261"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just finished patching up these wings! And now to put them to the test again."
      Speaker = "Icarus"
      Event = "IcarusHomeChat09"
    }
    {
      Id = "Icarus_0262"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's funny, I start getting restless whenever I'm not putting these wings to good use."
      Speaker = "Icarus"
      Event = "IcarusHomeChat10"
    }
    {
      Id = "Icarus_0263"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wanted to say hello before I took off for the night. Take care then, hey?"
      Speaker = "Icarus"
      Event = "IcarusHomeChat11"
    }
    {
      Id = "Icarus_0264"
      InheritFrom = "BaseNarrative"
