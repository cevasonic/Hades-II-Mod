    {
      Id = "Storyteller_0103"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Again sets forth the Princess of the Dead..."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerRunStartVoiceLines"
    }
    {
      Id = "Storyteller_0104"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Once more the Princess sets upon her task."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerRunStartVoiceLines"
    }
    {
      Id = "Storyteller_0105"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Thus the relentless Princess starts again."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerRunStartVoiceLines"
    }
    {
      Id = "Storyteller_0106"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}She steps into the fetid surface air..."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerRunStartVoiceLines"
    }
    {
      Id = "Storyteller_0363"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}After the fury of that battle, calm."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerFightReactionVoiceLines"
    }
    {
      Id = "Storyteller_0364"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Again her foes are utterly destroyed."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerFightReactionVoiceLines"
    }
    {
      Id = "Storyteller_0366"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Her victory achieved, she presses on."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerFightReactionVoiceLines"
    }
    {
      Id = "Storyteller_0368"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Few traces of her cruel foes remain."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerFightReactionVoiceLines"
    }
    {
      Id = "Storyteller_0370"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Another battle fought with skill and grace."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerFightReactionVoiceLines"
    }
    {
      Id = "Storyteller_0362"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}The Titan's forces, shattered at her feet."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerFightReactionVoiceLines"
    }
    {
      Id = "Storyteller_0369"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}She stands alone, unless you count her pet."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerFightReactionVoiceLines"
    }
    {
      Id = "Storyteller_0371"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Her foes did not so much as touch her in that bout."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerFightReactionVoiceLines"
    }
    {
      Id = "Storyteller_0374"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}The worst of Erebus, fallen like leaves."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerFightReactionVoiceLines"
    }
    {
      Id = "Storyteller_0375"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}The deadliest of Oceanus, gone."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerFightReactionVoiceLines"
    }
    {
      Id = "Storyteller_0376"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}The Daemons of the Mourning Fields, dispersed."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerFightReactionVoiceLines"
    }
    {
      Id = "Storyteller_0377"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Even the Titan's strongest Satyrs were no match."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerFightReactionVoiceLines"
    }
    {
      Id = "Storyteller_0378"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}A captain of the Titan's guard, vanquished."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerFightReactionVoiceLines"
    }
    {
      Id = "Storyteller_0379"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}That fearsome maw retreats into the depths."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerFightReactionVoiceLines"
    }
    {
      Id = "Storyteller_0380"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}That dreaded sailor, driven to the depths."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerFightReactionVoiceLines"
    }
    {
      Id = "Storyteller_0381"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}One fewer countless dangers on the mountaintop."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerFightReactionVoiceLines"
    }
    {
      Id = "Storyteller_0382"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}The greatest of Automatons, destroyed."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerFightReactionVoiceLines"
    }
    {
      Id = "Storyteller_0383"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Monstrous Typhon's hateful brood, repelled."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerFightReactionVoiceLines"
    }
    {
      Id = "Storyteller_0058"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Whither goes the Princess, so shall I."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerFightReactionVoiceLines"
    }
    {
      Id = "Storyteller_0072"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}The Princess calls into the dark, to no avail."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerFightReactionVoiceLines"
    }
    {
      Id = "Storyteller_0075"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hail Princess, light of the Moon."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerFightReactionVoiceLines"
    }
    {
      Id = "Storyteller_0365"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}None can escape the Princess of the Dead."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerFightReactionVoiceLines"
    }
    {
      Id = "Storyteller_0367"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Shades of the dead, her only witnesses."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerFightReactionVoiceLines"
    }
    {
      Id = "Storyteller_0372"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}All is quiet once again, for now."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerFightReactionVoiceLines"
    }
    {
      Id = "Storyteller_0373"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Now only death and the Princess remain."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerFightReactionVoiceLines"
    }
    {
      Id = "Storyteller_0408"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Thus she returns to the Ephyra square."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerReturnToHubVoiceLines"
    }
    {
      Id = "Storyteller_0409"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Steadily, she retraces her steps."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerReturnToHubVoiceLines"
    }
    {
      Id = "Storyteller_0410"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Her work here for the night is done."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerReturnToHubVoiceLines"
    }
    {
      Id = "Storyteller_0411"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Back to the heart of the necropolis."
      Speaker = "Storyteller"
      Event = "GlobalVoiceLines.StorytellerReturnToHubVoiceLines"
    }
    {
