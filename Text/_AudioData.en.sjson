      DisplayName = "The Verminancer's back, is he...?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_1614"
      InheritFrom = "BaseSubtitle"
      DisplayName = "One of the leaders of this Satyr cult..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_1615"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Best keep your rodents to yourself!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_1620"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A Goldwrath...!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_1621"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Are you how Chronos gets his gold?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_1622"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come on, Goldwrath!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_1623"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Let's go you sack of filth!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_1624"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh great, the treasury..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_1625"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Found the treasury..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "Melinoe_1008"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Death to the servants of Chronos!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_0467"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A champion of Chronos...!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_0468"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No mercy for servants of the Titan...!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_0469"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll send your soul into the depths of hell."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_0470"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Are you the Satyr currently in charge?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_0471"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This city belongs to the mortals...!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_0472"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Let this be a message to your lord!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_3142"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Now there's a seasoned sailor..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_3143"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Back for another voyage, Captain?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_3144"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm commandeering this vessel!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_3145"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Looks like you have a stowaway, Captain!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_3146"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll run this blasted ship aground!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_3147"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You'll soon sail back to hell."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2616"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A Dracon of that size? And serving Chronos too..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2617"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Best use those wings to fly away, Dracon!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2618"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You Dracons ought to choose wiser alliances."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2619"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Soon you shall be afraid of me, Dracon."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2620"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not had enough of me, Dracon?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2957"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's... gods...!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_3006"
      InheritFrom = "BaseSubtitle"
      DisplayName = "One of Typhon's broodlings..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_3007"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You've got your father's looks..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_3008"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're one of Typhon's bigger children aren't you."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_3009"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That broodling again..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_3010"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It's that broodling... or a twin?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_3132"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You two appear well-fed..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_3133"
      InheritFrom = "BaseSubtitle"
      DisplayName = "These two again."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_3134"
      InheritFrom = "BaseSubtitle"
      DisplayName = "These two again? Or two just like the rest."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_3135"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You two get along quite well for twins."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_3136"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I don't like either one of you."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_0682"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ah, yes."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterMiscStartLines"
    }
    {
      Id = "MelinoeField_0683"
      InheritFrom = "BaseNarrative"
      DisplayName = "This again."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterMiscStartLines"
    }
    {
      Id = "MelinoeField_0684"
      InheritFrom = "BaseNarrative"
      DisplayName = "Let's begin...!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterMiscStartLines"
    }
    {
      Id = "MelinoeField_0685"
      InheritFrom = "BaseNarrative"
      DisplayName = "Let's go, then."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterMiscStartLines"
    }
    {
      Id = "MelinoeField_0686"
      InheritFrom = "BaseNarrative"
      DisplayName = "You and me...!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterMiscStartLines"
    }
    {
      Id = "MelinoeField_0687"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've returned."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterMiscStartLines"
    }
    {
      Id = "MelinoeField_0688"
      InheritFrom = "BaseNarrative"
      DisplayName = "You won't stop me."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterMiscStartLines"
    }
    {
      Id = "MelinoeField_0689"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm back."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterMiscStartLines"
    }
    {
      Id = "Melinoe_1005"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Foul spirit."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "Melinoe_1006"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Go haunt some other glade."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "Melinoe_0999"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Got you."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "Melinoe_1000"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Done."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "Melinoe_1001"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Enough."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "Melinoe_1002"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Whew."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "Melinoe_1639"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Back to the dark with you."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "Melinoe_1640"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It's clear again..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "Melinoe_1641"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Such rage it must have felt..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "Melinoe_1642"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It's gone..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "Melinoe_1643"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Detest that thing..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "Melinoe_1644"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The shadows dissipate..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3702"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...And here your soul shall stay."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3703"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll not fall to some hired thug."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3704"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Whatever you were paid was not enough."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3705"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Your little plan to slay me backfired."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3706"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You should have stayed up top."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_0165"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Took me for simple prey."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_0167"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Out with you, serpent."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_0168"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Stick to the seas next time."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_0169"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hideous thing..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3022"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...I can sting too."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3023"
      InheritFrom = "BaseSubtitle"
      DisplayName = "These always grow back..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3024"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Too much squirming."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3025"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Your place is out at sea."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3026"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Squish."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_1123"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's enough slithering about..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_1124"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Venomous fiends."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_1125"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll cast you out each time."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_1126"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Crude sorcery at best."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_1127"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I usually like snakes..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_1134"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Drink {#Emph}that {#Prev}up."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_1135"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Phantoms, begone..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_1136"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How many mortals have you tormented?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_1137"
      InheritFrom = "BaseSubtitle"
      DisplayName = "They won't be gone for long..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_1138"
      InheritFrom = "BaseSubtitle"
      DisplayName = "All banished for now..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_1139"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No blood where you're going."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_1616"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Your master will fare no better."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_1617"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Traitorous wretch."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_1618"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Good riddance..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_1619"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Eugh{#Prev}, that {#Emph}stench..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_1626"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Where does Chronos find these things..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_1627"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Melted down."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_1628"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I much prefer silver..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_1629"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not losing to a {#Emph}bag..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_1630"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Who needs Gold anyway..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_0473"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Your soul be damned, traitor."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_0474"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You chose the wrong side."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_0475"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Another night, another Satyr slaughtered."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_0476"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I look forward to meeting your replacement."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_0477"
      InheritFrom = "BaseSubtitle"
      DisplayName = "For Ephyra."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_0478"
      InheritFrom = "BaseSubtitle"
      DisplayName = "For Olympus."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "Melinoe_1009"
      InheritFrom = "BaseSubtitle"
      DisplayName = "One less traitor."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3713"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You ought to be at rest."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3714"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Peace, Spirit."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3715"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Now calm yourself, Spirit."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3716"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Let go your rage, Spirit."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3712"
      InheritFrom = "BaseSubtitle"
      DisplayName = "If Heracles could handle it..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3148"
      InheritFrom = "BaseSubtitle"
      DisplayName = "May this be your final voyage for a while."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3149"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll take the helm from here."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3150"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The sea claims another."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3151"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Are all sailors as surly as that one?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3152"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Are all sailors as salty as that one?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3153"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Enjoy Poseidon's depths."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3154"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're sunk, Yargonaut."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_1866"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You'll soon be back for more, won't you?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_1868"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Don't get in my way."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_1871"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Drove it away for now..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_1870"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How many ships have fallen in that maw?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_1869"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Tell Scylla I said {#Emph}hi."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_1867"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's for Odysseus and his crew."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_2474"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What did he take me for?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_2475"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Mindless machinery and nothing more."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_2476"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Probably took me for a Harpy or something."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_2477"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Another unfortunate misunderstanding."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_2478"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Save it for Prometheus next time."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_2479"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You picked the wrong target."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_2621"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I much prefer Dracons that cannot fly..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_2622"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This mountain's for the gods."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_2623"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How is Chronos controlling those..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_2624"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A magnificent beast, but a threat..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_2625"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Olympus is no place for such monstrosities..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3301"
      InheritFrom = "BaseSubtitle"
      DisplayName = "All these monstrosities... oh, no..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3011"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Foul creature..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3013"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Eugh{#Prev}, that is a {#Emph}stench..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3014"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Go cry to your father."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3015"
      InheritFrom = "BaseSubtitle"
      DisplayName = "One less of Typhon's brood."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3016"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What a brute..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3012"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Children can be such a nuisance, so they say."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3137"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not so easy to hunt down, was I?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3138"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Stay in the ground next time."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3141"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Now this fortress is your grave."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3139"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Your father shall be hearing about this."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3140"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll deal with your father next."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3300"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That monster, that was... {#Emph}Typhon..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3241"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Retreated..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3242"
      InheritFrom = "BaseSubtitle"
      DisplayName = "See you again shortly."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3243"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It fell back..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3244"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Drove it back..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3245"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just his tail..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3246"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just his tail... one of them..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3691"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It's improper to stare."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3692"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Properly disgusting."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3693"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Should have stayed shut."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3694"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How many more of those does Typhon have..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_3695"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That was vile..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_2955"
      InheritFrom = "BaseSubtitle"
      DisplayName = "These are... eggs..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_2952"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The walls are... breathing..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_2954"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This is all... one being..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_0690"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Out of my sight..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_0691"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Out with you."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_0692"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Mindless wretch."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_0693"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's what you get."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_0694"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We're settled."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_0695"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Until we meet again."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_0696"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Remember that."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_0697"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We'll have to do this again."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "Melinoe_0861"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You with me, Homer?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "Melinoe_0862"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Ready, Homer?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "Melinoe_0863"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Let's go, Homer."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "Melinoe_0864"
      InheritFrom = "BaseSubtitle"
      DisplayName = "See that, Homer?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "Melinoe_1130"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You there, Homer?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "Melinoe_1131"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What say you, Homer?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "Melinoe_1133"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come along, Homer."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "Melinoe_1134"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Say something, Homer?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "Melinoe_1531"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Keep up, Homer."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MiniBossEncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_0170"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Erm..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.CrawlerMiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_0171"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Why are you glaring at me like that, little one?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.CrawlerMiniBossEncounterStartVoiceLines"
    }
    {
      Id = "Melinoe_1925"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Uh-oh!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.CrawlerMiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_0172"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Have I offended in some way?!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.CrawlerMiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_0173"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh no."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.CrawlerMiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_0174"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You again."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.CrawlerMiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_0175"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The King Vermin...!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.CrawlerMiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_0176"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hail, O King."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.CrawlerMiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_0177"
      InheritFrom = "BaseSubtitle"
      DisplayName = "At last, a worthy opponent."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.CrawlerMiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_0178"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Have at you, King!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.CrawlerMiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2085"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Toula, time to shine."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.CrawlerMiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2086"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Toula, King Vermin."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.CrawlerMiniBossEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_1858"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That maw... there's no mistaking it."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.CharybdisEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_1860"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're going to let me pass!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.CharybdisEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_1863"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Feast on this {#Emph}ship{#Prev}, not me!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.CharybdisEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_3721"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Got some new tentacles I see!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.CharybdisEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_1859"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Charybdis, Devourer of Ships...!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.CharybdisEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_1861"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hungry for more, Charybdis?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.CharybdisEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_1862"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Back from the depths, I see."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.CharybdisEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_1864"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How many tentacles does this thing have...?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.CharybdisEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_1865"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You won't be stopping {#Emph}me{#Prev}, Charybdis!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.CharybdisEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2466"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Wow, you must be Talos. Please tell me you're smarter than the other Automatons around here?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.TalosEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2467"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll have to take that as an absolutely not!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.TalosEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2468"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Remember me, Talos? Or just attack me right away..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.TalosEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2470"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'd like a word with Lord Hephaestus about you."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.TalosEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2471"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You probably can't understand a word I say."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.TalosEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2473"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Perhaps I'll knock some sense into you yet."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.TalosEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2469"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm back to put you out of commission again."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.TalosEncounterStartVoiceLines"
    }
    {
      Id = "MelinoeField_2472"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Back in one piece, Talos?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.TalosEncounterStartVoiceLines"
    }
    {
      Id = "Melinoe_1388"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Heracles..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.FoundShopVoiceLines"
    }
    {
      Id = "Melinoe_1389"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Him again..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.FoundShopVoiceLines"
    }
