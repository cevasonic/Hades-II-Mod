      Event = "GlobalVoiceLines.BadgeUpgradedVoiceLines"
    }
    {
      Id = "Melinoe_5332"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hereby our rank is Specter I. We are darkness."
