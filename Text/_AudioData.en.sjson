      Event = "GlobalVoiceLines.BadgeUpgradedVoiceLines"
    }
    {
      Id = "Melinoe_5319"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}We are as Specters drifting in the dark. Let it thus be known!"
