      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.EliteEncounterClearedLines"
    }
    {
      Id = "MelinoeField_2764"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thank you, Selene."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.EliteEncounterClearedLines"
    }
    {
      Id = "MelinoeField_2765"
      InheritFrom = "BaseNarrative"
      DisplayName = "For Sister Selene."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.EliteEncounterClearedLines"
    }
    {
      Id = "MelinoeField_2766"
      InheritFrom = "BaseNarrative"
      DisplayName = "This is our Monument."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.EliteEncounterClearedLines"
    }
    {
      Id = "MelinoeField_2767"
      InheritFrom = "BaseNarrative"
      DisplayName = "I saw clear through my prey."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.EliteEncounterClearedLines"
    }
    {
      Id = "MelinoeField_2769"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}To be Unseen is to be unscathed."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.PerfectClearEncounterInitiatedLines"
    }
    {
      Id = "MelinoeField_2770"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}To be Unseen is to become as mist."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.PerfectClearEncounterInitiatedLines"
    }
    {
      Id = "MelinoeField_2771"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll slay you all without a scratch."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.PerfectClearEncounterInitiatedLines"
    }
    {
      Id = "MelinoeField_2772"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come catch me if you can..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.PerfectClearEncounterInitiatedLines"
    }
    {
      Id = "MelinoeField_2773"
      InheritFrom = "BaseNarrative"
      DisplayName = "Think you can catch me?"
