      Event = "GlobalVoiceLines.BadgeUpgradedVoiceLines"
    }
    {
      Id = "Melinoe_5331"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hereby our rank is Wraith I. We shall be feared."
