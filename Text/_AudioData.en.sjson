      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.PerfectClearGotHitVoiceLines"
    }
    {
      Id = "MelinoeField_2779"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Guh{#Prev}, they got me there..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.PerfectClearGotHitVoiceLines"
    }
    {
