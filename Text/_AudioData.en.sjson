    }
    {
      Id = "MelinoeField_2756"
      InheritFrom = "BaseNarrative"
      DisplayName = "Reveal yourself, whoever haunts this shrine."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.EliteEncounterInitiatedLines"
    }
    {
      Id = "MelinoeField_2757"
      InheritFrom = "BaseNarrative"
      DisplayName = "You cannot hide from us."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.EliteEncounterInitiatedLines"
    }
    {
      Id = "MelinoeField_2758"
      InheritFrom = "BaseNarrative"
      DisplayName = "Show yourself by the light of the Moon."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.EliteEncounterInitiatedLines"
    }
    {
      Id = "MelinoeField_2759"
      InheritFrom = "BaseNarrative"
      DisplayName = "What haunts this place, come forth!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.EliteEncounterInitiatedLines"
    }
    {
      Id = "MelinoeField_2760"
      InheritFrom = "BaseNarrative"
      DisplayName = "Selene, show my foe to me."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.EliteEncounterInitiatedLines"
    }
    {
      Id = "MelinoeField_2761"
      InheritFrom = "BaseNarrative"
      DisplayName = "Who dares disturb this Monument?"
