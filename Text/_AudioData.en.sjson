    {
      Id = "Melinoe_1260"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Aid from two relatives at once?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DevotionChoicePresentedVoiceLines"
    }
    {
      Id = "Melinoe_1261"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The gods and their petty squabbles..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DevotionChoicePresentedVoiceLines"
    }
    {
      Id = "Melinoe_1262"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Choose one, spurn the other..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DevotionChoicePresentedVoiceLines"
    }
    {
      Id = "Melinoe_1263"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Can't they form an orderly queue?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DevotionChoicePresentedVoiceLines"
    }
    {
      Id = "Melinoe_1264"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Whom to upset this time?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DevotionChoicePresentedVoiceLines"
    }
    {
      Id = "Melinoe_1265"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Wait, what?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.GodRejectedVoiceLines"
    }
    {
      Id = "Melinoe_1266"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Lord Uncle, I meant no offense."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.GodRejectedVoiceLines"
    }
    {
      Id = "Melinoe_1268"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Forgive me, Queen Hera."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.GodRejectedVoiceLines"
    }
    {
      Id = "Melinoe_1267"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm sorry, Uncle Poseidon."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.GodRejectedVoiceLines"
    }
    {
      Id = "Melinoe_1270"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Nothing personal, Cousin."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.GodRejectedVoiceLines"
    }
    {
      Id = "Melinoe_1271"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Please understand, Grandmother."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.GodRejectedVoiceLines"
    }
    {
      Id = "Melinoe_1269"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Sorry, Great-Auntie!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.GodRejectedVoiceLines"
    }
    {
      Id = "Melinoe_1272"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Don't hate me, Aphrodite?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.GodRejectedVoiceLines"
    }
    {
      Id = "MelinoeField_3038"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hephaestus, don't be mad..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.GodRejectedVoiceLines"
    }
    {
      Id = "MelinoeField_3039"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Is this what you want, Ares?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.GodRejectedVoiceLines"
    }
    {
      Id = "MelinoeField_3040"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Care for a fight, Ares?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.GodRejectedVoiceLines"
    }
    {
      Id = "Melinoe_1273"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I mean no disrespect..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.GodRejectedVoiceLines"
    }
    {
      Id = "Melinoe_1274"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We fickle gods..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.GodRejectedVoiceLines"
    }
    {
      Id = "Melinoe_1275"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Had to do it..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.GodRejectedVoiceLines"
    }
    {
      Id = "MelinoeField_2366"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Had to do it..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.GodRejectedVoiceLines"
    }
    {
      Id = "MelinoeField_2367"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Let's take it easy now..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.GodRejectedVoiceLines"
    }
    {
      Id = "MelinoeField_2368"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Sorry...!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.GodRejectedVoiceLines"
    }
    {
      Id = "MelinoeField_2369"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well here we go."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.GodRejectedVoiceLines"
    }
    {
      Id = "MelinoeField_2370"
