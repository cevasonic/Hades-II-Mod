{
  /*
  This file was autogenerated on 8/28/2025 at 6:02 PM
  by the BuildText tool.
  */
  lang = "en"
  Texts = [
    {
      Id = "Melinoe_1880"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Peace, Arachne."
      Speaker = "Melinoe"
      Event = "NPC_Arachne_01.InteractVoiceLines"
    }
    {
      Id = "Arachne_0157"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Be well, won't you?"
      Speaker = "Arachne"
      Event = "NPC_Arachne_01.InteractVoiceLines"
    }
    {
      Id = "Arachne_0158"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Take care out there."
      Speaker = "Arachne"
      Event = "NPC_Arachne_01.InteractVoiceLines"
    }
    {
      Id = "Arachne_0151"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And to you."
      Speaker = "Arachne"
      Event = "NPC_Arachne_01.InteractVoiceLines"
    }
    {
      Id = "Arachne_0152"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How do you do?"
      Speaker = "Arachne"
      Event = "NPC_Arachne_01.InteractVoiceLines"
    }
    {
      Id = "Arachne_0153"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thank you kindly."
      Speaker = "Arachne"
      Event = "NPC_Arachne_01.InteractVoiceLines"
    }
    {
      Id = "Arachne_0154"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh I know my way around."
      Speaker = "Arachne"
      Event = "NPC_Arachne_01.InteractVoiceLines"
    }
    {
      Id = "Arachne_0155"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Wherever we may go."
      Speaker = "Arachne"
      Event = "NPC_Arachne_01.InteractVoiceLines"
    }
    {
      Id = "Arachne_0156"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Appreciate the thought."
      Speaker = "Arachne"
      Event = "NPC_Arachne_01.InteractVoiceLines"
    }
    {
      Id = "Arachne_0159"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're awfully polite."
      Speaker = "Arachne"
      Event = "NPC_Arachne_01.InteractVoiceLines"
    }
    {
      Id = "Arachne_0160"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No need to be so formal here."
      Speaker = "Arachne"
      Event = "NPC_Arachne_01.InteractVoiceLines"
    }
    {
      Id = "Arachne_0161"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, {#Emph}you!"
      Speaker = "Arachne"
      Event = "NPC_Arachne_01.InteractVoiceLines"
    }
    {
      Id = "Arachne_0162"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come now."
      Speaker = "Arachne"
      Event = "NPC_Arachne_01.InteractVoiceLines"
    }
    {
      Id = "Arachne_0002"
      InheritFrom = "BaseNarrative"
      DisplayName = "What are you doing here? Besides tramping all over my webs, that is! Oh, it's nothing, silly. I can always make more perfectly good silk! I can't always see you."
      Speaker = "Arachne"
      Event = "ArachneFirstMeeting"
    }
    {
      Id = "Melinoe_0636"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Erm{#Prev}, hi, Arachne. Sorry about all this! I think we'll soon be seeing more of one another, now. My task has begun."
      Speaker = "Melinoe"
      Event = "ArachneFirstMeeting"
    }
    {
      Id = "Arachne_0003"
      InheritFrom = "BaseNarrative"
      DisplayName = "Truly? Why then, I'll get out of your hair, you have to go. But first, you {#Emph}have {#Prev}to try on one of these. And don't worry about any wear-and-tear! I've plenty more in stock, {#Emph}ha ha ha ha..."
      Speaker = "Arachne"
      Event = "ArachneFirstMeeting"
    }
    {
      Id = "Arachne_0118"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh no, you're hurt, my friend! And with such a long journey still ahead. Though don't you fret! My silk will make you feel as good as new."
      Speaker = "Arachne"
      Event = "ArachneLowHealth01"
    }
    {
      Id = "Arachne_0034"
      InheritFrom = "BaseNarrative"
      DisplayName = "My silk is everything to me! It's stronger than it looks. Keeps me safe! It can suffocate even the strongest prey. Don't you like it? Is there a certain pattern-color combination you admire?"
      Speaker = "Arachne"
      Event = "ArachneAboutSilk01"
    }
    {
      Id = "Melinoe_1806"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's lovely, Arachne. Look, I wish I could stay and admire it, but..."
      Speaker = "Melinoe"
      Event = "ArachneAboutSilk01"
    }
    {
      Id = "Arachne_0035"
      InheritFrom = "BaseNarrative"
      DisplayName = "...But you can't. I understand, I truly do. Though it {#Emph}would {#Prev}mean a lot to me if you would take some of my silk with you on your way."
      Speaker = "Arachne"
      Event = "ArachneAboutSilk01"
    }
    {
      Id = "MelinoeField_1785"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your silk is so luxurious, and the enchantments on the thread are strong. Arachne, it's incredible, really. You know that, right?"
      Speaker = "Melinoe"
      Event = "ArachneAboutSilk02"
    }
    {
      Id = "Arachne_0042"
      InheritFrom = "BaseNarrative"
      DisplayName = "Of course I know, my friend. While I may not be quite as strong as you, for my size, I'm something else. And I don't tire easily! As for the rest... trade secret, {#Emph}hah, ha ha ha ha..."
      Speaker = "Arachne"
      Event = "ArachneAboutSilk02"
    }
    {
      Id = "MelinoeField_1786"
      InheritFrom = "BaseNarrative"
      DisplayName = "There must be something I can do to repay you for all your hard work. We live modestly in the Crossroads, though we're not without our sources of supplies. Whatever you need, name it."
      Speaker = "Melinoe"
      Event = "ArachneAboutPay01"
    }
    {
      Id = "Arachne_0043"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well that's rather forward of you, my friend, and I appreciate it, truly. Whatever I need, huh. I'll have to give a little thought to that! But right now, I need for you to decide which of these dresses you like, and try it on."
      Speaker = "Arachne"
      Event = "ArachneAboutPay01"
    }
    {
      Id = "Melinoe_1810"
      InheritFrom = "BaseNarrative"
      DisplayName = "Arachne, the outfit you wove for me was so beautiful. I'm sorry to say I got into a bit of a scrape or two... and I'm afraid it didn't survive."
      Speaker = "Melinoe"
      Event = "ArachneAboutOutfits01"
    }
    {
      Id = "Arachne_0041"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, {#Emph}hah{#Prev}, that's quite all right, silly! It wasn't made to last. What is? It was made to be in the moment with {#Emph}you. {#Prev}Now here, I've plenty more."
      Speaker = "Arachne"
      Event = "ArachneAboutOutfits01"
    }
    {
      Id = "Arachne_0036"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Don't, my friend. Just, you don't need to look at me like that. You don't need to look at me at all! Look at the fineries I've made! Silk in every shape and color, see? It's beautiful, isn't it?"
      Speaker = "Arachne"
      Event = "ArachneAboutSelf01"
    }
    {
      Id = "Melinoe_1807"
      InheritFrom = "BaseNarrative"
      DisplayName = "It is, Arachne, but... to think I could have wronged you with an inadvertent glance just now. It's just I'm concerned for your safety out here."
      Speaker = "Melinoe"
      Event = "ArachneAboutSelf01"
    }
    {
      Id = "Arachne_0037"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh there's no need for that. You see, my form included certain benefits. I get to live a {#Emph}long{#Prev}, long time to enjoy it. Besides, just because {#Emph}you {#Prev}found me here, doesn't mean just anybody can."
      Speaker = "Arachne"
      Event = "ArachneAboutSelf01"
    }
    {
      Id = "Arachne_0038"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't remember, anymore, what it was like... having two legs. Only the two. I'm hideous, I know, but... I don't fall over myself like I once did. It's second nature now, scurrying about."
      Speaker = "Arachne"
      Event = "ArachneAboutSelf02"
    }
    {
      Id = "Melinoe_1808"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't speak that way! My task would go much faster if I had legs like yours, Arachne."
      Speaker = "Melinoe"
      Event = "ArachneAboutSelf02"
    }
    {
      Id = "Arachne_0039"
      InheritFrom = "BaseNarrative"
      DisplayName = "Save your pity for another soul, my friend. Now then! I've saved some of my {#Emph}softest {#Prev}silk for {#Emph}you."
      Speaker = "Arachne"
      Event = "ArachneAboutSelf02"
    }
    {
      Id = "Melinoe_1809"
      InheritFrom = "BaseNarrative"
      DisplayName = "Are you sure you're all right here? I can scarce go fifty paces in these woods without having to defend myself."
      Speaker = "Melinoe"
      Event = "ArachneAboutLair01"
    }
    {
      Id = "Arachne_0040"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm comfortable alone. I have my little lair, I've sustenance, and I have my weaving! I no longer even need a loom and thread. I'm grateful. And, I do so appreciate you visiting! Come back again, won't you?"
      Speaker = "Arachne"
      Event = "ArachneAboutLair01"
    }
    {
      Id = "Arachne_0081"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's mostly quiet in these woods. Lost Souls keep to themselves most of the time. So I listen to the trees... they're {#Emph}tall{#Prev}, and {#Emph}wise{#Prev}, and {#Emph}older {#Prev}than the ones where I come from..."
      Speaker = "Arachne"
      Event = "ArachneAboutTrees01"
    }
    {
      Id = "MelinoeField_1782"
      InheritFrom = "BaseNarrative"
      DisplayName = "Growing up, I always listened to the whisper of the woods as well! In some respects, it reminds me of the spirits inhabiting this place. Their voices cannot easily be heard."
      Speaker = "Melinoe"
      Event = "ArachneAboutTrees01"
    }
    {
      Id = "Arachne_0082"
      InheritFrom = "BaseNarrative"
      DisplayName = "But they {#Emph}can {#Prev}be heard, can't they. I'm not imagining it, when I hear them call to me and comfort me? Though there's no need to answer that! For certain things, I'd rather not be sure."
      Speaker = "Arachne"
      Event = "ArachneAboutTrees01"
    }
    {
      Id = "Arachne_0085"
      InheritFrom = "BaseNarrative"
      DisplayName = "These woods have changed an awful lot of late. Sometimes I think of moving out of here. I understand it gets all cold and damp as you head farther down?"
      Speaker = "Arachne"
      Event = "ArachneAboutOceanus01"
    }
    {
      Id = "MelinoeField_1789"
      InheritFrom = "BaseNarrative"
      DisplayName = "There is a path I know that passes through the edge of Oceanus, where the bottom of the sea and the Underworld meet. No trees, only... strange tubes of metal... brine."
      Speaker = "Melinoe"
      Event = "ArachneAboutOceanus01"
    }
    {
      Id = "Arachne_0086"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sounds like a real change of pace! Don't think I'd like it quite as much without my trees. But {#Emph}metal tubes? {#Prev}Could hang my webs on those...! Ah well... a dream's a dream, {#Emph}ha ha ha ha ha..."
      Speaker = "Arachne"
      Event = "ArachneAboutOceanus01"
    }
    {
      Id = "Arachne_0087"
      InheritFrom = "BaseNarrative"
      DisplayName = "Where have you been lately, my friend? I'd grown so well-accustomed to you visiting these woods that, when you didn't show up for a night or two, why... I became a touch concerned is all."
      Speaker = "Arachne"
      Event = "ArachneAboutSurface01"
    }
    {
      Id = "MelinoeField_1784"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm sorry that I worried you. My task requires that I head up to the surface now, as well as down below. It's a big adjustment for me there."
      Speaker = "Melinoe"
      Event = "ArachneAboutSurface01"
    }
    {
      Id = "Arachne_0088"
      InheritFrom = "BaseNarrative"
      DisplayName = "You went {#Emph}that {#Prev}way? {#Emph}Ha ha ha ha{#Prev}, I don't so much as miss it anymore, where I came from. Well, you must know your way around. But if you need a local's point of view, you need but ask."
      Speaker = "Arachne"
      Event = "ArachneAboutSurface01"
    }
    {
      Id = "Arachne_0044"
      InheritFrom = "BaseNarrative"
      DisplayName = "I loved to weave since I was very small. My father, he would make the richest dyes... reds like the setting sun, blues as deep as the sea, and {#Emph}oh{#Prev}, the {#Emph}purples! {#Prev}I wanted to make fabric worthy of such colors as those..."
      Speaker = "Arachne"
      Event = "ArachneAboutWeaving01"
    }
    {
      Id = "MelinoeField_1484"
      InheritFrom = "BaseNarrative"
      DisplayName = "And now you do. You have extraordinary talent. How long did it take to get so proficient? I've practiced my craft all my life though still fall short of my goals far too often..."
      Speaker = "Melinoe"
      Event = "ArachneAboutWeaving01"
    }
    {
      Id = "Arachne_0045"
      InheritFrom = "BaseNarrative"
      DisplayName = "You'll get to where you need to be, my friend. I see how hard you work! As for me, as a young woman, I was already quite good. But truth be told, I'm even better now that I'm like this. A blessing... and a curse, {#Emph}ha ha ha..."
      Speaker = "Arachne"
      Event = "ArachneAboutWeaving01"
    }
    {
      Id = "Arachne_0046"
      InheritFrom = "BaseNarrative"
      DisplayName = "All I wanted was to have a little shoppe. {#Emph}Arachne's Garments, Dyes, and Fabrics! {#Prev}Not the catchiest of names, now that I sound it out. But our reputation would have been impeccable."
      Speaker = "Arachne"
      Event = "ArachneAboutWeaving02"
    }
    {
      Id = "MelinoeField_1485"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know it's not what you imagined... but you've a loyal customer in me. Although, the part where you ask nothing for your services does make me feel a bit guilty, I suppose."
      Speaker = "Melinoe"
      Event = "ArachneAboutWeaving02"
    }
    {
      Id = "Arachne_0047"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't even start with that! My weavings and my garments aren't just for show, they're practical evening-wear! {#Emph}You{#Prev}, my friend, are helping them fulfill their life's purpose, {#Emph}ha ha ha..."
      Speaker = "Arachne"
      Event = "ArachneAboutWeaving02"
    }
    {
      Id = "Melinoe_1811"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've been so busy, Arachne. Not just all these dresses, but... all Erebus is teeming with silken cocoons. You're certain it's all right for me to break them?"
      Speaker = "Melinoe"
      Event = "ArachneAboutCocoons01"
    }
    {
      Id = "Arachne_0048"
      InheritFrom = "BaseNarrative"
      DisplayName = "Of course, you big silly! What, do you suppose they're teeming with my countless brood? By the time you see a cocoon, anything in there is either {#Emph}for {#Prev}you, or was out to {#Emph}get {#Prev}you. Now, here."
      Speaker = "Arachne"
      Event = "ArachneAboutCocoons01"
    }
    {
      Id = "Arachne_0049"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now you don't truly think {#Emph}I {#Prev}weave all those cocoons you see out there myself, do you? I weave faster than anyone, though even {#Emph}I'm {#Prev}not that quick...!"
      Speaker = "Arachne"
      Event = "ArachneAboutCocoons02"
    }
    {
      Id = "Melinoe_1812"
      InheritFrom = "BaseNarrative"
      DisplayName = "That does make sense. So instead you command a massive hidden army of spiderlings, standing at the ready to do your bidding?"
      Speaker = "Melinoe"
      Event = "ArachneAboutCocoons02"
    }
    {
      Id = "Arachne_0050"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh {#Prev}no, most of them hang upside-down rather than stand. {#Emph}Khh, {#Prev}come now! I'm not the only spider in the woods! The others keep to themselves. But they do listen {#Emph}sometimes{#Prev}, I suppose, {#Emph}ha ha ha ha ha..."
      Speaker = "Arachne"
      Event = "ArachneAboutCocoons02"
    }
    {
      Id = "Arachne_0067"
      InheritFrom = "BaseNarrative"
      DisplayName = "You must be famished! Might I interest you in a little sustenance? And I do mean {#Emph}little, hahaha! {#Prev}I have a fresh batch here if you'd like to try them!"
      Speaker = "Arachne"
      Event = "ArachneAboutFood01"
    }
    {
      Id = "MelinoeField_1486"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh! No thank you, Arachne. I... have no appetite at all. And I'm not much for eating animals, even insects. Although I'm certain your flies are very delicious."
      Speaker = "Melinoe"
      Event = "ArachneAboutFood01"
    }
    {
      Id = "Arachne_0068"
      InheritFrom = "BaseNarrative"
      DisplayName = "They {#Emph}are! {#Prev}A touch of an acquired taste, I know. But I got used to them much faster than just about any other aspect of this life. {#Emph}Ah {#Prev}well! Your loss, I'm sure."
      Speaker = "Arachne"
      Event = "ArachneAboutFood01"
    }
    {
      Id = "MelinoeField_1487"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're always here all by yourself. The woods are filled with spiders... don't you ever get together, something like that? Make great big webs you couldn't on your own?"
      Speaker = "Melinoe"
      Event = "ArachneAboutSpiders01"
    }
    {
      Id = "Arachne_0368"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well I suppose we certainly could. It's just, I happen to {#Emph}hate {#Prev}spiders. Near as I can tell, all spiders do. Weaving's a solitary exercise, and besides... I much prefer {#Emph}your {#Prev}company."
      Speaker = "Arachne"
      Event = "ArachneAboutSpiders01"
    }
    {
      Id = "MelinoeField_1488"
      InheritFrom = "BaseNarrative"
      DisplayName = "I... for what it's worth, I never have disliked spiders, myself. They keep the woods free of pests. And what would this place be without their webs?"
      Speaker = "Melinoe"
      Event = "ArachneAboutSpiders02"
    }
    {
      Id = "Arachne_0052"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thank you, my friend. I know you mean well when you say such things. If it makes you feel any better, I don't just hate what {#Emph}I've {#Prev}become. You gods... I hate you, too. {#Emph}Ha ha ha ha..."
      Speaker = "Arachne"
      Event = "ArachneAboutSpiders02"
    }
    {
      Id = "Arachne_0053"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know the thing about spiders, my friend, it's that... well, they're my kin. My own brood, you see. But they're {#Emph}ungrateful {#Prev}rascals to the last! They want nothing to do with me at all."
      Speaker = "Arachne"
      Event = "ArachneAboutSpiders03"
    }
    {
      Id = "MelinoeField_1489"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your own brood...! You were the very first. But, how did you, {#Emph}erm... {#Prev}wouldn't you have needed...?"
      Speaker = "Melinoe"
      Event = "ArachneAboutSpiders03"
    }
    {
      Id = "Arachne_0054"
      InheritFrom = "BaseNarrative"
      DisplayName = "A {#Emph}mate? {#Prev}Oh, he didn't stick around. So you see, this curse isn't just {#Emph}mine. {#Prev}It's for generations still to come. Perhaps we spiders aren't so different from you gods. {#Emph}Ha ha ha ha..."
      Speaker = "Arachne"
      Event = "ArachneAboutSpiders03"
    }
    {
      Id = "Arachne_0083"
      InheritFrom = "BaseNarrative"
      DisplayName = "I never truly stopped to think how much alike we are, the two of us. Both outcasts, aren't we? You should be living in a {#Emph}palace! {#Prev}Not... talking to a {#Emph}spider {#Prev}in the middle of nowhere."
      Speaker = "Arachne"
      Event = "ArachneAboutRelationship01"
    }
    {
      Id = "MelinoeField_1783"
      InheritFrom = "BaseNarrative"
      DisplayName = "And you should be the most-renowned, most-beloved weaver in all the land! But that isn't what the Fates had in store for us. Although... it's not all bad, is it?"
      Speaker = "Melinoe"
      Event = "ArachneAboutRelationship01"
    }
    {
      Id = "Arachne_0084"
      InheritFrom = "BaseNarrative"
      DisplayName = "It isn't? It... isn't. Because if I was still up there... the envy of gods and mortals alike... I wouldn't have met {#Emph}you. {#Prev}My one true friend. {#Emph}Ha ha ha ha ha..."
      Speaker = "Arachne"
      Event = "ArachneAboutRelationship01"
    }
    {
      Id = "Arachne_0116"
      InheritFrom = "BaseNarrative"
      DisplayName = "About last time... I know that there are others in your life, whom you care about. And that makes me glad. You should feel {#Emph}loved! {#Prev}A lot! But look at {#Emph}me... {#Prev}all I can do a lot is {#Emph}weave."
      Speaker = "Arachne"
      Event = "ArachneAboutRelationship02"
    }
    {
      Id = "MelinoeField_1803"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your size has nothing to do with the love you can give. But how you feel about yourself... it must affect the love you can receive. Whether you can believe it to be true."
      Speaker = "Melinoe"
      Event = "ArachneAboutRelationship02"
    }
    {
      Id = "Arachne_0117"
      InheritFrom = "BaseNarrative"
      DisplayName = "You make me feel how I used to feel. And back then...? Back when I used to be myself? You know, we mortals could be {#Emph}just {#Prev}as jealous as the gods. But knowing that you care for me even a little bit, why... it's more than enough. Here, go..."
      Speaker = "Arachne"
      Event = "ArachneAboutRelationship02"
    }
    {
      Id = "Arachne_0392"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've kept on thinking, my friend... about how I've been drawn to you. Like a fly to one of my webs... except I mean to catch {#Emph}them{#Prev}, and I don't think you've meant to do the same to me."
      Speaker = "Arachne"
      Event = "ArachneAboutRelationship03"
    }
    {
      Id = "MelinoeField_4398"
      InheritFrom = "BaseNarrative"
      DisplayName = "Of course I haven't meant to {#Emph}catch {#Prev}you, Arachne. It's as I said... I think we've helped keep each other company in these lonesome woods, but... is there... something more?"
      Speaker = "Melinoe"
      Event = "ArachneAboutRelationship03"
    }
    {
      Id = "Arachne_0393"
      InheritFrom = "BaseNarrative"
      DisplayName = "I... I don't think so, no. Not while I'm the way I am. The girl I {#Emph}used {#Prev}to be, why... she may have been mortal, but she was a {#Emph}lot {#Prev}better than this, {#Emph}ha ha ha ha ha..."
      Speaker = "Arachne"
      Event = "ArachneAboutRelationship03"
    }
    {
      Id = "Arachne_0394"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lately, when I'd long to be a girl again, my friend... I think it was in part because I liked the thought that I could be with you. You know, like in a normal way."
      Speaker = "Arachne"
      Event = "ArachneAboutRelationship04"
    }
    {
      Id = "MelinoeField_4399"
      InheritFrom = "BaseNarrative"
      DisplayName = "Arachne, what we have is special. Even if I met the mortal girl you once were, I'd likely not have taken notice in the same way. Mortal Shades are commonplace... you're not."
      Speaker = "Melinoe"
      Event = "ArachneAboutRelationship04"
    }
    {
      Id = "Arachne_0395"
      InheritFrom = "BaseNarrative"
      DisplayName = "I do appreciate you saying that. Back when I gave Athena a piece of my mind... I knew I was giving something up. But it was just a fantasy, while {#Emph}we {#Prev}have something {#Emph}real."
      Speaker = "Arachne"
      Event = "ArachneAboutRelationship04"
    }
    {
      Id = "Arachne_0069"
      InheritFrom = "BaseNarrative"
      DisplayName = "So then the gods above are helping you, aren't they? Though why do I even ask, I already know. I've seen these woods light up with all their multicolored messages..."
      Speaker = "Arachne"
      Event = "ArachneAboutGods01"
    }
    {
      Id = "MelinoeField_1776"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's true. Olympus and I share a common goal, for the Titan of Time threatens us all. I should have told you, it's just... I didn't know what to say."
      Speaker = "Melinoe"
      Event = "ArachneAboutGods01"
    }
    {
      Id = "Arachne_0070"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hah, ha ha ha ha{#Prev}... so the Fates got me {#Emph}again. {#Prev}I may be a better weaver than all the gods combined, but those three beat me {#Emph}every time. {#Prev}Though don't worry! I won't turn my abdomen on you. Even if the gods will benefit..."
      Speaker = "Arachne"
      Event = "ArachneAboutGods01"
    }
    {
      Id = "MelinoeField_1777"
      InheritFrom = "BaseNarrative"
      DisplayName = "You seem distant, Arachne. Is everything all right? Is this about my aiding the Olympians?"
      Speaker = "Melinoe"
      Event = "ArachneAboutGods02"
    }
    {
      Id = "Arachne_0071"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah, hahaha... {#Prev}wait. What do you mean {#Emph}you're {#Prev}aiding the Olympians? I thought you said it was the other way around! They're helping {#Emph}you!"
      Speaker = "Arachne"
      Event = "ArachneAboutGods02"
    }
    {
      Id = "MelinoeField_1778"
      InheritFrom = "BaseNarrative"
      DisplayName = "Same difference, isn't it? A mutual exchange. Like a friendship! There must be reciprocity. But, I know this puts you in a terrible position, and... I would never take your support for granted."
      Speaker = "Melinoe"
      Event = "ArachneAboutGods02"
    }
    {
      Id = "Arachne_0072"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well! You may know {#Emph}all {#Prev}about the gods, more than I. But it seems you have a thing or two to learn still when it comes to {#Emph}friendship. {#Prev}Even a little old spider knows that! Now have a dress."
      Speaker = "Arachne"
      Event = "ArachneAboutGods02"
    }
    {
      Id = "Arachne_0073"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know you don't know what to say, my friend. But I want you to know... you don't have to say anything at all! In fact, I'd rather that you didn't right now. Be safe out there, all right?"
      Speaker = "Arachne"
      Event = "ArachneAboutGods03"
    }
    {
      Id = "Arachne_0074"
      InheritFrom = "BaseNarrative"
      DisplayName = "Another evening where you're forced to do the bidding of the gods? It's not a {#Emph}partnership {#Prev}you've got with them, you know. They'll tolerate you just as long as they think you're {#Emph}inferior {#Prev}to them. Now, here. Take this and go."
      Speaker = "Arachne"
      Event = "ArachneAboutGods04"
    }
    {
      Id = "Arachne_0075"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know the gods did this to me, don't you? Although I shouldn't say {#Emph}the {#Prev}gods. Was truly just the one. But the others... they didn't {#Emph}care. {#Prev}They were complicit in the whole thing! It was as though {#Emph}I {#Prev}was a spider to them all along."
      Speaker = "Arachne"
      Event = "ArachneAboutGods05"
    }
    {
      Id = "MelinoeField_1779"
      InheritFrom = "BaseNarrative"
      DisplayName = "Arachne... the gods could be kinder to mortals. You'll hear no argument from me on that. I've a certain point of view on it, myself. Most mortals I've met... they've all been dead."
      Speaker = "Melinoe"
      Event = "ArachneAboutGods05"
    }
    {
      Id = "Arachne_0076"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yet you abide Olympus anyhow! I understand, I do. They're family. And that's one thing we can never change... not really. Although the Titan whom you're up against... isn't he family, too? {#Emph}Ha ha ha ha..."
      Speaker = "Arachne"
      Event = "ArachneAboutGods05"
    }
    {
      Id = "Arachne_0077"
      InheritFrom = "BaseNarrative"
      DisplayName = "So what's she truly like? {#Emph}Gray-eyed Athena. {#Prev}As wise and calculating as they say? {#Emph}Ha ha ha ha... {#Prev}to think she's supposedly the {#Emph}sensible {#Prev}one. She's just as cruel and vindictive as the rest..."
      Speaker = "Arachne"
      Event = "ArachneAboutGods06"
    }
    {
      Id = "MelinoeField_1780"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wouldn't know. I've heard from most of the Olympians by now, but not Athena. Sounds like she's got her hands full, holding back the Titan's armies gathered at the mountain's base."
      Speaker = "Melinoe"
      Event = "ArachneAboutGods06"
    }
    {
      Id = "Arachne_0078"
      InheritFrom = "BaseNarrative"
      DisplayName = "How very noble of her! If you meet eventually, you'll have to tell me how she is. And do feel free to let her know Arachne's still alive and well, and weaving even {#Emph}better {#Prev}than before."
      Speaker = "Arachne"
      Event = "ArachneAboutGods06"
    }
    {
      Id = "Arachne_0077_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "So what's she truly like? {#Emph}Gray-eyed Athena. {#Prev}As wise and calculating as they say? {#Emph}Ha ha ha ha... {#Prev}to think she's supposedly the {#Emph}sensible {#Prev}one."
      Speaker = "Arachne"
      Event = "ArachneAboutGods06_B"
    }
    {
      Id = "MelinoeField_2721"
      InheritFrom = "BaseNarrative"
      DisplayName = "I... don't hear from her quite like most of the rest. She must really have her hands full, holding back the Titan's armies gathered at the mountain's base."
      Speaker = "Melinoe"
      Event = "ArachneAboutGods06_B"
    }
    {
      Id = "Arachne_0078_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "How very noble of her! Do feel free to let her know Arachne's still alive and well, and weaving even {#Emph}better {#Prev}than before."
      Speaker = "Arachne"
      Event = "ArachneAboutGods06_B"
    }
    {
      Id = "Arachne_0079"
      InheritFrom = "BaseNarrative"
      DisplayName = "Should I have held back? When I was challenged by the gods themselves? To decide who was the {#Emph}greatest {#Prev}weaver of all. I was just a mortal girl. Can you imagine the pressure?"
      Speaker = "Arachne"
      Event = "ArachneAboutPride01"
    }
    {
      Id = "MelinoeField_1781"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wouldn't have held back either, in your place. When our limits are put to the test... only then can we discover who we really are."
      Speaker = "Melinoe"
      Event = "ArachneAboutPride01"
    }
    {
      Id = "Arachne_0080"
      InheritFrom = "BaseNarrative"
      DisplayName = "All I discovered was I ceased being a mortal girl anymore. You should have {#Emph}seen {#Prev}the masterpiece I made! Athena's little {#Emph}tapestry {#Prev}wasn't even close. Maybe it was worth it... my humiliation in exchange for hers..."
      Speaker = "Arachne"
      Event = "ArachneAboutPride01"
    }
    {
      Id = "Arachne_0089"
      InheritFrom = "BaseNarrative"
      DisplayName = "My friend, I truly hate to ask, but you don't suppose... knowing your craft, you don't suppose there might still be some way to turn me back into myself again, do you?"
      Speaker = "Arachne"
      Event = "ArachneAboutCurse01"
    }
    {
      Id = "MelinoeField_1790"
      InheritFrom = "BaseNarrative"
      DisplayName = "Arachne... I've tried everything I know. This curse of metamorphosis upon you, it's... well, it's extremely powerful. Such change is irreversible as far as I can tell. I'm sorry."
      Speaker = "Melinoe"
      Event = "ArachneAboutCurse01"
    }
    {
      Id = "Arachne_0090"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's quite all right. Just figured I would ask. Such curses wouldn't be much good if they could just be waved away, now, would they? {#Emph}Ha ha ha ha..."
      Speaker = "Arachne"
      Event = "ArachneAboutCurse01"
    }
    {
      Id = "MelinoeField_1791"
      InheritFrom = "BaseNarrative"
      DisplayName = "Arachne, I... I wasn't entirely forthright with you before, about your curse. Theoretically, there is a way that it can be undone. But it is unlikely to work, and shall be very dangerous."
      Speaker = "Melinoe"
      Event = "ArachneAboutCurse02"
    }
    {
      Id = "Arachne_0091"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}What? {#Prev}I don't care what it takes, you have to tell me, my friend, {#Emph}please!"
      Speaker = "Arachne"
      Event = "ArachneAboutCurse02"
    }
    {
      Id = "MelinoeField_1792"
      InheritFrom = "BaseNarrative"
      DisplayName = "First, we must discover the source of the curse; Athena is no enchantress. Someone aided her. And second... Athena herself must change her original intent. She has to want this."
      Speaker = "Melinoe"
      Event = "ArachneAboutCurse02"
    }
    {
      Id = "Arachne_0092"
      InheritFrom = "BaseNarrative"
      DisplayName = "But she {#Emph}despises {#Prev}me! And why would she tell anybody who provided her the curse? Oh, my friend, I almost wish you hadn't told me! Don't bother, {#Emph}ha ha ha ha. {#Prev}Hope can be such a tease..."
      Speaker = "Arachne"
      Event = "ArachneAboutCurse02"
    }
    {
      Id = "MelinoeField_1793"
      InheritFrom = "BaseNarrative"
      DisplayName = "Regarding your curse, Arachne... Headmistress discovered who created it. So, if you require closure on this aspect of your life... come visit at the Crossroads. But, such knowledge may be a curse all its own, so... choose carefully, please."
      Speaker = "Melinoe"
      Event = "ArachneAboutCurse03"
    }
    {
      Id = "Arachne_0093"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh... why... I suppose that I'll be giving that some thought! What would I even do different, knowing something like that? Give me some time... all right, my friend?"
      Speaker = "Arachne"
      Event = "ArachneAboutCurse03"
    }
    {
      Id = "MelinoeField_1794"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Are you all right, my friend?"
      Speaker = "Melinoe"
      Event = "ArachneAboutCurse04"
    }
    {
      Id = "Arachne_0094"
      InheritFrom = "BaseNarrative"
      DisplayName = "I... {#Emph}yes! {#Prev}Yes, I've some new dresses for you. Here! Which one do you desire?"
      Speaker = "Arachne"
      Event = "ArachneAboutCurse04"
    }
    {
      Id = "MelinoeField_1795"
      InheritFrom = "BaseNarrative"
      DisplayName = "Arachne, we need to talk about what happened with Headmistress. She didn't fashion a poison expressly to ruin your life. She didn't even know you at the time."
      Speaker = "Melinoe"
      Event = "ArachneAboutCurse05"
    }
    {
      Id = "Arachne_0095"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't you think I know all that? But what am I supposed to do, {#Emph}thank {#Prev}her? I may be very small, my friend, but I still have my pride... and you can still have your dress."
      Speaker = "Arachne"
      Event = "ArachneAboutCurse05"
    }
    {
      Id = "Arachne_0096"
      InheritFrom = "BaseNarrative"
      DisplayName = "So much talk of late about my curse! Let's just go back to how things were, what do you say? All this {#Emph}tension... {#Prev}I don't need it anymore than you. You were only trying to help. And so am I."
      Speaker = "Arachne"
      Event = "ArachneAboutCurse06"
    }
    {
      Id = "MelinoeField_1796"
      InheritFrom = "BaseNarrative"
      DisplayName = "I just want you to be well, that's all. The past has already transpired and can't be changed. But {#Emph}we {#Prev}get to decide what happens next."
      Speaker = "Melinoe"
      Event = "ArachneAboutCurse06"
    }
    {
      Id = "Arachne_0097"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps we do! Either we or the Fates, I suppose. Thank you for listening to me, my friend. And you be well yourself, all right?"
      Speaker = "Arachne"
      Event = "ArachneAboutCurse06"
    }
    {
      Id = "MelinoeField_4390"
      InheritFrom = "BaseNarrative"
      DisplayName = "Arachne, now that we know Headmistress Hecate had a hand in your curse, there is some possibility we can persuade Athena to undo it. Or rather, you could."
      Speaker = "Melinoe"
      Event = "ArachneCurseQuest01"
    }
    {
      Id = "Arachne_0379"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why don't you humor me some more with this, my friend. What exactly do you have in mind? Olympus is a bit of a climb from here..."
      Speaker = "Arachne"
      Event = "ArachneCurseQuest01"
    }
    {
      Id = "MelinoeField_4391"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've a more convenient means in mind: a certain Amulet that I can use to briefly summon her. If it's all right with you, then she can join us here, and you can make your plea."
      Speaker = "Melinoe"
      Event = "ArachneCurseQuest01"
    }
    {
      Id = "Arachne_0380"
      InheritFrom = "BaseNarrative"
      DisplayName = "What would I even say? But... {#Emph}oh{#Prev}, I'll certainly give it some thought. Next time you have that Amulet, then I {#Emph}might {#Prev}take you up on that. Thank you."
      Speaker = "Arachne"
      Event = "ArachneCurseQuest01"
    }
    {
      Id = "MelinoeField_4392"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have Athena's Amulet, Arachne. Would you be willing to confront her now? Just, speak to how you've changed, how you wish to have your old self back! Whatever she requires."
      Speaker = "Melinoe"
      Event = "ArachneCurseQuestComplete01"
    }
    {
      Id = "Arachne_0381"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll... I'll do what I have to do, my friend. Now, if you could bring forth the goddess of wisdom, I'd be much obliged."
      Speaker = "Arachne"
      Event = "ArachneCurseQuestComplete01"
    }
    {
      Id = "MelinoeField_4393"
      InheritFrom = "BaseNarrative"
      DisplayName = "Very well, here goes. And whatever happens, I'll be right here. {#Emph}Heed now my voice, Lady Athena; one who has sought you is with me!"
      Speaker = "Melinoe"
      Event = "ArachneCurseQuestComplete01"
    }
    {
      Id = "Athena_0249"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hail, Melinoë. {#Emph}Ah{#Prev}, these woods. And sure enough there's the World's Most Talented Weaver herself. Still plying your trade, Arachne?"
      Speaker = "Athena"
      Event = "ArachneCurseQuestComplete01"
    }
    {
      Id = "Arachne_0382"
      InheritFrom = "BaseNarrative"
      DisplayName = "I most certainly am, Lady Athena! What else would I be doing? Even if I were still the mortal girl I once was, I imagine I'd have stuck with it. And you, how have you been?"
      Speaker = "Arachne"
      Event = "ArachneCurseQuestComplete01"
    }
    {
      Id = "Athena_0250"
      InheritFrom = "BaseNarrative"
      DisplayName = "Fully occupied. I cannot remain for long, for that reason and more, so what is it? You've grown tired of your form?"
      Speaker = "Athena"
      Event = "ArachneCurseQuestComplete01"
    }
    {
      Id = "Arachne_0383"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well I do miss my old shape and size, and... I've been like this for a while, so... I thought maybe you could turn me back. I'd do anything, please."
      Speaker = "Arachne"
      Event = "ArachneCurseQuestComplete01"
    }
    {
      Id = "Athena_0251"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Anything? {#Prev}Then I've a simple-enough request: Apologize for what you did in all sincerity, and tell me what you've learned."
      Speaker = "Athena"
      Event = "ArachneCurseQuestComplete01"
    }
    {
      Id = "Arachne_0384"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, why, sure... {#Emph}um{#Prev}, I'm... I'm sorry, Lady Athena. Truly sorry. Sorry that I would... debase myself in front of you like this! In front of my own friend!"
      Speaker = "Arachne"
      Event = "ArachneCurseQuestComplete01"
    }
    {
      Id = "MelinoeField_4394"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Arachne! {#Prev}Please, Lady Athena, she's upset and hasn't thought this through. I know how sorrowful she is."
      Speaker = "Melinoe"
      Event = "ArachneCurseQuestComplete01"
    }
    {
      Id = "Arachne_0385"
      InheritFrom = "BaseNarrative"
      DisplayName = "Stay out of this, my friend. As for {#Emph}you{#Prev}, Lady Athena, you want to know what I learned?"
      Speaker = "Arachne"
      Event = "ArachneCurseQuestComplete01"
    }
    {
      Id = "Athena_0252"
      InheritFrom = "BaseNarrative"
      DisplayName = "I caution you to measure your words with care, spider. I did not travel all this way to be the object of your ridicule."
      Speaker = "Athena"
      Event = "ArachneCurseQuestComplete01"
    }
    {
      Id = "Arachne_0386"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I learned, just now, that I'll {#Emph}never {#Prev}apologize to you {#Emph}in all sincerity. {#Prev}I'd sooner be a lowly spider till the end of time. And look upon my works! I can {#Emph}still {#Prev}weave better than you."
      Speaker = "Arachne"
      Event = "ArachneCurseQuestComplete01"
    }
    {
      Id = "Athena_0253"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I suppose you think this outburst moved me in some way, and that I'll now grant your desire? No. You may appear worse off, but you clearly haven't changed at all, Arachne."
      Speaker = "Athena"
      Event = "ArachneCurseQuestComplete01"
    }
    {
      Id = "Arachne_0387"
      InheritFrom = "BaseNarrative"
      DisplayName = "Neither have you. Now either go on and squash me like I know you want to, or be on your way. You're scaring the flies."
      Speaker = "Arachne"
      Event = "ArachneCurseQuestComplete01"
    }
    {
      Id = "Athena_0254"
      InheritFrom = "BaseNarrative"
      DisplayName = "Fine. I'll take my leave, and we shall never see each other again. Enjoy the feast of flies. Melinoë? This was a mistake."
      Speaker = "Athena"
      Event = "ArachneCurseQuestComplete01"
    }
    {
      Id = "MelinoeField_4395"
      InheritFrom = "BaseNarrative"
      DisplayName = "Arachne... why did you do that? We went through so much for this one chance, and now it's gone!"
      Speaker = "Melinoe"
      Event = "ArachneCurseQuestComplete01"
    }
    {
      Id = "Arachne_0388"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, my friend. That was the chance I had been waiting for. I just didn't realize it till I looked Athena in the eyes again. Now, {#Emph}shoo. {#Prev}I've kept you long enough. {#Emph}Ha ha ha ha..."
      Speaker = "Arachne"
      Event = "ArachneCurseQuestComplete01"
    }
    {
      Id = "Arachne_0389"
      InheritFrom = "BaseNarrative"
      DisplayName = "Turns out, apologizing to Athena just isn't for me, my friend. However, I apologize to you. For making you go out of your way... making a scene in front of another goddess. Sorry."
      Speaker = "Arachne"
      Event = "ArachneAboutCurseQuest01"
    }
    {
      Id = "MelinoeField_4396"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Oh, Arachne. I'd have rather you said that to Lady Athena and gotten what you desired. I doubt you'll have another opportunity."
      Speaker = "Melinoe"
      Event = "ArachneAboutCurseQuest01"
    }
    {
      Id = "Arachne_0390"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's quite all right. When I saw Athena again, all battle-weary but same as ever, something in me snapped. And now I'm free! You gods have been having a time... turns out you face the consequences of your pride, same as any of us."
      Speaker = "Arachne"
      Event = "ArachneAboutCurseQuest01"
    }
    {
      Id = "MelinoeField_4397"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I suppose you're right. You really told her off! I still can scarcely believe it. Including that she spared you after all."
      Speaker = "Melinoe"
      Event = "ArachneAboutCurseQuest01"
    }
    {
      Id = "Arachne_0391"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, you know. I always had a touch of temper on me. Feels good to let it all out once in a while, come what may! And I've been weaving like there's no tomorrow since."
      Speaker = "Arachne"
      Event = "ArachneAboutCurseQuest01"
    }
    {
      Id = "Arachne_0055"
      InheritFrom = "BaseNarrative"
      DisplayName = "Saw you get into a scuffle with the great big witch. Why are you fighting? I thought you were on the same side! {#Emph}Oh{#Prev}, I can hardly keep up with everything lately."
      Speaker = "Arachne"
      Event = "ArachneAboutHecate01"
    }
    {
      Id = "Melinoe_1813"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress and I aren't really fighting. Well... no, I suppose we are, except it isn't born of anger, or misunderstanding. It's just her way of making certain I'm prepared."
      Speaker = "Melinoe"
      Event = "ArachneAboutHecate01"
    }
    {
      Id = "Arachne_0056"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Huh. {#Prev}Well look, you show her for me the next chance you get, won't you, my friend? And no pressure! But I might be watching just in case. I won't get underfoot, I promise."
      Speaker = "Arachne"
      Event = "ArachneAboutHecate01"
    }
    {
      Id = "Arachne_0057"
      InheritFrom = "BaseNarrative"
      DisplayName = "How fares the big witch, by the by, my friend? I often see her in these woods! And every now and then, she says hello. Makes time for little old Arachne. How {#Emph}ungodlike {#Prev}of her, {#Emph}ha ha ha ha..."
      Speaker = "Arachne"
      Event = "ArachneAboutHecate02"
    }
    {
      Id = "MelinoeField_1787"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress seems as steady as can be. It's strange... her confidence in my ability is one of the greatest sources of pressure that I feel. Although, I can't exactly tell her that..."
      Speaker = "Melinoe"
      Event = "ArachneAboutHecate02"
    }
    {
      Id = "Arachne_0058"
      InheritFrom = "BaseNarrative"
      DisplayName = "And whyever not? I'd always want to hear the honest truth from you. She's a smart one, no? Likely she knows that something's off. You ought to have a little {#Emph}chat{#Prev}, {#Emph}ha ha ha ha..."
      Speaker = "Arachne"
      Event = "ArachneAboutHecate02"
    }
    {
      Id = "MelinoeField_1490"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, I don't suppose you happened to see a woodsy goddess stalking through? Greenish attire, wielding a bow about her height?"
      Speaker = "Melinoe"
      Event = "ArachneAboutArtemis01"
    }
    {
      Id = "Arachne_0061"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know which one you mean, my friend, and I know she's been nosing about. As a rule, I stay away from goddesses like {#Emph}that. {#Prev}Even if they are your kin."
      Speaker = "Arachne"
      Event = "ArachneAboutArtemis01"
    }
    {
      Id = "MelinoeField_1491"
      InheritFrom = "BaseNarrative"
      DisplayName = "Goddesses like what? You make it sound as though you fear Olympus more than you fear Chronos himself."
      Speaker = "Melinoe"
      Event = "ArachneAboutArtemis01"
    }
    {
      Id = "Arachne_0062"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, I {#Emph}do. {#Prev}It's not Chronos that made me this way; if anything I've grown more used to it with time. Now, go find your woodsy goddess. And be careful not to lead her here, all right?"
      Speaker = "Arachne"
      Event = "ArachneAboutArtemis01"
    }
    {
      Id = "Arachne_0059"
      InheritFrom = "BaseNarrative"
      DisplayName = "The other night, I saw you having conversation with the old Boatman who's been showing up more frequently of late. How's he doing, anyway?"
      Speaker = "Arachne"
      Event = "ArachneAboutCharon01"
    }
    {
      Id = "MelinoeField_1788"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lord Charon takes just about everything in stride. But until he's back to ferrying the dead to their final resting-places, I don't think he'll be entirely himself."
      Speaker = "Melinoe"
      Event = "ArachneAboutCharon01"
    }
    {
      Id = "Arachne_0060"
      InheritFrom = "BaseNarrative"
      DisplayName = "I remember when I stowed away on his little boat! He somehow spotted me amongst his cargo. Oh, I thought I was a goner! But he just kept on. Even stopped for me in Erebus, {#Emph}ha ha ha ha..."
      Speaker = "Arachne"
      Event = "ArachneAboutCharon01"
    }
    {
      Id = "Arachne_0119"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why, that's the Sash I gave to you! Isn't it so very soft? May it help keep you warm and safe, wherever your journeys may take you. Now, {#Emph}here's {#Prev}a little something to match..."
      Speaker = "Arachne"
      Event = "ArachneAboutKeepsake01"
    }
    {
      Id = "Arachne_0129"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah! {#Prev}No, wha-what is that? An amphibian?! Do get it out of here, my friend! {#Emph}Please {#Prev}help me get it out!"
      Speaker = "Arachne"
      Event = "ArachneAboutFrogFamiliar01"
    }
    {
      Id = "MelinoeField_1804"
      InheritFrom = "BaseNarrative"
      DisplayName = "Steady yourself, Arachne. This is Frinos! Frinos is a friend; a Familiar friend of mine, in fact. He means you no harm at all. Your stash of flies, however... that we may need to safeguard."
      Speaker = "Melinoe"
      Event = "ArachneAboutFrogFamiliar01"
    }
    {
      Id = "Arachne_0130"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, {#Emph}haha, ah {#Prev}that is a {#Emph}relief! {#Prev}Well, then, {#Emph}Frinos... {#Prev}if indeed you are a friend, then you are welcome here. And if you'd like a bite to eat, then you are {#Emph}more {#Prev}than welcome to that, too."
      Speaker = "Arachne"
      Event = "ArachneAboutFrogFamiliar01"
    }
    {
      Id = "Arachne_0131"
      InheritFrom = "BaseNarrative"
      DisplayName = "Is that {#Emph}your {#Prev}cat, my friend? I don't much care for how it's giving me the {#Emph}eye. {#Prev}Good thing I'm way up here, {#Emph}haha! {#Prev}Though wait... can't those things {#Emph}climb?"
      Speaker = "Arachne"
      Event = "ArachneAboutCatFamiliar01"
    }
    {
      Id = "MelinoeField_1805"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't worry, this is Toula, my familiar. And she'll keep her feline instincts well in check around Arachne, won't you, girl?"
      Speaker = "Melinoe"
      Event = "ArachneAboutCatFamiliar01"
    }
    {
      Id = "Arachne_0132"
      InheritFrom = "BaseNarrative"
      DisplayName = "I used to love cats... they just don't get on with me quite like they used to. For obvious reasons, I suppose..."
      Speaker = "Arachne"
      Event = "ArachneAboutCatFamiliar01"
    }
    {
      Id = "Arachne_0121"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sorry for all those silk-bombs out there, by the by! All these caustic little mud bubbles I try to wrap up and simmer down. But, if you pop them early, they go up like a moth in a flame, {#Emph}ha ha ha ha..."
      Speaker = "Arachne"
      Event = "ArachneAboutMines01"
    }
    {
      Id = "Arachne_0122"
      InheritFrom = "BaseNarrative"
      DisplayName = "Those Whispers that you see floating about... it's just what happens when a Shade gets caught up in the trees. In time, they can't tell where the branches end and they begin. They're angry, sure. But not with {#Emph}you{#Prev}, my friend."
      Speaker = "Arachne"
      Event = "ArachneAboutGuards01"
    }
    {
      Id = "Arachne_0123"
      InheritFrom = "BaseNarrative"
      DisplayName = "Shades of all sorts wind up in here, you know. Those little Spindles all throughout this place... I don't know what they even were when they drew breath. All I know is that they died before their time. Well, so it goes, {#Emph}ha ha ha ha..."
      Speaker = "Arachne"
      Event = "ArachneAboutRadiators01"
    }
    {
      Id = "Arachne_0124"
      InheritFrom = "BaseNarrative"
      DisplayName = "I liked it better when there weren't all those Wastrels around here. I think they lost their way before they died. Now that they're all long gone... we get to see them for exactly what they are, don't we now?"
      Speaker = "Arachne"
      Event = "ArachneAboutBrawlers01"
    }
    {
      Id = "Arachne_0125"
      InheritFrom = "BaseNarrative"
      DisplayName = "How many Caskets have you had to fend aside, do you suppose? First sign of anything that breathes, and they flock to it like it's going out of style. And, always with the {#Emph}spitting! {#Prev}At least I'm much too small for them to see."
      Speaker = "Arachne"
      Event = "ArachneAboutMages01"
    }
    {
      Id = "Arachne_0126"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do watch for Thorn-Weepers out there. Thank goodness for my webs, as I can stay up high where all those nasty vines of theirs can't reach. But as for {#Emph}you{#Prev}, you're easy pickings, bare feet and all..."
      Speaker = "Arachne"
      Event = "ArachneAboutSiegeVines01"
    }
    {
      Id = "Arachne_0127"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not seen too many Shadow-Spillers hereabouts! Good thing, since it's been plenty dark such as it is. How so many souls manage getting themselves {#Emph}tangled up {#Prev}like that, I never want to know..."
      Speaker = "Arachne"
      Event = "ArachneAboutFogEmitters01"
    }
    {
      Id = "Arachne_0128"
      InheritFrom = "BaseNarrative"
      DisplayName = "You must have seen more than your share of Root-Stalkers by now. It's fortunate for me that they mostly like to stay put, so I can keep out of their way. But you're bigger, and you can't just slip by, huh...?"
      Speaker = "Arachne"
      Event = "ArachneAboutTreants01"
    }
    {
      Id = "Arachne_0103"
      InheritFrom = "BaseNarrative"
      DisplayName = "Another customer already! You just missed the great big witch. Not often that I'm honored with her presence. Next you see her out there, give her a good one for me, would you? {#Emph}Hm ha ha ha..."
      Speaker = "Arachne"
      Event = "HecateWithArachne01_FollowUp"
    }
    {
      Id = "Arachne_0120"
      InheritFrom = "BaseNarrative"
      DisplayName = "All right, my friend, the time has come to unveil my latest designs; woven with care, especially for you! {#Emph}Behold! {#Prev}And more importantly, enjoy!"
      Speaker = "Arachne"
      Event = "ArachneGrantsReward01"
    }
    {
      Id = "Arachne_0366"
      InheritFrom = "BaseNarrative"
      DisplayName = "It gets so quiet in these woods. The sound of my weaving, why, it's practically silent... might as well just be the rush of the leaves. So I sing a little to myself."
      Speaker = "Arachne"
      Event = "ArachneAboutQuiet01"
    }
    {
      Id = "MelinoeField_4389"
      InheritFrom = "BaseNarrative"
      DisplayName = "The woods may be quiet but they're filled with restless spirits. You're like a ray of moonlight in the middle of it all."
      Speaker = "Melinoe"
      Event = "ArachneAboutQuiet01"
    }
    {
      Id = "Arachne_0367"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well that is kind of you to say. Though moonlight doesn't come in quite so many different colors as my silk, does it?"
      Speaker = "Arachne"
      Event = "ArachneAboutQuiet01"
    }
    {
      Id = "Arachne_0432"
      InheritFrom = "BaseNarrative"
      DisplayName = "Have you been getting anywhere, my friend? I know that, whatever you do, you do {#Emph}not {#Prev}give up. But I don't rightly know how close you are to what you mean to achieve."
      Speaker = "Arachne"
      Event = "ArachneAboutUltimateProgress01"
    }
    {
      Id = "MelinoeField_4414"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm closer than before, but how much further I have left is difficult to say. Your silk has been of so much help!"
      Speaker = "Melinoe"
      Event = "ArachneAboutUltimateProgress01"
    }
    {
      Id = "Arachne_0433"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm glad it has and figured that it would. Only the {#Emph}very {#Prev}best for {#Emph}you{#Prev}. And one of these nights, you'll make it {#Emph}all {#Prev}the way. And maybe with my silk, {#Emph}ha ha ha ha ha..."
      Speaker = "Arachne"
      Event = "ArachneAboutUltimateProgress01"
    }
    {
      Id = "Arachne_0434"
      InheritFrom = "BaseNarrative"
      DisplayName = "We've had some goings-on here in these woods, a lot more goings-on than usual! Lost Souls all acting strange. Did something happen I should know about?"
      Speaker = "Arachne"
      Event = "ArachnePostTrueEnding01"
    }
    {
      Id = "MelinoeField_4415"
      InheritFrom = "BaseNarrative"
      DisplayName = "Arachne, it's just that my task is finally complete! Well, for the most part. King Hades and Queen Persephone are back, and they'll soon give all the Lost Souls here a place to go."
      Speaker = "Melinoe"
      Event = "ArachnePostTrueEnding01"
    }
    {
      Id = "Arachne_0435"
      InheritFrom = "BaseNarrative"
      DisplayName = "My, but that {#Emph}is {#Prev}exciting! You {#Emph}did {#Prev}it, my friend! But then, it looks to me as though your fighting isn't over with..."
      Speaker = "Arachne"
      Event = "ArachnePostTrueEnding01"
    }
    {
      Id = "MelinoeField_4416"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not yet, and possibly not for a while. So if it's all the same to you, I may keep passing by every so often. And not just for the beautiful silk dresses, but to say hello."
      Speaker = "Melinoe"
      Event = "ArachnePostTrueEnding01"
    }
    {
      Id = "Arachne_0436"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why, then, hello right back! And you are truly welcome here whenever you desire. I'm so happy for you!"
      Speaker = "Arachne"
      Event = "ArachnePostTrueEnding01"
    }
    {
      Id = "Arachne_0437"
      InheritFrom = "BaseNarrative"
      DisplayName = "Say, if the King and Queen are back just like you said, doesn't that mean... why, doesn't it mean you should be back in their palace, too?"
      Speaker = "Arachne"
      Event = "ArachnePostTrueEnding02"
    }
    {
      Id = "MelinoeField_4417"
      InheritFrom = "BaseNarrative"
      DisplayName = "I grew up near to these woods and I mean to remain here for the foreseeable future. Too much I'm not ready to give up."
      Speaker = "Melinoe"
      Event = "ArachnePostTrueEnding02"
    }
    {
      Id = "Arachne_0438"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, you big silly. You could have had it {#Emph}good. {#Prev}They would have given you the most {#Emph}beautiful {#Prev}dresses, I'm sure. Though maybe not more beautiful than these..."
      Speaker = "Arachne"
      Event = "ArachnePostTrueEnding02"
    }
    {
      Id = "MelinoeField_4418"
      InheritFrom = "BaseNarrative"
      DisplayName = "You might not believe this, Arachne, but recently I met the Fates themselves! All three of them!"
      Speaker = "Melinoe"
      Event = "ArachnePostEpilogue01"
    }
    {
      Id = "Arachne_0439"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh {#Prev}you did, did you? And, did you happen to see what they were working on? I like to keep up with the latest happenings in the weaving world."
      Speaker = "Arachne"
      Event = "ArachnePostEpilogue01"
    }
    {
      Id = "MelinoeField_4419"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well if anything I got the sense that they were in between projects, and might be weaving {#Emph}less {#Prev}from here on out..."
      Speaker = "Melinoe"
      Event = "ArachnePostEpilogue01"
    }
    {
      Id = "Arachne_0440"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sounds like they {#Emph}just {#Prev}couldn't keep up. But that's all right. The old always have to make way for the young and the new! And before you get too worried that I'm speaking out of turn, I don't think they'll notice little old me, {#Emph}ha ha ha ha ha."
      Speaker = "Arachne"
      Event = "ArachnePostEpilogue01"
    }
    {
      Id = "Arachne_0441"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've been wondering what else the Fates had to say to you. To think that all those different strands they weave affect our lives..."
      Speaker = "Arachne"
      Event = "ArachnePostEpilogue02"
    }
    {
      Id = "MelinoeField_4420"
      InheritFrom = "BaseNarrative"
      DisplayName = "My impression was they're going into a sort of retirement. Leaving us to make our own decisions. I don't know if it'll feel any different than before, though."
      Speaker = "Melinoe"
      Event = "ArachnePostEpilogue02"
    }
    {
      Id = "Arachne_0442"
      InheritFrom = "BaseNarrative"
      DisplayName = "I highly doubt it will. The kinds of choices that I've made... I don't know that anybody could have made them for me. Not even those three, {#Emph}ha ha ha ha ha."
      Speaker = "Arachne"
      Event = "ArachnePostEpilogue02"
    }
    {
      Id = "Arachne_0445"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's been so nice seeing you here. I have been weaving up a storm, so please stop by as often as you like, all right?"
      Speaker = "Arachne"
      Event = "ArachneAboutSayingLittle01"
    }
    {
      Id = "MelinoeField_4424"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wouldn't miss it. My nights aren't always pleasant, but you and your silken dresses are!"
      Speaker = "Melinoe"
      Event = "ArachneAboutSayingLittle01"
    }
    {
      Id = "Arachne_0446"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well thank you for that, truly. Now go on, I don't want to keep you. Well I do but, you know what I mean, {#Emph}ha ha ha ha ha."
      Speaker = "Arachne"
      Event = "ArachneAboutSayingLittle01"
    }
    {
      Id = "Arachne_0004"
      InheritFrom = "BaseNarrative"
      DisplayName = "Surely you saw some of the weavings I've been working on along the way?"
      Speaker = "Arachne"
      Event = "ArachneChat01"
    }
    {
      Id = "Arachne_0005"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm so grateful that you're here! Please make yourself at home."
      Speaker = "Arachne"
      Event = "ArachneChat02"
    }
    {
      Id = "Arachne_0006"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know there's not much I can do to help, but here."
      Speaker = "Arachne"
      Event = "ArachneChat03"
    }
    {
      Id = "Arachne_0007"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's always so nice to see you. You do know that, don't you?"
      Speaker = "Arachne"
      Event = "ArachneChat04"
    }
    {
      Id = "Arachne_0008"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just watch your step out there as best you can, all right? {#Emph}Hm hm hm hm hm..."
      Speaker = "Arachne"
      Event = "ArachneChat05"
    }
    {
      Id = "Arachne_0009"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wove each of these with love and care for {#Emph}just {#Prev}such an evening!"
      Speaker = "Arachne"
      Event = "ArachneChat06"
    }
    {
      Id = "Arachne_0010"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, don't worry about all those webs. I was going to replace them anyhow!"
      Speaker = "Arachne"
      Event = "ArachneChat07"
    }
    {
      Id = "Arachne_0011"
      InheritFrom = "BaseNarrative"
      DisplayName = "I want you looking your {#Emph}very {#Prev}best out there tonight, my friend."
      Speaker = "Arachne"
      Event = "ArachneChat08"
    }
    {
      Id = "Arachne_0012"
      InheritFrom = "BaseNarrative"
      DisplayName = "My latest fits are light as a feather, and sturdy as silver, you'll see!"
      Speaker = "Arachne"
      Event = "ArachneChat09"
    }
    {
      Id = "Arachne_0013"
      InheritFrom = "BaseNarrative"
      DisplayName = "Welcome back to {#Emph}Arachne's Garments, Dyes, and Fabrics! {#Prev}How may I be of service?"
      Speaker = "Arachne"
      Event = "ArachneChat10"
    }
    {
      Id = "Arachne_0014"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thank you for visiting {#Emph}Arachne's Garments, Dyes, and Fabrics! {#Prev}Please come again!"
      Speaker = "Arachne"
      Event = "ArachneChat11"
    }
    {
      Id = "Arachne_0015"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, if it isn't my favorite customer! What might I do for you this eve?"
      Speaker = "Arachne"
      Event = "ArachneChat12"
    }
    {
      Id = "Arachne_0016"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know you can't stay for long... but it's wonderful to see you here, my friend."
      Speaker = "Arachne"
      Event = "ArachneChat13"
    }
    {
      Id = "Arachne_0017"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've plenty of these freshly woven garments here from which to choose!"
      Speaker = "Arachne"
      Event = "ArachneChat14"
    }
    {
      Id = "Arachne_0018"
      InheritFrom = "BaseNarrative"
      DisplayName = "My silk is stronger than it looks, so may it help to keep you safe out there."
      Speaker = "Arachne"
      Event = "ArachneChat15"
    }
    {
      Id = "Arachne_0019"
      InheritFrom = "BaseNarrative"
      DisplayName = "You look absolutely stunning dressed in silk, you know that, right?"
      Speaker = "Arachne"
      Event = "ArachneChat16"
    }
    {
      Id = "Arachne_0020"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do try one of these on for size, my friend, then I'll get out of your hair."
      Speaker = "Arachne"
      Event = "ArachneChat17"
    }
    {
      Id = "Arachne_0021"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know my little lair is a bit out of your way, so thanks for visiting me here."
      Speaker = "Arachne"
      Event = "ArachneChat18"
    }
    {
      Id = "Arachne_0022"
      InheritFrom = "BaseNarrative"
      DisplayName = "You sure you wouldn't like to try a couple flies? They're fresh!"
      Speaker = "Arachne"
      Event = "ArachneChat19"
    }
    {
      Id = "Arachne_0023"
      InheritFrom = "BaseNarrative"
      DisplayName = "So, do you... see anything you like? {#Emph}Ha ha ha ha..."
      Speaker = "Arachne"
      Event = "ArachneChat20"
    }
    {
      Id = "Arachne_0024"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, do watch for some of my cocoons out there! I packed them just for you."
      Speaker = "Arachne"
      Event = "ArachneChat21"
    }
    {
      Id = "Arachne_0025"
      InheritFrom = "BaseNarrative"
      DisplayName = "You won't find higher-quality silk anywhere above the surface or below."
      Speaker = "Arachne"
      Event = "ArachneChat22"
    }
    {
      Id = "Arachne_0026"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, I miss you already. You'll come back soon, won't you?"
      Speaker = "Arachne"
      Event = "ArachneChat23"
    }
    {
      Id = "Arachne_0027"
      InheritFrom = "BaseNarrative"
      DisplayName = "Seeing you under the light of the full moon, why, it just takes my breath away."
      Speaker = "Arachne"
      Event = "ArachneChat24"
    }
    {
      Id = "Arachne_0028"
      InheritFrom = "BaseNarrative"
      DisplayName = "I thought I heard you softly moving through the trees, and now you're here!"
      Speaker = "Arachne"
      Event = "ArachneChat25"
    }
    {
      Id = "Arachne_0029"
      InheritFrom = "BaseNarrative"
      DisplayName = "If only there was more that I could do for you, my friend..."
      Speaker = "Arachne"
      Event = "ArachneChat26"
    }
    {
      Id = "Arachne_0030"
      InheritFrom = "BaseNarrative"
      DisplayName = "It must be very difficult for you right now, but do take heart, all right?"
      Speaker = "Arachne"
      Event = "ArachneChat27"
    }
    {
      Id = "Arachne_0031"
      InheritFrom = "BaseNarrative"
      DisplayName = "Promise you'll let me know if this is anything short of a perfect fit."
      Speaker = "Arachne"
      Event = "ArachneChat28"
    }
    {
      Id = "Arachne_0032"
      InheritFrom = "BaseNarrative"
      DisplayName = "They always said my silk was like a warm embrace, {#Emph}ha ha ha ha..."
      Speaker = "Arachne"
      Event = "ArachneChat29"
    }
    {
      Id = "Arachne_0033"
      InheritFrom = "BaseNarrative"
      DisplayName = "I won't have you going out in anything less than the very best."
      Speaker = "Arachne"
      Event = "ArachneChat30"
    }
    {
      Id = "Melinoe_1606"
      InheritFrom = "BaseNarrative"
      DisplayName = "Each time I pass through Erebus, it's comforting to know I may run into you along the way. Here's something for your lovely lair."
      Speaker = "Melinoe"
      Event = "ArachneGift01"
    }
    {
      Id = "Arachne_0106"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, why this is very sweet! It should attract a host of flies, I think, so thank you, very, {#Emph}very {#Prev}much! Now won't you please take this? It's only fair...!"
      Speaker = "Arachne"
      Event = "ArachneGift01"
    }
    {
      Id = "Arachne_0107"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wait, is this what I think it is? Oh, {#Emph}no{#Prev}, I shouldn't, not again. Weaving silken fineries for somebody such as you truly is an honor and its own reward! Besides, this stuff is for the gods..."
      Speaker = "Arachne"
      Event = "ArachneGift02"
    }
    {
      Id = "MelinoeField_1797"
      InheritFrom = "BaseNarrative"
      DisplayName = "The gods may often be the ones indulging in this stuff, but it's not just for them. It's for you! For those whom we regard as friends."
      Speaker = "Melinoe"
      Event = "ArachneGift02"
    }
    {
      Id = "Arachne_0108"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, you're much too kind to me! I'm only doing what anybody would be doing in my place, but {#Emph}you? {#Prev}You're treating me like royalty! This Nectar... I tried a touch of it before. It's too good for flies... or spiders."
      Speaker = "Arachne"
      Event = "ArachneGift03"
    }
    {
      Id = "MelinoeField_1798"
      InheritFrom = "BaseNarrative"
      DisplayName = "Too good for flies, perhaps. But it's especially for {#Emph}you. {#Prev}A gift of friendship, whose savor only grows the deeper the friendship is. May it warm you on a cold night such as this."
      Speaker = "Melinoe"
      Event = "ArachneGift03"
    }
    {
      Id = "Arachne_0109"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come now, this is all too much! If I were still myself, why, I'd be blushing from my cheeks to my toes. It's just... it's been so long since anybody got me anything, you know?"
      Speaker = "Arachne"
      Event = "ArachneGift04"
    }
    {
      Id = "MelinoeField_1799"
      InheritFrom = "BaseNarrative"
      DisplayName = "I like getting you such things, Arachne. It makes me so unhappy, sometimes, seeing you all by yourself like this. I can never stay for long... so perhaps this Nectar can remind you of the pleasant times we share, when I'm not around."
      Speaker = "Melinoe"
      Event = "ArachneGift04"
    }
    {
      Id = "Arachne_0110"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It most certainly shall. I won't forget your kindness."
      Speaker = "Arachne"
      Event = "ArachneGift04"
    }
    {
      Id = "Arachne_0111"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ha ha ha ha{#Prev}, I don't mean to be rude, it's just... {#Emph}imagine {#Prev}what the gods above would think, seeing their {#Emph}proudest {#Prev}tradition used to honor the {#Emph}lowliest {#Prev}of creatures in this world."
      Speaker = "Arachne"
      Event = "ArachneGift05"
    }
    {
      Id = "MelinoeField_1800"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're not lowly! You're a magnificent talent. A beautiful voice. A trusted friend. I don't know anybody like you, Arachne! And I'm glad you're {#Emph}you. {#Prev}Exactly as you are. I mean it."
      Speaker = "Melinoe"
      Event = "ArachneGift05"
    }
    {
      Id = "Arachne_0112"
      InheritFrom = "BaseNarrative"
      DisplayName = "I... why, I'm — I'm very flattered you would feel that way... it's just... it's too bad you never knew me in my prime, you know? {#Emph}Ah{#Prev}, but what am I saying, I'm just... {#Emph}ha ha ha ha..."
      Speaker = "Arachne"
      Event = "ArachneGift05"
    }
    {
      Id = "Arachne_0113"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know you're doing this just to be kind, my friend, except... the heart does what it wants, and... I, well... I'm concerned I'm beginning to take it the wrong way! I like being alone, I do... but I get lonely still, from time to time."
      Speaker = "Arachne"
      Event = "ArachneGift06"
    }
    {
      Id = "MelinoeField_1801"
      InheritFrom = "BaseNarrative"
      DisplayName = "I get lonely, too. But when I'm here, with you in your lovely little lair, I feel... oh I don't know, I... just want you to be happier! Perhaps it's as you said; the heart does what it wants."
      Speaker = "Melinoe"
      Event = "ArachneGift06"
    }
    {
      Id = "Arachne_0114"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, your poor heart, if all it wants is {#Emph}this! {#Prev}You're a goddess... positively sublime, you realize? You must have a dozen others falling over themselves just to win your affection!"
      Speaker = "Arachne"
      Event = "ArachneGift06"
    }
    {
      Id = "MelinoeField_1802"
      InheritFrom = "BaseNarrative"
      DisplayName = "Even if there were. My other relationships... none of them is any substitute for the one I have with you."
      Speaker = "Melinoe"
      Event = "ArachneGift06"
    }
    {
      Id = "Arachne_0115"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I see... {#Emph}ha ha ha ha..."
      Speaker = "Arachne"
      Event = "ArachneGift06"
    }
    {
      Id = "MelinoeField_4400"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wanted you to have this: The Ambrosia of the gods. You have our talent, and you even have our pride. I figure, what's one more of our greatest gifts?"
      Speaker = "Melinoe"
      Event = "ArachneGift07"
    }
    {
      Id = "Arachne_0396"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ambrosia... you'll soon spoil me like this, you big silly! What am I going to do with so much? I'll be sipping away forever!"
      Speaker = "Arachne"
      Event = "ArachneGift07"
    }
    {
      Id = "MelinoeField_4401"
      InheritFrom = "BaseNarrative"
      DisplayName = "Forever's a long time. And, ideally this is for sharing anyhow. Perhaps for the eventual grand opening of your shoppe!"
      Speaker = "Melinoe"
      Event = "ArachneGift07"
    }
    {
      Id = "Arachne_0397"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now {#Emph}there's {#Prev}an idea. Well then, I ought to store this safe and sound, and know {#Emph}just {#Prev}the way... wrapped in the finest silk."
      Speaker = "Arachne"
      Event = "ArachneGift07"
    }
    {
      Id = "MelinoeField_4402"
      InheritFrom = "BaseNarrative"
      DisplayName = "Here's to the success of Arachne's Garments, Dyes, and Fabrics, whenever the time comes. I find it helps always having something to look forward to, even if it's a way off."
      Speaker = "Melinoe"
      Event = "ArachneGift08"
    }
    {
      Id = "Arachne_0398"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why this is very gracious of you, my friend, and I'd embrace you if I could only reach, and you were so willing, but... I'd best appreciate you from afar."
      Speaker = "Arachne"
      Event = "ArachneGift08"
    }
    {
      Id = "MelinoeField_4403"
      InheritFrom = "BaseNarrative"
      DisplayName = "But I'm not far; I'm here. And I want you to know, I'm glad you haven't changed. If you did... I might have lost you."
      Speaker = "Melinoe"
      Event = "ArachneGift08"
    }
    {
      Id = "Arachne_0399"
      InheritFrom = "BaseNarrative"
      DisplayName = "You'd sooner lose me now since I {#Emph}am {#Prev}rather small! But thank you, truly. I used to think you were just saying things to pity me but now I know you're not."
      Speaker = "Arachne"
      Event = "ArachneGift08"
    }
    {
      Id = "Arachne_0400"
      InheritFrom = "BaseNarrative"
      DisplayName = "No more Ambrosia, {#Emph}please{#Prev}, my friend. I'm running out of room! And you have given little old me more than enough."
      Speaker = "Arachne"
      Event = "ArachneGift09"
    }
    {
      Id = "MelinoeField_4404"
      InheritFrom = "BaseNarrative"
      DisplayName = "Of course, but... perhaps the two of us could share some at some point. Even now...? Since you {#Emph}are {#Prev}running out of room. "
      Speaker = "Melinoe"
      Event = "ArachneGift09"
    }
    {
      Id = "Arachne_0401"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh! {#Prev}Well if you're not too busy, I would truly welcome that. Care to pop the bottle? The cap's a little tight for me..."
      Speaker = "Arachne"
      Event = "ArachneGift09"
    }
    {
      Id = "Arachne_0402"
      InheritFrom = "BaseNarrative"
      DisplayName = "...You've been so gracious with your time and with your love. Most mortals hate spiders... can't imagine most of you goddesses or gods feel any different."
      Speaker = "Arachne"
      Event = "ArachneGift09"
    }
    {
      Id = "MelinoeField_4405"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's commonplace to fear what we don't understand. I'm a witch; we get that a lot. Perhaps that's why I felt connected to you from the start."
      Speaker = "Melinoe"
      Event = "ArachneGift09"
    }
    {
      Id = "Arachne_0403"
      InheritFrom = "BaseNarrative"
      DisplayName = "You felt connected to me because you {#Emph}stepped {#Prev}on me, my friend! Good thing you heard me screaming my head off. That was not the greatest way to meet..."
      Speaker = "Arachne"
      Event = "ArachneGift09"
    }
    {
      Id = "MelinoeField_4406"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps not, but I'd say it worked out. And I've not stepped on you ever again, have I?"
      Speaker = "Melinoe"
      Event = "ArachneGift09"
    }
    {
      Id = "Arachne_0404"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, no, you haven't, I suppose. Say, this Ambrosia, it is {#Emph}really {#Prev}something else! And a little goes a long way!"
      Speaker = "Arachne"
      Event = "ArachneGift09"
    }
    {
      Id = "MelinoeField_4407"
      InheritFrom = "BaseNarrative"
      DisplayName = "Right? I'm glad you're enjoying it. It's always best with those you care about, and this is clearly a good batch."
      Speaker = "Melinoe"
      Event = "ArachneGift09"
    }
    {
      Id = "Arachne_0405"
      InheritFrom = "BaseNarrative"
      DisplayName = "You really do care about me, {#Emph}huh. {#Prev}For the longest time I just wouldn't let myself believe it. But now you {#Emph}know {#Prev}I'm never turning back, and you're still you."
      Speaker = "Arachne"
      Event = "ArachneGift09"
    }
    {
      Id = "MelinoeField_4408"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wouldn't know who else to be. What about you? If you could be anything or anybody else, what would you choose?"
      Speaker = "Melinoe"
      Event = "ArachneGift09"
    }
    {
      Id = "Arachne_0406"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why, I... well I'd choose to be the greatest weaver that the world has ever known, is what. I'm choosing that right now."
      Speaker = "Arachne"
      Event = "ArachneGift09"
    }
    {
      Id = "Arachne_0407"
      InheritFrom = "BaseNarrative"
      DisplayName = "That was truly wonderful, my friend. Thank you so much, for being here with me. For everything."
      Speaker = "Arachne"
      Event = "ArachneGift09"
    }
    {
      Id = "MelinoeField_4410"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Of course. You're my friend, too."
      Speaker = "Melinoe"
      Event = "ArachneGift09"
    }
    {
      Id = "Melinoe_1915"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Arachne, this is beautiful...!"
      Speaker = "Melinoe"
      Event = "NPC_Arachne_01.GiftGivenVoiceLines"
    }
    {
      Id = "Arachne_0252"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come on, come on...!"
      Speaker = "Arachne"
      Event = "NPC_Arachne_01.LastStandReactionVoiceLines"
    }
    {
      Id = "Arachne_0253"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh no...!"
      Speaker = "Arachne"
      Event = "NPC_Arachne_01.LastStandReactionVoiceLines"
    }
    {
      Id = "Arachne_0254"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I can't look...!"
      Speaker = "Arachne"
      Event = "NPC_Arachne_01.LastStandReactionVoiceLines"
    }
    {
      Id = "Arachne_0255"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}<Gasp>"
      Speaker = "Arachne"
      Event = "NPC_Arachne_01.LastStandReactionVoiceLines"
    }
    {
      Id = "Arachne_0289"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hey!"
      Speaker = "Arachne"
      Event = "NPC_Arachne_01.OnHitVoiceLines"
    }
    {
      Id = "Arachne_0290"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Whoa there!"
      Speaker = "Arachne"
      Event = "NPC_Arachne_01.OnHitVoiceLines"
    }
    {
      Id = "Arachne_0291"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You want to play?"
      Speaker = "Arachne"
      Event = "NPC_Arachne_01.OnHitVoiceLines"
    }
    {
      Id = "Arachne_0292"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Missed me!"
      Speaker = "Arachne"
      Event = "NPC_Arachne_01.OnHitVoiceLines"
    }
    {
      Id = "Arachne_0293"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Can't catch me!"
      Speaker = "Arachne"
      Event = "NPC_Arachne_01.OnHitVoiceLines"
    }
    {
      Id = "Arachne_0294"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Too slow!"
      Speaker = "Arachne"
      Event = "NPC_Arachne_01.OnHitVoiceLines"
    }
    {
      Id = "Arachne_0295"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Missed again!"
      Speaker = "Arachne"
      Event = "NPC_Arachne_01.OnHitVoiceLines"
    }
    {
      Id = "Arachne_0296"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Haha{#Prev}, you missed!"
      Speaker = "Arachne"
      Event = "NPC_Arachne_01.OnHitVoiceLines"
    }
    {
      Id = "Arachne_0297"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Almost!"
      Speaker = "Arachne"
      Event = "NPC_Arachne_01.OnHitVoiceLines"
    }
    {
      Id = "Arachne_0298"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ahh! {#Prev}Kidding. You missed."
      Speaker = "Arachne"
      Event = "NPC_Arachne_01.OnHitVoiceLines"
    }
    {
      Id = "Arachne_0065"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, hello there, my friend! I happened to see the Boatman sculling down the Cocytus, presumably to {#Emph}you{#Prev}, for he had all {#Emph}sorts {#Prev}of supplies. He was generous enough to offer me passage. Whether he knew it or not, {#Emph}ha ha ha ha..."
      Speaker = "Arachne"
      Event = "ArachneHubFirstMeeting01"
    }
    {
      Id = "Melinoe_3141"
      InheritFrom = "BaseNarrative"
      DisplayName = "Great to see you here and welcome, Arachne! I'm certain Charon doesn't mind such a courteous stowaway. Is there anything we can do to make your stay with us more comfortable?"
      Speaker = "Melinoe"
      Event = "ArachneHubFirstMeeting01"
    }
    {
      Id = "Arachne_0066"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, thank you. I don't intend to be here very long. Especially since the Boatman is my ticket home. I'll just make certain all my silk here is patched up, and then be on my way. Be well, won't you?"
      Speaker = "Arachne"
      Event = "ArachneHubFirstMeeting01"
    }
    {
      Id = "Melinoe_3142"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You, too..."
      Speaker = "Melinoe"
      Event = "ArachneHubFirstMeeting01"
    }
    {
      Id = "Arachne_0098"
      InheritFrom = "BaseNarrative"
      DisplayName = "...{#Emph}Oh{#Prev}, don't worry. I'll be fine! I know those woods out there like the back of my, {#Emph}um... leg{#Prev}, I do suppose! I'm always grateful for your hospitality, great Titaness."
      Speaker = "Arachne"
      Event = "ArachneWithHecateInHub01"
    }
    {
      Id = "Hecate_0545"
      InheritFrom = "BaseNarrative"
      DisplayName = "And you are welcome here and safe, Arachne. Now I must beg your pardon. The matters that unfold of late require more of my attention than I'd like..."
      Speaker = "Hecate"
      Event = "ArachneWithHecateInHub01"
    }
    {
      Id = "Arachne_0099"
      InheritFrom = "BaseNarrative"
      DisplayName = "I truly understand. Then I'll get out of your hair. Farewell for now!"
      Speaker = "Arachne"
      Event = "ArachneWithHecateInHub01"
    }
    {
      Id = "Hecate_0546"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Farewell in turn."
      Speaker = "Hecate"
      Event = "ArachneWithHecateInHub01"
    }
    {
      Id = "Arachne_0100"
      InheritFrom = "BaseNarrative"
      DisplayName = "...But, this {#Emph}can't {#Prev}be.... Titaness, whatever do you mean? Because if you meant what you said, why... all those times you told me that I'm welcome here and safe... all lies, then. Is that it?"
      Speaker = "Arachne"
      Event = "ArachneWithHecateInHub02"
    }
    {
      Id = "Hecate_0547"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your anger's justified. 'Twas my poison that Athena used whilst cursing you. But the curse is hers, not mine. I'd no desire that you knew {#Emph}any {#Prev}of this. Melinoë, however, swayed me against my instincts."
      Speaker = "Hecate"
      Event = "ArachneWithHecateInHub02"
    }
    {
      Id = "Arachne_0101"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I don't know what to say. So this is {#Emph}your {#Prev}fault. Athena never could have done this to me without your {#Emph}help. {#Prev}You Titans and the gods... you're all alike. Good evening!"
      Speaker = "Arachne"
      Event = "ArachneWithHecateInHub02"
    }
    {
      Id = "Hecate_0548"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Arachne, be reasonable... {#Emph}ungh..."
      Speaker = "Hecate"
      Event = "ArachneWithHecateInHub02"
    }
    {
      Id = "Arachne_0171"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Certainly!"
      Speaker = "Arachne"
      Event = "GlobalVoiceLines.CostumeChangedVoiceLines"
    }
    {
      Id = "Arachne_0172"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Of course!"
      Speaker = "Arachne"
      Event = "GlobalVoiceLines.CostumeChangedVoiceLines"
    }
    {
      Id = "Arachne_0173"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Of course."
      Speaker = "Arachne"
      Event = "GlobalVoiceLines.CostumeChangedVoiceLines"
    }
    {
      Id = "Arachne_0174"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Right away."
      Speaker = "Arachne"
      Event = "GlobalVoiceLines.CostumeChangedVoiceLines"
    }
    {
      Id = "Arachne_0175"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Coming right up!"
      Speaker = "Arachne"
      Event = "GlobalVoiceLines.CostumeChangedVoiceLines"
    }
    {
      Id = "Arachne_0176"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, yes."
      Speaker = "Arachne"
      Event = "GlobalVoiceLines.CostumeChangedVoiceLines"
    }
    {
      Id = "Arachne_0177"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I hear that!"
      Speaker = "Arachne"
      Event = "GlobalVoiceLines.CostumeChangedVoiceLines"
    }
    {
      Id = "Arachne_0178"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Wonderful."
      Speaker = "Arachne"
      Event = "GlobalVoiceLines.CostumeChangedVoiceLines"
    }
    {
      Id = "Arachne_0179"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You bet."
      Speaker = "Arachne"
      Event = "GlobalVoiceLines.CostumeChangedVoiceLines"
    }
    {
      Id = "Arachne_0180"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Why, sure!"
      Speaker = "Arachne"
      Event = "GlobalVoiceLines.CostumeChangedVoiceLines"
    }
    {
      Id = "Arachne_0183"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, you look {#Emph}wonderful!"
      Speaker = "Arachne"
      Event = "GlobalVoiceLines.CostumeChangedVoiceLines"
    }
    {
      Id = "Arachne_0189"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You truly look lovely."
      Speaker = "Arachne"
      Event = "GlobalVoiceLines.CostumeChangedVoiceLines"
    }
    {
      Id = "Arachne_0196"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Like a warm embrace..."
      Speaker = "Arachne"
      Event = "GlobalVoiceLines.CostumeChangedVoiceLines"
    }
    {
      Id = "Arachne_0198"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Absolutely stunning...!"
      Speaker = "Arachne"
      Event = "GlobalVoiceLines.CostumeChangedVoiceLines"
    }
    {
      Id = "Arachne_0181"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A {#Emph}perfect {#Prev}fit!"
      Speaker = "Arachne"
      Event = "GlobalVoiceLines.CostumeChangedVoiceLines"
    }
    {
      Id = "Arachne_0187"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Made this one just for you."
      Speaker = "Arachne"
      Event = "GlobalVoiceLines.CostumeChangedVoiceLines"
    }
    {
      Id = "Arachne_0188"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I knew you'd pick this one!"
      Speaker = "Arachne"
      Event = "GlobalVoiceLines.CostumeChangedVoiceLines"
    }
    {
      Id = "Arachne_0191"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Now you enjoy, all right?"
      Speaker = "Arachne"
      Event = "GlobalVoiceLines.CostumeChangedVoiceLines"
    }
    {
      Id = "Arachne_0192"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Whew! {#Prev}Enjoy it while it lasts..."
      Speaker = "Arachne"
      Event = "GlobalVoiceLines.CostumeChangedVoiceLines"
    }
    {
      Id = "Arachne_0193"
      InheritFrom = "BaseSubtitle"
      DisplayName = "All in an evening's work!"
      Speaker = "Arachne"
      Event = "GlobalVoiceLines.CostumeChangedVoiceLines"
    }
    {
      Id = "Arachne_0194"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Woven with care."
      Speaker = "Arachne"
      Event = "GlobalVoiceLines.CostumeChangedVoiceLines"
    }
    {
      Id = "Arachne_0195"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It's all yours."
      Speaker = "Arachne"
      Event = "GlobalVoiceLines.CostumeChangedVoiceLines"
    }
    {
      Id = "Arachne_0197"
      InheritFrom = "BaseSubtitle"
      DisplayName = "May it keep you safe."
      Speaker = "Arachne"
      Event = "GlobalVoiceLines.CostumeChangedVoiceLines"
    }
    {
      Id = "Arachne_0200"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What a sight you are."
      Speaker = "Arachne"
      Event = "GlobalVoiceLines.CostumeChangedVoiceLines"
    }
    {
      Id = "Arachne_0190"
      InheritFrom = "BaseSubtitle"
