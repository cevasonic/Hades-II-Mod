      Event = "NPC_Athena_01.EncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_2810"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're here!"
      Speaker = "Melinoe"
      Event = "NPC_Athena_01.EncounterEndVoiceLines"
    }
    {
      Id = "MelinoeField_2568"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Lady Athena...!"
      Speaker = "Melinoe"
