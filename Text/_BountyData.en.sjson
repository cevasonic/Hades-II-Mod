      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0308"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The lowest reaches of your father's realm."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0310"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How quickly you have reached this mountain's summit..."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0309"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The summit of Olympus, beyond Time..."
