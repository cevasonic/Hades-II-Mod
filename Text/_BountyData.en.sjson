      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0315"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This Trial has no constancy at all."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0316"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I have yet to consider all the possibilities herein."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0305"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I caution that this Trial likely is impossible for you."
