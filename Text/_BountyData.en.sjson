      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0300"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Heed now the summons of the Queen of Olympus."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0301"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The influence of Strife spreads rapidly, but can be slowed."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0302"
      InheritFrom = "BaseSubtitle"
      DisplayName = "One of your relatives devotes himself to war; this is for him."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0274"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This Trial shall compare you to the caretaker of your domain."
