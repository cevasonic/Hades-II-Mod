    {
      Id = "Chaos_0248"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Perhaps you should cease attempting this Trial for now."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0249"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Perhaps if your weapon was stronger? Or perhaps not."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0250"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I have eternity for these attempts; do you?"
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0251"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Only continue with this Trial if that is your wish."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0237"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Repeated failure is acceptable to me, for it is amusing."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0239"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Your prior failure in this Trial was quite interesting to observe."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0242"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This Trial has been difficult, and yet you reattempt."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0243"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I think this Trial may be far too difficult for you."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0244"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Try all you like; your repeat attempts are interesting."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0247"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We have been through this before, and shall do it again."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0233"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Repetition sometimes is required for success."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0236"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I am curious to see if you shall fail this Trial once again."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0238"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Shall this Trial prove too much for you again?"
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0232"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You are the variable in this Trial, Spawn of Hades."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0234"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A Trial may require multiple attempts."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0235"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I have affected this night much like you experienced before."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0240"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Perhaps you have a better sense of what to expect this time."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0241"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I appreciate your willingness to reattempt this Trial."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0245"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This is a Trial that you know; yet the outcome may change."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0246"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I shall be interested to see what you do differently this time."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0217"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Our Trial thus begins, O Spawn of Hades."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0262"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Vengeance is an impulse I would better understand."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0265"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Gold flows freely throughout my domain; claim it."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0268"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Let us see the so-called Earth-Shaker live up to his title."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0277"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This is a Trial of strength, so please use it with care."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0271"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The god of the forge knows something of creation himself."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0275"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This is a Trial of destruction, so please see what you can do."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0269"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I have no wish to see the god of light, only his strength."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0270"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The cold brought on by the goddess of seasons, I know well."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0272"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The goddess of love is well accustomed to being observed."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0273"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The goddess of the hearth, and the potential of her flames..."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0276"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This is a Trial of haste, so please do not hesitate."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0224"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You lack the power you accumulated; but not the knowledge."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0225"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I can take away your strength, but not your experience."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0264"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You have a strong connection to the Moon; show it to me."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0267"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Queen of Olympus understands the bonds we share."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0278"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I believe your magick shall be of little use in this Trial."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0263"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Do the Fates determine what transpires, or do you?"
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0266"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The King of Olympus commands thunder, but I created it."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0219"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You have arrived here rather quickly, Spawn of Hades."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0220"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Let us begin our current Trial from this point."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0221"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Commence this Trial from this point, beginning now."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0222"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I have an interest in evaluating this domain."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0223"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You may proceed immediately, Spawn of Hades."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0226"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This Trial shall attempt to break you, Spawn of Hades."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0227"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It is possible that this Trial is impossible, Spawn of Hades."
