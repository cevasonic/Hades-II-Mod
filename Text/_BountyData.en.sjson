      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0304"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I leave the details of this Trial for you to discover."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0306"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Whether this Trial goes as we expect, let us find out."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0311"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I chose each detail of this Trial arbitrarily."
