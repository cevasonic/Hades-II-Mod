      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0109"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Is all this in accordance with the Fates' design?"
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0110"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Of infinite possibilities, this was your choice."
