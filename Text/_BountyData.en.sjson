      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0228"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I do not think you shall complete this Trial, though please try."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0229"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Fates themselves determine the details of this Trial."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0230"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I cede control of the details of this Trial to the Fates."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0231"
      InheritFrom = "BaseSubtitle"
      DisplayName = "In choosing this Trial, all other choices shall be made for you."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0298"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The King of the Olympians relies upon his storms for shelter."
      Speaker = "Chaos"
      Event = "GlobalVoiceLines.StartPackagedBountyRunVoiceLines"
    }
    {
      Id = "Chaos_0299"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not much would survive if the goddess of seasons so chose."
