    {
      Id = "Chronos_1137"
      InheritFrom = "BaseSubtitle"
      DisplayName = "If you think {#Emph}this {#Prev}is bothersome, just wait till you see my next trick!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.SkipZeusVoiceLines"
    }
    {
      Id = "Chronos_1125"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Alas the weather has been causing quite a few delays!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.SkipZeusVoiceLines"
    }
    {
      Id = "Chronos_1126"
      InheritFrom = "BaseSubtitle"
      DisplayName = "My dear son Zeus is presently preoccupied with even graver matters than your own!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.SkipZeusVoiceLines"
    }
    {
      Id = "Chronos_1127"
      InheritFrom = "BaseSubtitle"
      DisplayName = "If only my son Zeus and all his ilk could see you now, my girl!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.SkipZeusVoiceLines"
    }
    {
      Id = "Chronos_1128"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The gods themselves have abandoned you, granddaughter...!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.SkipZeusVoiceLines"
    }
    {
      Id = "Chronos_1130"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not quite so powerful without your Lord Uncle's lightning bolt, are you?"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.SkipZeusVoiceLines"
    }
    {
      Id = "Chronos_1131"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Where is that good-for-nothing son of mine when you need him, {#Emph}hm?"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.SkipZeusVoiceLines"
    }
    {
      Id = "Chronos_1132"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Oh my{#Prev}, the view from up here truly is magnificent, my girl! "
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.SkipZeusVoiceLines"
    }
    {
      Id = "Chronos_1133"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Such a shame that your Lord Uncle could not be here to join us!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.SkipZeusVoiceLines"
    }
    {
      Id = "Chronos_1134"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Why {#Emph}look at me{#Prev}, I dilly-dally whilst the Father of All Monsters does the work!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.SkipZeusVoiceLines"
    }
    {
      Id = "Chronos_1135"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Dum-dum-dum-dummm, dum-dum-dum-dummmm..."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.SkipZeusVoiceLines"
    }
    {
      Id = "Chronos_1136"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hmm-hmm-hmm-hmmm, hmm-hmm-hmm-hmmmm...."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.SkipZeusVoiceLines"
    }
    {
      Id = "Chronos_1129"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...or perhaps merely running late!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.SkipZeusVoiceLines"
    }
    {
      Id = "Chronos_1138"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not so fast."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PreBabalityVoiceLines"
    }
    {
      Id = "Chronos_1139"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No! Not yet."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PreBabalityVoiceLines"
    }
    {
      Id = "Chronos_1140"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I think not."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PreBabalityVoiceLines"
    }
    {
      Id = "Chronos_1141"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We're not done!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PreBabalityVoiceLines"
    }
    {
      Id = "Chronos_1142"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Get back here, monster!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PreBabalityVoiceLines"
    }
    {
      Id = "Chronos_1143"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh {#Emph}come on{#Prev}, Typhon...!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PreBabalityVoiceLines"
    }
    {
      Id = "Chronos_1144"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come {#Emph}on{#Prev}, Typhon...!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PreBabalityVoiceLines"
    }
    {
      Id = "Chronos_1145"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Get back {#Emph}up{#Prev}, monster!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PreBabalityVoiceLines"
    }
    {
      Id = "Chronos_1146"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh {#Emph}get up{#Prev}, Typhon..."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PreBabalityVoiceLines"
    }
    {
      Id = "Chronos_1147"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Some monster {#Emph}he {#Prev}is..."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PreBabalityVoiceLines"
    }
    {
      Id = "Chronos_1148"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hrr..."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PreBabalityVoiceLines"
    }
    {
      Id = "Chronos_1149"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Augh..."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PreBabalityVoiceLines"
    }
    {
      Id = "Chronos_1150"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}<Laughter>"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PreBabalityVoiceLines"
    }
    {
      Id = "Chronos_1151"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}<Laughter>"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PreBabalityVoiceLines"
    }
    {
      Id = "Chronos_1152"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And as for you..."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.BabalityVoiceLines"
    }
    {
      Id = "Chronos_1153"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Turn back!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.BabalityVoiceLines"
    }
    {
      Id = "Chronos_1154"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Turn back!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.BabalityVoiceLines"
    }
    {
      Id = "Chronos_1155"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Turn back{#Prev}, I say!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.BabalityVoiceLines"
    }
    {
      Id = "Chronos_1156"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Turn back...!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.BabalityVoiceLines"
    }
    {
      Id = "Chronos_1157"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Turn back."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.BabalityVoiceLines"
    }
    {
      Id = "Chronos_1158"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Turn back...?"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.BabalityVoiceLines"
    }
    {
      Id = "Chronos_1159"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just, {#Emph}turn back...!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.BabalityVoiceLines"
    }
    {
      Id = "Chronos_1160"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Why won't you {#Emph}turn back?!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.BabalityVoiceLines"
    }
    {
      Id = "MelinoeField_3787"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Aaah!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.BabalityVoiceLines"
    }
    {
      Id = "MelinoeField_3789"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You'll pay for this, Titan! I swear it!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.PostBabalityVoiceLines"
    }
    {
      Id = "Chronos_1173"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Why, is she not {#Emph}adorable{#Prev}, Typhon? Look at her little {#Emph}feet {#Prev}as she goes running all about!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PostBabalityVoiceLines"
    }
    {
      Id = "Chronos_1174"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You make attempts to break my spell! How very {#Emph}clever{#Prev}, especially for one so very {#Emph}young!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PostBabalityVoiceLines"
    }
    {
      Id = "Chronos_1175"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ah{#Prev}, the carefree joys of youth! Do you not miss those bygone times, my girl?"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PostBabalityVoiceLines"
    }
    {
      Id = "Chronos_1176"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Now do go {#Emph}easy {#Prev}on her, Typhon! She is but a poor, {#Emph}defenseless {#Prev}little girl."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PostBabalityVoiceLines"
    }
    {
      Id = "Chronos_1177"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Run, little girl, or try! But there is nowhere left for you to go, and these are nightmares that shall {#Emph}never {#Prev}cease."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PostBabalityVoiceLines"
    }
    {
      Id = "Chronos_1179"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Now, Typhon, if you cannot even stop a helpless little girl, then I do not know what to tell you..."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PostBabalityVoiceLines"
    }
    {
      Id = "Chronos_1180"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Well! {#Prev}If the Father of All Monsters and I cannot even stop this darling little child, then perhaps we are unfit to rule!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PostBabalityVoiceLines"
    }
    {
      Id = "Chronos_1181"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Cease with all your struggling, already! What can you possibly be hoping to achieve?!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PostBabalityVoiceLines"
    }
    {
      Id = "Chronos_1182"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Though it is terribly uncouth to take one's anger out on little children, you have left me with no other choice!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PostBabalityVoiceLines"
    }
    {
      Id = "Chronos_1184"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A fitting form for one as small-minded as you! Although barely a {#Emph}snack {#Prev}for Typhon here!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PostBabalityVoiceLines"
    }
    {
      Id = "Chronos_1183"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Would you look at us, Typhon? Having to beat up on little girls! How mortifying...!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PostBabalityVoiceLines"
    }
    {
      Id = "Chronos_1178"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Run, little girl! Perhaps evade from time to time as well! That is all you can do!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PostBabalityVoiceLines"
    }
    {
      Id = "Chronos_1161"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You are nothing but a pathetic child. May you always remember that, should you somehow withstand what shall imminently transpire."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PostBabalityVoiceLines"
    }
    {
      Id = "Chronos_1163"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Always remember how small and frightened you once must have felt. Inside, you are {#Emph}still {#Prev}that same old wretched girl."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PostBabalityVoiceLines"
    }
    {
      Id = "Chronos_1164"
      InheritFrom = "BaseSubtitle"
      DisplayName = "There is no way to turn back Time. But I can make exceptions here and there... because I {#Emph}make the blasted rules!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PostBabalityVoiceLines"
    }
    {
      Id = "Chronos_1165"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Let me remind you just how small and weak you truly are. We all grow older, yes, but none of us shall ever change in our entirety."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PostBabalityVoiceLines"
    }
    {
      Id = "Chronos_1166"
      InheritFrom = "BaseSubtitle"
      DisplayName = "To think if I was but a bit more careful then I could have taken {#Emph}you {#Prev}along with all the rest of your dear family; and saved myself the trouble {#Emph}here!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PostBabalityVoiceLines"
    }
    {
      Id = "Chronos_1167"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Stubborn little {#Emph}brat! That {#Prev}is what you are. Look at yourself, in all your youthful frailty. This is all you {#Emph}ever {#Prev}were."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PostBabalityVoiceLines"
    }
    {
      Id = "Chronos_1168"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Know your insignificance, child! You may pitter-patter all about now to your heart's content. I certainly care {#Emph}not!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PostBabalityVoiceLines"
    }
    {
      Id = "Chronos_1169"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Alas that you were raised without appropriate parental guidance for you lack even the most basic manners, even for a rotten little girl."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PostBabalityVoiceLines"
    }
    {
      Id = "Chronos_1170"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You clearly never learned to listen to your elders, girl, so {#Emph}fine! {#Prev}I am quite finished with attempts at {#Emph}reasoning {#Prev}with you."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PostBabalityVoiceLines"
    }
    {
      Id = "Chronos_1171"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Your {#Emph}mother {#Prev}would have been so very {#Emph}proud {#Prev}of the delightful little girl you once were! {#Emph}Ah {#Prev}well."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PostBabalityVoiceLines"
    }
    {
      Id = "Chronos_1172"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Poor little girl{#Prev}, are you going to {#Emph}cry? {#Prev}For all the {#Emph}hardship {#Prev}which you have endured?"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.PostBabalityVoiceLines"
    }
    {
      Id = "MelinoeField_3800"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Let me {#Emph}go!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.ClearedBabalityVoiceLines"
    }
    {
      Id = "MelinoeField_3801"
      InheritFrom = "BaseSubtitle"
      DisplayName = "All right that {#Emph}does it!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.ClearedBabalityVoiceLines"
    }
    {
      Id = "MelinoeField_3802"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...{#Emph}My {#Prev}turn now!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.ClearedBabalityVoiceLines"
    }
    {
      Id = "MelinoeField_3803"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll make you {#Emph}pay!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.ClearedBabalityVoiceLines"
    }
    {
      Id = "MelinoeField_3804"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Unacceptable!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.ClearedBabalityVoiceLines"
    }
    {
      Id = "MelinoeField_3805"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Enough!!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.ClearedBabalityVoiceLines"
    }
    {
      Id = "Chronos_1185"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You broke free..."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ClearedBabalityVoiceLines"
    }
    {
      Id = "Chronos_1186"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You've... grown..."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ClearedBabalityVoiceLines"
    }
    {
      Id = "Chronos_1187"
      InheritFrom = "BaseSubtitle"
      DisplayName = "My spell...!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ClearedBabalityVoiceLines"
    }
    {
      Id = "Chronos_1188"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How did you...?"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ClearedBabalityVoiceLines"
    }
    {
      Id = "Chronos_1189"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How is this—"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ClearedBabalityVoiceLines"
    }
    {
      Id = "Chronos_1190"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This cannot—"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ClearedBabalityVoiceLines"
    }
    {
      Id = "Chronos_1191"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, blast..."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ClearedBabalityVoiceLines"
    }
    {
      Id = "Chronos_1193"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Back to your old self?"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ClearedBabalityVoiceLines"
    }
    {
      Id = "Chronos_1194"
      InheritFrom = "BaseSubtitle"
      DisplayName = "They grow up so fast..."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ClearedBabalityVoiceLines"
    }
    {
      Id = "Chronos_1192"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not again..."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ClearedBabalityVoiceLines"
    }
    {
      Id = "Chronos_1203"
      InheritFrom = "BaseSubtitle"
      DisplayName = "All right, all right, you {#Emph}win{#Prev}, you little..."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosRunClearVoiceLines"
    }
    {
      Id = "Chronos_1195"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Typhon! Wait! {#Emph}Augh..."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosRunClearVoiceLines"
    }
    {
      Id = "Chronos_1196"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This is an {#Emph}outrage! Augh!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosRunClearVoiceLines"
    }
    {
      Id = "Chronos_1197"
      InheritFrom = "BaseSubtitle"
      DisplayName = "He had a {#Emph}family{#Prev}, you monster!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosRunClearVoiceLines"
    }
    {
      Id = "Chronos_1198"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Would you look at the Time...?"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosRunClearVoiceLines"
    }
    {
      Id = "Chronos_1199"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Well, I ought be getting back..."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosRunClearVoiceLines"
    }
    {
      Id = "Chronos_1200"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The blasted Fates must be abetting you!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosRunClearVoiceLines"
    }
    {
      Id = "Chronos_1201"
      InheritFrom = "BaseSubtitle"
      DisplayName = "So much for the Father of All Monsters then!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosRunClearVoiceLines"
    }
    {
      Id = "Chronos_1202"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well this did not exactly go as planned...!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosRunClearVoiceLines"
    }
    {
      Id = "Chronos_1204"
      InheritFrom = "BaseSubtitle"
      DisplayName = "All right, you won again, {#Emph}happy?!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosRunClearVoiceLines"
    }
    {
      Id = "Chronos_1205"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Are you quite {#Emph}pleased {#Prev}with yourself now?!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosRunClearVoiceLines"
    }
    {
      Id = "Chronos_1206"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well glory unto you! {#Emph}Argh!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosRunClearVoiceLines"
    }
  ]
}
