    }
    {
      Id = "Chronos_0996"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You wish to see the End of Time? {#Emph}Here {#Prev}it is!"
      Speaker = "Chronos"
      Event = "Chronos.NextPhaseVoiceLines"
    }
    {
      Id = "Chronos_0275"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Time... cannot... be stopped...!"
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_1451"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Mark... my... words..."
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_0277"
      InheritFrom = "BaseSubtitle"
      DisplayName = "But, Time... cannot... be stopped..."
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_1447"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Leave... me... be..."
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_1450"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You... shall... see..."
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_1454"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What... is this... about...?"
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_1457"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Future... family... I..."
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_0276"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Time... cannot... be stopped..."
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_0278"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You... shall not... succeed..."
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_0279"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hah, haha, hahah..."
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_0280"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hahaha, hah, hah..."
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_0281"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I always... shall... return..."
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_0283"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How is this... possible...?"
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_0284"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Do not... presume... you won..."
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_0285"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You think... that you... prevailed...?"
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_0286"
      InheritFrom = "BaseSubtitle"
      DisplayName = "May all... my kin... be damned...!"
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_0288"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This I... shall not... forget..."
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_0289"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Once more... you bested... me..."
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_0290"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I shall... remember... this..."
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_0282"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No god... can vanquish... me..."
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_0287"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Curse you... and all... the gods..."
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_1364"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Nrrraaaaauugggghhhh...!"
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_1365"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What is happening to me...?"
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_1366"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Imposter! {#Prev}How did you..."
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_1367"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What, I... feel... most odd..."
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_1368"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Time... cannot... be..."
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_1369"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What have you done to me...?"
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_1370"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The sting of my own scythe..."
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_1371"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You, who did this to me, how...?"
      Speaker = "Chronos"
      Event = "Chronos.DefeatedVoiceLines"
    }
    {
      Id = "Chronos_0164"
      InheritFrom = "BaseNarrative"
      DisplayName = "Let yourself in, I see. Through the gutter? This family never had any class! Though I am working on alleviating that within this House, if you would pardon all the {#Emph}dust. {#Prev}We have been {#Emph}renovating {#Prev}around here."
      Speaker = "Chronos"
      Event = "ChronosBossFirstMeeting"
    }
    {
      Id = "MelinoeField_1311"
      InheritFrom = "BaseNarrative"
      DisplayName = "Get up. You get up off that stolen throne! You know who I am, and you know why I'm here."
      Speaker = "Melinoe"
      Event = "ChronosBossFirstMeeting"
    }
    {
      Id = "Chronos_0165"
      InheritFrom = "BaseNarrative"
      DisplayName = "A family with no class, and no civility, either. Have I not made clear to you that your attempt to do me harm shall be in vain? I am a deathless {#Emph}Titan. {#Prev}You merely are a poor, misguided {#Emph}girl."
      Speaker = "Chronos"
      Event = "ChronosBossFirstMeeting"
    }
    {
      Id = "MelinoeField_1312"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hear me, you enemy of Night and Darkness, now; \n {#Emph}For your transgressions, you shall imminently die; \n {#Emph}Under chthonic doctrine, this I vow! \n {#Emph}For there is no escape from Fate beneath the sky."
      Speaker = "Melinoe"
      Event = "ChronosBossFirstMeeting"
    }
    {
      Id = "Chronos_0166"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Manners! {#Prev}Cursing is forbidden in this House. By that token, {#Emph}fighting {#Prev}is forbidden as well. But for you, my girl? We shall have to make an exception. {#Emph}Time {#Prev}for you to {#Emph}go."
      Speaker = "Chronos"
      Event = "ChronosBossFirstMeeting"
    }
    {
      Id = "Chronos_0456"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Behold!"
      Speaker = "Chronos"
      Event = "ChronosBossFirstMeeting"
    }
    {
      Id = "MelinoeField_1313"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Death to Chronos!"
      Speaker = "Melinoe"
      Event = "ChronosBossFirstMeeting"
    }
    {
      Id = "Chronos_0204"
      InheritFrom = "BaseNarrative"
      DisplayName = "Pray, who might you be, my girl? It is not often that I entertain of late. Perhaps after this House becomes a little more presentable... though for the moment, you must pardon all the dust. We have been {#Emph}renovating {#Prev}around here."
      Speaker = "Chronos"
      Event = "ChronosBossFirstMeeting_B"
    }
    {
      Id = "Chronos_0205"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ahh{#Prev}, what a surprise. My granddaughter! The one loose end I failed to tie up, now fully grown, almost. I have so many questions, if you please. How have you been? And how, exactly, did you find me here?"
      Speaker = "Chronos"
      Event = "ChronosBossFirstMeeting_B"
    }
    {
      Id = "Chronos_0207"
      InheritFrom = "BaseNarrative"
      DisplayName = "A guest, arrived so soon! It is not often that I entertain of late. Perhaps after this House becomes a little more presentable... though for the moment, you must pardon all the dust. We have been {#Emph}renovating {#Prev}around here."
      Speaker = "Chronos"
      Event = "ChronosBossFirstMeeting_C"
    }
    {
      Id = "Chronos_0208"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come, now, Granddaughter. There is no need to rush! You have come all this way. And I have so many questions. How have you been? And how, exactly, did you find me here?"
      Speaker = "Chronos"
      Event = "ChronosBossFirstMeeting_C"
    }
    {
      Id = "Chronos_0167"
      InheritFrom = "BaseNarrative"
      DisplayName = "You slipped through my fingers before, only to return and give to me another opportunity to add you to my collection? Did Athena truly get all the wisdom in our family?"
      Speaker = "Chronos"
      Event = "ChronosBossLostAgainstHim01"
    }
    {
      Id = "MelinoeField_1314"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your {#Emph}collection... {#Prev}you speak of your kin as objects to be put on display. The gods ought have put {#Emph}you {#Prev}on display after cutting you to pieces, instead of discarding you like common filth."
      Speaker = "Melinoe"
      Event = "ChronosBossLostAgainstHim01"
    }
    {
      Id = "Chronos_0168"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know, I am still rather sore about all that. I truly thought my children would be different; that they would show their elders some respect. But they did not. And my tolerance... has its limits."
      Speaker = "Chronos"
      Event = "ChronosBossLostAgainstHim01"
    }
    {
      Id = "Chronos_0169"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your eyes do not deceive; I am as hale and hearty as can be! That sinking sense you must have felt after our previous exchange? The fear of the utter senselessness of your entire enterprise? You now know it to be true."
      Speaker = "Chronos"
      Event = "ChronosBossWonAgainstHim01"
    }
    {
      Id = "MelinoeField_1315"
      InheritFrom = "BaseNarrative"
      DisplayName = "I was never going to destroy you in a single clash. You more than anybody ought to know results of any worth take time."
      Speaker = "Melinoe"
      Event = "ChronosBossWonAgainstHim01"
    }
    {
      Id = "Chronos_0170"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ahh{#Prev}, so then you wish to make a habit of such unceremonious appearances as {#Emph}this! {#Prev}As though they might amount to something, in the end. Fine. For my part, I occasionally need to stretch my limbs."
      Speaker = "Chronos"
      Event = "ChronosBossWonAgainstHim01"
    }
    {
      Id = "Chronos_0171"
      InheritFrom = "BaseNarrative"
      DisplayName = "You should have seen the hideous appearance of this place when I arrived! Or, I suppose you {#Emph}did{#Prev}, but were too little to recall. I daresay now it is a little more presentable. Yet you barge in, tracking blood and filth across the floor."
      Speaker = "Chronos"
      Event = "ChronosBossAboutHouse01"
    }
    {
      Id = "MelinoeField_1316"
      InheritFrom = "BaseNarrative"
      DisplayName = "My apologies to your custodial staff. Next time, I'll have to try to be a little more presentable when I arrive."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutHouse01"
    }
    {
      Id = "Chronos_0172"
      InheritFrom = "BaseNarrative"
      DisplayName = "You seethe with bitter irony; but look at yourself! Come to confront me whilst more dead than alive. Well, the sooner I cast you out, the sooner my {#Emph}custodial staff {#Prev}can start to tidy up."
      Speaker = "Chronos"
      Event = "ChronosBossAboutHouse01"
    }
    {
      Id = "Chronos_0609"
      InheritFrom = "BaseNarrative"
      DisplayName = "Did you enjoy your swim? The River Styx once flowed through here like blood. Foul traces of it yet remain in the Fields above, but now in my vicinity, it is all grains of gold."
      Speaker = "Chronos"
      Event = "ChronosBossAboutStyx01"
    }
    {
      Id = "MelinoeField_2021"
      InheritFrom = "BaseNarrative"
      DisplayName = "You would transform the River Styx itself to suit your fancy? Or perhaps I heard you incorrectly. I may still have too many of your grains of gold stuck in my ears."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutStyx01"
    }
    {
      Id = "Chronos_0610"
      InheritFrom = "BaseNarrative"
      DisplayName = "No wonder you have had such difficulty listening to me. Nevertheless, I trust the point I am about to make shall come through loud and clear."
      Speaker = "Chronos"
      Event = "ChronosBossAboutStyx01"
    }
    {
      Id = "Chronos_0603"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have been busy on the surface, have you not? Paid witness to indomitable fleets that sail toward inevitable victory, and the destruction of the mountain of the gods."
      Speaker = "Chronos"
      Event = "ChronosBossAboutThessaly01"
    }
    {
      Id = "MelinoeField_1951"
      InheritFrom = "BaseNarrative"
      DisplayName = "The only fleet I saw up there was a ramshackle mess whose crew could barely stand, much less put up a fight. No wonder you have failed to take Olympus yet."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutThessaly01"
    }
    {
      Id = "Chronos_0604"
      InheritFrom = "BaseNarrative"
      DisplayName = "My fleets may not be to your standards, girl; but they have one important characteristic, which the gods all sorely lack: They are loyal to {#Emph}me {#Prev}to the end. Whichever end I {#Emph}deem!"
      Speaker = "Chronos"
      Event = "ChronosBossAboutThessaly01"
    }
    {
      Id = "Chronos_0175"
      InheritFrom = "BaseNarrative"
      DisplayName = "You are too young to know what it was like. Before the gods re-shaped the world to be like this. Mortals did not have to die in agony, and waste away within this {#Emph}pit. {#Prev}A simpler age, and all the better for it."
      Speaker = "Chronos"
      Event = "ChronosBossAboutGoldenAge01"
    }
    {
      Id = "MelinoeField_1318"
      InheritFrom = "BaseNarrative"
      DisplayName = "All the better, because you controlled every detail, is that it? You couldn't stand that others had a different outlook than your own. You went to war with your own children! After eating them whole, so they say."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutGoldenAge01"
    }
    {
      Id = "Chronos_0176"
      InheritFrom = "BaseNarrative"
      DisplayName = "They say a lot of things! {#Emph}They {#Prev}went to war with {#Emph}me. {#Prev}My offspring and my other charges did not always take to discipline; I had too many to look after to take cheek from any one. And {#Emph}you{#Prev}, my girl, are not entitled to anything more."
      Speaker = "Chronos"
      Event = "ChronosBossAboutGoldenAge01"
    }
    {
      Id = "Chronos_0501"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have by now seen something of this world. Consider what the gods have wrought: war, famine, betrayal! During my Golden Age, there were no such concerns. It was a tranquil time... until the gods decided to wrest control forcibly!"
      Speaker = "Chronos"
      Event = "ChronosBossAboutGoldenAge02"
    }
    {
      Id = "MelinoeField_1504"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps your rule was not as perfect as you claim. Perhaps you were a stifling presence on your children and their generation, leaving them with little choice but to rid themselves of you."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutGoldenAge02"
    }
    {
      Id = "Chronos_0502"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, they {#Emph}failed! {#Prev}And thus presents itself this golden opportunity to teach my {#Emph}children and their generation {#Prev}a most-valuable lesson about having to live with the consequences of their actions!"
      Speaker = "Chronos"
      Event = "ChronosBossAboutGoldenAge02"
    }
    {
      Id = "Chronos_0493"
      InheritFrom = "BaseNarrative"
      DisplayName = "My legions know you well by now; the trouble you have caused. Yet only my most ardent followers may spill their blood within my halls."
      Speaker = "Chronos"
      Event = "ChronosBossAboutSatyrs01"
    }
    {
      Id = "MelinoeField_1500"
      InheritFrom = "BaseNarrative"
      DisplayName = "These Satyr worshipers of yours must be very honored to be the first to die here. Not the wisest creatures, though, are they?"
      Speaker = "Melinoe"
      Event = "ChronosBossAboutSatyrs01"
    }
    {
      Id = "Chronos_0494"
      InheritFrom = "BaseNarrative"
      DisplayName = "The wise do not follow; the wise {#Emph}lead. {#Prev}These Satyrs lack a mortal fear of death, believing that their sacrifice shall bring me strength and that they shall live on. Let us {#Emph}grant {#Prev}their desire."
      Speaker = "Chronos"
      Event = "ChronosBossAboutSatyrs01"
    }
    {
      Id = "Chronos_0214"
      InheritFrom = "BaseNarrative"
      DisplayName = "The course of history is mine to shape. Yet you continue vexing me, as though you wish to do so in my stead. Fine, what shall it be? Shall I just go ahead and cede my rightful throne?"
      Speaker = "Chronos"
      Event = "ChronosBossAboutHistory01"
    }
    {
      Id = "MelinoeField_1403"
      InheritFrom = "BaseNarrative"
      DisplayName = "You don't set the course of history... you're Time. You're just the paving stones we cross along our way. More than getting back at the gods, you're getting back at the Fates, who know your rightful place in all of this."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutHistory01"
    }
    {
      Id = "Chronos_0215"
      InheritFrom = "BaseNarrative"
      DisplayName = "I do, in fact, take issue with the Fates. Though they ought to be none of {#Emph}your {#Prev}concern, or anyone's. Imagine being free to make your own decisions now, only to long for the weight of their yoke upon your back! How {#Emph}pathetic."
      Speaker = "Chronos"
      Event = "ChronosBossAboutHistory01"
    }
    {
      Id = "Chronos_0497"
      InheritFrom = "BaseNarrative"
      DisplayName = "The future is unwoven; uncertain. Not even the Fates themselves can anticipate how all of this shall end, or {#Emph}when. {#Prev}Yet you press on."
      Speaker = "Chronos"
      Event = "ChronosBossAboutFuture01"
    }
    {
      Id = "MelinoeField_1502"
      InheritFrom = "BaseNarrative"
      DisplayName = "I thought you were all about the inevitable. Whether the outcome of all this has been foretold or not, I'll see it through. Call it a morbid curiosity."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutFuture01"
    }
    {
      Id = "Chronos_0498"
      InheritFrom = "BaseNarrative"
      DisplayName = "I call it reckless abandon, nothing more. You fail to consider the many possibilities in which you prove unable to enjoy the fruits of your labors..."
      Speaker = "Chronos"
      Event = "ChronosBossAboutFuture01"
    }
    {
      Id = "Chronos_0499"
      InheritFrom = "BaseNarrative"
      DisplayName = "A moment passes... then another, and another. I have names for them in every measure, you know? The very brief ones. The ones that linger..."
      Speaker = "Chronos"
      Event = "ChronosBossAboutTime01"
    }
    {
      Id = "MelinoeField_1503"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you're quite finished, I'll try not to take up more than a few of the very brief ones you mentioned."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutTime01"
    }
    {
      Id = "Chronos_0500"
      InheritFrom = "BaseNarrative"
      DisplayName = "I understand the need to cut {#Emph}Time {#Prev}down to smaller bits, I do. Hours, cut down to minutes. Minutes, cut down to seconds. Because the whole of it, my girl... is {#Emph}too much to fathom."
      Speaker = "Chronos"
      Event = "ChronosBossAboutTime01"
    }
    {
      Id = "Chronos_0503"
      InheritFrom = "BaseNarrative"
      DisplayName = "What {#Emph}are {#Prev}those {#Emph}garish {#Prev}instruments with which you try to cause such harm? Like as not some {#Emph}gadgets {#Prev}that the Fates themselves had vainly hoped would put an end to me!"
      Speaker = "Chronos"
      Event = "ChronosBossAboutWeapons01"
    }
    {
      Id = "MelinoeField_1505"
      InheritFrom = "BaseNarrative"
      DisplayName = "Whether they {#Emph}vainly {#Prev}hoped is yet to be determined. These may not be the arms the gods once used to bring you down but they'll get the job done just the same. You watch."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutWeapons01"
    }
    {
      Id = "Chronos_0504"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh we shall do more than {#Emph}watch{#Prev}, Hrodreptus and I. This scythe of mine is not merely for cutting short the Mourning Fields wheat, whilst putting back the Hound of Hell..."
      Speaker = "Chronos"
      Event = "ChronosBossAboutWeapons01"
    }
    {
      Id = "Chronos_0901"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now {#Emph}what {#Prev}is that preposterous contraption which you wear? Alas not even {#Emph}I {#Prev}am able to keep up with you young upstarts and your perplexing fashion trends."
      Speaker = "Chronos"
      Event = "ChronosBossAboutSuit01"
    }
    {
      Id = "MelinoeField_3325"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh this is the Black Coat. I haven't put it on for fashion's sake, although you're right in that you won't be able to keep up."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutSuit01"
    }
    {
      Id = "Chronos_0902"
      InheritFrom = "BaseNarrative"
      DisplayName = "Such confidence in your abilities, or in the Fates' designs. But you must know, newfangled armaments such as that cannot compare with the classics."
      Speaker = "Chronos"
      Event = "ChronosBossAboutSuit01"
    }
    {
      Id = "Chronos_1384"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now what is that you have, which gleams of gold? Why, that is {#Emph}mine! {#Prev}One of my finest Time Pieces...! You {#Emph}thief! {#Prev}And now you brazenly come here with it?"
      Speaker = "Chronos"
      Event = "ChronosBossAboutKeepsake01"
    }
    {
      Id = "MelinoeField_5027"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh I'm no {#Emph}thief{#Prev}. This was a {#Emph}gift! {#Prev}But let's not bother to get into that. I don't have all night. Neither do you."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutKeepsake01"
    }
    {
      Id = "Chronos_1385"
      InheritFrom = "BaseNarrative"
      DisplayName = "How astonishingly presumptuous. I have all the time in the world! But {#Emph}you{#Prev}, my girl, are {#Emph}quickly running out."
      Speaker = "Chronos"
      Event = "ChronosBossAboutKeepsake01"
    }
    {
      Id = "Chronos_0607"
      InheritFrom = "BaseNarrative"
      DisplayName = "I recognize that blade you bear: The scythe of Death himself! Alas that he was momentarily without it when I caught him in my snare, along with this House's other former residents."
      Speaker = "Chronos"
      Event = "ChronosBossAboutThanatosAspect01"
    }
    {
      Id = "MelinoeField_1953"
      InheritFrom = "BaseNarrative"
      DisplayName = "You may have taken Death, yet death is here for you. It would be fitting if you met your end by Zorephet."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutThanatosAspect01"
    }
    {
      Id = "Chronos_0608"
      InheritFrom = "BaseNarrative"
      DisplayName = "It would be most unlikely, I should think. Then let us match now, scythe to scythe! Your Zorephet against my Hrodreptus. And we shall imminently see who reaps, and who sows."
      Speaker = "Chronos"
      Event = "ChronosBossAboutThanatosAspect01"
    }
    {
      Id = "MelinoeField_1506"
      InheritFrom = "BaseNarrative"
      DisplayName = "Pardon my lateness, I had some wretches to contend with. I thought you let everyone go, regardless of past transgressions."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutWretches01"
    }
    {
      Id = "Chronos_0505"
      InheritFrom = "BaseNarrative"
      DisplayName = "I let just about everyone go, yes. You may be surprised, however, to learn that some of those so-called {#Emph}wretches {#Prev}do not care for Hades very much. They were quite eager to serve me instead, when nicely asked. With you, I shall not even bother."
      Speaker = "Chronos"
      Event = "ChronosBossAboutWretches01"
    }
    {
      Id = "MelinoeField_1508"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're so indignant of my father's generation. What came of yours? I don't see many of your contemporaries rallied to your cause, or any other for that matter."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutTitans01"
    }
    {
      Id = "Chronos_0507"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, you see, most of the other Titans met their end, just as did I. The doing of your father and his {#Emph}generation! {#Prev}Perhaps when all of this is settled, I shall see to bringing my contemporaries back! A few of them."
      Speaker = "Chronos"
      Event = "ChronosBossAboutTitans01"
    }
    {
      Id = "MelinoeField_1509"
      InheritFrom = "BaseNarrative"
      DisplayName = "Get up, wretch. Titan. {#Emph}Lord Master Chronos. {#Prev}Whatever they call you now. It's {#Emph}time{#Prev}, as you might say."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutOrigin01"
    }
    {
      Id = "Chronos_0508"
      InheritFrom = "BaseNarrative"
      DisplayName = "It is, indeed. And they have called me many things; many names, in aeons past. There are those who think me nothing more than the offspring of Heaven and Earth, of all the {#Emph}nerve. {#Prev}And you are even less cordial than {#Emph}they."
      Speaker = "Chronos"
      Event = "ChronosBossAboutOrigin01"
    }
    {
      Id = "Chronos_0550"
      InheritFrom = "BaseNarrative"
      DisplayName = "Have you once marveled at the ever-turning gears in Tartarus? My little contribution to the Underworld's design; a steady means of moving things along. I call it {#Emph}clockwork. {#Prev}A cycle without end! Akin to the turning of the seasons."
      Speaker = "Chronos"
      Event = "ChronosBossAboutClockwork01"
    }
    {
      Id = "MelinoeField_1594"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm not here for a tour. That {#Emph}clockwork {#Prev}could have only come from {#Emph}you. {#Prev}An eyesore, going nowhere, groaning all along."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutClockwork01"
    }
    {
      Id = "Chronos_0551"
      InheritFrom = "BaseNarrative"
      DisplayName = "Going {#Emph}nowhere? {#Prev}One with capacity for magick ought espouse a deeper understanding of this world! We are always going {#Emph}somewhere; {#Prev}the {#Emph}future{#Prev}, my girl! Into the {#Emph}future."
      Speaker = "Chronos"
      Event = "ChronosBossAboutClockwork01"
    }
    {
      Id = "Chronos_0554"
      InheritFrom = "BaseNarrative"
      DisplayName = "So you are keeping careful track of Time; such things of course are plain for me to see. But your reasons for it, I hardly can surmise. To gauge, perhaps, how quickly you shall fall?"
      Speaker = "Chronos"
      Event = "ChronosBossAboutGameplayTimer01"
    }
    {
      Id = "MelinoeField_1596"
      InheritFrom = "BaseNarrative"
      DisplayName = "Either me or you. So how much time shall we require here tonight? In all your wisdom, surely you must know."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutGameplayTimer01"
    }
    {
      Id = "Chronos_0555"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, this shall take but a {#Emph}trifle{#Prev}, I expect! Not yet a formal measurement, although perhaps that too shall change..."
      Speaker = "Chronos"
      Event = "ChronosBossAboutGameplayTimer01"
    }
    {
      Id = "Chronos_0556"
      InheritFrom = "BaseNarrative"
      DisplayName = "You ceased to track the measurement of just how quickly we may settle our disputes. Was it too much for you? To be so self-aware of your inexorable flight toward uncertainty?"
      Speaker = "Chronos"
      Event = "ChronosBossAboutGameplayTimer02"
    }
    {
      Id = "MelinoeField_1597"
      InheritFrom = "BaseNarrative"
      DisplayName = "I am an immortal goddess of the Underworld. Time means nothing to me. I can do this forever."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutGameplayTimer02"
    }
    {
      Id = "Chronos_0557"
      InheritFrom = "BaseNarrative"
      DisplayName = "Is that so? {#Emph}Forever {#Prev}is a very long while. We shall have to make this slow and excruciating, to sate your gluttonous desire for more..."
      Speaker = "Chronos"
      Event = "ChronosBossAboutGameplayTimer02"
    }
    {
      Id = "Chronos_0601"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have considerable power over Time, that you can turn some of my innate power against {#Emph}me! {#Prev}Perhaps your knack for this is merely a recessive family trait."
      Speaker = "Chronos"
      Event = "ChronosBossAboutPausing01"
    }
    {
      Id = "MelinoeField_1950"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't insult me, and don't fool yourself. When you took my family, you created in me a lifelong desire to see you destroyed. So I simply prepared."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutPausing01"
    }
    {
      Id = "Chronos_0602"
      InheritFrom = "BaseNarrative"
      DisplayName = "A lifelong desire. Your {#Emph}life{#Prev}, girl, is but a blink of an eye to {#Emph}me! {#Prev}No one achieves abilities as yours through force of will alone. Though you are no mere {#Emph}god{#Prev}; you are a {#Emph}witch."
      Speaker = "Chronos"
      Event = "ChronosBossAboutPausing01"
    }
    {
      Id = "Chronos_0905"
      InheritFrom = "BaseNarrative"
      DisplayName = "An evening most-unusual this has turned out to be! My forces fought so fiercely against you, yet somehow proved unable to succeed... I shall have to have a word with them."
      Speaker = "Chronos"
      Event = "ChronosBossAboutShrine01"
    }
    {
      Id = "MelinoeField_3327"
      InheritFrom = "BaseNarrative"
      DisplayName = "They still shall fear me more than you. Through all of this adversity that you put up, I grow in strength. And when you too lie in ruin, Night's will shall finally be done."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutShrine01"
    }
    {
      Id = "Chronos_0906"
      InheritFrom = "BaseNarrative"
      DisplayName = "Spoken like a mindless follower. My girl, you are not entirely dissimilar from some of those who regularly fail to do my bidding... and I shall treat you very much the same."
      Speaker = "Chronos"
      Event = "ChronosBossAboutShrine01"
    }
    {
      Id = "Chronos_1237"
      InheritFrom = "BaseNarrative"
      DisplayName = "The ill effects of Chaos, here... such senselessness! So then have you persuaded the Primordial Originator into thinking that I somehow got the best of our exchange? Nyx and the Three Fates, for nothing at all!"
      Speaker = "Chronos"
      Event = "ChronosBossAboutRandomBounties1"
    }
    {
      Id = "MelinoeField_3807"
      InheritFrom = "BaseNarrative"
      DisplayName = "Chaos indicated some displeasure, yes. But the effects you sense are no more to my benefit than yours. We're talking about a perfectly impartial being."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutRandomBounties1"
    }
    {
      Id = "Chronos_1238"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Impartial{#Prev}, you say? A thinking being is incapable of that! The moment Chaos first conceived of anything, they renounced impartiality forever! And certainly they are not on {#Emph}my {#Prev}side."
      Speaker = "Chronos"
      Event = "ChronosBossAboutRandomBounties1"
    }
    {
      Id = "Chronos_1386"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}You{#Prev}, with all that vengeance on your mind, claiming to care nothing for the family which I denied you! {#Emph}Good{#Prev}, because you {#Emph}certainly {#Prev}did not miss much! They cared nothing for {#Emph}our family{#Prev}, either! Left me to {#Emph}rot! {#Prev}You are {#Emph}no different!"
      Speaker = "Chronos"
      Event = "ChronosBossAboutFamily01"
    }
    {
      Id = "MelinoeField_5043"
      InheritFrom = "BaseNarrative"
      DisplayName = "You alone care deeply for our family, is that it? Come on. They left you to rot because you gave them every reason to hate you."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutFamily01"
    }
    {
      Id = "Chronos_1401"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Pah! {#Prev}They sought power I refused to share. They had not worked for it! Perhaps if they asked nicely, none of this would have elapsed. But there is no undoing past mistakes."
      Speaker = "Chronos"
      Event = "ChronosBossAboutFamily01"
    }
    {
      Id = "Chronos_1436"
      InheritFrom = "BaseNarrative"
      DisplayName = "You were never meant to be involved in this, Granddaughter! You must have been a mere babe when first I arrived here, alas too late to meet. Yet even now you are too young to understand."
      Speaker = "Chronos"
      Event = "ChronosBossAboutFamily02"
    }
    {
      Id = "MelinoeField_5083"
      InheritFrom = "BaseNarrative"
      DisplayName = "I would have been imprisoned with the rest. Though enlighten me... what is it that I'm still too young to understand?"
      Speaker = "Melinoe"
      Event = "ChronosBossAboutFamily02"
    }
    {
      Id = "Chronos_1437"
      InheritFrom = "BaseNarrative"
      DisplayName = "You are too young to understand the disappointment and dejection that only family can provide. But the more of us you meet... the more of us you know... the sooner you shall learn."
      Speaker = "Chronos"
      Event = "ChronosBossAboutFamily02"
    }
    {
      Id = "Chronos_1438"
      InheritFrom = "BaseNarrative"
      DisplayName = "I must say, I am quite unaccustomed to so many frequent visits from my kin! Perhaps if Hades and the others deigned to call as often, our relationships would not have been as strained."
      Speaker = "Chronos"
      Event = "ChronosBossAboutFamily03"
    }
    {
      Id = "MelinoeField_5084"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh this is not that sort of call. Though I didn't realize you were merely lonesome! Are your Satyr worshipers not stimulating enough as House guests?"
      Speaker = "Melinoe"
      Event = "ChronosBossAboutFamily03"
    }
    {
      Id = "Chronos_1439"
      InheritFrom = "BaseNarrative"
      DisplayName = "They are worshipers, not kin! You were unfortunately caught in the midst of a dispute, and do not know the difference between having family around or not."
      Speaker = "Chronos"
      Event = "ChronosBossAboutFamily03"
    }
    {
      Id = "MelinoeField_5085"
      InheritFrom = "BaseNarrative"
      DisplayName = "Because of {#Emph}you! {#Prev}And this {#Emph}dispute {#Prev}of yours! And now you'll be destroyed for what you've done. Was it worth it?"
      Speaker = "Melinoe"
      Event = "ChronosBossAboutFamily03"
    }
    {
      Id = "Chronos_1440"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, when you put it {#Emph}that {#Prev}way, {#Emph}no! {#Prev}Had I not made any mistakes, we would not be here {#Emph}now{#Prev}, would we? Certainly not as such vicious foes! Yet here we are, each in turn facing the consequences of the past."
      Speaker = "Chronos"
      Event = "ChronosBossAboutFamily03"
    }
    {
      Id = "MelinoeField_5086"
      InheritFrom = "BaseNarrative"
      DisplayName = "You spoke before about the consequences of the past... of your own mistakes. Yet {#Emph}this {#Prev}is how you choose to rectify them? Your entire family is against you...!"
      Speaker = "Melinoe"
      Event = "ChronosBossAboutFamily04"
    }
    {
      Id = "Chronos_1441"
      InheritFrom = "BaseNarrative"
      DisplayName = "As ever! The only difference now is there are even {#Emph}more {#Prev}of you, all falling in line. You would excise me from my own family? Then, very well! But {#Emph}this {#Prev}is the result!"
      Speaker = "Chronos"
      Event = "ChronosBossAboutFamily04"
    }
    {
      Id = "MelinoeField_5087"
      InheritFrom = "BaseNarrative"
      DisplayName = "You don't even want to rule the Underworld or the surface, do you? You just want to get back at your children. How petty... and pathetic."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutFamily04"
    }
    {
      Id = "Chronos_1442"
      InheritFrom = "BaseNarrative"
      DisplayName = "Each passing generation, even quicker to judge than the last! Was I the {#Emph}perfect father? {#Prev}No. Otherwise my children would have been perfect as well! And now even you are caught in this spiral!"
      Speaker = "Chronos"
      Event = "ChronosBossAboutFamily04"
    }
    {
      Id = "Chronos_1443"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}I {#Prev}know why you continue to return! You seek {#Emph}more {#Prev}than these conversations of ours, but also that Mirror in those squalid chambers down the hall... the single artifact I could not budge! But it is {#Emph}useless {#Prev}without Night herself!"
      Speaker = "Chronos"
      Event = "ChronosBossAboutFamily05"
    }
    {
      Id = "MelinoeField_5206"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm not here for this House's former furnishings. You should know, you have at least one relative who would be most distraught if you're destroyed. You alone can prevent that... if you would end all this."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutFamily05"
    }
    {
      Id = "Chronos_1458_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, I intend to! But we are far past the point of preventing the distress of this {#Emph}supposed {#Prev}relative to whom you refer! What was already done is done, and there is no turning back, regrets be damned: that is the very {#Emph}nature {#Prev}of Time."
      Speaker = "Chronos"
      Event = "ChronosBossAboutFamily05"
    }
    {
      Id = "Chronos_0173"
      InheritFrom = "BaseNarrative"
      DisplayName = "You saw your father out there, I presume? He required a special arrangement. For aeons, he incarcerated countless souls within this place; not to mention {#Emph}me. {#Prev}Seemed only fitting he should have to waste away accordingly."
      Speaker = "Chronos"
      Event = "ChronosBossAboutHades01"
    }
    {
      Id = "MelinoeField_1317"
      InheritFrom = "BaseNarrative"
      DisplayName = "You couch it in morality, when vengeance is reason enough. Though since you've reasoned it all out, by what right did you take the other members of my family? And Nyx and all the rest?"
      Speaker = "Melinoe"
      Event = "ChronosBossAboutHades01"
    }
    {
      Id = "Chronos_0174"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why, because they opposed me. Except you have this rather vexing knack for resisting some of my time-honored techniques... a recessive family trait, perhaps. Although, your brother... he was not so fortunate. You, too, shall break, however... soon enough."
      Speaker = "Chronos"
      Event = "ChronosBossAboutHades01"
    }
    {
      Id = "Chronos_0495"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hades used some of his failing strength to spur you on! Even whilst bound in chains no god can break, your father yet proves to be a pest."
      Speaker = "Chronos"
      Event = "ChronosBossAboutHades02"
    }
    {
      Id = "MelinoeField_1501"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've tortured and humiliated him. All this talk of how you plan to bring about a bygone age, yet petty vengeance seems to be your chief concern."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutHades02"
    }
    {
      Id = "Chronos_0496"
      InheritFrom = "BaseNarrative"
      DisplayName = "The thing is, my girl, I can have {#Emph}both. {#Prev}You should have seen the cruel, inventive ways your father tortured mortal souls! Thus I dispense a form of justice to {#Emph}him{#Prev}, and to {#Emph}you."
      Speaker = "Chronos"
      Event = "ChronosBossAboutHades02"
    }
    {
      Id = "Chronos_0547"
      InheritFrom = "BaseNarrative"
      DisplayName = "You are {#Emph}quite {#Prev}dangerous, I must admit. You have repeatedly breached into Tartarus, and this House; impossibilities, if not for your tainted bloodline! And you are able to withstand my conjuring. Might I again politely ask you {#Emph}how?"
      Speaker = "Chronos"
      Event = "ChronosBossAboutMelinoe01"
    }
    {
      Id = "MelinoeField_1592"
      InheritFrom = "BaseNarrative"
      DisplayName = "You call that {#Emph}politely? {#Prev}You didn't even say the magick word. But since you really want to know... I'm from the future. You'll later come to realize the error of your ways, and teach me to stop you before you can cause more harm."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutMelinoe01"
    }
    {
      Id = "Chronos_0548"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ha ha ha! {#Prev}Oh, quite an imaginative tale. A comedy, for the utterly outrageous premise beggars belief! My girl, one cannot travel {#Emph}back {#Prev}in Time! Time marches ever forward; and I alone determine at which rate."
      Speaker = "Chronos"
      Event = "ChronosBossAboutMelinoe01"
    }
    {
      Id = "Chronos_0212"
      InheritFrom = "BaseNarrative"
      DisplayName = "You are proving to be quite a nuisance, if only because you insist on continually setting loose your father's wretched old three-headed cur! To think how such a beast used to be kept within these walls."
      Speaker = "Chronos"
      Event = "ChronosBossAboutCerberus01"
    }
    {
      Id = "MelinoeField_1402"
      InheritFrom = "BaseNarrative"
      DisplayName = "So you keep casting out poor Cerberus into the Mourning Fields, where he rages alone. Of all your unforgivable offenses..."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutCerberus01"
    }
    {
      Id = "Chronos_0213"
      InheritFrom = "BaseNarrative"
      DisplayName = "What would you have me do? I do not require him to guard the gates to this realm, for they are open wide. And I certainly do not require him to shed everywhere. Though {#Emph}blood{#Prev}shed, I accept."
      Speaker = "Chronos"
      Event = "ChronosBossAboutCerberus01"
    }
    {
      Id = "Chronos_0605"
      InheritFrom = "BaseNarrative"
      DisplayName = "My work is made much easier for all the enemies Olympus has accrued. From the Satyrs, to the Harpies, to the Cyclops Polyphemus and much more! It is not I alone who seeks the downfall of the gods."
      Speaker = "Chronos"
      Event = "ChronosBossAboutPolyphemus01"
    }
    {
      Id = "MelinoeField_1952"
      InheritFrom = "BaseNarrative"
      DisplayName = "So you gathered up the dregs lusting for power or revenge! Such company you keep. I know that Polyphemus well enough by now... his loyalty can almost certainly be bought."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutPolyphemus01"
    }
    {
      Id = "Chronos_0606"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, that it {#Emph}can. Loyalty {#Prev}is either earned or bought, and it makes very little difference either way. Polyphemus has his limitations, to be sure. But he is not a {#Emph}lost cause."
      Speaker = "Chronos"
      Event = "ChronosBossAboutPolyphemus01"
    }
    {
      Id = "Chronos_0711"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why do you ceaselessly attack my humble shepherd Polyphemus, who seeks merely to attend his flock in peace? At least you have given him a bit of reprieve by being {#Emph}here."
      Speaker = "Chronos"
      Event = "ChronosBossAboutPolyphemus02"
    }
    {
      Id = "MelinoeField_2552"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your humble shepherd doesn't let me leave the city of Ephyra willingly, so I've been showing myself out. You should know, he often is asleep on the job..."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutPolyphemus02"
    }
    {
      Id = "Chronos_0712"
      InheritFrom = "BaseNarrative"
      DisplayName = "Punishable behavior, if true! Of course, I pay that Cyclops next to nothing. And you always get what you pay for, girl..."
      Speaker = "Chronos"
      Event = "ChronosBossAboutPolyphemus02"
    }
    {
      Id = "Chronos_0903"
      InheritFrom = "BaseNarrative"
      DisplayName = "When first I came here to this House, your father and his servants, they did not put up much of a fight. Not even Nyx herself! Although in fairness, I did take them by surprise."
      Speaker = "Chronos"
      Event = "ChronosBossAboutNyx01"
    }
    {
      Id = "MelinoeField_3326"
      InheritFrom = "BaseNarrative"
      DisplayName = "What did you think you would accomplish, taking Night Incarnate as your captive, among all the rest? Her influence is not so easily undone."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutNyx01"
    }
    {
      Id = "Chronos_0904"
      InheritFrom = "BaseNarrative"
      DisplayName = "I grant you that it has been rather dark in spite of Nyx's temporary leave. Nevertheless, I do prefer having fewer disagreeable sorts about. Not even one, in fact."
      Speaker = "Chronos"
      Event = "ChronosBossAboutNyx01"
    }
    {
      Id = "MelinoeField_1590"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know, I'm almost impressed. Not only have you ransacked my father's domain and made war on Olympus, you had the audacity to deceive Primordial Chaos! That takes a spine."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutChaos01"
    }
    {
      Id = "Chronos_0545"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why thank you, my girl! I must admit, I thought that Chaos would be something of a bargainer, for I was willing to exchange their daughter Nyx for the Three Fates. But now, I have them all!"
      Speaker = "Chronos"
      Event = "ChronosBossAboutChaos01"
    }
    {
      Id = "MelinoeField_1591"
      InheritFrom = "BaseNarrative"
      DisplayName = "You played the chthonic gods for a pack of fools... these eldest, most powerful forces in existence. Such choices may come back to haunt you."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutChaos01"
    }
    {
      Id = "Chronos_0546"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes, {#Emph}you {#Prev}have come back to haunt me here repeatedly. You, the best that the gods of the Underworld and Olympus have to offer. {#Emph}Bah!"
      Speaker = "Chronos"
      Event = "ChronosBossAboutChaos01"
    }
    {
      Id = "MelinoeField_1507"
      InheritFrom = "BaseNarrative"
      DisplayName = "So what have you done with the Three Fates? You would incur the wrath of all chthonic gods, as though the wrath of all Olympus weren't enough..."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutFates01"
    }
    {
      Id = "Chronos_0506"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, I banished them! Where, I cannot say, or {#Emph}when. {#Prev}In any event, they trouble us no longer, with their manipulative weavings. No, what happens now... is entirely up to {#Emph}us."
      Speaker = "Chronos"
      Event = "ChronosBossAboutFates01"
    }
    {
      Id = "Chronos_0552"
      InheritFrom = "BaseNarrative"
      DisplayName = "I am quite flummoxed with that {#Emph}Boatman {#Prev}fellow just outside, who has the gall to scull his little boat right to my very doorstep! The Satyrs have more fear of {#Emph}him {#Prev}than {#Emph}you."
      Speaker = "Chronos"
      Event = "ChronosBossAboutCharon01"
    }
    {
      Id = "MelinoeField_1595"
      InheritFrom = "BaseNarrative"
      DisplayName = "You ought fear him yourself. Lord Charon knows every stone in the Underworld... every drop in the five rivers. You say you can't be stopped? Neither can he."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutCharon01"
    }
    {
      Id = "Chronos_0553"
      InheritFrom = "BaseNarrative"
      DisplayName = "...That trinket-peddler, crudely hawking his ill-gotten wares to his very limited base of customers! And hoarding so much Gold I generously wrought. A noble ally that you have!"
      Speaker = "Chronos"
      Event = "ChronosBossAboutCharon01"
    }
    {
      Id = "Chronos_0707"
      InheritFrom = "BaseNarrative"
      DisplayName = "My understanding is that you attended quite the musical performance in the pit of Oceanus! To have navigated all of the infernal pipework just for that."
      Speaker = "Chronos"
      Event = "ChronosBossAboutScylla01"
    }
    {
      Id = "MelinoeField_2550"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, it's no trouble at all. Such a vibrant interest there in the performing arts! You should visit more often."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutScylla01"
    }
    {
      Id = "Chronos_0708"
      InheritFrom = "BaseNarrative"
      DisplayName = "I truly ought, and wrest control over the blasted place as my rightful domain! For now, I merely sponsor some of the delightful programming you enjoy each night!"
      Speaker = "Chronos"
      Event = "ChronosBossAboutScylla01"
    }
    {
      Id = "Chronos_0709"
      InheritFrom = "BaseNarrative"
      DisplayName = "Whilst I have yet to attend one myself, it is my understanding that performances by Scylla and her Siren cohort oft leave much to be desired. Perhaps I ought rescind my patronage..."
      Speaker = "Chronos"
      Event = "ChronosBossAboutScylla02"
    }
    {
      Id = "MelinoeField_2551"
      InheritFrom = "BaseNarrative"
      DisplayName = "I do worry they're a bit of a sunk cost. I see the same handful of devoted listeners in their audience night after night, but no real signs of growth."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutScylla02"
    }
    {
      Id = "Chronos_0710"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well my girl, a small devoted audience is naught at which to scoff! I myself started with but a few Satyr devotees, and look how far I have come!"
      Speaker = "Chronos"
      Event = "ChronosBossAboutScylla02"
    }
    {
      Id = "MelinoeField_1593"
      InheritFrom = "BaseNarrative"
      DisplayName = "I thought all the chthonic gods opposed you openly. But you persuaded {#Emph}Eris{#Prev}, of all creatures, to your side! A laughable alliance, though not bad for sowing more destruction and dissent."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutEris01"
    }
    {
      Id = "Chronos_0549"
      InheritFrom = "BaseNarrative"
      DisplayName = "I am owed credit for a great many things, my girl; but not for any such alliances with Strife! What use have I for Nyx's youngest whelp? Although perhaps she is no fool, if she has rallied to my banners as you say."
      Speaker = "Chronos"
      Event = "ChronosBossAboutEris01"
    }
    {
      Id = "Chronos_0703"
      InheritFrom = "BaseNarrative"
      DisplayName = "You somehow reached the mountain of the gods. Clashed with Prometheus himself, he claims! Whichever path you choose... we Titans shall be there."
      Speaker = "Chronos"
      Event = "ChronosBossAboutPrometheus01"
    }
    {
      Id = "MelinoeField_2548"
      InheritFrom = "BaseNarrative"
      DisplayName = "Good. Then I have every opportunity to slay you all. So, you liberated the prisoner of Olympus in exchange for his servitude? I heard Prometheus once had integrity."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutPrometheus01"
    }
    {
      Id = "Chronos_0704"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh {#Prev}but he has it still! Which is the reason he has joined my cause. Besides... who better to lead my strike forces against Olympus than one who was so unjustly wronged by the gods? For I cannot do {#Emph}everything {#Prev}myself!"
      Speaker = "Chronos"
      Event = "ChronosBossAboutPrometheus01"
    }
    {
      Id = "Chronos_0705"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Titan of Foresight confessed that you were able to withstand his fury. To which I said, {#Emph}Prometheus, my good fellow! If you knew this would transpire, why did you not forewarn me? And why did you not prevent it?"
      Speaker = "Chronos"
      Event = "ChronosBossAboutPrometheus02"
    }
    {
      Id = "MelinoeField_2549"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps you overestimate the Titan of Foresight's power to clearly see into the future. Along with his strength."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutPrometheus02"
    }
    {
      Id = "Chronos_0706"
      InheritFrom = "BaseNarrative"
      DisplayName = "He claims to keep the details of the future to himself... so as not to alter the desired outcome. How convenient! It does not take a genius such as he to know I shall eventually prevail!"
      Speaker = "Chronos"
      Event = "ChronosBossAboutPrometheus02"
    }
    {
      Id = "Chronos_0893"
      InheritFrom = "BaseNarrative"
      DisplayName = "I understand your latest vainglorious attempt to re-claim Olympus for the gods did not pan out. Perhaps in the moment you witnessed the Father of All Monsters in all his terrifying stature, you at last understood your folly."
      Speaker = "Chronos"
      Event = "ChronosBossAboutTyphon01"
    }
    {
      Id = "MelinoeField_3320"
      InheritFrom = "BaseNarrative"
      DisplayName = "You awakened that monstrosity and call {#Emph}me {#Prev}vainglorious? Typhon is not going to take orders from you or {#Emph}anyone! {#Prev}You'll have nothing left to rule over if he has his way!"
      Speaker = "Melinoe"
      Event = "ChronosBossAboutTyphon01"
    }
    {
      Id = "Chronos_0894"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, you {#Emph}gods {#Prev}shall have nothing left to rule over if he has his way. And I, {#Emph}mine! {#Prev}Typhon may not be the negotiating type; but we need no agreement to pursue the same result."
      Speaker = "Chronos"
      Event = "ChronosBossAboutTyphon01"
    }
    {
      Id = "Chronos_0997"
      InheritFrom = "BaseNarrative"
      DisplayName = "I understand your latest vainglorious attempt to re-claim Olympus met with some success! Perhaps in the moment you witnessed the Father of All Monsters in all his terrifying stature, some primordial instinct took hold."
      Speaker = "Chronos"
      Event = "ChronosBossAboutTyphon01_B"
    }
    {
      Id = "MelinoeField_3321"
      InheritFrom = "BaseNarrative"
      DisplayName = "Tell me something, before I turn you back to dust again. If Typhon destroys Mount Olympus as you so desire, where do you expect he'll go from there? Back to sleep?"
      Speaker = "Melinoe"
      Event = "ChronosBossAboutTyphon02"
    }
    {
      Id = "Chronos_0895"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, that is none of my concern. Ours is a wide world, and {#Emph}deep! {#Prev}Typhon shall have free rein to go where he pleases. Perhaps he shall rule over the seas in Poseidon's stead!"
      Speaker = "Chronos"
      Event = "ChronosBossAboutTyphon02"
    }
    {
      Id = "MelinoeField_3322"
      InheritFrom = "BaseNarrative"
      DisplayName = "Liar. You plan to double-cross him. Send him roaring back to the abyss after your use for him is ended. Not even {#Emph}you {#Prev}are fool enough to disregard him as a threat."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutTyphon02"
    }
    {
      Id = "Chronos_0896"
      InheritFrom = "BaseNarrative"
      DisplayName = "The future shall be well in hand, of that I can assure you, Granddaughter. Best focus on the present, and the many hardships we endure."
      Speaker = "Chronos"
      Event = "ChronosBossAboutTyphon02"
    }
    {
      Id = "Chronos_0897"
      InheritFrom = "BaseNarrative"
      DisplayName = "My, to have toppled Typhon from that mountaintop... certainly it was not something that you could have done alone, yet still! How {#Emph}proud {#Prev}you must have felt."
      Speaker = "Chronos"
      Event = "ChronosBossAboutTyphon03"
    }
    {
      Id = "MelinoeField_3323"
      InheritFrom = "BaseNarrative"
      DisplayName = "I felt a tinge of satisfaction, yes. But you do know what's an even greater feeling than thwarting the Father of All Monsters, don't you?"
      Speaker = "Melinoe"
      Event = "ChronosBossAboutTyphon03"
    }
    {
      Id = "Chronos_0898"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you insinuate that besting me in battle is a thrill akin to overcoming the Great Despoiler of Olympus, then you flatter me, my girl. Go on and try... even as Typhon stirs."
      Speaker = "Chronos"
      Event = "ChronosBossAboutTyphon03"
    }
    {
      Id = "Chronos_0899"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hmhmhm{#Prev}, angry now as ever! Do you wish to know exactly how I reawakened Typhon, my girl? Or how I managed it without you gods detecting what I had in store?"
      Speaker = "Chronos"
      Event = "ChronosBossAboutTyphon04"
    }
    {
      Id = "MelinoeField_3324"
      InheritFrom = "BaseNarrative"
      DisplayName = "Please indulge me, Grandfather. For I do so enjoy your tales."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutTyphon04"
    }
    {
      Id = "Chronos_0900"
      InheritFrom = "BaseNarrative"
      DisplayName = "You would never believe it if you knew. For you are narrow-minded, you and all the gods! I have {#Emph}outsmarted {#Prev}you... and I shall overpower you as well."
      Speaker = "Chronos"
      Event = "ChronosBossAboutTyphon04"
    }
    {
      Id = "Chronos_0985"
      InheritFrom = "BaseNarrative"
      DisplayName = "What have you done... to the Father of All Monsters, what have you {#Emph}done? {#Prev}For he is... nowhere to be found...!"
      Speaker = "Chronos"
      Event = "ChronosBossAboutTyphonDeath01"
    }
    {
      Id = "MelinoeField_3879"
      InheritFrom = "BaseNarrative"
      DisplayName = "Such details are none of your concern, wretch. Know only that you're next. May your final moments be in pain."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutTyphonDeath01"
    }
    {
      Id = "Chronos_0986"
      InheritFrom = "BaseNarrative"
      DisplayName = "You speak to me of pain... I can lock you with it for eternity. You shall come to understand it even better than I!"
      Speaker = "Chronos"
      Event = "ChronosBossAboutTyphonDeath01"
    }
    {
      Id = "MelinoeField_3662"
      InheritFrom = "BaseNarrative"
      DisplayName = "Odd. All of this looks entirely the same, and so do you, Titan. I had expected that perhaps this night had something new for me in store."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutAltFight01"
    }
    {
      Id = "Chronos_1063"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, do not sound so disappointed, Granddaughter. If you wish for me to muster some newfangled trick of mine in order to enliven these proceedings, I am happy to oblige..."
      Speaker = "Chronos"
      Event = "ChronosBossAboutAltFight01"
    }
    {
      Id = "Chronos_1331"
      InheritFrom = "BaseNarrative"
      DisplayName = "You think yourself quite clever and most skilled to have withstood the End of Time, but you achieved nothing at all! For I am here as usual, whilst you remain right {#Emph}there."
      Speaker = "Chronos"
      Event = "ChronosBossAboutAltFight02"
    }
    {
      Id = "MelinoeField_4563"
      InheritFrom = "BaseNarrative"
      DisplayName = "You also thought there was no possible way I could vanquish you, let alone in that End of Time place. You're more error-prone than you realize."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutAltFight02"
    }
    {
      Id = "Chronos_1332"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, {#Emph}you {#Prev}are error-prone, my girl, because Time is by its very nature quite precise, and it is always right. But if you wish to test your suppositions, by all means."
      Speaker = "Chronos"
      Event = "ChronosBossAboutAltFight02"
    }
    {
      Id = "Chronos_1333"
      InheritFrom = "BaseNarrative"
      DisplayName = "The End of Time was not to your liking, was it, {#Emph}hm? {#Prev}Why, if you wanted me to go a little {#Emph}easier{#Prev}, my girl, you merely could have asked..."
      Speaker = "Chronos"
      Event = "ChronosBossAboutAltFight03"
    }
    {
      Id = "MelinoeField_4564"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm here to see you destroyed, Titan, not to tour these bland locations that appear to be symbolic of your nature. I figure it shall go much more efficiently this way."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutAltFight03"
    }
    {
      Id = "Chronos_1334"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Efficiently! {#Prev}Now you are truly sounding like a granddaughter of mine. Then let us settle once again our differences, but now in all due haste."
      Speaker = "Chronos"
      Event = "ChronosBossAboutAltFight03"
    }
    {
      Id = "Chronos_1329"
      InheritFrom = "BaseNarrative"
      DisplayName = "I am accustomed to the {#Emph}stink {#Prev}of the Olympians and their {#Emph}supposed {#Prev}blessings on your person, so this occasion is a most-welcome reprieve. None of {#Emph}their {#Prev}power, merely {#Emph}yours!"
      Speaker = "Chronos"
      Event = "ChronosBossAboutNoBoons01"
    }
    {
      Id = "MelinoeField_4562"
      InheritFrom = "BaseNarrative"
      DisplayName = "My power ought to be enough, I think. Though the more you underestimate me the better, I suppose. Shall we?"
      Speaker = "Melinoe"
      Event = "ChronosBossAboutNoBoons01"
    }
    {
      Id = "Chronos_1330"
      InheritFrom = "BaseNarrative"
      DisplayName = "Shall we {#Emph}what? {#Prev}Shall my Satyr worshipers and I dispose of our most-irritating interlopers {#Emph}again {#Prev}and {#Emph}again? {#Prev}Then {#Emph}yes{#Prev}, most certainly."
      Speaker = "Chronos"
      Event = "ChronosBossAboutNoBoons01"
    }
    {
      Id = "Chronos_0976"
      InheritFrom = "BaseNarrative"
      DisplayName = "What did you call that old witch whom you seem to care about so much? Your {#Emph}headmistress? {#Prev}Tell me now exactly who she is, if you yet value her well-being in the least."
      Speaker = "Chronos"
      Event = "ChronosBossAboutHecateKidnapped01"
    }
    {
      Id = "MelinoeField_3877"
      InheritFrom = "BaseNarrative"
      DisplayName = "...She was my mother's handmaiden, nothing more. When you attacked my father's House, she took me away. When I came of age, I vowed to stop you; despite her efforts to dissuade me. Let her go."
      Speaker = "Melinoe"
      Event = "ChronosBossAboutHecateKidnapped01"
    }
    {
      Id = "Chronos_0977"
      InheritFrom = "BaseNarrative"
      DisplayName = "...At first I thought perhaps that you were a child of Zeus rather than Hades, but you are a terrible liar, Granddaughter. Now you shall suffer for your actions... or the {#Emph}handmaiden {#Prev}shall do so in your stead."
      Speaker = "Chronos"
      Event = "ChronosBossAboutHecateKidnapped01"
    }
    {
      Id = "MelinoeField_3878"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Don't you touch her!"
      Speaker = "Melinoe"
      Event = "ChronosBossAboutHecateKidnapped01"
    }
    {
      Id = "Chronos_0978"
      InheritFrom = "BaseNarrative"
      DisplayName = "That headmistress of yours has proven not to be informative at all thus far. I can be even more persuasive if necessary, of course. But first, to the matter at hand..."
      Speaker = "Chronos"
      Event = "ChronosBossAboutHecateKidnapped02"
    }
    {
      Id = "Chronos_1049"
      InheritFrom = "BaseNarrative"
      DisplayName = "Insolent girl. I do not know how you last managed to escape from me but you have gravely erred in setting foot again within these halls, thus giving {#Emph}me {#Prev}a second chance."
      Speaker = "Chronos"
      Event = "ChronosBossPostTrueEnding01"
    }
    {
      Id = "MelinoeField_4135"
      InheritFrom = "BaseNarrative"
      DisplayName = "This is not your second chance, Titan, but your last. You are an aberration and should not even exist, not here like this."
      Speaker = "Melinoe"
      Event = "ChronosBossPostTrueEnding01"
    }
    {
      Id = "Chronos_1050"
      InheritFrom = "BaseNarrative"
      DisplayName = "If I may interrupt? {#Emph}Erm{#Prev}, greetings! In case the resemblance is insufficient, I am {#Emph}you! {#Prev}Yet I am also {#Emph}me. {#Prev}I know this must be difficult to accept but my granddaughter is quite correct..."
      Speaker = "Chronos"
      Event = "ChronosBossPostTrueEnding01"
    }
    {
      Id = "MelinoeField_4136"
      InheritFrom = "BaseNarrative"
      DisplayName = "Grandfather, let me handle this. Knowing how {#Emph}you {#Prev}used to be, he won't be listening to reason here."
      Speaker = "Melinoe"
      Event = "ChronosBossPostTrueEnding01"
    }
    {
      Id = "Chronos_1051"
      InheritFrom = "BaseNarrative"
      DisplayName = "What is this foolishness, this... {#Emph}mockery?! {#Prev}You would confound me with these cheap illusions, whilst you deign to lecture {#Emph}me {#Prev}about what should exist or not? {#Emph}Begone!"
      Speaker = "Chronos"
      Event = "ChronosBossPostTrueEnding01"
    }
    {
      Id = "Chronos_1271"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have seen that I do not stay gone. Fight me to your heart's content! No matter the outcome it is {#Emph}you {#Prev}who ends up banished from this place. Or are you here merely to rummage through your family's old, unneeded things?"
      Speaker = "Chronos"
      Event = "ChronosBossPostTrueEnding02"
    }
    {
      Id = "MelinoeField_3871"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have no need of anything of theirs. Only your head."
      Speaker = "Melinoe"
      Event = "ChronosBossPostTrueEnding02"
    }
    {
      Id = "Chronos_1272"
      InheritFrom = "BaseNarrative"
      DisplayName = "That you cannot have, my girl, for I shall be requiring it to rule the realms with wisdom such as my unruly children never had. And you, apparently, have even less."
      Speaker = "Chronos"
      Event = "ChronosBossPostTrueEnding02"
    }
    {
      Id = "Chronos_0177"
      InheritFrom = "BaseNarrative"
      DisplayName = "Once more you have eluded my grasp in getting here, as though you wish to fall only to me."
      Speaker = "Chronos"
      Event = "ChronosBossMiscStart01"
    }
    {
      Id = "Chronos_0178"
      InheritFrom = "BaseNarrative"
      DisplayName = "You shall find my patience limitless for all your foolish antics here, my girl."
      Speaker = "Chronos"
      Event = "ChronosBossMiscStart02"
    }
    {
      Id = "Chronos_0179"
      InheritFrom = "BaseNarrative"
      DisplayName = "I spent aeons buried in the depths below; a few rude trespasses from you are hardly of concern."
      Speaker = "Chronos"
      Event = "ChronosBossMiscStart03"
    }
    {
      Id = "Chronos_0180"
      InheritFrom = "BaseNarrative"
      DisplayName = "This little spat with you was clearly never going to resolve in a more-civil way..."
      Speaker = "Chronos"
      Event = "ChronosBossMiscStart04"
    }
    {
      Id = "Chronos_0181"
      InheritFrom = "BaseNarrative"
      DisplayName = "Long have I lorded on this throne; a bit of vigorous activity should do me well."
      Speaker = "Chronos"
      Event = "ChronosBossMiscStart05"
    }
    {
      Id = "Chronos_0182"
      InheritFrom = "BaseNarrative"
      DisplayName = "To think that the combined might of my forces proved insufficient against a mere girl."
      Speaker = "Chronos"
      Event = "ChronosBossMiscStart06"
    }
    {
      Id = "Chronos_0183"
      InheritFrom = "BaseNarrative"
      DisplayName = "You are methodical, I grant you that. But I shall have to take from you much more."
      Speaker = "Chronos"
      Event = "ChronosBossMiscStart07"
    }
    {
      Id = "Chronos_0184"
      InheritFrom = "BaseNarrative"
      DisplayName = "You cannot be in two places at once. Whilst you vainly lash out, Olympus burns..."
      Speaker = "Chronos"
      Event = "ChronosBossMiscStart08"
    }
    {
      Id = "Chronos_0185"
      InheritFrom = "BaseNarrative"
      DisplayName = "Time can seem to pass in an instant, or last an eternity. On this occasion, let us make it quick."
      Speaker = "Chronos"
      Event = "ChronosBossMiscStart09"
    }
    {
      Id = "Chronos_0186"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Fates themselves could not prevent my rightful rule; what hope have you?"
      Speaker = "Chronos"
      Event = "ChronosBossMiscStart10"
    }
    {
      Id = "Chronos_1485"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Scoff> {#Prev}...You wish to bring about the end of Time...? Well then, {#Emph}observe... {#Prev}for I shall give you... but a {#Emph}glimpse...!"
      Speaker = "Chronos"
      Event = "ChronosBossPreTrueEndingFinalPhase01"
    }
    {
      Id = "Chronos_0987"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I have withstood the gods... even the Fates! Yet you would deign to bring me low. How {#Emph}dare {#Prev}you. How {#Emph}dare {#Prev}you?"
      Speaker = "Chronos"
      Event = "ChronosBossR2Outro01"
    }
    {
      Id = "Chronos_0216"
      InheritFrom = "BaseNarrative"
      DisplayName = "...{#Emph}Nngh! {#Prev}This audience has lasted long enough. You do not get to {#Emph}barge {#Prev}into this House, and waste {#Emph}my {#Prev}time! I {#Emph}am {#Prev}Time. And I can make your every moment {#Emph}hell."
      Speaker = "Chronos"
      Event = "ChronosR1FirstWin"
    }
    {
      Id = "Chronos_0221"
      InheritFrom = "BaseNarrative"
      DisplayName = "...{#Emph}Nrgh{#Prev}, you wretched child...! Like father, like daughter, then, is it...?"
      Speaker = "Chronos"
      Event = "ChronosR1Win01"
    }
    {
      Id = "Chronos_0222"
      InheritFrom = "BaseNarrative"
      DisplayName = "...You do not belong here... you do not belong {#Emph}anywhere{#Prev}, at all..."
      Speaker = "Chronos"
      Event = "ChronosR1Win02"
    }
    {
      Id = "Chronos_0223"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Pah...! {#Prev}It took six full-grown gods to thwart me once... not one mere {#Emph}child!"
      Speaker = "Chronos"
      Event = "ChronosR1Win03"
    }
    {
      Id = "Chronos_0224"
      InheritFrom = "BaseNarrative"
      DisplayName = "...{#Emph}Heh heh... {#Prev}so, you possess some of your father's strength. Or rather, {#Emph}mine..."
      Speaker = "Chronos"
      Event = "ChronosR1Win04"
    }
    {
      Id = "Chronos_0225"
      InheritFrom = "BaseNarrative"
      DisplayName = "...{#Emph}Augh... {#Prev}I grow quite weary of this dour place..."
      Speaker = "Chronos"
      Event = "ChronosR1Win05"
    }
    {
      Id = "Chronos_0226"
      InheritFrom = "BaseNarrative"
      DisplayName = "...{#Emph}Ungh... {#Prev}perhaps... a change of scenery is best..."
      Speaker = "Chronos"
      Event = "ChronosR1Win06"
    }
    {
      Id = "Chronos_0217"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Gasp> {#Prev}I thought... {#Emph}none {#Prev}could resist the ravages of Time... but, {#Emph}you? How...?"
      Speaker = "Chronos"
      Event = "ChronosBossOutro01"
    }
    {
      Id = "MelinoeField_1404"
      InheritFrom = "BaseNarrative"
      DisplayName = "You'll get no answers from me, and no mercy, either. Now {#Emph}die{#Prev}, already. And I'll collect the ichor from your veins. Or whatever flows through them."
      Speaker = "Melinoe"
      Event = "ChronosBossOutro01"
    }
    {
      Id = "Chronos_0218"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hah, hah, hah! {#Prev}What is death to the deathless? A mere nuisance! This House is {#Emph}mine. {#Prev}Once I am gone... you shall be cast away."
      Speaker = "Chronos"
      Event = "ChronosBossOutro01"
    }
    {
      Id = "MelinoeField_1405"
      InheritFrom = "BaseNarrative"
      DisplayName = "I expect so. And you'll be re-made and back on the throne before I can return. But I {#Emph}shall {#Prev}return. And I'll slay you again, and again, and {#Emph}again{#Prev}, if I must."
      Speaker = "Melinoe"
      Event = "ChronosBossOutro01"
    }
    {
      Id = "Chronos_0219"
      InheritFrom = "BaseNarrative"
      DisplayName = "Even if, in so doing, it meant that you would never see your dear old family again? Because the mercy I have shown to them thus far is something I may have to re-evaluate."
      Speaker = "Chronos"
      Event = "ChronosBossOutro01"
    }
    {
      Id = "MelinoeField_1406"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Our {#Prev}family. And what do I care? I don't even know them. But I {#Emph}do {#Prev}know you ought be dead here in another moment; any last words?"
      Speaker = "Melinoe"
      Event = "ChronosBossOutro01"
    }
    {
      Id = "Chronos_0892"
      InheritFrom = "BaseNarrative"
      DisplayName = "...For you, my girl...? A mere reminder... nothing more..."
      Speaker = "Chronos"
      Event = "ChronosBossOutro01"
    }
    {
      Id = "Chronos_1402"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Argh... {#Prev}some family {#Emph}you {#Prev}are! Go on and try to cast me out as they once did! See what good shall come of it!"
      Speaker = "Chronos"
      Event = "ChronosBossOutroUltimateProgress01"
    }
    {
      Id = "MelinoeField_5044"
      InheritFrom = "BaseNarrative"
      DisplayName = "I intend to. Though if you wished to be part of the family so much, perhaps you oughtn't have waged war with them."
      Speaker = "Melinoe"
      Event = "ChronosBossOutroUltimateProgress01"
    }
    {
      Id = "Chronos_1403"
      InheritFrom = "BaseNarrative"
      DisplayName = "With {#Emph}them{#Prev}, you say! Not {#Emph}us! {#Prev}You, too, are a reject, daughter of Hades! Always shall be, and always would have been!"
      Speaker = "Chronos"
      Event = "ChronosBossOutroUltimateProgress01"
    }
    {
      Id = "Chronos_1404"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Gah... {#Prev}you gods learn nothing from the past! Recklessly changed everything to suit your whim!"
      Speaker = "Chronos"
      Event = "ChronosBossOutroUltimateProgress02"
    }
    {
      Id = "MelinoeField_5045"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're the one who's learned nothing. Despite all the time you've had to think on it."
      Speaker = "Melinoe"
      Event = "ChronosBossOutroUltimateProgress02"
    }
    {
      Id = "Chronos_1405"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh on the contrary... I know change is inevitable, with Time... the only question is... which sort..."
      Speaker = "Chronos"
      Event = "ChronosBossOutroUltimateProgress02"
    }
    {
      Id = "Chronos_1445"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Augh...! {#Prev}My own family has done worse to me before... well, I am vastly stronger now! Stronger with each passing night...!"
      Speaker = "Chronos"
      Event = "ChronosBossOutroUltimateProgress03"
    }
    {
      Id = "MelinoeField_5089"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're old and tired. You don't even know why you're fighting anymore. To prove something to your children?"
      Speaker = "Melinoe"
      Event = "ChronosBossOutroUltimateProgress03"
    }
    {
      Id = "Chronos_1446"
      InheritFrom = "BaseNarrative"
      DisplayName = "They took {#Emph}everything {#Prev}from me! Everything and more. Now they seek for you to take the {#Emph}rest. {#Prev}Such a wretched family, this..."
      Speaker = "Chronos"
      Event = "ChronosBossOutroUltimateProgress03"
    }
    {
      Id = "Chronos_1448"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Gah...! {#Prev}Well, this was certainly a treat, Granddaughter. Again tomorrow night, perhaps...?"
      Speaker = "Chronos"
      Event = "ChronosBossOutroUltimateProgress04"
    }
    {
      Id = "MelinoeField_5090"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps. So tell me, Titan... is {#Emph}this {#Prev}what having family about is like? Bitter feuds and snide remarks?"
      Speaker = "Melinoe"
      Event = "ChronosBossOutroUltimateProgress04"
    }
    {
      Id = "Chronos_1449"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh {#Emph}yes! {#Prev}This is the whole of it! I may have denied it to you... but I was doing you a {#Emph}favor! {#Prev}You shall see..."
      Speaker = "Chronos"
      Event = "ChronosBossOutroUltimateProgress04"
    }
    {
      Id = "Chronos_1452"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Nrgh...! {#Prev}You truly think... you {#Emph}gods... {#Prev}are better fit to rule this world than I...?"
      Speaker = "Chronos"
      Event = "ChronosBossOutroUltimateProgress05"
    }
    {
      Id = "MelinoeField_5091"
      InheritFrom = "BaseNarrative"
      DisplayName = "We both know that is {#Emph}not {#Prev}what this is about, Titan. And all that plagues this world is not getting any better while we perpetuate it."
      Speaker = "Melinoe"
      Event = "ChronosBossOutroUltimateProgress05"
    }
    {
      Id = "Chronos_1453"
      InheritFrom = "BaseNarrative"
      DisplayName = "If not this world, my girl... then what {#Emph}is {#Prev}this about... do you suppose...?"
      Speaker = "Chronos"
      Event = "ChronosBossOutroUltimateProgress05"
    }
    {
      Id = "MelinoeField_5092"
      InheritFrom = "BaseNarrative"
      DisplayName = "My mother's handmaiden... you give her back. Right now."
      Speaker = "Melinoe"
      Event = "ChronosBossOutroAfterHecateKidnapped01"
    }
    {
      Id = "Chronos_1455"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Urgh...! {#Prev}You care so much... for this {#Emph}witch-handmaiden {#Prev}of yours. Would that a single relative of mine... showed me even an iota of concern...!"
      Speaker = "Chronos"
      Event = "ChronosBossOutroAfterHecateKidnapped01"
    }
    {
      Id = "MelinoeField_5093"
      InheritFrom = "BaseNarrative"
      DisplayName = "What reason would they have to care? Look what you've done! You're trying to take {#Emph}everything {#Prev}from us! Our future!"
      Speaker = "Melinoe"
      Event = "ChronosBossOutroAfterHecateKidnapped01"
    }
    {
      Id = "Chronos_1456"
      InheritFrom = "BaseNarrative"
      DisplayName = "We are {#Emph}family... {#Prev}we do not take, we {#Emph}share! {#Prev}Destroy me, then! If you possess such strength. And see what {#Emph}future {#Prev}you shall bring about..."
      Speaker = "Chronos"
      Event = "ChronosBossOutroAfterHecateKidnapped01"
    }
    {
      Id = "Chronos_1275"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}...Gah. Hah, hah! {#Prev}Again you lay me low. And again you waste your {#Emph}time. {#Prev}I know what it is you seek..."
      Speaker = "Chronos"
      Event = "ChronosBossOutroPreTrueEnding01"
    }
    {
      Id = "MelinoeField_5207"
      InheritFrom = "BaseNarrative"
      DisplayName = "Of course you do. By now I think we've each made our desires rather clear."
      Speaker = "Melinoe"
      Event = "ChronosBossOutroPreTrueEnding01"
    }
    {
      Id = "Chronos_1529"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then go... and take a good look in that Mirror whilst you flail! And do hurry... for I shall never be gone... for long."
      Speaker = "Chronos"
      Event = "ChronosBossOutroPreTrueEnding01"
    }
    {
      Id = "Chronos_1277"
      InheritFrom = "BaseNarrative"
      DisplayName = "You truly think... the power which you used on Typhon can be turned on me? Then prove it! I would like to see you {#Emph}try!"
      Speaker = "Chronos"
      Event = "ChronosBossOutroPreTrueEnding01_B"
    }
    {
      Id = "Chronos_1052"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Nraugh... {#Prev}but I thought... none could possibly resist the ravages of Time... but, {#Emph}you? How...?"
      Speaker = "Chronos"
      Event = "ChronosBossOutroPostTrueEnding01"
    }
    {
      Id = "Chronos_1053"
      InheritFrom = "BaseNarrative"
      DisplayName = "You, my vestige, shall unfortunately never know. Now forgive this old man his transgressions..."
      Speaker = "Chronos"
      Event = "ChronosBossOutroPostTrueEnding01"
    }
    {
      Id = "Chronos_0227"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ungh...! {#Prev}This matters not... my plans are already... well underway..."
      Speaker = "Chronos"
      Event = "ChronosBossMiscDefeat01"
    }
    {
      Id = "Chronos_0228"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ngh... {#Prev}I have... returned from worse... suffered much worse... than from the likes of you..."
      Speaker = "Chronos"
      Event = "ChronosBossMiscDefeat02"
    }
    {
      Id = "Chronos_0229"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Augh... {#Prev}you truly are a nuisance, to be sure... but you accomplish naught..."
      Speaker = "Chronos"
      Event = "ChronosBossMiscDefeat03"
    }
    {
      Id = "Chronos_0230"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Gah... {#Prev}to have been brought this low once more, by a mere {#Emph}god..."
      Speaker = "Chronos"
      Event = "ChronosBossMiscDefeat04"
    }
    {
      Id = "Chronos_0231"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Urgh... {#Prev}you are no granddaughter of mine... that you would deign to treat me thus...!"
      Speaker = "Chronos"
      Event = "ChronosBossMiscDefeat05"
    }
    {
      Id = "Chronos_0232"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Mmph... {#Prev}I always... hated... children such as you..."
      Speaker = "Chronos"
      Event = "ChronosBossMiscDefeat06"
    }
    {
      Id = "Chronos_0233"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Khh... {#Prev}I curse the day... your father... sired you..."
      Speaker = "Chronos"
      Event = "ChronosBossMiscDefeat07"
    }
    {
      Id = "Chronos_0234"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Rrngh...! {#Prev}How... are you able to resist...?"
      Speaker = "Chronos"
      Event = "ChronosBossMiscDefeat08"
    }
    {
      Id = "Chronos_0235"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Guh... {#Prev}goodbye again, only for now, my girl..."
      Speaker = "Chronos"
      Event = "ChronosBossMiscDefeat09"
    }
    {
      Id = "Chronos_0236"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Nrgh... {#Prev}you waste your precious time... Olympus {#Emph}burns..."
      Speaker = "Chronos"
      Event = "ChronosBossMiscDefeat10"
    }
    {
      Id = "Chronos_0237"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Rngh... {#Prev}you cannot stop me... merely... slow me down a bit..."
      Speaker = "Chronos"
      Event = "ChronosBossMiscDefeat11"
    }
    {
      Id = "Chronos_0238"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Argh...! {#Prev}How is it that I cannot vanquish such a {#Emph}brat...?"
      Speaker = "Chronos"
      Event = "ChronosBossMiscDefeat12"
    }
    {
      Id = "Chronos_0239"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Gasp> {#Prev}My age, perhaps, is catching up with me..."
      Speaker = "Chronos"
      Event = "ChronosBossMiscDefeat13"
    }
    {
      Id = "Chronos_0240"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hngh... {#Prev}once more, you bring me low... but not for long..."
      Speaker = "Chronos"
      Event = "ChronosBossMiscDefeat14"
    }
    {
      Id = "Chronos_0241"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Tsch... {#Prev}brought low once more... for what? Some grains of {#Emph}Sand?"
      Speaker = "Chronos"
      Event = "ChronosBossMiscDefeat15"
    }
    {
      Id = "Chronos_0242"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Naugh... {#Prev}this victory of yours... shall be short-lived..."
      Speaker = "Chronos"
      Event = "ChronosBossMiscDefeat16"
    }
    {
      Id = "Chronos_0243"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Nngh...! {#Prev}Once more... I am undone...! I shall be back... in the blink of an eye..."
      Speaker = "Chronos"
      Event = "ChronosBossMiscDefeat17"
    }
    {
      Id = "Chronos_0244"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Raugh... {#Prev}of all my vexing relatives... you are amongst the worst..."
      Speaker = "Chronos"
      Event = "ChronosBossMiscDefeat18"
    }
    {
      Id = "Chronos_0998"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Grngh... {#Prev}monstrous... grandchild... you..."
      Speaker = "Chronos"
      Event = "ChronosBossAltFightMiscDefeat01"
    }
    {
      Id = "Chronos_0999"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Augh... {#Prev}but this... is impossible..."
      Speaker = "Chronos"
      Event = "ChronosBossAltFightMiscDefeat02"
    }
    {
      Id = "Chronos_1000"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Nrrgh... {#Prev}how... could this... transpire...?"
      Speaker = "Chronos"
      Event = "ChronosBossAltFightMiscDefeat03"
    }
    {
      Id = "Chronos_1001"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Rngh... {#Prev}you... accursed... Fates...!"
      Speaker = "Chronos"
      Event = "ChronosBossAltFightMiscDefeat04"
    }
    {
      Id = "Chronos_1002"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Argh... {#Prev}I struck... not even {#Emph}once...?"
      Speaker = "Chronos"
      Event = "ChronosBossAltFightMiscDefeat05"
    }
    {
      Id = "Chronos_1003"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hngh... {#Prev}you... eluded me... at each and every turn..."
      Speaker = "Chronos"
      Event = "ChronosBossAltFightMiscDefeat06"
    }
    {
      Id = "Chronos_1004"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Gah... {#Prev}you were... too swift... even for Time...?"
      Speaker = "Chronos"
      Event = "ChronosBossAltFightMiscDefeat07"
    }
    {
      Id = "Chronos_1005"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ngh... {#Prev}such haste... I have not seen such haste since..."
      Speaker = "Chronos"
      Event = "ChronosBossAltFightMiscDefeat08"
    }
    {
      Id = "Chronos_1510"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Augh... {#Prev}not even... my full strength... sufficed..."
      Speaker = "Chronos"
      Event = "ChronosBossAltFightMiscDefeat09"
    }
    {
      Id = "Chronos_1511"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Argh... {#Prev}even here... at the very end... of Time? Was this... inevitable, after all...?"
      Speaker = "Chronos"
      Event = "ChronosBossAltFightMiscDefeat10"
    }
    {
      Id = "Chronos_1512"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Gah...! {#Prev}I was evaded... {#Emph}constantly... {#Prev}as though you always were... a step ahead..."
      Speaker = "Chronos"
      Event = "ChronosBossAltFightMiscDefeat11"
    }
    {
      Id = "Chronos_1516"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Argh...! {#Prev}I was too slow... but at least I fade, knowing... Time only flies... when you are having {#Emph}fun!"
      Speaker = "Chronos"
      Event = "ChronosBossAltFightMiscDefeat12"
    }
    {
      Id = "Chronos_1513"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ungh...! {#Prev}You think... you reached the End of Time... yet fail to see... that it is also... the beginning...!"
      Speaker = "Chronos"
      Event = "ChronosBossAltFightMiscDefeat13"
    }
    {
      Id = "Chronos_1514"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Nraugh...! {#Prev}How could you... be so swift...? Or am I... now too slow...?"
      Speaker = "Chronos"
      Event = "ChronosBossAltFightMiscDefeat14"
    }
    {
      Id = "Chronos_1515"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Augh...! {#Prev}Such impossible haste... with which you struck...! Faster than Time...!"
      Speaker = "Chronos"
      Event = "ChronosBossAltFightMiscDefeat15"
    }
    {
      Id = "Chronos_1064"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Expecting someone else?"
      Speaker = "Chronos"
      Event = "Chronos_TyphonFight.PreFightVoiceLines"
    }
    {
      Id = "Chronos_1071"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh good, you have arrived."
      Speaker = "Chronos"
      Event = "Chronos_TyphonFight.PreFightVoiceLines"
    }
    {
      Id = "Chronos_1072"
      InheritFrom = "BaseSubtitle"
      DisplayName = "To have come all this way..."
      Speaker = "Chronos"
      Event = "Chronos_TyphonFight.PreFightVoiceLines"
    }
    {
      Id = "Chronos_0008"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Greetings, little one."
      Speaker = "Chronos"
      Event = "Chronos_TyphonFight.PreFightVoiceLines"
    }
    {
      Id = "Chronos_0024"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How fare you, little one?"
      Speaker = "Chronos"
      Event = "Chronos_TyphonFight.PreFightVoiceLines"
    }
    {
      Id = "Chronos_0025"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You."
      Speaker = "Chronos"
      Event = "Chronos_TyphonFight.PreFightVoiceLines"
    }
    {
      Id = "Chronos_0027"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}There {#Prev}you are."
      Speaker = "Chronos"
      Event = "Chronos_TyphonFight.PreFightVoiceLines"
    }
    {
      Id = "Chronos_0028"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just in time."
      Speaker = "Chronos"
      Event = "Chronos_TyphonFight.PreFightVoiceLines"
    }
    {
      Id = "Chronos_0029"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Greetings."
      Speaker = "Chronos"
      Event = "Chronos_TyphonFight.PreFightVoiceLines"
    }
    {
      Id = "Chronos_0783"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Right on Time."
      Speaker = "Chronos"
      Event = "Chronos_TyphonFight.PreFightVoiceLines"
    }
    {
      Id = "Chronos_0791"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What a coincidence."
      Speaker = "Chronos"
      Event = "Chronos_TyphonFight.PreFightVoiceLines"
    }
    {
      Id = "Chronos_1226"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Olympus..."
      Speaker = "Chronos"
      Event = "Chronos_TyphonFight.PreFightVoiceLines"
    }
    {
      Id = "Chronos_1229"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You called?"
      Speaker = "Chronos"
      Event = "Chronos_TyphonFight.PreFightVoiceLines"
    }
    {
      Id = "Chronos_1225"
      InheritFrom = "BaseSubtitle"
