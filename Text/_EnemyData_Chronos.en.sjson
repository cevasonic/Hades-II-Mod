    }
    {
      Id = "Chronos_0876"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come... with... {#Emph}me."
      Speaker = "Chronos"
      Event = "Chronos.NextPhaseVoiceLines"
    }
    {
      Id = "Chronos_0877"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You... are... {#Emph}done."
      Speaker = "Chronos"
      Event = "Chronos.NextPhaseVoiceLines"
    }
    {
      Id = "Chronos_1486"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come finish what your father started, Granddaughter!"
      Speaker = "Chronos"
      Event = "Chronos.NextPhaseVoiceLines"
    }
    {
      Id = "Chronos_1487"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And do take a good look around..."
      Speaker = "Chronos"
      Event = "Chronos.NextPhaseVoiceLines"
    }
    {
      Id = "Chronos_1488"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Ask yourself... where do you think you are?"
      Speaker = "Chronos"
      Event = "Chronos.NextPhaseVoiceLines"
    }
    {
      Id = "Chronos_1489"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Or perhaps the better question is {#Emph}when?"
      Speaker = "Chronos"
      Event = "Chronos.NextPhaseVoiceLines"
    }
    {
      Id = "Chronos_1490"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What is it that you think you see?"
      Speaker = "Chronos"
      Event = "Chronos.NextPhaseVoiceLines"
    }
    {
      Id = "Chronos_1491"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Who exactly do you think I am? Do you take me for?!"
      Speaker = "Chronos"
      Event = "Chronos.NextPhaseVoiceLines"
    }
    {
      Id = "Chronos_1492"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And how could you {#Emph}possibly {#Prev}think {#Emph}you {#Prev}could bring about my destruction?!"
      Speaker = "Chronos"
      Event = "Chronos.NextPhaseVoiceLines"
    }
    {
      Id = "Chronos_1493"
      InheritFrom = "BaseSubtitle"
      DisplayName = "But by all means, {#Emph}please{#Prev}, go ahead and try! Or {#Emph}do {#Prev}it, better yet!"
      Speaker = "Chronos"
      Event = "Chronos.NextPhaseVoiceLines"
    }
    {
      Id = "Chronos_1494"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Bring this entire blasted world screaming to a halt!"
      Speaker = "Chronos"
      Event = "Chronos.NextPhaseVoiceLines"
    }
    {
      Id = "Chronos_1495"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Better than to leave the world in careless hands!"
      Speaker = "Chronos"
      Event = "Chronos.NextPhaseVoiceLines"
    }
    {
      Id = "Chronos_1496"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You would be doing me a {#Emph}mercy!"
      Speaker = "Chronos"
      Event = "Chronos.NextPhaseVoiceLines"
    }
    {
      Id = "Chronos_1497"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And saving me a great deal of trouble."
      Speaker = "Chronos"
      Event = "Chronos.NextPhaseVoiceLines"
    }
    {
      Id = "Chronos_1498"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come on, {#Emph}stop {#Prev}me!"
      Speaker = "Chronos"
      Event = "Chronos.NextPhaseVoiceLines"
    }
    {
      Id = "Chronos_1499"
      InheritFrom = "BaseSubtitle"
      DisplayName = "But understand one thing..."
      Speaker = "Chronos"
      Event = "Chronos.NextPhaseVoiceLines"
    }
    {
      Id = "Chronos_1500"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I shall {#Emph}always {#Prev}be one step ahead of you!"
      Speaker = "Chronos"
      Event = "Chronos.NextPhaseVoiceLines"
    }
    {
      Id = "Chronos_1501"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}All {#Prev}of you!"
      Speaker = "Chronos"
      Event = "Chronos.NextPhaseVoiceLines"
    }
    {
      Id = "Chronos_1502"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And always remember..."
      Speaker = "Chronos"
      Event = "Chronos.NextPhaseVoiceLines"
    }
    {
      Id = "Chronos_1503"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Time is the one thing in this life... which, once discarded..."
      Speaker = "Chronos"
      Event = "Chronos.NextPhaseVoiceLines"
    }
    {
      Id = "Chronos_1504"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...can {#Emph}never be recovered!"
      Speaker = "Chronos"
      Event = "Chronos.NextPhaseVoiceLines"
    }
    {
      Id = "Chronos_0988"
      InheritFrom = "BaseSubtitle"
      DisplayName = "My patience... has its {#Emph}limits!"
      Speaker = "Chronos"
      Event = "Chronos.NextPhaseVoiceLines"
    }
    {
      Id = "Chronos_0989"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I... have had... {#Emph}enough!"
      Speaker = "Chronos"
      Event = "Chronos.NextPhaseVoiceLines"
    }
    {
      Id = "Chronos_0990"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Time... cannot... be {#Emph}stopped!"
      Speaker = "Chronos"
      Event = "Chronos.NextPhaseVoiceLines"
    }
    {
      Id = "Chronos_0991"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That... is quite... {#Emph}enough!"
      Speaker = "Chronos"
      Event = "Chronos.NextPhaseVoiceLines"
    }
    {
      Id = "Chronos_0992"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You... foolish... {#Emph}girl!"
