      Event = "Chronos.PlayerInjuredVoiceLines"
    }
    {
      Id = "Chronos_0318"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Expire..."
      Speaker = "Chronos"
      Event = "Chronos.PlayerInjuredVoiceLines"
    }
    {
      Id = "Chronos_0319"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not so fast..."
      Speaker = "Chronos"
      Event = "Chronos.PlayerInjuredVoiceLines"
    }
    {
      Id = "Chronos_0320"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You cannot run forever..."
      Speaker = "Chronos"
      Event = "Chronos.PlayerInjuredVoiceLines"
    }
    {
      Id = "Chronos_0321"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Heedless whelp."
      Speaker = "Chronos"
      Event = "Chronos.PlayerInjuredVoiceLines"
    }
    {
      Id = "Chronos_0322"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Impetuous of you..."
      Speaker = "Chronos"
      Event = "Chronos.PlayerInjuredVoiceLines"
    }
    {
      Id = "Chronos_0323"
      InheritFrom = "BaseSubtitle"
      DisplayName = "There..."
      Speaker = "Chronos"
      Event = "Chronos.PlayerInjuredVoiceLines"
    }
    {
      Id = "Chronos_0324"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Prepared for more?"
      Speaker = "Chronos"
      Event = "Chronos.PlayerInjuredVoiceLines"
    }
    {
      Id = "Chronos_0325"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What now?"
      Speaker = "Chronos"
      Event = "Chronos.PlayerInjuredVoiceLines"
    }
    {
      Id = "Chronos_0326"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How daft you are..."
      Speaker = "Chronos"
      Event = "Chronos.PlayerInjuredVoiceLines"
    }
    {
      Id = "Chronos_0327"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Learn some respect!"
      Speaker = "Chronos"
      Event = "Chronos.PlayerInjuredVoiceLines"
    }
    {
      Id = "Chronos_0328"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You had it coming."
      Speaker = "Chronos"
      Event = "Chronos.PlayerInjuredVoiceLines"
    }
    {
      Id = "Chronos_0329"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We are not done."
      Speaker = "Chronos"
      Event = "Chronos.PlayerInjuredVoiceLines"
    }
    {
      Id = "Chronos_0330"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Another, then?"
      Speaker = "Chronos"
      Event = "Chronos.PlayerInjuredVoiceLines"
    }
    {
      Id = "Chronos_0331"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Relent."
      Speaker = "Chronos"
      Event = "Chronos.PlayerInjuredVoiceLines"
    }
    {
      Id = "Chronos_0332"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Relent, blast you!"
      Speaker = "Chronos"
      Event = "Chronos.PlayerInjuredVoiceLines"
    }
    {
      Id = "Chronos_0333"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Embarrassing."
      Speaker = "Chronos"
      Event = "Chronos.PlayerInjuredVoiceLines"
    }
    {
      Id = "Chronos_0334"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Get from this hall."
      Speaker = "Chronos"
      Event = "Chronos.PlayerInjuredVoiceLines"
    }
    {
      Id = "Chronos_0335"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Time takes all."
      Speaker = "Chronos"
      Event = "Chronos.PlayerInjuredVoiceLines"
    }
    {
      Id = "Chronos_0336"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Too slow, my girl..."
      Speaker = "Chronos"
      Event = "Chronos.PlayerInjuredVoiceLines"
    }
    {
      Id = "Chronos_0337"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Alas, my girl..."
      Speaker = "Chronos"
      Event = "Chronos.PlayerInjuredVoiceLines"
    }
    {
      Id = "Chronos_0338"
      InheritFrom = "BaseSubtitle"
      DisplayName = "My scythe shall find you."
      Speaker = "Chronos"
      Event = "Chronos.PlayerInjuredVoiceLines"
    }
    {
      Id = "Chronos_1507"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What...? You should be {#Emph}gone!"
      Speaker = "Chronos"
      Event = "Chronos.LastStandReactionVoiceLines"
    }
    {
      Id = "Chronos_1508"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}How {#Prev}are you {#Emph}resisting {#Prev}all of this?"
      Speaker = "Chronos"
      Event = "Chronos.LastStandReactionVoiceLines"
    }
    {
      Id = "Chronos_1509"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Impossible... "
      Speaker = "Chronos"
      Event = "Chronos.LastStandReactionVoiceLines"
    }
    {
      Id = "Chronos_1521"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You would destroy me, truly, then..."
      Speaker = "Chronos"
      Event = "Chronos.LastStandReactionVoiceLines"
    }
    {
      Id = "Chronos_1522"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Fine! {#Emph}Do it!"
      Speaker = "Chronos"
      Event = "Chronos.LastStandReactionVoiceLines"
    }
    {
      Id = "Chronos_1524"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Make me forever gone!"
      Speaker = "Chronos"
      Event = "Chronos.LastStandReactionVoiceLines"
    }
    {
      Id = "Chronos_1523"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Come on{#Prev}, Granddaughter!"
      Speaker = "Chronos"
      Event = "Chronos.LastStandReactionVoiceLines"
    }
    {
      Id = "Chronos_1525"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I care not!"
      Speaker = "Chronos"
      Event = "Chronos.LastStandReactionVoiceLines"
    }
    {
      Id = "Chronos_1505"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Gah...! {#Prev}But this is... my domain!"
      Speaker = "Chronos"
      Event = "Chronos.LastStandReactionVoiceLines"
    }
    {
      Id = "Chronos_1506"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Augh...! {#Prev}How utterly mortifying...!"
      Speaker = "Chronos"
      Event = "Chronos.LastStandReactionVoiceLines"
    }
    {
      Id = "Chronos_0291"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Still you resist...?"
      Speaker = "Chronos"
      Event = "Chronos.LastStandReactionVoiceLines"
    }
    {
      Id = "Chronos_0292"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not finished yet?"
      Speaker = "Chronos"
      Event = "Chronos.LastStandReactionVoiceLines"
    }
    {
      Id = "Chronos_0293"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Our family's favorite trick..."
      Speaker = "Chronos"
      Event = "Chronos.LastStandReactionVoiceLines"
    }
    {
      Id = "Chronos_0294"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Your strength shall fail you..."
      Speaker = "Chronos"
      Event = "Chronos.LastStandReactionVoiceLines"
    }
    {
      Id = "Chronos_0295"
      InheritFrom = "BaseSubtitle"
      DisplayName = "But one more cut or two..."
      Speaker = "Chronos"
      Event = "Chronos.LastStandReactionVoiceLines"
    }
    {
      Id = "Chronos_0296"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You only make things worse!"
      Speaker = "Chronos"
      Event = "Chronos.LastStandReactionVoiceLines"
    }
    {
      Id = "Chronos_0297"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, please."
      Speaker = "Chronos"
      Event = "Chronos.LastStandReactionVoiceLines"
    }
    {
      Id = "Chronos_0298"
      InheritFrom = "BaseSubtitle"
      DisplayName = "My girl, would you please die?"
      Speaker = "Chronos"
