    {
      Id = "Storyteller_0474"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The alluring Siren song fades finally to nothingness, leaving the Princess of the Dead to contemplate the pathways plunging deeper toward forbidden regions of the realm."
      Speaker = "Storyteller"
      Event = "Inspect_G_Boss01_02"
    }
    {
      Id = "MelinoeField_3821"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We're almost to the Fields."
      Speaker = "Melinoe"
      Event = "Inspect_G_Boss01_02"
    }
    {
      Id = "Storyteller_0143"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Where once reverberated the enthralling music of the Sirens, sheer silence now remains; yet for how long shall those immortal songstresses be stilled?"
      Speaker = "Storyteller"
      Event = "Inspect_G_Boss01_01"
    }
    {
      Id = "MelinoeField_0222"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Doubtless only till my next attempt..."
      Speaker = "Melinoe"
      Event = "Inspect_G_Boss01_01"
    }
    {
      Id = "Storyteller_0420"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Though bolstered by colossal Charybdis, Scylla and those monstrous songstresses from the abyssal sea yet prove unable to complete their deadly act."
      Speaker = "Storyteller"
      Event = "Inspect_G_Boss02_01"
    }
    {
      Id = "MelinoeField_3613"
      InheritFrom = "BaseSubtitle"
      DisplayName = "In the end, a normal night for them."
      Speaker = "Melinoe"
      Event = "Inspect_G_Boss02_01"
    }
    {
      Id = "Storyteller_0455"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}With such a rousing show abruptly ended all too soon, the Shades there in attendance are left to wonder whether to await an encore, or a refund."
      Speaker = "Storyteller"
      Event = "Inspect_G_Boss02_02"
    }
    {
      Id = "MelinoeField_3653"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Passes are nonrefundable I think..."
      Speaker = "Melinoe"
      Event = "Inspect_G_Boss02_02"
    }
    {
      Id = "Storyteller_0169"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Within a green-tinged chamber that the shrilly-singing Sirens made their own, a pathway plunges deep into the unknown outskirts of the Underworld."
      Speaker = "Storyteller"
      Event = "Inspect_G_PostBoss_01"
    }
    {
      Id = "MelinoeField_0815"
      InheritFrom = "BaseSubtitle"
      DisplayName = "So this is Scylla's little lair, huh?"
      Speaker = "Melinoe"
      Event = "Inspect_G_PostBoss_01"
    }
    {
      Id = "Storyteller_0211"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Collected works of sailor-slaying Scylla and her Sirens lie conspicuously scattered here, a parting vengeance on the sensibility of those who dare to take a closer look."
      Speaker = "Storyteller"
      Event = "Inspect_G_PostBoss_02"
    }
    {
      Id = "MelinoeField_1326"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}You're such a mess, that little dress... {#Prev}oh, gods..."
      Speaker = "Melinoe"
      Event = "Inspect_G_PostBoss_02"
    }
    {
      Id = "MelinoeField_0983"
      InheritFrom = "BaseSubtitle"
      DisplayName = "First tunnel to my right..."
      Speaker = "Melinoe"
      Event = "G_PostBoss01.EnterVoiceLines"
    }
    {
      Id = "MelinoeField_0984"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Sirens' ready-room..."
      Speaker = "Melinoe"
      Event = "G_PostBoss01.EnterVoiceLines"
    }
    {
      Id = "MelinoeField_0985"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No Sirens, thank the gods..."
      Speaker = "Melinoe"
      Event = "G_PostBoss01.EnterVoiceLines"
    }
    {
      Id = "MelinoeField_0986"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Best get out before Scylla comes back."
      Speaker = "Melinoe"
      Event = "G_PostBoss01.EnterVoiceLines"
    }
    {
      Id = "MelinoeField_0987"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The edge of Oceanus..."
      Speaker = "Melinoe"
      Event = "G_PostBoss01.EnterVoiceLines"
    }
    {
      Id = "MelinoeField_0988"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The very bottom of the sea..."
