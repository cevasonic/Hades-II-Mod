    {
      Id = "Storyteller_0019"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Within the sopping, blackest pits of Oceanus reside horrors that the greatest mortal or immortal poets could not possibly describe."
      Speaker = "Storyteller"
      Event = "Inspect_G_Intro_01"
    }
    {
      Id = "Melinoe_0854"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Don't sell yourself short, Homer."
      Speaker = "Melinoe"
      Event = "Inspect_G_Intro_01"
    }
    {
      Id = "Melinoe_0151"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll find a way."
      Speaker = "Melinoe"
      Event = "Inspect_G_Intro_01"
    }
    {
      Id = "Storyteller_0142"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The Underworld plunges deeper than the deepest sea; yet there are such places where the edge of one and the other meet."
      Speaker = "Storyteller"
      Event = "Inspect_G_Intro_02"
    }
    {
      Id = "MelinoeField_0221"
      InheritFrom = "BaseSubtitle"
      DisplayName = "One dark abyss next to another..."
      Speaker = "Melinoe"
      Event = "Inspect_G_Intro_02"
    }
    {
      Id = "MelinoeField_5026"
      InheritFrom = "BaseSubtitle"
      DisplayName = "All right, Fates, where are you...?"
      Speaker = "Melinoe"
      Event = "G_Intro.EnterVoiceLines"
    }
    {
      Id = "Melinoe_5692"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Fear not, you three... we'll find you..."
      Speaker = "Melinoe"
      Event = "G_Intro.EnterVoiceLines"
    }
    {
      Id = "MelinoeField_4601"
      InheritFrom = "BaseSubtitle"
