      Event = "G_Intro.EnterVoiceLines"
    }
    {
      Id = "Storyteller_0146"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Even the faintest river-current in the Underworld bears willingly the Boatman of the Dead... wheresoever he may please."
      Speaker = "Storyteller"
      Event = "Inspect_G_Shop01_01"
    }
    {
      Id = "MelinoeField_0225"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm grateful he made the trip."
      Speaker = "Melinoe"
      Event = "Inspect_G_Shop01_01"
    }
    {
      Id = "Storyteller_0144"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}That which slithers, seeps, and crawls, all of it thrives within the foul air and crushing climate near the bottom of the sea."
      Speaker = "Storyteller"
      Event = "Inspect_G_MiniBoss01_01"
    }
    {
      Id = "MelinoeField_0223"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The air is definitely stuffier down here..."
      Speaker = "Melinoe"
      Event = "Inspect_G_MiniBoss01_01"
    }
    {
      Id = "Storyteller_0145"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}As surface-vermin flee from sinking vessels, so have Underworld vermin sought darker reaches of their realm, in the tumult of the times."
      Speaker = "Storyteller"
      Event = "Inspect_G_MiniBoss_02_01"
    }
    {
      Id = "MelinoeField_0224"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It's hard to be a rodent..."
      Speaker = "Melinoe"
      Event = "Inspect_G_MiniBoss_02_01"
    }
    {
      Id = "Storyteller_0358"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}There are such creatures born of nightmare and the sea, which float eternally toward death and decay, and so invariably find themselves exactly here."
      Speaker = "Storyteller"
      Event = "Inspect_G_MiniBoss03_01"
    }
    {
      Id = "MelinoeField_3260"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Think I just stepped in one..."
      Speaker = "Melinoe"
      Event = "Inspect_G_MiniBoss03_01"
    }
    {
      Id = "Storyteller_0147"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}In black and murky Oceanus past the border of the Underworld, the putrid waters are purified, as if to show that there, Poseidon holds no sway."
      Speaker = "Storyteller"
      Event = "Inspect_G_Reprieve01_01"
    }
    {
      Id = "MelinoeField_0226"
      InheritFrom = "BaseSubtitle"
      DisplayName = "As long as his Boons still work..."
      Speaker = "Melinoe"
      Event = "Inspect_G_Reprieve01_01"
    }
    {
      Id = "Storyteller_0148"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The mirror sheen of the standing waters all about reveal to denizens of Oceanus their full selves; to their horror, or to their delight."
      Speaker = "Storyteller"
      Event = "Inspect_G_Story01_01"
    }
    {
      Id = "MelinoeField_0227"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This is not a good view..."
