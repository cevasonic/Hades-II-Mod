      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0672"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Nraaaauggh!"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0673"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hraaaauggh!"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0660"
      InheritFrom = "BaseSubtitle"
      DisplayName = "To {#Emph}battle!!"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0661"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Who would dare?!"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0662"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You {#Emph}first!!"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0663"
      InheritFrom = "BaseSubtitle"
      DisplayName = "To the {#Emph}slaughter!!"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0664"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We {#Emph}fight!!"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0665"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Blood shall spill!!"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0666"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll crush you {#Emph}all!"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0667"
      InheritFrom = "BaseSubtitle"
      DisplayName = "For you, Father!!"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0668"
      InheritFrom = "BaseSubtitle"
      DisplayName = "For the Queen!!"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0669"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Gods, watch this!!"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0670"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Who dies first?!"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0671"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Face my club!!"
