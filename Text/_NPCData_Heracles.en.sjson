{
  /*
  This file was autogenerated on 8/5/2025 at 6:47 PM
  by the BuildText tool.
  */
  lang = "en"
  Texts = [
    {
      Id = "MelinoeField_0718"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Gods watch over us."
      Speaker = "Melinoe"
      Event = "NPC_Heracles_01.InteractVoiceLines"
    }
    {
      Id = "MelinoeField_0717"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Stay strong, Son of Zeus."
      Speaker = "Melinoe"
      Event = "NPC_Heracles_01.InteractVoiceLines"
    }
    {
      Id = "Heracles_0080"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Witches..."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.InteractVoiceLines"
    }
    {
      Id = "Heracles_0171"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hm."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.InteractVoiceLines"
    }
    {
      Id = "Heracles_0172"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hm."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.InteractVoiceLines"
    }
    {
      Id = "Heracles_0173"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Mm."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.InteractVoiceLines"
    }
    {
      Id = "Heracles_0425"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What?"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.InteractVoiceLines"
    }
    {
      Id = "Heracles_0424"
      InheritFrom = "BaseSubtitle"
      DisplayName = "They won't."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.InteractVoiceLines"
    }
    {
      Id = "Heracles_0426"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No need."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.InteractVoiceLines"
    }
    {
      Id = "Heracles_0427"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I know my path."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.InteractVoiceLines"
    }
    {
      Id = "Heracles_0428"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Leave me out."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.InteractVoiceLines"
    }
    {
      Id = "Heracles_0429"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Towards what?"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.InteractVoiceLines"
    }
    {
      Id = "Heracles_0423"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Don't call me that again."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.InteractVoiceLines"
    }
    {
      Id = "Heracles_0002"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're the help? Oh, that's rich. Friendly word of advice, {#Emph}sister: {#Prev}Stay out of my bloody way, else you're liable to get hurt. Now scoot, and tell whomever sent you that I work alone."
      Speaker = "Heracles"
      Event = "HeraclesFirstMeeting"
    }
    {
      Id = "MelinoeField_0228"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your threat is duly noted, Son of Zeus. I'm headed for the docks, but understand this city's sealed shut."
      Speaker = "Melinoe"
      Event = "HeraclesFirstMeeting"
    }
    {
      Id = "Heracles_0003"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then you understand you ought turn back. This town is {#Emph}dead{#Prev}, and doesn't let the living pass."
      Speaker = "Heracles"
      Event = "HeraclesFirstMeeting"
    }
    {
      Id = "MelinoeField_0229"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm Daughter of Hades; the dead shall answer to me. They may just need a little encouragement."
      Speaker = "Melinoe"
      Event = "HeraclesFirstMeeting"
    }
    {
      Id = "Heracles_0004"
      InheritFrom = "BaseNarrative"
      DisplayName = "Try all you like. But remember you were warned."
      Speaker = "Heracles"
      Event = "HeraclesFirstMeeting"
    }
    {
      Id = "Heracles_0005"
      InheritFrom = "BaseNarrative"
      DisplayName = "You. Things are about to turn ugly, and I require neither assistance nor witnesses, sister."
      Speaker = "Heracles"
      Event = "HeraclesCombat01"
    }
    {
      Id = "MelinoeField_0230"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm passing through. And I'm not leaving here until the traitors to the House of Hades lie broken at our feet."
      Speaker = "Melinoe"
      Event = "HeraclesCombat01"
    }
    {
      Id = "Heracles_0006"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hah! {#Prev}Fine, then. We'll each earn our share. Though the lion's share is coming with me."
      Speaker = "Heracles"
      Event = "HeraclesCombat01"
    }
    {
      Id = "Heracles_0233"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hold, sister. Remember, not a word about before, or else. We can have ourselves another happy massacre and then be on our way."
      Speaker = "Heracles"
      Event = "HeraclesPreEncounterAboutAltFight01"
    }
    {
      Id = "MelinoeField_3762"
      InheritFrom = "BaseNarrative"
      DisplayName = "And then perhaps we'll meet again on my way to the summit, if the conditions are just right. Wouldn't that be nice?"
      Speaker = "Melinoe"
      Event = "HeraclesPreEncounterAboutAltFight01"
    }
    {
      Id = "Heracles_0234"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sure it would. We understand each other, then. Now to the bloodletting at hand."
      Speaker = "Heracles"
      Event = "HeraclesPreEncounterAboutAltFight01"
    }
    {
      Id = "Heracles_0277"
      InheritFrom = "BaseNarrative"
      DisplayName = "I heard the tidings of your victory, but knew this wasn't over. Always more to be done. Now, come on."
      Speaker = "Heracles"
      Event = "HeraclesPreEncounterAboutTrueEnding01"
    }
    {
      Id = "Heracles_0281"
      InheritFrom = "BaseNarrative"
      DisplayName = "Look who decided to show her shining face again. You want to earn some extra coin, have I the opportunity for you."
      Speaker = "Heracles"
      Event = "HeraclesPreEncounterAboutTimePassing01"
    }
    {
      Id = "Heracles_0023"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm working here, sister. Care to pitch in, fine, but don't get underfoot."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart01"
    }
    {
      Id = "Heracles_0025"
      InheritFrom = "BaseNarrative"
      DisplayName = "Much as I'd love to have ourselves a {#Emph}chat{#Prev}, I'm on the job. And better get to work."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart03"
    }
    {
      Id = "Heracles_0026"
      InheritFrom = "BaseNarrative"
      DisplayName = "You look like you've a taste for blood. Come get your fill for now."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart04"
    }
    {
      Id = "Heracles_0027"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well don't just stand there, sister; we've a war here to perpetuate."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart05"
    }
    {
      Id = "Heracles_0028"
      InheritFrom = "BaseNarrative"
      DisplayName = "Enjoy the silence, sister. We'll have company here any moment now."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart06"
    }
    {
      Id = "Heracles_0029"
      InheritFrom = "BaseNarrative"
      DisplayName = "Need a break from all the slaughter, just stand back. {#Emph}Far {#Prev}back."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart07"
    }
    {
      Id = "Heracles_0030"
      InheritFrom = "BaseNarrative"
      DisplayName = "The gods must want for us to give another glorious performance, huh."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart08"
    }
    {
      Id = "Heracles_0032"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why am I even talking to you, sister? You save your breath, I'll save mine."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart10"
    }
    {
      Id = "Heracles_0034"
      InheritFrom = "BaseNarrative"
      DisplayName = "We get to know each other, you'll live to regret it. Happens all the time."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart11"
    }
    {
      Id = "Heracles_0035"
      InheritFrom = "BaseNarrative"
      DisplayName = "You think you know me, sister. But you don't."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart12"
    }
    {
      Id = "Heracles_0040"
      InheritFrom = "BaseNarrative"
      DisplayName = "Suggest remaining far afield of me at all times, witch."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart13"
    }
    {
      Id = "Heracles_0041"
      InheritFrom = "BaseNarrative"
      DisplayName = "You blasted gods and goddesses are all alike..."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart14"
    }
    {
      Id = "Heracles_0042"
      InheritFrom = "BaseNarrative"
      DisplayName = "Go about your business, sister. I'm on the job."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart16"
    }
    {
      Id = "Heracles_0206"
      InheritFrom = "BaseNarrative"
      DisplayName = "This vessel's going back to the bottom of the sea, whether you're here or not."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart17"
    }
    {
      Id = "Heracles_0207"
      InheritFrom = "BaseNarrative"
      DisplayName = "Rough waters ahead, sister. End up overboard, I won't be diving in to get you out."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart18"
    }
    {
      Id = "Heracles_0208"
      InheritFrom = "BaseNarrative"
      DisplayName = "Another stowaway aboard. And here I thought I was the only one."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart19"
    }
    {
      Id = "Heracles_0209"
      InheritFrom = "BaseNarrative"
      DisplayName = "The sea took these ships' crews once before, and it's about to take them back."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart20"
    }
    {
      Id = "Heracles_0210"
      InheritFrom = "BaseNarrative"
      DisplayName = "This ship's a mess, but let me go ahead and swab the deck, if you'll stand clear."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart21"
    }
    {
      Id = "Heracles_0211"
      InheritFrom = "BaseNarrative"
      DisplayName = "What a coincidence, I was just heading to the mountain of the gods myself."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart22"
    }
    {
      Id = "Heracles_0332"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've an urge to smash this ship to splinters, but then we'd be forced to swim."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart23"
    }
    {
      Id = "Heracles_0333"
      InheritFrom = "BaseNarrative"
      DisplayName = "I claim this ship in the name of the gods, although you're one of them, aren't you?"
      Speaker = "Heracles"
      Event = "HeraclesMiscStart24"
    }
    {
      Id = "Heracles_0334"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not much room here to maneuver, so best stay far afield of my club."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart25"
    }
    {
      Id = "Heracles_0335"
      InheritFrom = "BaseNarrative"
      DisplayName = "The darkness of these waters brings about a certain peace, doesn't it, sister?"
      Speaker = "Heracles"
      Event = "HeraclesMiscStart26"
    }
    {
      Id = "Heracles_0336"
      InheritFrom = "BaseNarrative"
      DisplayName = "Go someplace else. This blasted mountain's defenses are already spread too thin."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart27"
    }
    {
      Id = "Heracles_0337"
      InheritFrom = "BaseNarrative"
      DisplayName = "The gods require all the aid they can muster, which is why we're both here."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart28"
    }
    {
      Id = "Heracles_0338"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh good. I was beginning to feel lonesome having to shoulder all the work myself..."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart29"
    }
    {
      Id = "Heracles_0339"
      InheritFrom = "BaseNarrative"
      DisplayName = "Suggest you stand clear before you're driven back from this mountain like all the rest."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart30"
    }
    {
      Id = "Heracles_0341"
      InheritFrom = "BaseNarrative"
      DisplayName = "Everybody wants a piece of Olympus lately, don't they. But it's not for the taking."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart32"
    }
    {
      Id = "Heracles_0343"
      InheritFrom = "BaseNarrative"
      DisplayName = "Best watch your step in all this ice and snow. Wouldn't want you to slip."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart34"
    }
    {
      Id = "Heracles_0344"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now what could be more glorious than crushing Satyrs into frozen earth?"
      Speaker = "Heracles"
      Event = "HeraclesMiscStart35"
    }
    {
      Id = "Heracles_0345"
      InheritFrom = "BaseNarrative"
      DisplayName = "I was here first, sister. Go find your own Harpies and such to massacre."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart36"
    }
    {
      Id = "Heracles_0346"
      InheritFrom = "BaseNarrative"
      DisplayName = "This is just a warm-up for what's to come later this evening, isn't it, sister?"
      Speaker = "Heracles"
      Event = "HeraclesMiscStart37"
    }
    {
      Id = "Heracles_0347"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll pull my strikes should you happen to get in the way here, but at the summit? No."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart38"
    }
    {
      Id = "Heracles_0348"
      InheritFrom = "BaseNarrative"
      DisplayName = "Soon you shall face me and the Flame Thief once again, but let's keep up the act for now."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart39"
    }
    {
      Id = "Heracles_0350"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm just about to start killing everything that moves, other than you and your pet."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart40"
    }
    {
      Id = "Heracles_0351"
      InheritFrom = "BaseNarrative"
      DisplayName = "Credit to the most efficient killer here; you do the work, you get the coin."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart41"
    }
    {
      Id = "Heracles_0638"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's been too long since last we slaughtered everything that moved about this place."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart42"
    }
    {
      Id = "Heracles_0639"
      InheritFrom = "BaseNarrative"
      DisplayName = "While you've been navigating your father's catacombs, I've had all the glory to myself."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart43"
    }
    {
      Id = "Heracles_0641"
      InheritFrom = "BaseNarrative"
      DisplayName = "We're making a regular habit of crushing the life from anything that moves."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart44"
    }
    {
      Id = "Heracles_0643"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're bloodied, so you'd best stand back and leave the taking of the glory all to me."
      Speaker = "Heracles"
      Event = "HeraclesMiscStart45"
    }
    {
      Id = "Heracles_0007"
      InheritFrom = "BaseNarrative"
      DisplayName = "You live. By my good graces, granted, but... first I've seen somebody stand against the filth that's overtaken this accursed town."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutEphyra01"
    }
    {
      Id = "MelinoeField_0231"
      InheritFrom = "BaseNarrative"
      DisplayName = "I aim to cleanse the filth down to the source. He resides deep in the Underworld, though I've business to attend to on Olympus first."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutEphyra01"
    }
    {
      Id = "Heracles_0008"
      InheritFrom = "BaseNarrative"
      DisplayName = "What a coincidence! I just returned from there not long ago. So the gods are putting all the pieces into place.... You watch yourself, sister."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutEphyra01"
    }
    {
      Id = "Heracles_0009"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know what you are. You bloody witches. One foreign word... one finger-wagging gesture directed at me... and I'll squeeze you till you pop."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutWitches01"
    }
    {
      Id = "MelinoeField_0232"
      InheritFrom = "BaseNarrative"
      DisplayName = "That won't be necessary... though I would know how came you to feel this way about us {#Emph}bloody witches? {#Prev}How many have you met?"
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutWitches01"
    }
    {
      Id = "Heracles_0010"
      InheritFrom = "BaseNarrative"
      DisplayName = "Two questions too many. The more you know, the more you can manipulate. Now, off with you."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutWitches01"
    }
    {
      Id = "MelinoeField_3765"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sir, what are you doing in the middle of the Rift of Thessaly. How did you even get here? Although, you must be a powerful swimmer."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutThessaly01"
    }
    {
      Id = "Heracles_0239"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm proficient in a wide variety of athletics, since you mention it. Swimming, leaping, striking things with clubs."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutThessaly01"
    }
    {
      Id = "MelinoeField_3766"
      InheritFrom = "BaseNarrative"
      DisplayName = "So this is part of your patrol path? To think my journey could have been even more infested with foes if not for you."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutThessaly01"
    }
    {
      Id = "Heracles_0240"
      InheritFrom = "BaseNarrative"
      DisplayName = "Much would be different if not for me. Though you're one of the few I've met of late to admit it. Fair voyaging, sister."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutThessaly01"
    }
    {
      Id = "MelinoeField_0233"
      InheritFrom = "BaseNarrative"
      DisplayName = "Olympus is fortunate to have your strength and service, Son of Zeus."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutOlympus01"
    }
    {
      Id = "Heracles_0011"
      InheritFrom = "BaseNarrative"
      DisplayName = "I serve the gods all right. Served them a long time, one tall order after another. They've brought me fame, glory... {#Emph}everything. {#Prev}They never get enough of me."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutOlympus01"
    }
    {
      Id = "MelinoeField_0234"
      InheritFrom = "BaseNarrative"
      DisplayName = "But {#Emph}you've {#Prev}had enough of {#Emph}them. {#Prev}Then... what are you doing here?"
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutOlympus01"
    }
    {
      Id = "Heracles_0012"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, my work history can demonstrate I never get enough of {#Emph}them{#Prev}, either. I take a job, I do it."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutOlympus01"
    }
    {
      Id = "Heracles_0241"
      InheritFrom = "BaseNarrative"
      DisplayName = "Welcome to your ancestral mountain, sister. Everything you dreamed of? I once yearned to be here, too. I got over it."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutOlympus02"
    }
    {
      Id = "MelinoeField_3767"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yet you're still defending this place. You speak as though you've lost your purpose, but I've seen you fight."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutOlympus02"
    }
    {
      Id = "Heracles_0242"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Purpose. {#Prev}The gods asked the world of me before I could join them here, only to have to defend their honor some more. You'll find your {#Emph}own {#Prev}purpose, soon enough."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutOlympus02"
    }
    {
      Id = "Heracles_0013"
      InheritFrom = "BaseNarrative"
      DisplayName = "...You have her blessing, then. Just like that, she gave you her strength. Her approval..."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutHera01"
    }
    {
      Id = "MelinoeField_0235"
      InheritFrom = "BaseNarrative"
      DisplayName = "You mean Hera? Of course she did; we're all on the same side. More than that, we're family."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutHera01"
    }
    {
      Id = "Heracles_0014"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Family. {#Prev}It figures that her grace the Queen presides over the entire concept. Marriage, birthing, and the like. Curses, in a charitable form."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutHera01"
    }
    {
      Id = "Heracles_0253"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you're a daughter of Hades for true, that makes us cousins, doesn't it? Although knowing my father, you must have a lot of those..."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutFamily01"
    }
    {
      Id = "MelinoeField_3989"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've met quite a few recently among the Olympians themselves. But I grew up mostly in solitude."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutFamily01"
    }
    {
      Id = "Heracles_0254"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thank the Fates for that. Fewer relatives means fewer obligations... fewer wars to be recruited into through no doing of your own, other than being born..."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutFamily01"
    }
    {
      Id = "Heracles_0284"
      InheritFrom = "BaseNarrative"
      DisplayName = "Everywhere I go, the dead know me; it's irksome. Used to be able to show up to a slaughter without drawing attention."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutFame01"
    }
    {
      Id = "MelinoeField_3997"
      InheritFrom = "BaseNarrative"
      DisplayName = "The consequence of notoriety. The Shades where I'm from all think the world of you! We may or may not even have a wall-scroll depicting your adventures."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutFame01"
    }
    {
      Id = "Heracles_0285"
      InheritFrom = "BaseNarrative"
      DisplayName = "They don't know anything about me, only the falsehoods and half-truths. I don't need a cult of mindless followers."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutFame01"
    }
    {
      Id = "MelinoeField_3993"
      InheritFrom = "BaseNarrative"
      DisplayName = "You ever see Lady Medea around here? Long dark hair and attire. She could probably help thin the crowd. No denying we're outnumbered."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutMedea01"
    }
    {
      Id = "Heracles_0275"
      InheritFrom = "BaseNarrative"
      DisplayName = "Already owe her for a time I wasn't... at my best. Won't be asking further favors from a witch. You take more than you give."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutMedea01"
    }
    {
      Id = "MelinoeField_3994"
      InheritFrom = "BaseNarrative"
      DisplayName = "What did witches ever do to you? It sounds as though she helped you out, yet you still speak of her with such disdain."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutMedea01"
    }
    {
      Id = "Heracles_0276"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know what you're capable of. I respect the power of an erupting volcano, doesn't mean I want to be near one."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutMedea01"
    }
    {
      Id = "MelinoeField_4009"
      InheritFrom = "BaseNarrative"
      DisplayName = "In all your travels back and forth from Mount Olympus, have you ever seen a young man with wings soaring over the waters, dropping explosives to disrupt the Titan's fleets?"
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutIcarus01"
    }
    {
      Id = "Heracles_0261"
      InheritFrom = "BaseNarrative"
      DisplayName = "The son of the artificer Daedalus. Those are not real wings, and he's a Shade now. He and his father both. What of him?"
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutIcarus01"
    }
    {
      Id = "MelinoeField_4010"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, it's just that... he's quite an admirer of yours, apparently. He'd give anything to meet you at some point. I thought perhaps I could facilitate an introduction."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutIcarus01"
    }
    {
      Id = "Heracles_0262"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not interested in admirers. Especially ones whose drowned corpses I had to bury. He's better off with the idea of me."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutIcarus01"
    }
    {
      Id = "MelinoeField_4011"
      InheritFrom = "BaseNarrative"
      DisplayName = "Icarus, the son of Daedalus we spoke of, he was very moved to learn you may have helped administer his final rites. He said to tell you cheers... I think he'd want to say much more."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutIcarus02"
    }
    {
      Id = "Heracles_0263"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Urgh. {#Prev}Would you just leave me be with all his sentiment."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutIcarus02"
    }
    {
      Id = "Heracles_0352"
      InheritFrom = "BaseNarrative"
      DisplayName = "Word is the Fates themselves are gone. Too bad. I always wanted that job for myself. Not that they can be killed."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutFates01"
    }
    {
      Id = "MelinoeField_3771"
      InheritFrom = "BaseNarrative"
      DisplayName = "You always wanted to kill the Three Fates... for deciding you'd become a great hero of exceeding strength whose achievements would inspire countless others?"
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutFates01"
    }
    {
      Id = "Heracles_0353"
      InheritFrom = "BaseNarrative"
      DisplayName = "Certainly if not for them I wouldn't be here. Well now they know what it's like... getting strung about with no say in the matter. The Fates be damned! Justice is all we need."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutFates01"
    }
    {
      Id = "Heracles_0015"
      InheritFrom = "BaseNarrative"
      DisplayName = "You made it out before. Cyclops must have caught your scent, though. He's strong, that one."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutPolyphemus01"
    }
    {
      Id = "MelinoeField_0236"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's a ringing endorsement. Though {#Emph}you {#Prev}must be stronger still! Ever considered putting him to the test? Could save me a lot of trouble."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutPolyphemus01"
    }
    {
      Id = "Heracles_0016"
      InheritFrom = "BaseNarrative"
      DisplayName = "He's not my type. Besides, he's a spawn of the gods, just like you and me. Wouldn't be proper if we were all fighting all the time, now would it?"
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutPolyphemus01"
    }
    {
      Id = "Heracles_0017"
      InheritFrom = "BaseNarrative"
      DisplayName = "Our fathers sure made a mess of things for us, didn't they, sister. Born to the mightiest of gods, yet living like outcasts... like bloody animals."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutFathers01"
    }
    {
      Id = "MelinoeField_0237"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's Chronos that made a mess of things. If he'd have just stayed dead, we'd be at peace. And together with our fathers, no doubt."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutFathers01"
    }
    {
      Id = "Heracles_0018"
      InheritFrom = "BaseNarrative"
      DisplayName = "Have you {#Emph}met {#Prev}our fathers? Sure, we're in the midst of an interminable war, but at least we're far away from {#Emph}them."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutFathers01"
    }
    {
      Id = "MelinoeField_0241"
      InheritFrom = "BaseNarrative"
      DisplayName = "You seem to know the Boatman pretty well. Worked together before?"
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutCharon01"
    }
    {
      Id = "Heracles_0184"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've had occasion to visit your realm in the past. The Boatman is my supplier. And evidently yours as well... buying up all the merchandise."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutCharon01"
    }
    {
      Id = "MelinoeField_0485"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I've not exactly been discreet..."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutCharon01"
    }
    {
      Id = "Heracles_0271"
      InheritFrom = "BaseNarrative"
      DisplayName = "Friendly word of advice: beware a large and not-entirely-dead boar snuffing about in the Ephyra alleyways. It's come for me."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutBoar01"
    }
    {
      Id = "MelinoeField_3992"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're being hunted by a boar, not the other way around? Did I hear that correctly?"
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutBoar01"
    }
    {
      Id = "Heracles_0272"
      InheritFrom = "BaseNarrative"
      DisplayName = "We... had our troubles in the past while it was more... alive. This is what I get for not finishing the job when I had the chance."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutBoar01"
    }
    {
      Id = "MelinoeField_3768"
      InheritFrom = "BaseNarrative"
      DisplayName = "Have you had any run-ins with the Titan Prometheus while on Olympus recently? He seems to be the one leading the assault forces besieging your family's home."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutPrometheus01"
    }
    {
      Id = "Heracles_0257"
      InheritFrom = "BaseNarrative"
      DisplayName = "Is he now? That's rich. Wasn't he supposed to be tied up on some mountain someplace else, getting picked apart?"
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutPrometheus01"
    }
    {
      Id = "MelinoeField_3769"
      InheritFrom = "BaseNarrative"
      DisplayName = "How do you not know he's free? You should be hunting {#Emph}him{#Prev}, not this fodder. Who's setting your objectives?"
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutPrometheus01"
    }
    {
      Id = "Heracles_0258"
      InheritFrom = "BaseNarrative"
      DisplayName = "My orders come directly from the King and Queen. If you've any concerns with how I'm carrying out my work, just go complain to them."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutPrometheus01"
    }
    {
      Id = "Heracles_0259"
      InheritFrom = "BaseNarrative"
      DisplayName = "You make it to the mountaintop as yet? In case you haven't, nothing good awaits you there. Or so I hear."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutTyphon01"
    }
    {
      Id = "MelinoeField_3770"
      InheritFrom = "BaseNarrative"
      DisplayName = "What, you mean Typhon? I'm surprised the Olympians don't have you helping out with {#Emph}him{#Prev}, instead of bashing a bunch of weaklings far from where the real danger is."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutTyphon01"
    }
    {
      Id = "Heracles_0260"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Olympians won't abide some half-god stealing their glory. I get the drudgery, not the important work. Thank the Fates that {#Emph}you {#Prev}get some of each."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutTyphon01"
    }
    {
      Id = "Heracles_0634"
      InheritFrom = "BaseNarrative"
      DisplayName = "What is it like... being up against that monster at the summit. I've not faced something of that size. Not yet at least."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutTyphon02"
    }
    {
      Id = "MelinoeField_4021"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've not faced anything of Typhon's size either. His enormity is to his disadvantage in some ways, but facing {#Emph}him{#Prev}, a torrential storm, and his broodlings all at once can be a lot."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutTyphon02"
    }
    {
      Id = "Heracles_0635"
      InheritFrom = "BaseNarrative"
      DisplayName = "To think the multi-headed Hydra I once slew was merely one of his offspring. But there shall be worse monsters to fight in ages hence..."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutTyphon02"
    }
    {
      Id = "Heracles_0235"
      InheritFrom = "BaseNarrative"
      DisplayName = "There's no more work here to be done... but it never ends. No hard feelings, by the way, about before."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutAltFight01"
    }
    {
      Id = "MelinoeField_3763"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, none at all. I always wondered what it'd feel like to get struck full-on by the force of your club, and now I don't."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutAltFight01"
    }
    {
      Id = "Heracles_0236"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nor do I like leaving any room for doubt. And if you need a reminder about my club, you know where to locate me."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutAltFight01"
    }
    {
      Id = "Heracles_0295"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're not what I thought. Kept your mouth shut about me. Even somehow overcame Prometheus after I butted in. Why and how?"
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutAltFightWin01"
    }
    {
      Id = "MelinoeField_3777"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have my reasons and my ways. Why should I be forthcoming about them? You've not exactly been eager to open up."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutAltFightWin01"
    }
    {
      Id = "Heracles_0296"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thought if I asked {#Emph}nicely{#Prev}, but that doesn't work on me either. Well, suit yourself. Not like I can drag it out of you."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutAltFightWin01"
    }
    {
      Id = "Heracles_0237"
      InheritFrom = "BaseNarrative"
      DisplayName = "Last we had a skirmish such as this, after the dust settled, you were nowhere to be found. Fled, like a thief in the night."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutReturning01"
    }
    {
      Id = "MelinoeField_3764"
      InheritFrom = "BaseNarrative"
      DisplayName = "I had to make an early exit. Figured you would have no trouble resolving the matter, seeing as you work alone."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutReturning01"
    }
    {
      Id = "Heracles_0238"
      InheritFrom = "BaseNarrative"
      DisplayName = "That I do. But I don't like combatants disappearing on me. Stay where I can see you, or stay out of the way."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutReturning01"
    }
    {
      Id = "Heracles_0019"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your blood runs red. You're not entirely a goddess. We truly get the best of both worlds."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutBlood01"
    }
    {
      Id = "MelinoeField_0238"
      InheritFrom = "BaseNarrative"
      DisplayName = "You were born to a mortal mother, weren't you? My mother's half-mortal. Death itself is in our blood. But you're different..."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutBlood01"
    }
    {
      Id = "Heracles_0020"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Different. {#Prev}Neither god, nor mortal, nor Shade. It's as you say; death itself is in my blood. All mortals are born to die. I was born also to kill."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutBlood01"
    }
    {
      Id = "Heracles_0255"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, if it isn't my old Lion Fang. I had multiples to spare, and you looked like you could use some of its savagery yourself."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutKeepsake01"
    }
    {
      Id = "MelinoeField_3990"
      InheritFrom = "BaseNarrative"
      DisplayName = "Its strength is useful certainly, though why give it away? The stronger I am, the more I can encroach on your glory."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutKeepsake01"
    }
    {
      Id = "Heracles_0256"
      InheritFrom = "BaseNarrative"
      DisplayName = "Simple, sister: I don't want it anymore. Neither the Fang nor the glory. Take my work for all I care; there's always more."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutKeepsake01"
    }
    {
      Id = "Heracles_0326"
      InheritFrom = "BaseNarrative"
      DisplayName = "Those magick tricks... you're borrowing that power. How can you trust it when strength belongs to you alone?"
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutMagick01"
    }
    {
      Id = "MelinoeField_3998"
      InheritFrom = "BaseNarrative"
      DisplayName = "Magick and raw strength are not in opposition; both ultimately come from within, they're just trained differently."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutMagick01"
    }
    {
      Id = "Heracles_0327"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't think so, sister. You're drawing from the moon, and the earth, and... who knows what else. But in this world, you can't rely on anybody but yourself."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutMagick01"
    }
    {
      Id = "Heracles_0243"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've more aptitude for weaponry than one might expect. I once sought to master every armament under the sun, but in the end... I settled for the simple club."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutWeapons01"
    }
    {
      Id = "MelinoeField_3985"
      InheritFrom = "BaseNarrative"
      DisplayName = "I am bearer of the Arms of Night in all their various Aspects; I'd never settle for just one. Do you not fear you've grown complacent?"
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutWeapons01"
    }
    {
      Id = "Heracles_0244"
      InheritFrom = "BaseNarrative"
      DisplayName = "No. Tread this path long enough, you'll find that any weapon can do the job. At that point, there's no real choice. Though I still carry all these other arms just to put on a show."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutWeapons01"
    }
    {
      Id = "Heracles_0282"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd given you no thought at all while you were gone. Otherwise I would have figured you had given up."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutTimePassing01"
    }
    {
      Id = "MelinoeField_3995"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't know what I'm supposed to say to that except I hadn't given you much thought lately either. Is there anyone you {#Emph}do {#Prev}regularly think about?"
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutTimePassing01"
    }
    {
      Id = "Heracles_0283"
      InheritFrom = "BaseNarrative"
      DisplayName = "I think mainly of the bodies I have crushed beneath my club and feet. You're welcome to join them, at any point."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutTimePassing01"
    }
    {
      Id = "MelinoeField_3996"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No thank you, that's all right."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutTimePassing01"
    }
    {
      Id = "Heracles_0278"
      InheritFrom = "BaseNarrative"
      DisplayName = "They said the war was finally drawing to a close. Somebody must have forgotten to notify those we slaughtered."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutTrueEnding01"
    }
    {
      Id = "MelinoeField_4005"
      InheritFrom = "BaseNarrative"
      DisplayName = "We need them here for the time being anyhow. Has Olympus informed you of the nature of the next phase of our plan?"
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutTrueEnding01"
    }
    {
      Id = "Heracles_0279"
      InheritFrom = "BaseNarrative"
      DisplayName = "I got the gist: We fight on. Nothing changes. Never has before, so... why would it now?"
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutTrueEnding01"
    }
    {
      Id = "MelinoeField_4006"
      InheritFrom = "BaseNarrative"
      DisplayName = "What are you talking about? A lot's changed! Olympus is no longer in danger. The House of Hades is restored."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutTrueEnding01"
    }
    {
      Id = "Heracles_0280"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The way it always was."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutTrueEnding01"
    }
    {
      Id = "MelinoeField_4022"
      InheritFrom = "BaseNarrative"
      DisplayName = "What will you do when all of this is over, sir? Or rather, what would you desire to do?"
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutTrueEnding02"
    }
    {
      Id = "Heracles_0636"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Why ask? I tend not to give desire too much thought, beyond any immediate and bestial cravings I may have."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutTrueEnding02"
    }
    {
      Id = "MelinoeField_4023"
      InheritFrom = "BaseNarrative"
      DisplayName = "I would appreciate any perspective, that's all. All my life I had an obligation to my family to fulfill. I'm not certain what to do with myself now that I have..."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutTrueEnding02"
    }
    {
      Id = "Heracles_0637"
      InheritFrom = "BaseNarrative"
      DisplayName = "I am the last individual whose perspective you should heed, sister. Chase your dreams if you still have any. Now scoot."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutTrueEnding02"
    }
    {
      Id = "MelinoeField_4007"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Titan Prometheus seems rather pleased of late. Why do you suppose that is?"
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutEpilogue01"
    }
    {
      Id = "Heracles_0286"
      InheritFrom = "BaseNarrative"
      DisplayName = "How should I know, and why should it matter? Seeing as we don't discuss him here, or anywhere."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutEpilogue01"
    }
    {
      Id = "MelinoeField_4008"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then let's discuss you. Have you gotten what you sought? With the Fates declaring that an age of mortals is to come."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutEpilogue01"
    }
    {
      Id = "Heracles_0287"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm a mere half-god, as you may recall. I never get what I want. But when finally comes a time for change, I'll welcome it. May that next age no longer need for gods or men like me."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutEpilogue01"
    }
    {
      Id = "Heracles_0354"
      InheritFrom = "BaseNarrative"
      DisplayName = "Having given it all some further thought, I must admit I undersold what you achieved, sister. Your task was difficult."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutEpilogue02"
    }
    {
      Id = "MelinoeField_4019"
      InheritFrom = "BaseNarrative"
      DisplayName = "It could have been worse. I had the strength of mighty Heracles on my side, at least for the most part. But thank you; that means a lot coming from you."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutEpilogue02"
    }
    {
      Id = "Heracles_0355"
      InheritFrom = "BaseNarrative"
      DisplayName = "No need. For now, it seems we get to ply our trade without the pressure to accomplish the impossible. I'll take it."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutEpilogue02"
    }
    {
      Id = "Heracles_0330"
      InheritFrom = "BaseNarrative"
      DisplayName = "You talk too much, you know that, witch? Dispense with the pleasantries, and we could be killing even more."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutSayingLittle01"
    }
    {
      Id = "MelinoeField_4018"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm not certain which pleasantries you mean, but if you'd like to speak even less, that's certainly your prerogative."
      Speaker = "Melinoe"
      Event = "HeraclesFieldAboutSayingLittle01"
    }
    {
      Id = "Heracles_0331"
      InheritFrom = "BaseNarrative"
      DisplayName = "Speaking never was my specialty. And as you may have surmised, I'm more the sort to focus on my strengths."
      Speaker = "Heracles"
      Event = "HeraclesFieldAboutSayingLittle01"
    }
    {
      Id = "Heracles_0033"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you're starved for conversation, you'll have better fortune with the Boatman there."
      Speaker = "Heracles"
      Event = "HeraclesMiscChat01"
    }
    {
      Id = "Heracles_0036"
      InheritFrom = "BaseNarrative"
      DisplayName = "You never saw me, I never saw you. Scoot."
      Speaker = "Heracles"
      Event = "HeraclesMiscChat04"
    }
    {
      Id = "Heracles_0037"
      InheritFrom = "BaseNarrative"
      DisplayName = "Save it for somebody who cares, sister."
      Speaker = "Heracles"
      Event = "HeraclesMiscChat05"
    }
    {
      Id = "Heracles_0038"
      InheritFrom = "BaseNarrative"
      DisplayName = "Whatever you're about to say to me, don't."
      Speaker = "Heracles"
      Event = "HeraclesMiscChat06"
    }
    {
      Id = "Heracles_0039"
      InheritFrom = "BaseNarrative"
      DisplayName = "I look like I want to have ourselves a chat?"
      Speaker = "Heracles"
      Event = "HeraclesMiscChat07"
    }
    {
      Id = "Heracles_0358"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Urgh. {#Prev}You just made me lose count of all my blasted coin."
      Speaker = "Heracles"
      Event = "HeraclesMiscChat08"
    }
    {
      Id = "MelinoeField_0239"
      InheritFrom = "BaseNarrative"
      DisplayName = "Great Son of Zeus, I offer you this gift of Nectar, that it may quench your thirst as you labor for the gods. They must be grateful for your might."
      Speaker = "Melinoe"
      Event = "HeraclesGift01"
    }
    {
      Id = "Heracles_0021"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Heh. {#Prev}Saves me having to find another bottle for when next I have to prove my fealty. Here, something for your trouble."
      Speaker = "Heracles"
      Event = "HeraclesGift01"
    }
    {
      Id = "Heracles_0022"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sure you don't want to give me only half the bottle there? Seeing as I'm merely half a god... I got their strength but seldom get their luxury."
      Speaker = "Heracles"
      Event = "HeraclesGift02"
    }
    {
      Id = "MelinoeField_0240"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nothing's gained from luxury in excess, anyway. But there are times a little doesn't hurt! May this soothe your spirit when the occasion arises."
      Speaker = "Melinoe"
      Event = "HeraclesGift02"
    }
    {
      Id = "Heracles_0288"
      InheritFrom = "BaseNarrative"
      DisplayName = "You truly take me for a fool, believing I would drink from {#Emph}this? {#Prev}You could have ensorcelled the contents in any number of ways, to drive me to madness, or worse..."
      Speaker = "Heracles"
      Event = "HeraclesGift03"
    }
    {
      Id = "MelinoeField_3772"
      InheritFrom = "BaseNarrative"
      DisplayName = "I swear to you upon my father's name that I've done no such thing. And it would have obviously spoiled if I had. Do you want to see me drink it first?"
      Speaker = "Melinoe"
      Event = "HeraclesGift03"
    }
    {
      Id = "Heracles_0289"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No. I can dispose of it myself."
      Speaker = "Heracles"
      Event = "HeraclesGift03"
    }
    {
      Id = "Heracles_0290"
      InheritFrom = "BaseNarrative"
      DisplayName = "My favor, in exchange for {#Emph}drink? {#Prev}No. You waste your resources and time; {#Emph}my {#Prev}time as well. You'll get a share of spoils if you earn your kills, but nothing more. "
      Speaker = "Heracles"
      Event = "HeraclesGift04"
    }
    {
      Id = "MelinoeField_3773"
      InheritFrom = "BaseNarrative"
      DisplayName = "I understand. Nevertheless, we're both working for the same family, and I have seen firsthand the efforts you're taking to drive back their enemies. And I'm grateful."
      Speaker = "Melinoe"
      Event = "HeraclesGift04"
    }
    {
      Id = "Heracles_0170"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}<Scoff>"
      Speaker = "Heracles"
      Event = "HeraclesGift04"
    }
    {
      Id = "Heracles_0291"
      InheritFrom = "BaseNarrative"
      DisplayName = "They never give this stuff to me themselves, the mountain gods. Developed a distaste for it as a result, especially after a certain... contest with the god of wine. But that was long ago."
      Speaker = "Heracles"
      Event = "HeraclesGift05"
    }
    {
      Id = "MelinoeField_3774"
      InheritFrom = "BaseNarrative"
      DisplayName = "You tried to out-drink Lord Dionysus? Even with all your fortitude, that sounds like a very dangerous undertaking from what I understand."
      Speaker = "Melinoe"
      Event = "HeraclesGift05"
    }
    {
      Id = "Heracles_0292"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It was."
      Speaker = "Heracles"
      Event = "HeraclesGift05"
    }
    {
      Id = "MelinoeField_3775"
      InheritFrom = "BaseNarrative"
      DisplayName = "You say the gods never shared Nectar with you; well, I'm sharing some now. Perhaps you can regain a taste for it."
      Speaker = "Melinoe"
      Event = "HeraclesGift06"
    }
    {
      Id = "Heracles_0293"
      InheritFrom = "BaseNarrative"
      DisplayName = "No more of this, witch. I told you I don't care for it, and presently I have no plans to go make any offerings myself. My tolerance for {#Emph}you {#Prev}likewise nears its limit."
      Speaker = "Heracles"
      Event = "HeraclesGift06"
    }
    {
      Id = "MelinoeField_3776"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your tolerance is enough, sir. I see how hard you work, expecting nothing in return. For all you've given to Olympus, may you never give your soul."
      Speaker = "Melinoe"
      Event = "HeraclesGift06"
    }
    {
      Id = "Heracles_0294"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...That would require me to have one still."
      Speaker = "Heracles"
      Event = "HeraclesGift06"
    }
    {
      Id = "MelinoeField_3778"
      InheritFrom = "BaseNarrative"
      DisplayName = "You said I wasn't what you thought; neither are you what I expected, sir. I'd heard tales of your exploits, and truly never seen so fierce a fighter. But I know there's more to you. Here, then! For one of your divinity, a divine gift."
      Speaker = "Melinoe"
      Event = "HeraclesGift07"
    }
    {
      Id = "Heracles_0297"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ambrosia... you would take me for another god. I am half-man; such stuff is not for me, and you sully its purpose merely in the offering. What do you want from me?"
      Speaker = "Heracles"
      Event = "HeraclesGift07"
    }
    {
      Id = "MelinoeField_3779"
      InheritFrom = "BaseNarrative"
      DisplayName = "I want you to accept that there are gods and goddesses who hold you in esteem. If falling short of perfection means falling short of godhood, then none of us are divine."
      Speaker = "Melinoe"
      Event = "HeraclesGift07"
    }
    {
      Id = "Heracles_0298"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Now you're on to something, sister. Well, if and when the rest of the family gets around to accepting your terms, let's all share this bottle. I'll just hang onto it for now."
      Speaker = "Heracles"
      Event = "HeraclesGift07"
    }
    {
      Id = "MelinoeField_0642"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No trouble at all, thank you."
      Speaker = "Melinoe"
      Event = "NPC_Heracles_01.GiftGivenVoiceLines"
    }
    {
      Id = "Heracles_0043"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0044"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You again."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0045"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're just in time..."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0046"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're just in time."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0048"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Our labors never cease."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0049"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Our paths keep crossing huh."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0050"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Back for more glory, huh?"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0051"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The witch returns..."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0052"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Where'd you come from?"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0053"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just you, huh?"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0056"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ah."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0430"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Could have been you."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0433"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Witch."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0436"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That worked."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0437"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No you don't."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0447"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Keep your distance."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0438"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Rough waters."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0439"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Call it a mutiny."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0440"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Another stowaway."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0441"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Ahoy."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0442"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A fellow sailor."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0443"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Going my way?"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0446"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Took you for a Harpy."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0444"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Cold out."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0445"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Welcome."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0448"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Blasted snow."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0449"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're the backup?"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0434"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Been a while."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0435"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Still around?"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0431"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Surprise."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0432"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Evening."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0047"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Again we meet, sister."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0054"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hullo...!"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0055"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hullo."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "MelinoeField_1963"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Welcome aboard...!"
      Speaker = "Melinoe"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "MelinoeField_1964"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Welcome aboard...?"
      Speaker = "Melinoe"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "MelinoeField_1965"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How does he do that?"
      Speaker = "Melinoe"
      Event = "NPC_Heracles_01.EntranceVoiceLines"
    }
    {
      Id = "Heracles_0057"
      InheritFrom = "BaseSubtitle"
      DisplayName = "They come."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0058"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Prepare."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0059"
      InheritFrom = "BaseSubtitle"
      DisplayName = "There."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0060"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Stay out of my path."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0061"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Stand clear!"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0062"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Stand clear."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0363"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Time to get to work..."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0450"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Now, then..."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0451"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The more the better."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0452"
      InheritFrom = "BaseSubtitle"
      DisplayName = "They're mine."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0454"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come on, then."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0455"
      InheritFrom = "BaseSubtitle"
      DisplayName = "To the slaughter."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0456"
      InheritFrom = "BaseSubtitle"
      DisplayName = "They come."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0457"
      InheritFrom = "BaseSubtitle"
      DisplayName = "More work!"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0458"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Ought to be quick."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0459"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come, friends."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0460"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Earn your keep if you like."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0462"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What have we here..."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0453"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Don't get underfoot."
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0461"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Split the proceeds?"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0185"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It begins!!"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0186"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Face me!!"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0187"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come on!!"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0188"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come on!!"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0189"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Stand and fight!!"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0190"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll tear you limb from limb!!"
      Speaker = "Heracles"
      Event = "NPC_Heracles_01.EncounterStartVoiceLines"
    }
    {
      Id = "Heracles_0191"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Olympus!!"
