      Event = "ObstacleData[742272].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_4037"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}...Moonlight guide us home tonight..."
      Speaker = "Melinoe"
      Event = "ObstacleData[742272].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_4038"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}...In shadow all are one..."
      Speaker = "Melinoe"
      Event = "ObstacleData[742272].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_4026"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Artemis..."
      Speaker = "Melinoe"
      Event = "ObstacleData[742272].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_4027"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hey..."
      Speaker = "Melinoe"
      Event = "ObstacleData[742272].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_5178"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The song from our flight..."
      Speaker = "Melinoe"
      Event = "ObstacleData[742272].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_2938_B"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Father..."
      Speaker = "Melinoe"
      Event = "ObstacleData[742624].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_5167"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Our gift from Olympus looks good by Father's fountain..."
      Speaker = "Melinoe"
      Event = "ObstacleData[800527].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_1727"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Where are you, Headmistress..."
      Speaker = "Melinoe"
      Event = "ObstacleData[567567].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_5723"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Dora's gone... just needs a little time."
      Speaker = "Melinoe"
      Event = "ObstacleData[800388].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_5681"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Still asleep..."
      Speaker = "Melinoe"
      Event = "ObstacleData[800742].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_5163"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Oh{#Prev}, where's Icarus...?"
      Speaker = "Melinoe"
      Event = "ObstacleData[743162].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_3003"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hail, Spirit Mixer."
      Speaker = "Melinoe"
      Event = "ObstacleData[590506].InteractVoiceLines"
    }
    {
      Id = "Melinoe_3004"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Cheers, Mixer."
      Speaker = "Melinoe"
      Event = "ObstacleData[590506].InteractVoiceLines"
    }
    {
      Id = "Melinoe_3005"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Good evening, Mixer."
      Speaker = "Melinoe"
      Event = "ObstacleData[590506].InteractVoiceLines"
    }
    {
      Id = "Melinoe_5336"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Salutations to the Unseen!"
      Speaker = "Melinoe"
      Event = "ObstacleData[590506].InteractVoiceLines"
    }
    {
      Id = "Melinoe_5337"
      InheritFrom = "BaseSubtitle"
      DisplayName = "To the restoration of the Underworld!"
      Speaker = "Melinoe"
      Event = "ObstacleData[590506].InteractVoiceLines"
    }
    {
      Id = "Melinoe_5339"
      InheritFrom = "BaseSubtitle"
      DisplayName = "By my father's name!"
      Speaker = "Melinoe"
      Event = "ObstacleData[590506].InteractVoiceLines"
    }
    {
      Id = "Melinoe_5338"
      InheritFrom = "BaseSubtitle"
      DisplayName = "May Night's will be done!"
      Speaker = "Melinoe"
      Event = "ObstacleData[590506].InteractVoiceLines"
    }
    {
      Id = "Melinoe_3683"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Still fast asleep... even here?"
      Speaker = "Melinoe"
      Event = "ObstacleData[738827].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_4640"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not moved at all. Let's see if this works..."
      Speaker = "Melinoe"
      Event = "ObstacleData[738827].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Hypnos_0021"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}<Sigh>"
      Speaker = "Hypnos"
      Event = "ObstacleData[738827].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_4709"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And there he is..."
      Speaker = "Melinoe"
      Event = "ObstacleData[738827].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Hypnos_0032"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Zzz... welcome tooo..."
      Speaker = "Hypnos"
      Event = "ObstacleData[738827].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_4644"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What are all these things...?"
      Speaker = "Melinoe"
      Event = "ObstacleData[799541].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_4713"
      InheritFrom = "BaseSubtitle"
      DisplayName = "At least he seems to be quite comfortable."
      Speaker = "Melinoe"
      Event = "ObstacleData[780928].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Hypnos_0035"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Zzz... wide away... away... zzz..."
      Speaker = "Hypnos"
      Event = "ObstacleData[780928].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Hypnos_0036"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}...mmmaking positive.... zzz..."
      Speaker = "Hypnos"
      Event = "ObstacleData[780928].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_4645"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Wait, there he is..."
      Speaker = "Melinoe"
      Event = "ObstacleData[780928].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_4646"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh no, he's still asleep..."
      Speaker = "Melinoe"
      Event = "ObstacleData[780928].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_3293"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Halfway to Night's Gift..."
      Speaker = "Melinoe"
      Event = "ThreadedEvents.VoiceLines"
    }
    {
      Id = "Melinoe_3294"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm part of the way there."
      Speaker = "Melinoe"
      Event = "ThreadedEvents.VoiceLines"
    }
    {
      Id = "Melinoe_3295"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Night's Gift awaits..."
      Speaker = "Melinoe"
      Event = "ThreadedEvents.VoiceLines"
    }
    {
      Id = "Melinoe_1610"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Mustn't forget my Altar back there..."
      Speaker = "Melinoe"
      Event = "ObstacleData[558210].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_2540"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Silver Pool reacted to my spell..."
      Speaker = "Melinoe"
      Event = "ObstacleData[558210].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_2407"
      InheritFrom = "BaseSubtitle"
      DisplayName = "There's the Grave Thirst aura by the Silver Pool..."
      Speaker = "Melinoe"
      Event = "ObstacleData[558210].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_5477"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Grave Thirst aura's even stronger now."
      Speaker = "Melinoe"
      Event = "ObstacleData[558210].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_4397"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Now for the Silver Pool."
      Speaker = "Melinoe"
      Event = "ObstacleData[558210].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_4398"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Should try the Silver Pool."
      Speaker = "Melinoe"
      Event = "ObstacleData[558210].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_4399"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Should try the Pool."
      Speaker = "Melinoe"
      Event = "ObstacleData[558210].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_4400"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Pool should have something for me..."
      Speaker = "Melinoe"
      Event = "ObstacleData[558210].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_4401"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Now for my waking-phrase..."
      Speaker = "Melinoe"
      Event = "ObstacleData[558210].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_4402"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Should try the waking-phrase..."
      Speaker = "Melinoe"
      Event = "ObstacleData[558210].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_0538"
      InheritFrom = "BaseSubtitle"
      DisplayName = "My Altar..."
      Speaker = "Melinoe"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_2716"
      InheritFrom = "BaseSubtitle"
      DisplayName = "My Altar's all charged up..."
      Speaker = "Melinoe"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_0563"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I can get through..."
      Speaker = "Melinoe"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0643"
      InheritFrom = "BaseSubtitle"
      DisplayName = "All hail our victorious Princess of the Underworld!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0493"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Get over here, young one, {#Emph}right {#Prev}now!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0042"
      InheritFrom = "BaseSubtitle"
      DisplayName = "May we converse?"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0405"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come forth, would ya?"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0406"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I've something to discuss."
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0514"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hey might I have a word?"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0230"
      InheritFrom = "BaseSubtitle"
      DisplayName = "See anything that wasn't here before, young one?"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0228_B"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Disciples, atten{#Emph}tion!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0594"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Heheheheh{#Prev}, all that was a mere jest. Carry on!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_4958"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Commander!"
      Speaker = "Melinoe"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0595"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, {#Emph}um, hey!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0588"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Oh, hohoho. Ah, hahaha!! {#Prev}My strength {#Emph}returns!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_4954"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Commander...?"
      Speaker = "Melinoe"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0318"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Wait, what, she {#Emph}did?! {#Prev}But, how in the — OK, she's here, shut {#Emph}up!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_3283"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Am I officially Night's Champion...?"
      Speaker = "Melinoe"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0313"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Huzzah! {#Prev}Another glorious victory, another well-earned Gift!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_3278"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Night's second Gift awaits..."
      Speaker = "Melinoe"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0308"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Your prize awaits, and glory is yours! A third of it anyway."
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0301"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The time to prove yourself has finally come!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0302"
      InheritFrom = "BaseSubtitle"
      DisplayName = "If you would honor me with a quick chat?"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0431"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You bear my trusty Tooth!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0432"
      InheritFrom = "BaseSubtitle"
      DisplayName = "May my Tooth bring you fortune and fame."
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0515"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...There's no way she could have — oh, {#Emph}hey!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0518"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I, for one, was {#Emph}certain {#Prev}she'd prevail!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0516"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Slayer of Titans returns!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0517"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Way to stick it to that Chronos guy!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0519"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The vanquisher of Typhon has arrived!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0520"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You really showed that Typhon huh?"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0521"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Huzzah {#Prev}for the savior of Olympus!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0522"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're tellin' me she beat Typhon {#Emph}again?"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0223"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I see we got some new faces today, fresh out of Erebus!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0224"
      InheritFrom = "BaseSubtitle"
      DisplayName = "To all of you just joining up, welcome!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0523"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Some of you made it from the surface {#Emph}eh?"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0524"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We got a Shade come all the way from Mount Olympus here!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0525"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You Shades are new around these parts so you answer to {#Emph}me!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0526"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A Shade come all the way from Tartarus is here with us!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0527"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...And that concludes our little orientation. Any questions, shoot!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0528"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...So basically, I'm gonna need you all to stand around, all right?"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0225"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Tablet of Peace showed you how to get here; but I shall show you the way."
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0292"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Our numbers grow, and thusly does our strength!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0293"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We bid you welcome to the vanguard of the Underworld!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0294"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Somebody fresh from Oceanus joins our ranks!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0295"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No use crying in the Mourning Fields when you can join us here!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0507"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hey everybody look who's back!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0508"
      InheritFrom = "BaseSubtitle"
      DisplayName = "All right act normal everyone, she's back!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0509"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}You {#Prev}there, get back in formation or {#Emph}else!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0510"
      InheritFrom = "BaseSubtitle"
      DisplayName = "So anybody got a tale to tell or what?"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0513"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I know the sound of that gait well!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0037"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...She's here, come on you slackers, straighten up!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0038"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Ah, there she is again at last."
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0039"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...and that concludes our lesson for today. At ease."
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0040"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...and another thing... {#Emph}um{#Prev}, stand up straight!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0041"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Everybody at attention!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0104"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...and what are we to do? Merely stand by, and let the Titan have his way?!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0105"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...but that, disciples, is a tale for another circumstance."
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0107"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We bid you welcome to our training grounds!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0108"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Another step on the path to perfection!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0165"
      InheritFrom = "BaseSubtitle"
      DisplayName = "She's here, now watch and learn!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0296"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Always she returns, as dusk gives way to night!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0297"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Atten{#Emph}tion! {#Prev}Got a Silver Sister on deck!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0228_C"
      InheritFrom = "BaseSubtitle"
      DisplayName = "She has {#Emph}returned!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0298"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hold, everybody, Silver Sister on deck!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0299"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Keep practicing, as though you still had lives that depended on it!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0005"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Ah, I know the sound of that gait. Come here where these old eyes can see ya."
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0511"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Behold Night's Champion everybody!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0512"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Done with that Silver Puddle over there?"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0024"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...and that, my disciples, is the true meaning of life. Remember it well!"
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0025"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...and then I say... h-hold up, somebody's here."
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_0071"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Commander."
      Speaker = "Melinoe"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_2919"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Commander Schelemeus, {#Emph}sir!"
      Speaker = "Melinoe"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0109"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Young one."
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0111"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Disciple."
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Skelly_0110"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Kiddo."
      Speaker = "Skelly"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_2770"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Frinos, you're here!"
      Speaker = "Melinoe"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_5478"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hi gang. Any of you interested in a new look?"
      Speaker = "Melinoe"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_3244"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Toula, you made it!"
      Speaker = "Melinoe"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_3591"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Raki, welcome!"
      Speaker = "Melinoe"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_3775"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hecuba returns!"
      Speaker = "Melinoe"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_3960"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Gale, welcome back!"
      Speaker = "Melinoe"
      Event = "Hub_PreRun.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Storyteller_0008"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The Crossroads training grounds are watched over by fearless seafarer, Schelemeus, famed in death as he was famed in life."
      Speaker = "Storyteller"
      Event = "InspectPreRun01"
    }
    {
      Id = "Melinoe_0033"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We cannot fail with such a genius on our side."
      Speaker = "Melinoe"
      Event = "InspectPreRun01"
    }
    {
      Id = "Skelly_0011"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Nope!"
      Speaker = "Skelly"
      Event = "InspectPreRun01"
    }
    {
      Id = "Storyteller_0013"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Within the haunted Crossroads reside Shades and Spirits of all sorts, some resembling their mortal selves, and others, rendered down to purest essences."
      Speaker = "Storyteller"
      Event = "InspectHomerReveal02"
    }
    {
      Id = "Melinoe_1132"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You all right, Homer?"
      Speaker = "Melinoe"
      Event = "InspectHomerReveal02"
    }
    {
      Id = "Storyteller_0033"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Nay..."
      Speaker = "Storyteller"
      Event = "InspectHomerReveal02"
    }
    {
      Id = "Storyteller_0355"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The rank and file of the Crossroads swell with Shades who once were lost but now have joined in our Princess Melinoë's most-righteous cause."
      Speaker = "Storyteller"
      Event = "InspectRecruitedShades01"
    }
    {
      Id = "Melinoe_4085"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Welcome to the ranks of the Unseen!"
      Speaker = "Melinoe"
      Event = "InspectRecruitedShades01"
    }
    {
      Id = "Storyteller_0063"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}So ancient is the Pitch-Black Stone, it predates Time itself. Its surface ever seems to drain what light and color dare linger nearby."
      Speaker = "Storyteller"
      Event = "InspectBountyBoard01"
    }
    {
      Id = "Melinoe_1117"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I can see beneath that surface now..."
      Speaker = "Melinoe"
      Event = "InspectBountyBoard01"
    }
    {
      Id = "Storyteller_0233"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}A secret monument to Night, etched with her will and testament, looms tall within the training grounds, revealing its nature only to the worthy."
      Speaker = "Storyteller"
      Event = "InspectPact01"
    }
    {
      Id = "Melinoe_2960"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm in the Inner Circle now..."
      Speaker = "Melinoe"
      Event = "InspectPact01"
    }
    {
      Id = "Storyteller_0356"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}At the threshold to the world beyond the Crossroads, the Altar of Ashes thrums with ancient power, boundless as that of the gods and heroes depicted in the myriad Arcana."
      Speaker = "Storyteller"
      Event = "InspectUpgradedAltar01"
    }
    {
      Id = "Melinoe_4086"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A power within us all..."
      Speaker = "Melinoe"
      Event = "InspectUpgradedAltar01"
    }
    {
      Id = "Storyteller_0351"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}A deathlike pallor emanates now from the Arms of Night, or one of them at least; their Fate-wrought thirst to separate immortal souls laid bare."
      Speaker = "Storyteller"
      Event = "InspectGraveThirst01"
    }
    {
      Id = "Melinoe_4081"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}The Gathering of Ancient Bones..."
      Speaker = "Melinoe"
      Event = "InspectGraveThirst01"
    }
    {
      Id = "Storyteller_0352"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Within the Silver Pool now swim dark apparitions of the Arms of Night, in forms unlike the Princess of the Underworld has previously seen."
      Speaker = "Storyteller"
      Event = "InspectAspectsUnlocked01"
    }
    {
      Id = "Melinoe_4082"
      InheritFrom = "BaseSubtitle"
      DisplayName = "So many different forms..."
      Speaker = "Melinoe"
      Event = "InspectAspectsUnlocked01"
    }
    {
      Id = "Storyteller_0357"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Each of the ancient Fate-wrought Arms of Night is now rejoined under the Princess of the Underworld's care, all equally prepared to rid the realm of any of its foes."
      Speaker = "Storyteller"
      Event = "InspectAllWeaponsUnlocked01"
    }
    {
      Id = "Melinoe_4087"
      InheritFrom = "BaseSubtitle"
      DisplayName = "As am I."
      Speaker = "Melinoe"
      Event = "InspectAllWeaponsUnlocked01"
    }
    {
      Id = "Storyteller_0349"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The Princess of the Underworld now holds the key to the once-warded gateway leading all the way up to the surface of this world; but how is she to fare in that forbidden realm?"
      Speaker = "Storyteller"
      Event = "InspectAltRunDoor01"
    }
    {
      Id = "Melinoe_4079"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We'll find out!"
      Speaker = "Melinoe"
      Event = "InspectAltRunDoor01"
    }
    {
      Id = "Storyteller_0350"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}A growing pack of ever-faithful Animal Familiars now stand ready to follow the Princess of the Dead into the depths, or wheresoever her fateful task shall take her next."
      Speaker = "Storyteller"
      Event = "InspectPreRunFamiliars01"
    }
    {
      Id = "Melinoe_4080"
      InheritFrom = "BaseSubtitle"
      DisplayName = "My little protectors!"
      Speaker = "Melinoe"
      Event = "InspectPreRunFamiliars01"
    }
    {
      Id = "Storyteller_0347"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Above, a full Moon flares, bestowing all her grace and power from beyond an earthly canopy of trees and soaring precipices which provide a pristine vantage point."
      Speaker = "Storyteller"
      Event = "InspectPreRunFullMoon01"
    }
    {
      Id = "Melinoe_4077"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The crossroads between realms..."
      Speaker = "Melinoe"
      Event = "InspectPreRunFullMoon01"
    }
    {
      Id = "Storyteller_0348"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The Moon this eve is nowhere to be seen, her light but temporarily extinguished, so that soon it may shine bright once more with newfound strength and possibility."
      Speaker = "Storyteller"
      Event = "InspectPreRunNewMoon01"
    }
    {
      Id = "Melinoe_4078"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Our cycle begins anew..."
      Speaker = "Melinoe"
      Event = "InspectPreRunNewMoon01"
    }
    {
      Id = "Storyteller_0412"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}That well-worn storage case by now contains tokens of gratitude from many gods and more; a perpetual reminder that the Princess of the Dead shall never fight alone."
      Speaker = "Storyteller"
      Event = "InspectManyKeepsakes01"
    }
    {
      Id = "Melinoe_4271"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're always with me..."
      Speaker = "Melinoe"
      Event = "InspectManyKeepsakes01"
    }
    {
      Id = "Storyteller_0353"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The three Gifts of the Veil, to be bestowed to one deserving of the title of Night's Champion, beckon the fierce Princess of the Dead to prove her unequaled prowess to all."
      Speaker = "Storyteller"
      Event = "InspectSkellyStatuesLocked01"
    }
    {
      Id = "Melinoe_4083"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, I don't know..."
      Speaker = "Melinoe"
      Event = "InspectSkellyStatuesLocked01"
    }
    {
      Id = "Skelly_0580"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, I {#Emph}do {#Prev}know!"
      Speaker = "Skelly"
      Event = "InspectSkellyStatuesLocked01"
    }
    {
      Id = "Storyteller_0354"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh, erm, eh, erm-erm-erm... So majestic in their poise are the three sculptures of our Princess of the Dead that they demand the reverence of any soul in their vicinity."
      Speaker = "Storyteller"
      Event = "InspectSkellyStatues01"
    }
    {
      Id = "Melinoe_4084"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Reverence{#Prev}, huh...?"
      Speaker = "Melinoe"
      Event = "InspectSkellyStatues01"
    }
    {
      Id = "Skelly_0581"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Yeah{#Prev}, just look at 'em!"
      Speaker = "Skelly"
      Event = "InspectSkellyStatues01"
    }
    {
      Id = "Storyteller_0235"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}It is the dead of night within a haunted, barely moonlit thicket at the Underworld's edge. There, a young forsaken Princess hunts her prey..."
      Speaker = "Storyteller"
      Event = "HecateHideAndSeekIntro01"
    }
    {
      Id = "Melinoe_2106"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Ready or not, hence I go...!"
      Speaker = "Melinoe"
      Event = "HecateHideAndSeekIntro01"
    }
    {
      Id = "Melinoe_4841"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hi, kitties!"
      Speaker = "Melinoe"
      Event = "ObstacleData[783240].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_2114"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hi Shades, is Hecate about...? Not seen her, huh?"
      Speaker = "Melinoe"
      Event = "ObstacleData[561454].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Storyteller_0140"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The keen-eyed Princess finds a set of tracks, suggesting that her foe trod through this dusty ground not very long before..."
      Speaker = "Storyteller"
      Event = "InspectHomerReveal01"
    }
    {
      Id = "Melinoe_2105"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Shush{#Prev}, Homer! How shall I ever catch her if you're going to describe my every move?"
      Speaker = "Melinoe"
      Event = "InspectHomerReveal01"
    }
    {
      Id = "Storyteller_0149"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Uhhh erm-erm-erm, I, I, I've no idea to whom you refer... to whom the Princess of the Dead refers! As she continues on her fateful search."
      Speaker = "Storyteller"
      Event = "InspectHomerReveal01"
    }
    {
      Id = "Melinoe_2269"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Quit teasing me and help me look!"
      Speaker = "Melinoe"
      Event = "InspectHomerReveal01"
    }
    {
      Id = "Hecate_0207"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...But, Lord Hades, I..."
      Speaker = "Hecate"
      Event = "Flashback_DeathAreaBedroomHades.StartUnthreadedEvents.VoiceLines"
    }
    {
      Id = "Hades_0048"
      InheritFrom = "BaseNarrative"
      DisplayName = "...You have your orders. Now return to shadow. And, take care of her. For all of us."
      Speaker = "Hades"
      Event = "HadesWithHecate01"
    }
    {
      Id = "Hecate_0208"
      InheritFrom = "BaseNarrative"
      DisplayName = "No harm shall come to young Melinoë, my lord. In this, at least, I shall not fail you."
      Speaker = "Hecate"
      Event = "HadesWithHecate01"
    }
    {
      Id = "Hecate_0209"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Farewell..."
      Speaker = "Hecate"
      Event = "HadesWithHecate01"
    }
    {
      Id = "Hades_0017"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Goodbye, Daughter..."
      Speaker = "Hades"
      Event = "HadesWithHecate01"
    }
    {
      Id = "MelinoeField_3305"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ow...!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DeathVoiceLines"
    }
    {
      Id = "MelinoeField_3306"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ow!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DeathVoiceLines"
    }
    {
      Id = "MelinoeField_3307"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}What?!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DeathVoiceLines"
    }
    {
      Id = "MelinoeField_3308"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hey!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DeathVoiceLines"
    }
    {
      Id = "MelinoeField_3309"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Gah!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DeathVoiceLines"
    }
    {
      Id = "MelinoeField_3310"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ouch!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DeathVoiceLines"
    }
    {
      Id = "Melinoe_0123"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Wha—?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DeathVoiceLines"
    }
    {
      Id = "Melinoe_0125"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Augh!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DeathVoiceLines"
    }
    {
      Id = "Melinoe_0126"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Gaah!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DeathVoiceLines"
    }
    {
      Id = "MelinoeField_1384"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ungh!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DeathVoiceLines"
    }
    {
      Id = "Melinoe_0124"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ungh{#Prev}, no!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DeathVoiceLines"
    }
    {
      Id = "MelinoeField_1387"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How—?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DeathVoiceLines"
    }
    {
      Id = "MelinoeField_1389"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DeathVoiceLines"
    }
    {
      Id = "MelinoeField_1390"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ngh{#Prev}, no...!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DeathVoiceLines"
    }
    {
      Id = "MelinoeField_1388"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You!!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DeathVoiceLines"
    }
    {
      Id = "Moros_1020"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Nothin' to see here! {#Emph}Bye!"
      Speaker = "Moros"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Moros_1021"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hey! Go on. {#Emph}Get outta here!"
      Speaker = "Moros"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Moros_1022"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Could you mind your own business?"
      Speaker = "Moros"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Moros_1023"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're early, go away!"
      Speaker = "Moros"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Hecate_0134"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You must be stronger than this, Melinoë."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Hecate_0137"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Return and rest, and try again, Melinoë."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Hecate_0139"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Consider the mistakes you made, Melinoë."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Hecate_0010"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're clearly unprepared as yet."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Hecate_0132"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I know that you are stronger than this."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Hecate_0133"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I know you could have done better than that."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Hecate_0135"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A lesson learned, I trust?"
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Hecate_0136"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Moon was witness to our clash this night."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Hecate_0138"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I take no joy in this, I hope you know."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "HecateField_0074"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Collapsed under the pressure of it all..."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "HecateField_0075"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You almost had me! Not quite."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "HecateField_0076"
      InheritFrom = "BaseSubtitle"
      DisplayName = "So very close, and yet not strong enough."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "HecateField_0077"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Fought more fiercely than last time at least."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "HecateField_0078"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Do not be disappointed; you fought well."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "HecateField_0079"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You barely got to me at all that time."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Scylla_0134"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We're {#Emph}Scylla and the Sirens{#Prev}, everybody!!"
      Speaker = "Scylla"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Scylla_0135"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thank you, everybody! Good night!"
      Speaker = "Scylla"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Scylla_0136"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Thank you, Oceanus!!"
      Speaker = "Scylla"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Scylla_0137"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hey, {#Emph}thanks {#Prev}for coming to our show!"
      Speaker = "Scylla"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Scylla_0264"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hey wait, don't go! We're just getting started!"
      Speaker = "Scylla"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Scylla_0265"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh it's OK! Our latest jam isn't for everyone."
      Speaker = "Scylla"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Scylla_0266"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No wait! We've still got more material to share!"
      Speaker = "Scylla"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Scylla_0267"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Go on, {#Emph}run {#Prev}away! And tell {#Emph}everybody {#Prev}about us!"
      Speaker = "Scylla"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Scylla_0268"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Heeheeheehee! {#Prev}Told you gals she couldn't handle {#Emph}us!"
      Speaker = "Scylla"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Scylla_0269"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Do come on back, we're playing every night!"
      Speaker = "Scylla"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Chronos_0197"
      InheritFrom = "BaseSubtitle"
      DisplayName = "An inevitable outcome, nothing more."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Chronos_0198"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We must do this again some other time."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Chronos_0199"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No good shall come to those who swear allegiance to the gods."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Chronos_0200"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I had expected somewhat more from my own kin."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Chronos_0201"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What did you hope you would accomplish here?"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Chronos_0202"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Time may heal all wounds, or may inflict them just as readily."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Chronos_0468"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I alone shall not forget your meaningless efforts."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Chronos_0469"
      InheritFrom = "BaseSubtitle"
      DisplayName = "As you can see, I am quite spry despite my age."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Chronos_0470"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Attack me all you like; I have all the time in the world."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Chronos_0471"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The youth of this age grow soft in body and in mind."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Chronos_0257"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The same predictable result, yet you persist."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Chronos_0258"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What did you expect would change this time?"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Chronos_0259"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Once more you slip through my grasp, but I shall catch you yet."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Chronos_0260"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Again you have risked everything, only to fail ignobly."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Chronos_0467"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thus history repeats as it is wont to do."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Chronos_0472"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You ought not have anticipated any other outcome."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Chronos_0261"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That is what you get for all the inconvenience you caused!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Chronos_0262"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Our previous engagement likewise ought have ended thus!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Chronos_0263"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Did you truly think you would prevail against me once more?"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Chronos_0264"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Ah, a bitter defeat! Now, that is more like it."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "MelinoeField_3435"
      InheritFrom = "BaseSubtitle"
      DisplayName = "From mists of memory, return to shadow, now...!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Zagreus_0025"
      InheritFrom = "BaseSubtitle"
      DisplayName = "She's gone... it's only me again... hey when do I wake up...?"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Zagreus_0450"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'd settle for the latter bit..."
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Zagreus_0033"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Sure thing! I think of weapons all the time!"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "MelinoeField_3434"
      InheritFrom = "BaseSubtitle"
      DisplayName = "From mists of memory, return to shadow, now..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Zagreus_0041"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Be safe out there!"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "MelinoeField_3436"
      InheritFrom = "BaseSubtitle"
      DisplayName = "From mists of memory, return to shadow, now."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Zagreus_0049"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...She's gone again. {#Emph}Big brother... me...?"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Zagreus_0061"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Wait was that her? What's going on. {#Emph}Melinoë...?"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Zagreus_0066"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Wait are you there? Sister, are you there? {#Emph}Augh..."
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Zagreus_0104"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Good news! The terms of your Infernal Contract are fulfilled!"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Zagreus_0105"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I just beat up my little sister, everyone, thank you!"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Zagreus_0310"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hey how'd you do that disappearing trick...?"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Zagreus_0311"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Did all you Shades enjoy our little show?"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Zagreus_0312"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Any other would-be challengers out there? No...?"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Zagreus_0313"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Been doing this since before you were born, Sister!"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Zagreus_0317"
      InheritFrom = "BaseSubtitle"
      DisplayName = "They didn't make me Security Specialist for nothing!"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Zagreus_0318"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're strong, Melinoë, but as it turns out I am also strong."
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Medea_0368"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A feast of freshly fallen blood for me..."
      Speaker = "Medea"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Medea_0369"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well, Cyclops! We make a decent partnership."
      Speaker = "Medea"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Medea_0371"
      InheritFrom = "BaseSubtitle"
      DisplayName = "See you some other night then, sorceress!"
      Speaker = "Medea"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Medea_0372"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And thus once more, the will of Night is done."
      Speaker = "Medea"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Medea_0570"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You spent all of the blood you had to spare..."
      Speaker = "Medea"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Medea_0571"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Do not lament this outcome. Draw from it!"
      Speaker = "Medea"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Medea_0572"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Your mind was clouded tonight, sorceress."
      Speaker = "Medea"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Medea_0573"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Great Hecate, this victory is mine...!"
      Speaker = "Medea"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Medea_0574"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I may lack your divinity, but I make do."
      Speaker = "Medea"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Polyphemus_0089"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Get your hindquarters out of my town."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Polyphemus_0090"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That ought to teach you."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Polyphemus_0091"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You mess with my sheep, I mess with {#Emph}you."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Polyphemus_0092"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Chow time... wait, where'd you go?"
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Polyphemus_0093"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Urgh {#Prev}where'd she go that time?"
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Polyphemus_0094"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Worked up a real appetite back there."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Polyphemus_0095"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Nobody messes with my sheep."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Polyphemus_0096"
      InheritFrom = "BaseSubtitle"
      DisplayName = "So much for my meal ticket huh."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Polyphemus_0097"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Get back here, you little..."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Polyphemus_0098"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Sounds like we're done here, huh."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "ErisField_0122"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Return to shadow, now!"
      Speaker = "Eris"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "ErisField_0123"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Return to shadow, now...!"
      Speaker = "Eris"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "ErisField_0124"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's right, Miss Perfect, go on home and {#Emph}cry."
      Speaker = "Eris"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "ErisField_0125"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Aha, haha! {#Prev}Got so far, only to trip and fall!"
      Speaker = "Eris"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "ErisField_0126"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Sorry, babe, but that's the way it goes!"
      Speaker = "Eris"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "ErisField_0127"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Same time, same place tomorrow night, Trouble?"
      Speaker = "Eris"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "ErisField_0128"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Don't hate me, babe! I'm just being {#Emph}me!"
      Speaker = "Eris"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "ErisField_0129"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We have {#Emph}got {#Prev}to do this again sometime, OK?"
      Speaker = "Eris"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Heracles_0403"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Be grateful that I didn't crush your every bone."
      Speaker = "Heracles"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Heracles_0401"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Got her, Flame Thief. Only took the both of us."
      Speaker = "Heracles"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Heracles_0404"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You may have taken Flame Thief there, but not me."
      Speaker = "Heracles"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Heracles_0405"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Looks like she's gone, Prometheus. Now what...?"
      Speaker = "Heracles"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Heracles_0406"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You said that we'd lose, Prometheus. To... make us {#Emph}win?"
      Speaker = "Heracles"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Prometheus_0111"
      InheritFrom = "BaseSubtitle"
      DisplayName = "There was no dignity in this at all."
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Prometheus_0112"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I had no other means to drive you back."
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Prometheus_0113"
      InheritFrom = "BaseSubtitle"
      DisplayName = "She's gone for now, Aetos, but she'll return..."
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Prometheus_0163"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll tear the gods apart with my bare hands..."
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Prometheus_0164"
      InheritFrom = "BaseSubtitle"
      DisplayName = "There wasn't anything you could have done."
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Prometheus_0165"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Your boundless pride won't save you anymore."
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Prometheus_0474"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This needed to be done... I know you'll understand."
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Prometheus_0475"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll never serve the gods; only the future."
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Prometheus_0477"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well done, Aetos... we played our part for now."
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Prometheus_0476"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We got her there, big man... good mercenary work."
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Prometheus_0166"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I know your every move; whilst you know nothing."
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.DeathReturnVoiceLines"
    }
    {
      Id = "Prometheus_0167"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Another night, the same exact outcome."
      Speaker = "Prometheus"
