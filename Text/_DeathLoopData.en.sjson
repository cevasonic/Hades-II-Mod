{
  /*
  This file was autogenerated on 10/22/2025 at 12:29 AM
  by the BuildText tool.
  */
  lang = "en"
  Texts = [
    {
      Id = "Melinoe_5736"
      InheritFrom = "BaseNarrative"
      DisplayName = "May it all turn out that way in time, Homer. Though, we're not there yet, especially not with the Fates still missing. We achieved something important, but more is to be done."
      Speaker = "Melinoe"
      Event = "TrueEndingFinaleResponse01"
    }
    {
      Id = "Melinoe_5737"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...I said we're not finished!"
      Speaker = "Melinoe"
      Event = "TrueEndingFinaleResponse01"
    }
    {
      Id = "Melinoe_1164"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Stand tall and show no weakness..."
      Speaker = "Melinoe"
      Event = "Hub_Main.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_2950"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ah! {#Prev}Carry on, everyone. I'm OK."
      Speaker = "Melinoe"
      Event = "Hub_Main.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_2425"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, hello...!"
      Speaker = "Melinoe"
      Event = "Hub_Main.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_2426"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm fine, really!"
      Speaker = "Melinoe"
      Event = "Hub_Main.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_2427"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No need to be concerned!"
      Speaker = "Melinoe"
      Event = "Hub_Main.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_2428"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Begging your pardon, Shades."
      Speaker = "Melinoe"
      Event = "Hub_Main.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_2429"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Good evening everyone...!"
      Speaker = "Melinoe"
      Event = "Hub_Main.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_2430"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thank you for waiting..."
      Speaker = "Melinoe"
      Event = "Hub_Main.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_2431"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come along then...!"
      Speaker = "Melinoe"
      Event = "Hub_Main.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_2432"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Let's have a look around."
      Speaker = "Melinoe"
      Event = "Hub_Main.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_2820"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The cauldron's ready for me now..."
      Speaker = "Melinoe"
      Event = "Hub_Main.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_1585"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Is that...?"
      Speaker = "Melinoe"
      Event = "Hub_Main.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_4693"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Lord Moros was just here..."
      Speaker = "Melinoe"
      Event = "Hub_Main.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_2439"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What is all this...?"
      Speaker = "Melinoe"
      Event = "Hub_Main.DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_1900"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come on, Mel. Exit's back the other way..."
      Speaker = "Melinoe"
      Event = "Hub_Main.EnterVoiceLines"
    }
    {
      Id = "Storyteller_0234"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The Crossroads: that haven hidden 'twixt the surface and the Underworld conceals those still loyal to Lord Hades, rightful ruler of the dead."
      Speaker = "Storyteller"
      Event = "InspectCrossroads01"
    }
    {
      Id = "Melinoe_2959"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Together, we'll retake my father's realm."
      Speaker = "Melinoe"
      Event = "InspectCrossroads01"
    }
    {
      Id = "Storyteller_0078"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The modestly appointed tent of fierce Princess Melinoë nonetheless is dutifully organized and immaculately clean."
      Speaker = "Storyteller"
      Event = "InspectTent01"
    }
    {
      Id = "Melinoe_0032"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I won't live in squalor."
      Speaker = "Melinoe"
      Event = "InspectTent01"
    }
    {
      Id = "Storyteller_0121"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The dark Princess reveals her deepest fears only to a stoic old amphibian, which long ago hopped into her tent, and into her heart."
      Speaker = "Storyteller"
      Event = "InspectTent01"
    }
    {
      Id = "Melinoe_1684"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Only the deepest fears for you, Frinos!"
      Speaker = "Melinoe"
      Event = "InspectTent01"
    }
    {
      Id = "Storyteller_0340"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The embodiment of Sleep dozes interminably in a private little grove, visited on occasion by the Princess of the Underworld whenever she requires time to think and plan."
      Speaker = "Storyteller"
      Event = "InspectCrossroadsHypnos01"
    }
    {
      Id = "Melinoe_4070"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Or just to check on him."
      Speaker = "Melinoe"
      Event = "InspectCrossroadsHypnos01"
    }
    {
      Id = "Storyteller_0502"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Having vacated the Crossroads in all haste, the until-recently-long-dormant incarnate of Sleep delivered certain articles in show of gratitude, and... perhaps more..."
      Speaker = "Storyteller"
      Event = "InspectHypnosGift01"
    }
    {
      Id = "Melinoe_5435"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I ended his dreams, and in a way, he ended mine."
      Speaker = "Melinoe"
      Event = "InspectHypnosGift01"
    }
    {
      Id = "Storyteller_0341"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}A finely-chiseled countenance of the Underworld's unseated king instills a sense of quiet contemplation and resolve in whosoever dares to meet those stone unseeing eyes."
      Speaker = "Storyteller"
      Event = "InspectHadesFountain01"
    }
    {
      Id = "Melinoe_4071"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Watch over me, Father..."
      Speaker = "Melinoe"
      Event = "InspectHadesFountain01"
    }
    {
      Id = "Storyteller_0526"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}There are no second chances in this world. The Titan Chronos once intoned that there is no undoing past mistakes... mere fleeting possibilities, lost to Time."
      Speaker = "Storyteller"
      Event = "InspectHadesFountain02"
    }
    {
      Id = "Melinoe_5764"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Possibilities that could have been..."
      Speaker = "Melinoe"
      Event = "InspectHadesFountain02"
    }
    {
      Id = "Storyteller_0012"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The Crossroads hide the plans and movements of the nightmare-bringing witch and her compatriots, but for how long?"
      Speaker = "Storyteller"
      Event = "InspectCrossroadsPassage01"
    }
    {
      Id = "Melinoe_0403"
      InheritFrom = "BaseSubtitle"
      DisplayName = "For long enough."
      Speaker = "Melinoe"
      Event = "InspectCrossroadsPassage01"
    }
    {
      Id = "Storyteller_0345"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}On black wings does the uncontrollable embodiment of Strife go wheresoever she may please, and lately, that is often in the Princess of the Underworld's way."
      Speaker = "Storyteller"
      Event = "InspectCrossroadsEris01"
    }
    {
      Id = "Melinoe_4075"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Cheers, Eris..."
      Speaker = "Melinoe"
      Event = "InspectCrossroadsEris01"
    }
    {
      Id = "Eris_0133"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Huh?"
      Speaker = "Eris"
      Event = "InspectCrossroadsEris01"
    }
    {
      Id = "Storyteller_0080"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The last will of the Three Fates, those reclusive determiners of all that is to come, is now under the Princess of the Underworld's care."
      Speaker = "Storyteller"
      Event = "InspectFatedList01"
    }
    {
      Id = "Melinoe_1682"
      InheritFrom = "BaseSubtitle"
      DisplayName = "With their aid, we may have a chance."
      Speaker = "Melinoe"
      Event = "InspectFatedList01"
    }
    {
      Id = "Storyteller_0122"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Not even the wiles and stratagems of that resourceful sacker of cities, Odysseus, may be sufficient to overcome the Titan of Time..."
      Speaker = "Storyteller"
      Event = "InspectOdysseus01"
    }
    {
      Id = "Melinoe_1685"
      InheritFrom = "BaseSubtitle"
      DisplayName = "They say never to underestimate that man..."
      Speaker = "Melinoe"
      Event = "InspectOdysseus01"
    }
    {
      Id = "Odysseus_0123"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hah{#Prev}, come on."
      Speaker = "Odysseus"
      Event = "InspectOdysseus01"
    }
    {
      Id = "Storyteller_0134"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The unhappy goddess of comeuppance casts her judging gaze on all within the Crossroads, which she safeguards out of duty, and of spite."
      Speaker = "Storyteller"
      Event = "InspectNemesis01"
    }
    {
      Id = "Melinoe_1687"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Don't want to get on Nem's bad side..."
      Speaker = "Melinoe"
      Event = "InspectNemesis01"
    }
    {
      Id = "Nemesis_0120"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Whatever."
      Speaker = "Nemesis"
      Event = "InspectNemesis01"
    }
    {
      Id = "Storyteller_0135"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The widely-hated, feared embodiment of Doom goes wherever the ever-weaving Fates decide, and none but they can anticipate his arrival."
      Speaker = "Storyteller"
      Event = "InspectMoros01"
    }
    {
      Id = "Melinoe_1688"
      InheritFrom = "BaseSubtitle"
      DisplayName = "He sure knows how to make an entrance..."
      Speaker = "Melinoe"
      Event = "InspectMoros01"
    }
    {
      Id = "Moros_0093"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Princess?"
      Speaker = "Moros"
      Event = "InspectMoros01"
    }
    {
      Id = "Storyteller_0136"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Some Spirits of the Dead forever wander aimlessly, whilst others, lacking even so much will, merely linger in a single place."
      Speaker = "Storyteller"
      Event = "InspectDora01"
    }
    {
      Id = "Melinoe_1689"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Dora does need to get out more often..."
      Speaker = "Melinoe"
      Event = "InspectDora01"
    }
    {
      Id = "Dora_0118"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not happening."
      Speaker = "Dora"
      Event = "InspectDora01"
    }
    {
      Id = "Storyteller_0344"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Numerous are the responsibilities of Hecate, Witch of the Crossroads, unseen watcher between realms, and keeper of the key to pathways hidden even to immortal eyes."
      Speaker = "Storyteller"
      Event = "InspectCrossroadsHecate01"
    }
    {
      Id = "Melinoe_4074"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And our Headmistress."
      Speaker = "Melinoe"
      Event = "InspectCrossroadsHecate01"
    }
    {
      Id = "Storyteller_0346"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The faithful animal attendants of the Witch of the Crossroads oft inspire other beasts to seek the shelter and the solace of this refuge between realms."
      Speaker = "Storyteller"
      Event = "InspectCrossroadsBeasts01"
    }
    {
      Id = "Melinoe_4076"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We've much to learn from beasts."
      Speaker = "Melinoe"
      Event = "InspectCrossroadsBeasts01"
    }
    {
      Id = "Storyteller_0129"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}After ever-scheming Chronos claimed the House of Hades, Shades of the dead residing there all scattered to the ends of the earth."
      Speaker = "Storyteller"
      Event = "InspectBroker01"
    }
    {
      Id = "Melinoe_1679"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You Shades are welcome here and safe."
      Speaker = "Melinoe"
      Event = "InspectBroker01"
    }
    {
      Id = "Storyteller_0238"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Much is to be learned from history, if one but studies the lessons hidden in any purported accounts; a lifelong pursuit, in and of itself."
      Speaker = "Storyteller"
      Event = "InspectLearnedSage01"
    }
    {
      Id = "Melinoe_2961"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Still no telling what the future holds..."
      Speaker = "Melinoe"
      Event = "InspectLearnedSage01"
    }
    {
      Id = "Storyteller_0239"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Once there was an administrative chamber in the Underworld, where Shades kept careful track of each detail; a trade a few such souls as yet pursue."
      Speaker = "Storyteller"
      Event = "InspectRecordKeeper01"
    }
    {
      Id = "Melinoe_2962"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Surely such efforts were rewarded handsomely."
      Speaker = "Melinoe"
      Event = "InspectRecordKeeper01"
    }
    {
      Id = "Storyteller_0301"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The gift of music, bestowed to mortals by shining Apollo himself, has the capacity to stir the soul like nothing else; regardless if the soul is of the living or the dead."
      Speaker = "Storyteller"
      Event = "InspectMusicMaker01"
    }
    {
      Id = "Melinoe_3750"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well then let's stir some souls!"
      Speaker = "Melinoe"
      Event = "InspectMusicMaker01"
    }
    {
      Id = "Storyteller_0342"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The Moon oft shines particularly bright in one fair corner of the Crossroads, where the Princess of the Underworld may always clear her thoughts and have a moment's peace."
      Speaker = "Storyteller"
      Event = "InspectCrossroadsClearing01"
    }
    {
      Id = "Melinoe_4072"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And listen to the frogs."
      Speaker = "Melinoe"
      Event = "InspectCrossroadsClearing01"
    }
    {
      Id = "Storyteller_0343"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The sonorous voice of the goddess of the hunt fills the clearing like a ray of moonlight, stirring the eternal souls of Shades that there reside."
      Speaker = "Storyteller"
      Event = "InspectCrossroadsArtemis01"
    }
    {
      Id = "Melinoe_4073"
      InheritFrom = "BaseSubtitle"
      DisplayName = "She's not bad, is she?"
      Speaker = "Melinoe"
      Event = "InspectCrossroadsArtemis01"
    }
    {
      Id = "Storyteller_0130"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Fleeting is the sense of hope or joy within the Crossroads, yet what little may emerge is often concentrated in the small taverna there."
      Speaker = "Storyteller"
      Event = "InspectTaverna01"
    }
    {
      Id = "Melinoe_1680"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No time to unwind..."
      Speaker = "Melinoe"
      Event = "InspectTaverna01"
    }
    {
      Id = "Storyteller_0241"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Liquid lamentation flows through the River Cocytus, yet even in such hopeless waters, certain creatures learn to live and thrive."
      Speaker = "Storyteller"
      Event = "InspectCrossroadsFishingPoint01"
    }
    {
      Id = "Melinoe_2964"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I {#Emph}do {#Prev}sense some of them want out..."
      Speaker = "Melinoe"
      Event = "InspectCrossroadsFishingPoint01"
    }
    {
      Id = "Storyteller_0240"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}A small spring draws its heat from deep within the Earth, its waters so pristine and pure that they can cleanse the body and the soul."
      Speaker = "Storyteller"
      Event = "InspectCrossroadsBathHouse01"
    }
    {
      Id = "Melinoe_2963"
      InheritFrom = "BaseSubtitle"
      DisplayName = "If I get in, I might never want to get out..."
      Speaker = "Melinoe"
      Event = "InspectCrossroadsBathHouse01"
    }
    {
      Id = "Storyteller_0497"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The sun and moon: two sides forming a whole, a newfound symbol of the union 'twixt Olympus and the Underworld, and a gift to the Crossroads from the gods themselves."
      Speaker = "Storyteller"
      Event = "InspectSunMoonTimeSculpture01"
    }
    {
      Id = "Melinoe_5168"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Lord Hephaestus must have crafted this himself."
      Speaker = "Melinoe"
      Event = "InspectSunMoonTimeSculpture01"
    }
    {
      Id = "Melinoe_1710"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Moonlight guide you, Broker."
      Speaker = "Melinoe"
      Event = "ObstacleData[558096].InteractVoiceLines"
    }
    {
      Id = "Melinoe_3009"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Record Keeper."
      Speaker = "Melinoe"
      Event = "ObstacleData[589467].InteractVoiceLines"
    }
    {
      Id = "Melinoe_3010"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hail, Keeper."
      Speaker = "Melinoe"
      Event = "ObstacleData[589467].InteractVoiceLines"
    }
    {
      Id = "Melinoe_3011"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Greetings, Record Keeper."
      Speaker = "Melinoe"
      Event = "ObstacleData[589467].InteractVoiceLines"
    }
    {
      Id = "Melinoe_3006"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Greetings, Sage."
      Speaker = "Melinoe"
      Event = "ObstacleData[589466].InteractVoiceLines"
    }
    {
      Id = "Melinoe_3007"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hail, O learned Sage."
      Speaker = "Melinoe"
      Event = "ObstacleData[589466].InteractVoiceLines"
    }
    {
      Id = "Melinoe_3008"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Good evening, Sage."
      Speaker = "Melinoe"
      Event = "ObstacleData[589466].InteractVoiceLines"
    }
    {
      Id = "Melinoe_3845"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Apollo would be proud!"
      Speaker = "Melinoe"
      Event = "ObstacleData[738510].InteractVoiceLines"
    }
    {
      Id = "Melinoe_3846"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Salutations, Music Maker."
      Speaker = "Melinoe"
      Event = "ObstacleData[738510].InteractVoiceLines"
    }
    {
      Id = "Melinoe_3677"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Play on, Music Maker."
      Speaker = "Melinoe"
      Event = "ObstacleData[738510].InteractVoiceLines"
    }
    {
      Id = "Melinoe_2600"
      InheritFrom = "BaseSubtitle"
      DisplayName = "There's something by the Broker..."
      Speaker = "Melinoe"
      Event = "ObstacleData[583652].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_2280"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A shipment's arrived."
      Speaker = "Melinoe"
      Event = "ObstacleData[583652].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_2281"
      InheritFrom = "BaseSubtitle"
      DisplayName = "New shipment there."
      Speaker = "Melinoe"
      Event = "ObstacleData[583652].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_2282"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Something for me?"
      Speaker = "Melinoe"
      Event = "ObstacleData[583652].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_2283"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Lord Charon always delivers."
      Speaker = "Melinoe"
      Event = "ObstacleData[583652].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_0156"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Another shipment already..."
      Speaker = "Melinoe"
      Event = "ObstacleData[583652].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_3409"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The hound and polecat must have gone to scout..."
      Speaker = "Melinoe"
      Event = "ObstacleData[590518].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_5434"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Something where Hypnos used to be..."
      Speaker = "Melinoe"
      Event = "ObstacleData[800612].DistanceTriggers.VoiceLines"
    }
    {
      Id = "Melinoe_4746"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I have an incantation to complete..."
      Speaker = "Melinoe"
      Event = "SetupEvents.DistanceTrigger.VoiceLines"
    }
    {
      Id = "Melinoe_4747"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Cauldron first."
      Speaker = "Melinoe"
      Event = "SetupEvents.DistanceTrigger.VoiceLines"
    }
    {
      Id = "Melinoe_4743"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Should speak with Headmistress before I go..."
      Speaker = "Melinoe"
      Event = "SetupEvents.DistanceTrigger.VoiceLines"
    }
    {
      Id = "Melinoe_4744"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Should talk to Headmistress..."
      Speaker = "Melinoe"
      Event = "SetupEvents.DistanceTrigger.VoiceLines"
    }
    {
      Id = "Melinoe_4745"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Need to speak with Headmistress."
      Speaker = "Melinoe"
      Event = "SetupEvents.DistanceTrigger.VoiceLines"
    }
    {
      Id = "Melinoe_3566"
