{
  /*
  This file was autogenerated on 10/9/2025 at 6:51 PM
  by the BuildText tool.
  */
  lang = "en"
  Texts = [
    {
      Id = "Melinoe_1707"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Death to Chronos, sir."
      Speaker = "Melinoe"
      Event = "NPC_Odysseus_01.InteractVoiceLines"
    }
    {
      Id = "Odysseus_0214"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And greetings!"
      Speaker = "Odysseus"
      Event = "NPC_Odysseus_01.InteractVoiceLines"
    }
    {
      Id = "Odysseus_0215"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Salutations!"
      Speaker = "Odysseus"
      Event = "NPC_Odysseus_01.InteractVoiceLines"
    }
    {
      Id = "Odysseus_0216"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Salutations, Goddess."
      Speaker = "Odysseus"
      Event = "NPC_Odysseus_01.InteractVoiceLines"
    }
    {
      Id = "Odysseus_0217"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You'll get him yet."
      Speaker = "Odysseus"
      Event = "NPC_Odysseus_01.InteractVoiceLines"
    }
    {
      Id = "Odysseus_0224"
      InheritFrom = "BaseSubtitle"
      DisplayName = "He'll get his."
      Speaker = "Odysseus"
      Event = "NPC_Odysseus_01.InteractVoiceLines"
    }
    {
      Id = "Odysseus_0102"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, don't I wish."
      Speaker = "Odysseus"
      Event = "NPC_Odysseus_01.InteractVoiceLines"
    }
    {
      Id = "Odysseus_0218"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And you as well."
      Speaker = "Odysseus"
      Event = "NPC_Odysseus_01.InteractVoiceLines"
    }
    {
      Id = "Odysseus_0317"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Shadows conceal you."
      Speaker = "Odysseus"
      Event = "NPC_Odysseus_01.InteractVoiceLines"
    }
    {
      Id = "Odysseus_0219"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You likewise."
      Speaker = "Odysseus"
      Event = "NPC_Odysseus_01.InteractVoiceLines"
    }
    {
      Id = "Odysseus_0220"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And may you prevail."
      Speaker = "Odysseus"
      Event = "NPC_Odysseus_01.InteractVoiceLines"
    }
    {
      Id = "Odysseus_0221"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We'll find our way."
      Speaker = "Odysseus"
      Event = "NPC_Odysseus_01.InteractVoiceLines"
    }
    {
      Id = "Odysseus_0222"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Aye that."
      Speaker = "Odysseus"
      Event = "NPC_Odysseus_01.InteractVoiceLines"
    }
    {
      Id = "Odysseus_0223"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We'll get through this."
      Speaker = "Odysseus"
      Event = "NPC_Odysseus_01.InteractVoiceLines"
    }
    {
      Id = "Odysseus_0002"
      InheritFrom = "BaseNarrative"
      DisplayName = "Tell me you killed the bastard? Drove your staff into his wretched skull, slid a dagger in his gut? {#Emph}Eh{#Prev}, not that he'd die from that; works on mortals, though!"
      Speaker = "Odysseus"
      Event = "OdysseusFirstMeeting"
    }
    {
      Id = "Melinoe_0016_C"
      InheritFrom = "BaseNarrative"
      DisplayName = "Chronos the Titan of Time is vanquished, Odysseus. I have his head right here! At least... I wish I did."
      Speaker = "Melinoe"
      Event = "OdysseusFirstMeeting"
    }
    {
      Id = "Odysseus_0225"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well you'll get him next time, I reckon."
      Speaker = "Odysseus"
      Event = "OdysseusFirstMeeting"
    }
    {
      Id = "Odysseus_0033"
      InheritFrom = "BaseNarrative"
      DisplayName = "Our good witch there knows you've a mountain of a journey ahead of you, Goddess. You hear about our mountains on the surface? Big tall rocks?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutMountains01"
    }
    {
      Id = "Melinoe_0448"
      InheritFrom = "BaseNarrative"
      DisplayName = "What, you mean like Mount Olympus, or Mount Othrys? Of course I've heard of them! They reach up to the sky. I can only imagine."
      Speaker = "Melinoe"
      Event = "OdysseusAboutMountains01"
    }
    {
      Id = "Odysseus_0034"
      InheritFrom = "BaseNarrative"
      DisplayName = "You look up from the base to the peak, you'll swear they can't be climbed, {#Emph}but! {#Prev}If you only concern yourself with making that next step... you'll make it to the top."
      Speaker = "Odysseus"
      Event = "OdysseusAboutMountains01"
    }
    {
      Id = "Melinoe_0058"
      InheritFrom = "BaseSubtitle"
      DisplayName = "To the top..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutMountains01"
    }
    {
      Id = "Odysseus_0028"
      InheritFrom = "BaseNarrative"
      DisplayName = "Those thorny chaps you've been dealing with... their numbers grow in each report I get. If you've thoughts on how we could have better prepared you..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutErebus01"
    }
    {
      Id = "Melinoe_0056"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll share my thoughts when necessary, Odysseus. For the moment, I'm sorting through them still."
      Speaker = "Melinoe"
      Event = "OdysseusAboutErebus01"
    }
    {
      Id = "Odysseus_0029"
      InheritFrom = "BaseNarrative"
      DisplayName = "Aye, best not to speak without prepared remarks. I understand the feeling only too well. You'll keep me posted, though?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutErebus01"
    }
    {
      Id = "Melinoe_0057"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I will."
      Speaker = "Melinoe"
      Event = "OdysseusAboutErebus01"
    }
    {
      Id = "Odysseus_0035"
      InheritFrom = "BaseNarrative"
      DisplayName = "You run into anything bad whilst you're out there, you come talk to me about it. Chances are I've seen it, fought it, otherwise gotten past it, and can offer some advice."
      Speaker = "Odysseus"
      Event = "OdysseusAboutAdvice01"
    }
    {
      Id = "Melinoe_0450"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Definitely."
      Speaker = "Melinoe"
      Event = "OdysseusAboutAdvice01"
    }
    {
      Id = "Odysseus_0036"
      InheritFrom = "BaseNarrative"
      DisplayName = "You be wary of the sorts you meet out there, all right? You find a live one gives you any trouble, you know where to hit him where it hurts."
      Speaker = "Odysseus"
      Event = "OdysseusMeeting05"
    }
    {
      Id = "Melinoe_0451"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I most certainly do."
      Speaker = "Melinoe"
      Event = "OdysseusMeeting05"
    }
    {
      Id = "Melinoe_0456"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've known Headmistress quite a while, haven't you? Where did you meet, I always wanted to ask?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutHecate01"
    }
    {
      Id = "Odysseus_0040"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Heh{#Prev}, well. All I can say is that I was... alone. At the end of one life, and the start of another. Lost. She appeared before me then, in all her splendor, and... she revealed to me a path I hadn't seen."
      Speaker = "Odysseus"
      Event = "OdysseusAboutHecate01"
    }
    {
      Id = "Melinoe_0457"
      InheritFrom = "BaseNarrative"
      DisplayName = "That all sounds very figurative. Were you already dead?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutHecate01"
    }
    {
      Id = "Odysseus_0041"
      InheritFrom = "BaseNarrative"
      DisplayName = "I was. She told me she could grant me a new life. She needed a tactician knowledgeable of the surface. I thought, who am I to turn a goddess down? I followed her. It's been a while now."
      Speaker = "Odysseus"
      Event = "OdysseusAboutHecate01"
    }
    {
      Id = "Melinoe_0458"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A good while I'm sure."
      Speaker = "Melinoe"
      Event = "OdysseusAboutHecate01"
    }
    {
      Id = "Odysseus_0143"
      InheritFrom = "BaseNarrative"
      DisplayName = "The good witch put you to the test out there, did she? Quite an intensive teaching style, I always thought. She expects a lot from you, but that's just what happens when you've such potential."
      Speaker = "Odysseus"
      Event = "OdysseusAboutLosingToHecate01"
    }
    {
      Id = "Melinoe_2185"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then she must be disappointed with my results, although she's careful not to show it. Same as you, Odysseus."
      Speaker = "Melinoe"
      Event = "OdysseusAboutLosingToHecate01"
    }
    {
      Id = "Odysseus_0144"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come, I know how dispiriting it is to chart one's course, only to lose one's way. We rarely get where we must go the fastest way we can."
      Speaker = "Odysseus"
      Event = "OdysseusAboutLosingToHecate01"
    }
    {
      Id = "Melinoe_2186"
      InheritFrom = "BaseSubtitle"
      DisplayName = "As long as we get there at all."
      Speaker = "Melinoe"
      Event = "OdysseusAboutLosingToHecate01"
    }
    {
      Id = "Odysseus_0377"
      InheritFrom = "BaseNarrative"
      DisplayName = "You and the Goddess Artemis make quite a force out there by all accounts. And you sing together beautifully, at that...! Olympus sent her to check up on us, then, aye?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutArtemis01"
    }
    {
      Id = "Melinoe_4102"
      InheritFrom = "BaseNarrative"
      DisplayName = "I think so, yes. But I have complete trust in her if that's what you're wondering. She tells Olympus no more than they need to know to rest assured about our partnership."
      Speaker = "Melinoe"
      Event = "OdysseusAboutArtemis01"
    }
    {
      Id = "Odysseus_0378"
      InheritFrom = "BaseNarrative"
      DisplayName = "She is by nature rather cautious, isn't she? Well for my part, I'm pleased you have in her not just an ally... but a friend."
      Speaker = "Odysseus"
      Event = "OdysseusAboutArtemis01"
    }
    {
      Id = "Melinoe_4103"
      InheritFrom = "BaseSubtitle"
      DisplayName = "For my part, too."
      Speaker = "Melinoe"
      Event = "OdysseusAboutArtemis01"
    }
    {
      Id = "Melinoe_3333"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, where'd Hecuba and Gale scamper off to? I'd ask Headmistress but she doesn't like it when I show even the slightest concern for her Familiars. {#Emph}They're fine, Melinoë."
      Speaker = "Melinoe"
      Event = "OdysseusAboutFamiliars01"
    }
    {
      Id = "Odysseus_0268"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh they probably {#Emph}are {#Prev}fine! Each on a little scouting expedition at my own behest, under the auspices of the good witch of course. The hound goes one way, the polecat another."
      Speaker = "Odysseus"
      Event = "OdysseusAboutFamiliars01"
    }
    {
      Id = "Melinoe_3334"
      InheritFrom = "BaseNarrative"
      DisplayName = "Those little scouting expeditions always seem to last a while. I'll have to keep an eye out for them, then."
      Speaker = "Melinoe"
      Event = "OdysseusAboutFamiliars01"
    }
    {
      Id = "Odysseus_0269"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Where they're going, they shall appreciate seeing a friendly face."
      Speaker = "Odysseus"
      Event = "OdysseusAboutFamiliars01"
    }
    {
      Id = "Odysseus_0235"
      InheritFrom = "BaseNarrative"
      DisplayName = "Word has it Eris has been spotted in the depths along your path... intelligence you likely could have used {#Emph}before {#Prev}she made your journey worse for you. Apologies, Goddess..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutErisCurse01"
    }
    {
      Id = "Melinoe_3096"
      InheritFrom = "BaseNarrative"
      DisplayName = "She's trying to stop me, or at least slow me down. And... she knows too much about our intentions. What do we do? Children of Nyx are supposed to be on {#Emph}our {#Prev}side."
      Speaker = "Melinoe"
      Event = "OdysseusAboutErisCurse01"
    }
    {
      Id = "Odysseus_0236"
      InheritFrom = "BaseNarrative"
      DisplayName = "She doesn't know the {#Emph}half {#Prev}of what we've planned. Besides, her boredom drives her more than anything. Run into her a few more times, she'll soon grow sick of it and go away."
      Speaker = "Odysseus"
      Event = "OdysseusAboutErisCurse01"
    }
    {
      Id = "Melinoe_3097"
      InheritFrom = "BaseSubtitle"
      DisplayName = "So deems the Great Tactician...?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutErisCurse01"
    }
    {
      Id = "Odysseus_0237"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Aye, Goddess."
      Speaker = "Odysseus"
      Event = "OdysseusAboutErisCurse01"
    }
    {
      Id = "Melinoe_3335"
      InheritFrom = "BaseNarrative"
      DisplayName = "Have you caught Eris snooping through our plans or anything? Have to be even more discreet with her about..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutEris01"
    }
    {
      Id = "Odysseus_0270"
      InheritFrom = "BaseNarrative"
      DisplayName = "She stays over in her little corner mostly, Goddess, but I've been keeping my eye on her in case of anything. As long as she undermines our efforts well out of earshot..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutEris01"
    }
    {
      Id = "Melinoe_3336"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We can plan around it, you mean."
      Speaker = "Melinoe"
      Event = "OdysseusAboutEris01"
    }
    {
      Id = "Odysseus_0271"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Aye."
      Speaker = "Odysseus"
      Event = "OdysseusAboutEris01"
    }
    {
      Id = "Odysseus_0272"
      InheritFrom = "BaseNarrative"
      DisplayName = "Good, you're back. According to reports, Eris flew off toward the Rift of Thessaly on an intercept course with the fleet. Except I don't think that she's headed there to help. Not {#Emph}you{#Prev}, at least."
      Speaker = "Odysseus"
      Event = "OdysseusAboutErisBoss01"
    }
    {
      Id = "Melinoe_3311"
      InheritFrom = "BaseNarrative"
      DisplayName = "These reports aren't of much benefit to me after the fact. But at least I can confirm they're accurate. How preposterous that we cannot rid ourselves of her."
      Speaker = "Melinoe"
      Event = "OdysseusAboutErisBoss01"
    }
    {
      Id = "Odysseus_0273"
      InheritFrom = "BaseNarrative"
      DisplayName = "All we can do is work with what we've got. I apologize that we could not forewarn you on this one. We'll continue investigating her motives and accomplices."
      Speaker = "Odysseus"
      Event = "OdysseusAboutErisBoss01"
    }
    {
      Id = "Melinoe_3312"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm not convinced she has any of either."
      Speaker = "Melinoe"
      Event = "OdysseusAboutErisBoss01"
    }
    {
      Id = "Odysseus_0422"
      InheritFrom = "BaseNarrative"
      DisplayName = "Eris making problems for you on the surface, isn't she... whilst so close to your goal. Well if it's any reassurance, we know the workings of her weapon better than she does. She must run out of ammunition frequently..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutErisBossTactics01"
    }
    {
      Id = "Melinoe_4213"
      InheritFrom = "BaseNarrative"
      DisplayName = "She does. Sometimes she jams the mechanism, gets distracted getting it unstuck. Should use those opportunities to strike. Not much place for taking cover anyhow."
      Speaker = "Melinoe"
      Event = "OdysseusAboutErisBossTactics01"
    }
    {
      Id = "Odysseus_0423"
      InheritFrom = "BaseNarrative"
      DisplayName = "She's trying to intimidate you. With the Rail of Adamant, she's much more dangerous at range. Perhaps you could outflank or outmaneuver her somehow..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutErisBossTactics01"
    }
    {
      Id = "Melinoe_4214"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It's worth a shot."
      Speaker = "Melinoe"
      Event = "OdysseusAboutErisBossTactics01"
    }
    {
      Id = "Odysseus_0157"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nemesis has been in an especially foul mood of late. Anything I should know about?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutNemesis01"
    }
    {
      Id = "Melinoe_2212"
      InheritFrom = "BaseNarrative"
      DisplayName = "I was going to ask you the same. She sought my task, but that's nothing new. Though, she's been clashing with Headmistress more and more..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutNemesis01"
    }
    {
      Id = "Odysseus_0158"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, shame it's been this way. Personally, I'd rather have Divine Retribution with me than against. I reckon you can't just smooth things over with her, can you?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutNemesis01"
    }
    {
      Id = "Melinoe_2213"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I have my doubts..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutNemesis01"
    }
    {
      Id = "Odysseus_0159"
      InheritFrom = "BaseNarrative"
      DisplayName = "So, how has Nemesis been faring out there? Taking matters into her very capable hands. Not making {#Emph}too {#Prev}much grief for you, I reckon?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutNemesis02"
    }
    {
      Id = "Melinoe_2214"
      InheritFrom = "BaseNarrative"
      DisplayName = "So you know already? And Headmistress must, too. Nemesis is being Nemesis! Discovering firsthand our task is not as simple as it seems."
      Speaker = "Melinoe"
      Event = "OdysseusAboutNemesis02"
    }
    {
      Id = "Odysseus_0160"
      InheritFrom = "BaseNarrative"
      DisplayName = "Say no more, then! Though, if she becomes too intent on impeding your results over achieving her own, we'll step in."
      Speaker = "Odysseus"
      Event = "OdysseusAboutNemesis02"
    }
    {
      Id = "Melinoe_2215"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It won't come to that."
      Speaker = "Melinoe"
      Event = "OdysseusAboutNemesis02"
    }
    {
      Id = "Odysseus_0622"
      InheritFrom = "BaseNarrative"
      DisplayName = "So blasted quiet now... at first I couldn't tell what changed, till I recalled Hypnos had gone away. I was so accustomed to always hearing him in the background..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutHypnosWakeUp01"
    }
    {
      Id = "Melinoe_5244"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wait, you miss his ceaseless snoring? You of everyone at the Crossroads were in closest proximity, so I figured you'd be the most pleased that he's finally home."
      Speaker = "Melinoe"
      Event = "OdysseusAboutHypnosWakeUp01"
    }
    {
      Id = "Odysseus_0623"
      InheritFrom = "BaseNarrative"
      DisplayName = "Pleased for {#Emph}him{#Prev}, aye, and the auditory change isn't a {#Emph}bad {#Prev}one, but... even when things improve, it can be an adjustment."
      Speaker = "Odysseus"
      Event = "OdysseusAboutHypnosWakeUp01"
    }
    {
      Id = "Melinoe_5245"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll miss him too, mostly..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutHypnosWakeUp01"
    }
    {
      Id = "Melinoe_2218"
      InheritFrom = "BaseNarrative"
      DisplayName = "You and Commander Schelemeus both were great and famous sailors, isn't that so? Did the two of you ever meet in your mortal days?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutSkelly01"
    }
    {
      Id = "Odysseus_0163"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, {#Emph}great sailor {#Prev}is an understatement, Goddess! They say his exploits rivaled even mine! Alas that I never once had an opportunity to witness his prowess. {#Emph}Ah{#Prev}, it must have been something!"
      Speaker = "Odysseus"
      Event = "OdysseusAboutSkelly01"
    }
    {
      Id = "Melinoe_2219"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We're fortunate to have you both."
      Speaker = "Melinoe"
      Event = "OdysseusAboutSkelly01"
    }
    {
      Id = "Melinoe_2209"
      InheritFrom = "BaseNarrative"
      DisplayName = "Odysseus, have you ever seen Hypnos so much as shift in his sleep? I know he's been through a lot, but still..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutHypnos01"
    }
    {
      Id = "Odysseus_0151"
      InheritFrom = "BaseNarrative"
      DisplayName = "Can't say I have! Been just that way from the night the good witch got him. The snoring I became accustomed to eventually..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutHypnos01"
    }
    {
      Id = "Melinoe_2210"
      InheritFrom = "BaseNarrative"
      DisplayName = "Think he's ever going to wake? None of the incantations we've tried have had any effect."
      Speaker = "Melinoe"
      Event = "OdysseusAboutHypnos01"
    }
    {
      Id = "Odysseus_0152"
      InheritFrom = "BaseSubtitle"
      DisplayName = "He's Sleep itself, isn't he?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutHypnos01"
    }
    {
      Id = "Odysseus_0153"
      InheritFrom = "BaseNarrative"
      DisplayName = "So {#Emph}Doom {#Prev}has come to stay with us a bit? My last and only other brush with him did not resolve {#Emph}particularly {#Prev}well, so... I'll just keep my distance, if that's quite all right."
      Speaker = "Odysseus"
      Event = "OdysseusAboutMoros01"
    }
    {
      Id = "Melinoe_2211"
      InheritFrom = "BaseNarrative"
      DisplayName = "All children of Nyx are welcome in these Crossroads. Though I think Lord Moros wishes to keep {#Emph}his {#Prev}distance, too."
      Speaker = "Melinoe"
      Event = "OdysseusAboutMoros01"
    }
    {
      Id = "Odysseus_0154"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No objections here!"
      Speaker = "Odysseus"
      Event = "OdysseusAboutMoros01"
    }
    {
      Id = "Odysseus_0396"
      InheritFrom = "BaseNarrative"
      DisplayName = "I take it {#Emph}you're {#Prev}the reason Icarus is back. Always seemed like a good lad! I kept my mouth shut at the time but I was disappointed when he left."
      Speaker = "Odysseus"
      Event = "OdysseusAboutIcarus01"
    }
    {
      Id = "Melinoe_4508"
      InheritFrom = "BaseNarrative"
      DisplayName = "It was his choice to make. I think he always valued your experience as well. He didn't get to have adventures like you back when he was alive."
      Speaker = "Melinoe"
      Event = "OdysseusAboutIcarus01"
    }
    {
      Id = "Odysseus_0397"
      InheritFrom = "BaseNarrative"
      DisplayName = "Who does, Goddess? Though clearly he picked up some know-how whilst away. Even got {#Emph}wings {#Prev}to show for it! Think he might have an extra set?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutIcarus01"
    }
    {
      Id = "Melinoe_4509"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh I don't know..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutIcarus01"
    }
    {
      Id = "Odysseus_0393"
      InheritFrom = "BaseNarrative"
      DisplayName = "We've not too many Shades all the way out on the Olympus front, only a few brave souls. They're saying that you met Lady Athena face-to-face, how is she holding up?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutAthena01"
    }
    {
      Id = "Melinoe_4185"
      InheritFrom = "BaseNarrative"
      DisplayName = "Considering she's holding back great numbers of the Titan's forces single-handedly, she seems remarkably composed."
      Speaker = "Melinoe"
      Event = "OdysseusAboutAthena01"
    }
    {
      Id = "Odysseus_0394"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd ask you thank her for the times she may have saved my skin, but... discretion's for the best."
      Speaker = "Odysseus"
      Event = "OdysseusAboutAthena01"
    }
    {
      Id = "Melinoe_4186"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You sure I shouldn't say anything?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutAthena01"
    }
    {
      Id = "Odysseus_0395"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Aye."
      Speaker = "Odysseus"
      Event = "OdysseusAboutAthena01"
    }
    {
      Id = "Melinoe_3313"
      InheritFrom = "BaseNarrative"
      DisplayName = "During a recent voyage, I found Circe the Enchantress on her little isle, evidently safe from all the turmoil at sea. Don't you two know each other fairly well?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutCirce01"
    }
    {
      Id = "Odysseus_0261"
      InheritFrom = "BaseNarrative"
      DisplayName = "In life and death we can but strive to know each other well, Goddess.... Though I knew Circe... just a bit, at least; as casual acquaintances is all, why do you ask?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutCirce01"
    }
    {
      Id = "Melinoe_3314"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh just in case you wanted me to tell her anything when next we met, as she may be providing some assistance when I navigate the Rift of Thessaly."
      Speaker = "Melinoe"
      Event = "OdysseusAboutCirce01"
    }
    {
      Id = "Odysseus_0262"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, no need to tell her anything. Best keep your focus on the task at hand."
      Speaker = "Odysseus"
      Event = "OdysseusAboutCirce01"
    }
    {
      Id = "Melinoe_3315"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Noted."
      Speaker = "Melinoe"
      Event = "OdysseusAboutCirce01"
    }
    {
      Id = "Melinoe_3330"
      InheritFrom = "BaseNarrative"
      DisplayName = "Odysseus, what happened between you and Circe, anyhow? She mentioned you, said nothing in particular, except... I sensed some pain. There {#Emph}and {#Prev}here."
      Speaker = "Melinoe"
      Event = "OdysseusAboutCirce02"
    }
    {
      Id = "Odysseus_0263"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's not a pain entirely, Goddess. When I was whole, returning from a war, I found Circe and her isle, and... I lived there for about a year. She housed me and my men, and we grew close. I learned a lot from her, and then... we left."
      Speaker = "Odysseus"
      Event = "OdysseusAboutCirce02"
    }
    {
      Id = "Melinoe_3331"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your voyage home. You stopped for an entire year, then voyaged on and never saw her again..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutCirce02"
    }
    {
      Id = "Odysseus_0264"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, aye, until I saw her again here. It's just... it's in the past, and for the both of us, I think. Not every such relationship need last eternally."
      Speaker = "Odysseus"
      Event = "OdysseusAboutCirce02"
    }
    {
      Id = "Melinoe_3332"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I understand, I think..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutCirce02"
    }
    {
      Id = "Odysseus_0135"
      InheritFrom = "BaseNarrative"
      DisplayName = "We've multiple reports the armies of Chronos are massing on the surface up there, and not yet caught wind of your efforts. At least you aren't contending with {#Emph}them{#Prev}, aye?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutChronos01"
    }
    {
      Id = "Melinoe_2172"
      InheritFrom = "BaseNarrative"
      DisplayName = "My route through the Underworld is fraught in its own right, but yes, it's comforting to know that army of traitors remains ignorant of me."
      Speaker = "Melinoe"
      Event = "OdysseusAboutChronos01"
    }
    {
      Id = "Odysseus_0136"
      InheritFrom = "BaseNarrative"
      DisplayName = "There's not a downward route that's more discreet. Those thorny chaps in the woods, they've no love for Chronos either, at least."
      Speaker = "Odysseus"
      Event = "OdysseusAboutChronos01"
    }
    {
      Id = "Melinoe_2173"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll get past them."
      Speaker = "Melinoe"
      Event = "OdysseusAboutChronos01"
    }
    {
      Id = "Odysseus_0242"
      InheritFrom = "BaseNarrative"
      DisplayName = "You look as though you've seen a ghost, if you'll forgive the very antiquated mortal turn-of-phrase, Goddess. So we'd say to someone looking disconcerted. Things all right?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutChronosAnomaly01"
    }
    {
      Id = "Melinoe_3304"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes and no; I saw Chronos out there. I thought he had me, but I broke free from his spell. This was in Oceanus, though I also caught him snooping near the pathways out of Erebus."
      Speaker = "Melinoe"
      Event = "OdysseusAboutChronosAnomaly01"
    }
    {
      Id = "Odysseus_0243"
      InheritFrom = "BaseNarrative"
      DisplayName = "Damn it... our reports said nothing of the sort, but then... some of our Shade informants haven't yet returned. We had expected Chronos to stay put in the lowest reaches. You must have caused enough of a stir to catch his notice."
      Speaker = "Odysseus"
      Event = "OdysseusAboutChronosAnomaly01"
    }
    {
      Id = "Melinoe_3305"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've hardly been discreet in my approach. Is there truly no other way?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutChronosAnomaly01"
    }
    {
      Id = "Odysseus_0244"
      InheritFrom = "BaseNarrative"
      DisplayName = "We reckon not. We're counting on him thinking you're inconsequential to his plans. As for our own, I shall go over this with the good witch. Be safe, and cheers for the report."
      Speaker = "Odysseus"
      Event = "OdysseusAboutChronosAnomaly01"
    }
    {
      Id = "Melinoe_3306"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Of course."
      Speaker = "Melinoe"
      Event = "OdysseusAboutChronosAnomaly01"
    }
    {
      Id = "Odysseus_0161"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got a most troubling report, a sighting in the pathways on the outskirts of Erebus. Did our eyes out there see true?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutChronos02"
    }
    {
      Id = "Melinoe_2216"
      InheritFrom = "BaseNarrative"
      DisplayName = "If it's Chronos that they saw, then yes. Now at least I know what he looks like; but he knows {#Emph}me{#Prev}, in turn. Why do you think he let me go? Have we been compromised?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutChronos02"
    }
    {
      Id = "Odysseus_0162"
      InheritFrom = "BaseNarrative"
      DisplayName = "No one gets into the Crossroads whom we don't permit, or can even know we're here... not even him. So he's sniffing around? Fine. He wastes {#Emph}his {#Prev}time whilst {#Emph}you {#Prev}get closer to your mark."
      Speaker = "Odysseus"
      Event = "OdysseusAboutChronos02"
    }
    {
      Id = "Melinoe_2217"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Is he even capable of wasting time...?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutChronos02"
    }
    {
      Id = "Odysseus_0228"
      InheritFrom = "BaseNarrative"
      DisplayName = "You got him, didn't you? Killed the bastard, for... one night, at least. The first report I heard, I scarce believed, but by the third or fourth, I'd come around. {#Emph}Well done{#Prev}, Goddess!"
      Speaker = "Odysseus"
      Event = "OdysseusAboutChronosBossW01"
    }
    {
      Id = "Melinoe_2967"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd not be surprised if our reports already say he's returned. But I got what I needed for now. And a little bit of payback, I suppose."
      Speaker = "Melinoe"
      Event = "OdysseusAboutChronosBossW01"
    }
    {
      Id = "Odysseus_0229"
      InheritFrom = "BaseNarrative"
      DisplayName = "Aye, and he'll be sore about it, I expect, but... even though we're not there yet... we needed this, I think. {#Emph}You {#Prev}needed this. On to the next phase then?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutChronosBossW01"
    }
    {
      Id = "Melinoe_2968"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, yes."
      Speaker = "Melinoe"
      Event = "OdysseusAboutChronosBossW01"
    }
    {
      Id = "Odysseus_0230"
      InheritFrom = "BaseNarrative"
      DisplayName = "You found him, Goddess... your look says it all, along with my reports. Gave him something to remember you by, I reckon, even if the battle didn't go your way..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutChronosBossL01"
    }
    {
      Id = "Melinoe_3094"
      InheritFrom = "BaseNarrative"
      DisplayName = "Chronos was exactly where we expected... but I could not foresee his every technique. And my ability to withstand his magick went only so far."
      Speaker = "Melinoe"
      Event = "OdysseusAboutChronosBossL01"
    }
    {
      Id = "Odysseus_0231"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, fortunately for you, the old are often rather slow to learn. You run into him a few more times like that, you'll soon know every trick he's got. Though... do be very careful out there, aye?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutChronosBossL01"
    }
    {
      Id = "Melinoe_3095"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Aye..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutChronosBossL01"
    }
    {
      Id = "Odysseus_0420"
      InheritFrom = "BaseNarrative"
      DisplayName = "Our Shades have proved unable to approach the House of Hades, so they've no reports about the way the Titan fights. I'm afraid you're on your own for that one, Goddess..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutChronosBossTactics01"
    }
    {
      Id = "Melinoe_4211"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh I can give you a report myself. He looks rather frail, but he's quick. His scythe has significant reach, and he can freeze me at a moment's notice, but only for so long. And his forces are present to ensure I'm outnumbered."
      Speaker = "Melinoe"
      Event = "OdysseusAboutChronosBossTactics01"
    }
    {
      Id = "Odysseus_0421"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Freeze you... {#Prev}meaning he tries to stop you using {#Emph}time{#Prev}, but can't hold you for long. Just as the good witch thought then, aye? It means his power over you is limited; {#Emph}you're {#Prev}the one that can't be stopped, not {#Emph}him."
      Speaker = "Odysseus"
      Event = "OdysseusAboutChronosBossTactics01"
    }
    {
      Id = "Melinoe_4212"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It hasn't felt that way to me as yet."
      Speaker = "Melinoe"
      Event = "OdysseusAboutChronosBossTactics01"
    }
    {
      Id = "Odysseus_0384"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've {#Emph}Typhon {#Prev}to contend with on that mountaintop, Goddess...? Our Shades say he's near the size of a mountain himself... please tell me that's hyperbole on their part?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutTyphon01"
    }
    {
      Id = "Melinoe_4109"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well to put it in perspective... by my estimation, he's at least a hundred times the size of Polyphemus. Though I've not had the opportunity to take his measure properly."
      Speaker = "Melinoe"
      Event = "OdysseusAboutTyphon01"
    }
    {
      Id = "Odysseus_0385"
      InheritFrom = "BaseNarrative"
      DisplayName = "You'll take his measure yet, I reckon. It's what you've done with every other foe you've faced thus far! Our Shades and the good witch think it unwise to take on such a threat yourself, but... you're not planning to back down, are you."
      Speaker = "Odysseus"
      Event = "OdysseusAboutTyphon01"
    }
    {
      Id = "Melinoe_4110"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No."
      Speaker = "Melinoe"
      Event = "OdysseusAboutTyphon01"
    }
    {
      Id = "Odysseus_0386"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Good."
      Speaker = "Odysseus"
      Event = "OdysseusAboutTyphon01"
    }
    {
      Id = "Melinoe_4230"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well to put it in perspective... by my estimation, he's more than a hundred times the size of a Cyclops. Though I've not had the opportunity to take his measure properly."
      Speaker = "Melinoe"
      Event = "OdysseusAboutTyphon01_B"
    }
    {
      Id = "Odysseus_0387"
      InheritFrom = "BaseNarrative"
      DisplayName = "The good witch has been quite concerned about your confrontations with Typhon. Reckon you never trained to take opponents of {#Emph}that {#Prev}size."
      Speaker = "Odysseus"
      Event = "OdysseusAboutTyphonL01"
    }
    {
      Id = "Melinoe_4111"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh I trained just last night. Typhon is immensely strong, and large enough to blot out the light of the Moon, but evidently {#Emph}not {#Prev}invincible. They say Lord Zeus defeated him before."
      Speaker = "Melinoe"
      Event = "OdysseusAboutTyphonL01"
    }
    {
      Id = "Odysseus_0388"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}They {#Prev}say a lot of things, Goddess; I'm far more interested in {#Emph}your {#Prev}account. If it's your instinct that this monster can be stopped, your word is good enough for me. Though I would... also love to see some {#Emph}proof{#Prev}, of course."
      Speaker = "Odysseus"
      Event = "OdysseusAboutTyphonL01"
    }
    {
      Id = "Melinoe_4112"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Of course."
      Speaker = "Melinoe"
      Event = "OdysseusAboutTyphonL01"
    }
    {
      Id = "Odysseus_0389"
      InheritFrom = "BaseNarrative"
      DisplayName = "You felled that mountain-sized monstrosity, Goddess...! It would be false of me to say I had no doubt you {#Emph}would{#Prev}, though... I'd only a bit, I swear. So, how did you outsmart him?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutTyphonW01"
    }
    {
      Id = "Melinoe_4113"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Outsmart {#Prev}him? All I could do was keep hitting him with all my might. It helped that Lord Zeus also struck him hard with lightning bolts. Eventually it worked, and Typhon fell."
      Speaker = "Melinoe"
      Event = "OdysseusAboutTyphonW01"
    }
    {
      Id = "Odysseus_0390"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well! Your battle prowess may be unsurpassed, but your ability to weave a yarn is... not {#Emph}quite {#Prev}there. When next you overcome the Father of All Monsters, do make of it a much more rousing tale, would you?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutTyphonW01"
    }
    {
      Id = "Melinoe_4114"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...No promises."
      Speaker = "Melinoe"
      Event = "OdysseusAboutTyphonW01"
    }
    {
      Id = "Odysseus_0391"
      InheritFrom = "BaseNarrative"
      DisplayName = "So there you were! Alone, atop the rain-soaked mountain... when out of the dark came a roar so deafening it shook Olympus to its roots. And with it came Typhon himself, more vengeful even than before...! What then, Goddess?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutTyphonW02"
    }
    {
      Id = "Melinoe_4115"
      InheritFrom = "BaseNarrative"
      DisplayName = "We fought. I prevailed. Oh, blast... I was supposed to weave a yarn. {#Emph}Erm{#Prev}, he kept trying to crush me with his {#Emph}chin... {#Prev}but I evaded, and clambered to the top of his head, where I drove the Sister Blades Lim and Oros into his {#Emph}brain!"
      Speaker = "Melinoe"
      Event = "OdysseusAboutTyphonW02"
    }
    {
      Id = "Odysseus_0392"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, quite gruesome at the end there, I {#Emph}like {#Prev}it! My only criticism, if I may, is that... all too many tales involving huge monstrosities resolve that way. {#Emph}Erm{#Prev}, what if... he were to swallow you whole? Only for you to cut yourself out of his gullet?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutTyphonW02"
    }
    {
      Id = "Melinoe_4116"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I was just getting to that part!"
      Speaker = "Melinoe"
      Event = "OdysseusAboutTyphonW02"
    }
    {
      Id = "Odysseus_0592"
      InheritFrom = "BaseNarrative"
      DisplayName = "How are you holding up, Goddess...? My instinct is to {#Emph}celebrate {#Prev}the death of Typhon, but... I never forgot the first man I slew. How the light left his eyes..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutTyphonDeath01"
    }
    {
      Id = "Melinoe_5050"
      InheritFrom = "BaseNarrative"
      DisplayName = "Typhon sought destruction, and he got it. I won't rejoice in the outcome, but won't lament it either. Especially when there's more left to be done."
      Speaker = "Melinoe"
      Event = "OdysseusAboutTyphonDeath01"
    }
    {
      Id = "Odysseus_0593"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have the right approach. You'll have time to recount every choice and consequence when all of this is over, but for now... best to press on and finish what you started."
      Speaker = "Odysseus"
      Event = "OdysseusAboutTyphonDeath01"
    }
    {
      Id = "Melinoe_5051"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I intend to."
      Speaker = "Melinoe"
      Event = "OdysseusAboutTyphonDeath01"
    }
    {
      Id = "Odysseus_0588"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your goal is within reach, Goddess, that much I know just from how tense the good witch seems to be of late... not to pry but are you clear about what more needs to be done?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutUltimateProgress01"
    }
    {
      Id = "Melinoe_5048"
      InheritFrom = "BaseNarrative"
      DisplayName = "I believe so. I'd be inclined to tell you all of it, except you know how Headmistress gets about these things. Suffice it to say that the final phase of our plan is in progress."
      Speaker = "Melinoe"
      Event = "OdysseusAboutUltimateProgress01"
    }
    {
      Id = "Odysseus_0589"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's all I need to hear. This phase is up to you and her. For my part, it seems you're able to get to where you need to be consistently enough."
      Speaker = "Odysseus"
      Event = "OdysseusAboutUltimateProgress01"
    }
    {
      Id = "Melinoe_5049"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yes. Thank you for charting my course."
      Speaker = "Melinoe"
      Event = "OdysseusAboutUltimateProgress01"
    }
    {
      Id = "Odysseus_0590"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Anytime."
      Speaker = "Odysseus"
      Event = "OdysseusAboutUltimateProgress01"
    }
    {
      Id = "Odysseus_0594"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not seen the good witch recently, have you, Goddess? You'd tell me if there was any reason for concern...?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutHecateKidnapped01"
    }
    {
      Id = "Melinoe_5052"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No need to worry about a thing."
      Speaker = "Melinoe"
      Event = "OdysseusAboutHecateKidnapped01"
    }
    {
      Id = "Odysseus_0172"
      InheritFrom = "BaseNarrative"
      DisplayName = "How's life of late down at the bottom of the sea? All sorts of nastiness lurking there, {#Emph}that {#Prev}the reports make clear. I wager you've seen some things."
      Speaker = "Odysseus"
      Event = "OdysseusAboutScylla01"
    }
    {
      Id = "Melinoe_2181"
      InheritFrom = "BaseNarrative"
      DisplayName = "You'd win that wager handily. The worst of them has to be this sea-monstress called Scylla, and her Siren friends. They have this ridiculous act..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutScylla01"
    }
    {
      Id = "Odysseus_0173"
      InheritFrom = "BaseNarrative"
      DisplayName = "What, Scylla's still around? With the Sirens, no less, {#Emph}hah! {#Prev}It's a wonder you made it back. Please tell me you didn't listen to a word they sang?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutScylla01"
    }
    {
      Id = "Melinoe_2182"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, I heard an earful."
      Speaker = "Melinoe"
      Event = "OdysseusAboutScylla01"
    }
    {
      Id = "Odysseus_0174"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ungh..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutScylla01"
    }
    {
      Id = "Odysseus_0175"
      InheritFrom = "BaseNarrative"
      DisplayName = "I once was desperate to hear the Sirens' song... I barely resisted their temptations; of course I was... merely mortal. Perhaps you're less susceptible to their allure."
      Speaker = "Odysseus"
      Event = "OdysseusAboutScylla02"
    }
    {
      Id = "Melinoe_2183"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps. At any rate I fail to see the appeal. Although, it's possible the Sirens were better off without Scylla. She seems rather bossy..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutScylla02"
    }
    {
      Id = "Odysseus_0176"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh she's a menace. Caught half a dozen of my crew like she'd a separate set of teeth for each of the poor lads. We'd little choice but to pray to the gods, and sail on. Tell her hello for me!"
      Speaker = "Odysseus"
      Event = "OdysseusAboutScylla02"
    }
    {
      Id = "Melinoe_2184"
      InheritFrom = "BaseNarrative"
      DisplayName = "Did the gods answer your call at least?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutScylla02"
    }
    {
      Id = "Odysseus_0177"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Erm{#Prev}, for the most part!"
      Speaker = "Odysseus"
      Event = "OdysseusAboutScylla02"
    }
    {
      Id = "Melinoe_2202_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've seen you here alone more often lately, Odysseus. You're thinking about your family, aren't you? Some potent memory from your past."
      Speaker = "Melinoe"
      Event = "OdysseusAboutScylla03"
    }
    {
      Id = "Odysseus_0195"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, Goddess, you may see through most of us Shades, but your empathy for me's a bit... misplaced. Penelope, Telemachus, and I... we're cordial with each other still, but... how to say this without sounding callous..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutScylla03"
    }
    {
      Id = "Melinoe_2203"
      InheritFrom = "BaseNarrative"
      DisplayName = "Please speak your mind with me. I'm certain you're not callous."
      Speaker = "Melinoe"
      Event = "OdysseusAboutScylla03"
    }
    {
      Id = "Odysseus_0232"
      InheritFrom = "BaseNarrative"
      DisplayName = "...My mind wanders not to matters of family, but... to the Sirens' blasted song. I scarce got to hear it even once, whilst navigating through their waters. I wanted {#Emph}desperately {#Prev}to cast myself into the sea, just for a better listen..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutScylla03"
    }
    {
      Id = "Melinoe_2204"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Sirens' song? You can't expect me to believe that Scylla's incessant drivel is the source of the Great Tactician's concerns of late?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutScylla03"
    }
    {
      Id = "Odysseus_0197"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now, now, spare me the ridicule, I'm dead serious about this. You weren't with me on the surface there and wouldn't understand..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutScylla03"
    }
    {
      Id = "Melinoe_2205"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Seemingly not..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutScylla03"
    }
    {
      Id = "Melinoe_2206"
      InheritFrom = "BaseNarrative"
      DisplayName = "When last we spoke in the taverna, I didn't mean to shame you for your musical tastes. I just had no idea that Scylla could be taken seriously by anybody... much less you."
      Speaker = "Melinoe"
      Event = "OdysseusAboutScylla04"
    }
    {
      Id = "Odysseus_0233"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, think nothing of it. Siren music's an {#Emph}acquired taste... {#Prev}acquired by all those who sailed in their vicinity whilst I was whole. {#Emph}Incessant drivel{#Prev}, though, that's all you think it is?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutScylla04"
    }
    {
      Id = "Melinoe_2207"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, perhaps I was a bit uncharitable in my assessment, it's just... I have trouble separating my disdain for the performer from the quality of her craft."
      Speaker = "Melinoe"
      Event = "OdysseusAboutScylla04"
    }
    {
      Id = "Odysseus_0199"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It must be very catchy, aye?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutScylla04"
    }
    {
      Id = "Melinoe_2208"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Aye..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutScylla04"
    }
    {
      Id = "Melinoe_5248"
      InheritFrom = "BaseNarrative"
      DisplayName = "Were you aware that Scylla and Charybdis had teamed up?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutScyllaAltFight01"
    }
    {
      Id = "Odysseus_0626"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh you could certainly say that. Why do you ask?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutScyllaAltFight01"
    }
    {
      Id = "Melinoe_5249"
      InheritFrom = "BaseNarrative"
      DisplayName = "I caught their latest performance. It was quite a spectacle to say the least. You could have forewarned me that the two were working in concert!"
      Speaker = "Melinoe"
      Event = "OdysseusAboutScyllaAltFight01"
    }
    {
      Id = "Odysseus_0627"
      InheritFrom = "BaseNarrative"
      DisplayName = "Goddess, forgive me, but I thought it was quite common knowledge that Scylla and Charybdis were collaborating... it's not a new development at all."
      Speaker = "Odysseus"
      Event = "OdysseusAboutScyllaAltFight01"
    }
    {
      Id = "Melinoe_5250"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Perhaps I merely missed the news."
      Speaker = "Melinoe"
      Event = "OdysseusAboutScyllaAltFight01"
    }
    {
      Id = "Odysseus_0628"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I don't see how you could have..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutScyllaAltFight01"
    }
    {
      Id = "Melinoe_5246"
      InheritFrom = "BaseNarrative"
      DisplayName = "Scylla mentioned something about a potential sponsor in the audience of one of her shows, Odysseus. Do you have any idea who that could be? I thought it might be Chronos, but can't imagine him listening to her music."
      Speaker = "Melinoe"
      Event = "OdysseusAboutScyllaSponsor01"
    }
    {
      Id = "Odysseus_0624"
      InheritFrom = "BaseNarrative"
      DisplayName = "A potential sponsor... that's not come up in our reports, though I'll review and let you know if anything turns up. Probably just some old sailor who got an earful and couldn't let it go. Do you know what this sponsorship entails?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutScyllaSponsor01"
    }
    {
      Id = "Melinoe_5247"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Probably more of her nightly shows."
      Speaker = "Melinoe"
      Event = "OdysseusAboutScyllaSponsor01"
    }
    {
      Id = "Odysseus_0625"
      InheritFrom = "BaseSubtitle"
      DisplayName = "She's having quite a run..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutScyllaSponsor01"
    }
    {
      Id = "Odysseus_0418"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sirens proving to be quite the hindrance, aren't they. Our Shades have intermingled with the crowd of onlookers surrounding them, and have some observations to impart."
      Speaker = "Odysseus"
      Event = "OdysseusAboutScyllaTactics01"
    }
    {
      Id = "Melinoe_4209"
      InheritFrom = "BaseNarrative"
      DisplayName = "About what, my repeated failures to overcome a deranged musical troupe despite intensive lifelong training in both magickal and martial ways?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutScyllaTactics01"
    }
    {
      Id = "Odysseus_0419"
      InheritFrom = "BaseNarrative"
      DisplayName = "No need to stand in your own way, Goddess. With Scylla and the Sirens, you are up against three foes at once. The percussionist is stuck in place but presents a significant threat. Our Shades suggest dealing with that one first."
      Speaker = "Odysseus"
      Event = "OdysseusAboutScyllaTactics01"
    }
    {
      Id = "Melinoe_4210"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll give it a shot."
      Speaker = "Melinoe"
      Event = "OdysseusAboutScyllaTactics01"
    }
    {
      Id = "Odysseus_0398"
      InheritFrom = "BaseNarrative"
      DisplayName = "That music... I'd recognize it anywhere! Even without the words. And here I thought I must have been the sole admirer of Siren songs in all the Crossroads."
      Speaker = "Odysseus"
      Event = "OdysseusAboutScyllaSong01"
    }
    {
      Id = "Melinoe_4187"
      InheritFrom = "BaseNarrative"
      DisplayName = "I... just wanted to see if our Music Maker even knew that particular piece. Perhaps it shouldn't be permitted here. Especially if it has insidious power over men's hearts."
      Speaker = "Melinoe"
      Event = "OdysseusAboutScyllaSong01"
    }
    {
      Id = "Odysseus_0399"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh {#Prev}I think we dead men are no longer as susceptible. Though I'd best give it another listen, just to be certain."
      Speaker = "Odysseus"
      Event = "OdysseusAboutScyllaSong01"
    }
    {
      Id = "Melinoe_4188"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Let me know if it becomes distracting."
      Speaker = "Melinoe"
      Event = "OdysseusAboutScyllaSong01"
    }
    {
      Id = "Odysseus_0254"
      InheritFrom = "BaseNarrative"
      DisplayName = "A word of caution, Goddess, in regard to an impediment you may confront when finally you reach the far end of the Mourning Fields. Reports suggest it's some sort of infernal beast... a big one. Our Shades had to stay very far away."
      Speaker = "Odysseus"
      Event = "OdysseusAboutCerberus01"
    }
    {
      Id = "Melinoe_3324"
      InheritFrom = "BaseNarrative"
      DisplayName = "We knew there was a secure entrance into Tartarus around that point... this beast must be how come the tunnel stays secure. Have we any details?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutCerberus01"
    }
    {
      Id = "Odysseus_0255"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well it has several fire-spitting maws, allegedly, which troublingly fits the profile of your father's household pet. Though, if this really is the case... may it simply let you pass!"
      Speaker = "Odysseus"
      Event = "OdysseusAboutCerberus01"
    }
    {
      Id = "Melinoe_3325"
      InheritFrom = "BaseNarrative"
      DisplayName = "What, you mean Cerberus himself guards the entrance to Tartarus? Why would he do the bidding of Chronos? Impossible."
      Speaker = "Melinoe"
      Event = "OdysseusAboutCerberus01"
    }
    {
      Id = "Odysseus_0256"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The reports are inconclusive, but I thought you should know."
      Speaker = "Odysseus"
      Event = "OdysseusAboutCerberus01"
    }
    {
      Id = "Melinoe_3326"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can corroborate our Shades' reports. And add that this infernal beast is none other than Cerberus, my father's household pet... acting on instinct and pure rage."
      Speaker = "Melinoe"
      Event = "OdysseusAboutCerberus01_B"
    }
    {
      Id = "Odysseus_0257"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ahh{#Prev}, I feared as much. For they said the beast had several fire-spitting maws. I don't suppose he recognized you after all this time, and... let you pass...?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutCerberus01_B"
    }
    {
      Id = "Melinoe_3327"
      InheritFrom = "BaseSubtitle"
      DisplayName = "He did neither of those things. I have to help him."
      Speaker = "Melinoe"
      Event = "OdysseusAboutCerberus01_B"
    }
    {
      Id = "Odysseus_0129"
      InheritFrom = "BaseNarrative"
      DisplayName = "With your Olympus-dwelling relatives assisting you, I've half a mind to ask you to let them know I'm on your side, except... not all of them love me."
      Speaker = "Odysseus"
      Event = "OdysseusAboutPoseidon01"
    }
    {
      Id = "Melinoe_0478"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}What? {#Prev}But you're the Great Tactician, Odysseus! Even the gods were impressed with your machinations in your glory days."
      Speaker = "Melinoe"
      Event = "OdysseusAboutPoseidon01"
    }
    {
      Id = "Odysseus_0130"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lady Athena and others favored me, it's true, but your uncle Poseidon, well... I got on his bad side, I believe. Maybe he's let it go after all this time but that's a risk I'm not prepared to take, so {#Emph}erm{#Prev}, keep quiet about me, would you?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutPoseidon01"
    }
    {
      Id = "Melinoe_0479"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I hear you."
      Speaker = "Melinoe"
      Event = "OdysseusAboutPoseidon01"
    }
    {
      Id = "Odysseus_0204"
      InheritFrom = "BaseNarrative"
      DisplayName = "So, there's a bit of a new wrinkle in our plans. We've been able to verify some of the details that Master Hermes suggested to you, about what's... brewing on the surface."
      Speaker = "Odysseus"
      Event = "OdysseusAboutHermes01"
    }
    {
      Id = "Melinoe_2223"
      InheritFrom = "BaseNarrative"
      DisplayName = "Please tell me what you may... and if you think it wise for me to deviate from my objective to address whatever's going on up there."
      Speaker = "Melinoe"
      Event = "OdysseusAboutHermes01"
    }
    {
      Id = "Odysseus_0205"
      InheritFrom = "BaseNarrative"
      DisplayName = "The forces of Chronos gather to sail on Olympus through a channel cut across the land. You're poised to disrupt the enemy ranks from within. Aid Olympus, and your chances against Chronos may improve."
      Speaker = "Odysseus"
      Event = "OdysseusAboutHermes01"
    }
    {
      Id = "Melinoe_2224"
      InheritFrom = "BaseNarrative"
      DisplayName = "The warded pathway leading up should drop me right into the heart of our foe's forward garrison. It seems so reckless..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutHermes01"
    }
    {
      Id = "Odysseus_0206"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Call it a calculated risk."
      Speaker = "Odysseus"
      Event = "OdysseusAboutHermes01"
    }
    {
      Id = "Melinoe_2189"
      InheritFrom = "BaseNarrative"
      DisplayName = "When was the last reported sighting of a Root-Stalker out in the woods?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutTreant01"
    }
    {
      Id = "Odysseus_0190"
      InheritFrom = "BaseNarrative"
      DisplayName = "See, that's the sort of inquiry I'd expect from somebody who sighted a Root-Stalker out in the woods very, very recently. So there's still something rotten in Erebus, then?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutTreant01"
    }
    {
      Id = "Melinoe_2190"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Unfortunately, yes."
      Speaker = "Melinoe"
      Event = "OdysseusAboutTreant01"
    }
    {
      Id = "Odysseus_0188"
      InheritFrom = "BaseNarrative"
      DisplayName = "What was the source of your misfortune, that you're back with such a scowl? Some Wailers, or Caskets, perhaps? Oh... a {#Emph}Shadow-Spiller."
      Speaker = "Odysseus"
      Event = "OdysseusAboutFogEmitter01"
    }
    {
      Id = "Melinoe_2187"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes, a Shadow-Spiller. I lost my way against one. Can hardly see a thing when they're about! I should be stronger than this..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutFogEmitter01"
    }
    {
      Id = "Odysseus_0189"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've strength enough. They merely test your nerve. Foes such as that are to be faced head-on, no hesitation. Set for another go?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutFogEmitter01"
    }
    {
      Id = "Melinoe_2188"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I am."
      Speaker = "Melinoe"
      Event = "OdysseusAboutFogEmitter01"
    }
    {
      Id = "Odysseus_0191"
      InheritFrom = "BaseNarrative"
      DisplayName = "Heard reports you were proceeding well through Oceanus, but evidently they were not up-to-date. What brings you back, Goddess?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutWaterUnitMiniboss01"
    }
    {
      Id = "Melinoe_2191"
      InheritFrom = "BaseNarrative"
      DisplayName = "A Sea-Serpent, if you must know. A particularly substantial one caught me out. You ever face them in your mortal voyages?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutWaterUnitMiniboss01"
    }
    {
      Id = "Odysseus_0192"
      InheritFrom = "BaseNarrative"
      DisplayName = "I did, aye. But not alone! Even with my shipmates, seasoned veterans all, we scarce could track the slippery bastards darting out of the waters. {#Emph}Erm{#Prev}, not reassuring, is this?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutWaterUnitMiniboss01"
    }
    {
      Id = "Melinoe_2192"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not entirely."
      Speaker = "Melinoe"
      Event = "OdysseusAboutWaterUnitMiniboss01"
    }
    {
      Id = "Odysseus_0193"
      InheritFrom = "BaseNarrative"
      DisplayName = "Goddess, latest reports said you encountered the King Vermin! Don't care if you're immortal, I'm relieved you made it back in one piece..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutVerminMiniboss01"
    }
    {
      Id = "Melinoe_2193"
      InheritFrom = "BaseNarrative"
      DisplayName = "It can't be. I did confront a rodent of extraordinary savagery, but it was so little! I assumed the King Vermin was huge."
      Speaker = "Melinoe"
      Event = "OdysseusAboutVerminMiniboss01"
    }
    {
      Id = "Odysseus_0194"
      InheritFrom = "BaseNarrative"
      DisplayName = "Tall tales. The King Vermin's wrath is inversely proportional to its stature. And its stature, as I understand, is very small indeed..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutVerminMiniboss01"
    }
    {
      Id = "Melinoe_2194"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Brr..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutVerminMiniboss01"
    }
    {
      Id = "Odysseus_0403"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's swarming season for the Hellifish in Oceanus, as you may have seen. Should you run into them, advice is not to bother much with smaller ones but get the {#Emph}biggest {#Prev}one."
      Speaker = "Odysseus"
      Event = "OdysseusAboutOctofish01"
    }
    {
      Id = "Melinoe_4191"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd rather not bother with any of them and all their stinging. How long do swarming seasons typically go on?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutOctofish01"
    }
    {
      Id = "Odysseus_0404"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, {#Emph}season {#Prev}is a bit of a misnomer, as the current season started back when I was just a lad. The good news is you get accustomed to the stinging after a while!"
      Speaker = "Odysseus"
      Event = "OdysseusAboutOctofish01"
    }
    {
      Id = "Melinoe_4192"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Wonderful."
      Speaker = "Melinoe"
      Event = "OdysseusAboutOctofish01"
    }
    {
      Id = "Odysseus_0288"
      InheritFrom = "BaseNarrative"
      DisplayName = "Found yourself a Phantom Lair in the Fields, if my Shades down there are still to be believed. Blood-sucking bastards... the {#Emph}Phantoms{#Prev}, not the Shades."
      Speaker = "Odysseus"
      Event = "OdysseusAboutVampire01"
    }
    {
      Id = "Melinoe_3347"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't such creatures usually stalk the surface in their search of {#Emph}living {#Prev}prey? They must go rather hungry in the Underworld."
      Speaker = "Melinoe"
      Event = "OdysseusAboutVampire01"
    }
    {
      Id = "Odysseus_0289"
      InheritFrom = "BaseNarrative"
      DisplayName = "Better {#Emph}that {#Prev}than burn under the break of day, or so they figure, probably. Well, you know what they're after next you meet again."
      Speaker = "Odysseus"
      Event = "OdysseusAboutVampire01"
    }
    {
      Id = "Melinoe_3348"
      InheritFrom = "BaseSubtitle"
      DisplayName = "They won't get it."
      Speaker = "Melinoe"
      Event = "OdysseusAboutVampire01"
    }
    {
      Id = "Odysseus_0286"
      InheritFrom = "BaseNarrative"
      DisplayName = "Can you confirm a sighting of Queen Lamia down in the Mourning Fields, Goddess? I'd caution you to watch for signs of slithering about, except I reckon I may be too late..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutLamia01"
    }
    {
      Id = "Melinoe_3346"
      InheritFrom = "BaseNarrative"
      DisplayName = "I must have drawn her out of her den, yes. That or I barged into it, but either way, her magick proved too much for me last night..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutLamia01"
    }
    {
      Id = "Odysseus_0287"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Too much even for {#Emph}you? {#Prev}Nay."
      Speaker = "Odysseus"
      Event = "OdysseusAboutLamia01"
    }
    {
      Id = "Odysseus_0290"
      InheritFrom = "BaseNarrative"
      DisplayName = "They sent the {#Emph}Verminancer {#Prev}after you, Goddess? We know that Satyr by no other title, nor of any others of that size. He's one of the Titan Lord's high priests!"
      Speaker = "Odysseus"
      Event = "OdysseusAboutRatCatcher01"
    }
    {
      Id = "Melinoe_3349"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then the Titan Lord shall soon have one {#Emph}fewer {#Prev}high priest."
      Speaker = "Melinoe"
      Event = "OdysseusAboutRatCatcher01"
    }
    {
      Id = "Odysseus_0291"
      InheritFrom = "BaseNarrative"
      DisplayName = "Even if you take him, our reports say that he cannot {#Emph}truly {#Prev}die. A gift from Chronos, in exchange for performing the ritual that brought him back..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutRatCatcher01"
    }
    {
      Id = "Melinoe_3350"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I can at least test the veracity of our reports."
      Speaker = "Melinoe"
      Event = "OdysseusAboutRatCatcher01"
    }
    {
      Id = "Melinoe_3351"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not the report I wished to deliver, though I've some idea of what Chronos has been doing with all of his excess Gold... I was trounced last night by a gigantic bag of coins."
      Speaker = "Melinoe"
      Event = "OdysseusAboutGoldElemental01"
    }
    {
      Id = "Odysseus_0292"
      InheritFrom = "BaseNarrative"
      DisplayName = "A {#Emph}Goldwrath{#Prev}, then! I reckon if you're Chronos, and you've got a limitless supply of shiny metal... might as well use some of them for your profane research. {#Emph}Ah{#Prev}, but you were close..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutGoldElemental01"
    }
    {
      Id = "Melinoe_3352"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That I was..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutGoldElemental01"
    }
    {
      Id = "Odysseus_0247"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not sighted Chronos on the surface yet. Why risk it when you've got bloodthirsty Satyrs serving as your eyes and ears? His forces are more organized than first they seemed."
      Speaker = "Odysseus"
      Event = "OdysseusAboutSatyrCrossbow01"
    }
    {
      Id = "Melinoe_3320"
      InheritFrom = "BaseNarrative"
      DisplayName = "I just had an unfortunate run-in with one of those Satyrs. Well-armed, well-trained... and Chronos has entire legions."
      Speaker = "Melinoe"
      Event = "OdysseusAboutSatyrCrossbow01"
    }
    {
      Id = "Odysseus_0248"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hrm{#Prev}, this is the war they've sought ever since the gods put Chronos in the ground. The promise of the Titan's return; immortality and untold riches..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutSatyrCrossbow01"
    }
    {
      Id = "Melinoe_3321"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Lies."
      Speaker = "Melinoe"
      Event = "OdysseusAboutSatyrCrossbow01"
    }
    {
      Id = "Odysseus_0299"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Most likely, aye."
      Speaker = "Odysseus"
      Event = "OdysseusAboutSatyrCrossbow01"
    }
    {
      Id = "Melinoe_3316"
      InheritFrom = "BaseNarrative"
      DisplayName = "I must admit, on some occasion all the tales you told about the sea-monster Charybdis felt almost beyond belief. Now having faced the blasted thing, I feel you sold it short."
      Speaker = "Melinoe"
      Event = "OdysseusAboutCharybdis01"
    }
    {
      Id = "Odysseus_0410"
      InheritFrom = "BaseNarrative"
      DisplayName = "What, faced Charybdis? {#Emph}Ah{#Prev}, Goddess. I'd heard reports about some sort of whirlpool within Poseidon's Rift and now my fear's confirmed. At least she didn't swallow you outright...!"
      Speaker = "Odysseus"
      Event = "OdysseusAboutCharybdis01"
    }
    {
      Id = "Melinoe_4199"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Any practical advice on how to deal with her?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutCharybdis01"
    }
    {
      Id = "Odysseus_0411"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Avoid her at all costs?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutCharybdis01"
    }
    {
      Id = "Odysseus_0412"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps I could have offered more-creative ways of navigating past Charybdis in your voyages when last we spoke of her. I realize sailing around may not be possible..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutCharybdis02"
    }
    {
      Id = "Melinoe_4200"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, it is not. I thought the main threat was to fall into that maw of hers... but I've found that her many thrashing arms or tentacles present more of a problem."
      Speaker = "Melinoe"
      Event = "OdysseusAboutCharybdis02"
    }
    {
      Id = "Odysseus_0413"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then worry about {#Emph}them. {#Prev}Perhaps you could isolate a couple at a time, use whatever space you have to keep moving. Poke her in the arms enough and she ought to back off."
      Speaker = "Odysseus"
      Event = "OdysseusAboutCharybdis02"
    }
    {
      Id = "Melinoe_4201"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I can relate to that."
      Speaker = "Melinoe"
      Event = "OdysseusAboutCharybdis02"
    }
    {
      Id = "Odysseus_0405"
      InheritFrom = "BaseNarrative"
      DisplayName = "Some of the drowned sailors whom you face up there whilst sailing through Poseidon's Rift were probably once men I used to know... not that I could recognize them now."
      Speaker = "Odysseus"
      Event = "OdysseusAboutZombieCaptain01"
    }
    {
      Id = "Melinoe_4193"
      InheritFrom = "BaseNarrative"
      DisplayName = "There's one at least that seems to have a level of command over the rest, if fancier attire and weaponry are any indication. I fought him just last night on his big ship."
      Speaker = "Melinoe"
      Event = "OdysseusAboutZombieCaptain01"
    }
    {
      Id = "Odysseus_0406"
      InheritFrom = "BaseNarrative"
      DisplayName = "Likely the Yargonaut, if the reports add up. There was a band of similarly-named adventurers he may have hailed from. But they were from a bit before my time. Perhaps still trying to re-live their glory days..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutZombieCaptain01"
    }
    {
      Id = "Melinoe_4194"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And getting in my way."
      Speaker = "Melinoe"
      Event = "OdysseusAboutZombieCaptain01"
    }
    {
      Id = "Melinoe_4195"
      InheritFrom = "BaseNarrative"
      DisplayName = "Did you ever face Dracons in your mortal days, Odysseus? The kind that fly about on wings much like a bat's, but huge. They've become quite a problem on Olympus recently."
      Speaker = "Melinoe"
      Event = "OdysseusAboutDragonMiniBoss01"
    }
    {
      Id = "Odysseus_0407"
      InheritFrom = "BaseNarrative"
      DisplayName = "My home was mountainous though we were mostly free from flying beasts. Still, in my experience they all have something in common: Susceptibility to being shot out of the sky."
      Speaker = "Odysseus"
      Event = "OdysseusAboutDragonMiniBoss01"
    }
    {
      Id = "Melinoe_4196"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I can see that."
      Speaker = "Melinoe"
      Event = "OdysseusAboutDragonMiniBoss01"
    }
    {
      Id = "Melinoe_3610"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know the great Olympian defender, Talos? One of the most ingenious inventions of Hephaestus, and a walking work of art... yet utterly unable to distinguish friend from foe."
      Speaker = "Melinoe"
      Event = "OdysseusAboutTalos01"
    }
    {
      Id = "Odysseus_0297"
      InheritFrom = "BaseNarrative"
      DisplayName = "That disappointing lack of judgment allegedly is not an oversight. Olympus deploys Talos where they want {#Emph}no one {#Prev}to tread, and lately, their own mountain is that place."
      Speaker = "Odysseus"
      Event = "OdysseusAboutTalos01"
    }
    {
      Id = "Melinoe_3611"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sometimes I think Olympus doesn't have the most cohesive plan for their defense. Isn't Lady Athena herself supposed to be in charge?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutTalos01"
    }
    {
      Id = "Odysseus_0298"
      InheritFrom = "BaseNarrative"
      DisplayName = "Supposed to be, aye. You know your family, Goddess! In matters of importance, they all want to get involved."
      Speaker = "Odysseus"
      Event = "OdysseusAboutTalos01"
    }
    {
      Id = "Melinoe_3612"
      InheritFrom = "BaseSubtitle"
      DisplayName = "For their sake, I hope Talos isn't costly to repair."
      Speaker = "Melinoe"
      Event = "OdysseusAboutTalos01"
    }
    {
      Id = "Odysseus_0408"
      InheritFrom = "BaseNarrative"
      DisplayName = "Which sorts of foul monstrosities were the Olympians contending with of late? As if the Titan's armies weren't troublesome enough, now Typhon's brood..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutTyphonMiniboss01"
    }
    {
      Id = "Melinoe_4197"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well... imagine horrors of all shapes and sizes, each some mix of muscle, eyes, and {#Emph}teeth. {#Prev}They climb up from beneath the ground... some practically ooze from the walls! The one that got me last night was particularly large."
      Speaker = "Melinoe"
      Event = "OdysseusAboutTyphonMiniboss01"
    }
    {
      Id = "Odysseus_0409"
      InheritFrom = "BaseNarrative"
      DisplayName = "And I take it Typhon has far more of these children than even your Lord Uncle Zeus, and all spoiled rotten. Feuding families! The cause of most every great war I've known."
      Speaker = "Odysseus"
      Event = "OdysseusAboutTyphonMiniboss01"
    }
    {
      Id = "Melinoe_4198"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'd not considered it that way..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutTyphonMiniboss01"
    }
    {
      Id = "Melinoe_4197_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well... imagine horrors of all shapes and sizes, each some mix of muscle, eyes, and {#Emph}teeth. {#Prev}They climb up from beneath the ground... some practically ooze from the walls!"
      Speaker = "Melinoe"
      Event = "OdysseusAboutTyphonMiniboss01_B"
    }
    {
      Id = "Odysseus_0541"
      InheritFrom = "BaseNarrative"
      DisplayName = "What brought you back that it would cause you visible distress, Goddess? We heard you made it to the summit but reports are inconclusive after that... or, unbelievable."
      Speaker = "Odysseus"
      Event = "OdysseusAboutSurfaceThreat01"
    }
    {
      Id = "Melinoe_5079"
      InheritFrom = "BaseNarrative"
      DisplayName = "Some sort of infestation plagues the summit... monstrosities abound. They can't possibly be servants of Chronos, but... they must be part of his scheme."
      Speaker = "Melinoe"
      Event = "OdysseusAboutSurfaceThreat01"
    }
    {
      Id = "Odysseus_0542"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well let's not speculate before we gather all the necessary facts. You've stood against these monstrosities and managed to return. Your family members must know more, provided they're... still able to reach you."
      Speaker = "Odysseus"
      Event = "OdysseusAboutSurfaceThreat01"
    }
    {
      Id = "Melinoe_5080"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I ought to make certain of that."
      Speaker = "Melinoe"
      Event = "OdysseusAboutSurfaceThreat01"
    }
    {
      Id = "Odysseus_0044"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're really using that labrys, Goddess? Or, pardon, what you call the Moonstone Axe. No disrespect, but isn't it... a little much? Not even Ajax could have wielded such a thing."
      Speaker = "Odysseus"
      Event = "OdysseusAboutAxe01"
    }
    {
      Id = "Melinoe_0059"
      InheritFrom = "BaseNarrative"
      DisplayName = "Weren't you the one who taught me to improvise, Odysseus? I'll use whatever means at my disposal. Who is Ajax?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutAxe01"
    }
    {
      Id = "Odysseus_0045"
      InheritFrom = "BaseNarrative"
      DisplayName = "Who's {#Emph}Ajax? {#Prev}Only the biggest lad I've ever met, {#Emph}who's Ajax{#Prev}. But I forget myself, for he didn't have the strength of Hades flowing through him."
      Speaker = "Odysseus"
      Event = "OdysseusAboutAxe01"
    }
    {
      Id = "Odysseus_0131"
      InheritFrom = "BaseNarrative"
      DisplayName = "If I may be so bold, Goddess? You witches are reliant on your magick when it comes to fighting from afar. Ever think of taking up the bow again? I could give you some pointers..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutBows01"
    }
    {
      Id = "Melinoe_0480"
      InheritFrom = "BaseNarrative"
      DisplayName = "We don't discuss the bow, Odysseus. I'm still recovering from the last time you gave me some of those pointers about it."
      Speaker = "Melinoe"
      Event = "OdysseusAboutBows01"
    }
    {
      Id = "Odysseus_0132"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ah, well. We all have our strengths and weaknesses. A single weakness in your case, perhaps."
      Speaker = "Odysseus"
      Event = "OdysseusAboutBows01"
    }
    {
      Id = "Melinoe_0481"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Doesn't count."
      Speaker = "Melinoe"
      Event = "OdysseusAboutBows01"
    }
    {
      Id = "Odysseus_0354"
      InheritFrom = "BaseNarrative"
      DisplayName = "How has our map been working out for you thus far? You reached Oceanus, sure, though the path ahead grows still more labyrinthine based on all we've ascertained."
      Speaker = "Odysseus"
      Event = "OdysseusAboutBiomeMap01"
    }
    {
      Id = "Melinoe_4089"
      InheritFrom = "BaseNarrative"
      DisplayName = "There seem as many pathways in the Underworld as stars in the night sky... yet your map has shown the way precisely. You must have an excellent sense of direction."
      Speaker = "Melinoe"
      Event = "OdysseusAboutBiomeMap01"
    }
    {
      Id = "Odysseus_0355"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh {#Prev}I don't know, but if our map helps overcompensate for my own lack, then good. Though, careful when you reach the Mourning Fields. No map shall benefit you {#Emph}there."
      Speaker = "Odysseus"
      Event = "OdysseusAboutBiomeMap01"
    }
    {
      Id = "Melinoe_4090"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What of the golden petals?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutBiomeMap01"
    }
    {
      Id = "Odysseus_0356"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Do watch for those."
      Speaker = "Odysseus"
      Event = "OdysseusAboutBiomeMap01"
    }
    {
      Id = "Odysseus_0357"
      InheritFrom = "BaseNarrative"
      DisplayName = "We've ceased attempts to find a good route through Elysium, hence your somewhat unconventional way into Tartarus. The old administrative corridor remains neglected still?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutBiomeMap02"
    }
    {
      Id = "Melinoe_4091"
      InheritFrom = "BaseNarrative"
      DisplayName = "Completely deserted, to the point of being rather peaceful. Drops me right into the maintenance sector, just as you mapped out."
      Speaker = "Melinoe"
      Event = "OdysseusAboutBiomeMap02"
    }
    {
      Id = "Odysseus_0358"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, our Shades deserve the greatest share of credit for {#Emph}that {#Prev}feat, though I'll take {#Emph}some {#Prev}if you insist. Your task is difficult enough that we didn't need you getting lost along the way."
      Speaker = "Odysseus"
      Event = "OdysseusAboutBiomeMap02"
    }
    {
      Id = "Melinoe_4092"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No objections here."
      Speaker = "Melinoe"
      Event = "OdysseusAboutBiomeMap02"
    }
    {
      Id = "Odysseus_0352"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your pathway down into the Underworld may seem a little roundabout, but avoiding the main regions is your best shot at eluding Chronos till you can face him on {#Emph}your {#Prev}terms. "
      Speaker = "Odysseus"
      Event = "OdysseusAboutTask01"
    }
    {
      Id = "Melinoe_4088"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have that pathway long since memorized; a straight shot down to Tartarus would have been too good to be true. I'm grateful that this other route even exists."
      Speaker = "Melinoe"
      Event = "OdysseusAboutTask01"
    }
    {
      Id = "Odysseus_0353"
      InheritFrom = "BaseNarrative"
      DisplayName = "And {#Emph}I {#Prev}am grateful that your father's realm is vast indeed, that we could chart a course along its border all the way to where you need to be."
      Speaker = "Odysseus"
      Event = "OdysseusAboutTask01"
    }
    {
      Id = "Odysseus_0133"
      InheritFrom = "BaseNarrative"
      DisplayName = "The good witch there noted you were able to vanquish her in a full-on contest. Impressive stuff! You get much farther?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutOceanus01"
    }
    {
      Id = "Melinoe_0482"
      InheritFrom = "BaseNarrative"
      DisplayName = "I did. Down to the chambers near the bottom of the sea. Strange music echoing all through the place. I wasn't prepared."
      Speaker = "Melinoe"
      Event = "OdysseusAboutOceanus01"
    }
    {
      Id = "Odysseus_0134"
      InheritFrom = "BaseNarrative"
      DisplayName = "Strange music, {#Emph}huh... {#Prev}reminds me of when... {#Emph}oh{#Prev}, I'll spare the tales for another time! You've enough on your mind, I can tell."
      Speaker = "Odysseus"
      Event = "OdysseusAboutOceanus01"
    }
    {
      Id = "Odysseus_0245"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, you made it to the Mourning Fields, good! Tartarus is not too far behind... directly underneath, in fact, but the ingress is a bit of a walk from your initial drop..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutFields01"
    }
    {
      Id = "Melinoe_3318"
      InheritFrom = "BaseNarrative"
      DisplayName = "A bit of a walk, fraught with soul-devouring Daemons and other life-hating fiends. Too powerful to be imprisoned so they're free to wander there, something like that?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutFields01"
    }
    {
      Id = "Odysseus_0246"
      InheritFrom = "BaseNarrative"
      DisplayName = "We mortals just love the Fields, Goddess! A place to rid oneself of misery — or drown in it. A perfect spot for Daemons, only {#Emph}some {#Prev}of which shall leave you be."
      Speaker = "Odysseus"
      Event = "OdysseusAboutFields01"
    }
    {
      Id = "Melinoe_3319"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That has been my experience."
      Speaker = "Melinoe"
      Event = "OdysseusAboutFields01"
    }
    {
      Id = "Odysseus_0258"
      InheritFrom = "BaseNarrative"
      DisplayName = "I heard your efforts to bring Cerberus back to his senses were successful... at least temporarily, Goddess. He bounded off to Tartarus, only to be cast out into the Fields again?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutTartarus01"
    }
    {
      Id = "Melinoe_3328"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's what I gathered, yes. In Tartarus, he seeks his master... my father. Whom I happened upon, bound in chains! Chronos is torturing them... mocking them."
      Speaker = "Melinoe"
      Event = "OdysseusAboutTartarus01"
    }
    {
      Id = "Odysseus_0259"
      InheritFrom = "BaseNarrative"
      DisplayName = "Chronos is using {#Emph}them {#Prev}to get at {#Emph}you. {#Prev}Instill in you emotions that compel you to throw caution to the wind. Remember, wars are won and lost in hearts and minds."
      Speaker = "Odysseus"
      Event = "OdysseusAboutTartarus01"
    }
    {
      Id = "Melinoe_3329"
      InheritFrom = "BaseNarrative"
      DisplayName = "Did you not act on your emotions in your mortal days?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutTartarus01"
    }
    {
      Id = "Odysseus_0438"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And just look at the mess I'm in now!"
      Speaker = "Odysseus"
      Event = "OdysseusAboutTartarus01"
    }
    {
      Id = "Melinoe_2225"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why not send Nemesis to the surface in my stead? Even if I undo the wards sealing the path, I don't know that I'll last long up there."
      Speaker = "Melinoe"
      Event = "OdysseusAboutSurface01"
    }
    {
      Id = "Odysseus_0207"
      InheritFrom = "BaseNarrative"
      DisplayName = "The matter on Olympus isn't as personal for Nemesis as it is for you; and she hasn't been especially receptive to suggestion recently."
      Speaker = "Odysseus"
      Event = "OdysseusAboutSurface01"
    }
    {
      Id = "Melinoe_2226"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No, I suppose not."
      Speaker = "Melinoe"
      Event = "OdysseusAboutSurface01"
    }
    {
      Id = "Odysseus_0208"
      InheritFrom = "BaseNarrative"
      DisplayName = "The good witch always figured you would make your way up to the mortal realm. Once you were ready and the situation called for it. Well done."
      Speaker = "Odysseus"
      Event = "OdysseusAboutSurface02"
    }
    {
      Id = "Melinoe_2227"
      InheritFrom = "BaseNarrative"
      DisplayName = "She warded the pathway there, until such time as I had the means to pass through. But the climate on the surface is another matter..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutSurface02"
    }
    {
      Id = "Odysseus_0209"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your Underworld birthright stuff getting in the way? A curse not just a blessing, it would seem. Well, if your witchery got you this far, surely it can aid with this... predicament."
      Speaker = "Odysseus"
      Event = "OdysseusAboutSurface02"
    }
    {
      Id = "Melinoe_2228"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's the plan."
      Speaker = "Melinoe"
      Event = "OdysseusAboutSurface02"
    }
    {
      Id = "Odysseus_0239"
      InheritFrom = "BaseNarrative"
      DisplayName = "How was it sailing through the Rift of Thessaly, Goddess? Sometimes I long for my past days and nights at sea. Probably since I've forgotten just how miserable it was..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutThessaly01"
    }
    {
      Id = "Melinoe_3307"
      InheritFrom = "BaseNarrative"
      DisplayName = "I feel I could remind you at this point. Chronos has this vast fleet of ships drawn from the very depths, drowned crews and all. I had to commandeer whichever craft I could."
      Speaker = "Melinoe"
      Event = "OdysseusAboutThessaly01"
    }
    {
      Id = "Odysseus_0240"
      InheritFrom = "BaseNarrative"
      DisplayName = "A proper nautical experience, then! Fraught with {#Emph}danger, mystery...! Ah{#Prev}, I feel a little envious of those drowned crews! After I died, I thought my sailing days were done."
      Speaker = "Odysseus"
      Event = "OdysseusAboutThessaly01"
    }
    {
      Id = "Melinoe_3308"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, Chronos could probably use more sailors after what I did to them."
      Speaker = "Melinoe"
      Event = "OdysseusAboutThessaly01"
    }
    {
      Id = "Odysseus_0241"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Put in a good word for me would you?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutThessaly01"
    }
    {
      Id = "Odysseus_0295"
      InheritFrom = "BaseNarrative"
      DisplayName = "This may not be the best occasion to inform you but we've reason to believe the trouble brewing on Olympus is significantly worse than it appears. Not even the gods are fully aware. Unfortunately, neither are we..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutOlympus01"
    }
    {
      Id = "Melinoe_3608"
      InheritFrom = "BaseNarrative"
      DisplayName = "The forces of Chronos attack nonstop, while the gods and their defenses hold them back... then it's a ruse for some especially dramatic gesture that the Titan has in store?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutOlympus01"
    }
    {
      Id = "Odysseus_0296"
      InheritFrom = "BaseNarrative"
      DisplayName = "My thoughts exactly. But have no fear, Goddess! I once fought alongside a great warrior who said {#Emph}fear is for the weak{#Prev}. I happen to think fear is for the living, but like most good things, it isn't healthy in abundance."
      Speaker = "Odysseus"
      Event = "OdysseusAboutOlympus01"
    }
    {
      Id = "Melinoe_3609"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Fear is for our enemies."
      Speaker = "Melinoe"
      Event = "OdysseusAboutOlympus01"
    }
    {
      Id = "Odysseus_0304"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Aye."
      Speaker = "Odysseus"
      Event = "OdysseusAboutOlympus01"
    }
    {
      Id = "Odysseus_0210"
      InheritFrom = "BaseNarrative"
      DisplayName = "How was the surface, still warm and welcoming I reckon? You're to be commended for even setting foot up there."
      Speaker = "Odysseus"
      Event = "OdysseusAboutPolyphemus01"
    }
    {
      Id = "Melinoe_0060"
      InheritFrom = "BaseNarrative"
      DisplayName = "It was dreadful. The city of Ephyra is completely overrun. And, there's a blind Cyclops making sure no one gets out."
      Speaker = "Melinoe"
      Event = "OdysseusAboutPolyphemus01"
    }
    {
      Id = "Odysseus_0031"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, that all sounds entirely unfortunate. That blind Cyclops must be Polyphemus. My crew and I once had a bad run-in with him. He still going on about eating people?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutPolyphemus01"
    }
    {
      Id = "Melinoe_0061"
      InheritFrom = "BaseSubtitle"
      DisplayName = "He is."
      Speaker = "Melinoe"
      Event = "OdysseusAboutPolyphemus01"
    }
    {
      Id = "Odysseus_0032"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Augh..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutPolyphemus01"
    }
    {
      Id = "Melinoe_3337"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your old adversary Polyphemus wanted me to give you a message on his behalf. Though, come to think, I'm uncertain what he wanted me to say. Perhaps just... kick you savagely?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutPolyphemus02"
    }
    {
      Id = "Odysseus_0274"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Eh{#Prev}, sounds like the Cyclops that I used to know all right. My crew and I, we were his captives for a while... and his food supply. I found a way to get us out of there, but it was ugly..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutPolyphemus02"
    }
    {
      Id = "Melinoe_3338"
      InheritFrom = "BaseNarrative"
      DisplayName = "He calls you Nobody. How did he come to know you by that name?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutPolyphemus02"
    }
    {
      Id = "Odysseus_0275"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Nobody {#Prev}took his {#Emph}eye{#Prev}, Goddess... I gave to him a name that wouldn't make a lick of sense when he called over to his mates for help. We had to try."
      Speaker = "Odysseus"
      Event = "OdysseusAboutPolyphemus02"
    }
    {
      Id = "Melinoe_3339"
      InheritFrom = "BaseSubtitle"
      DisplayName = "He has {#Emph}mates?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutPolyphemus02"
    }
    {
      Id = "Odysseus_0276"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Perhaps not anymore."
      Speaker = "Odysseus"
      Event = "OdysseusAboutPolyphemus02"
    }
    {
      Id = "Odysseus_0277"
      InheritFrom = "BaseNarrative"
      DisplayName = "How is old Polyphemus, anyhow? Slowed down a bit since he was young, perhaps...? I scarce was any match for him, but I was merely mortal, whilst you're... {#Emph}you."
      Speaker = "Odysseus"
      Event = "OdysseusAboutPolyphemus03"
    }
    {
      Id = "Melinoe_3340"
      InheritFrom = "BaseNarrative"
      DisplayName = "He's territorial, though seems much more concerned with sleep and appetite than any other cause. So, you really blinded him, then...?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutPolyphemus03"
    }
    {
      Id = "Odysseus_0278"
      InheritFrom = "BaseNarrative"
      DisplayName = "I did... and only wish he had {#Emph}another {#Prev}eye so that I could have done it {#Emph}twice{#Prev}. For evidently {#Emph}he {#Prev}is not remorseful in the least for what he did, and... as you {#Emph}plainly {#Prev}see, neither am I."
      Speaker = "Odysseus"
      Event = "OdysseusAboutPolyphemus03"
    }
    {
      Id = "Melinoe_3341"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...I'll get him for you."
      Speaker = "Melinoe"
      Event = "OdysseusAboutPolyphemus03"
    }
    {
      Id = "Odysseus_0279"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Good."
      Speaker = "Odysseus"
      Event = "OdysseusAboutPolyphemus03"
    }
    {
      Id = "Melinoe_2220"
      InheritFrom = "BaseNarrative"
      DisplayName = "I encountered mighty Heracles on the surface. No mistaking him! Though I thought he was dead. He seemed very much alive, on the outside, anyway. And still in service to the gods..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutHeracles01"
    }
    {
      Id = "Odysseus_0211"
      InheritFrom = "BaseNarrative"
      DisplayName = "The great {#Emph}Heracles... {#Prev}that's a complicated one. Part {#Emph}man{#Prev}, part {#Emph}god... {#Prev}part monster too, perhaps. The rules of death don't quite apply to him. What did he want? He give you any trouble?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutHeracles01"
    }
    {
      Id = "Melinoe_2221"
      InheritFrom = "BaseNarrative"
      DisplayName = "He was quite brusque. Told me to stay out of his way. Sounds like he has a task of his own. Maybe Olympus isn't counting on me to succeed..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutHeracles01"
    }
    {
      Id = "Odysseus_0212"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Eh, {#Prev}don't take it personally. You have wise relatives, and ruthless ones. They may not like their odds hinging on any one individual. And... do watch yourself with Heracles, aye?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutHeracles01"
    }
    {
      Id = "Melinoe_2222"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Aye..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutHeracles01"
    }
    {
      Id = "Odysseus_0293"
      InheritFrom = "BaseNarrative"
      DisplayName = "Prometheus opposes us... now {#Emph}that {#Prev}one hurts, Goddess. Amongst us mortals, he was quite popular. Beloved, even! Gave us the gift of fire. Practically made us who we are."
      Speaker = "Odysseus"
      Event = "OdysseusAboutPrometheus01"
    }
    {
      Id = "Melinoe_3606"
      InheritFrom = "BaseNarrative"
      DisplayName = "And in so doing, he violated the will of Olympus. Supposedly he has the gift of foresight... he ought to have anticipated the consequences of his disobedience."
      Speaker = "Melinoe"
      Event = "OdysseusAboutPrometheus01"
    }
    {
      Id = "Odysseus_0294"
      InheritFrom = "BaseNarrative"
      DisplayName = "What makes you think he didn't? All the more reason we admired him. He knew the cost of what he did for us, and paid it willingly, or... so I choose to think. But all that's in the past. If he's thrown in with Chronos now, he's lost his way."
      Speaker = "Odysseus"
      Event = "OdysseusAboutPrometheus01"
    }
    {
      Id = "Melinoe_3607"
      InheritFrom = "BaseSubtitle"
      DisplayName = "He's done both."
      Speaker = "Melinoe"
      Event = "OdysseusAboutPrometheus01"
    }
    {
      Id = "Odysseus_0379"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wanted to ask you more about Prometheus. By your own estimation, is he truly mad...? And, if he stands opposed to all your family, then who set him loose to begin with...?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutPrometheus02"
    }
    {
      Id = "Melinoe_4104"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't exactly know on either count. He speaks in riddles sometimes, but he doesn't sound as though he's lost his mind. My suspicion is that the forces of Chronos liberated him in exchange for his obedience, but..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutPrometheus02"
    }
    {
      Id = "Odysseus_0380"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...But he's no hired thug, is he."
      Speaker = "Odysseus"
      Event = "OdysseusAboutPrometheus02"
    }
    {
      Id = "Melinoe_4105"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No, I think not."
      Speaker = "Melinoe"
      Event = "OdysseusAboutPrometheus02"
    }
    {
      Id = "Melinoe_4106"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know mortals better than anybody here. Prometheus claims that the gods are cruel, and that he fights not for the Titan Lord, but mortalkind. What do you make of all that?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutPrometheus03"
    }
    {
      Id = "Odysseus_0381"
      InheritFrom = "BaseNarrative"
      DisplayName = "Look, I've known mortals who think gods can be uncaring. Some of them defy the gods even in death. Others understand that gods are... {#Emph}everything{#Prev}, really. We have only this world, more beautiful than it is flawed."
      Speaker = "Odysseus"
      Event = "OdysseusAboutPrometheus03"
    }
    {
      Id = "Melinoe_4107"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're speaking in the abstract. I want to know your personal opinion here, Odysseus. Are the gods in the wrong? Did we bring this on ourselves...?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutPrometheus03"
    }
    {
      Id = "Odysseus_0382"
      InheritFrom = "BaseNarrative"
      DisplayName = "My personal opinion is that gods and mortals are a {#Emph}complicated {#Prev}bunch; and that you shouldn't doubt yourself, lest you falter. If I felt you or the good witch were in the wrong, I'd tell you so."
      Speaker = "Odysseus"
      Event = "OdysseusAboutPrometheus03"
    }
    {
      Id = "Melinoe_4108"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You swear to that?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutPrometheus03"
    }
    {
      Id = "Odysseus_0383"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Aye, Goddess."
      Speaker = "Odysseus"
      Event = "OdysseusAboutPrometheus03"
    }
    {
      Id = "Melinoe_5223"
      InheritFrom = "BaseNarrative"
      DisplayName = "Odysseus, I need your counsel and discretion on something. Prometheus has an ally whom I thought was on my family's side. I faced them together near the mountain's summit, where the smoke is thick. But, I mustn't say who..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutPrometheusAltFight01"
    }
    {
      Id = "Odysseus_0614"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Mm{#Prev}, quite the report all right, and I have my suspicions as to whom you mean. Certainly the gods must know, at least Master Hermes, or... do you reckon that they're unaware?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutPrometheusAltFight01"
    }
    {
      Id = "Melinoe_5224"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't think they realize, though perhaps Hermes does and won't let on. Prometheus said I wouldn't tell a soul who it was because of the harm that doing so would bring. Do you think he's telling the truth?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutPrometheusAltFight01"
    }
    {
      Id = "Odysseus_0615"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd not wager otherwise. We had best treat it as the truth for now, unless you believe this ally poses an imminent threat to your family. Are you in a position to further investigate?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutPrometheusAltFight01"
    }
    {
      Id = "Melinoe_5225"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I think so..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutPrometheusAltFight01"
    }
    {
      Id = "Odysseus_0616"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Keep me apprised."
      Speaker = "Odysseus"
      Event = "OdysseusAboutPrometheusAltFight01"
    }
    {
      Id = "Odysseus_0147"
      InheritFrom = "BaseNarrative"
      DisplayName = "Goddess, I was just thinking of your travels, taking you beneath the surface and above, I reckon to the ends of the earth! No mere {#Emph}journey... {#Prev}got to be a better word for it..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutTravel01"
    }
    {
      Id = "Melinoe_2195"
      InheritFrom = "BaseNarrative"
      DisplayName = "What, is {#Emph}task {#Prev}not sufficiently extravagant? Perhaps {#Emph}assignment? {#Prev}Or {#Emph}voyage? Quest {#Prev}doesn't feel right at all..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutTravel01"
    }
    {
      Id = "Odysseus_0148"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, too upbeat, and {#Emph}voyage {#Prev}is more of a nautical term.... {#Emph}Erm{#Prev}, we'll think of something."
      Speaker = "Odysseus"
      Event = "OdysseusAboutTravel01"
    }
    {
      Id = "Melinoe_2196"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}...trek... sojourn..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutTravel01"
    }
    {
      Id = "Melinoe_2174"
      InheritFrom = "BaseNarrative"
      DisplayName = "How did you manage it, Odysseus? Back when you had the outcome of a full-scale war riding on you, then a treacherous sea-journey, all with only one life to live... or so then you thought?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutPressure01"
    }
    {
      Id = "Odysseus_0137"
      InheritFrom = "BaseNarrative"
      DisplayName = "For certain, the one-life-to-live bit instilled in me the will to survive. Most mortals cling to life, but I was better than most at rejecting my doubts. And when my plans all fell apart, I improvised...!"
      Speaker = "Odysseus"
      Event = "OdysseusAboutPressure01"
    }
    {
      Id = "Melinoe_2175"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Your {#Prev}plans fell apart? How did you avoid becoming distraught? Keep all your doubts at bay in the face of failure?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutPressure01"
    }
    {
      Id = "Odysseus_0138"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's that I always relished finding a way out. No matter what I'd gotten myself into. Treating my predicaments as mazes to be navigated, puzzles to be solved..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutPressure01"
    }
    {
      Id = "Melinoe_2176"
      InheritFrom = "BaseNarrative"
      DisplayName = "But at times there are impasses; outcomes that simply cannot be achieved..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutPressure01"
    }
    {
      Id = "Odysseus_0139"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Nay, Goddess. Not if you ask me."
      Speaker = "Odysseus"
      Event = "OdysseusAboutPressure01"
    }
    {
      Id = "Odysseus_0140"
      InheritFrom = "BaseNarrative"
      DisplayName = "You asked before about how I managed it... the pressure to always prevail through what, in retrospect, were... many {#Emph}terribly exciting {#Prev}scenarios, all whilst bearing the burden of so many others' expectations and my own."
      Speaker = "Odysseus"
      Event = "OdysseusAboutPressure02"
    }
    {
      Id = "Melinoe_2177"
      InheritFrom = "BaseNarrative"
      DisplayName = "You said you always believed there was a solution, a positive outcome that could be discovered and achieved... I've been thinking about that."
      Speaker = "Melinoe"
      Event = "OdysseusAboutPressure02"
    }
    {
      Id = "Odysseus_0141"
      InheritFrom = "BaseNarrative"
      DisplayName = "Good. But it occurred to me there's something else: Love drove me on, Goddess. The great war that earned me my place in Elysium... I wanted desperately not to go. To stay home with my wife and newborn son."
      Speaker = "Odysseus"
      Event = "OdysseusAboutPressure02"
    }
    {
      Id = "Melinoe_2178"
      InheritFrom = "BaseNarrative"
      DisplayName = "You were left with no choice but to fight. So you held to hope that someday you'd see your family again..."
      Speaker = "Melinoe"
      Event = "OdysseusAboutPressure02"
    }
    {
      Id = "Odysseus_0142"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Sound familiar, does it?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutPressure02"
    }
    {
      Id = "Odysseus_0596"
      InheritFrom = "BaseNarrative"
      DisplayName = "You found a path to victory and got us there. Wouldn't have been much of a plan if it didn't leave room to improvise! Of course our plan now also has this {#Emph}other {#Prev}phase as a result..."
      Speaker = "Odysseus"
      Event = "OdysseusPostTrueEnding01"
    }
    {
      Id = "Melinoe_5738"
      InheritFrom = "BaseNarrative"
      DisplayName = "Cleaning up after Chronos... we all thought I would get rid of him. But, I found another way... one I think shall leave my family better off, if not the rest of the world, eventually."
      Speaker = "Melinoe"
      Event = "OdysseusPostTrueEnding01"
    }
    {
      Id = "Odysseus_0597"
      InheritFrom = "BaseNarrative"
      DisplayName = "I well and truly understand, Goddess, and do believe your choice was wise. As for what's next, everything is ready for you to proceed if and when you are."
      Speaker = "Odysseus"
      Event = "OdysseusPostTrueEnding01"
    }
    {
      Id = "Melinoe_5739"
      InheritFrom = "BaseNarrative"
      DisplayName = "Eliminating real possibilities that we could have failed... ensuring {#Emph}time flows freely forth{#Prev}, as Chronos puts it. I don't quite know what to expect, but the change we're fighting for won't happen overnight. What do you make of it?"
      Speaker = "Melinoe"
      Event = "OdysseusPostTrueEnding01"
    }
    {
      Id = "Odysseus_0598"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Eh{#Prev}, my personal opinion is it doesn't hurt to {#Emph}try! {#Prev}To the extent you'd other matters to resolve, consider it an opportunity to do so. And, we'll always be anticipating your return."
      Speaker = "Odysseus"
      Event = "OdysseusPostTrueEnding01"
    }
    {
      Id = "Melinoe_5055"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Then let's give it a go."
      Speaker = "Melinoe"
      Event = "OdysseusPostTrueEnding01"
    }
    {
      Id = "Odysseus_0599"
      InheritFrom = "BaseNarrative"
      DisplayName = "Everything proceeding as expected in the new phase of your task thus far, Goddess? Stretching the definition of {#Emph}expected{#Prev}, perhaps, as this is... new territory for us all."
      Speaker = "Odysseus"
      Event = "OdysseusPostTrueEnding02"
    }
    {
      Id = "Melinoe_5111"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's an unusual assignment, ensuring time flows freely. If done correctly, everything will seem as before. And even if not... there's no guarantee anything will go wrong."
      Speaker = "Melinoe"
      Event = "OdysseusPostTrueEnding02"
    }
    {
      Id = "Odysseus_0600"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well that makes this sound more familiar than I thought. Life in all its uncertainties! Anyway, we're watching Chronos and ensuring that your route remains intact."
      Speaker = "Odysseus"
      Event = "OdysseusPostTrueEnding02"
    }
    {
      Id = "Melinoe_5112"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll make the most of it. Thank you."
      Speaker = "Melinoe"
      Event = "OdysseusPostTrueEnding02"
    }
    {
      Id = "Odysseus_0601"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sounds like your father's House is back in some semblance of order. Always wanted to visit if ever I could, if only to greet an old comrade or two from the war."
      Speaker = "Odysseus"
      Event = "OdysseusPostTrueEndingAboutHouse01"
    }
    {
      Id = "Melinoe_5213"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd also like to visit again, but there's no telling when if ever we would have that chance so long as we're Unseen. Officially they're not even supposed to know we're here."
      Speaker = "Melinoe"
      Event = "OdysseusPostTrueEndingAboutHouse01"
    }
    {
      Id = "Odysseus_0602"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know, but it doesn't make the desire go away! At any rate, as long as the servants of the King and Queen are well. Perhaps our paths shall later cross, who knows."
      Speaker = "Odysseus"
      Event = "OdysseusPostTrueEndingAboutHouse01"
    }
    {
      Id = "Melinoe_5214"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Fates?"
      Speaker = "Melinoe"
      Event = "OdysseusPostTrueEndingAboutHouse01"
    }
    {
      Id = "Odysseus_0603"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Or Prometheus, aye."
      Speaker = "Odysseus"
      Event = "OdysseusPostTrueEndingAboutHouse01"
    }
    {
      Id = "Odysseus_0604"
      InheritFrom = "BaseNarrative"
      DisplayName = "Is Typhon really up there on the summit still? {#Emph}Hm{#Prev}, no trace of him in our reports, but if Chronos... {#Emph}erm{#Prev}, your grandfather, that is... if he's using some sort of chronomancy to transport you..."
      Speaker = "Odysseus"
      Event = "OdysseusPostTrueEndingAboutTyphon01"
    }
    {
      Id = "Melinoe_5215"
      InheritFrom = "BaseNarrative"
      DisplayName = "He is, yes. And I end up confronting Typhon as before. Apparently these are possibilities within the flow of time in which I haven't prevailed... until I do."
      Speaker = "Melinoe"
      Event = "OdysseusPostTrueEndingAboutTyphon01"
    }
    {
      Id = "Odysseus_0605"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't see how that's possible. What, there are all these other instances of you out there, some failing, some prevailing, all at the same time? Nonsense... but then again, who am I to question bizarre plans?"
      Speaker = "Odysseus"
      Event = "OdysseusPostTrueEndingAboutTyphon01"
    }
    {
      Id = "Melinoe_5216"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Whatever works, aye?"
      Speaker = "Melinoe"
      Event = "OdysseusPostTrueEndingAboutTyphon01"
    }
    {
      Id = "Melinoe_5217"
      InheritFrom = "BaseNarrative"
      DisplayName = "I take it you heard about the Fates? Apparently everyone already has, figured you'd be among the first. Though come to think of it, I've not heard you speak about them much..."
      Speaker = "Melinoe"
      Event = "OdysseusPostEpilogue01"
    }
    {
      Id = "Odysseus_0608"
      InheritFrom = "BaseNarrative"
      DisplayName = "...It's because deep down I've always felt we make our choices for ourselves. Admittedly a controversial point of view when we've strong evidence that those three often choose for us, but... I have to heed my instincts on this one."
      Speaker = "Odysseus"
      Event = "OdysseusPostEpilogue01"
    }
    {
      Id = "Melinoe_5218"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wait, you don't believe in what they do? Their prophecies, the coming of a new age... none of it?"
      Speaker = "Melinoe"
      Event = "OdysseusPostEpilogue01"
    }
    {
      Id = "Odysseus_0609"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wouldn't go {#Emph}that {#Prev}far, but... I {#Emph}choose {#Prev}to believe in those I know and trust, including members of your family. If that makes me a fool, then so be it."
      Speaker = "Odysseus"
      Event = "OdysseusPostEpilogue01"
    }
    {
      Id = "Melinoe_5219"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}So be it? {#Prev}Sounds like accepting fate to me."
      Speaker = "Melinoe"
      Event = "OdysseusPostEpilogue01"
    }
    {
      Id = "Odysseus_0610"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Oh {#Prev}you know what I mean!"
      Speaker = "Odysseus"
      Event = "OdysseusPostEpilogue01"
    }
    {
      Id = "Melinoe_5220"
      InheritFrom = "BaseNarrative"
      DisplayName = "This new age the Fates foretold, when they'll {#Emph}hand it over to mortals{#Prev}, by which I think they meant the big decisions... what say our Shades about all that?"
      Speaker = "Melinoe"
      Event = "OdysseusPostEpilogue02"
    }
    {
      Id = "Odysseus_0611"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've heard a mix of viewpoints, though they've been enthusiastic on the whole. Ungrateful wretches, aye? We're only here by the grace of the gods."
      Speaker = "Odysseus"
      Event = "OdysseusPostEpilogue02"
    }
    {
      Id = "Melinoe_5221"
      InheritFrom = "BaseNarrative"
      DisplayName = "It isn't always grace, I suppose. Many of these Shades met an early demise due to acts of gods. They don't want to be pushed around."
      Speaker = "Melinoe"
      Event = "OdysseusPostEpilogue02"
    }
    {
      Id = "Odysseus_0612"
      InheritFrom = "BaseNarrative"
      DisplayName = "There shall always be someone or something to push such people around. Whether it's a god or not hardly matters. The gods can have their moods, I know. But I'd not have gone far without them. It's why I'm here."
      Speaker = "Odysseus"
      Event = "OdysseusPostEpilogue02"
    }
    {
      Id = "Melinoe_5222"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Nice of you to say."
      Speaker = "Melinoe"
      Event = "OdysseusPostEpilogue02"
    }
    {
      Id = "Odysseus_0613"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I don't say, I swear."
      Speaker = "Odysseus"
      Event = "OdysseusPostEpilogue02"
    }
    {
      Id = "Melinoe_0452"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wanted to say, I appreciate your counsel, Odysseus. You've been like a brother to me. Or an uncle? One of those. You'd know better than I."
      Speaker = "Melinoe"
      Event = "OdysseusBackstory01"
    }
    {
      Id = "Odysseus_0037"
      InheritFrom = "BaseNarrative"
      DisplayName = "Look, you don't have to tell me what it's like not having a family about. I spent a good-sized portion of my mortal days away from home. Had a war to fight, got a little sidetracked after."
      Speaker = "Odysseus"
      Event = "OdysseusBackstory01"
    }
    {
      Id = "Melinoe_0453"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Sidetracked? {#Prev}Headmistress says that you spent many years at sea. Some of them in the company of goddesses, at that."
      Speaker = "Melinoe"
      Event = "OdysseusBackstory01"
    }
    {
      Id = "Odysseus_0038"
      InheritFrom = "BaseNarrative"
      DisplayName = "Aye, well. By the time I finally returned, I scarce recognized my son, and my wife... we lived out our mortal days together, and that was enough. I reckon they're comfortable somewhere below."
      Speaker = "Odysseus"
      Event = "OdysseusBackstory01"
    }
    {
      Id = "Melinoe_0454"
      InheritFrom = "BaseNarrative"
      DisplayName = "You haven't seen them? What happened?"
      Speaker = "Melinoe"
      Event = "OdysseusBackstory01"
    }
    {
      Id = "Odysseus_0039"
      InheritFrom = "BaseNarrative"
      DisplayName = "Penelope and I drifted apart. Happens with mortals, sometimes. And it happens with Shades too. As for my son Telemachus, he's his own man. Such is life. Or death, as it turns out."
      Speaker = "Odysseus"
      Event = "OdysseusBackstory01"
    }
    {
      Id = "Melinoe_0455"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yes..."
      Speaker = "Melinoe"
      Event = "OdysseusBackstory01"
    }
    {
      Id = "Odysseus_0430"
      InheritFrom = "BaseNarrative"
      DisplayName = "Fair warning I'm a proper wretch right now, Goddess. Used to think I lived a complete life! But all your journeys made me realize that there was {#Emph}much {#Prev}I left unsaid. Too much."
      Speaker = "Odysseus"
      Event = "OdysseusLooseEndsQuest01"
    }
    {
      Id = "Melinoe_4219"
      InheritFrom = "BaseNarrative"
      DisplayName = "What? How do my journeys factor into that? And cease your wretchedness at once... or tell me how to make it stop."
      Speaker = "Melinoe"
      Event = "OdysseusLooseEndsQuest01"
    }
    {
      Id = "Odysseus_0431"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Eh{#Prev}, you've met Scylla and the Sirens, the Cyclops Polyphemus, the Enchantress Circe... one way or another, they each left an indelible mark on me; to say nothing of my wife and son, wherever they are. I think... I need to go..."
      Speaker = "Odysseus"
      Event = "OdysseusLooseEndsQuest01"
    }
    {
      Id = "Melinoe_4220"
      InheritFrom = "BaseNarrative"
      DisplayName = "Go {#Emph}where? {#Prev}Odysseus, you can't leave now, we need you here! There must be something we can do."
      Speaker = "Melinoe"
      Event = "OdysseusLooseEndsQuest01"
    }
    {
      Id = "Odysseus_0432"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Eugh. {#Prev}Probably there is, but I — I wouldn't wish to overburden you. You already take on far too much."
      Speaker = "Odysseus"
      Event = "OdysseusLooseEndsQuest01"
    }
    {
      Id = "Melinoe_4221"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Tell me more."
      Speaker = "Melinoe"
      Event = "OdysseusLooseEndsQuest01"
    }
    {
      Id = "Odysseus_0433"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Perhaps some... other time..."
      Speaker = "Odysseus"
      Event = "OdysseusLooseEndsQuest01"
    }
    {
      Id = "Odysseus_0563"
      InheritFrom = "BaseNarrative"
      DisplayName = "Apologies, I've... started letting my misery break free. Moments of weakness, becoming more frequent than I care to admit. I've been thinking about what to do... a {#Emph}plan."
      Speaker = "Odysseus"
      Event = "OdysseusLooseEndsQuest02"
    }
    {
      Id = "Melinoe_5101"
      InheritFrom = "BaseNarrative"
      DisplayName = "What is it? You mentioned Scylla, Polyphemus, Circe... I see them frequently enough that I could speak to them on your behalf if you'd like?"
      Speaker = "Melinoe"
      Event = "OdysseusLooseEndsQuest02"
    }
    {
      Id = "Odysseus_0564"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, I'd not ask you to do {#Emph}that. {#Prev}However, your connection to my Knuckle Bones is strong enough, perhaps I could relay a message to them myself. Just get my Keepsake there and I could do the rest?"
      Speaker = "Odysseus"
      Event = "OdysseusLooseEndsQuest02"
    }
    {
      Id = "Melinoe_5102"
      InheritFrom = "BaseNarrative"
      DisplayName = "A spirit projection... I could probably maintain one for a little while. You mean to confront your old acquaintances?"
      Speaker = "Melinoe"
      Event = "OdysseusLooseEndsQuest02"
    }
    {
      Id = "Odysseus_0565"
      InheritFrom = "BaseNarrative"
      DisplayName = "For now, that's all, Goddess. If aiding me this way won't stray from your objectives."
      Speaker = "Odysseus"
      Event = "OdysseusLooseEndsQuest02"
    }
    {
      Id = "Melinoe_5103"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Of course not. We'll see it through."
      Speaker = "Melinoe"
      Event = "OdysseusLooseEndsQuest02"
    }
    {
      Id = "Odysseus_0581"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm grateful that you let me pay a visit to some of my former associates, Goddess. It changed nothing, really, but... I felt as though I put several matters to rest. As for what happens now... I may be gone a little while..."
      Speaker = "Odysseus"
      Event = "OdysseusLooseEndsQuestComplete01"
    }
    {
      Id = "Melinoe_5104"
      InheritFrom = "BaseNarrative"
      DisplayName = "Things are settled here enough... take all the time you need, and you'll be welcome whenever you return. Can you say where you're going?"
      Speaker = "Melinoe"
      Event = "OdysseusLooseEndsQuestComplete01"
    }
    {
      Id = "Odysseus_0582"
      InheritFrom = "BaseNarrative"
      DisplayName = "...To find my mortal family... my wife and son. I've done it before. May it not take quite as long on {#Emph}this {#Prev}occasion, though."
      Speaker = "Odysseus"
      Event = "OdysseusLooseEndsQuestComplete01"
    }
    {
      Id = "Melinoe_5105"
      InheritFrom = "BaseNarrative"
      DisplayName = "It won't. You must have charted every passageway through the Underworld by now! But what will you do then?"
      Speaker = "Melinoe"
      Event = "OdysseusLooseEndsQuestComplete01"
    }
    {
      Id = "Odysseus_0583"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll figure that out on the way. In the meantime, I've deputized some of our Shades to keep an eye on things, and privately said my goodbyes to our good witch. Be well, in my absence."
      Speaker = "Odysseus"
      Event = "OdysseusLooseEndsQuestComplete01"
    }
    {
      Id = "Melinoe_5106"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Safe journeys, Odysseus..."
      Speaker = "Melinoe"
      Event = "OdysseusLooseEndsQuestComplete01"
    }
    {
      Id = "Melinoe_5108"
      InheritFrom = "BaseNarrative"
      DisplayName = "We missed you here, and I'm so pleased you're back! How was your trip? Did you find your family?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutReturn01"
    }
    {
      Id = "Odysseus_0585"
      InheritFrom = "BaseNarrative"
      DisplayName = "Aye, Goddess, I found them all right. Followed a couple leads down in Elysium, ran into a couple of former compatriots, and we got there. Penelope and Telemachus... {#Emph}erm{#Prev}, well, they recognized me right away."
      Speaker = "Odysseus"
      Event = "OdysseusAboutReturn01"
    }
    {
      Id = "Melinoe_5109"
      InheritFrom = "BaseNarrative"
      DisplayName = "Were they all right? Apologies, it's not my wish to drag these details out of you, it's just... this is your latest tale!"
      Speaker = "Melinoe"
      Event = "OdysseusAboutReturn01"
    }
    {
      Id = "Odysseus_0586"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ahh{#Prev}, what's to tell? It was... well, it was comforting. I reckon the time we spent apart was healing in a way. They asked I visit them again, down the line."
      Speaker = "Odysseus"
      Event = "OdysseusAboutReturn01"
    }
    {
      Id = "Melinoe_5110"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I think you should. I'm glad it went well."
      Speaker = "Melinoe"
      Event = "OdysseusAboutReturn01"
    }
    {
      Id = "Odysseus_0587"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It could have gone far worse."
      Speaker = "Odysseus"
      Event = "OdysseusAboutReturn01"
    }
    {
      Id = "Odysseus_0543"
      InheritFrom = "BaseNarrative"
      DisplayName = "If I may confide something, Goddess? Throughout my mortal life, I never wanted to depend on anyone. But, I always had aid... from great warriors, sailors, even gods! Yet... even still, it's difficult to ask assistance in personal matters."
      Speaker = "Odysseus"
      Event = "OdysseusAboutAssistance01"
    }
    {
      Id = "Melinoe_5081"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know the feeling well. A sense of weakness... the inability to do something oneself. We strive for self-sufficience and we don't wish to heap our troubles on our comrades."
      Speaker = "Melinoe"
      Event = "OdysseusAboutAssistance01"
    }
    {
      Id = "Odysseus_0544"
      InheritFrom = "BaseNarrative"
      DisplayName = "Aye, we know it {#Emph}isn't {#Prev}weakness, but... we have to fight our instincts there a bit, don't we? Though mainly, what I wished to say was, {#Emph}thank you. {#Prev}For the aid you've given me. You needn't have gone out of your way."
      Speaker = "Odysseus"
      Event = "OdysseusAboutAssistance01"
    }
    {
      Id = "Melinoe_5082"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Of course. We've come this far together."
      Speaker = "Melinoe"
      Event = "OdysseusAboutAssistance01"
    }
    {
      Id = "Odysseus_0155"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, I miss the feeling of the rain, sometimes. Then I remember years at sea, soaked to the bone, and thank the gods the blasted stuff can't get to me as once it did."
      Speaker = "Odysseus"
      Event = "OdysseusAboutRain01"
    }
    {
      Id = "Melinoe_2179"
      InheritFrom = "BaseNarrative"
      DisplayName = "The rain brings life, as well as death... especially the latter on this night. The Lost Souls out there seem to hate it near as much as you."
      Speaker = "Melinoe"
      Event = "OdysseusAboutRain01"
    }
    {
      Id = "Odysseus_0156"
      InheritFrom = "BaseNarrative"
      DisplayName = "Aye, almost seems to soften them up, doesn't it? Leave them ripe for the harvest. Go pick some off for me, will you?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutRain01"
    }
    {
      Id = "Melinoe_2180"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I think I will."
      Speaker = "Melinoe"
      Event = "OdysseusAboutRain01"
    }
    {
      Id = "Odysseus_0400"
      InheritFrom = "BaseNarrative"
      DisplayName = "Have the old Knuckle Bones been of some use, Goddess? Must look a little worn, but... brought me fortune many times, in games of chance and when my life was on the line."
      Speaker = "Odysseus"
      Event = "OdysseusAboutKeepsake01"
    }
    {
      Id = "Melinoe_4189"
      InheritFrom = "BaseNarrative"
      DisplayName = "Odysseus, if they were dear to you all through your life, why would you give them to me now? No matter how useful they still may be, which is quite a bit!"
      Speaker = "Melinoe"
      Event = "OdysseusAboutKeepsake01"
    }
    {
      Id = "Odysseus_0401"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come now, nothing would please me more than for you to succeed. If some small token of my past could be of benefit, it's yours. Besides, I got a Nectar bottle in exchange!"
      Speaker = "Odysseus"
      Event = "OdysseusAboutKeepsake01"
    }
    {
      Id = "Melinoe_4190"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It wasn't meant to be a trade."
      Speaker = "Melinoe"
      Event = "OdysseusAboutKeepsake01"
    }
    {
      Id = "Odysseus_0402"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just keep the blasted Bones."
      Speaker = "Odysseus"
      Event = "OdysseusAboutKeepsake01"
    }
    {
      Id = "Odysseus_0145"
      InheritFrom = "BaseNarrative"
      DisplayName = "See Charon's latest haul, Goddess? Shipment by the riverside, all yours. And we're watching the rivers, making certain this won't be the last."
      Speaker = "Odysseus"
      Event = "OdysseusAboutMailbox01"
    }
    {
      Id = "Melinoe_2335"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lord Charon risks aiding my efforts in such a direct way. Are we able to compensate him at all?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutMailbox01"
    }
    {
      Id = "Odysseus_0146"
      InheritFrom = "BaseNarrative"
      DisplayName = "Aye, with what Gold we've gathered recently. He really means to melt down every last one of those Chronos coins we can get our hands on."
      Speaker = "Odysseus"
      Event = "OdysseusAboutMailbox01"
    }
    {
      Id = "Melinoe_2336"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh yes."
      Speaker = "Melinoe"
      Event = "OdysseusAboutMailbox01"
    }
    {
      Id = "Odysseus_0427"
      InheritFrom = "BaseNarrative"
      DisplayName = "You must be Charon's finest customer. I reckon he enjoys the frequent visits to the Underworld, in his way. At least it's mostly cargo shipments now, not just confused, complaining Shades of the recently deceased..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutMailbox02"
    }
    {
      Id = "Melinoe_4217"
      InheritFrom = "BaseNarrative"
      DisplayName = "Did you accept your death with dignity when it was finally your time, Odysseus? You seem as though you would have clung to life with all your might."
      Speaker = "Melinoe"
      Event = "OdysseusAboutMailbox02"
    }
    {
      Id = "Odysseus_0428"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, I'd gotten on in years by then. Still didn't care much for the circumstances, not that anybody does! Though, I did appreciate the opportunity to meet the fearsome Boatman at long last, and ride into the Underworld the {#Emph}proper {#Prev}way."
      Speaker = "Odysseus"
      Event = "OdysseusAboutMailbox02"
    }
    {
      Id = "Melinoe_4218"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've mentioned that you'd gone into the Underworld and back while you still lived. Lord Charon didn't take you then?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutMailbox02"
    }
    {
      Id = "Odysseus_0429"
      InheritFrom = "BaseSubtitle"
      DisplayName = "He certainly did not! A tale for another night, perhaps."
      Speaker = "Odysseus"
      Event = "OdysseusAboutMailbox02"
    }
    {
      Id = "Odysseus_0265"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your little garden there has cheered this old place up a bit, Goddess! In trying times, such simple pleasures oft are first to fade. Precisely when they're needed most."
      Speaker = "Odysseus"
      Event = "OdysseusAboutGarden01"
    }
    {
      Id = "Melinoe_3309"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thank you, and pleased to hear it, Great Tactician. Though, I'd not expected a mere flower patch to leave such an impression on someone like you."
      Speaker = "Melinoe"
      Event = "OdysseusAboutGarden01"
    }
    {
      Id = "Odysseus_0266"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come now, all I {#Emph}do {#Prev}is pay attention to details. Victory comes to those whose hearts are predisposed. I mean, look at us, our spirits are quite literally all we have; and now, flowers!"
      Speaker = "Odysseus"
      Event = "OdysseusAboutGarden01"
    }
    {
      Id = "Melinoe_3310"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Help keep an eye on them for me, would you?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutGarden01"
    }
    {
      Id = "Odysseus_0267"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Of course."
      Speaker = "Odysseus"
      Event = "OdysseusAboutGarden01"
    }
    {
      Id = "Odysseus_0434"
      InheritFrom = "BaseNarrative"
      DisplayName = "Note we have several projects to expand these Crossroads that could use your blessings when you get the opportunity, Goddess. Your choice, and there's no urgency at all."
      Speaker = "Odysseus"
      Event = "OdysseusAboutCrossroads01"
    }
    {
      Id = "Melinoe_4222"
      InheritFrom = "BaseNarrative"
      DisplayName = "Eventually the waters in the hot springs and the fishing pier need to be purified, not to mention the taverna grounds. Have you a preferential order between those?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutCrossroads01"
    }
    {
      Id = "Odysseus_0435"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well you know the Shades, they like to gather up in the taverna, so I reckon I'd start there... or whichever one is simplest for you!"
      Speaker = "Odysseus"
      Event = "OdysseusAboutCrossroads01"
    }
    {
      Id = "Melinoe_4223"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll look into it."
      Speaker = "Melinoe"
      Event = "OdysseusAboutCrossroads01"
    }
    {
      Id = "Odysseus_0183"
      InheritFrom = "BaseNarrative"
      DisplayName = "That renewal project that we used to talk about? I still think of it all the time, these Crossroads flourishing with worldly delights...!"
      Speaker = "Odysseus"
      Event = "OdysseusAboutCosmetics01"
    }
    {
      Id = "Melinoe_3800"
      InheritFrom = "BaseNarrative"
      DisplayName = "I still think about it, too, and made some preliminary steps of late. The well-being of every last Shade in this place is important to our goal."
      Speaker = "Melinoe"
      Event = "OdysseusAboutCosmetics01"
    }
    {
      Id = "Odysseus_0184"
      InheritFrom = "BaseNarrative"
      DisplayName = "But, we've more pressing matters now, it seems. What, you intend to stop fighting Chronos just to spruce up the surroundings here?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutCosmetics01"
    }
    {
      Id = "Melinoe_3801"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not exactly. I have a delegate in mind."
      Speaker = "Melinoe"
      Event = "OdysseusAboutCosmetics01"
    }
    {
      Id = "Odysseus_0185"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Interesting..."
      Speaker = "Odysseus"
      Event = "OdysseusAboutCosmetics01"
    }
    {
      Id = "Odysseus_0186"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've recruited that one shifty-looking Shade for the renewal project! A scrappy start is still a start, I'm... pleased to see it underway!"
      Speaker = "Odysseus"
      Event = "OdysseusAboutCosmetics02"
    }
    {
      Id = "Melinoe_3802"
      InheritFrom = "BaseNarrative"
      DisplayName = "I thought you might say that! It gives Dora something practical to do. And means the project needn't be a hopeless dream."
      Speaker = "Melinoe"
      Event = "OdysseusAboutCosmetics02"
    }
    {
      Id = "Odysseus_0187"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A sound plan, Goddess."
      Speaker = "Odysseus"
      Event = "OdysseusAboutCosmetics02"
    }
    {
      Id = "Odysseus_0424"
      InheritFrom = "BaseNarrative"
      DisplayName = "This new table's {#Emph}excellent! {#Prev}Plenty of room for our map of all the regions that we're monitoring, and these side compartments for our new reports, and an elegant finish...!"
      Speaker = "Odysseus"
      Event = "OdysseusAboutTable01"
    }
    {
      Id = "Melinoe_4215"
      InheritFrom = "BaseNarrative"
      DisplayName = "Odysseus, somehow I'd not expected you to have this much enthusiasm for a piece of furnishing. Especially a piece you strictly need to carry out your duties here."
      Speaker = "Melinoe"
      Event = "OdysseusAboutTable01"
    }
    {
      Id = "Odysseus_0425"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, that's quite an accusation... coming from someone who seems to love her work at {#Emph}least {#Prev}as much as I. Or perhaps you've just never had a proper {#Emph}table {#Prev}to your name?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutTable01"
    }
    {
      Id = "Melinoe_4216"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I don't use tables much now that you mention it."
      Speaker = "Melinoe"
      Event = "OdysseusAboutTable01"
    }
    {
      Id = "Odysseus_0426"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Your loss!"
      Speaker = "Odysseus"
      Event = "OdysseusAboutTable01"
    }
    {
      Id = "Odysseus_0525"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's grown much livelier now with the Music Maker here! A fine choice of recruit for us, Goddess. I was always partial to a rousing battle-ballad, though a variety is welcome, too."
      Speaker = "Odysseus"
      Event = "OdysseusAboutMusicPlayer01"
    }
    {
      Id = "Melinoe_4224"
      InheritFrom = "BaseNarrative"
      DisplayName = "I figured that the Music Maker would grow rather popular quite soon. Got any song requests?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutMusicPlayer01"
    }
    {
      Id = "Odysseus_0526"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh you don't want to know; happy for {#Emph}you {#Prev}to make the hard decisions there!"
      Speaker = "Odysseus"
      Event = "OdysseusAboutMusicPlayer01"
    }
    {
      Id = "Melinoe_4225"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And live with the consequences, yes."
      Speaker = "Melinoe"
      Event = "OdysseusAboutMusicPlayer01"
    }
    {
      Id = "Odysseus_0527"
      InheritFrom = "BaseNarrative"
      DisplayName = "Our Record Keeper there once worked in a secure Administrative Chamber in your father's halls, if you can believe it, Goddess. Must have been quite the experience!"
      Speaker = "Odysseus"
      Event = "OdysseusAboutGameStats01"
    }
    {
      Id = "Melinoe_4226"
      InheritFrom = "BaseNarrative"
      DisplayName = "My father must have prized such analytical minds as that one's. Perhaps once all of this is over, the Record Keeper could return to working in my father's House."
      Speaker = "Melinoe"
      Event = "OdysseusAboutGameStats01"
    }
    {
      Id = "Odysseus_0528"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd floated that idea myself, to which the Record Keeper cowered, for some reason, and refused to talk to me again! Bit of an odd one, aye?"
      Speaker = "Odysseus"
      Event = "OdysseusAboutGameStats01"
    }
    {
      Id = "Melinoe_4227"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Probably been through quite a bit."
      Speaker = "Melinoe"
      Event = "OdysseusAboutGameStats01"
    }
    {
      Id = "Odysseus_0414"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've gone at this for fifty nights at least, Goddess. Is there occasion yet to give yourself a bit of a reprieve? You're putting yourself through a lot is all."
      Speaker = "Odysseus"
      Event = "OdysseusAboutRunProgress01"
    }
    {
      Id = "Melinoe_4202"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've had reprieve along the way, thank you. The springs, the garden, the taverna... even just conversing like this! It's not as though I'm pushing myself in every waking moment."
      Speaker = "Melinoe"
      Event = "OdysseusAboutRunProgress01"
    }
    {
      Id = "Odysseus_0415"
      InheritFrom = "BaseNarrative"
      DisplayName = "Aye, we never can push ourselves as hard as possible for as long as we'd like. But, you've come a long way, and in the off chance you're not keeping track, I am!"
      Speaker = "Odysseus"
      Event = "OdysseusAboutRunProgress01"
    }
    {
      Id = "Melinoe_4203"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Good. And I'll go farther still."
      Speaker = "Melinoe"
      Event = "OdysseusAboutRunProgress01"
    }
    {
      Id = "Odysseus_0416"
      InheritFrom = "BaseNarrative"
      DisplayName = "This is about your hundredth night, Goddess... several moons at least in mortal terms. Feels like a while, yet no time at all. That's the insidious work of Chronos for you!"
      Speaker = "Odysseus"
      Event = "OdysseusAboutRunProgress02"
    }
    {
      Id = "Melinoe_4204"
      InheritFrom = "BaseNarrative"
      DisplayName = "I think you're right, now that you mention it! The passage of time has always felt strange to me, but even more so since this all began. Did you feel similarly in your mortal days?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutRunProgress02"
    }
    {
      Id = "Odysseus_0417"
      InheritFrom = "BaseNarrative"
      DisplayName = "Aye, like you have no idea. It must be even stranger for you gods... so much time can pass in the blink of an eye! The best we all can do is use it well."
      Speaker = "Odysseus"
      Event = "OdysseusAboutRunProgress02"
    }
    {
      Id = "Odysseus_0710"
      InheritFrom = "BaseNarrative"
      DisplayName = "According to our counts, you have prevailed on more than fifty nights now, Goddess. Wanted to take a moment to celebrate that achievement with you."
      Speaker = "Odysseus"
      Event = "OdysseusAboutRunProgress03"
    }
    {
      Id = "Melinoe_5447"
      InheritFrom = "BaseNarrative"
      DisplayName = "Has it already been that long? Time works in strange ways."
      Speaker = "Melinoe"
      Event = "OdysseusAboutRunProgress03"
    }
    {
      Id = "Odysseus_0711"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Aye, we can all agree on that by now."
      Speaker = "Odysseus"
      Event = "OdysseusAboutRunProgress03"
    }
    {
      Id = "Odysseus_0712"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's been five hundred nights since all of this began, Goddess. Well, more or less. In mortal terms... that's quite a while. Perhaps even for you."
      Speaker = "Odysseus"
      Event = "OdysseusAboutRunProgress04"
    }
    {
      Id = "Melinoe_5448"
      InheritFrom = "BaseNarrative"
      DisplayName = "I ceased keeping track at a certain point, and relinquished any coherent sense of the passage of time. When do you suppose we ought to wind down on all this?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutRunProgress04"
    }
    {
      Id = "Odysseus_0713"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Whenever you please, and no sooner than that."
      Speaker = "Odysseus"
      Event = "OdysseusAboutRunProgress04"
    }
    {
      Id = "Odysseus_0178"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come join us, Goddess! I was just regaling the Shades about when first I traveled to the Underworld. Whilst I yet lived and breathed, if you can believe it! And thusly I got out."
      Speaker = "Odysseus"
      Event = "OdysseusBackstory02"
    }
    {
      Id = "Melinoe_2197"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come on, Odysseus, there was no escape from here when my father ruled. Are these Shades truly so impressionable?"
      Speaker = "Melinoe"
      Event = "OdysseusBackstory02"
    }
    {
      Id = "Odysseus_0179"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh I'm {#Emph}dead serious! {#Prev}My tales aren't... quite as tall as they may seem! But now, the gates of hell are flung wide open, aren't they...?"
      Speaker = "Odysseus"
      Event = "OdysseusBackstory02"
    }
    {
      Id = "Melinoe_2198"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We're going to seal them shut."
      Speaker = "Melinoe"
      Event = "OdysseusBackstory02"
    }
    {
      Id = "Melinoe_2197_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come on, Odysseus. Are these Shades truly so impressionable?"
      Speaker = "Melinoe"
      Event = "OdysseusBackstory02_B"
    }
    {
      Id = "Melinoe_5243"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not for much longer!"
      Speaker = "Melinoe"
      Event = "OdysseusBackstory02_B"
    }
    {
      Id = "Odysseus_0180"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh! {#Prev}Hail, Goddess, I, {#Emph}erm... {#Prev}didn't notice your approach. Half-inclined to blame the onset of the years, but I've no such excuses in this state."
      Speaker = "Odysseus"
      Event = "OdysseusAboutMood01"
    }
    {
      Id = "Melinoe_2199"
      InheritFrom = "BaseNarrative"
      DisplayName = "I didn't mean to startle you. How's the mood been around here, everything all right?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutMood01"
    }
    {
      Id = "Odysseus_0181"
      InheritFrom = "BaseNarrative"
      DisplayName = "Mood and everything is well enough. Our ranks swell with Shades moved by the tale that the Princess of the Underworld has returned, with vengeance on her mind."
      Speaker = "Odysseus"
      Event = "OdysseusAboutMood01"
    }
    {
      Id = "Melinoe_2200"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nothing like a bit of sworn vengeance to inspire the masses. Though, what about you?"
      Speaker = "Melinoe"
      Event = "OdysseusAboutMood01"
    }
    {
      Id = "Odysseus_0182"
      InheritFrom = "BaseNarrative"
      DisplayName = "Everything's shipshape with me; especially after a brief reprieve right here. Be well, Goddess."
      Speaker = "Odysseus"
      Event = "OdysseusAboutMood01"
    }
    {
      Id = "Melinoe_2201"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You, too."
      Speaker = "Melinoe"
      Event = "OdysseusAboutMood01"
    }
    {
      Id = "Melinoe_2118"
      InheritFrom = "BaseNarrative"
      DisplayName = "Odysseus, have you seen Hecate about?"
      Speaker = "Melinoe"
      Event = "OdysseusHideAndSeek01"
    }
    {
      Id = "Odysseus_0200"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Mm{#Prev}, not in a little while, little goddess. Though, I'd expect that pointy hat of hers to give her away!"
      Speaker = "Odysseus"
      Event = "OdysseusHideAndSeek01"
    }
    {
      Id = "Melinoe_2119"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll look for it! Thank you!"
      Speaker = "Melinoe"
      Event = "OdysseusHideAndSeek01"
    }
    {
      Id = "Odysseus_0201"
      InheritFrom = "BaseSubtitle"
      DisplayName = "She's got to be around here somewhere, little goddess!"
      Speaker = "Odysseus"
      Event = "OdysseusHideAndSeek01"
    }
    {
      Id = "Odysseus_0359"
      InheritFrom = "BaseNarrative"
      DisplayName = "It isn't much but our Shades out there, they... scraped together some {#Emph}materials {#Prev}that we reckon you could use. Here! Least we can do."
      Speaker = "Odysseus"
      Event = "OdysseusGrantsMetaCardPoints01"
    }
    {
      Id = "Melinoe_4093"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ash of the Dead... Odysseus, are these...? Our Shades are giving up their own mortal remains. All for our cause."
      Speaker = "Melinoe"
      Event = "OdysseusGrantsMetaCardPoints01"
    }
    {
      Id = "Odysseus_0360"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And who can blame them?"
      Speaker = "Odysseus"
      Event = "OdysseusGrantsMetaCardPoints01"
    }
    {
      Id = "Odysseus_0361"
      InheritFrom = "BaseNarrative"
      DisplayName = "Back in my mortal days, bronze was the most precious metal that I knew, so quickly could it cut a man's life short. But I've come to understand your appreciation for silver! Go on. Take it! Our Shades and I, we practically insist."
      Speaker = "Odysseus"
      Event = "OdysseusGrantsOreFSilver01"
    }
    {
      Id = "Melinoe_4094"
      InheritFrom = "BaseNarrative"
      DisplayName = "Truly? Silver so pure isn't easy to come by, even with the proper tools. I'll make good use of it, for all our sakes."
      Speaker = "Melinoe"
      Event = "OdysseusGrantsOreFSilver01"
    }
    {
      Id = "Odysseus_0362"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's all we ask."
      Speaker = "Odysseus"
      Event = "OdysseusGrantsOreFSilver01"
    }
    {
      Id = "Odysseus_0363"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're on the prowl for ingredients that can go into that pot, aren't you, Goddess? Here, perhaps you can use these. No mere flowers, I've been told."
      Speaker = "Odysseus"
      Event = "OdysseusGrantsPlantFMoly01"
    }
    {
      Id = "Melinoe_4095"
      InheritFrom = "BaseNarrative"
      DisplayName = "Fresh Molies...! The roots are still perfectly black. Several incantations I've been mulling all would benefit from these. How did you know?"
      Speaker = "Melinoe"
      Event = "OdysseusGrantsPlantFMoly01"
    }
    {
      Id = "Odysseus_0364"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Oh{#Prev}, I have my ways."
      Speaker = "Odysseus"
      Event = "OdysseusGrantsPlantFMoly01"
    }
    {
      Id = "Odysseus_0365"
      InheritFrom = "BaseNarrative"
      DisplayName = "You'll soon surpass the good witch at your current rate, Goddess! So say some of our Shades at least, and they make a persuasive argument. Here! A symbol of their faith."
      Speaker = "Odysseus"
      Event = "OdysseusGrantsMemPointsCommon01"
    }
    {
      Id = "Melinoe_4096"
      InheritFrom = "BaseNarrative"
      DisplayName = "They would relinquish some of their Psyche, to benefit a task I never could achieve alone..."
      Speaker = "Melinoe"
      Event = "OdysseusGrantsMemPointsCommon01"
    }
    {
      Id = "Odysseus_0366"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Fortunately, you don't have to!"
      Speaker = "Odysseus"
      Event = "OdysseusGrantsMemPointsCommon01"
    }
    {
      Id = "Odysseus_0367"
      InheritFrom = "BaseNarrative"
      DisplayName = "A bit of something for you here, Goddess. The gift of skeletal remains would not be looked on favorably back where I come from, but then... you've more respect for the dead than mortals generally did."
      Speaker = "Odysseus"
      Event = "OdysseusGrantsMetaCurrency01"
    }
    {
      Id = "Melinoe_4097"
      InheritFrom = "BaseNarrative"
      DisplayName = "More Bones than I can quickly count, or locate on my own. Then I shall leave them in the Wretched Broker's care!"
      Speaker = "Melinoe"
      Event = "OdysseusGrantsMetaCurrency01"
    }
    {
      Id = "Odysseus_0368"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And get yourself a fair deal in exchange."
      Speaker = "Odysseus"
      Event = "OdysseusGrantsMetaCurrency01"
    }
    {
      Id = "Odysseus_0369"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm not the sort to dwell too much about what the Three Fates may have in store for us, Goddess, but... I do have a bit of Fabric we attribute to their work. And now it's yours."
      Speaker = "Odysseus"
      Event = "OdysseusGrantsMetaFabric01"
    }
    {
      Id = "Melinoe_4098"
      InheritFrom = "BaseNarrative"
      DisplayName = "Fate Fabric! Few better ways to ensure the cauldron properly conducts a magickal effect. I could definitely use this if you'd be so kind."
      Speaker = "Melinoe"
      Event = "OdysseusGrantsMetaFabric01"
    }
    {
      Id = "Odysseus_0370"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh I'm not {#Emph}kind{#Prev}, I just... don't like to lose."
      Speaker = "Odysseus"
      Event = "OdysseusGrantsMetaFabric01"
    }
    {
      Id = "Odysseus_0371"
      InheritFrom = "BaseNarrative"
      DisplayName = "Beautiful night, isn't it? The kind where one may catch brief glimpses of the Moon amid her race across the sky. She even left a little something for you here."
      Speaker = "Odysseus"
      Event = "OdysseusGrantsCardUpgradePoints01"
    }
    {
      Id = "Melinoe_4099"
      InheritFrom = "BaseNarrative"
      DisplayName = "Moon Dust. You've no idea how much I could use this in my meditations recently...! Although you always have an idea, don't you?"
      Speaker = "Melinoe"
      Event = "OdysseusGrantsCardUpgradePoints01"
    }
    {
      Id = "Odysseus_0372"
      InheritFrom = "BaseSubtitle"
      DisplayName = "One, at the very least."
      Speaker = "Odysseus"
      Event = "OdysseusGrantsCardUpgradePoints01"
    }
    {
      Id = "Odysseus_0373"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got something here for you, Goddess. For whenever our little garden over there could use a little extra greenery... or if you're ever left unsure about what to plant next."
      Speaker = "Odysseus"
      Event = "OdysseusGrantsSeedMystery01"
    }
    {
      Id = "Melinoe_4100"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thank you, Odysseus! But, what are these? I try to keep whatever seeds I find well-organized."
      Speaker = "Melinoe"
      Event = "OdysseusGrantsSeedMystery01"
    }
    {
      Id = "Odysseus_0374"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Mystery Seeds! A little surprise."
      Speaker = "Odysseus"
      Event = "OdysseusGrantsSeedMystery01"
    }
    {
      Id = "Odysseus_0375"
      InheritFrom = "BaseNarrative"
      DisplayName = "Our Shades report good things about your Animal Familiars, you know. Not all such creatures get on well with spirits of the dead, so... here's a little token of appreciation!"
      Speaker = "Odysseus"
      Event = "OdysseusGrantsFamiliarPoints01"
    }
    {
      Id = "Melinoe_4101"
      InheritFrom = "BaseNarrative"
      DisplayName = "Witch's Delight, cooked to perfection. Headmistress must have made this batch herself... does she know you're giving this to me?"
      Speaker = "Melinoe"
      Event = "OdysseusGrantsFamiliarPoints01"
    }
    {
      Id = "Odysseus_0376"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just take the blasted gifts, Goddess, the Shades insist!"
      Speaker = "Odysseus"
      Event = "OdysseusGrantsFamiliarPoints01"
    }
    {
      Id = "Odysseus_0629"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have an offering for you, Goddess! On behalf of all the Shades residing here, we are honored to be in your service and stand ready to do whatever it takes to prevail! Please share these spoils with whomever you see fit."
      Speaker = "Odysseus"
      Event = "OdysseusGrantsGiftPoints01"
    }
    {
      Id = "Melinoe_5230"
      InheritFrom = "BaseNarrative"
      DisplayName = "Some Nectar, thank you! I feel like one of the gods of Olympus right now. You truly won't mind if I pass these bottles along?"
      Speaker = "Melinoe"
      Event = "OdysseusGrantsGiftPoints01"
    }
    {
      Id = "Odysseus_0630"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Shades and I would only mind if you hoarded them."
      Speaker = "Odysseus"
      Event = "OdysseusGrantsGiftPoints01"
    }
    {
      Id = "Hecate_0201"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Tactician brings ill tidings with an optimistic bent. Fine. And what news from the men of the isles, if any yet survive?"
      Speaker = "Hecate"
      Event = "OdysseusWithHecate01"
    }
    {
      Id = "Odysseus_0042"
      InheritFrom = "BaseNarrative"
      DisplayName = "According to my confidants, they've all sworn in with Chronos, I'm afraid. Mortals... they often want whatever they don't have. Another Golden Age, in this case. The {#Emph}promise {#Prev}of one."
      Speaker = "Odysseus"
      Event = "OdysseusWithHecate01"
    }
    {
      Id = "Hecate_0202"
      InheritFrom = "BaseNarrative"
      DisplayName = "'Tis a {#Emph}lie {#Prev}that spurs their betrayal, rather than a promise. They shall perish, then... by the wrath of the gods."
      Speaker = "Hecate"
      Event = "OdysseusWithHecate01"
    }
    {
      Id = "Odysseus_0043"
      InheritFrom = "BaseNarrative"
      DisplayName = "And then their wretched souls shall hound us with renewed vengefulness. I've witnessed endless wars before, Madam. So have you gods. How can we stop this?"
      Speaker = "Odysseus"
      Event = "OdysseusWithHecate01"
    }
    {
      Id = "Hecate_0203"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}We {#Prev}cannot. {#Emph}Melinoë{#Prev}, however? Certainly {#Emph}you {#Prev}can, correct?"
      Speaker = "Hecate"
      Event = "OdysseusWithHecate01"
    }
    {
      Id = "Melinoe_0459"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I can and shall."
      Speaker = "Melinoe"
      Event = "OdysseusWithHecate01"
    }
    {
      Id = "Odysseus_0149"
      InheritFrom = "BaseNarrative"
      DisplayName = "...And, {#Emph}erm{#Prev}, that's the end of my report this time, Madam. Should you have any questions, please don't hesitate to summon me at any time."
      Speaker = "Odysseus"
      Event = "OdysseusWithHecate02"
    }
    {
      Id = "Hecate_0204"
      InheritFrom = "BaseNarrative"
      DisplayName = "I shan't, Odysseus. Although, there is one further matter that I wanted to discuss with you, and rather quietly..."
      Speaker = "Hecate"
      Event = "OdysseusWithHecate02"
    }
    {
      Id = "Odysseus_0150"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Certainly, Madam."
      Speaker = "Odysseus"
      Event = "OdysseusWithHecate02"
    }
    {
      Id = "Odysseus_0708"
      InheritFrom = "BaseNarrative"
      DisplayName = "...In short, the reconstruction is proceeding, though not at a brisk pace, and the damage on the surface is contained. Wounds that shall slowly heal. We'll see what scars remain."
      Speaker = "Odysseus"
      Event = "OdysseusWithHecate03"
    }
    {
      Id = "Hecate_0881"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sister Selene makes a similar assessment. Well, then... what shall you do from here, Odysseus? You could visit the surface whilst the Underworld remains in disrepair."
      Speaker = "Hecate"
      Event = "OdysseusWithHecate03"
    }
    {
      Id = "Odysseus_0709"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh I may wander for a bit, Madam, but... by your leave, I'd like to keep the Crossroads as my base of operations for the time. I reckon we've a good thing going here, don't we?"
      Speaker = "Odysseus"
      Event = "OdysseusWithHecate03"
    }
    {
      Id = "Hecate_0882"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I daresay yes we do."
      Speaker = "Hecate"
      Event = "OdysseusWithHecate03"
    }
    {
      Id = "Odysseus_0164"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I'm saying that the possibility exists. Eternal vigilance is near impossible. Enemies have always exploited the lack thereof... I ever tell you of the old wooden horse trick?"
      Speaker = "Odysseus"
      Event = "OdysseusWithNemesis01"
    }
    {
      Id = "Nemesis_0135"
      InheritFrom = "BaseNarrative"
      DisplayName = "The old wooden horse trick, yeah. Surely your reputation as the Great Tactician hinges on more than this one tale?"
      Speaker = "Nemesis"
      Event = "OdysseusWithNemesis01"
    }
    {
      Id = "Odysseus_0165"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, but classics ought to be retold! Though, if you'd rather, I have far more tales of trickery and valor. Take the Cave of the Cyclops!"
      Speaker = "Odysseus"
      Event = "OdysseusWithNemesis01"
    }
    {
      Id = "Nemesis_0136"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not Cave of the Cyclops..."
      Speaker = "Nemesis"
      Event = "OdysseusWithNemesis01"
    }
    {
      Id = "Odysseus_0004"
      InheritFrom = "BaseNarrative"
      DisplayName = "You watch your back out there, all right?"
      Speaker = "Odysseus"
      Event = "OdysseusChat01"
    }
    {
      Id = "Odysseus_0005"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ready to take another stab at this, Goddess?"
      Speaker = "Odysseus"
      Event = "OdysseusChat02"
    }
    {
      Id = "Odysseus_0006"
      InheritFrom = "BaseNarrative"
      DisplayName = "If I were Chronos, I'd be properly afraid of you."
      Speaker = "Odysseus"
      Event = "OdysseusChat03"
    }
    {
      Id = "Odysseus_0007"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got everything here well under control."
      Speaker = "Odysseus"
      Event = "OdysseusChat04"
    }
    {
      Id = "Odysseus_0008"
      InheritFrom = "BaseNarrative"
      DisplayName = "Courage, Goddess. And no quarter to your enemies, all right?"
      Speaker = "Odysseus"
      Event = "OdysseusChat05"
    }
    {
      Id = "Odysseus_0009"
      InheritFrom = "BaseNarrative"
      DisplayName = "Moonlight guide you, as you witches say."
      Speaker = "Odysseus"
      Event = "OdysseusChat06"
    }
    {
      Id = "Odysseus_0010"
      InheritFrom = "BaseNarrative"
      DisplayName = "Quite a mess we've gotten ourselves into, haven't we?"
      Speaker = "Odysseus"
      Event = "OdysseusChat07"
    }
    {
      Id = "Odysseus_0011"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know things must seem dire, but take heart. We'll navigate through this."
      Speaker = "Odysseus"
      Event = "OdysseusChat08"
    }
    {
      Id = "Odysseus_0012"
      InheritFrom = "BaseNarrative"
      DisplayName = "Any luck finding the head of Chronos yet?"
      Speaker = "Odysseus"
      Event = "OdysseusChat09"
    }
    {
      Id = "Odysseus_0013"
      InheritFrom = "BaseNarrative"
      DisplayName = "Be sure to hit them where it hurts for me, will you?"
      Speaker = "Odysseus"
      Event = "OdysseusChat10"
    }
    {
      Id = "Odysseus_0014"
      InheritFrom = "BaseNarrative"
      DisplayName = "All's well enough here. We'll see you when you're back."
      Speaker = "Odysseus"
      Event = "OdysseusChat11"
    }
    {
      Id = "Odysseus_0015"
      InheritFrom = "BaseNarrative"
      DisplayName = "Death to Chronos and all that, aye?"
      Speaker = "Odysseus"
      Event = "OdysseusChat12"
    }
    {
      Id = "Odysseus_0016"
      InheritFrom = "BaseNarrative"
      DisplayName = "Beg pardon, Goddess, I must get this correspondence to the surface right away."
      Speaker = "Odysseus"
      Event = "OdysseusChat13"
    }
    {
      Id = "Odysseus_0017"
      InheritFrom = "BaseNarrative"
      DisplayName = "Fresh shipment of supplies came in whilst you were out."
      Speaker = "Odysseus"
      Event = "OdysseusChat14"
    }
    {
      Id = "Odysseus_0018"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't mind me, Goddess, I'm just busy drafting up some of our latest schemes."
      Speaker = "Odysseus"
      Event = "OdysseusChat15"
    }
    {
      Id = "Odysseus_0019"
      InheritFrom = "BaseNarrative"
      DisplayName = "We've many sympathizers on the surface and below still loyal to your father."
      Speaker = "Odysseus"
      Event = "OdysseusChat16"
    }
    {
      Id = "Odysseus_0020"
      InheritFrom = "BaseNarrative"
      DisplayName = "Go forth and slaughter me some wretched traitors, will you, Goddess?"
      Speaker = "Odysseus"
      Event = "OdysseusChat17"
    }
    {
      Id = "Odysseus_0021"
      InheritFrom = "BaseNarrative"
      DisplayName = "Once more you grace me with your presence here, Goddess."
      Speaker = "Odysseus"
      Event = "OdysseusChat18"
    }
    {
      Id = "Odysseus_0022"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Eh{#Prev}, would that we could talk like this a while, but I've a matter to resolve."
      Speaker = "Odysseus"
      Event = "OdysseusChat19"
    }
    {
      Id = "Odysseus_0023"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Nightmare Goddess stands before me in all her glory..."
      Speaker = "Odysseus"
      Event = "OdysseusChat20"
    }
    {
      Id = "Odysseus_0024"
      InheritFrom = "BaseNarrative"
      DisplayName = "You need anything at all, you know where to find me, Goddess."
      Speaker = "Odysseus"
      Event = "OdysseusChat21"
    }
    {
      Id = "Odysseus_0025"
      InheritFrom = "BaseNarrative"
      DisplayName = "You come back safely, else I'll have to venture out there and haul you in myself."
      Speaker = "Odysseus"
      Event = "OdysseusChat22"
    }
    {
      Id = "Odysseus_0026"
      InheritFrom = "BaseNarrative"
      DisplayName = "You'll have your vengeance, Goddess. I am sure of it."
      Speaker = "Odysseus"
      Event = "OdysseusChat23"
    }
    {
      Id = "Odysseus_0027"
      InheritFrom = "BaseNarrative"
      DisplayName = "We'll dig ourselves out of this one yet, you rest assured, Goddess."
      Speaker = "Odysseus"
      Event = "OdysseusChat24"
    }
    {
      Id = "Odysseus_0320"
      InheritFrom = "BaseNarrative"
      DisplayName = "May your witchery and silver always serve you well."
      Speaker = "Odysseus"
      Event = "OdysseusChat25"
    }
    {
      Id = "Odysseus_0321"
      InheritFrom = "BaseNarrative"
      DisplayName = "No telling what the Fates may have in store for us, aye?"
      Speaker = "Odysseus"
      Event = "OdysseusChat26"
    }
    {
      Id = "Odysseus_0322"
      InheritFrom = "BaseNarrative"
      DisplayName = "Always a pleasure to be in your company, Goddess."
      Speaker = "Odysseus"
      Event = "OdysseusChat27"
    }
    {
      Id = "Odysseus_0323"
      InheritFrom = "BaseNarrative"
      DisplayName = "Through hard times such as these, our bonds grow strong."
      Speaker = "Odysseus"
      Event = "OdysseusChat28"
    }
    {
      Id = "Odysseus_0324"
      InheritFrom = "BaseNarrative"
      DisplayName = "The good witch is very proud of you, you know that, aye?"
      Speaker = "Odysseus"
      Event = "OdysseusChat29"
    }
    {
      Id = "Odysseus_0325"
      InheritFrom = "BaseNarrative"
      DisplayName = "Our Shades shall keep us well apprised of your progress."
      Speaker = "Odysseus"
      Event = "OdysseusChat30"
    }
    {
      Id = "Odysseus_0326"
      InheritFrom = "BaseNarrative"
      DisplayName = "There's not much worse than being separated from one's family, aye...?"
      Speaker = "Odysseus"
      Event = "OdysseusChat31"
    }
    {
      Id = "Odysseus_0327"
      InheritFrom = "BaseNarrative"
      DisplayName = "We'll back you on this every step of the way, as many nights as it requires, Goddess."
      Speaker = "Odysseus"
      Event = "OdysseusChat32"
    }
    {
      Id = "Odysseus_0477"
      InheritFrom = "BaseNarrative"
      DisplayName = "Even I get a break from time to time, as should {#Emph}you!"
      Speaker = "Odysseus"
      Event = "OdysseusTavernaChat01"
    }
    {
      Id = "Odysseus_0478"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just having a quick drink here with our fellow Shades."
      Speaker = "Odysseus"
      Event = "OdysseusTavernaChat02"
    }
    {
      Id = "Odysseus_0479"
      InheritFrom = "BaseNarrative"
      DisplayName = "Turns out I can take reports in the taverna here, Goddess!"
      Speaker = "Odysseus"
      Event = "OdysseusTavernaChat03"
    }
    {
      Id = "Odysseus_0480"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lively bunch we've got for a bunch of deadbeats, aye?"
      Speaker = "Odysseus"
      Event = "OdysseusTavernaChat04"
    }
    {
      Id = "Odysseus_0481"
      InheritFrom = "BaseNarrative"
      DisplayName = "You see that, lads? I told you she'd turn up!"
      Speaker = "Odysseus"
      Event = "OdysseusTavernaChat05"
    }
    {
      Id = "Odysseus_0482"
      InheritFrom = "BaseNarrative"
      DisplayName = "Stick around a bit, Goddess! You've earned some rest."
      Speaker = "Odysseus"
      Event = "OdysseusTavernaChat06"
    }
    {
      Id = "Melinoe_0471"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey Odysseus? Got you something here I wanted you to have. For always keeping an eye out!"
      Speaker = "Melinoe"
      Event = "OdysseusGift01"
    }
    {
      Id = "Odysseus_0087"
      InheritFrom = "BaseNarrative"
      DisplayName = "Goddess, your presence alone is all I could ask. Though, if you're in a giving mood, then perhaps you'll accept a small gift from me, in turn?"
      Speaker = "Odysseus"
      Event = "OdysseusGift01"
    }
    {
      Id = "Odysseus_0088"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm most grateful, Goddess, and expect to knock this back at the taverna at the soonest opportunity."
      Speaker = "Odysseus"
      Event = "OdysseusGift02"
    }
    {
      Id = "Melinoe_0473"
      InheritFrom = "BaseNarrative"
      DisplayName = "No rush! Just as long as you enjoy it when that opportunity presents itself!"
      Speaker = "Melinoe"
      Event = "OdysseusGift02"
    }
    {
      Id = "Odysseus_0089"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, would you look at that! How could I possibly say no? It seems you've found my weakness here, Goddess."
      Speaker = "Odysseus"
      Event = "OdysseusGift03"
    }
    {
      Id = "Melinoe_0474"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Great Tactician has no weaknesses, I'm sure! Though he does now have an extra bottle of Nectar."
      Speaker = "Melinoe"
      Event = "OdysseusGift03"
    }
    {
      Id = "Odysseus_0090"
      InheritFrom = "BaseNarrative"
      DisplayName = "I ought to be the one honoring {#Emph}you{#Prev}, Goddess. My inclination is to save this for the moment of our victory, but it's good to have in reserve, in case of some emergency, you understand."
      Speaker = "Odysseus"
      Event = "OdysseusGift04"
    }
    {
      Id = "Melinoe_0475"
      InheritFrom = "BaseNarrative"
      DisplayName = "I understand, indeed! And you already honor me with your friendship, Odysseus... as well as with your knowledge about how to deal swift death!"
      Speaker = "Melinoe"
      Event = "OdysseusGift04"
    }
    {
      Id = "Odysseus_0091"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh {#Emph}I see {#Prev}what you're up to, here, Goddess! If you continue to exploit my weakness to this stuff, I may yet learn to turn it to a strength. Good plan!"
      Speaker = "Odysseus"
      Event = "OdysseusGift05"
    }
    {
      Id = "Melinoe_0476"
      InheritFrom = "BaseNarrative"
      DisplayName = "What can I say? I learned from the best. May you grow stronger and stronger."
      Speaker = "Melinoe"
      Event = "OdysseusGift05"
    }
    {
      Id = "Odysseus_0653"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know, I journeyed far and wide throughout my mortal days, meeting great mortals and even greater gods, but... never could I have imagined ending up here, only to receive such a handsome gift from one such as you."
      Speaker = "Odysseus"
      Event = "OdysseusGift06"
    }
    {
      Id = "Melinoe_0477"
      InheritFrom = "BaseNarrative"
      DisplayName = "They say life takes strange turns, and so apparently does death, Odysseus. Whatever the Fates may have in store, I hope you'll always be nearby to lend your counsel."
      Speaker = "Melinoe"
      Event = "OdysseusGift06"
    }
    {
      Id = "Odysseus_0654"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well I do like to travel, but... I think you'll always know where to find me. Cheers for the Nectar... should last me through whatever hard times are to come."
      Speaker = "Odysseus"
      Event = "OdysseusGift06"
    }
    {
      Id = "Melinoe_5083"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey how about a visit to the taverna if you're not overly preoccupied right now? This Ambrosia here needs opening!"
      Speaker = "Melinoe"
      Event = "OdysseusGift07"
    }
    {
      Id = "Odysseus_0545"
      InheritFrom = "BaseNarrative"
      DisplayName = "That it most certainly does, but, and this pains me to say, I've too many reports right now requiring verification. A lot's been going on. So... perhaps later?"
      Speaker = "Odysseus"
      Event = "OdysseusGift07"
    }
    {
      Id = "Melinoe_5084"
      InheritFrom = "BaseNarrative"
      DisplayName = "How about you hold onto the bottle then? {#Emph}Later {#Prev}can be whenever you desire. Your Shade informants could even come along!"
      Speaker = "Melinoe"
      Event = "OdysseusGift07"
    }
    {
      Id = "Odysseus_0546"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hah{#Prev}, there's a thought! I'd likely never hear from them again. Though that would {#Emph}also {#Prev}mean I could visit the taverna more often..."
      Speaker = "Odysseus"
      Event = "OdysseusGift07"
    }
    {
      Id = "Melinoe_5085"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The makings of a plan...!"
      Speaker = "Melinoe"
      Event = "OdysseusGift07"
    }
    {
      Id = "Melinoe_5092"
      InheritFrom = "BaseNarrative"
      DisplayName = "What would you say to a productive evening of inspiring more loyalty over at the taverna again? I enjoy our conversations there."
      Speaker = "Melinoe"
      Event = "OdysseusGift08"
    }
    {
      Id = "Odysseus_0553"
      InheritFrom = "BaseNarrative"
      DisplayName = "I {#Emph}would {#Prev}say let's be off immediately, but I {#Emph}must {#Prev}say, I'm anticipating word from an informant soon and so need to stay put... I also mean... to visit the taverna somewhat less."
      Speaker = "Odysseus"
      Event = "OdysseusGift08"
    }
    {
      Id = "Melinoe_5093"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh! {#Prev}I apologize. It's not been my intent to keep attempting to draw you away from your responsibilities."
      Speaker = "Melinoe"
      Event = "OdysseusGift08"
    }
    {
      Id = "Odysseus_0554"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's nothing that you did, it's just... I knew the sorts who spent their days and nights feasting, taking leave of their senses. I swore never to be so indulgent. To always leave {#Emph}some {#Prev}of my desires unfulfilled."
      Speaker = "Odysseus"
      Event = "OdysseusGift08"
    }
    {
      Id = "Melinoe_5094"
      InheritFrom = "BaseNarrative"
      DisplayName = "I understand the feeling. To yearn for something is a driving force. Though, how about we give this bottle to your informant? For a duty well-performed."
      Speaker = "Melinoe"
      Event = "OdysseusGift08"
    }
    {
      Id = "Odysseus_0555"
      InheritFrom = "BaseNarrative"
      DisplayName = "An excellent tactical choice. I'll tell them it was courtesy of the Princess of the Underworld herself!"
      Speaker = "Odysseus"
      Event = "OdysseusGift08"
    }
    {
      Id = "Melinoe_5095"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'd rather it be from both of us."
      Speaker = "Melinoe"
      Event = "OdysseusGift08"
    }
    {
      Id = "Odysseus_0556"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hah. {#Prev}Fine."
      Speaker = "Odysseus"
      Event = "OdysseusGift08"
    }
    {
      Id = "Melinoe_3342"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you're not too caught up in your reports right now, what do you say we put this bottle of Ambrosia to its proper use?"
      Speaker = "Melinoe"
      Event = "OdysseusTaverna01"
    }
    {
      Id = "Odysseus_0280"
      InheritFrom = "BaseNarrative"
      DisplayName = "I {#Emph}am {#Prev}caught up in my reports, Goddess! Focused on what matters most... meet you at the taverna."
      Speaker = "Odysseus"
      Event = "OdysseusTaverna01"
    }
    {
      Id = "Odysseus_0281"
      InheritFrom = "BaseNarrative"
      DisplayName = "...We mortals had what we called {#Emph}wine{#Prev}, an acrid sort of drink made of crushed {#Emph}grapes{#Prev}. We'd sometimes say it tasted as good as Ambrosia, but... it most certainly did not."
      Speaker = "Odysseus"
      Event = "OdysseusTaverna01"
    }
    {
      Id = "Melinoe_3343"
      InheritFrom = "BaseNarrative"
      DisplayName = "You speak of so many hardships from your mortal days and nights and yet, there's always this sense of longing there... you miss those times, don't you?"
      Speaker = "Melinoe"
      Event = "OdysseusTaverna01"
    }
    {
      Id = "Odysseus_0282"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Such moments and occasions do occur. I know a lot more {#Emph}now {#Prev}than I did then, and... sometimes I miss that feeling... knowing less. Or the camaraderie of sailing with my crew."
      Speaker = "Odysseus"
      Event = "OdysseusTaverna01"
    }
    {
      Id = "Melinoe_3344"
      InheritFrom = "BaseNarrative"
      DisplayName = "But many of your crew are with you here now, right? Even the Shade of your old dog. How can you miss them if they're still around?"
      Speaker = "Melinoe"
      Event = "OdysseusTaverna01"
    }
    {
      Id = "Odysseus_0283"
      InheritFrom = "BaseNarrative"
      DisplayName = "We're Shades, Goddess, and... not all quite as whole as I. Besides, you still can miss your past with those you still know now! Remember when you used to play at hiding with our good witch, back when you were very small?"
      Speaker = "Odysseus"
      Event = "OdysseusTaverna01"
    }
    {
      Id = "Melinoe_3345"
      InheritFrom = "BaseNarrative"
      DisplayName = "I never thought that we were playing; she was teaching me to hunt for unseen prey. But, I {#Emph}do {#Prev}see your point."
      Speaker = "Melinoe"
      Event = "OdysseusTaverna01"
    }
    {
      Id = "Odysseus_0284"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well my original point was merely that this Ambrosia's {#Emph}really {#Prev}something else! Let us ensure it does not go to waste."
      Speaker = "Odysseus"
      Event = "OdysseusTaverna01"
    }
    {
      Id = "Odysseus_0285"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd not realized how much I needed that. It's true what they say, that Ambrosia tastes much better in good company."
      Speaker = "Odysseus"
      Event = "OdysseusTaverna01"
    }
    {
      Id = "Melinoe_0769"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Of course."
      Speaker = "Melinoe"
      Event = "OdysseusTaverna01"
    }
    {
      Id = "Melinoe_5086"
      InheritFrom = "BaseNarrative"
      DisplayName = "How go the reports this evening, or rather, do you have occasion for a taverna break perhaps?"
      Speaker = "Melinoe"
      Event = "OdysseusTaverna02"
    }
    {
      Id = "Odysseus_0547"
      InheritFrom = "BaseNarrative"
      DisplayName = "Reckon I could join you for just such an occasion, now that you raise the possibility, Goddess. You ready now?"
      Speaker = "Odysseus"
      Event = "OdysseusTaverna02"
    }
    {
      Id = "Odysseus_0548"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I fought alongside quite a number of these Shades, you know. Loyal in life as well as now in death... where do you suppose that comes from? Loyalty, I mean."
      Speaker = "Odysseus"
      Event = "OdysseusTaverna02"
    }
    {
      Id = "Melinoe_5087"
      InheritFrom = "BaseNarrative"
      DisplayName = "Having a sense of purpose or a cause. And, a basic desire for stability and truth. Loyalty is consistency."
      Speaker = "Melinoe"
      Event = "OdysseusTaverna02"
    }
    {
      Id = "Odysseus_0549"
      InheritFrom = "BaseNarrative"
      DisplayName = "Aye to all that, but it is even simpler to me! Loyalty comes from individuals. It's like a form of love; some give it, some receive it, sometimes it's mutual, sometimes it's not."
      Speaker = "Odysseus"
      Event = "OdysseusTaverna02"
    }
    {
      Id = "Melinoe_5088"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress always taught me never to demand loyalty. {#Emph}Loyalty wears thin if not for trust{#Prev}, she'd say. Did your fellow Shades follow you out of loyalty or obligation?"
      Speaker = "Melinoe"
      Event = "OdysseusTaverna02"
    }
    {
      Id = "Odysseus_0550"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hm! {#Prev}A mix of each. The good witch is right that the best kind of loyalty is given. I reckon {#Emph}you {#Prev}inspire {#Emph}that {#Prev}sort, Goddess; the both of you. I'd not have stayed here this long otherwise."
      Speaker = "Odysseus"
      Event = "OdysseusTaverna02"
    }
    {
      Id = "Melinoe_5089"
      InheritFrom = "BaseNarrative"
      DisplayName = "Chronos certainly could have used someone of your skill and experience. With all his promises of a new Golden Age, surely he commands quite a bit of loyalty himself."
      Speaker = "Melinoe"
      Event = "OdysseusTaverna02"
    }
    {
      Id = "Odysseus_0551"
      InheritFrom = "BaseNarrative"
      DisplayName = "I tried serving tyrants before; wasn't for me. Now, what do you say we inspire some more loyalty {#Emph}right now? {#Prev}Let's have these Shades come join us for a round."
      Speaker = "Odysseus"
      Event = "OdysseusTaverna02"
    }
    {
      Id = "Odysseus_0552"
      InheritFrom = "BaseNarrative"
      DisplayName = "How is it that we got so much done on what was meant to be a break? Anyhow, the Shades were grateful! As am I."
      Speaker = "Odysseus"
      Event = "OdysseusTaverna02"
    }
    {
      Id = "Melinoe_5091"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We should do it again!"
      Speaker = "Melinoe"
      Event = "OdysseusTaverna02"
    }
    {
      Id = "Melinoe_0470"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got these Twin Lures, Odysseus, and I can't exactly use them on my own. You know the rules!"
      Speaker = "Melinoe"
      Event = "OdysseusFishing01"
    }
    {
      Id = "Odysseus_0066"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Fishing! {#Prev}My greatest weakness, Goddess! The waters and I haven't always mixed, but perhaps it'll go better for me now. Besides, I'm overdue for a short leave. Let's go!"
      Speaker = "Odysseus"
      Event = "OdysseusFishing01"
    }
    {
      Id = "Odysseus_0251"
      InheritFrom = "BaseNarrative"
      DisplayName = "Used to be I fished out of necessity alone. The earth would oft be stingy with her bounties, whilst the sea would yield plenty to us mortals, if we knew where to look."
      Speaker = "Odysseus"
      Event = "OdysseusFishing01"
    }
    {
      Id = "Melinoe_3322"
      InheritFrom = "BaseNarrative"
      DisplayName = "What's been the biggest difference for you since those times? Not having to eat for sustenance? Not having to watch your mortal body slowly fall apart as you grew older?"
      Speaker = "Melinoe"
      Event = "OdysseusFishing01"
    }
    {
      Id = "Odysseus_0252"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Heh{#Prev}, well! You already know a couple of those points if for some reason we were tasked to make a list, but... the biggest difference, if I had to choose, is that... I finally am free."
      Speaker = "Odysseus"
      Event = "OdysseusFishing01"
    }
    {
      Id = "Melinoe_3323"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're free? But as a mortal, weren't you a king? A mighty warrior, leader of men... and a husband, and a father! Here you have a place of honor, too, except... we dwell in shadows. Our deeds are never to be told."
      Speaker = "Melinoe"
      Event = "OdysseusFishing01"
    }
    {
      Id = "Odysseus_0253"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, we shall see about that last bit, but for the rest! Perhaps I got all of the wanderlust out of my system whilst I lived and breathed. Most of it, anyhow!"
      Speaker = "Odysseus"
      Event = "OdysseusFishing01"
    }
    {
      Id = "Odysseus_0084"
      InheritFrom = "BaseNarrative"
      DisplayName = "I thoroughly enjoyed our outing, though I still thoroughly hate fish."
      Speaker = "Odysseus"
      Event = "OdysseusFishing01"
    }
    {
      Id = "Melinoe_5096"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey what if we stop by the fishing pier again? It's been a while, and standing patiently is far less indulgent than sipping Ambrosia, right?"
      Speaker = "Melinoe"
      Event = "OdysseusFishing02"
    }
    {
      Id = "Odysseus_0557"
      InheritFrom = "BaseNarrative"
      DisplayName = "You make a compelling argument, Goddess! And, I ought to confront my {#Emph}discomfort {#Prev}with the waters more. Head on over and I'll be there soon."
      Speaker = "Odysseus"
      Event = "OdysseusFishing02"
    }
    {
      Id = "Odysseus_0558"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Something I should tell you, by the way. These times we spend together, which I thoroughly enjoy, I... wouldn't want the other Shades to get the wrong impression."
      Speaker = "Odysseus"
      Event = "OdysseusFishing02"
    }
    {
      Id = "Melinoe_5097"
      InheritFrom = "BaseNarrative"
      DisplayName = "And what impression would that be? {#Emph}Oh{#Prev}, you mean their mortal preconceptions. A man and a goddess together can only mean one thing. End up one way."
      Speaker = "Melinoe"
      Event = "OdysseusFishing02"
    }
    {
      Id = "Odysseus_0559"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well yes, but it's a preconception rooted in events that have occurred... including to me. And even though our Shades are {#Emph}loyal{#Prev}, they {#Emph}do {#Prev}like to gossip, we know that."
      Speaker = "Odysseus"
      Event = "OdysseusFishing02"
    }
    {
      Id = "Melinoe_5098"
      InheritFrom = "BaseNarrative"
      DisplayName = "I suppose. If anything they ought be gossiping about Headmistress and yourself, rather than us."
      Speaker = "Melinoe"
      Event = "OdysseusFishing02"
    }
    {
      Id = "Odysseus_0560"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}What? {#Prev}Oh come on, Goddess, the good witch and I... we're like... oh blast, there must be {#Emph}some {#Prev}appropriate analogy..."
      Speaker = "Odysseus"
      Event = "OdysseusFishing02"
    }
    {
      Id = "Melinoe_5099"
      InheritFrom = "BaseNarrative"
      DisplayName = "I didn't mean to overreach, it's just... well, I can think of many reasons that Headmistress would inspire loyalty in someone such as you. And you in her."
      Speaker = "Melinoe"
      Event = "OdysseusFishing02"
    }
    {
      Id = "Odysseus_0561"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Augh{#Prev}, you're as bad as those gossiping Shades, except I can't have {#Emph}you {#Prev}banished for your conduct. Now, what do you say we scoop some fish out of these waters, aye?"
      Speaker = "Odysseus"
      Event = "OdysseusFishing02"
    }
    {
      Id = "Odysseus_0562"
      InheritFrom = "BaseNarrative"
      DisplayName = "...{#Emph}Ah. {#Prev}It's been good to chat away a bit instead of having to give counsel all the time, so cheers for that, Goddess. But, don't tell the good witch or anyone what you told me...?"
      Speaker = "Odysseus"
      Event = "OdysseusFishing02"
    }
    {
      Id = "Melinoe_5100"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I won't, I won't..."
      Speaker = "Melinoe"
      Event = "OdysseusFishing02"
    }
    {
      Id = "Melinoe_0462"
      InheritFrom = "BaseNarrative"
      DisplayName = "I was just thinking nothing clears the mind like a refreshing, burning-hot soak. Care to accompany me?"
      Speaker = "Melinoe"
      Event = "OdysseusBathHouse01"
    }
    {
      Id = "Odysseus_0655"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, I do enjoy a good relaxing bath, even whilst dead, and who am I to say no to a goddess... so why not!"
      Speaker = "Odysseus"
      Event = "OdysseusBathHouse01"
    }
    {
      Id = "Odysseus_0656"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know your customs and mine aren't quite the same, but my eyes are going to remain averted here, if that's all right."
      Speaker = "Odysseus"
      Event = "OdysseusBathHouse01"
    }
    {
      Id = "Melinoe_0464"
      InheritFrom = "BaseNarrative"
      DisplayName = "Would mortals often {#Emph}bathe{#Prev}, Odysseus?"
      Speaker = "Melinoe"
      Event = "OdysseusBathHouse01"
    }
    {
      Id = "Odysseus_0657"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, {#Emph}erm{#Prev}, well... perhaps once in a while, when they could. Though, seldomly both men and women at the same time. Doing so could seem... untoward."
      Speaker = "Odysseus"
      Event = "OdysseusBathHouse01"
    }
    {
      Id = "Melinoe_0465"
      InheritFrom = "BaseNarrative"
      DisplayName = "I see. We gods have no such shame, I realize. Have I made you uncomfortable?"
      Speaker = "Melinoe"
      Event = "OdysseusBathHouse01"
    }
    {
      Id = "Odysseus_0658"
      InheritFrom = "BaseNarrative"
      DisplayName = "Me? No, no, of course not! In fact I've bathed with goddesses before, it's just... it's been a little while."
      Speaker = "Odysseus"
      Event = "OdysseusBathHouse01"
    }
    {
      Id = "Melinoe_5242"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh that's all right, doubtless you'll recall the finer points. You mostly just have to try and let go your burdens."
      Speaker = "Melinoe"
      Event = "OdysseusBathHouse01"
    }
    {
      Id = "Odysseus_0659"
      InheritFrom = "BaseNarrative"
      DisplayName = "Should be simple, as I've many of those! In fact no matter how many I let go, it seems some yet remain. Though being here does help."
      Speaker = "Odysseus"
      Event = "OdysseusBathHouse01"
    }
    {
      Id = "Melinoe_0466"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well... as long as it's agreeable for you."
      Speaker = "Melinoe"
      Event = "OdysseusBathHouse01"
    }
    {
      Id = "Odysseus_0063"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well! Don't know about you, but I am properly relaxed, I'd say!"
      Speaker = "Odysseus"
      Event = "OdysseusBathHouse01"
    }
    {
      Id = "Melinoe_0463"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey I was thinking I'm due for a good boil in the springs. Join me for a bit?"
      Speaker = "Melinoe"
      Event = "OdysseusBathHouse02"
    }
    {
      Id = "Odysseus_0048"
      InheritFrom = "BaseNarrative"
      DisplayName = "A visit to the baths, with you, right now? {#Emph}Hah! {#Prev}Sure! I'm honored to accompany you, Goddess."
      Speaker = "Odysseus"
      Event = "OdysseusBathHouse02"
    }
    {
      Id = "Odysseus_0051"
      InheritFrom = "BaseNarrative"
      DisplayName = "I trust the temperature is to your liking, aye?"
      Speaker = "Odysseus"
      Event = "OdysseusBathHouse02"
    }
    {
      Id = "Melinoe_0467"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've met many goddesses even in your mortal days, haven't you...?"
      Speaker = "Melinoe"
      Event = "OdysseusBathHouse02"
    }
    {
      Id = "Odysseus_0060"
      InheritFrom = "BaseNarrative"
      DisplayName = "In this I'm very fortunate, indeed. The lady Athena often watched over me. I'd never have survived the war if not for her. Then, on my travels home, there was Calypso... and Circe..."
      Speaker = "Odysseus"
      Event = "OdysseusBathHouse02"
    }
    {
      Id = "Melinoe_3217"
      InheritFrom = "BaseNarrative"
      DisplayName = "Circe used to study under Headmistress, always with her crystals. And Calypso... she's a Nymph, correct? A lesser goddess I suppose."
      Speaker = "Melinoe"
      Event = "OdysseusBathHouse02"
    }
    {
      Id = "Odysseus_0061"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nothing lesser about her, with respect. These goddesses, they... enthralled me each in their own right. Almost made me forget myself. Forget my family."
      Speaker = "Odysseus"
      Event = "OdysseusBathHouse02"
    }
    {
      Id = "Melinoe_0469"
      InheritFrom = "BaseNarrative"
      DisplayName = "But you did not forget. You made your journey home. Even I know the tale."
      Speaker = "Melinoe"
      Event = "OdysseusBathHouse02"
    }
    {
      Id = "Odysseus_0062"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's a tale, Goddess. Anyway, life takes its complicated turns. Take it from me."
      Speaker = "Odysseus"
      Event = "OdysseusBathHouse02"
    }
    {
      Id = "Odysseus_0064"
      InheritFrom = "BaseNarrative"
      DisplayName = "That was a splendid and much-needed time. Truly appreciate the invitation."
      Speaker = "Odysseus"
      Event = "OdysseusBathHouse02"
    }
    {
      Id = "Melinoe_0460"
      InheritFrom = "BaseNarrative"
      DisplayName = "Odysseus, how about alleviating the rigors of all this tactical planning with a visit to the springs?"
      Speaker = "Melinoe"
      Event = "OdysseusBathHouseDecline01"
    }
    {
      Id = "Odysseus_0046"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Erm, {#Prev}I really do appreciate the offer, Goddess, just... I reckon your Headmistress would rather I stay here. You understand, don't you?"
      Speaker = "Odysseus"
      Event = "OdysseusBathHouseDecline01"
    }
    {
      Id = "Melinoe_0461"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Maybe some other time."
      Speaker = "Melinoe"
      Event = "OdysseusBathHouseDecline01"
    }
    {
      Id = "Melinoe_1156"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Odysseus on leave..."
      Speaker = "Melinoe"
      Event = "NPC_Odysseus_01.MissingDistanceTrigger.VoiceLines"
    }
    {
      Id = "Melinoe_2412"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Odysseus out checking on reports..."
      Speaker = "Melinoe"
      Event = "NPC_Odysseus_01.MissingDistanceTrigger.VoiceLines"
    }
    {
      Id = "Melinoe_2413"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Odysseus must be needed elsewhere..."
      Speaker = "Melinoe"
      Event = "NPC_Odysseus_01.MissingDistanceTrigger.VoiceLines"
    }
    {
      Id = "Melinoe_1157"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Odysseus is on assignment huh?"
      Speaker = "Melinoe"
      Event = "NPC_Odysseus_01.MissingDistanceTrigger.VoiceLines"
    }
    {
      Id = "Melinoe_2899"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Your trusty Knuckle Bones? Thank you!"
      Speaker = "Melinoe"
      Event = "NPC_Odysseus_01.GiftGivenVoiceLines"
    }
    {
      Id = "Odysseus_0566"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Scylla and the Sirens..."
      Speaker = "Odysseus"
      Event = "GlobalVoiceLines.OdysseusSongReactionVoiceLines"
    }
    {
      Id = "Odysseus_0312"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Blast..."
      Speaker = "Odysseus"
      Event = "GlobalVoiceLines.OdysseusSongReactionVoiceLines"
    }
    {
      Id = "Odysseus_0439"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We play to {#Emph}win!"
      Speaker = "Odysseus"
      Event = "GlobalVoiceLines.OdysseusPreDamageVoiceLines"
    }
    {
      Id = "Odysseus_0440"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Whatever it takes."
      Speaker = "Odysseus"
      Event = "GlobalVoiceLines.OdysseusPreDamageVoiceLines"
    }
    {
      Id = "Odysseus_0441"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Let's even the odds."
      Speaker = "Odysseus"
      Event = "GlobalVoiceLines.OdysseusPreDamageVoiceLines"
    }
    {
      Id = "Odysseus_0442"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Fight to survive!"
      Speaker = "Odysseus"
      Event = "GlobalVoiceLines.OdysseusPreDamageVoiceLines"
    }
    {
      Id = "Odysseus_0443"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Seize victory!"
      Speaker = "Odysseus"
      Event = "GlobalVoiceLines.OdysseusPreDamageVoiceLines"
    }
    {
      Id = "Odysseus_0444"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We {#Emph}never {#Prev}hesitate!"
      Speaker = "Odysseus"
      Event = "GlobalVoiceLines.OdysseusPreDamageVoiceLines"
    }
    {
      Id = "Odysseus_0445"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Ahoy again, Scylla!"
      Speaker = "Odysseus"
      Event = "GlobalVoiceLines.OdysseusPreDamageVoiceLines"
    }
    {
      Id = "Odysseus_0446"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Remember me, Cyclops?"
      Speaker = "Odysseus"
      Event = "GlobalVoiceLines.OdysseusPreDamageVoiceLines"
    }
    {
      Id = "Odysseus_0447"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Get him{#Prev}, Goddess!"
      Speaker = "Odysseus"
      Event = "GlobalVoiceLines.OdysseusPreDamageVoiceLines"
    }
    {
      Id = "Odysseus_0448"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You have this, {#Emph}go!"
      Speaker = "Odysseus"
      Event = "GlobalVoiceLines.OdysseusPreDamageVoiceLines"
    }
  ]
}
