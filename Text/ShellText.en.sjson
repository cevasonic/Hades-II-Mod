    /* Gameplay Options / Controls Options */
    {
      Id = "EasyMode"
      DisplayName = "{!Icons.EasyModeIcon} God Mode"
      Description = """
      {#AlertHighlightFormat}Instantly makes you tougher, more so whenever you fail.

      {#AlertItalicFormat}Failure is the greatest instructor of all. {#Prev}Try this if you find you're struggling, want to focus on the story, or any reason.
      """
    }
    {
      Id = "EasyModeResistanceCap"
