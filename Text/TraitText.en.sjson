    /* Meta Upgrades / MetaUpgrades / Arcana Cards / Card Table Cards */
    {
      Id = "IncreaseMetaUpgradeCard"
      DisplayName = "Grasp of the Arcana"
      Description = "Gain {#UpgradeFormat}+{$TempTextData.Amount} {#Prev}{#MemFormatBold}Grasp{#Prev}. Greater {#MemFormatBold}Grasp {#Prev}lets you activate more {#BoldFormat}Arcana Cards {#Prev}at once."
    }    
    {
     Id = "ChanneledCast"
     DisplayName = "The Sorceress"
     Description = "Your {$Keywords.Omega} are {$TooltipData.StatDisplay1} faster."
    }
    {
     Id = "ChanneledCast_FlavorText01"
     DisplayName = "Left to her own devices, she learned to confront the world on her own terms."
    }

    {
     Id = "LowManaDamageBonus"
     DisplayName = "The Huntress"
     Description = "While you have less than {#ManaFormat}{$TraitData.LowManaDamageMetaupgrade.AddOutgoingDamageModifiers.FullManaThreshold}%{!Icons.Mana}{#Prev}, your {$Keywords.Attack} and {$Keywords.Special} deal {$TooltipData.StatDisplay1} damage."
    }
    {
     Id = "LowManaDamageMetaupgrade_Tray"
     DisplayName = "The Huntress"
     Description = "While you have less than {#ManaFormat}{$TraitData.LowManaDamageMetaupgrade.AddOutgoingDamageModifiers.FullManaThreshold}%{!Icons.Mana}{#Prev}, your {$Keywords.Attack} and {$Keywords.Special} deal {$TooltipData.StatDisplay1} damage."
    }
    {
      Id = "LowManaDamageBonus_FlavorText01"
      DisplayName = "Through discipline and instinct comes surpassing skill both in shadow and the light of the Moon."
    }
    
    {
      Id = "BonusHealth"
      DisplayName = "Persistence"
      Description = "You have {#UpgradeFormat}{$TooltipData.StatDisplay2}{!Icons.HealthUp} {#Prev}and {#UpgradeFormat}{$TooltipData.StatDisplay1}{!Icons.ManaUp}{#Prev}."
    }
    {
      Id = "HealthManaBonusMetaUpgrade"
      InheritFrom = "BonusHealth"
      Description = "You have {$TooltipData.StatDisplay2}{!Icons.HealthUp} and {$TooltipData.StatDisplay1}{!Icons.ManaUp}."
    }
    {
     Id = "BonusHealth_FlavorText01"
     DisplayName = "He stole from gods the gift of fire, for mortals; thus he suffered, but grew strong."
    }

    {
     Id = "ManaOverTime"
     DisplayName = "The Unseen"
     Description = "You restore {$TooltipData.StatDisplay1}{#Prev}{!Icons.Mana} every {#BoldFormat}1 Sec."
    }
    {
     Id = "ManaOverTimeMetaUpgrade_Tray"
     DisplayName = "The Unseen"
     Description = "You restore {$TooltipData.StatDisplay1}{#Prev}{!Icons.Mana} every {#BoldFormat}1 Sec."
    }
    {
     Id = "ManaOverTime_FlavorText01"
     DisplayName = "Upon their ancient oath, in shadow, they serve; and to shadow, they return."
    }

    {
     Id = "CastBuff"
     DisplayName = "The Furies"
     Description = "You deal {$TooltipData.StatDisplay1} damage to foes in your {$Keywords.CastSet}."
    }
    {
     Id = "CastBuff_FlavorText01"
     DisplayName = "In the deepest reaches of the Underworld, three are as feared as the god of the dead himself."
    }
    
    {
     Id = "StartingGold"
     DisplayName = "The Boatman"
     Description = "You have {#AltUpgradeFormat}{$TooltipData.StatDisplay1}{#Prev}{!Icons.Currency}."
    }
    {
     Id = "StartingGold_FlavorText01"
     DisplayName = "Vast riches lie hidden in the realm of the dead; but only a modest fee is needed to get in."
    }

    {
      Id = "SprintShield"
      DisplayName = "The Swift Runner"
      Description = "Your {$Keywords.Sprint} is {#UpgradeFormat}{$TooltipData.StatDisplay1} {#Prev}faster and lets you pass through most foes in your way."
    }
    {
      Id = "SprintShieldMetaUpgrade_Tray"
	  InheritFrom = "SprintShield"
      Description = "Your {$Keywords.Sprint} is {#UpgradeFormat}{$TooltipData.StatDisplay1} {#Prev}faster and lets you pass through most foes in your way."
    }

    {
      Id = "DodgeSprint_FlavorText01"
      DisplayName = "Those who attempted to confront the greatest of the Greeks merely met his spear."
    }
    
    {
      Id = "ChanneledBlock"
      DisplayName = "The Lovers"
      Description = "You take {#BoldFormatGraft}0 {#Prev}damage the first {#AltUpgradeFormat}{$TooltipData.StatDisplay1} {#Prev}time(s) you are hit in {$Keywords.Boss} {$Keywords.EncounterPlural}."
    }
    {
      Id = "ChanneledBlock_Tray"
      InheritFrom = "ChanneledBlock"
      Description = "You take {#BoldFormatGraft}0 {#Prev}damage the first {#AltUpgradeFormat}{$TooltipData.StatDisplay1} {#Prev}time(s) you are hit in {$Keywords.Boss} {$Keywords.EncounterPlural}."
    }
    {
      Id = "ChanneledBlock_FlavorText01"
      DisplayName = "Their music brought them together, and not even Death could keep them apart for long."
    }

    {
     Id = "HealthRegen"
     DisplayName = "The Wayward Son"
     Description = "After you exit a {$Keywords.RoomAlt}, restore {$TooltipData.StatDisplay1}{!Icons.Health}."
    }
    {
     Id = "HealthRegen_Vow"
     DisplayName = "The Wayward Son"
     Description = "After you exit a {$Keywords.RoomAlt}, restore {$TooltipData.StatDisplay1}{!Icons.Health}, less than usual due to the {#PenaltyFormat}{$TooltipData.CustomStatLinesWithShrineUpgrade.ShrineUpgradeName}{#Prev}."
    }
    {
      Id = "DoorHealMetaUpgrade_Tray"
      DisplayName = "The Wayward Son"
      Description = "After you exit a {$Keywords.RoomAlt}, restore {$TooltipData.StatDisplay1}{!Icons.Health}."
    }
    {
      Id = "HealthRegen_FlavorText01"
      DisplayName = "Even the Underworld itself struggled to contain him, such was his lust for life."
    }

    {
      Id = "LastStand"
      DisplayName = "Death"
      Description = "You have {$TooltipData.StatDisplay1} {$Keywords.ExtraChance}."
    }
    {
      Id = "LastStand_Tray"
      InheritFrom = "LastStand"
      Description = "You have {$TooltipData.StatDisplay1} {$Keywords.ExtraChance}."
    }
    {
      Id = "LastStand_FlavorText01"
      DisplayName = "Some mortals would sense his soft approach, others taken by surprise."
    }
    {
      Id = "CastCount"
      DisplayName = "Eternity"
      Description = "While you {$Keywords.HoldNoTooltip} your {$Keywords.Omega}, everything moves slower for {#UpgradeFormat}{$TooltipData.StatDisplay1} Sec."
    }
    {
      Id = "CastCount_Tray"
      InheritFrom = "CastCount"
      Description = "While you {$Keywords.HoldNoTooltip} your {$Keywords.Omega}, everything moves slower for {#UpgradeFormat}{$TooltipData.StatDisplay1} Sec."
    }
    {
      Id = "CastCount_FlavorText01"
      DisplayName = "The inevitable cannot be prevented, though perhaps can be forestalled."
    }
    {
      Id = "BonusDodge"
      DisplayName = "The Messenger"
      Description = "Your {$Keywords.CastSet} momentarily make you {$Keywords.Invulnerable} and move {$TooltipData.StatDisplay1} faster."
    }
    {
      Id = "BonusDodge_AutoEquip"
      DisplayName = "{$Keywords.AutoEquip}: {#ItalicLightFormat}Activate at least {#BoldFormat}{$MetaUpgradeCardData.BonusDodge.AutoEquipRequirements.MinDuplicateCount} {#Prev}Cards that use the same amount of {!Icons.ManaCrystal}."
    }

    {
      Id = "DodgeBonusMetaUpgrade"
      InheritFrom = "BonusDodge"
    }
    {
      Id = "BonusDodgeMetaUpgrade_Tray"
      InheritFrom = "BonusDodge"
      Description = "Your {$Keywords.CastSet} momentarily make you {$Keywords.Invulnerable} and move {$TooltipData.StatDisplay1} faster."
    }
    {
      Id = "BonusDodge_FlavorText01"
      DisplayName = "With incomparable swiftness can he travel from the highest peaks to the lowest depths."
    }

    {
      Id = "MaxHealthPerRoom"
      DisplayName = "The Centaur"
      Description = "You gain {#UpgradeFormat}{$TooltipData.StatDisplay1}{#Prev}{!Icons.HealthUp} and {#UpgradeFormat}{$TooltipData.StatDisplay1}{#Prev}{!Icons.ManaUp} whenever you pass through {$TooltipData.ExtractData.RoomInterval} {$Keywords.RoomPlural}."
    }
    {
      Id = "MaxHealthPerRoom_Tray"
      InheritFrom = "MaxHealthPerRoom"
      Description = "You gain {#UpgradeFormat}{$TooltipData.StatDisplay1}{#Prev}{!Icons.HealthUp} and {#UpgradeFormat}{$TooltipData.StatDisplay1}{#Prev}{!Icons.ManaUp} whenever you pass through {$TooltipData.ExtractData.RoomInterval} {$Keywords.RoomPlural}."
    }
    {
      Id = "MaxHealthPerRoom_AutoEquip"
      DisplayName = "{$Keywords.AutoEquip}: {#ItalicLightFormat}Activate Cards that use {#GraspFormat}1{#Prev}{!Icons.ManaCrystal} through {#GraspFormat}{$TooltipData.ExtractData.Requirement}{!Icons.ManaCrystal}{#Prev}."
    }
    {
      Id = "MaxHealthPerRoom_FlavorText01"
      DisplayName = "Many of the greatest heroes mortalkind has to offer have in common his patient instruction."
    }
    {
      Id = "StatusVulnerability"
      DisplayName = "Origination"
      Description = "You deal {$TooltipData.StatDisplay1} damage to foes with at least {#BoldFormatGraft}{$TraitData.EffectVulnerabilityMetaUpgrade.AddOutgoingDamageModifiers.MinRequiredVulnerabilityEffects} {#Prev}{$Keywords.StatusPluralAlt} from different Olympians."
    }
    {
      Id = "EffectVulnerabilityMetaUpgrade_Tray"
      InheritFrom = "StatusVulnerability"
      Description = "You deal {$TooltipData.StatDisplay1} damage to foes with at least {#BoldFormatGraft}{$TraitData.EffectVulnerabilityMetaUpgrade.AddOutgoingDamageModifiers.MinRequiredVulnerabilityEffects} {#Prev}{$Keywords.StatusPluralAlt} from different Olympians."
    }
    {
      Id = "StatusVulnerability_FlavorText01"
      DisplayName = "From the infinite void emerged all that exists, and back to that void it all may yet return."
    }
    {
      Id = "MagicCrit"
      DisplayName = "Night"
      Description = "You have {$TooltipData.StatDisplay1} chance to deal {$Keywords.Crit} damage with each move in an {$Keywords.DeathBuff}."
    }
    {
      Id = "MagicCritMetaUpgrade_Tray"
      InheritFrom = "MagicCrit"
      Description = "You have {$TooltipData.StatDisplay1} chance to deal {$Keywords.Crit} damage with each move in an {$Keywords.DeathBuff}."
    }
    {
     Id = "MagicCrit_FlavorText01"
     DisplayName = "She sprang from Chaos, and formed much of the natural world, above the surface and below."
    }
    {
      Id = "DoorReroll"
      DisplayName = "The Enchantress"
      Description = "You have {#UpgradeFormat}{$TooltipData.StatDisplay1}{#Prev}{!Icons.ReRollAlt}, and can alter {#BoldFormat}Location Rewards{#Prev}."
    }
    {
      Id = "DoorReroll_Tray"
      InheritFrom = "DoorReroll"
      Description = "You have {#UpgradeFormat}{$TooltipData.StatDisplay1}{#Prev}{!Icons.ReRollAlt}, and can alter {#BoldFormat}Location Rewards{#Prev}."
    }
    {
      Id = "DoorReroll_FlavorText01"
      DisplayName = "In mastering metamorphosis, she discovered that only the true nature of a thing cannot be changed."
    }
    {
      Id = "TradeOff"
      DisplayName = "The Fates"
      Description = "You have {#UpgradeFormat}{$TooltipData.StatDisplay1}{#Prev}{!Icons.ReRollAlt}."
    }
    {
      Id = "TradeOff_AutoEquip"
      DisplayName = "{$Keywords.AutoEquip}: {#ItalicLightFormat}Activate {#ItalicFormat}all {#Prev}surrounding Cards.{#Prev}"
    }
    {
     Id = "TradeOff_FlavorText01"
     DisplayName = "Even the gods themselves are subject to the whims of the three weavers of destiny."
    }
    {
      Id = "ScreenReroll"
      DisplayName = "The Champions"
      Description = "You have {#UpgradeFormat}{$TooltipData.StatDisplay1}{#Prev}{!Icons.ReRollAlt}, and can alter {#BoldFormatGraft}{$Keywords.GodBoonPlural} {#Prev}and certain other choices."
    }
    {
      Id = "ScreenReroll_Tray"
      InheritFrom = "ScreenReroll"
      Description = "You have {#UpgradeFormat}{$TooltipData.StatDisplay1}{#Prev}{!Icons.ReRollAlt}, and can alter {#BoldFormatGraft}{$Keywords.GodBoonPlural} {#Prev}and certain other choices."
    }
    {
      Id = "ScreenReroll_FlavorText01"
      DisplayName = "Once-mortal foes, they found each other once again in death, and were exalted in Elysium."
    }
    {
      Id = "RarityBoost"
      DisplayName = "Excellence"
      Description = "Any {$Keywords.GodBoonPlural} you find have {$TooltipData.StatDisplay1} chance to include {$Keywords.Legendary} or at least {$Keywords.Rare} blessings."
    }
    {
      Id = "RarityBoostMetaUpgrade_Tray"
      InheritFrom = "RarityBoost"
      Description = "Any {$Keywords.GodBoonPlural} you find have {$TooltipData.StatDisplay1} chance to include {$Keywords.Legendary} or at least {$Keywords.Rare} blessings."
    }
    {
      Id = "RarityBoost_FlavorText01"
      DisplayName = "Not even gods can always live to their fullest purpose; yet mortals all must strive."
    }

    {
      Id = "EpicRarityBoost"
      DisplayName = "Divinity"
      Description = "Any {$Keywords.GodBoonPlural} you find have {$TooltipData.StatDisplay1} chance to include {$Keywords.Epic} blessings."
    }
    {
      Id = "EpicRarityBoostMetaUpgrade_Tray"
      DisplayName = "Divinity"
      Description = "Any {$Keywords.GodBoonPlural} you find have {$TooltipData.StatDisplay1} chance to include {$Keywords.Epic} blessings."
    }
    {
      Id = "EpicRarity_AutoEquip"
      DisplayName = "{$Keywords.AutoEquip}: {#ItalicLightFormat}Activate all {#BoldFormat}{$MetaUpgradeCardData.EpicRarityBoost.AutoEquipRequirements.CardsRequired} {#Prev}Cards in any other row."
    }
    {
      Id = "EpicRarity_AutoEquip_Alt"
      DisplayName = "{$Keywords.AutoEquip}: {#ItalicLightFormat}Activate all {#BoldFormat}{$MetaUpgradeCardData.EpicRarityBoost.AutoEquipRequirements.CardsRequired} {#Prev}Cards in any other row or column."
    }
    {
      Id = "EpicRarityBoost_FlavorText01"
      DisplayName = "The privilege of godhood is bestowed at birth, save for the rarest cases, when it is earned."
    }
    {
      Id = "EpicRarityBoostMetaUpgrade"
      InheritFrom = "EpicRarityBoost"
    }

    {
      Id = "BonusRarity"
      DisplayName = "The Queen"
      Description = "Any {$Keywords.GodBoonPlural} you find have {$TooltipData.StatDisplay1} chance to include {$Keywords.Duo} blessings."
    }
    {
      Id = "DuoRarityBoostMetaUpgrade_Tray"
      DisplayName = "The Queen"
      Description = "Any {$Keywords.GodBoonPlural} you are offered have {$TooltipData.StatDisplay1} chance to be a {$Keywords.Duo} {#ItalicLightFormat}(whenever possible){#Prev}."
    }
    {
      Id = "BonusRarity_AutoEquip"
      DisplayName = "{$Keywords.AutoEquip}: {#ItalicLightFormat}Activate no more than {#BoldFormat}{$MetaUpgradeCardData.BonusRarity.AutoEquipRequirements.MaxDuplicateCount} {#Prev}Cards that use the same amount of {!Icons.ManaCrystal}."
    }
    {
      Id = "DuoRarityBoostMetaUpgrade"
      InheritFrom = "BonusRarity"
    }
    {
      Id = "BonusRarity_FlavorText01"
      DisplayName = "From Olympus she descends to reign in the Underworld, as the surface-land grows cold."
    }
    {
      Id = "CardDraw"
      DisplayName = "Judgment"
      Description = "You activate {$TooltipData.StatDisplay1} random inactive {#BoldFormatGraft}Arcana Cards {#Prev}whenever you vanquish a {$Keywords.Boss}."
    }
    {
      Id = "BossProgressionMetaUpgrade_Tray"
      DisplayName = "Judgment"
      Description = "You activate {$TooltipData.StatDisplay1} random inactive {#BoldFormatGraft}Arcana Cards {#Prev}whenever you vanquish a {$Keywords.Boss}."
    }
    {
      Id = "CardDraw_AutoEquip"
      DisplayName = "{$Keywords.AutoEquip}: {#ItalicLightFormat}Activate no more than {#BoldFormat}{$MetaUpgradeCardData.CardDraw.AutoEquipRequirements.RequiredMetaUpgradesMax} {#Prev}Cards."
    }
    {
      Id = "CardDraw_FlavorText01"
      DisplayName = "The Underworld King is to decide what shall become of each and every mortal life."
    }
    {
      Id = "SorceryRegenUpgrade"
      DisplayName = "The Moon"
      Description = "Your {$Keywords.Spell} also charges up automatically as though you used {$TooltipData.StatDisplay1}{!Icons.Mana} every {#BoldFormat}1 Sec."
    }
    {
