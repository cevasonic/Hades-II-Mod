      /*
  	When writing traits use the following four values as a 'shorthand' - you should rarely have to reference any of raw variables

  	TotalPercentIncrease1 : New! if it's the first one, but then the total percentage change in the value otherwise
  	OldTotal1 : the value before this trait is added
  	NewTotal1 : shows the new total value after this trait is added
  	DisplayDelta1 : No additional formatting, just a reference to the "Increase1" entry
  	*/
    {
      Id = "Increase1"
      DisplayName = "{$TooltipData.OldTotal1}{!Icons.RightArrow}{$TooltipData.NewTotal1}"
      OverwriteLocalization = true
    }
    {
      Id = "Increase2"
      DisplayName = "{$TooltipData.OldTotal2}{!Icons.RightArrow}{$TooltipData.NewTotal2}"
      OverwriteLocalization = true
    }
    {
      Id = "PercentIncrease1"
      DisplayName = "{#UpgradeFormat}{$TooltipData.OldTotal1:P}{!Icons.RightArrow}{$TooltipData.NewTotal1:P}{#Prev}"
      OverwriteLocalization = true
    }
    {
      Id = "PercentIncrease2"
      DisplayName = "{#UpgradeFormat}{$TooltipData.OldTotal2:P}{!Icons.RightArrow}{$TooltipData.NewTotal2:P}{#Prev}"
      OverwriteLocalization = true
    }
    {
      Id = "DeltaNewTotal1"
