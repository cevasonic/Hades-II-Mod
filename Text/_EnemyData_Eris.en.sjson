    }
    {
      Id = "ErisField_0120"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How could you... be so {#Emph}cruel...?"
      Speaker = "Eris"
      Event = "Eris.DeathVoiceLines"
    }
    {
      Id = "ErisField_0114"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}No! {#Prev}Nononono, come on, wait!"
      Speaker = "Eris"
      Event = "Eris.DeathVoiceLines"
    }
    {
      Id = "ErisField_0115"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh no not again, not {#Emph}again!"
      Speaker = "Eris"
      Event = "Eris.DeathVoiceLines"
    }
    {
      Id = "ErisField_0116"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, {#Emph}haha! {#Prev}I'll get you for this!!"
      Speaker = "Eris"
      Event = "Eris.DeathVoiceLines"
    }
    {
      Id = "ErisField_0117"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I thought that we were friends?!"
      Speaker = "Eris"
      Event = "Eris.DeathVoiceLines"
    }
    {
      Id = "ErisField_0118"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How could you do this to me, babe?!"
      Speaker = "Eris"
      Event = "Eris.DeathVoiceLines"
    }
    {
      Id = "ErisField_0119"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Cold... darkness... {#Emph}ungh..."
      Speaker = "Eris"
      Event = "Eris.DeathVoiceLines"
    }
    {
      Id = "ErisField_0121"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No...! You're making a mistake...!"
      Speaker = "Eris"
      Event = "Eris.DeathVoiceLines"
    }
    {
      Id = "ErisField_0346"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Return to shadow... now...?"
      Speaker = "Eris"
      Event = "Eris.DeathVoiceLines"
    }
    {
      Id = "ErisField_0347"
      InheritFrom = "BaseSubtitle"
      DisplayName = "But I don't wanna go, I just {#Emph}got {#Prev}here!"
      Speaker = "Eris"
      Event = "Eris.DeathVoiceLines"
    }
    {
      Id = "ErisField_0348"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Can't drag me back to hell without a fight!"
      Speaker = "Eris"
      Event = "Eris.DeathVoiceLines"
    }
    {
      Id = "ErisField_0349"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I always get the last laugh, babe! {#Emph}Hahaha-oww!"
      Speaker = "Eris"
      Event = "Eris.DeathVoiceLines"
    }
    {
      Id = "ErisField_0479"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ow ow ow ow ow ow OW!"
      Speaker = "Eris"
      Event = "Eris.DeathVoiceLines"
    }
    {
      Id = "ErisField_0480"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}I'm... just... gonna... fly... back!"
      Speaker = "Eris"
      Event = "Eris.DeathVoiceLines"
    }
    {
      Id = "ErisField_0484"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}All right{#Prev}, all right, I'm going. {#Emph}Bye!"
      Speaker = "Eris"
      Event = "Eris.DeathVoiceLines"
    }
    {
      Id = "ErisField_0481"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Augh! {#Prev}Same time again tomorrow, babe?"
      Speaker = "Eris"
      Event = "Eris.DeathVoiceLines"
    }
    {
      Id = "ErisField_0482"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ow! {#Prev}How about giving me a {#Emph}chance {#Prev}next time?"
      Speaker = "Eris"
      Event = "Eris.DeathVoiceLines"
    }
    {
      Id = "ErisField_0483"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ungh{#Prev}, why does this always {#Emph}happen {#Prev}to me?"
      Speaker = "Eris"
      Event = "Eris.DeathVoiceLines"
    }
    {
      Id = "ErisField_0485"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How did you... get so fast?"
      Speaker = "Eris"
      Event = "Eris.DeathVoiceLines"
    }
    {
      Id = "ErisField_0486"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Did I not even hit you {#Emph}once?"
      Speaker = "Eris"
      Event = "Eris.DeathVoiceLines"
    }
    {
      Id = "MelinoeField_1907"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You started it."
      Speaker = "Melinoe"
      Event = "Eris.BossKillVoiceLines"
    }
    {
      Id = "MelinoeField_1908"
      InheritFrom = "BaseSubtitle"
      DisplayName = "She started it."
      Speaker = "Melinoe"
      Event = "Eris.BossKillVoiceLines"
    }
    {
      Id = "MelinoeField_1909"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Get out of here."
      Speaker = "Melinoe"
      Event = "Eris.BossKillVoiceLines"
    }
    {
      Id = "MelinoeField_1910"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Buzz off."
      Speaker = "Melinoe"
      Event = "Eris.BossKillVoiceLines"
    }
    {
      Id = "MelinoeField_1911"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Remember that."
      Speaker = "Melinoe"
      Event = "Eris.BossKillVoiceLines"
    }
    {
      Id = "MelinoeField_1912"
      InheritFrom = "BaseSubtitle"
      DisplayName = "She never learns."
      Speaker = "Melinoe"
      Event = "Eris.BossKillVoiceLines"
    }
    {
      Id = "MelinoeField_1913"
      InheritFrom = "BaseSubtitle"
      DisplayName = "See you, Strife."
      Speaker = "Melinoe"
      Event = "Eris.BossKillVoiceLines"
    }
    {
      Id = "MelinoeField_1914"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Much better..."
      Speaker = "Melinoe"
      Event = "Eris.BossKillVoiceLines"
    }
    {
      Id = "ErisField_0002"
      InheritFrom = "BaseNarrative"
      DisplayName = "Heya, sailor! What a coincidence, running into you like this {#Emph}so {#Prev}far away from home. Where you headed? Maybe I could give you a lift."
      Speaker = "Eris"
      Event = "ErisBossFirstMeeting"
    }
    {
      Id = "MelinoeField_1806"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know perfectly well where I'm headed. And I can get there on my own, thanks."
      Speaker = "Melinoe"
      Event = "ErisBossFirstMeeting"
    }
    {
      Id = "ErisField_0003"
      InheritFrom = "BaseNarrative"
      DisplayName = "You sure about that? Because it looks like you've been having a {#Emph}pretty {#Prev}rough night so far. And it's only going to get worse."
      Speaker = "Eris"
      Event = "ErisBossFirstMeeting"
    }
    {
      Id = "MelinoeField_1807"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't care for your insinuations here, Eris. Speak plain, or get out of my way."
      Speaker = "Melinoe"
      Event = "ErisBossFirstMeeting"
    }
    {
      Id = "ErisField_0004"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh I'll speak plain: You're boring. I don't {#Emph}like {#Prev}you. And you don't get to order me around...!"
      Speaker = "Eris"
      Event = "ErisBossFirstMeeting"
    }
    {
      Id = "ErisField_0011"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come on, {#Emph}really? {#Prev}I thought I made myself real clear with you before, but here you are like nothing happened, and it's just another night!"
      Speaker = "Eris"
      Event = "ErisBossAboutObstacles01"
    }
    {
      Id = "MelinoeField_1920"
      InheritFrom = "BaseNarrative"
      DisplayName = "This {#Emph}is {#Prev}just another night to me, Eris. So you stand with Chronos against the gods, so what? You're just another obstacle on my path."
      Speaker = "Melinoe"
      Event = "ErisBossAboutObstacles01"
    }
    {
      Id = "ErisField_0012"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hate to break it to you, Trouble: Obstacles are things you're supposed to {#Emph}avoid! {#Prev}But in {#Emph}this {#Prev}channel, you're going to run into me {#Emph}every time."
      Speaker = "Eris"
      Event = "ErisBossAboutObstacles01"
    }
    {
      Id = "MelinoeField_3267"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why is it that you're putting all your effort into stopping me? You're Strife; you should be unpredictable! Perhaps lash out at the forces of Chronos, for a change of pace..."
      Speaker = "Melinoe"
      Event = "ErisBossAboutRandomness01"
    }
    {
      Id = "ErisField_0355"
      InheritFrom = "BaseNarrative"
      DisplayName = "What makes you think I {#Emph}don't? {#Prev}You're not the center of the world, babe! And I couldn't be {#Emph}more {#Prev}unpredictable! Don't know why I keep running into you, though. It's so {#Emph}random!"
      Speaker = "Eris"
      Event = "ErisBossAboutRandomness01"
    }
    {
      Id = "ErisField_0013"
      InheritFrom = "BaseNarrative"
      DisplayName = "Another go? Can't always tell if you're stubborn, or just plain... {#Emph}you {#Prev}know. Not that it matters either way."
      Speaker = "Eris"
      Event = "ErisBossAboutMistakes01"
    }
    {
      Id = "MelinoeField_1921"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're standing between me and my objective, Eris... or, floating. The point is, sooner or later, you'll come to understand that's a mistake."
      Speaker = "Melinoe"
      Event = "ErisBossAboutMistakes01"
    }
    {
      Id = "ErisField_0014"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Aw{#Prev}, but we all make mistakes, right? Neither one of us would be here otherwise. So you ready now, or what? Let's have some {#Emph}fun."
      Speaker = "Eris"
      Event = "ErisBossAboutMistakes01"
    }
    {
      Id = "ErisField_0015"
      InheritFrom = "BaseNarrative"
      DisplayName = "Isn't this {#Emph}great{#Prev}, Trouble? Now before I shoot you all to hell, I just want us both to take a moment to {#Emph}breathe, relax... really {#Prev}just appreciate all that we have."
      Speaker = "Eris"
      Event = "ErisBossAboutRelaxation01"
    }
    {
      Id = "MelinoeField_1922"
      InheritFrom = "BaseNarrative"
      DisplayName = "These senseless fights with you... I cannot rightly say I appreciate them at all. Though, at least the Moon is beautiful tonight?"
      Speaker = "Melinoe"
      Event = "ErisBossAboutRelaxation01"
    }
    {
      Id = "ErisField_0016"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}That's {#Prev}the spirit! Now how 'bout we stain that pale glow of hers in blood and ichor, huh? And we'll let the sea drink its fill, for good measure!"
      Speaker = "Eris"
      Event = "ErisBossAboutRelaxation01"
    }
    {
      Id = "ErisField_0155"
      InheritFrom = "BaseNarrative"
      DisplayName = "You think just 'cause you've been cozying up to me at the Crossroads that I'm gonna let up on you here? Well you're wrong, babe! I know what you're trying to do."
      Speaker = "Eris"
      Event = "ErisBossAboutRelationship01"
    }
    {
      Id = "MelinoeField_3075"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know what I'm trying to do because I've plainly and repeatedly explained myself. And yet, you still pretend as though there's something much more complicated going on."
      Speaker = "Melinoe"
      Event = "ErisBossAboutRelationship01"
    }
    {
      Id = "ErisField_0156"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ohh{#Prev}, and now you're trying to guilt-trip me to top it off. Well I don't need to take that kind of guff from you. Nobody pushes me around, get it?"
      Speaker = "Eris"
      Event = "ErisBossAboutRelationship01"
    }
    {
      Id = "MelinoeField_3076"
      InheritFrom = "BaseNarrative"
      DisplayName = "Always ready and eager for the fight. I've never met someone so driven, yet so lacking in any purpose whatsoever."
      Speaker = "Melinoe"
      Event = "ErisBossAboutPurpose01"
    }
    {
      Id = "ErisField_0157"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm about to blow your mind, you ready, babe? No purpose {#Emph}is {#Prev}a purpose. Think about it! And now I'm gonna blow away the rest of you, too."
      Speaker = "Eris"
      Event = "ErisBossAboutPurpose01"
    }
    {
      Id = "ErisField_0048"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're tougher than you look, I'll give you that, Trouble. And I'll give you something {#Emph}else {#Prev}for what you did to me last time."
      Speaker = "Eris"
      Event = "ErisBossAboutConsequences01"
    }
    {
      Id = "MelinoeField_1923"
      InheritFrom = "BaseNarrative"
      DisplayName = "The outcome of our prior meeting was the direct result of your provocation and hostility. Tonight may go even worse."
      Speaker = "Melinoe"
      Event = "ErisBossAboutConsequences01"
    }
    {
      Id = "ErisField_0049"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wait, you're telling me our choices have {#Emph}c-c-consequences...? C'mon{#Prev}, don't be so gullible. Anyway! I'm gonna open fire now."
      Speaker = "Eris"
      Event = "ErisBossAboutConsequences01"
    }
    {
      Id = "MelinoeField_3082"
      InheritFrom = "BaseNarrative"
      DisplayName = "I must say, especially for someone who claims to thrive on pure disorder, you {#Emph}are {#Prev}very punctual and consistent, Eris. Every time I've crossed the Rift, you've been right here."
      Speaker = "Melinoe"
      Event = "ErisBossAboutProblems01"
    }
    {
      Id = "ErisField_0169"
      InheritFrom = "BaseNarrative"
      DisplayName = "No need to rub it in! Look, I know this is becoming a problem, but I swear, I can get it under control. Just promise me you won't tell anybody?"
      Speaker = "Eris"
      Event = "ErisBossAboutProblems01"
    }
    {
      Id = "MelinoeField_3083"
      InheritFrom = "BaseNarrative"
      DisplayName = "You want me to promise not to tell anybody that you're punctual and consistent. Why, because you'd hate for them to start to think better of you for a change?"
      Speaker = "Melinoe"
      Event = "ErisBossAboutProblems01"
    }
    {
      Id = "ErisField_0170"
      InheritFrom = "BaseNarrative"
      DisplayName = "Um, {#Emph}yeah! {#Prev}Although, since when do I even care what anybody thinks of me...? That's not who I am! It's all because you're ruining it for me!"
      Speaker = "Eris"
      Event = "ErisBossAboutProblems01"
    }
    {
      Id = "MelinoeField_4060"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have yet to be late for our clashes even once — no matter how quickly I reach these shores, you're here first. But your goal is to be {#Emph}less {#Prev}dependable, not {#Emph}more?"
      Speaker = "Melinoe"
      Event = "ErisBossAboutProblems02"
    }
    {
      Id = "ErisField_0437"
      InheritFrom = "BaseNarrative"
      DisplayName = "My goal is {#Emph}never {#Prev}to have a goal in my life! It's just, I'm going through some sort of phase I think. All the competition with you and Nemmie must have got to me."
      Speaker = "Eris"
      Event = "ErisBossAboutProblems02"
    }
    {
      Id = "MelinoeField_4061"
      InheritFrom = "BaseNarrative"
      DisplayName = "And what is it you think {#Emph}we're {#Prev}competing for? First to be forced back to the depths of the Underworld?"
      Speaker = "Melinoe"
      Event = "ErisBossAboutProblems02"
    }
    {
      Id = "ErisField_0438"
      InheritFrom = "BaseNarrative"
      DisplayName = "Never said it's you I'm competing with, babe. And you know what I realized about this whole thing we've got going? Discipline and Disorder go hand in hand."
      Speaker = "Eris"
      Event = "ErisBossAboutProblems02"
    }
    {
      Id = "ErisField_0439"
      InheritFrom = "BaseNarrative"
      DisplayName = "Maybe it's not such a bad thing that I keep showing up on time. {#Emph}You can always count on Strife! {#Prev}That's kind of got a ring to it, right?"
      Speaker = "Eris"
      Event = "ErisBossAboutProblems03"
    }
    {
      Id = "MelinoeField_4062"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you wish to be dependable, that means not just showing up on time, but making yourself useful in some way. Though I suppose that's probably a step too far."
      Speaker = "Melinoe"
      Event = "ErisBossAboutProblems03"
    }
    {
      Id = "ErisField_0440"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can't believe you almost got me thinking there was something wrong with me, and just because I {#Emph}care! {#Prev}But don't worry... I'll make sure {#Emph}something's {#Prev}wrong at least!"
      Speaker = "Eris"
      Event = "ErisBossAboutProblems03"
    }
    {
      Id = "ErisField_0162"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just about everybody on Olympus giving you their best, huh? You must be {#Emph}very {#Prev}proud. The gods, they don't agree on much at all."
      Speaker = "Eris"
      Event = "ErisBossAboutAres01"
    }
    {
      Id = "MelinoeField_3078"
      InheritFrom = "BaseNarrative"
      DisplayName = "No they do not. Yet when the need arises, they can set their differences aside. Something to try with your own kin."
      Speaker = "Melinoe"
      Event = "ErisBossAboutAres01"
    }
    {
      Id = "ErisField_0163"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know who really gets what's going on up there? Ares. If anybody's brought {#Emph}that {#Prev}family together, it's the god of war. {#Emph}His {#Prev}cause even I can get behind!"
      Speaker = "Eris"
      Event = "ErisBossAboutAres01"
    }
    {
      Id = "MelinoeField_3079"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you admire Ares so much, know that he has lent me his aid; I have his blessing even now. Though I suppose you still won't be compelled to step aside?"
      Speaker = "Melinoe"
      Event = "ErisBossAboutAres02"
    }
    {
      Id = "ErisField_0164"
      InheritFrom = "BaseNarrative"
      DisplayName = "You suppose right! And say you {#Emph}do {#Prev}have Ares making up for all your weakness, it's probably because he wants this war to {#Emph}last {#Prev}and {#Emph}last! {#Prev}He can aid {#Emph}you{#Prev}; I can aid {#Emph}him."
      Speaker = "Eris"
      Event = "ErisBossAboutAres02"
    }
    {
      Id = "ErisField_0350"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can't believe Ares is helping {#Emph}you {#Prev}not me. I kept trying to get through to him, figured he'd hear me out, but it's too stormy on Olympus. Say, would you...? You know..."
      Speaker = "Eris"
      Event = "ErisBossAboutAres03"
    }
    {
      Id = "MelinoeField_3264"
      InheritFrom = "BaseNarrative"
      DisplayName = "You want me to ask the god of war to lend you his aid, to make my efforts to support him and his family in their near-hopeless battle against Typhon even more difficult?"
      Speaker = "Melinoe"
      Event = "ErisBossAboutAres03"
    }
    {
      Id = "ErisField_0351"
      InheritFrom = "BaseNarrative"
      DisplayName = "Quit with the {#Emph}sarcasm{#Prev}, Trouble! All I did was ask you for a favor {#Emph}once{#Prev}, but... you had to go and make an {#Emph}insult {#Prev}out of it. {#Emph}Fine! {#Prev}I can get the god of war's attention on my {#Emph}own!"
      Speaker = "Eris"
      Event = "ErisBossAboutAres03"
    }
    {
      Id = "ErisField_0171"
      InheritFrom = "BaseNarrative"
      DisplayName = "Whoa, Trouble, you're {#Emph}huge! {#Prev}Like you and Nemmie had a child! Which, come to think of it, is just about the {#Emph}worst {#Prev}thing I've ever imagined. And I've imagined {#Emph}a lot."
      Speaker = "Eris"
      Event = "ErisBossAboutCirce01"
    }
    {
      Id = "MelinoeField_3084"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then imagine what I'm about to do to you in this form, courtesy of Circe the Enchantress. Had you not been so delinquent, you could have learned from her yourself."
      Speaker = "Melinoe"
      Event = "ErisBossAboutCirce01"
    }
    {
      Id = "ErisField_0172"
      InheritFrom = "BaseNarrative"
      DisplayName = "Learned to become a {#Emph}freak{#Prev}, you mean? That's the difference between you and me: You need somebody to teach you {#Emph}everything{#Prev}, while {#Emph}I've {#Prev}got pure instinct!"
      Speaker = "Eris"
      Event = "ErisBossAboutCirce01"
    }
    {
      Id = "ErisField_0173"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah, hahaha{#Prev}, you're so {#Emph}tiny {#Prev}right now, babe! How {#Emph}cuuute. {#Prev}Old Circe must have done that to you, yeah? I've flown by her little island where she's doing all her lunatic experiments."
      Speaker = "Eris"
      Event = "ErisBossAboutCirce02"
    }
    {
      Id = "MelinoeField_3085"
      InheritFrom = "BaseNarrative"
      DisplayName = "You had so much promise as a student, Eris... even now you easily identified the work of an experienced enchantress. But only to spurn our craft."
      Speaker = "Melinoe"
      Event = "ErisBossAboutCirce02"
    }
    {
      Id = "ErisField_0174"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your craft turns you into a walking joke! I'm just pointing it out. Well, whatever happens next, thanks for the laughs!"
      Speaker = "Eris"
      Event = "ErisBossAboutCirce02"
    }
    {
      Id = "ErisField_0356"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know that wispy Shade-kid, what's-his-name...? {#Emph}Ick, Icky... Icarus! {#Prev}I've seen him stealing glances, flying around... {#Emph}copying {#Prev}me! Where'd he get the {#Emph}wings?"
      Speaker = "Eris"
      Event = "ErisBossAboutIcarus01"
    }
    {
      Id = "MelinoeField_3268"
      InheritFrom = "BaseNarrative"
      DisplayName = "Icarus assuredly is not copying you. This may come as a shock, but there are those attempting to be useful currently... rather than interfering with our plans."
      Speaker = "Melinoe"
      Event = "ErisBossAboutIcarus01"
    }
    {
      Id = "ErisField_0357"
      InheritFrom = "BaseNarrative"
      DisplayName = "You think he's {#Emph}attempting to be useful? Pff{#Prev}, come {#Emph}on! {#Prev}He's just a little freak. Maybe he's into {#Emph}Harpies {#Prev}and is trying to get in with them... but then again, who cares!"
      Speaker = "Eris"
      Event = "ErisBossAboutIcarus01"
    }
    {
      Id = "ErisField_0358"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Aww, loook! {#Prev}You brought an ugly little bird with you! Close as you're ever gonna get to wings like {#Emph}these{#Prev}, babe. But you have to walk everywhere. No {#Emph}wonder {#Prev}you're so unhappy!"
      Speaker = "Eris"
      Event = "ErisBossAboutRavenFamiliar01"
    }
    {
      Id = "MelinoeField_3269"
      InheritFrom = "BaseNarrative"
      DisplayName = "I am {#Emph}not {#Prev}unhappy. And I took a boat most of the way here, thanks! Multiple boats! And I'm not about to let you insult Raki to my face, or his."
      Speaker = "Melinoe"
      Event = "ErisBossAboutRavenFamiliar01"
    }
    {
      Id = "ErisField_0359"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Babe{#Prev}, come {#Emph}on.{#Prev} That bird is so pale it's probably {#Emph}dying! {#Prev}Here, maybe I can put it out of its misery. And {#Emph}you{#Prev}, too."
      Speaker = "Eris"
      Event = "ErisBossAboutRavenFamiliar01"
    }
    {
      Id = "ErisField_0445"
      InheritFrom = "BaseNarrative"
      DisplayName = "Done with your shopping finally, Trouble? Charon sure seems to have a lot in stock there on that fancy ship of his! Although he hasn't sold {#Emph}me {#Prev}anything."
      Speaker = "Eris"
      Event = "ErisBossAboutCharon01"
    }
    {
      Id = "MelinoeField_4065"
      InheritFrom = "BaseNarrative"
      DisplayName = "I doubt he ever would. Lord Charon's loyal to the realm. You're not. It's as simple as that, even if you are his sister."
      Speaker = "Melinoe"
      Event = "ErisBossAboutCharon01"
    }
    {
      Id = "ErisField_0446"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Loyal to the realm. {#Prev}At least I'm not a suck-up! Though if you {#Emph}like {#Prev}him so much, here's something you can moan and groan about."
      Speaker = "Eris"
      Event = "ErisBossAboutCharon01"
    }
    {
      Id = "ErisField_0447"
      InheritFrom = "BaseNarrative"
      DisplayName = "Moonlight sure is guiding you tonight! Too bad Selene can't just whisk you over to Olympus on that chariot of hers. Why {#Emph}can't {#Prev}she, anyway? I thought she was your friend!"
      Speaker = "Eris"
      Event = "ErisBossAboutSelene01"
    }
    {
      Id = "MelinoeField_4066"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps Selene doesn't easily abandon her responsibilities, although I know that concept may be difficult for you to comprehend. Care to whisk me to Olympus in her stead?"
      Speaker = "Melinoe"
      Event = "ErisBossAboutSelene01"
    }
    {
      Id = "ErisField_0448"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll have to pass. Not like these wings could lift the both of us! Although I {#Emph}do {#Prev}have something here for you instead."
      Speaker = "Eris"
      Event = "ErisBossAboutSelene01"
    }
    {
      Id = "ErisField_0443"
      InheritFrom = "BaseNarrative"
      DisplayName = "What's with that Cyclops over by the Ephyra docks? He almost hit me with a boulder as I flew over here a couple nights ago!"
      Speaker = "Eris"
      Event = "ErisBossAboutPolyphemus01"
    }
    {
      Id = "MelinoeField_4064"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's Polyphemus. He's blind so there's no need to take his boulder-throwing as a personal affront. He was probably aiming at me."
      Speaker = "Melinoe"
      Event = "ErisBossAboutPolyphemus01"
    }
    {
      Id = "ErisField_0444"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, {#Emph}that's {#Prev}a relief! I took a bunch of his sheep, you don't wanna know why, and was starting to worry he caught on. I get the livestock, {#Emph}you {#Prev}get the heat!"
      Speaker = "Eris"
      Event = "ErisBossAboutPolyphemus01"
    }
    {
      Id = "ErisField_0165"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wait so {#Emph}Prometheus {#Prev}is supposed to be in charge where the real action is? Thought he was busy getting pecked to the brink of death over and over by some {#Emph}bird."
      Speaker = "Eris"
      Event = "ErisBossAboutPrometheus01"
    }
    {
      Id = "MelinoeField_3080"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can attest he and that bird have come to terms. Come on, have pity on me, Eris. I have to deal with fire and feathers here, and again at the top of Olympus."
      Speaker = "Melinoe"
      Event = "ErisBossAboutPrometheus01"
    }
    {
      Id = "ErisField_0166"
      InheritFrom = "BaseNarrative"
      DisplayName = "That is a pretty good appeal, babe... {#Emph}but{#Prev}, unfortunately for you, I don't have a heart. So, come on! Here comes your first helping of fire and feathers for the night."
      Speaker = "Eris"
      Event = "ErisBossAboutPrometheus01"
    }
    {
      Id = "ErisField_0167"
      InheritFrom = "BaseNarrative"
      DisplayName = "So if you get past me again, what's next for you, Trouble? I've never seen someone go through so {#Emph}much {#Prev}just to see their family. Most of us have to try to stay away from ours!"
      Speaker = "Eris"
      Event = "ErisBossAboutTyphon01"
    }
    {
      Id = "MelinoeField_3081"
      InheritFrom = "BaseNarrative"
      DisplayName = "That terrifying cloud encompassing the summit of Olympus conceals Typhon, in case you haven't heard. I'm surprised you haven't gone to see him for yourself! Anyway Prometheus is next, {#Emph}then {#Prev}Typhon. But you first."
      Speaker = "Melinoe"
      Event = "ErisBossAboutTyphon01"
    }
    {
      Id = "ErisField_0168"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're telling me you're here to pick bigger and bigger fights? {#Emph}Baaabe! {#Prev}I knew we had something going on, but we have more in common than I thought! C'mon, let's go."
      Speaker = "Eris"
      Event = "ErisBossAboutTyphon01"
    }
    {
      Id = "MelinoeField_3265"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're really never going to get out of my way, are you, Eris? You'd rather Typhon lay Mount Olympus to ruin. Although at that point I suppose this war would end."
      Speaker = "Melinoe"
      Event = "ErisBossAboutTyphon02"
    }
    {
      Id = "ErisField_0352"
      InheritFrom = "BaseNarrative"
      DisplayName = "It sure would! But after that things might not get too orderly for a while, and... who knows what Typhon does from {#Emph}there? {#Prev}Think of the {#Emph}possibilities{#Prev}, babe!"
      Speaker = "Eris"
      Event = "ErisBossAboutTyphon02"
    }
    {
      Id = "ErisField_0353"
      InheritFrom = "BaseNarrative"
      DisplayName = "What happened up there on Olympus last night, babe? Looked like the storm cleared for a little while. Almost flew in for a looksee, but... I don't like the cold!"
      Speaker = "Eris"
      Event = "ErisBossAboutTyphon03"
    }
    {
      Id = "MelinoeField_3266"
      InheritFrom = "BaseNarrative"
      DisplayName = "What happened was, after I got past {#Emph}you{#Prev}, I eventually climbed all the way up to the summit where I sent the Father of All Monsters Typhon crashing to the Earth."
      Speaker = "Melinoe"
      Event = "ErisBossAboutTyphon03"
    }
    {
      Id = "ErisField_0354"
      InheritFrom = "BaseNarrative"
      DisplayName = "You {#Emph}did? Whoa{#Prev}, you must be really {#Emph}strong{#Prev}, or Typhon must be really {#Emph}weak! {#Prev}And since you're back already then I guess whatever happened didn't mean a thing!"
      Speaker = "Eris"
      Event = "ErisBossAboutTyphon03"
    }
    {
      Id = "ErisField_0441"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not seen you here in a while, babe. And what happened to Typhon, anyway? There's been no sign of him at all!"
      Speaker = "Eris"
      Event = "ErisBossAboutTyphonDeath01"
    }
    {
      Id = "MelinoeField_4063"
      InheritFrom = "BaseNarrative"
      DisplayName = "Typhon had to leave reality as we know it. Though, sorry, Eris. I suppose you didn't even have a chance to introduce yourself to him, did you?"
      Speaker = "Melinoe"
      Event = "ErisBossAboutTyphonDeath01"
    }
    {
      Id = "ErisField_0442"
      InheritFrom = "BaseNarrative"
      DisplayName = "No I didn't, though if he's so easy to get rid of, maybe it's for the best! So what are you going to Olympus for, anyway? It better not be some sort of {#Emph}feast. {#Prev}Because I {#Emph}wasn't {#Prev}invited!"
      Speaker = "Eris"
      Event = "ErisBossAboutTyphonDeath01"
    }
    {
      Id = "ErisField_0372"
      InheritFrom = "BaseNarrative"
      DisplayName = "Too many Harpies around here, though they're all just a bunch of pushovers. They know who's the top bird and treat me like a {#Emph}goddess!"
      Speaker = "Eris"
      Event = "ErisBossAboutHarpies01"
    }
    {
      Id = "MelinoeField_3276"
      InheritFrom = "BaseNarrative"
      DisplayName = "You {#Emph}are {#Prev}a goddess, Eris. Although the Harpies aren't as quick to recognize my own divinity..."
      Speaker = "Melinoe"
      Event = "ErisBossAboutHarpies01"
    }
    {
      Id = "ErisField_0373"
      InheritFrom = "BaseNarrative"
      DisplayName = "Maybe they don't like you, since you don't have any wings? Although in your case, it could {#Emph}really {#Prev}be a lot of things..."
      Speaker = "Eris"
      Event = "ErisBossAboutHarpies01"
    }
    {
      Id = "ErisField_0370"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Pff. {#Prev}You took {#Emph}forever {#Prev}getting here! Only to turn up practically as dead as the crews of all those {#Emph}ships {#Prev}headed this way!"
      Speaker = "Eris"
      Event = "ErisBossLowHealth01"
    }
    {
      Id = "MelinoeField_3275"
      InheritFrom = "BaseNarrative"
      DisplayName = "Apologies for any inconvenience, Eris. Fortunately there's a quite-refreshing fountain not too far from here, which should do wonders for my injuries."
      Speaker = "Melinoe"
      Event = "ErisBossLowHealth01"
    }
    {
      Id = "ErisField_0371"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, then you're so {#Emph}close! {#Prev}Maybe you could make a break for it. The pathway out of here is right behind me..."
      Speaker = "Eris"
      Event = "ErisBossLowHealth01"
    }
    {
      Id = "ErisField_0374"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Aww{#Prev}, looks like those mean old sailors back there took a couple pieces out of you along your way! But don't worry, babe. {#Emph}I'll {#Prev}end your suffering!"
      Speaker = "Eris"
      Event = "ErisBossLowHealth02"
    }
    {
      Id = "ErisField_0379"
      InheritFrom = "BaseNarrative"
      DisplayName = "You got so {#Emph}close {#Prev}to beating me last time, babe! I could feel my wings growing heavy... like the Underworld was calling me {#Emph}home. {#Prev}But I'm totally fine now!"
      Speaker = "Eris"
      Event = "ErisBossCloseMatch01"
    }
    {
      Id = "MelinoeField_3280"
      InheritFrom = "BaseNarrative"
      DisplayName = "For the moment. You'll soon feel the Underworld calling you home once more. And you'll go, whether you like it or not."
      Speaker = "Melinoe"
      Event = "ErisBossCloseMatch01"
    }
    {
      Id = "ErisField_0380"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ooh{#Prev}, I {#Emph}love {#Prev}a good threat! Well then, let's see who's going home {#Emph}first{#Prev}, huh? Maybe it'll be just like {#Emph}before..."
      Speaker = "Eris"
      Event = "ErisBossCloseMatch01"
    }
    {
      Id = "ErisField_0158"
      InheritFrom = "BaseNarrative"
      DisplayName = "OK what in the hell is {#Emph}that {#Prev}you've got on, babe? You could use a change of style, sure, but {#Emph}this {#Prev}is {#Emph}way {#Prev}out-there."
      Speaker = "Eris"
      Event = "ErisBossAboutSuit01"
    }
    {
      Id = "MelinoeField_3077"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, you must be referring to the Black Coat. You're right that it's not necessarily my preference for attire, but it's not primarily for show. You'll understand in a moment."
      Speaker = "Melinoe"
      Event = "ErisBossAboutSuit01"
    }
    {
      Id = "ErisField_0159"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wait I remember the Black Coat! So {#Emph}that's {#Prev}what it looks like? And I thought the Adamant Rail looked ridiculous! Nyx had {#Emph}such {#Prev}bad taste."
      Speaker = "Eris"
      Event = "ErisBossAboutSuit01"
    }
    {
      Id = "ErisField_0381"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Eugh{#Prev}, you look like {#Emph}Nyx! {#Prev}That's still the Black Coat thing you're wearing, isn't it? Except you {#Emph}did {#Prev}something..."
      Speaker = "Eris"
      Event = "ErisBossAboutNyxAspect01"
    }
    {
      Id = "MelinoeField_3315"
      InheritFrom = "BaseNarrative"
      DisplayName = "This is Nyx's own Aspect of Xinth, which deemed me worthy to be its bearer. Perhaps so I could discipline you in your mother's stead."
      Speaker = "Melinoe"
      Event = "ErisBossAboutNyxAspect01"
    }
    {
      Id = "ErisField_0382"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Discipline me? {#Prev}Babe, I used to fight with Nyx all the time, but not like {#Emph}this. {#Prev}This is {#Emph}way {#Prev}better! Come on, Mother, give me the best you've got."
      Speaker = "Eris"
      Event = "ErisBossAboutNyxAspect01"
    }
    {
      Id = "ErisField_0146"
      InheritFrom = "BaseNarrative"
      DisplayName = "Give back the Golden Apple that you took from me last time, and I might just let you walk this once. What do you say?"
      Speaker = "Eris"
      Event = "ErisBossAboutGoldenApples01"
    }
    {
      Id = "MelinoeField_1924"
      InheritFrom = "BaseNarrative"
      DisplayName = "You mean the Golden Apple that you very likely {#Emph}stole? {#Prev}Supposedly they grow but in a single garden, and I highly doubt that such a place would let {#Emph}you {#Prev}in."
      Speaker = "Melinoe"
      Event = "ErisBossAboutGoldenApples01"
    }
    {
      Id = "ErisField_0147"
      InheritFrom = "BaseNarrative"
      DisplayName = "Life starts to get a {#Emph}lot {#Prev}more interesting once you accept that you {#Emph}don't {#Prev}always need an invitation to show up. Fine! Keep the Apple, then. I've got a whole lot more..."
      Speaker = "Eris"
      Event = "ErisBossAboutGoldenApples01"
    }
    {
      Id = "ErisField_0175"
      InheritFrom = "BaseNarrative"
      DisplayName = "Was that the ringing in my ears just now, or did I maybe hear a little Bell? {#Emph}Oh{#Prev}, you brought along my {#Emph}Keepsake{#Prev}, haven't you! Think that thing's gonna help you {#Emph}here?"
      Speaker = "Eris"
      Event = "ErisBossAboutKeepsake01"
    }
    {
      Id = "MelinoeField_3086"
      InheritFrom = "BaseNarrative"
      DisplayName = "If it bothers or confounds you the slightest bit, I'll consider it worthwhile. I know you can't so much as give a simple gift without some underhanded motive."
      Speaker = "Melinoe"
      Event = "ErisBossAboutKeepsake01"
    }
    {
      Id = "ErisField_0176"
      InheritFrom = "BaseNarrative"
      DisplayName = "While {#Emph}you {#Prev}give gifts with only perfectly pure thoughts bouncing around inside your big, targetable head! Come on. Nobody's like that, babe. Not even you."
      Speaker = "Eris"
      Event = "ErisBossAboutKeepsake01"
    }
    {
      Id = "ErisField_0451"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh no{#Prev}, did you bring Nemmie's Evil Eye? Goes to show how much she really thinks of fairness, making you use {#Emph}that {#Prev}thing just to get me back!"
      Speaker = "Eris"
      Event = "ErisBossAboutNemesisKeepsake01"
    }
    {
      Id = "MelinoeField_4068"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}I {#Prev}made the choice to bring the Eye, not Nemesis. Although she {#Emph}is {#Prev}Retribution Incarnate, so I'd like to think she would've been supportive had she known."
      Speaker = "Melinoe"
      Event = "ErisBossAboutNemesisKeepsake01"
    }
    {
      Id = "ErisField_0452"
      InheritFrom = "BaseNarrative"
      DisplayName = "Doesn't take a genius to put {#Emph}that {#Prev}one together, babe. {#Emph}I'm {#Prev}her little sister! The {#Emph}runt {#Prev}of Nyx's litter, the {#Emph}smallest {#Prev}and {#Emph}easiest {#Prev}to push around. But I always push back... {#Emph}or {#Prev}push first!"
      Speaker = "Eris"
      Event = "ErisBossAboutNemesisKeepsake01"
    }
    {
      Id = "ErisField_0453"
      InheritFrom = "BaseNarrative"
      DisplayName = "You must be {#Emph}really {#Prev}special to Moros if he gave you one of his shiny Pins! Maybe he thinks you won't make it {#Emph}without {#Prev}him! You {#Emph}look {#Prev}like someone who needs saving, babe."
      Speaker = "Eris"
      Event = "ErisBossAboutMorosKeepsake01"
    }
    {
      Id = "MelinoeField_4069"
      InheritFrom = "BaseNarrative"
      DisplayName = "And what is that supposed to mean? I'll have you know Lord Moros offered me this Keepsake as a simple courtesy and nothing more."
      Speaker = "Melinoe"
      Event = "ErisBossAboutMorosKeepsake01"
    }
    {
      Id = "ErisField_0454"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Uh huh, sure {#Prev}he did. You're both so dense sometimes, I swear! Now let's see if Lord Moros comes to your rescue..."
      Speaker = "Eris"
      Event = "ErisBossAboutMorosKeepsake01"
    }
    {
      Id = "ErisField_0449"
      InheritFrom = "BaseNarrative"
      DisplayName = "One thing I'll say for this place, it's way easier to fish here than at the Crossroads. I almost feel {#Emph}sorry {#Prev}for you, having to use a rod like some kind of starving mortal."
      Speaker = "Eris"
      Event = "ErisBossAboutFishing01"
    }
    {
      Id = "MelinoeField_4067"
      InheritFrom = "BaseNarrative"
      DisplayName = "I thought you didn't care for fishing. If now you do, you ought have more respect for the traditional technique."
      Speaker = "Melinoe"
      Event = "ErisBossAboutFishing01"
    }
    {
      Id = "ErisField_0450"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well then I guess that means I {#Emph}don't! {#Prev}But I was just about to shoot that fish swimming around right near the shore when you showed up. Now {#Emph}you {#Prev}get to be first!"
      Speaker = "Eris"
      Event = "ErisBossAboutFishing01"
    }
    {
      Id = "MelinoeField_3277"
      InheritFrom = "BaseNarrative"
      DisplayName = "So what's it like, having been forcibly dragged back to hell this many times? At least you know where you truly belong."
      Speaker = "Melinoe"
      Event = "ErisBossAboutDeath01"
    }
    {
      Id = "ErisField_0375"
      InheritFrom = "BaseNarrative"
      DisplayName = "You and me {#Emph}both{#Prev}, babe. {#Emph}You're {#Prev}the one who's not supposed to {#Emph}be {#Prev}up here! As for getting dragged back {#Emph}down{#Prev}, it's no big deal. I can just fly on back!"
      Speaker = "Eris"
      Event = "ErisBossAboutDeath01"
    }
    {
      Id = "MelinoeField_3278"
      InheritFrom = "BaseNarrative"
      DisplayName = "But as soon as your strength falters, the spirits of the dead shall take hold of you again. Many of them probably seek vengeance for something you did..."
      Speaker = "Melinoe"
      Event = "ErisBossAboutDeath01"
    }
    {
      Id = "ErisField_0376"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, then they can have a {#Emph}piece {#Prev}of me and feel all {#Emph}better {#Prev}about themselves! After all, I've got {#Emph}so {#Prev}much to {#Emph}give!"
      Speaker = "Eris"
      Event = "ErisBossAboutDeath01"
    }
    {
      Id = "ErisField_0377"
      InheritFrom = "BaseNarrative"
      DisplayName = "I almost thought you weren't going to show up! Leave me hanging yet another night, I mean... why {#Emph}not? {#Prev}You're so {#Emph}inconsiderate {#Prev}sometimes!"
      Speaker = "Eris"
      Event = "ErisBossAboutUnderworld01"
    }
    {
      Id = "MelinoeField_3279"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're telling me while I've been in the Underworld, you've just been waiting here night after night? What am I, supposed to tell you where I'm going in advance?"
      Speaker = "Melinoe"
      Event = "ErisBossAboutUnderworld01"
    }
    {
      Id = "ErisField_0378"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's what a real friend would do, so {#Emph}no{#Prev}, I guess not! Maybe you shouldn't come back. What do I care?"
      Speaker = "Eris"
      Event = "ErisBossAboutUnderworld01"
    }
    {
      Id = "ErisField_0360"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sure is dark out there tonight, {#Emph}huh? {#Prev}Even the dead sailors on the Rift looked a little spooked. Maybe something's up...?"
      Speaker = "Eris"
      Event = "ErisBossAboutShrine01"
    }
    {
      Id = "MelinoeField_3270"
      InheritFrom = "BaseNarrative"
      DisplayName = "There's {#Emph}Fear {#Prev}in the air. You've defied the will of Night too often, Eris. This time I'm not here merely for Olympus, but for {#Emph}you."
      Speaker = "Melinoe"
      Event = "ErisBossAboutShrine01"
    }
    {
      Id = "ErisField_0361"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're telling me {#Emph}Nyx {#Prev}put you up to this? {#Emph}Pff, right! {#Prev}She never cared about me, and she's {#Emph}not {#Prev}about to start now."
      Speaker = "Eris"
      Event = "ErisBossAboutShrine01"
    }
    {
      Id = "ErisField_0362"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Fear in the air{#Prev}, you said, last time it was like this. Maybe you really {#Emph}are {#Prev}doing some of Nyx's dirty work! In which case, you're {#Emph}way {#Prev}dumber than I thought..."
      Speaker = "Eris"
      Event = "ErisBossAboutShrine02"
    }
    {
      Id = "MelinoeField_3271"
      InheritFrom = "BaseNarrative"
      DisplayName = "You were invited and expected to be part of the Unseen. But you turned your back not only on us, but your mother, and the Underworld itself. A price is to be paid for that."
      Speaker = "Melinoe"
      Event = "ErisBossAboutShrine02"
    }
    {
      Id = "ErisField_0363"
      InheritFrom = "BaseNarrative"
      DisplayName = "And you've come to collect! Too bad I've got nothing to give. Unless you take payment in these little {#Emph}metal {#Prev}things that the Rail chews up and spits out."
      Speaker = "Eris"
      Event = "ErisBossAboutShrine02"
    }
    {
      Id = "ErisField_0368"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Whew{#Prev}, this is my kind of {#Emph}night! {#Prev}Real feeding frenzy out there, like everything is just... {#Emph}way... more. {#Prev}No idea what's going on but I {#Emph}like {#Prev}it."
      Speaker = "Eris"
      Event = "ErisBossAboutShrine03"
    }
    {
      Id = "MelinoeField_3274"
      InheritFrom = "BaseNarrative"
      DisplayName = "You never gave any consideration to the Oath of the Unseen, yet remain one of its main beneficiaries. Perhaps your mother Nyx did something for you after all."
      Speaker = "Melinoe"
      Event = "ErisBossAboutShrine03"
    }
    {
      Id = "ErisField_0369"
      InheritFrom = "BaseNarrative"
      DisplayName = "You mean these occasional evenings of complete and total depravity are meant to make up for everything Nyx {#Emph}didn't {#Prev}do...? Well I guess it's a start!"
      Speaker = "Eris"
      Event = "ErisBossAboutShrine03"
    }
    {
      Id = "ErisField_0364"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, you almost beat me here tonight, Trouble! You're {#Emph}way {#Prev}ahead of schedule! Although... {#Emph}huh... {#Prev}What am I {#Emph}saying? Schedule?! {#Prev}What's happening to me...?"
      Speaker = "Eris"
      Event = "ErisAboutPackagedBounties01"
    }
    {
      Id = "MelinoeField_3272"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you're feeling a little out of sorts this evening, perhaps it's simply because Primordial Chaos is exerting influence over reality as we know it."
      Speaker = "Melinoe"
      Event = "ErisAboutPackagedBounties01"
    }
    {
      Id = "ErisField_0365"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, {#Emph}right{#Prev}, that makes sense! {#Emph}Chaos {#Prev}made everything. But you know what? Now {#Emph}we {#Prev}can make some chaos, too."
      Speaker = "Eris"
      Event = "ErisAboutPackagedBounties01"
    }
    {
      Id = "ErisField_0366"
      InheritFrom = "BaseNarrative"
      DisplayName = "You made it past Ephyra {#Emph}real {#Prev}quick, Trouble. Must be {#Emph}Primordial Chaos exerting influence over reality {#Prev}again, {#Emph}huh...?"
      Speaker = "Eris"
      Event = "ErisAboutPackagedBounties02"
    }
    {
      Id = "MelinoeField_3273"
      InheritFrom = "BaseNarrative"
      DisplayName = "The thing is, Eris... I can be entirely forthright with you, yet you still take the absolute {#Emph}least {#Prev}charitable view of anything I say. So what does it matter how I respond?"
      Speaker = "Melinoe"
      Event = "ErisAboutPackagedBounties02"
    }
    {
      Id = "ErisField_0367"
      InheritFrom = "BaseNarrative"
      DisplayName = "See, that's exactly how {#Emph}I {#Prev}feel — what {#Emph}does {#Prev}it matter. Maybe it matters to {#Emph}Chaos, huh? {#Prev}Only {#Emph}one {#Prev}way to find out."
      Speaker = "Eris"
      Event = "ErisAboutPackagedBounties02"
    }
    {
      Id = "ErisField_0386"
      InheritFrom = "BaseNarrative"
      DisplayName = "See anything different about me, babe? Probably not! {#Emph}I {#Prev}haven't changed a bit, but you know what {#Emph}has {#Prev}is the Adamant Rail! I mean just {#Emph}look {#Prev}at it!"
      Speaker = "Eris"
      Event = "ErisBossAboutAltFight01"
    }
    {
      Id = "MelinoeField_3487"
      InheritFrom = "BaseNarrative"
      DisplayName = "That must be someone else's Aspect of the Rail. Perhaps you did or said something to make it change its form... though this could have been my doing as well."
      Speaker = "Melinoe"
      Event = "ErisBossAboutAltFight01"
    }
    {
      Id = "ErisField_0387"
      InheritFrom = "BaseNarrative"
      DisplayName = "There you go, always trying to take all the credit for yourself! Well the Rail doesn't answer to {#Emph}you{#Prev}, it answers to {#Emph}me. {#Prev}And I've already figured out all the new {#Emph}stuff {#Prev}it can do!"
      Speaker = "Eris"
      Event = "ErisBossAboutAltFight01"
    }
    {
      Id = "ErisField_0388"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Now watch {#Emph}this...!"
      Speaker = "Eris"
      Event = "ErisBossAboutAltFight01"
    }
    {
      Id = "ErisField_0389"
      InheritFrom = "BaseNarrative"
      DisplayName = "Earlier the Rail magickally switched over to this other style again. Like it {#Emph}knew {#Prev}you were on the way! I {#Emph}also {#Prev}knew you were on the way, pretty easy to spot you up there."
      Speaker = "Eris"
      Event = "ErisBossAboutAltFight02"
    }
    {
      Id = "MelinoeField_3488"
      InheritFrom = "BaseNarrative"
      DisplayName = "Have you any idea whose Aspect that even is, or why your ancient Fate-forged weapon might be magickally changing forms without your influence?"
      Speaker = "Melinoe"
      Event = "ErisBossAboutAltFight02"
    }
    {
      Id = "ErisField_0390"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}No! {#Prev}You talk like I'm supposed to be afraid of this thing when {#Emph}you're {#Prev}the one staring down the part that shoots."
      Speaker = "Eris"
      Event = "ErisBossAboutAltFight02"
    }
    {
      Id = "ErisField_0391"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Damn it {#Prev}I kept waiting for this stupid Rail to switch over to that other form again but it won't {#Emph}budge! {#Prev}Same old piece of junk. Doesn't even reload half the time..."
      Speaker = "Eris"
      Event = "ErisBossAboutAltFight03"
    }
    {
      Id = "MelinoeField_3489"
      InheritFrom = "BaseNarrative"
      DisplayName = "Keep speaking ill of it that way and it may do your bidding less and less! I'm surprised you have an Aspect to your name at all."
      Speaker = "Melinoe"
      Event = "ErisBossAboutAltFight03"
    }
    {
      Id = "ErisField_0392"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well life's just full of surprises, Trouble! I like this Aspect better anyway. Let's see if it still does my {#Emph}bidding!"
      Speaker = "Eris"
      Event = "ErisBossAboutAltFight03"
    }
    {
      Id = "ErisField_0393"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Rail switched up on me again! Hey, what if {#Emph}this {#Prev}is my true Aspect and the other one is for somebody else? This one's even got a {#Emph}face {#Prev}like mine, and {#Emph}wings!"
      Speaker = "Eris"
      Event = "ErisBossAboutAltFight04"
    }
    {
      Id = "MelinoeField_3490"
      InheritFrom = "BaseNarrative"
      DisplayName = "Look, the only reason you can sometimes use this Aspect is the Oath of the Unseen. Can't you feel the Fear in the night?"
      Speaker = "Melinoe"
      Event = "ErisBossAboutAltFight04"
    }
    {
      Id = "ErisField_0394"
      InheritFrom = "BaseNarrative"
      DisplayName = "All I feel right now, babe, is an overwhelming urge to turn you into little crispy slices with this thing. You think I care about some {#Emph}Oath? {#Prev}What am I, {#Emph}Nyx?!"
      Speaker = "Eris"
      Event = "ErisBossAboutAltFight04"
    }
    {
      Id = "ErisField_0395"
      InheritFrom = "BaseNarrative"
      DisplayName = "You washed up on the wrong part of the beach, Trouble. You see that giant stinking carcass over there? {#Emph}That's {#Prev}what you're gonna look like after this."
      Speaker = "Eris"
      Event = "ErisBossAboutAltFight05"
    }
    {
      Id = "MelinoeField_3491"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm not nearly that size, Eris! Nor am I an aquatic animal, nor are you going to kill me. Though I must say, this part of the beach is horrid, and the carcass doesn't help."
      Speaker = "Melinoe"
      Event = "ErisBossAboutAltFight05"
    }
    {
      Id = "ErisField_0396"
      InheritFrom = "BaseNarrative"
      DisplayName = "What do you even know about {#Emph}beaches{#Prev}, or carcasses? I've got my special Aspect of the Rail here, and {#Emph}all {#Prev}the sights and sounds and smells of the sea. So who needs {#Emph}you?!"
      Speaker = "Eris"
      Event = "ErisBossAboutAltFight05"
    }
    {
      Id = "Melinoe_4367"
      InheritFrom = "BaseNarrative"
      DisplayName = "When last we spoke you said whatever's wrong with you couldn't be fixed. What makes you say such things?"
      Speaker = "Melinoe"
      Event = "ErisBossAboutRelationship02"
    }
    {
      Id = "Eris_0260"
      InheritFrom = "BaseNarrative"
      DisplayName = "Appreciate all the concern but I just had a little moment that you're making a big deal. We're all a little broken, right?"
      Speaker = "Eris"
      Event = "ErisBossAboutRelationship02"
    }
    {
      Id = "Melinoe_4368"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps so. But we can better ourselves through effort and discipline, as much as we can muster. Or, we could endlessly get in each other's way."
      Speaker = "Melinoe"
      Event = "ErisBossAboutRelationship02"
    }
    {
      Id = "Eris_0261"
      InheritFrom = "BaseNarrative"
      DisplayName = "The thing is, I don't want to have to {#Emph}try. {#Prev}Not with {#Emph}this{#Prev}, not with {#Emph}you. {#Prev}I want things to be {#Emph}easy{#Prev}, you want things to be {#Emph}hard. {#Prev}But at least we really {#Emph}get {#Prev}each other now!"
      Speaker = "Eris"
      Event = "ErisBossAboutRelationship02"
    }
    {
      Id = "ErisField_0383"
      InheritFrom = "BaseNarrative"
      DisplayName = "Back to doing what we do! Nothing like trying to shoot you to pieces night after night like nothing happened, huh?"
      Speaker = "Eris"
      Event = "ErisBossAboutBecomingCloser01"
    }
    {
      Id = "MelinoeField_3527"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know I shouldn't be surprised that you're about to fight me as per usual, Eris, but... I held out hope you'd start to see me in a different light. So much for that?"
      Speaker = "Melinoe"
      Event = "ErisBossAboutBecomingCloser01"
    }
    {
      Id = "ErisField_0384"
      InheritFrom = "BaseNarrative"
      DisplayName = "So much for that! And don't be so full of yourself. It's not like we bared our souls to one another! Not sure I even {#Emph}have {#Prev}one. Anyway, no deferential treatment from me here."
      Speaker = "Eris"
      Event = "ErisBossAboutBecomingCloser01"
    }
    {
      Id = "MelinoeField_3528"
      InheritFrom = "BaseNarrative"
      DisplayName = "The part where you keep going out of your way to bar my passage to Olympus {#Emph}isn't {#Prev}what you would consider deferential treatment then?"
      Speaker = "Melinoe"
      Event = "ErisBossAboutBecomingCloser01"
    }
    {
      Id = "ErisField_0385"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know you {#Emph}do {#Prev}make a good point there, babe! But I'm not gonna dwell on it and just start shooting you, OK?"
      Speaker = "Eris"
      Event = "ErisBossAboutBecomingCloser01"
    }
    {
      Id = "MelinoeField_4070"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now that my brother's back, you still have no intention to return the Rail of Adamant, do you? Even though it was in his possession prior to all this."
      Speaker = "Melinoe"
      Event = "ErisBossPostTrueEnding01"
    }
    {
      Id = "ErisField_0455"
      InheritFrom = "BaseNarrative"
      DisplayName = "What makes you think he has greater right to it than {#Emph}me, huh{#Prev}, babe? He wasn't even using it five-sixths of the time! Just another weapon to him, but it's {#Emph}my {#Prev}one-and-only."
      Speaker = "Eris"
      Event = "ErisBossPostTrueEnding01"
    }
    {
      Id = "MelinoeField_4071"
      InheritFrom = "BaseNarrative"
      DisplayName = "How touching! I trust your mother shall make sure it all works out, seeing as she's back as well. I wonder if she's always known you'd get your hands on that thing."
      Speaker = "Melinoe"
      Event = "ErisBossPostTrueEnding01"
    }
    {
      Id = "ErisField_0456"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh {#Prev}she {#Emph}has! {#Prev}Because this isn't my first time! Then I kind of lost it at one point, and your brother got his hands on it instead... but I {#Emph}always {#Prev}take what's mine."
      Speaker = "Eris"
      Event = "ErisBossPostTrueEnding01"
    }
    {
      Id = "ErisField_0005"
      InheritFrom = "BaseNarrative"
      DisplayName = "Already locked and loaded here, so make your move, Trouble."
      Speaker = "Eris"
      Event = "ErisBossMiscStart01"
    }
    {
      Id = "ErisField_0006"
      InheritFrom = "BaseNarrative"
      DisplayName = "No going back to how things used to be, no matter {#Emph}what you do."
      Speaker = "Eris"
      Event = "ErisBossMiscStart02"
    }
    {
      Id = "ErisField_0007"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ready to give it your best shot here, Trouble? Because {#Emph}I {#Prev}sure am!"
      Speaker = "Eris"
      Event = "ErisBossMiscStart03"
    }
    {
      Id = "ErisField_0008"
      InheritFrom = "BaseNarrative"
      DisplayName = "Everybody always trying to make a difference. Nobody pulling it off."
      Speaker = "Eris"
      Event = "ErisBossMiscStart04"
    }
    {
      Id = "ErisField_0009"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just when I was starting to feel a little bored, {#Emph}along comes Trouble!"
      Speaker = "Eris"
      Event = "ErisBossMiscStart05"
    }
    {
      Id = "ErisField_0010"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nothing's gonna change! Except the number of holes you got in you."
      Speaker = "Eris"
      Event = "ErisBossMiscStart06"
    }
    {
      Id = "ErisField_0130"
      InheritFrom = "BaseNarrative"
      DisplayName = "This is for your own good, Trouble. Mine, too!"
      Speaker = "Eris"
      Event = "ErisBossMiscStart07"
    }
    {
      Id = "ErisField_0131"
      InheritFrom = "BaseNarrative"
      DisplayName = "Uh-uh-{#Emph}uh! {#Prev}The trail to the mountain's {#Emph}closed{#Prev}, in case you hadn't heard the latest, babe."
      Speaker = "Eris"
      Event = "ErisBossMiscStart08"
    }
    {
      Id = "ErisField_0132"
      InheritFrom = "BaseNarrative"
      DisplayName = "Back for another round? Good, 'cause I've got {#Emph}thousands."
      Speaker = "Eris"
      Event = "ErisBossMiscStart09"
    }
    {
      Id = "ErisField_0133"
      InheritFrom = "BaseNarrative"
      DisplayName = "Look at us, all settled into our routine. I {#Emph}hate {#Prev}routines!"
      Speaker = "Eris"
      Event = "ErisBossMiscStart10"
    }
    {
      Id = "ErisField_0134"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hate to do this to you, babe, but... oh, who am I kidding?"
      Speaker = "Eris"
      Event = "ErisBossMiscStart11"
    }
    {
      Id = "ErisField_0135"
      InheritFrom = "BaseNarrative"
      DisplayName = "You look lost, Trouble. Let me help you find your way back home."
      Speaker = "Eris"
      Event = "ErisBossMiscStart12"
    }
    {
      Id = "ErisField_0136"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't need a reason to get in your face. But I just happen to like it!"
      Speaker = "Eris"
      Event = "ErisBossMiscStart13"
    }
    {
      Id = "ErisField_0137"
      InheritFrom = "BaseNarrative"
      DisplayName = "So, ready to get shot all the way back to hell, Trouble?"
      Speaker = "Eris"
      Event = "ErisBossMiscStart14"
    }
    {
      Id = "ErisField_0138"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hope you're not sea-sick, babe. 'Cause {#Emph}you {#Prev}are about to get {#Emph}rocked."
      Speaker = "Eris"
      Event = "ErisBossMiscStart15"
    }
    {
      Id = "ErisField_0139"
      InheritFrom = "BaseNarrative"
      DisplayName = "If only you could fly, babe. But you can't! And I can't let you out of here."
      Speaker = "Eris"
      Event = "ErisBossMiscStart16"
    }
    {
      Id = "ErisField_0140"
      InheritFrom = "BaseNarrative"
      DisplayName = "What we're about to do, babe, I can do {#Emph}all night... {#Prev}after {#Emph}night{#Prev}, after {#Emph}night."
      Speaker = "Eris"
      Event = "ErisBossMiscStart17"
    }
    {
      Id = "ErisField_0141"
      InheritFrom = "BaseNarrative"
      DisplayName = "So maybe I can't kill you, Trouble, but I sure can try."
      Speaker = "Eris"
      Event = "ErisBossMiscStart18"
    }
    {
      Id = "ErisField_0142"
      InheritFrom = "BaseNarrative"
      DisplayName = "How many times am I gonna have to shoot you down, here, babe?"
      Speaker = "Eris"
      Event = "ErisBossMiscStart20"
    }
    {
      Id = "ErisField_0143"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're {#Emph}sick{#Prev}, babe! Losing over and over and {#Emph}over{#Prev}, and still you keep on?"
      Speaker = "Eris"
      Event = "ErisBossMiscStart21"
    }
    {
      Id = "ErisField_0144"
      InheritFrom = "BaseNarrative"
      DisplayName = "Can't always stop you, but I can {#Emph}always {#Prev}slow you down."
      Speaker = "Eris"
      Event = "ErisBossMiscStart22"
    }
    {
      Id = "ErisField_0145"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm a good sport, Trouble. Win or lose, it's all the same to me."
      Speaker = "Eris"
      Event = "ErisBossMiscStart23"
    }
    {
      Id = "ErisField_0148"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Finally! {#Prev}I can only stand here contemplating the water for so long, you know!"
      Speaker = "Eris"
      Event = "ErisBossMiscStart24"
    }
    {
      Id = "ErisField_0149"
      InheritFrom = "BaseNarrative"
      DisplayName = "Never thought I was the type to get into any sort of regular routine, but {#Emph}now {#Prev}look at me, babe!"
      Speaker = "Eris"
      Event = "ErisBossMiscStart25"
    }
    {
      Id = "ErisField_0150"
      InheritFrom = "BaseNarrative"
      DisplayName = "You don't {#Emph}really {#Prev}have to climb all the way up that mountain back there, do you, Trouble?"
      Speaker = "Eris"
      Event = "ErisBossMiscStart26"
    }
    {
      Id = "ErisField_0151"
      InheritFrom = "BaseNarrative"
      DisplayName = "Let's just have our fun, babe! I don't have all night, and neither do you."
      Speaker = "Eris"
      Event = "ErisBossMiscStart27"
    }
    {
      Id = "ErisField_0152"
      InheritFrom = "BaseNarrative"
      DisplayName = "Difference between you and me is I don't care {#Emph}one bit {#Prev}whether I win or lose."
      Speaker = "Eris"
      Event = "ErisBossMiscStart28"
    }
    {
      Id = "ErisField_0153"
      InheritFrom = "BaseNarrative"
      DisplayName = "You {#Emph}like {#Prev}this, don't you, Trouble? You don't have to tell me. Just admit it to yourself!"
      Speaker = "Eris"
      Event = "ErisBossMiscStart29"
    }
    {
      Id = "ErisField_0154"
      InheritFrom = "BaseNarrative"
      DisplayName = "I hate to be so predictable, but I love making you mad, so... it's kind of a wash!"
      Speaker = "Eris"
      Event = "ErisBossMiscStart30"
    }
    {
      Id = "ErisField_0026"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't take this personally, babe, but some things we just have to do, you know?"
      Speaker = "Eris"
      Event = "ErisBossMiscStart31"
    }
    {
      Id = "ErisField_0027"
      InheritFrom = "BaseNarrative"
      DisplayName = "While I'd love to slow you down with a delightful chat, I think {#Emph}this {#Prev}will get the job done {#Emph}even better."
      Speaker = "Eris"
      Event = "ErisBossMiscStart32"
    }
    {
      Id = "ErisField_0028"
      InheritFrom = "BaseNarrative"
      DisplayName = "Look, {#Emph}heh! {#Prev}I know it's been a little rocky between us, but... we'll probably look back at this and laugh!"
      Speaker = "Eris"
      Event = "ErisBossMiscStart33"
    }
    {
      Id = "ErisField_0029"
      InheritFrom = "BaseNarrative"
      DisplayName = "You don't look so happy to see me, babe! And I haven't even {#Emph}done {#Prev}anything yet..."
      Speaker = "Eris"
      Event = "ErisBossMiscStart34"
    }
    {
      Id = "ErisField_0030"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ungh! {#Prev}This isn't working...! Why won't you stop? What's it going to take, {#Emph}huh?"
      Speaker = "Eris"
      Event = "ErisBossMiscStart35"
    }
    {
      Id = "ErisField_0031"
      InheritFrom = "BaseNarrative"
      DisplayName = "You just don't know when to quit, do you, Trouble? {#Emph}Fine!"
      Speaker = "Eris"
      Event = "ErisBossMiscStart36"
    }
    {
      Id = "ErisField_0457"
      InheritFrom = "BaseNarrative"
      DisplayName = "Look what {#Emph}I {#Prev}got back for some strange reason I can't figure out, Trouble!"
      Speaker = "Eris"
      Event = "ErisBossMiscStart37"
    }
    {
      Id = "ErisField_0458"
      InheritFrom = "BaseNarrative"
      DisplayName = "I like the old Rail fine, but this {#Emph}new {#Prev}one's even better! Though, maybe not for you."
