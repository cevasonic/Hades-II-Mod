      Event = "ErisBossMiscStart38"
    }
    {
      Id = "ErisField_0459"
      InheritFrom = "BaseNarrative"
      DisplayName = "What a {#Emph}night! {#Prev}Got my new Aspect of the Rail, {#Emph}and {#Prev}a juicy target to try it on."
