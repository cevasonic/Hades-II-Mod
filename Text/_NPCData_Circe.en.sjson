  lang = "en"
  Texts = [
    {
      Id = "MelinoeField_3400"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}I see you guarding graves of mortals passed into the black beyond."
      Speaker = "Melinoe"
      Event = "NPC_Circe_01.UpgradeMenuOpenVoiceLines"
    }
    {
      Id = "Melinoe_0926_C"
      InheritFrom = "BaseSubtitle"
