    {
      Id = "Melinoe_1301"
      InheritFrom = "BaseNarrative"
      DisplayName = "Would you indulge me for a moment, Boatman? If we're to restore the old order around here, I was thinking why not start like this?"
      Speaker = "Melinoe"
      Event = "CharonGift01"
    }
    {
      Id = "Charon_0024"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hhhhrrrrnnnngggghhh...?"
      Speaker = "Charon"
      Event = "CharonGift01"
    }
    {
      Id = "Charon_0023"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oooohhhhhh..."
      Speaker = "Charon"
      Event = "CharonGift02"
    }
    {
      Id = "Melinoe_1208"
      InheritFrom = "BaseNarrative"
      DisplayName = "Indeed, Lord Charon. May we soon restore the old customs between our families, and bring about a new aeon of prosperity."
      Speaker = "Melinoe"
      Event = "CharonGift02"
    }
    {
      Id = "Charon_0090"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Auuggggghhhhhh..."
      Speaker = "Charon"
      Event = "CharonGift03"
    }
    {
      Id = "Melinoe_3383"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know you require only Gold, my lord. Nevertheless, I wanted to give you something more! I've always found your commitment to the realm and to your discipline inspiring."
      Speaker = "Melinoe"
      Event = "CharonGift03"
    }
    {
      Id = "Charon_0091"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Nrrrghhhhh, hauuuugghhhh..."
      Speaker = "Charon"
      Event = "CharonGift04"
    }
    {
      Id = "Melinoe_3384"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perseverance is what got us to this point, my lord. May your resolve never waver! Whenever mine does, I take comfort knowing I have such dependable allies."
      Speaker = "Melinoe"
      Event = "CharonGift04"
    }
    {
      Id = "Charon_0132"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Nraaauuggh, guhhh..."
      Speaker = "Charon"
      Event = "CharonGift05"
    }
    {
      Id = "Melinoe_5438"
      InheritFrom = "BaseNarrative"
      DisplayName = "You really should try it sometime, my lord! Nectar is one of the things just about everybody on Olympus can agree on, and that must mean something, right?"
      Speaker = "Melinoe"
      Event = "CharonGift05"
    }
    {
      Id = "Charon_0133"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hrrnnnmm, nnrrrr..."
      Speaker = "Charon"
      Event = "CharonGift06"
    }
    {
      Id = "Melinoe_5439"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know you never would permit yourself indulgences, my lord, but... you ought to receive more than mere coin in recompense for all your service! Perhaps the Nectar's but another token gesture."
      Speaker = "Melinoe"
      Event = "CharonGift06"
    }
    {
      Id = "Charon_0134"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ehhh..."
      Speaker = "Charon"
      Event = "CharonGift06"
    }
    {
      Id = "Melinoe_5440"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've heard in times past, you'd discreetly transport shipments of Ambrosia all the way into the depths of Tartarus. And knowing you, my lord, you would never sample your own wares, so here. This is a gift, not a delivery."
      Speaker = "Melinoe"
      Event = "CharonGift07"
    }
    {
      Id = "Charon_0136"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hoohhhhh, hrrrnnnn..."
      Speaker = "Charon"
      Event = "CharonGift07"
    }
    {
      Id = "Melinoe_5441"
      InheritFrom = "BaseSubtitle"
      DisplayName = "May there soon come such a time..."
      Speaker = "Melinoe"
      Event = "CharonGift07"
    }
    {
      Id = "Melinoe_5442"
      InheritFrom = "BaseNarrative"
      DisplayName = "Here, my lord. If you plan to keep the other Ambrosia bottle in reserve, perhaps you could share this one with a professional associate. No need to save it for later."
      Speaker = "Melinoe"
      Event = "CharonGift08"
    }
    {
      Id = "Charon_0137"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Auuugggghh, mmmm...? Kkrrnnn..."
      Speaker = "Charon"
      Event = "CharonGift08"
    }
    {
      Id = "Melinoe_5443"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I've merely strived to better understand you, knowing it was never about words or gifts. You are the Boatman of the Underworld... a mighty son of Nyx... and the most dependable sort of comrade I could ever want."
      Speaker = "Melinoe"
      Event = "CharonGift08"
    }
    {
      Id = "Charon_0138"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Nnnnhhh..."
      Speaker = "Charon"
      Event = "CharonGift08"
    }
