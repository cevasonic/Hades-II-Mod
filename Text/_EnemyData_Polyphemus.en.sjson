    }
    {
      Id = "Melinoe_1107"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Sleep tight."
      Speaker = "Melinoe"
      Event = "Polyphemus.BossKillVoiceLines"
    }
    {
      Id = "Melinoe_1108"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Out cold."
      Speaker = "Melinoe"
      Event = "Polyphemus.BossKillVoiceLines"
    }
    {
      Id = "Melinoe_1109"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That'll show him."
      Speaker = "Melinoe"
      Event = "Polyphemus.BossKillVoiceLines"
    }
    {
      Id = "MelinoeField_1723"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Don't stand in my way."
      Speaker = "Melinoe"
      Event = "Polyphemus.BossKillVoiceLines"
    }
    {
      Id = "MelinoeField_1726"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Eat {#Emph}that."
      Speaker = "Melinoe"
      Event = "Polyphemus.BossKillVoiceLines"
    }
    {
      Id = "MelinoeField_3741"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Lady Medea's gone..."
      Speaker = "Melinoe"
      Event = "Polyphemus.BossKillVoiceLines"
    }
    {
      Id = "MelinoeField_1724"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Fast asleep again..."
      Speaker = "Melinoe"
      Event = "Polyphemus.BossKillVoiceLines"
    }
    {
      Id = "MelinoeField_1725"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Sleep well, Cyclops..."
      Speaker = "Melinoe"
      Event = "Polyphemus.BossKillVoiceLines"
    }
    {
      Id = "MelinoeField_1727"
      InheritFrom = "BaseSubtitle"
      DisplayName = "All tired out."
      Speaker = "Melinoe"
      Event = "Polyphemus.BossKillVoiceLines"
    }
    {
      Id = "MelinoeField_1728"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Nap time."
      Speaker = "Melinoe"
      Event = "Polyphemus.BossKillVoiceLines"
    }
    {
      Id = "Polyphemus_0002"
      InheritFrom = "BaseNarrative"
      DisplayName = "You frightened my sheep. That's a real no-no in this town."
      Speaker = "Polyphemus"
      Event = "PolyphemusFirstMeeting"
    }
    {
      Id = "Melinoe_0490"
      InheritFrom = "BaseNarrative"
      DisplayName = "I apologize for my transgression, Cyclops. What do I owe you for the inconvenience? I can pay."
      Speaker = "Melinoe"
      Event = "PolyphemusFirstMeeting"
    }
    {
      Id = "Polyphemus_0003"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, you'll pay. The punishment's gettin' eaten alive. By {#Emph}me{#Prev}. Sorry, I don't make the rules."
      Speaker = "Polyphemus"
      Event = "PolyphemusFirstMeeting"
    }
    {
      Id = "Melinoe_0491"
      InheritFrom = "BaseNarrative"
      DisplayName = "That seems unusually strict. There's no use following a senseless code of law."
      Speaker = "Melinoe"
      Event = "PolyphemusFirstMeeting"
    }
    {
      Id = "Polyphemus_0004"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hah{#Prev}, only kiddin'! I {#Emph}do {#Prev}make the rules. And I get real tired only eatin' sheep."
      Speaker = "Polyphemus"
      Event = "PolyphemusFirstMeeting"
    }
    {
      Id = "MelinoeField_2448"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Then you'll eat dust!"
      Speaker = "Melinoe"
      Event = "PolyphemusFirstMeeting"
    }
    {
      Id = "Medea_0192"
      InheritFrom = "BaseNarrative"
      DisplayName = "I thank you, sorceress! Infusing Fear into the night lets me conduct certain experiments I normally cannot. Though I'm also bound to test you here, as does Great Hecate below."
      Speaker = "Medea"
      Event = "PolyphemusAboutAltFight01"
    }
    {
      Id = "MelinoeField_3546"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Test {#Prev}me! Lady Medea, what of the massive Cyclops already barring my path? He'll try to eat us both!"
      Speaker = "Melinoe"
      Event = "PolyphemusAboutAltFight01"
    }
    {
      Id = "Polyphemus_0474"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Nah. {#Prev}This witch here's not exactly to my taste, and besides... we got ourselves a little arrangement now. Since I can't smell as easy what with all the bodies popping up."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutAltFight01"
    }
    {
      Id = "Medea_0193"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your fight is with the Cyclops still! My aim is merely to enact the will of Night in my own way. Do try your best to pretend I'm not even here, which may be difficult, admittedly..."
      Speaker = "Medea"
      Event = "PolyphemusAboutAltFight01"
    }
    {
      Id = "MelinoeField_4331"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lady Medea! I thought you were supposed to be conducting research. And what do you mean, {#Emph}test me? {#Prev}That massive Cyclops already barring my path will try to eat us both!"
      Speaker = "Melinoe"
      Event = "PolyphemusAboutAltFight01_B"
    }
    {
      Id = "Medea_0194"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Are you quite serious, Cyclops? The bodies of the dead ought {#Emph}not {#Prev}to be consumed; all sorts of diseases and the like!"
      Speaker = "Medea"
      Event = "PolyphemusAboutAltFight02"
    }
    {
      Id = "Polyphemus_0475"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm telling you, they can be pretty good! Just got to age 'em right. But anyways we can pick up on that later. Got a {#Emph}warm {#Prev}one over there."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutAltFight02"
    }
    {
      Id = "MelinoeField_3547"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lady Medea, I cannot believe the two of you are getting on like this. The Testament of Night requires that you form alliances with those who stand in our way?"
      Speaker = "Melinoe"
      Event = "PolyphemusAboutAltFight02"
    }
    {
      Id = "Medea_0195"
      InheritFrom = "BaseNarrative"
      DisplayName = "We merely have a common interest, sorceress! The Cyclops yet stands in {#Emph}your {#Prev}way, so have at him! I'm here to make the night more foul at your own behest."
      Speaker = "Medea"
      Event = "PolyphemusAboutAltFight02"
    }
    {
      Id = "Polyphemus_0476"
      InheritFrom = "BaseNarrative"
      DisplayName = "Where'd that one witch go, and all the bodies, {#Emph}huh? {#Prev}And just as I was starting to like the new aroma around here..."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutAltFight03"
    }
    {
      Id = "MelinoeField_3548"
      InheritFrom = "BaseNarrative"
      DisplayName = "You and all of us are subject to the will of Night, Cyclops. Lady Medea was drawn here for that reason alone. For my part, I find it easier not having to contend with you both."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutAltFight03"
    }
    {
      Id = "Polyphemus_0477"
      InheritFrom = "BaseNarrative"
      DisplayName = "You want things {#Emph}easy{#Prev}, then what are you even doing over here? You just passed through one of the hardest towns I know, and things are only gonna get rougher."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutAltFight03"
    }
    {
      Id = "Polyphemus_0478"
      InheritFrom = "BaseNarrative"
      DisplayName = "You fixed it, meat! This witch is back, there's bodies everywhere! I've had it good. But you're about to get it {#Emph}bad."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutAltFight04"
    }
    {
      Id = "MelinoeField_3549"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lady Medea, aren't you supposed to stand with me here rather than with {#Emph}him? {#Prev}Though, the will of Night ought never to be questioned, and this is all part of the Vows I spoke..."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutAltFight04"
    }
    {
      Id = "Medea_0196"
      InheritFrom = "BaseNarrative"
      DisplayName = "Night brings terror, sorceress... a fear of the impossible and the unknown. I merely am fulfilling my responsibility unto that cause, so please! Address Lord Polyphemus here, not me."
      Speaker = "Medea"
      Event = "PolyphemusAboutAltFight04"
    }
    {
      Id = "Polyphemus_0479"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hah! Lord Polyphemus. {#Prev}Think I like the sound of that! After all, lords tend to have big appetites. Now come on over and I'll add you to the corpses on the ground."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutAltFight04"
    }
    {
      Id = "Polyphemus_0480"
      InheritFrom = "BaseNarrative"
      DisplayName = "Even with all the extra bodies here, I can always sniff you out. You're on my turf, and you'll address me as {#Emph}Lord Polyphemus {#Prev}from now on."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutAltFight05"
    }
    {
      Id = "MelinoeField_3550"
      InheritFrom = "BaseNarrative"
      DisplayName = "You can't be serious. You're not entitled to a greater status just because you asked! Or has Lady Medea poisoned your mind with newfound delusions?"
      Speaker = "Melinoe"
      Event = "PolyphemusAboutAltFight05"
    }
    {
      Id = "Medea_0199"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't look at {#Emph}me{#Prev}, sorceress. I'm here by will of Night alone, sworn to a Vow of Silence... even though it's difficult to keep."
      Speaker = "Medea"
      Event = "PolyphemusAboutAltFight05"
    }
    {
      Id = "Polyphemus_0481"
      InheritFrom = "BaseNarrative"
      DisplayName = "She don't want to talk to you, she said, but you keep on tryin'. And you know what? I don't want to talk to you, either."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutAltFight05"
    }
    {
      Id = "Polyphemus_0482"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I'm telling ya, it feels funny. Itches maybe, burns a little, I don't know. You sure it's gonna help me with my sleep?"
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutAltFight06"
    }
    {
      Id = "Medea_0200"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well for mortals, it induces an eternal sleep, preceded by a pain beyond compare. I made no more assurances, and... come to think? This may not be the remedy for you..."
      Speaker = "Medea"
      Event = "PolyphemusAboutAltFight06"
    }
    {
      Id = "Polyphemus_0483"
      InheritFrom = "BaseNarrative"
      DisplayName = "Least it hasn't messed up my sense of smell too much. 'Cause otherwise I wouldn't know we got ourselves somebody else who probably could use your {#Emph}remedies."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutAltFight06"
    }
    {
      Id = "Polyphemus_0484"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Sniff, Sniff> Eugh{#Prev}, my damn nose is all stuffed up. Think I'm allergic to something you got on you there, witch."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutAltFight07"
    }
    {
      Id = "Medea_0201"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're resistant to such toxins as could kill the strongest ox, Lord Polyphemus. Perhaps you've an aversion to the sorceress whom we must fight?"
      Speaker = "Medea"
      Event = "PolyphemusAboutAltFight07"
    }
    {
      Id = "Polyphemus_0485"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Sniff> {#Prev}What, she's {#Emph}here? Ugh{#Prev}, I'm losin' it if I can't even smell 'er when she's right in front of me like this."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutAltFight07"
    }
    {
      Id = "Polyphemus_0486"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}<Sniff> There {#Prev}she is..."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutAltFight07"
    }
    {
      Id = "Polyphemus_0487"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Sniff, Sniff> {#Prev}Well what am I supposed to do on nights like this? If I can't even smell her, I don't know where I'm supposed to kick."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutAltFight08"
    }
    {
      Id = "Medea_0202"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lord Polyphemus, your nasal passages must be utterly congested. The one to whom you're referring is right {#Emph}there! {#Prev}Next time, I shall have to unearth something you can use."
      Speaker = "Medea"
      Event = "PolyphemusAboutAltFight08"
    }
    {
      Id = "Polyphemus_0488"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Sniff> {#Prev}All right, sounds good, it's really not so bad. It's just if I can't smell my food, then I can't properly enjoy my meal."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutAltFight08"
    }
    {
      Id = "Polyphemus_0489"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}<Sniff> Ahh..."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutAltFight08"
    }
    {
      Id = "Polyphemus_0490"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Inhale> Yeah{#Prev}, you know I think that might have done the trick! 'Cause I can smell every last corpse a couple fields away. You're all right, witch! What'd you even {#Emph}give {#Prev}me?"
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutAltFight09"
    }
    {
      Id = "Medea_0203"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, it's just... I'd stashed away old herbal remedies my aunt had given me. Thought I would never find a use for them, but... didn't have the heart to throw them out."
      Speaker = "Medea"
      Event = "PolyphemusAboutAltFight09"
    }
    {
      Id = "Polyphemus_0491"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well that was awful generous of you, though now I'm in the mood for a quick bite. Or maybe a quick nap? You want to stick around?"
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutAltFight09"
    }
    {
      Id = "Medea_0204"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Why, {#Emph}certainly..."
      Speaker = "Medea"
      Event = "PolyphemusAboutAltFight09"
    }
    {
      Id = "Medea_0205"
      InheritFrom = "BaseNarrative"
      DisplayName = "...At any rate, Lord Polyphemus, we oughtn't even be speaking thus, for that is not my charge. But should you require any other remedies or toxins, I'm not far."
      Speaker = "Medea"
      Event = "PolyphemusAboutAltFight10"
    }
    {
      Id = "MelinoeField_3663"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lady Medea, you'd consort with Polyphemus there even without the Oath of the Unseen taking effect? I can't believe this! He's repeatedly attempted to devour me!"
      Speaker = "Melinoe"
      Event = "PolyphemusAboutAltFight10"
    }
    {
      Id = "Polyphemus_0492"
      InheritFrom = "BaseNarrative"
      DisplayName = "Watch with the attitude there, meat. The witch just said that she don't want to talk. You ever got somethin' to say here, you say it to {#Emph}me."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutAltFight10"
    }
    {
      Id = "Medea_0206"
      InheritFrom = "BaseNarrative"
      DisplayName = "Such appalling silence in these outskirts! I've grown too much accustomed to the bustle of the city, and its lingering scents of blood and decay."
      Speaker = "Medea"
      Event = "PolyphemusAboutAltFight11"
    }
    {
      Id = "MelinoeField_3816"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lady Medea, does Headmistress even know what you're doing here? She hadn't mentioned you'd be testing me."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutAltFight11"
    }
    {
      Id = "Medea_0207"
      InheritFrom = "BaseNarrative"
      DisplayName = "Great Hecate knows all. But now that you are Matron of the Oath, the consequences are yours to decide. And tonight, you spoke the Vows! Long have I been dying to oblige..."
      Speaker = "Medea"
      Event = "PolyphemusAboutAltFight11"
    }
    {
      Id = "Medea_0210"
      InheritFrom = "BaseNarrative"
      DisplayName = "Am I to merely be a shadow in the dark...? I cannot help but intervene not just with actions here but words. Lord Polyphemus, talk to her, would you?"
      Speaker = "Medea"
      Event = "PolyphemusAboutAltFight12"
    }
    {
      Id = "Polyphemus_0507"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sure, whatever you say there, witch. Let me go ahead and give this piece of meat I smell here a {#Emph}real {#Prev}talking-to."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutAltFight12"
    }
    {
      Id = "Polyphemus_0509"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know it's {#Emph}nice {#Prev}here with this witch around. I'm normally not big on talk, more about the olfactory, and the auditory, and all that. So I might let her handle the conversatin' for a bit..."
      Speaker = "Polyphemus"
      Event = "PolyphemusAltFightAboutMedea01"
    }
    {
      Id = "Medea_0211"
      InheritFrom = "BaseNarrative"
      DisplayName = "If I might briefly break my Vow of Silence, you look simply {#Emph}terrible{#Prev}, sorceress! More {#Emph}dead {#Prev}than {#Emph}alive. {#Prev}And now the Cyclops and I have to push you {#Emph}closer {#Prev}to the {#Emph}brink."
      Speaker = "Medea"
      Event = "PolyphemusAboutAltFight13"
    }
    {
      Id = "MelinoeField_3818"
      InheritFrom = "BaseNarrative"
      DisplayName = "I had some difficulties in Ephyra on the way, though thank you for noticing. I know the will of Night demands you show no mercy to me here; anything but."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutAltFight13"
    }
    {
      Id = "Medea_0212"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't think the will of Night ought be your chief concern... Lord Polyphemus, he is positively {#Emph}salivating. {#Prev}The power of the scent of blood! Particularly {#Emph}yours."
      Speaker = "Medea"
      Event = "PolyphemusAboutAltFight13"
    }
    {
      Id = "Medea_0213"
      InheritFrom = "BaseNarrative"
      DisplayName = "Those accursed curing pools there in the corners of the field... the Mandragora thrives in bloodied soil, but in doing so, it filters toxins out. How rather {#Emph}fortunate {#Prev}for you."
      Speaker = "Medea"
      Event = "PolyphemusAboutAltFight14"
    }
    {
      Id = "MelinoeField_3819"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your toxins are so potent, they immediately make me feel as though I'm burning up, even with those curing pools nearby."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutAltFight14"
    }
    {
      Id = "Medea_0214"
      InheritFrom = "BaseNarrative"
      DisplayName = "What can I say? I try! You'll even find that, no matter how many times you take ill, you won't become resistant... let alone immune."
      Speaker = "Medea"
      Event = "PolyphemusAboutAltFight14"
    }
    {
      Id = "Medea_0215"
      InheritFrom = "BaseNarrative"
      DisplayName = "My curses and concoctions are quite lethal normally. But you've been able to withstand them! I don't know whether to be impressed with you, or disappointed in myself."
      Speaker = "Medea"
      Event = "PolyphemusAboutAltFight15"
    }
    {
      Id = "MelinoeField_3931"
      InheritFrom = "BaseNarrative"
      DisplayName = "I thought this was to be a test of my abilities and growth! It more appears to be a test of your latest experiments."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutAltFight15"
    }
    {
      Id = "Medea_0216"
      InheritFrom = "BaseNarrative"
      DisplayName = "Must it merely be one or the other? Great Hecate has taught us always to be learning something more. {#Emph}That {#Prev}way, we shall grow as strong as the deadliest of poisons..."
      Speaker = "Medea"
      Event = "PolyphemusAboutAltFight15"
    }
    {
      Id = "Medea_0217"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well here we are already, sorceress! Mere moments prior we were speaking amicably by my cauldron, and yet now, it's come to {#Emph}this."
      Speaker = "Medea"
      Event = "PolyphemusAltFightMetMedeaEarlier01"
    }
    {
      Id = "MelinoeField_3932"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know you're to confront me here because of the Oath we took, Lady Medea, but the Cyclops hasn't had as good of an excuse..."
      Speaker = "Melinoe"
      Event = "PolyphemusAltFightMetMedeaEarlier01"
    }
    {
      Id = "Medea_0218"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come, you've trespassed on his property, for one, and he is famished, for another! Look at him, he's at a loss for words. Lord Polyphemus, you {#Emph}must {#Prev}say something!"
      Speaker = "Medea"
      Event = "PolyphemusAltFightMetMedeaEarlier01"
    }
    {
      Id = "Polyphemus_0508"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How 'bout I let my {#Emph}feet {#Prev}do the talkin' {#Emph}this {#Prev}time?"
      Speaker = "Polyphemus"
      Event = "PolyphemusAltFightMetMedeaEarlier01"
    }
    {
      Id = "Medea_0208"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, sorceress! You're utterly committed to the Oath. As your fight remains with Lord Polyphemus, I'm to be mostly silent henceforth; though I have no wish to be rude."
      Speaker = "Medea"
      Event = "PolyphemusAboutAltFightBackOn01"
    }
    {
      Id = "MelinoeField_3817"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know you're here because of certain obligations, Lady Medea, so I certainly bear no ill will. Well not to you, at least, but to {#Emph}Lord Polyphemus{#Prev}, I am not so sure."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutAltFightBackOn01"
    }
    {
      Id = "Medea_0209"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now he's upset again. Please understand that I am not responsible for any actions that the Cyclops takes... I hardly am responsible for {#Emph}mine."
      Speaker = "Medea"
      Event = "PolyphemusAboutAltFightBackOn01"
    }
    {
      Id = "Medea_0197"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, I {#Emph}quite {#Prev}like it here! As much as I've enjoyed experimenting in my little corner of the city, a bit of the outdoors is giving me some benefit, I think."
      Speaker = "Medea"
      Event = "PolyphemusAboutAltFightBackOn02"
    }
    {
      Id = "MelinoeField_3815"
      InheritFrom = "BaseNarrative"
      DisplayName = "If only I could say the same for your various toxins, venoms, poisons, and such, Lady Medea. Doesn't the will of Night forbid the use of certain substances?"
      Speaker = "Melinoe"
      Event = "PolyphemusAboutAltFightBackOn02"
    }
    {
      Id = "Medea_0198"
      InheritFrom = "BaseNarrative"
      DisplayName = "Is that so...? Perhaps I'm not entirely caught up on all the latest bylaws; but you have bigger problems here than a bit of sour blood. {#Emph}Oh, Cyclops...?"
      Speaker = "Medea"
      Event = "PolyphemusAboutAltFightBackOn02"
    }
    {
      Id = "Polyphemus_0005"
      InheritFrom = "BaseNarrative"
      DisplayName = "Can't you see I'm busy over here? Personally, I can't see a thing. Do I complain? No. I just tend my flock."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutFlock01"
    }
    {
      Id = "Melinoe_0493"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your blasted sheep are some of the most high-strung animals I have ever encountered."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutFlock01"
    }
    {
      Id = "Polyphemus_0006"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sheep are fast. It's not an easy job. And it's even harder when somebody makes a ruckus in my meadow. So what choice do I got? Besides eatin' {#Emph}you?"
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutFlock01"
    }
    {
      Id = "Polyphemus_0007"
      InheritFrom = "BaseNarrative"
      DisplayName = "You coulda had my friendship. A couple of my sheep. But instead? You spit in my eye."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutFriendship01"
    }
    {
      Id = "Melinoe_0494"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have done no such thing. I merely need access to the docks. Yet you insist on getting in my way."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutFriendship01"
    }
    {
      Id = "Polyphemus_0008"
      InheritFrom = "BaseNarrative"
      DisplayName = "Put yourself in my sandals. What would {#Emph}you {#Prev}do? You'd say: {#Emph}I don't like the way you're treating me. I am gonna eat you."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutFriendship01"
    }
    {
      Id = "Polyphemus_0009"
      InheritFrom = "BaseNarrative"
      DisplayName = "I try to watch my diet. Three square meals, that's it. No snacks. You're making it real difficult for me."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutDiet01"
    }
    {
      Id = "Melinoe_0495"
      InheritFrom = "BaseNarrative"
      DisplayName = "Where I am from, we fast under the waxing moon, and grow nutritious plants and funguses. I could bring you some next time if you would like?"
      Speaker = "Melinoe"
      Event = "PolyphemusAboutDiet01"
    }
    {
      Id = "Polyphemus_0010"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I can't just save you for later. You'd try to run. They always do. Oh, {#Emph}I {#Prev}know! I'll just start with the legs!"
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutDiet01"
    }
    {
      Id = "Melinoe_0496"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No you won't."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutDiet01"
    }
    {
      Id = "Polyphemus_0347"
      InheritFrom = "BaseNarrative"
      DisplayName = "Who told {#Emph}you {#Prev}you could call me by my name, {#Emph}eh? {#Prev}I never introduced myself to you. What, you gonna start calling me Poly next like I'm your pal?"
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutName01"
    }
    {
      Id = "MelinoeField_2858"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can't imagine you have many {#Emph}pals {#Prev}with how you go on trying to eat anything that moves. Though, we could still be friends! Put all that trying-to-eat-me behind us?"
      Speaker = "Melinoe"
      Event = "PolyphemusAboutName01"
    }
    {
      Id = "Polyphemus_0348"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Nah! {#Prev}Got all the pals I need. The sheep back there, dead below the dirt down here. You know what I {#Emph}do {#Prev}need, though? {#Emph}Yeah {#Prev}I think you do."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutName01"
    }
    {
      Id = "Polyphemus_0455"
      InheritFrom = "BaseNarrative"
      DisplayName = "Living here, it has its ups and downs. Lately for instance I don't get a lot of peace, though I sleep like a rock. I don't know, maybe I ought to move..."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutMoving01"
    }
    {
      Id = "MelinoeField_3164"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wholeheartedly support that choice. Aren't you more accustomed to island living anyhow? This city life, even on the outskirts here... the pace is far too quick."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutMoving01"
    }
    {
      Id = "Polyphemus_0456"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know what {#Emph}you {#Prev}want me to do. Although I miss the island life now that you bring it up. Still got unwanted company sometimes but not so much as now."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutMoving01"
    }
    {
      Id = "Polyphemus_0139"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just wanted to be left alone. Move to the countryside, quiet life of the shepherd and all. Only for you to drag me out of retirement."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutPast01"
    }
    {
      Id = "MelinoeField_0320"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've done no such thing. I'm going to the docks. You're choosing to try and stop me, when you could be tending to your sheep instead."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutPast01"
    }
    {
      Id = "Polyphemus_0140"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh I'll {#Emph}tend {#Prev}to them all right. But in order to do that, I got to tend to the likes of {#Emph}you {#Prev}first. Just like I used to in the good old days."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutPast01"
    }
    {
      Id = "Polyphemus_0129"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Sigh> {#Prev}Look, I'm just a humble shepherd trying to live in peace. But I gotta protect my own, you understand. Plus, I gotta eat."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutWar01"
    }
    {
      Id = "MelinoeField_0313"
      InheritFrom = "BaseNarrative"
      DisplayName = "You call this trying to live in peace?! Perhaps you shouldn't be interfering with my efforts to put an end to this war raging all around us!"
      Speaker = "Melinoe"
      Event = "PolyphemusAboutWar01"
    }
    {
      Id = "Polyphemus_0130"
      InheritFrom = "BaseNarrative"
      DisplayName = "The dead don't bother me. It's the living always been a pain in my behind. Good thing the {#Emph}living {#Prev}taste better than the {#Emph}dead."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutWar01"
    }
    {
      Id = "Polyphemus_0133"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know I can always hear you storming through town all the way from this calm relaxing pasture. Even before my sheep get spooked."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutBoulders01"
    }
    {
      Id = "MelinoeField_0316"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes, I figured the boulders raining down back there weren't landing near me by coincidence. You have excellent hearing, and rather good aim."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutBoulders01"
    }
    {
      Id = "Polyphemus_0134"
      InheritFrom = "BaseNarrative"
      DisplayName = "Aw, thanks. And you got {#Emph}excellent {#Prev}taste, I'm sure. Now hold still, so I can practice my {#Emph}rather good aim {#Prev}some more."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutBoulders01"
    }
    {
      Id = "MelinoeField_0352"
      InheritFrom = "BaseNarrative"
      DisplayName = "Each time you know I'm here, no matter the softness of my approach or anything I do to mask my scent. Your senses are very keen."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutBlindness01"
    }
    {
      Id = "Polyphemus_0190"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yeah, well, when you lose your eye... you got to learn to compensate. And I never saw too good to start with. Could never tell how far away things were."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutBlindness01"
    }
    {
      Id = "MelinoeField_0353"
      InheritFrom = "BaseNarrative"
      DisplayName = "It must have been extraordinarily difficult, nevertheless. And now you use these heightened abilities to tend your flock..."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutBlindness01"
    }
    {
      Id = "Polyphemus_0191"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Heightened abilities{#Prev}, I like that. Look, this world's a real ugly place. Difference between you and me is, I don't got to look at it no more. Now, hold still or start running... I don't even care."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutBlindness01"
    }
    {
      Id = "MelinoeField_0321"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you care so much about your sheep, why keep putting them in harm's way? Not to mention eating them. Let them leave here, now."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutSheep01"
    }
    {
      Id = "Polyphemus_0141"
      InheritFrom = "BaseNarrative"
      DisplayName = "'Scuse me? I didn't ask you for your shepherding advice, and besides... these sheep got nowhere else to be. And we're the {#Emph}dinner entertainment."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutSheep01"
    }
    {
      Id = "Polyphemus_0011"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know who's disrespected me like this? Nobody. Nobody took my sheep. Took my eye."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutNobody01"
    }
    {
      Id = "MelinoeField_2447"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes, well, sometimes we've no one to blame but ourselves."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutNobody01"
    }
    {
      Id = "Polyphemus_0012"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nobody's gonna pay for all that someday. But you're gonna pay right now. {#Emph}Heh. {#Prev}Metaphorically, I mean! I'm not gonna take your money. Just gonna eat ya... bones and all."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutNobody01"
    }
    {
      Id = "MelinoeField_0314"
      InheritFrom = "BaseNarrative"
      DisplayName = "You said nobody took your eye before, as well as your sheep. How did you lose them, then?"
      Speaker = "Melinoe"
      Event = "PolyphemusAboutNobody02"
    }
    {
      Id = "Polyphemus_0131"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nobody played a dirty trick on me, is how. Bunch of sailors thought they could get away with my sheep, so I ate a couple of 'em. The sailors, that is! But Nobody got me when I wasn't looking. Then he got away..."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutNobody02"
    }
    {
      Id = "MelinoeField_0315"
      InheritFrom = "BaseNarrative"
      DisplayName = "And you've sought vengeance on this Nobody ever since?"
      Speaker = "Melinoe"
      Event = "PolyphemusAboutNobody02"
    }
    {
      Id = "Polyphemus_0132"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, not me personally! Someday, somebody's gonna get Nobody for what he did. Though, I am gonna get {#Emph}you {#Prev}right here and now."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutNobody02"
    }
    {
      Id = "Polyphemus_0289"
      InheritFrom = "BaseNarrative"
      DisplayName = "No wonder you and Nobody are pals. He and his rats are the only ones that ever got away from me, other than you. That worthless good-for-nothing put you up to this?"
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutNobody03"
    }
    {
      Id = "MelinoeField_1949"
      InheritFrom = "BaseNarrative"
      DisplayName = "His name is Odysseus! He's a great hero and tactician, though you needn't worry about slaying him, for he's long dead already. Not your problem anymore."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutNobody03"
    }
    {
      Id = "Polyphemus_0514"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't matter if he's dead, I'll eat him anyways. And don't care what he calls himself. He's always gonna be a Nobody to me. Now how 'bout I send him a message?"
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutNobody03"
    }
    {
      Id = "Polyphemus_0520"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nobody's not with you this time, is he? Good at running away, that guy. Knew I'd seen the last of him, found out I {#Emph}smelled {#Prev}the last of him, and maybe now I {#Emph}heard {#Prev}the last of him too."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutNobody04"
    }
    {
      Id = "MelinoeField_4359"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't think Odysseus plans to make a habit of visiting, no. Which means you won't ever get to hear what happened when he first escaped from you. It's quite a tale!"
      Speaker = "Melinoe"
      Event = "PolyphemusAboutNobody04"
    }
    {
      Id = "Polyphemus_0521"
      InheritFrom = "BaseNarrative"
      DisplayName = "Think I can live with that. Nobody's a dirty sneak... who's gonna want a story about a guy like him?"
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutNobody04"
    }
    {
      Id = "Polyphemus_0287"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Sniff, Sniff> {#Prev}I never forget a scent, you know. And you got somethin' that's familiar to me from way back when. I know those Bones. {#Emph}Nobody {#Prev}had 'em before you."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutNobodyKeepsake01"
    }
    {
      Id = "MelinoeField_1948"
      InheritFrom = "BaseNarrative"
      DisplayName = "You must mean these Knuckle Bones... if they've ever been a source of ill fortune for you before, then perhaps you know what's coming."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutNobodyKeepsake01"
    }
    {
      Id = "Polyphemus_0288"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nobody's your {#Emph}pal{#Prev}, is that what you expect me to believe? Then first I'm gonna crush {#Emph}your {#Prev}bones, and then I'll eat 'em. And those Knuckle Bones, too."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutNobodyKeepsake01"
    }
    {
      Id = "Polyphemus_0515"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey meat, smells to me like you brought those Knuckle Bones again. Nobody really gave you those, huh?"
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutOdysseusQuest01"
    }
    {
      Id = "MelinoeField_4356"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ask him yourself, Cyclops. Nobody wants to speak with you. {#Emph}Heed now my voice, Odysseus; one whom you sought is here!"
      Speaker = "Melinoe"
      Event = "PolyphemusAboutOdysseusQuest01"
    }
    {
      Id = "Polyphemus_0516"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Nobody... {#Prev}can't smell ya for nothing but that's your voice, all right. Why not come a little {#Emph}closer {#Prev}so I can hear ya better?"
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutOdysseusQuest01"
    }
    {
      Id = "Odysseus_0571"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm afraid you won't be able to consume me in my current state, Cyclops, because I'm long since dead. A mere projection of a Shade, but I did wish to have a word!"
      Speaker = "Odysseus"
      Event = "PolyphemusAboutOdysseusQuest01"
    }
    {
      Id = "Polyphemus_0517"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, ya really {#Emph}are {#Prev}already dead. Always thought I'd kill ya myself. But ya got the last laugh again."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutOdysseusQuest01"
    }
    {
      Id = "Odysseus_0572"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not here to laugh, but to ask you a question. Back when you imprisoned me and my men, killing several of us, you ended up {#Emph}losing {#Prev}your one eye whilst we escaped... was it worth it?"
      Speaker = "Odysseus"
      Event = "PolyphemusAboutOdysseusQuest01"
    }
    {
      Id = "Polyphemus_0518"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I don't remember most meals. Think that's pretty normal. But I remember your crew... tough meat, aged under the sun and all. But worth my eye? {#Emph}Nah{#Prev}, wasn't the best trade."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutOdysseusQuest01"
    }
    {
      Id = "Odysseus_0573"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nor was it good for me, or them. Well {#Emph}anyhow! {#Prev}It seems we each gave one another lasting, bitter scars. Though mine is merely psychological. I'll leave you to the Princess now, you murderous bastard."
      Speaker = "Odysseus"
      Event = "PolyphemusAboutOdysseusQuest01"
    }
    {
      Id = "Polyphemus_0519"
      InheritFrom = "BaseNarrative"
      DisplayName = "Shove off, pal. I didn't ever want to see you again anyways."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutOdysseusQuest01"
    }
    {
      Id = "MelinoeField_0310"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're very obstinate for a peaceful shepherd. Did Poseidon do something to offend you at some point? Is {#Emph}that {#Prev}what this is about?"
      Speaker = "Melinoe"
      Event = "PolyphemusAboutPoseidon01"
    }
    {
      Id = "Polyphemus_0125"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, I don't get {#Emph}offended... {#Prev}I get {#Emph}even. {#Prev}And you don't get to ask questions no more... you get {#Emph}eaten."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutPoseidon01"
    }
    {
      Id = "MelinoeField_0311"
      InheritFrom = "BaseNarrative"
      DisplayName = "Last I'll say about Poseidon, I swear. He's my uncle, you know. For what it's worth... I'm sorry if he truly led you to believe you were his son."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutPoseidon02"
    }
    {
      Id = "Polyphemus_0126"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yeah, well, I like to play up the family resemblance just in case. Though I'm glad he's not my pop neither. Otherwise I'd be about to eat my own cousin, and that'd be real weird."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutPoseidon02"
    }
    {
      Id = "Polyphemus_0127"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey what's your beef with Chronos, anyways? He wants to change stuff up a bit, so what? Life's hard up here. It could be easier."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutChronos01"
    }
    {
      Id = "MelinoeField_0312"
      InheritFrom = "BaseNarrative"
      DisplayName = "It won't be. That {#Emph}town {#Prev}back there, as you call it, would have been bustling with mortals. Now it's a festering necropolis. All thanks to the Titan."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutChronos01"
    }
    {
      Id = "Polyphemus_0128"
      InheritFrom = "BaseNarrative"
      DisplayName = "My sheep, they're glad to be alive. No complaints. But individuals like you? You got too many ideals. Best I {#Emph}eat {#Prev}you, and be done."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutChronos01"
    }
    {
      Id = "MelinoeField_2829"
      InheritFrom = "BaseNarrative"
      DisplayName = "So what does Chronos offer you exactly for these ineffectual attempts to bar my passage?"
      Speaker = "Melinoe"
      Event = "PolyphemusAboutChronos02"
    }
    {
      Id = "Polyphemus_0343"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't see how that's any of your business, meat. {#Emph}You're {#Prev}the one barging into my turf, making a fuss in my town. Falls on me to keep things nice and orderly."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutChronos02"
    }
    {
      Id = "MelinoeField_2830"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ephyra is {#Emph}not {#Prev}your town. Unless that was your arrangement with the Titan, though the city wasn't his to give away. In any case, ready to earn your nightly keep?"
      Speaker = "Melinoe"
      Event = "PolyphemusAboutChronos02"
    }
    {
      Id = "Polyphemus_0344"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ohh {#Prev}you don't know the next thing about my {#Emph}arrangement. {#Prev}For one, I always take my pay up front. But with you here... I get a little {#Emph}bonus."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutChronos02"
    }
    {
      Id = "Polyphemus_0136"
      InheritFrom = "BaseNarrative"
      DisplayName = "Somethin' {#Emph}nasty {#Prev}in the air tonight. And it's not just {#Emph}you {#Prev}or the stink from town. Must be that witch up to no good. You palling up with her?"
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutMedea01"
    }
    {
      Id = "MelinoeField_0318"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you know of Lady Medea then you must know she's not somebody to be crossed. She would not hesitate to curse my foes; including you."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutMedea01"
    }
    {
      Id = "Polyphemus_0137"
      InheritFrom = "BaseNarrative"
      DisplayName = "Was that a threat? I think it was. You don't go saying stuff like that, not in this town. Your {#Emph}pal {#Prev}knows to stay where I can't smell her, unlike {#Emph}you."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutMedea01"
    }
    {
      Id = "MelinoeField_0319"
      InheritFrom = "BaseNarrative"
      DisplayName = "How is it you detain {#Emph}me {#Prev}every time, yet the mighty Heracles can rampage through the city all he likes and never has to deal with you? Or so he says."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutHeracles01"
    }
    {
      Id = "Polyphemus_0138"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's called a {#Emph}double standard{#Prev}, little sheep. Don't need my eye to know he's way bigger than you. You can knock me out for a nice short nap; he can knock me into next week. No thanks."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutHeracles01"
    }
    {
      Id = "Polyphemus_0445"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know your scent but don't got any real clue what you look like. Probably you're kind of like this shepherd's crook I got between my teeth. No meat on you at all."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutMelinoe01"
    }
    {
      Id = "MelinoeField_3159"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps if you knew my appearance you'd be less inclined to treat me as livestock. My hair is pale as wheat; I'm clad in saffron and silver; and I wield the Nocturnal Arms, forged in the depths of Chaos."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutMelinoe01"
    }
    {
      Id = "Polyphemus_0446"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Mmm{#Prev}, wheat and saffron! Throw in some sheep's milk, pinch of sea-salt, little of {#Emph}this{#Prev}, little of {#Emph}that{#Prev}? Then throw it in the fire for a bit... and you'll have bread to die for."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutMelinoe01"
    }
    {
      Id = "MelinoeField_0317"
      InheritFrom = "BaseNarrative"
      DisplayName = "What's become of the other Cyclopes? Your kind once aided the gods against the Titans, crafting weapons of war and such. Yet {#Emph}you {#Prev}turn your back..."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutCyclopes01"
    }
    {
      Id = "Polyphemus_0135"
      InheritFrom = "BaseNarrative"
      DisplayName = "What, you think we all keep in touch just 'cause we got one eye at most? What they did and what happened to 'em don't matter to me. 'Specially not when I'm {#Emph}hungry..."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutCyclopes01"
    }
    {
      Id = "Polyphemus_0119"
      InheritFrom = "BaseNarrative"
      DisplayName = "You some kind of {#Emph}deathless goddess of the Underworld{#Prev}, you said? Seems you'd be better off staying on {#Emph}your {#Prev}side of the fence."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutUnderworld01"
    }
    {
      Id = "MelinoeField_0307"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm here to pay my relatives a visit. You just keep getting in the way. Almost as though violence better suits you than the shepherd's life."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutUnderworld01"
    }
    {
      Id = "Polyphemus_0120"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why, you're a real thinker for a slice of meat! Just 'cause I'm retired don't mean I don't want to work up an appetite no more, does it now?"
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutUnderworld01"
    }
    {
      Id = "Polyphemus_0121"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Sniff> {#Prev}You stink like the dead. But you're not from the town. You're from further below. You'd be better off staying on your side of the fence."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutUnderworld01B"
    }
    {
      Id = "MelinoeField_0308"
      InheritFrom = "BaseNarrative"
      DisplayName = "Are you the one responsible for that spectral barrier at the city gates? It has the markings of Chronos all over it, and you seem to be the extra backup in case it fails."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutEphyra01"
    }
    {
      Id = "Polyphemus_0122"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh {#Emph}that {#Prev}thing, yeah. I knew it'd never hold. But they keep fixing it anyways! Almost like somebody out there don't want you here..."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutEphyra01"
    }
    {
      Id = "Polyphemus_0123"
      InheritFrom = "BaseNarrative"
      DisplayName = "I made those docks back there with my bare hands. Know some guys, they tally every skiff and trireme in the drink. We know where you're going."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutDocks01"
    }
    {
      Id = "MelinoeField_0309"
      InheritFrom = "BaseNarrative"
      DisplayName = "So what if you do? You're just another servant of Chronos. The gods shall punish you when all this is over."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutDocks01"
    }
    {
      Id = "Polyphemus_0124"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ehh{#Prev}, what do you know about it? They only care about their own! I'm just a joke to them. Am I a joke... to {#Emph}you?"
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutDocks01"
    }
    {
      Id = "Polyphemus_0281"
      InheritFrom = "BaseNarrative"
      DisplayName = "You went through my old barn the other night while I was out. Coulda cased the joint but you didn't. Drank from my well and that was it."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutBarn01"
    }
    {
      Id = "MelinoeField_1929"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm no thief. And besides, your residence is filthy! You could stand to clean it up instead of facing me. Let me know if you need assistance, as I'll soon be passing through again."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutBarn01"
    }
    {
      Id = "Polyphemus_0282"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Nah{#Prev}, thanks. If it was tidy in there I couldn't sniff my way around. And also, you {#Emph}shut up! {#Prev}I don't go tellin' {#Emph}you {#Prev}the way {#Emph}you {#Prev}ought to live!"
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutBarn01"
    }
    {
      Id = "Polyphemus_0285"
      InheritFrom = "BaseNarrative"
      DisplayName = "Where do you think you're goin', anyways? No ship that sails from the docks back there is gonna take the likes of {#Emph}you. {#Prev}Come to think of it... lately, we've had no ships at all."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutThessaly01"
    }
    {
      Id = "MelinoeField_1947"
      InheritFrom = "BaseNarrative"
      DisplayName = "The deathless fleet of Chronos is still out there in the waters of the Rift. Apparently when one ship sinks, another rises to replace it from the depths, drowned sailors for its crew..."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutThessaly01"
    }
    {
      Id = "Polyphemus_0286"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're pulling my leg. The dead can sail nowadays? I thought they were no good for anything but food. Might have to teach 'em to take on some of my household chores..."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutThessaly01"
    }
    {
      Id = "Polyphemus_0345"
      InheritFrom = "BaseNarrative"
      DisplayName = "So how is it over there, across the drink? Heard it's been snowing. Sounds like a real rotten place to live."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutOlympus01"
    }
    {
      Id = "MelinoeField_2831"
      InheritFrom = "BaseNarrative"
      DisplayName = "What, you mean Mount Olympus? The gods themselves quite like it, enough to want to fiercely defend it from the Titan you decided to support. But, yes... it's rather cold."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutOlympus01"
    }
    {
      Id = "Polyphemus_0346"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, I could never settle in a place like that. I like the temperature same way I like my meat, nice and hot. 'Course I can also eat it raw. Can't be too picky, and all that."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutOlympus01"
    }
    {
      Id = "Polyphemus_0457"
      InheritFrom = "BaseNarrative"
      DisplayName = "The dead... they talk sometimes, or try. Nothin' better to do around here. Know what they're going on about? I couldn't make it out at first, but sounds an awful lot like... {#Emph}Prometheus."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutPrometheus01"
    }
    {
      Id = "MelinoeField_3165"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Titan of Foresight, and one of your allies, in case you've not met; for apparently you serve the same master. What have the wretched dead to say about the likes of him?"
      Speaker = "Melinoe"
      Event = "PolyphemusAboutPrometheus01"
    }
    {
      Id = "Polyphemus_0458"
      InheritFrom = "BaseNarrative"
      DisplayName = "Mostly just moans and groans. Might be they're hungry like me! 'Cause if Prometheus really made off with fire from the gods like I'm hearin'... he probably knows how to cook."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutPrometheus01"
    }
    {
      Id = "MelinoeField_3166"
      InheritFrom = "BaseNarrative"
      DisplayName = "I remember back when first we met, you seemed {#Emph}enormous... {#Prev}much bigger than most any other foe I'd ever faced. But now, you're hardly any match for me."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutTyphon01"
    }
    {
      Id = "Polyphemus_0459"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Aw{#Prev}, thanks. And I remember back when first {#Emph}we {#Prev}met, my sleeping schedule was completely out of whack! But it's all better now. And I've still got my figure! {#Emph}Enormous{#Prev}, was it?"
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutTyphon01"
    }
    {
      Id = "MelinoeField_3167"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's all a matter of perspective, as I've learned. For instance, you're quite minuscule in comparison to the Father of All Monsters, Typhon. He's properly enormous."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutTyphon01"
    }
    {
      Id = "Polyphemus_0460"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll have to take your word for it. Anyways just how big can he be? No more than three square meals' worth if I had to guess. Been too long since I had some monster meat..."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutTyphon01"
    }
    {
      Id = "Polyphemus_0142"
      InheritFrom = "BaseNarrative"
      DisplayName = "Funny. Running into you again and again like this? It's made for some of the best sleep I got in years."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutInsomnia01"
    }
    {
      Id = "MelinoeField_0322"
      InheritFrom = "BaseNarrative"
      DisplayName = "Is that so? Well it would be even easier for me to knock you out cold if you didn't fight back."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutInsomnia01"
    }
    {
      Id = "Polyphemus_0143"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Eh{#Prev}, the fight's what does the trick. I don't give it my all, I don't get that deep relaxing slumber afterwards. Or the opportunity to get a hearty meal."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutInsomnia01"
    }
    {
      Id = "MelinoeField_0323"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know, if you've been having trouble sleeping, there's got to be a better solution than these repeated drubbings from me."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutInsomnia02"
    }
    {
      Id = "Polyphemus_0144"
      InheritFrom = "BaseNarrative"
      DisplayName = "I tried a lot of stuff. Sleeping on a full stomach, sleeping on an empty stomach. Nothing worked, but this? This works just fine for now..."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutInsomnia02"
    }
    {
      Id = "Polyphemus_0145"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Sniff> {#Prev}I smell {#Emph}blood. {#Prev}I was just getting ready to prepare my next meal... but the town welcoming committee must have prepped you already."
      Speaker = "Polyphemus"
      Event = "PolyphemusLowHealth01"
    }
    {
      Id = "MelinoeField_0324"
      InheritFrom = "BaseNarrative"
      DisplayName = "The {#Emph}welcoming committee{#Prev}, as you call it, are servants of Chronos... and shall suffer for their arrogance. You would cast your lot with {#Emph}them?"
      Speaker = "Melinoe"
      Event = "PolyphemusLowHealth01"
    }
    {
      Id = "Polyphemus_0146"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know, I used to have a little trouble eating food that looked back at me, or talked back at me. But I don't got that problem no more."
      Speaker = "Polyphemus"
      Event = "PolyphemusLowHealth01"
    }
    {
      Id = "Polyphemus_0147"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ooh, {#Prev}I can tell the town welcoming committee must have done a number on you already. Softened you up {#Emph}good. {#Prev}All the better for {#Emph}me."
      Speaker = "Polyphemus"
      Event = "PolyphemusLowHealth02"
    }
    {
      Id = "MelinoeField_0325"
      InheritFrom = "BaseNarrative"
      DisplayName = "The city's filled with the unburied dead. I can slay them but they merely rise again; they're very troublesome. The same as you."
      Speaker = "Melinoe"
      Event = "PolyphemusLowHealth02"
    }
    {
      Id = "Polyphemus_0148"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now don't you get testy. This is {#Emph}my {#Prev}pasture not yours. And every little sheep around here answers to {#Emph}me."
      Speaker = "Polyphemus"
      Event = "PolyphemusLowHealth02"
    }
    {
      Id = "Polyphemus_0115"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Wow! {#Prev}Just when I thought I had you last time, you gave me the slip. Didn't think I'd get another shot."
      Speaker = "Polyphemus"
      Event = "PolyphemusLostAgainstHim01"
    }
    {
      Id = "MelinoeField_0305"
      InheritFrom = "BaseNarrative"
      DisplayName = "You'll soon have many more such {#Emph}shots. {#Prev}But you're going to fail every time, I promise you."
      Speaker = "Melinoe"
      Event = "PolyphemusLostAgainstHim01"
    }
    {
      Id = "Polyphemus_0116"
      InheritFrom = "BaseNarrative"
      DisplayName = "How 'bout you promise me the {#Emph}meat on your bones. {#Prev}Though I get the feeling you don't got much to offer."
      Speaker = "Polyphemus"
      Event = "PolyphemusLostAgainstHim01"
    }
    {
      Id = "Polyphemus_0117"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't like playing with my food. Like it even less when my food plays with {#Emph}me. {#Prev}I'm on to that disappearing act of yours."
      Speaker = "Polyphemus"
      Event = "PolyphemusLostAgainstHim02"
    }
    {
      Id = "MelinoeField_0306"
      InheritFrom = "BaseNarrative"
      DisplayName = "I am a deathless goddess of the Underworld; the shadows will always take me before you will. Yet you would fight me endlessly anyway?"
      Speaker = "Melinoe"
      Event = "PolyphemusLostAgainstHim02"
    }
    {
      Id = "Polyphemus_0118"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh yeah! Everybody slips up once in a while. Even you. And when you do... we'll find out just how {#Emph}deathless {#Prev}you are."
      Speaker = "Polyphemus"
      Event = "PolyphemusLostAgainstHim02"
    }
    {
      Id = "Polyphemus_0283"
      InheritFrom = "BaseNarrative"
      DisplayName = "Almost got me last time, but not quite. Come to finish the job? You wouldn't be the first to try. But I'm still here, and you don't see anybody else around, do ya?"
      Speaker = "Polyphemus"
      Event = "PolyphemusBarelyLostAgainstHim01"
    }
    {
      Id = "MelinoeField_1946"
      InheritFrom = "BaseNarrative"
      DisplayName = "Finish {#Emph}what {#Prev}job? You're not my mark. I'd just as soon slip past you and be on my way, except your blasted sense of smell and hearing are too good."
      Speaker = "Melinoe"
      Event = "PolyphemusBarelyLostAgainstHim01"
    }
    {
      Id = "Polyphemus_0284"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why, thanks. And you know how I keep 'em top-notch like this, don't ya? When you got gifts like these, you gotta put 'em to good use."
      Speaker = "Polyphemus"
      Event = "PolyphemusBarelyLostAgainstHim01"
    }
    {
      Id = "Polyphemus_0111"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, {#Emph}hey! {#Prev}I wanted to say thanks. Gave me a real zinger there last time, you know that?"
      Speaker = "Polyphemus"
      Event = "PolyphemusWonAgainstHim01"
    }
    {
      Id = "Melinoe_0938"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're back. And you're grateful that I vanquished you earlier? You seem more the sort to hold a grudge."
      Speaker = "Melinoe"
      Event = "PolyphemusWonAgainstHim01"
    }
    {
      Id = "Polyphemus_0112"
      InheritFrom = "BaseNarrative"
      DisplayName = "I am, I am, it's just... I hadn't had a good night's sleep in I-don't-know-how-long. After you knocked me out cold, I woke up feeling more refreshed than ever! And real hungry, too."
      Speaker = "Polyphemus"
      Event = "PolyphemusWonAgainstHim01"
    }
    {
      Id = "Polyphemus_0113"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Tsch! {#Prev}Don't even try and sneak by. What, you think you were gonna catch me napping here? Not gonna happen."
      Speaker = "Polyphemus"
      Event = "PolyphemusWonAgainstHim02"
    }
    {
      Id = "Melinoe_0939"
      InheritFrom = "BaseNarrative"
      DisplayName = "It might. If you keep blocking my path, you'll get another thrashing, and you'll be sound asleep again in no time. That what you want?"
      Speaker = "Melinoe"
      Event = "PolyphemusWonAgainstHim02"
    }
    {
      Id = "Polyphemus_0114"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh! Got a dilemma on my hands! I'm always sleepy, yeah. But I'm always hungry, too. Guess that makes this a {#Emph}can't-lose proposition."
      Speaker = "Polyphemus"
      Event = "PolyphemusWonAgainstHim02"
    }
    {
      Id = "Polyphemus_0447"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know when somethin's off, and somethin's off. What are you up to, {#Emph}meat? {#Prev}Other than getting caught by me like every other time you tried to sneak through here."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutPackagedBounties01"
    }
    {
      Id = "MelinoeField_3160"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh I'm not sneaking; in fact I'm here for {#Emph}you {#Prev}this time, Cyclops. The Origin of All Existence is interested to see if I have what it takes to lay you to rest."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutPackagedBounties01"
    }
    {
      Id = "Polyphemus_0448"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Origin of All Existence...? {#Prev}You took a job to take me out, {#Emph}that's {#Prev}what I'm hearing from you? Well, you wouldn't be the first to try it. Now let me {#Emph}demonstrate {#Prev}what happened to the rest."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutPackagedBounties01"
    }
    {
      Id = "Polyphemus_0449"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh hey! The Origin of All Existence wanted me to let you know, you're just not cuttin' it. And the whole deal is off. I also get to eat you now."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutPackagedBounties02"
    }
    {
      Id = "MelinoeField_3161"
      InheritFrom = "BaseNarrative"
      DisplayName = "I find it exceedingly difficult to believe that Primordial Chaos would have been in contact with {#Emph}you {#Prev}about such matters. Easier to believe this is all part of the current Trial."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutPackagedBounties02"
    }
    {
      Id = "Polyphemus_0450"
      InheritFrom = "BaseNarrative"
      DisplayName = "If this is all part of some {#Emph}Trial{#Prev}, that makes me the judge. And I hereby declare you're {#Emph}dinner. {#Prev}That is unless {#Emph}you {#Prev}or your pal {#Emph}Primordial Chaos {#Prev}plan to do somethin' about it."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutPackagedBounties02"
    }
    {
      Id = "Polyphemus_0451"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hairs on the back of my neck all standin' up, and not 'cause of {#Emph}you. {#Prev}Or maybe it is, but... it's like I got a {#Emph}mark {#Prev}on me. Not had this feeling in a while."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutShrine01"
    }
    {
      Id = "MelinoeField_3162"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nothing personal, Cyclops. But the Testament of Night requires your defeat. You needn't concern yourself with the inner workings of it, so how about we just fight."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutShrine01"
    }
    {
      Id = "Polyphemus_0452"
      InheritFrom = "BaseNarrative"
      DisplayName = "Testament of {#Emph}what? {#Prev}I didn't get a damn word you said at the beginnin' there, but you got me on board at {#Emph}just fight!{#Prev}"
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutShrine01"
    }
    {
      Id = "Polyphemus_0453"
      InheritFrom = "BaseNarrative"
      DisplayName = "So you can mess with how things work at night? Between the feeling in my gut and the nonsense you've been talkin', I can tell you've been up to no good. You some kind of {#Emph}witch?"
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutShrine02"
    }
    {
      Id = "MelinoeField_3163"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lady Medea isn't the only one to practice around here. Since you're finally wising up to our true strength, know that you violate the will of Night herself by standing in my way."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutShrine02"
    }
    {
      Id = "Polyphemus_0454"
      InheritFrom = "BaseNarrative"
      DisplayName = "See, there you go again with all the fancy talk. But hey, I could go for a fancy meal just as soon as a tough piece of meat! Maybe you're both."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutShrine02"
    }
    {
      Id = "MelinoeField_3163_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "Since you're finally wising up to our true strength, know that you violate the will of Night herself by standing in my way."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutShrine02_B"
    }
    {
      Id = "MelinoeField_4123"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your service to the Titan Chronos is complete, Cyclops! His war against Olympus is ended if you've not already heard. I hold no enmity toward you. Be on your way!"
      Speaker = "Melinoe"
      Event = "PolyphemusPostTrueEnding01"
    }
    {
      Id = "Polyphemus_0493"
      InheritFrom = "BaseNarrative"
      DisplayName = "I was just wondering how come I haven't gotten paid. Thought maybe my shepherding hasn't been up to snuff."
      Speaker = "Polyphemus"
      Event = "PolyphemusPostTrueEnding01"
    }
    {
      Id = "MelinoeField_4124"
      InheritFrom = "BaseNarrative"
      DisplayName = "Chronos was compensating you for {#Emph}tending sheep? {#Prev}I thought you were supposed to be guarding the city gates."
      Speaker = "Melinoe"
      Event = "PolyphemusPostTrueEnding01"
    }
    {
      Id = "Polyphemus_0494"
      InheritFrom = "BaseNarrative"
      DisplayName = "What do you even know about it. You really think I'm gonna leave my flock now, after all we've been through? And I can always earn my meal ticket some other way."
      Speaker = "Polyphemus"
      Event = "PolyphemusPostTrueEnding01"
    }
    {
      Id = "MelinoeField_4125"
      InheritFrom = "BaseNarrative"
      DisplayName = "I see you decided not to act on my prior recommendation, for the good of your flock, whose sheep you often eat. For how much longer do you plan to bar me from the Rift?"
      Speaker = "Melinoe"
      Event = "PolyphemusPostTrueEnding02"
    }
    {
      Id = "Polyphemus_0495"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thinking it might be a while. Got my flock, got my barn, been sleeping better lately... and having to uproot? Settle someplace else? Packing, and unpacking, I don't want any of that."
      Speaker = "Polyphemus"
      Event = "PolyphemusPostTrueEnding02"
    }
    {
      Id = "MelinoeField_4126"
      InheritFrom = "BaseNarrative"
      DisplayName = "How fortunate you've made yourself such a comfortable arrangement that happens to be right in my blasted way."
      Speaker = "Melinoe"
      Event = "PolyphemusPostTrueEnding02"
    }
    {
      Id = "Polyphemus_0496"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Aw{#Prev}, that's just another perk: I even get my nightly exercise."
      Speaker = "Polyphemus"
      Event = "PolyphemusPostTrueEnding02"
    }
    {
      Id = "Polyphemus_0522"
      InheritFrom = "BaseNarrative"
      DisplayName = "How come you said whatever war is over, {#Emph}huh? {#Prev}The town's about the same. Last I checked the dead are meant to be underground, not walking through the streets."
      Speaker = "Polyphemus"
      Event = "PolyphemusPostTrueEnding03"
    }
    {
      Id = "MelinoeField_4360"
      InheritFrom = "BaseNarrative"
      DisplayName = "The war with Chronos is over, it's just... there are a few remaining details being sorted out, and the Underworld is in enough of a state of disrepair that it isn't back in order yet."
      Speaker = "Melinoe"
      Event = "PolyphemusPostTrueEnding03"
    }
    {
      Id = "Polyphemus_0523"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Aw{#Prev}, that's too bad. I'd tell you to go down there and help 'em out, but that might cut into my sleep routine, which has been pretty good lately. Now come on, it's almost bedtime here."
      Speaker = "Polyphemus"
      Event = "PolyphemusPostTrueEnding03"
    }
    {
      Id = "MelinoeField_4361"
      InheritFrom = "BaseNarrative"
      DisplayName = "For all these nights we've fought, you don't even know my name, do you, Cyclops? I'm still nothing but a piece of meat."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutMeat01"
    }
    {
      Id = "Polyphemus_0524"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, you said it, not me. Besides, it's not like {#Emph}I'm {#Prev}the one stomping in here, frightening my sheep... well no I guess I do some of the time, but still."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutMeat01"
    }
    {
      Id = "Polyphemus_0528"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not heard you show up in a while! Glad you're back. Been gone so long it's really been eatin' into my sleep schedule."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutSleep01"
    }
    {
      Id = "MelinoeField_4364"
      InheritFrom = "BaseNarrative"
      DisplayName = "For a moment there, I thought you were genuinely pleased at my return. But you just want me to render you unconscious."
      Speaker = "Melinoe"
      Event = "PolyphemusAboutSleep01"
    }
    {
      Id = "Polyphemus_0529"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yeah. That or stand still long enough for me to eat you up. But you don't seem interested in that, so I'll just go for the unconscious thing. I'm easy to please."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutSleep01"
    }
    {
      Id = "MelinoeField_4362"
      InheritFrom = "BaseNarrative"
      DisplayName = "This isn't going to last, you know, Cyclops. At some point, the City of Ephyra shall be rebuilt. Its streets will be teeming with mortals, the docks bustling with seafarers... rather than this."
      Speaker = "Melinoe"
      Event = "PolyphemusPostEpilogue01"
    }
    {
      Id = "Polyphemus_0525"
      InheritFrom = "BaseNarrative"
      DisplayName = "What are you, an oracle or somethin'? If they try and put the town back together, great. More meat for me whenever I want! You'll have to do for now."
      Speaker = "Polyphemus"
      Event = "PolyphemusPostEpilogue01"
    }
    {
      Id = "Polyphemus_0526"
      InheritFrom = "BaseNarrative"
      DisplayName = "Been finding if I talk too much, it messes with my sleep. Maybe we ought to cut with the chat and go straight to it. But I don't mean to be rude, so you... got any last words, meat?"
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutSayingLittle01"
    }
    {
      Id = "MelinoeField_4363"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Certainly, my last words are: You're never going to eat me, and you're never going to stop me, but you're welcome to keep trying, and cheers for all the Wool!"
      Speaker = "Melinoe"
      Event = "PolyphemusAboutSayingLittle01"
    }
    {
      Id = "Polyphemus_0527"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wait, hold on... so {#Emph}you're {#Prev}the one who's been stealing all my Wool this whole time? {#Emph}Aw{#Prev}, now that {#Emph}does {#Prev}it..."
      Speaker = "Polyphemus"
      Event = "PolyphemusAboutSayingLittle01"
    }
    {
      Id = "Polyphemus_0013"
      InheritFrom = "BaseNarrative"
      DisplayName = "Stepped out of line {#Emph}again{#Prev}, little sheep. You know what happens next."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart01"
    }
    {
      Id = "Polyphemus_0014"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Sniff> {#Prev}Somethin' stinks... oh I know what it is. It's {#Emph}you."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart02"
    }
    {
      Id = "Polyphemus_0015"
      InheritFrom = "BaseNarrative"
      DisplayName = "No sneaking past my sheep. No sneaking past me, neither."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart03"
    }
    {
      Id = "Polyphemus_0016"
      InheritFrom = "BaseNarrative"
      DisplayName = "One of these nights... I'm gonna catch you. And I'm gonna eat you."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart04"
    }
    {
      Id = "Polyphemus_0017"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's a little early for my dinnertime, but hey! I can be flexible."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart05"
    }
    {
      Id = "Polyphemus_0018"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Phew! {#Prev}Know I could smell you from a league away?"
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart06"
    }
    {
      Id = "Polyphemus_0019"
      InheritFrom = "BaseNarrative"
      DisplayName = "You just don't know what's good for you, do you?"
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart07"
    }
    {
      Id = "Polyphemus_0020"
      InheritFrom = "BaseNarrative"
      DisplayName = "You want some more of this, that's fine by me. Oh, I got plenty."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart08"
    }
    {
      Id = "Polyphemus_0021"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't normally like eating my food raw. But then, I like to try new stuff."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart09"
    }
    {
      Id = "Polyphemus_0022"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Shh! {#Prev}Think I heard somethin'. You hear it, right? The dinner bell..."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart10"
    }
    {
      Id = "Polyphemus_0149"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, what do you know? It's dinnertime already..."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart11"
    }
    {
      Id = "Polyphemus_0150"
      InheritFrom = "BaseNarrative"
      DisplayName = "All this shepherding all day works up a real appetite..."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart12"
    }
    {
      Id = "Polyphemus_0151"
      InheritFrom = "BaseNarrative"
      DisplayName = "Welcome back to the flock, little sheep. Now, come 'ere..."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart13"
    }
    {
      Id = "Polyphemus_0152"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got myself a good night's rest, but not enough to eat..."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart14"
    }
    {
      Id = "Polyphemus_0153"
      InheritFrom = "BaseNarrative"
      DisplayName = "You want to get to those docks, I want to eat you. Just the way it is."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart15"
    }
    {
      Id = "Polyphemus_0154"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do remember to watch for falling rocks in this town."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart16"
    }
    {
      Id = "Polyphemus_0155"
      InheritFrom = "BaseNarrative"
      DisplayName = "Here comes some {#Emph}dead meat{#Prev}, fresh from out of town..."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart17"
    }
    {
      Id = "Polyphemus_0156"
      InheritFrom = "BaseNarrative"
      DisplayName = "I really got to do somethin' about that wall you keep on getting through..."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart18"
    }
    {
      Id = "Polyphemus_0157"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're back for some more shepherding, huh, little sheep?"
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart19"
    }
    {
      Id = "Polyphemus_0158"
      InheritFrom = "BaseNarrative"
      DisplayName = "No one gets in this town, no one gets out; those are the rules."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart20"
    }
    {
      Id = "Polyphemus_0159"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got to hand it to ya. I've been sleeping like a baby lately over here."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart21"
    }
    {
      Id = "Polyphemus_0160"
      InheritFrom = "BaseNarrative"
      DisplayName = "After a hard day's shepherding, I could go for a good knock-out about now."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart22"
    }
    {
      Id = "Polyphemus_0161"
      InheritFrom = "BaseNarrative"
      DisplayName = "Even if I can't eat you, least I'll get some decent sleep here in a bit."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart23"
    }
    {
      Id = "Polyphemus_0162"
      InheritFrom = "BaseNarrative"
      DisplayName = "Guess it's almost my bedtime. But first, a little bit of exercise..."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart24"
    }
    {
      Id = "Polyphemus_0321"
      InheritFrom = "BaseNarrative"
      DisplayName = "Kick you right into the Moon right now if I could see the thing."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart25"
    }
    {
      Id = "Polyphemus_0322"
      InheritFrom = "BaseNarrative"
      DisplayName = "Really want to get stomped on some more, I'm good for it."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart26"
    }
    {
      Id = "Polyphemus_0323"
      InheritFrom = "BaseNarrative"
      DisplayName = "You want to end up like my sheep, you keep this up."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart27"
    }
    {
      Id = "Polyphemus_0324"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ohh{#Prev}, you just wait'll I get these hands on {#Emph}you."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart28"
    }
    {
      Id = "Polyphemus_0325"
      InheritFrom = "BaseNarrative"
      DisplayName = "Little early for my dinnertime, but then, I shouldn't eat so late."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart29"
    }
    {
      Id = "Polyphemus_0326"
      InheritFrom = "BaseNarrative"
      DisplayName = "You step onto my turf, you pay the price, that's just the rules."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart30"
    }
    {
      Id = "Polyphemus_0530"
      InheritFrom = "BaseNarrative"
      DisplayName = "Last time you knocked me out so fast, got the best sleep I had in a while!"
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart31"
    }
    {
      Id = "Polyphemus_0531"
      InheritFrom = "BaseNarrative"
      DisplayName = "Didn't even get a piece of you last time, but you can't get away forever..."
      Speaker = "Polyphemus"
      Event = "PolyphemusMiscStart32"
    }
    {
      Id = "Medea_0603"
      InheritFrom = "BaseNarrative"
      DisplayName = "You bear my favored Aspect of Revaal! The Cyclops truly is in for it now."
      Speaker = "Medea"
      Event = "MedeaMiscStart01"
    }
    {
      Id = "Medea_0604"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Aspect of the Goddess Hel... I shall enjoy bearing witness to her power."
      Speaker = "Medea"
      Event = "MedeaMiscStart02"
    }
    {
      Id = "Medea_0605"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Moon is full and getting in my eyes... on such an eve, I envy you, Lord Polyphemus."
      Speaker = "Medea"
      Event = "MedeaMiscStart03"
    }
    {
      Id = "Medea_0606"
      InheritFrom = "BaseNarrative"
      DisplayName = "I was right in the middle of a new concoction, but I'd abandon {#Emph}anything {#Prev}for {#Emph}this."
      Speaker = "Medea"
      Event = "MedeaMiscStart04"
    }
    {
      Id = "Medea_0607"
      InheritFrom = "BaseNarrative"
      DisplayName = "There really is quite a distinct aroma here, between the corpses and the shepherd's flock..."
      Speaker = "Medea"
      Event = "MedeaMiscStart05"
    }
    {
      Id = "Medea_0370"
      InheritFrom = "BaseNarrative"
      DisplayName = "My poisons are for mortal use, but also work on goddesses."
      Speaker = "Medea"
      Event = "MedeaMiscStart06"
    }
    {
      Id = "Medea_0351"
      InheritFrom = "BaseNarrative"
      DisplayName = "Let's have another brush with death now, sorceress."
      Speaker = "Medea"
      Event = "MedeaMiscStart07"
    }
    {
      Id = "Medea_0352"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come demonstrate to us your knowledge of the necromantic arts."
      Speaker = "Medea"
      Event = "MedeaMiscStart08"
    }
    {
      Id = "Medea_0353"
      InheritFrom = "BaseNarrative"
      DisplayName = "Great Hecate requires me to test your wherewithal, if you would be so kind?"
      Speaker = "Medea"
      Event = "MedeaMiscStart09"
    }
    {
      Id = "Medea_0354"
      InheritFrom = "BaseNarrative"
      DisplayName = "I shall not hesitate to draw some of your blood here, sorceress."
      Speaker = "Medea"
      Event = "MedeaMiscStart10"
    }
    {
      Id = "Medea_0355"
      InheritFrom = "BaseNarrative"
      DisplayName = "All my research has made me welcome this as a refreshing change of pace."
      Speaker = "Medea"
      Event = "MedeaMiscStart11"
    }
    {
      Id = "Medea_0356"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps I have {#Emph}already {#Prev}cursed you, sorceress! Let's see you break the spell."
      Speaker = "Medea"
      Event = "MedeaMiscStart12"
    }
    {
      Id = "Medea_0357"
      InheritFrom = "BaseNarrative"
      DisplayName = "Careful, lest I cut that tender throat of yours like that of a mewling babe."
      Speaker = "Medea"
      Event = "MedeaMiscStart13"
    }
    {
      Id = "Medea_0358"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sacrifices must be made on nights such as this. Yours or mine ought to suffice."
      Speaker = "Medea"
      Event = "MedeaMiscStart14"
    }
    {
      Id = "Medea_0359"
      InheritFrom = "BaseNarrative"
      DisplayName = "As blood is shortly to be drawn, rest easy knowing not one drop shall go to waste."
      Speaker = "Medea"
      Event = "MedeaMiscStart15"
    }
    {
      Id = "Medea_0360"
      InheritFrom = "BaseNarrative"
      DisplayName = "Know that your youth does not entitle you to mercy, sorceress."
      Speaker = "Medea"
      Event = "MedeaMiscStart16"
    }
    {
      Id = "Medea_0361"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come, sorceress! Seek vengeance now for what we did to you before..."
      Speaker = "Medea"
      Event = "MedeaMiscStart17"
    }
    {
      Id = "Medea_0362"
      InheritFrom = "BaseNarrative"
      DisplayName = "I heed the summons of the will of Night. Indeed, I'm more than happy to oblige."
      Speaker = "Medea"
      Event = "MedeaMiscStart18"
    }
    {
      Id = "Medea_0363"
      InheritFrom = "BaseNarrative"
      DisplayName = "You spoke the Vow of Rivals, so as mortals sometimes say: {#Emph}You asked for this."
      Speaker = "Medea"
      Event = "MedeaMiscStart19"
    }
    {
      Id = "Medea_0364"
      InheritFrom = "BaseNarrative"
      DisplayName = "My craft can kill most anything in moments, but not {#Emph}you. {#Prev}It may prove quite unpleasant though."
      Speaker = "Medea"
      Event = "MedeaMiscStart20"
    }
    {
      Id = "Medea_0365"
      InheritFrom = "BaseNarrative"
      DisplayName = "How is it that you're so resistant to my curses, sorceress...?"
      Speaker = "Medea"
      Event = "MedeaMiscStart21"
    }
    {
      Id = "Medea_0366"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Well, Lord Polyphemus. Perhaps we might catch up some more some other eve."
      Speaker = "Medea"
      Event = "MedeaMiscStart22"
    }
    {
      Id = "Medea_0367"
      InheritFrom = "BaseNarrative"
      DisplayName = "When you invoke the will of Night, you'd best not flinch."
      Speaker = "Medea"
      Event = "MedeaMiscStart23"
    }
    {
      Id = "Polyphemus_0085"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...so... fluffy..."
      Speaker = "Polyphemus"
      Event = "PolyphemusCorpse.OnHitVoiceLines"
    }
    {
      Id = "Polyphemus_0086"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...that... {#Emph}hmhm... {#Prev}tickles..."
      Speaker = "Polyphemus"
      Event = "PolyphemusCorpse.OnHitVoiceLines"
    }
    {
      Id = "Polyphemus_0087"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...my... sheep..."
      Speaker = "Polyphemus"
      Event = "PolyphemusCorpse.OnHitVoiceLines"
    }
    {
      Id = "Polyphemus_0088"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...so... tired..."
      Speaker = "Polyphemus"
      Event = "PolyphemusCorpse.OnHitVoiceLines"
    }
    {
      Id = "Polyphemus_0186"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...{#Emph}n'huh... huh..."
      Speaker = "Polyphemus"
      Event = "PolyphemusCorpse.OnHitVoiceLines"
    }
    {
      Id = "Polyphemus_0187"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...still... sleeping... here..."
      Speaker = "Polyphemus"
      Event = "PolyphemusCorpse.OnHitVoiceLines"
    }
    {
      Id = "Polyphemus_0188"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...not... now... Pop..."
      Speaker = "Polyphemus"
      Event = "PolyphemusCorpse.OnHitVoiceLines"
    }
    {
      Id = "Polyphemus_0189"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...be... up... soon..."
      Speaker = "Polyphemus"
      Event = "PolyphemusCorpse.OnHitVoiceLines"
    }
    {
      Id = "Polyphemus_0439"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...don't go anywhere... sheep..."
      Speaker = "Polyphemus"
      Event = "PolyphemusCorpse.OnHitVoiceLines"
    }
    {
      Id = "Polyphemus_0443"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...be up... in a minute..."
      Speaker = "Polyphemus"
      Event = "PolyphemusCorpse.OnHitVoiceLines"
    }
    {
      Id = "Polyphemus_0444"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...{#Emph}ah... {#Prev}that's... good..."
      Speaker = "Polyphemus"
      Event = "PolyphemusCorpse.OnHitVoiceLines"
    }
    {
      Id = "Polyphemus_0440"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...three sheep... four sheep... five..."
      Speaker = "Polyphemus"
      Event = "PolyphemusCorpse.OnHitVoiceLines"
    }
    {
      Id = "Polyphemus_0441"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...seven sheep... eight sheep... nine..."
      Speaker = "Polyphemus"
      Event = "PolyphemusCorpse.OnHitVoiceLines"
    }
    {
      Id = "Polyphemus_0442"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...ten sheep... {#Emph}uhhh... {#Prev}one sheep... two..."
      Speaker = "Polyphemus"
      Event = "PolyphemusCorpse.OnHitVoiceLines"
    }
    {
      Id = "Polyphemus_0510"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Look I only had a {#Emph}couple {#Prev}here and there..."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Medea_0337"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's {#Emph}you..."
      Speaker = "Medea"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Medea_0338"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm here...!"
      Speaker = "Medea"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Medea_0339"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sorceress..."
      Speaker = "Medea"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Medea_0340"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ah, yes."
      Speaker = "Medea"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Medea_0341"
      InheritFrom = "BaseNarrative"
      DisplayName = "Cyclops."
      Speaker = "Medea"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Medea_0344"
      InheritFrom = "BaseNarrative"
      DisplayName = "By will of Night."
      Speaker = "Medea"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Medea_0345"
      InheritFrom = "BaseNarrative"
      DisplayName = "We're all here."
      Speaker = "Medea"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Medea_0346"
      InheritFrom = "BaseNarrative"
      DisplayName = "Good evening, you two."
      Speaker = "Medea"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Medea_0347"
      InheritFrom = "BaseNarrative"
      DisplayName = "Shall we...?"
      Speaker = "Medea"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Medea_0348"
      InheritFrom = "BaseNarrative"
      DisplayName = "Such a night..."
      Speaker = "Medea"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Medea_0343"
      InheritFrom = "BaseNarrative"
      DisplayName = "My lord."
      Speaker = "Medea"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Medea_0342"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lord Polyphemus."
      Speaker = "Medea"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Medea_0349"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Moon is full..."
      Speaker = "Medea"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Medea_0350"
      InheritFrom = "BaseNarrative"
      DisplayName = "A new moon..."
      Speaker = "Medea"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "MelinoeField_0529"
      InheritFrom = "BaseNarrative"
      DisplayName = "Polyphemus!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "MelinoeField_0530"
      InheritFrom = "BaseNarrative"
      DisplayName = "Polyphemus..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Melinoe_1451"
      InheritFrom = "BaseNarrative"
      DisplayName = "You heard that, didn't you..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Melinoe_1452"
      InheritFrom = "BaseNarrative"
      DisplayName = "Did you enjoy your nap?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0468"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh there she is."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0099"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Sniff> Hrm."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0100"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got to be kidding."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0101"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hi!"
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0102"
      InheritFrom = "BaseNarrative"
      DisplayName = "Really."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0103"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're no sheep."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0104"
      InheritFrom = "BaseNarrative"
      DisplayName = "What is it now?"
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0105"
      InheritFrom = "BaseNarrative"
      DisplayName = "You again."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0106"
      InheritFrom = "BaseNarrative"
      DisplayName = "You {#Emph}again?"
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0107"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh great."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0108"
      InheritFrom = "BaseNarrative"
      DisplayName = "Somebody's there..."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0109"
      InheritFrom = "BaseNarrative"
      DisplayName = "Heard you were back..."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0110"
      InheritFrom = "BaseNarrative"
      DisplayName = "Who? {#Emph}Ohh..."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0192"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hold it."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0193"
      InheritFrom = "BaseNarrative"
      DisplayName = "I {#Emph}see {#Prev}you."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0194"
      InheritFrom = "BaseNarrative"
      DisplayName = "Heard you were in town."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0195"
      InheritFrom = "BaseNarrative"
      DisplayName = "Chow time..."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0196"
      InheritFrom = "BaseNarrative"
      DisplayName = "A dinner guest..."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0197"
      InheritFrom = "BaseNarrative"
      DisplayName = "Let me guess..."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0198"
      InheritFrom = "BaseNarrative"
      DisplayName = "We doing this?"
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0199"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, good."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0349"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Sniff> Ahh..."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0350"
      InheritFrom = "BaseNarrative"
      DisplayName = "Company..."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0351"
      InheritFrom = "BaseNarrative"
      DisplayName = "Here, sheepie..."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0352"
      InheritFrom = "BaseNarrative"
      DisplayName = "Where you going?"
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0353"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hold up."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0354"
      InheritFrom = "BaseNarrative"
      DisplayName = "Slow down."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0355"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wouldn't you know it."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0356"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Tsch. Hrm."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
    {
      Id = "Polyphemus_0357"
      InheritFrom = "BaseNarrative"
      DisplayName = "Step right up."
      Speaker = "Polyphemus"
      Event = "GlobalVoiceLines.PolyphemusGreetingLines"
    }
