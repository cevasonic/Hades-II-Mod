      DisplayName = "Ygnium..."
      Speaker = "Nyx"
      Event = "NPC_Nyx_Story_01.OnHitVoiceLines"
    }
    {
      Id = "Nyx_0104"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Zorephet..."
      Speaker = "Nyx"
      Event = "NPC_Nyx_Story_01.OnHitVoiceLines"
    }
    {
      Id = "Nyx_0105"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Revaal..."
      Speaker = "Nyx"
      Event = "NPC_Nyx_Story_01.OnHitVoiceLines"
    }
    {
      Id = "Nyx_0106"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Xinth..."
      Speaker = "Nyx"
      Event = "NPC_Nyx_Story_01.OnHitVoiceLines"
    }
    {
      Id = "Nyx_0042"
      InheritFrom = "BaseNarrative"
      DisplayName = "How unusual to see you here. My great ancestor and I have much to discuss, and shall resume after you take your leave."
      Speaker = "Nyx"
      Event = "NyxInChaos01"
    }
    {
      Id = "MelinoeField_4234"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh... forgive my rudeness having interrupted. Shall you come visit us at the Crossroads again soon, O Night?"
      Speaker = "Melinoe"
      Event = "NyxInChaos01"
    }
    {
      Id = "Nyx_0043"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sporadic visits are a possibility, especially after the House of Hades is entirely restored. Although my wish is for my children to be wholly independent of my influence."
      Speaker = "Nyx"
      Event = "NyxInChaos01"
    }
    {
      Id = "MelinoeField_4235"
      InheritFrom = "BaseNarrative"
      DisplayName = "Many mothers must feel the same way."
      Speaker = "Melinoe"
      Event = "NyxInChaos01"
    }
    {
      Id = "Nyx_0044"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I do not know their feelings, only mine."
      Speaker = "Nyx"
      Event = "NyxInChaos01"
    }
    {
      Id = "Nyx_0045"
      InheritFrom = "BaseNarrative"
      DisplayName = "Chaos typically avoids involvement in matters concerning the Underworld or the surface realms, so this was an exception. At some point we grew closer as a family, perhaps because we learned from yours."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutChaos01"
    }
    {
      Id = "MelinoeField_4669"
      InheritFrom = "BaseNarrative"
      DisplayName = "My family always seems to be on the verge of falling apart. This ordeal may have strengthened our bonds, but... sometimes I fear they shall not hold forever."
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutChaos01"
    }
    {
      Id = "Nyx_0046"
      InheritFrom = "BaseNarrative"
      DisplayName = "Weakened bonds may be reforged. That is the reason I am here with Chaos, to start with the eldest of my kin, and work my way down... a lengthy process, but a necessary one."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutChaos01"
    }
    {
      Id = "MelinoeField_4670"
      InheritFrom = "BaseSubtitle"
      DisplayName = "To a successful outcome."
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutChaos01"
    }
    {
      Id = "Nyx_0124"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have many children, but your mother the Queen, she does not. Therefore it saddens me that she was not available to witness your initial growth. Yet I am pleased that we remember a happier possibility."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutPersephone01"
    }
    {
      Id = "MelinoeField_5176"
      InheritFrom = "BaseNarrative"
      DisplayName = "We're back in one another's lives, and share some wonderful memories... I couldn't ask for much more. Queen Persephone must be fortunate to have guidance from the most experienced mother that the world has ever known!"
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutPersephone01"
    }
    {
      Id = "Nyx_0048"
      InheritFrom = "BaseNarrative"
      DisplayName = "It is a learning process even still, though I impart what knowledge I possess. But your mother's intuition for it often is superior to mine."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutPersephone01"
    }
    {
      Id = "MelinoeField_4672"
      InheritFrom = "BaseNarrative"
      DisplayName = "I look forward to getting to know her better myself. Have the two of you always been close?"
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutPersephone01"
    }
    {
      Id = "Nyx_0049"
      InheritFrom = "BaseNarrative"
      DisplayName = "Always is a long time. Though, Queen Persephone and I, we have been close since prior to your brother's birth, and ever since."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutPersephone01"
    }
    {
      Id = "MelinoeField_4673"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thank you for looking out for her."
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutPersephone01"
    }
    {
      Id = "Nyx_0050"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I always shall."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutPersephone01"
    }
    {
      Id = "Nyx_0057"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know, perhaps, I once presided solely over all the Underworld. There came a point when this exceeded my ability, and so my daughters the Three Fates selected someone to assist with governing the realm: Your father."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutHades01"
    }
    {
      Id = "MelinoeField_4677"
      InheritFrom = "BaseNarrative"
      DisplayName = "That was when he split off from his own brothers and foster-sisters... who became the Olympians. It must have been a turbulent time."
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutHades01"
    }
    {
      Id = "Nyx_0058"
      InheritFrom = "BaseNarrative"
      DisplayName = "It was a time of change. I did not expect for Hades to take to his role as readily, for it was difficult. Or for Persephone to bring life to this place in a welcome way. And now {#Emph}you {#Prev}and your brother... the realm is better off because of you."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutHades01"
    }
    {
      Id = "MelinoeField_4678"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thank you, O Nyx."
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutHades01"
    }
    {
      Id = "Nyx_0052"
      InheritFrom = "BaseNarrative"
      DisplayName = "You bear my Aspect of the Black Coat. Long has it been since I last wielded it myself. I solve most conflicts indirectly now, but I do think at times about the power of Xinth."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutNyxAspect01"
    }
    {
      Id = "MelinoeField_4674"
      InheritFrom = "BaseNarrative"
      DisplayName = "I am deeply honored to have been entrusted with that power, O Night. Most of the conflicts {#Emph}I've {#Prev}encountered recently... only direct approaches seemed to work."
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutNyxAspect01"
    }
    {
      Id = "Nyx_0053"
      InheritFrom = "BaseNarrative"
      DisplayName = "I understand how that may be, or how it may appear. Thus far, the six Nocturnal Arms have served us well. When I myself could not safeguard the realm, they did."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutNyxAspect01"
    }
    {
      Id = "Nyx_0055"
      InheritFrom = "BaseNarrative"
      DisplayName = "That scythe... that must be Zorephet in the Aspect designated to my Thanatos. He may soon desire its return."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutThanatosAspect01"
    }
    {
      Id = "MelinoeField_4675"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I had not considered that. Well if the time has come for Zorephet to be with Thanatos once more, then I am grateful for the time we had, and entrust it to you now, O Night."
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutThanatosAspect01"
    }
    {
      Id = "Nyx_0056"
      InheritFrom = "BaseNarrative"
      DisplayName = "I did not mean {#Emph}this {#Prev}soon. The Underworld is not yet ready for my son to carry out his work. You are to remain bearer of the Moonstone Axe till then."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutThanatosAspect01"
    }
    {
      Id = "MelinoeField_4676"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Oh... {#Prev}good."
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutThanatosAspect01"
    }
    {
      Id = "Nyx_0064"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your service to the realm may go unseen, but has not gone unnoticed, O Melinoë, Princess. As Fear spreads, so does our influence."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutShrine01"
    }
    {
      Id = "MelinoeField_4683"
      InheritFrom = "BaseNarrative"
      DisplayName = "In shadow, I serve; to shadow I return, O Night. And may your will be done."
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutShrine01"
    }
    {
      Id = "Nyx_0065"
      InheritFrom = "BaseSubtitle"
      DisplayName = "If that is your own will."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutShrine01"
    }
    {
      Id = "Nyx_0066"
      InheritFrom = "BaseNarrative"
      DisplayName = "My testaments within the Oath, enacted to the very last. Despite your demonstrated skill, I was uncertain whether you had the capacity."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutShrine02"
    }
    {
      Id = "MelinoeField_4684"
      InheritFrom = "BaseNarrative"
      DisplayName = "I was uncertain whether I had the capacity either, O Night. If ever my confidence is unwavering, then there's nothing for me to prove. And nothing to strive for."
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutShrine02"
    }
    {
      Id = "Nyx_0067"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well then, it seems you may require something new to strive for now. I trust more Fear may always spread..."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutShrine02"
    }
    {
      Id = "MelinoeField_4685"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Always."
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutShrine02"
    }
    {
      Id = "MelinoeField_4690"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wished to thank you for the Gifts of the Veil, O Night. To have earned the title of your Champion is perhaps the greatest honor of my life."
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutTrophyQuestComplete01"
    }
    {
      Id = "Nyx_0072"
      InheritFrom = "BaseNarrative"
      DisplayName = "You possess the Gifts of the Veil. Then, that is good. How did you come about them, and who bestowed the title?"
      Speaker = "Nyx"
      Event = "NyxInChaosAboutTrophyQuestComplete01"
    }
    {
      Id = "MelinoeField_4691"
      InheritFrom = "BaseNarrative"
      DisplayName = "I... completed the trials you put forth, that Commander Schelemeus put forth on your behalf... unless..."
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutTrophyQuestComplete01"
    }
    {
      Id = "Nyx_0073"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh yes, the skeleton, of course. I knew him by a different title once. I trust that he administered my {#Emph}trials{#Prev}, as you call them, capably?"
      Speaker = "Nyx"
      Event = "NyxInChaosAboutTrophyQuestComplete01"
    }
    {
      Id = "MelinoeField_4692"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well, I should think so... yes..."
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutTrophyQuestComplete01"
    }
    {
      Id = "Nyx_0074"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Then, good, my champion."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutTrophyQuestComplete01"
    }
    {
      Id = "Nyx_0075"
      InheritFrom = "BaseNarrative"
      DisplayName = "Some of my children residing in your Crossroads... we have not always interacted in the most productive way. I once thought that this failing was solely mine. But, I see the pattern frequently; a curse of sorts our families share."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutChildren01"
    }
    {
      Id = "MelinoeField_4693"
      InheritFrom = "BaseNarrative"
      DisplayName = "Even a single child seems very difficult to rear. I could not have been an easy one, for all my moods. I scarce imagine how it must have been for you with Nemesis, or Eris..."
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutChildren01"
    }
    {
      Id = "Nyx_0076"
      InheritFrom = "BaseNarrative"
      DisplayName = "Amongst others, yes. I was the constant in most of my children's lives, yet each has been a mystery. May Queen Persephone's relationship with you not be as tenuous as so many of mine."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutChildren01"
    }
    {
      Id = "MelinoeField_4694"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps you could visit your children more often... smooth things over..."
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutChildren01"
    }
    {
      Id = "Nyx_0077"
      InheritFrom = "BaseNarrative"
      DisplayName = "My children tend to need their space. But as I learned with Chaos, we have eternity to reconvene, if we so desire."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutChildren01"
    }
    {
      Id = "MelinoeField_4695"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Something to look forward to."
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutChildren01"
    }
    {
      Id = "Nyx_0059"
      InheritFrom = "BaseNarrative"
      DisplayName = "My many children dwell in darkness, yet I know where most of them reside. But not my daughters the Three Fates. They were cast into exile, to your knowledge?"
      Speaker = "Nyx"
      Event = "NyxInChaosAboutFates01"
    }
    {
      Id = "MelinoeField_4679"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes... Chronos sought to get them out of the way, as part of his conquest. I think he feels quite badly about it now, but that hasn't helped us find them. What can we do?"
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutFates01"
    }
    {
      Id = "Nyx_0060"
      InheritFrom = "BaseNarrative"
      DisplayName = "We look for signs. If the Fated List has been revealing prophecies to you, then some traces of their power to communicate remain."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutFates01"
    }
    {
      Id = "MelinoeField_4680"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We'll look for signs."
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutFates01"
    }
    {
      Id = "Nyx_0070"
      InheritFrom = "BaseNarrative"
      DisplayName = "I trust you are to thank for having shaken my son Hypnos from his slumber and compelled him to return. He had been doing fairly well in his responsibilities, up to a certain point."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutHypnosWakeUp01"
    }
    {
      Id = "MelinoeField_4688"
      InheritFrom = "BaseNarrative"
      DisplayName = "Please forgive him, O Night. He must have fallen into such a state as a defensive response when the Titan Chronos struck. I am relieved he's well... assuming that he is?"
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutHypnosWakeUp01"
    }
    {
      Id = "Nyx_0071"
      InheritFrom = "BaseNarrative"
      DisplayName = "He is himself. His brother Thanatos is pleased to have him back, as is your own. Thank you for looking after him."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutHypnosWakeUp01"
    }
    {
      Id = "MelinoeField_4689"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Of course."
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutHypnosWakeUp01"
    }
    {
      Id = "Nyx_0078"
      InheritFrom = "BaseNarrative"
      DisplayName = "How has my daughter Eris been? I regret that Hecate had to contend with her whilst I was unavailable. I did not think that Strife would choose to stay in any given place."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutEris01"
    }
    {
      Id = "MelinoeField_4696"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, Strife. While Eris has been difficult now and again, despite our differences, we have an understanding. She's... exciting to be around, if nothing else."
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutEris01"
    }
    {
      Id = "Nyx_0079"
      InheritFrom = "BaseNarrative"
      DisplayName = "That is more than I can say. Yet I have learned from her."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutEris01"
    }
    {
      Id = "MelinoeField_4697"
      InheritFrom = "BaseSubtitle"
      DisplayName = "As have I."
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutEris01"
    }
    {
      Id = "Nyx_0090"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have a blessing from my faithful Eye of Night. She is dependable; a quality that I have come to prize above all else. The two of you are close?"
      Speaker = "Nyx"
      Event = "NyxInChaosAboutSelene01"
    }
    {
      Id = "MelinoeField_4706"
      InheritFrom = "BaseNarrative"
      DisplayName = "She was always watching over me since I was very small. I am proud to call her Sister now, and to have worked with her directly in all this."
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutSelene01"
    }
    {
      Id = "Nyx_0091"
      InheritFrom = "BaseNarrative"
      DisplayName = "From what I gather, the Moon herself feels very much the same. Long may the two of you illuminate each other's greatest strengths."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutSelene01"
    }
    {
      Id = "MelinoeField_4707"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You honor us."
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutSelene01"
    }
    {
      Id = "Nyx_0087"
      InheritFrom = "BaseNarrative"
      DisplayName = "I sense the blessings of the god of war. I have not visited with him or the Olympians since I was indisposed."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutAres01"
    }
    {
      Id = "MelinoeField_4704"
      InheritFrom = "BaseNarrative"
      DisplayName = "I think they know that you have much to do right now, O Night. Did you use to travel to the surface very much?"
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutAres01"
    }
    {
      Id = "Nyx_0088"
      InheritFrom = "BaseNarrative"
      DisplayName = "My influence extends across the realms. And I have had occasion to interact with Lord Ares and the goddess Athena, amongst others. But it is not habitual."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutAres01"
    }
    {
      Id = "MelinoeField_4705"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm certain they'll look forward to when next you meet."
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutAres01"
    }
    {
      Id = "Nyx_0089"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Some of them fear me, I should think, but yes."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutAres01"
    }
    {
      Id = "Nyx_0093"
      InheritFrom = "BaseNarrative"
      DisplayName = "The notoriety of the Unseen has spread throughout the realms. As a result of your efforts, few remain who would so much as dare to stand against the Underworld now."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutBadgeProgress01"
    }
    {
      Id = "MelinoeField_4708"
      InheritFrom = "BaseNarrative"
      DisplayName = "We have many loyal Shades in every region keeping watch for us, even as we eliminate remaining traces of the threats that caused us so much harm. But there is more to do."
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutBadgeProgress01"
    }
    {
      Id = "Nyx_0094"
      InheritFrom = "BaseNarrative"
      DisplayName = "There always is, Melinoë, Princess. Which is why it can be valuable to take such moments to reflect on how far we have come, regardless of how far we have to go."
      Speaker = "Nyx"
      Event = "NyxInChaosAboutBadgeProgress01"
    }
    {
      Id = "MelinoeField_4709"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thank you, O Night."
      Speaker = "Melinoe"
      Event = "NyxInChaosAboutBadgeProgress01"
    }
    {
      Id = "Nyx_0038"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I see you all appear to be pursuing your responsibilities with diligence. Each child of mine, a valuable asset to the Witch of the Crossroads in my absence."
      Speaker = "Nyx"
      Event = "NyxWithNemesis01"
    }
    {
      Id = "Nemesis_0428"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Whatever she says goes, Mother. We did what we could."
      Speaker = "Nemesis"
      Event = "NyxWithNemesis01"
    }
    {
      Id = "Nyx_0039"
      InheritFrom = "BaseNarrative"
      DisplayName = "And Hypnos, he was here throughout this whole ordeal as well. Be certain to pay due respect to Hecate. You may remain here for the time, so long as more is to be done, and that you all continue to cooperate. Are we understood?"
      Speaker = "Nyx"
      Event = "NyxWithNemesis01"
    }
    {
      Id = "Nemesis_0429"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Of course, Mother. We cooperate here all the time."
      Speaker = "Nemesis"
      Event = "NyxWithNemesis01"
    }
    {
      Id = "Nyx_0040"
      InheritFrom = "BaseNarrative"
      DisplayName = "Of that, I am now certain. But I cannot remain to see it with my own eyes, for the realm has need of me below. Farewell, and may darkness guide you where moonlight cannot."
      Speaker = "Nyx"
      Event = "NyxWithNemesis01"
    }
    {
      Id = "Nemesis_0430"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Bye, Mother..."
      Speaker = "Nemesis"
      Event = "NyxWithNemesis01"
    }
    {
      Id = "Nyx_0035"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hecate, you have done all I could have asked, and more. My wayward children here were safe within your care. And by the wisdom of your counsel, I am free."
      Speaker = "Nyx"
      Event = "NyxWithHecate01"
    }
    {
      Id = "Hecate_0872"
      InheritFrom = "BaseNarrative"
      DisplayName = "You always have been generous, O Nyx. Above all, I am grateful you returned to us. What of your children, are they heading back with you?"
      Speaker = "Hecate"
      Event = "NyxWithHecate01"
    }
    {
      Id = "Nyx_0036"
      InheritFrom = "BaseNarrative"
      DisplayName = "They are grown, and I have much to do. If it is their wish to remain within these Crossroads, then I ask that you comply. I trust they have not been a burden?"
      Speaker = "Nyx"
      Event = "NyxWithHecate01"
    }
    {
      Id = "Hecate_0873"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Oh, no, of course not."
      Speaker = "Hecate"
      Event = "NyxWithHecate01"
    }
    {
      Id = "Nyx_0037"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then good. I cannot say when next I shall return. Farewell."
      Speaker = "Nyx"
      Event = "NyxWithHecate01"
    }
    {
      Id = "Hecate_0874"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Farewell, O Nyx."
      Speaker = "Hecate"
      Event = "NyxWithHecate01"
    }
    {
      Id = "Nyx_0061"
      InheritFrom = "BaseNarrative"
      DisplayName = "My daughters have returned to us. Knowing them, they gave you the impression that they did so on their own. However, if not for your efforts with the Fated List, they might have never found their way."
      Speaker = "Nyx"
      Event = "NyxInChaosPostEpilogue01"
    }
    {
      Id = "MelinoeField_4681"
      InheritFrom = "BaseNarrative"
      DisplayName = "Each prophecy fulfilled, a signal to the Fates... a beacon in the darkness of their exile, something of the sort?"
      Speaker = "Melinoe"
      Event = "NyxInChaosPostEpilogue01"
    }
    {
      Id = "Nyx_0062"
      InheritFrom = "BaseNarrative"
      DisplayName = "That is a reasonable way to think of it. You have done my family a great service, O Melinoë, Princess. The depth of my gratitude is beyond my means to describe."
      Speaker = "Nyx"
      Event = "NyxInChaosPostEpilogue01"
    }
    {
      Id = "MelinoeField_4682"
      InheritFrom = "BaseNarrative"
      DisplayName = "You honor me, O Night. May all of us cease losing family members for a while."
      Speaker = "Melinoe"
      Event = "NyxInChaosPostEpilogue01"
    }
    {
      Id = "Nyx_0063"
      InheritFrom = "BaseSubtitle"
      DisplayName = "May that be so."
      Speaker = "Nyx"
      Event = "NyxInChaosPostEpilogue01"
    }
    {
      Id = "Nyx_0107"
      InheritFrom = "BaseNarrative"
      DisplayName = "We welcome you unto the solitude of the abyss, Melinoë, Princess."
      Speaker = "Nyx"
      Event = "NyxInChaosChat01"
    }
    {
      Id = "Nyx_0108"
      InheritFrom = "BaseNarrative"
      DisplayName = "The House of Hades is beginning to grow even stronger than it always was."
      Speaker = "Nyx"
      Event = "NyxInChaosChat02"
    }
    {
      Id = "Nyx_0109"
      InheritFrom = "BaseNarrative"
      DisplayName = "Chaos imagined that you would arrive, and now you stand before us."
      Speaker = "Nyx"
      Event = "NyxInChaosChat03"
    }
    {
      Id = "Nyx_0110"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your father's House can grow quite boisterous, so I seek solace in these depths."
      Speaker = "Nyx"
      Event = "NyxInChaosChat04"
    }
    {
      Id = "Nyx_0111"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your brother has been doing well, and often wonders how you fare."
      Speaker = "Nyx"
      Event = "NyxInChaosChat05"
    }
    {
      Id = "Nyx_0112"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hypnos asked about you recently, as though I had not already told him."
      Speaker = "Nyx"
      Event = "NyxInChaosChat06"
    }
    {
      Id = "Nyx_0113"
      InheritFrom = "BaseNarrative"
      DisplayName = "I trust that Eris has not been {#Emph}too {#Prev}much of an impediment of late."
      Speaker = "Nyx"
      Event = "NyxInChaosChat07"
    }
    {
      Id = "Nyx_0114"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not long ago I had encountered Nemesis whilst here, and we each spoke of you."
      Speaker = "Nyx"
      Event = "NyxInChaosChat08"
    }
    {
      Id = "Nyx_0115"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Fated List remains within your care, and you have Moros to watch over it."
      Speaker = "Nyx"
      Event = "NyxInChaosChat09"
    }
    {
      Id = "Nyx_0116"
      InheritFrom = "BaseNarrative"
      DisplayName = "May the Nocturnal Arms continue to make manifest your will and wrath."
      Speaker = "Nyx"
      Event = "NyxInChaosChat10"
    }
    {
      Id = "Nyx_0117"
      InheritFrom = "BaseNarrative"
      DisplayName = "Chaos and I have aeons of history to discuss, so please do not wait up."
      Speaker = "Nyx"
      Event = "NyxInChaosChat11"
    }
    {
      Id = "Nyx_0118"
      InheritFrom = "BaseNarrative"
      DisplayName = "This is a very fearsome night, and we have you and all your Vows to thank for it."
      Speaker = "Nyx"
      Event = "NyxInChaosChat12"
    }
    {
      Id = "Nyx_0119"
      InheritFrom = "BaseNarrative"
      DisplayName = "May the blessing of faithful Selene guide you well beyond this point."
      Speaker = "Nyx"
      Event = "NyxInChaosChat13"
    }
    {
      Id = "Nyx_0120"
      InheritFrom = "BaseNarrative"
      DisplayName = "Persephone the Queen is often filled with joy that you have reunited finally."
      Speaker = "Nyx"
      Event = "NyxInChaosChat14"
    }
    {
      Id = "Nyx_0121"
      InheritFrom = "BaseNarrative"
      DisplayName = "In our obscurity lies strength. Seek to be valuable, not to be known."
      Speaker = "Nyx"
      Event = "NyxInChaosChat15"
    }
    {
      Id = "MelinoeField_4710"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wish to make an offering to you, O Night. For always concealing the Crossroads where I grew up, for the Nocturnal Arms, and all the many other gifts you bestowed."
      Speaker = "Melinoe"
      Event = "NyxGift01"
    }
    {
      Id = "Nyx_0095"
      InheritFrom = "BaseNarrative"
      DisplayName = "I thank you for this, child. And may the Nocturnal Arms long serve you as a Keepsake of sorts from me. The Witch of the Crossroads says you wield them with skill and grace."
      Speaker = "Nyx"
      Event = "NyxGift01"
    }
    {
      Id = "MelinoeField_4711"
      InheritFrom = "BaseSubtitle"
      DisplayName = "She does, does she..."
      Speaker = "Melinoe"
      Event = "NyxGift01"
    }
    {
      Id = "MelinoeField_4712"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wished to give you something more, O Night. For caring for Sister Selene, who is a dear friend, along with your wonderful children whom I've come to know."
      Speaker = "Melinoe"
      Event = "NyxGift02"
    }
    {
      Id = "Nyx_0096"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your family's custom is not mine, child. Nor do I wish to accept such gratitude whilst there is so much to be done before the realm is at full strength again. You have my thanks, as well as that request."
      Speaker = "Nyx"
      Event = "NyxGift02"
    }
    {
      Id = "Zagreus_0008"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Erm... {#Prev}is my hair getting lighter and my features getting fairer, or did I consume something that really isn't sitting well...?"
      Speaker = "Zagreus"
      Event = "ZagreusPastFirstMeeting"
    }
    {
      Id = "MelinoeField_3425"
      InheritFrom = "BaseNarrative"
      DisplayName = "Prince Zagreus, please listen to my voice! Can you hear me? Can you {#Emph}hear {#Prev}me?"
      Speaker = "Melinoe"
      Event = "ZagreusPastFirstMeeting"
    }
    {
      Id = "Zagreus_0009"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Definitely something I consumed, then. Or else... {#Emph}oh {#Prev}this is just a dream...! Hypnos {#Emph}has {#Prev}been growing rather bold with these! Is that you in there, mate?"
      Speaker = "Zagreus"
      Event = "ZagreusPastFirstMeeting"
    }
    {
      Id = "MelinoeField_3426"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, I... look, yes, technically this is a dream. But it's the only way I could reach out to you across the span of Time! Now, {#Emph}please! {#Prev}Our family is in danger, and I need your aid!"
      Speaker = "Melinoe"
      Event = "ZagreusPastFirstMeeting"
    }
    {
      Id = "Zagreus_0010"
      InheritFrom = "BaseNarrative"
      DisplayName = "All right, all right, slow down! It's fortunate I rather {#Emph}like {#Prev}such realistic dreams. And what do you mean {#Emph}our family? {#Prev}Who {#Emph}are {#Prev}you? Probably one of Mother's many cousins. Wouldn't explain the eyes, though. Or my father's sigil on your outfit..."
      Speaker = "Zagreus"
      Event = "ZagreusPastFirstMeeting"
    }
    {
      Id = "MelinoeField_3427"
      InheritFrom = "BaseNarrative"
      DisplayName = "Let me speak! Look, this is going to be difficult for you to accept, but... I'm Melinoë... your sister. From another time; a future time, not all that distant from your own!"
      Speaker = "Melinoe"
      Event = "ZagreusPastFirstMeeting"
    }
    {
      Id = "Zagreus_0011"
      InheritFrom = "BaseNarrative"
      DisplayName = "...See, that was going to be my next guess. Well, dream-sister-from-a-future-time? I would never want to snap awake before hearing you out, so what's the situation? What do you want me to do...?"
      Speaker = "Zagreus"
      Event = "ZagreusPastFirstMeeting"
    }
    {
      Id = "MelinoeField_3428"
      InheritFrom = "BaseNarrative"
      DisplayName = "I want you to find our grandfather Chronos, and destroy him! Because there's only so much I can do here myself. He's taken over your entire House...! Imprisoned our father, Mother, you, {#Emph}everybody...! {#Prev}And now he threatens Olympus. All as vengeance for what the gods once did."
      Speaker = "Melinoe"
      Event = "ZagreusPastFirstMeeting"
    }
    {
      Id = "Zagreus_0012"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Right. When you say {#Emph}what the gods once did{#Prev}, you mean the part where they got rid of Chronos permanently, long before I was ever born? Or {#Emph}you {#Prev}for that matter. But in the not-all-that-distant future, he returns, and single-handedly takes over everything...?"
      Speaker = "Zagreus"
      Event = "ZagreusPastFirstMeeting"
    }
    {
      Id = "MelinoeField_3429"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes. Please believe me! I myself was very little when the Titan struck, and have been training all my life in preparation for this very moment! But I cannot stop Chronos on my own. Will you aid me?"
      Speaker = "Melinoe"
      Event = "ZagreusPastFirstMeeting"
    }
    {
      Id = "Zagreus_0013"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm guessing not? Since this is a dream, and I'll likely just forget about it soon as I wake up! Also, you look and sound just like a figment of my imagination would probably look and sound. Can you {#Emph}prove {#Prev}anything you've said?"
      Speaker = "Zagreus"
      Event = "ZagreusPastFirstMeeting"
    }
    {
      Id = "MelinoeField_3430"
      InheritFrom = "BaseNarrative"
      DisplayName = "You won't forget me when you wake, I promise you. As for the proof you seek... you must know of Hecate, our mother's handmaiden! She trained me for this. Seek her, and tell her what I've said — but no one else!"
      Speaker = "Melinoe"
      Event = "ZagreusPastFirstMeeting"
    }
    {
      Id = "Zagreus_0014"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Erm{#Prev}, Sister, I'm afraid our mother {#Emph}has {#Prev}no such handmaiden... although, in some strange way you mentioning a name I've never heard is better proof than anything you've said to me thus far. Wait, what's the matter...?"
      Speaker = "Zagreus"
      Event = "ZagreusPastFirstMeeting"
    }
    {
      Id = "MelinoeField_3431"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's Chronos! I've incapacitated him, but he'll return... just as he will eventually in your own time. I need to go... before he finds me here, I need to go!"
      Speaker = "Melinoe"
      Event = "ZagreusPastFirstMeeting"
    }
    {
      Id = "Zagreus_0015"
      InheritFrom = "BaseNarrative"
      DisplayName = "But you just got here! Look... Melinoë, was it? Will I ever see you again, or was this more of a one-off?"
      Speaker = "Zagreus"
      Event = "ZagreusPastFirstMeeting"
    }
    {
      Id = "MelinoeField_3432"
      InheritFrom = "BaseNarrative"
      DisplayName = "I found you across dreams and time, Brother. I'll stop at nothing to do it again! Until then, please, let this remain a secret between us."
      Speaker = "Melinoe"
      Event = "ZagreusPastFirstMeeting"
    }
    {
      Id = "Zagreus_0016"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Great, I can't even tell Hypnos. Well, suit yourself! See you another day, Sister. Or night...?"
      Speaker = "Zagreus"
      Event = "ZagreusPastFirstMeeting"
    }
    {
      Id = "MelinoeField_3433"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Till then!"
      Speaker = "Melinoe"
      Event = "ZagreusPastFirstMeeting"
    }
    {
      Id = "Zagreus_0019"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just as I'm about to get my hair under control! Who are you, and what have you done with my reflection...? Only joking. I remembered everything just as you said. Particularly since you're here again so soon. Where were we?"
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting02"
    }
    {
      Id = "MelinoeField_3437"
      InheritFrom = "BaseNarrative"
      DisplayName = "I was trying to persuade you to take me at my word that I'm your sister from a future time, in which the Titan Chronos has usurped the House of Hades. I mean to stop him, and require your assistance."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting02"
    }
    {
      Id = "Zagreus_0020"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have a wide variety of questions first, even knowing that our time apparently is limited. First off, why {#Emph}me? {#Prev}Although I {#Emph}am {#Prev}the designated Security Specialist around here, so perhaps I know the answer to that one."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting02"
    }
    {
      Id = "MelinoeField_3438"
      InheritFrom = "BaseNarrative"
      DisplayName = "Some Security Specialist. Chronos caught the House entirely off guard! But you're my closest kin, you've subverted the will of the Fates before, and slain gods, if not Titans... I also lack the means of reaching anybody else this way."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting02"
    }
    {
      Id = "Zagreus_0021"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, great! I feel that strong kinship between us already. Next question: Where even {#Emph}is {#Prev}this Chronos, and what would you have me do if and when I locate him? A two-parter for you."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting02"
    }
    {
      Id = "MelinoeField_5208"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't know where Chronos is exactly, in your time, though I do have a lead: His remains were scattered to the deepest pits of Tartarus, which means he's probably recovering below where you reside. As for what to do if you can locate him... nothing as yet. We'll get to that."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting02"
    }
    {
      Id = "Zagreus_0022"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Erm{#Prev}, I hate to break it to you, Melinoë, but this isn't all that comprehensive a plan. Especially for something you've been planning all your life. Do I just wait for you to work through the details, or...?"
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting02"
    }
    {
      Id = "MelinoeField_3440"
      InheritFrom = "BaseNarrative"
      DisplayName = "No! Look. You're Security Specialist! Begin an investigation, though in absolute secrecy. Is anything amiss anywhere in the House, or in Tartarus? Any unusual activity from Satyrs, for example?"
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting02"
    }
    {
      Id = "Zagreus_0023"
      InheritFrom = "BaseNarrative"
      DisplayName = "We've had our share of Satyr problems, though not anywhere nearby. But I can have a look around. What about you...? Wait, are you in my {#Emph}bedchambers?"
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting02"
    }
    {
      Id = "MelinoeField_3441"
      InheritFrom = "BaseNarrative"
      DisplayName = "What's left of them, yes! I can only reach you like this while we're in the same location across Time. At any rate... I have to find the means for you to destroy the Titan there before he regains his full strength. But... blast."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting02"
    }
    {
      Id = "Zagreus_0024"
      InheritFrom = "BaseNarrative"
      DisplayName = "What is it, do you have to go again? Then don't wait up on my account. I'll see what I can do and speak to you when next you haunt my dreams. Take care, Sister! We'll sort this out."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting02"
    }
    {
      Id = "MelinoeField_3442"
      InheritFrom = "BaseNarrative"
      DisplayName = "You make it sound so effortless... farewell, Brother. Until we see each other next."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting02"
    }
    {
      Id = "Zagreus_0438"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hi there, Melinoë! My investigation into our grandfather's scheming has begun, though difficult to make good progress without telling anybody what I'm up to. Don't take this the wrong way, but... this truly is your only idea?"
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting02_2"
    }
    {
      Id = "MelinoeField_5046"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes. I don't think I can stop Chronos here. Even Olympus is stuck trying to keep his forces at bay. And he's far too hateful and hard-headed to stop on his own."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting02_2"
    }
    {
      Id = "Zagreus_0425"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's our family for you. Father certainly has no love for Chronos but he never speaks of him. Do you... happen to know what went over between them, to have made things this bad?"
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting02_2"
    }
    {
      Id = "MelinoeField_5047"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're in a better position to ask our father about that than I am. Chronos was a tyrant, and his children wouldn't have it! The Fates themselves deemed that the gods should rule! But that apparently wasn't enough for him."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting02_2"
    }
    {
      Id = "Zagreus_0426"
      InheritFrom = "BaseNarrative"
      DisplayName = "So now you want me to stop him for you. I mean, for {#Emph}us. {#Prev}I've had mixed experiences vanquishing certain members of our family before, but... that wasn't {#Emph}forever. {#Prev}And you've said next to nothing about how you expect me to do it."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting02_2"
    }
    {
      Id = "MelinoeField_5048"
      InheritFrom = "BaseNarrative"
      DisplayName = "Look... I have knowledge of an incantation known as Dissolution of Time. It requires several complicated steps I shall explain along the way. If it works... it should unravel him."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting02_2"
    }
    {
      Id = "Zagreus_0427"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Unravel him. {#Prev}That's a little vague for me, unless Chronos turns out to be a spool of yarn. Can you be more specific?"
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting02_2"
    }
    {
      Id = "MelinoeField_5049"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Unmake him. {#Prev}Destroy his ambitions along with him. Undo all the harm he caused. A threefold family bond is required: you, me, and Chronos. Then we shall infuse a special weapon with the negation of his very being... I'll get into that later."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting02_2"
    }
    {
      Id = "Zagreus_0428"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Well great I think you cleared everything up. Though I'll admit I don't like having to kill off family members just because Father doesn't know how to get along with them."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting02_2"
    }
    {
      Id = "MelinoeField_5050"
      InheritFrom = "BaseNarrative"
      DisplayName = "You would blame Father in all this? {#Emph}Ungh{#Prev}, blast... Chronos is starting to revive. I have to go. Keep searching for any sign of him! And remember, this is for all of us!"
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting02_2"
    }
    {
      Id = "Zagreus_0429"
      InheritFrom = "BaseNarrative"
      DisplayName = "I will, and... I understand, I think. We didn't ask to be born into this but it's what we got. We'll handle it as best we can."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting02_2"
    }
    {
      Id = "MelinoeField_5051"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's right. Thank you, Brother. Take care of yourself... and be kind to Mother, Father, Cerberus, and all, for me."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting02_2"
    }
    {
      Id = "Zagreus_0028"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hello again, Sister. You wanted me to search for signs of Chronos preparing for a big surprise, and... while it isn't much... I {#Emph}did {#Prev}locate machinery in Tartarus that seemed a little out-of-place."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting03"
    }
    {
      Id = "MelinoeField_3443"
      InheritFrom = "BaseNarrative"
      DisplayName = "Machinery... you mean the gears that turn the ever-shifting chambers. In my time, that machinery has spread through Tartarus as far as I can see. What do you make of it?"
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting03"
    }
    {
      Id = "Zagreus_0029"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well... normally I wouldn't have made anything of it, but perhaps it's connected to what you're saying. I'm working on tracing where it leads. What about you, any word about how we ought to proceed?"
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting03"
    }
    {
      Id = "MelinoeField_3444"
      InheritFrom = "BaseNarrative"
      DisplayName = "We need a weapon. The problem is that Chronos can resist the Arms once used to vanquish him. On top of that, it needs to be available both to you in your time, and to me in mine. The closer to our family the better. Can you think of something suitable?"
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting03"
    }
    {
      Id = "Zagreus_0030"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Nothing immediately comes to mind. I have some mortal weapons in my chambers but they hardly worked at any point. A weapon both in my time and in yours... and none of the Infernal Arms will do..."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting03"
    }
    {
      Id = "MelinoeField_3445"
      InheritFrom = "BaseNarrative"
      DisplayName = "Give it some thought, but please make haste. Chronos shall realize what I am up to here eventually, and this connection weakens every night. For now I'd better go."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting03"
    }
    {
      Id = "Zagreus_0439"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hold on! What happened to the servants of this House... to my friends? Loves of my life? You said Chronos took everybody. Did you mean {#Emph}everybody{#Prev}-everybody, or...?"
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting03"
    }
    {
      Id = "MelinoeField_3446"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well... no, {#Emph}erm{#Prev}, Hypnos is with us, but fast asleep. Commander Schelemeus, too; he's marshaling the Shades still loyal to our father. Poor Cerberus has been cast out into the Mourning Fields. But as for all the rest..."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting03"
    }
    {
      Id = "Zagreus_0032"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, at least the good {#Emph}Commander Schelemeus {#Prev}made it out. But Nyx, Achilles, Thanatos, Megaera, Dusa, Orpheus... our grandfather has all of them locked up?"
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting03"
    }
    {
      Id = "MelinoeField_3447"
      InheritFrom = "BaseNarrative"
      DisplayName = "He has our father bound in chains in Tartarus. I understand he's trapped the others... frozen them in Time. But we can break his hold on them. I'm certain that we can. Goodbye for now, Brother! Think of a weapon we can use to set this right."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting03"
    }
    {
      Id = "Zagreus_0036"
      InheritFrom = "BaseNarrative"
      DisplayName = "...{#Emph}Gigaros. {#Prev}My father's spear. You said that we would need a weapon that's available in both our times, is close to our family, and not been used to slay Chronos before. That one should do. It's big... and it hurts."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting04"
    }
    {
      Id = "MelinoeField_5103"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Huh... {#Prev}I see how that may work. Unfortunately, I've no idea where to find this Gigaros; Chronos may have gotten hold of it. But that's in my time... while in {#Emph}yours..."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting04"
    }
    {
      Id = "Zagreus_0037"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Eh{#Prev}, Father doesn't often let me use it anyway, and it's sealed off in his chambers. There must be something else. Though, at least I found the place where Chronos probably is piecing himself back together little by little!"
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting04"
    }
    {
      Id = "MelinoeField_3449"
      InheritFrom = "BaseNarrative"
      DisplayName = "You did? Where, what happened? How do you know it's the correct location?"
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting04"
    }
    {
      Id = "Zagreus_0038"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well for one thing, it appears to be directly underneath this House! Odd place to bury one's predecessor, but Father {#Emph}can {#Prev}be quite particular with punishments. Anyway when I descended deeper into Tartarus, I found a Satyr infestation that led me to some sort of cave. I went no farther for now."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting04"
    }
    {
      Id = "MelinoeField_3450"
      InheritFrom = "BaseNarrative"
      DisplayName = "Good. And do not enter until everything's prepared. But let's go back a moment to our father's spear. Is there some way you could procure it?"
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting04"
    }
    {
      Id = "Zagreus_0489"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sure. Father keeps it locked away, though no Security Specialist of any worth would be so easily deterred! I'm risking an eternity of torment, but sounds like Chronos has that in store for me regardless. So... what shall I do with Gigaros assuming I can get my hands on it?"
      DisplayNameMaxLength = 300
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting04"
    }
    {
      Id = "MelinoeField_5104"
      InheritFrom = "BaseNarrative"
      DisplayName = "Leave it here in your chambers for me to find. Could you persuade our father to give it to you, without letting him know exactly why? If we tamper too much with Time, Chronos shall find out. I don't need its physical form, only its essence sent across our astral-psychic gateway."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting04"
    }
    {
      Id = "Zagreus_0441"
      InheritFrom = "BaseNarrative"
      DisplayName = "Details, details, Sister! I like unreasonable challenges, and Father owes me anyway. So are you some sort of oracle, gathering up ancient artifacts, speaking to me in dreams and such? Perhaps these count as nightmares, what with the terrible future to look forward to."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting04"
    }
    {
      Id = "MelinoeField_3452"
      InheritFrom = "BaseNarrative"
      DisplayName = "We'll change that future. And I'm no oracle; I'm what you call a Witch. We're getting closer to our goal, Brother. Claim Father's spear, and I have more to do myself. I'll see you again soon."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting04"
    }
    {
      Id = "Zagreus_0444"
      InheritFrom = "BaseNarrative"
      DisplayName = "Good news, Sister! It took some doing but I managed to persuade our father to let me hang onto his favored spear a while."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting04_2"
    }
    {
      Id = "MelinoeField_5105"
      InheritFrom = "BaseNarrative"
      DisplayName = "You did? That's great! But, where is it? I found no trace of any such weapon when I passed through here."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting04_2"
    }
    {
      Id = "Zagreus_0445"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I have it secure, except... I felt a little hesitant about handing it over. Or however you mean to get hold of it across this astral-psychic-whatever-you-call-it."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting04_2"
    }
    {
      Id = "MelinoeField_5106"
      InheritFrom = "BaseNarrative"
      DisplayName = "Zagreus... I need that spear. {#Emph}We {#Prev}need that spear. What misgivings could you possibly be having now?"
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting04_2"
    }
    {
      Id = "Zagreus_0446"
      InheritFrom = "BaseNarrative"
      DisplayName = "Melinoë... you're asking me to permanently slay a member of our family whom I've never even met. I know it's important... but that doesn't mean I want to go through with it. I don't even know if I can."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting04_2"
    }
    {
      Id = "MelinoeField_5108"
      InheritFrom = "BaseNarrative"
      DisplayName = "Of {#Emph}course {#Prev}you can! What do you mean, you don't {#Emph}want {#Prev}to go through with it? We're the children of the Underworld King and Queen! We do what is required of us! Not merely what we desire."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting04_2"
    }
    {
      Id = "Zagreus_0447"
      InheritFrom = "BaseNarrative"
      DisplayName = "You sound just like Father. There was a time I never could communicate with him either and I sorely wished that he was dead and gone. I'm glad I never had the capability... I might have used it then."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting04_2"
    }
    {
      Id = "MelinoeField_5109"
      InheritFrom = "BaseNarrative"
      DisplayName = "I sound just like Father? {#Emph}Good! {#Prev}Yet there you go, comparing him to Chronos once again. Just because they're related doesn't make them {#Emph}anything {#Prev}alike. Nor is this situation remotely similar to the one you were in!"
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting04_2"
    }
    {
      Id = "Zagreus_0448"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, I don't know! My situation also involved family members desperately trying to kill each other!"
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting04_2"
    }
    {
      Id = "MelinoeField_5110"
      InheritFrom = "BaseNarrative"
      DisplayName = "We're trying to {#Emph}prevent {#Prev}that! {#Emph}Ungh{#Prev}, blast. We'll discuss this more another night. I can't force you to cooperate with me, but I {#Emph}can {#Prev}haunt your dreams!"
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting04_2"
    }
    {
      Id = "Zagreus_0449"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well it's a good thing I'm susceptible to threats! This was a lovely chat. See you some other nap-time, then?"
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting04_2"
    }
    {
      Id = "MelinoeField_5209"
      InheritFrom = "BaseNarrative"
      DisplayName = "Count on it! And mark you my words, we're going to {#Emph}fix {#Prev}this situation! We're not going to let our family fall apart!"
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting04_2"
    }
    {
      Id = "Zagreus_0454"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh hi, Sister. Back to haunt my dreams some more? I didn't like where we left off, arguing over our relatives and our duty. Besides, Father always says no fighting in this House."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting04_3"
    }
    {
      Id = "MelinoeField_5112"
      InheritFrom = "BaseNarrative"
      DisplayName = "I didn't feel good about it either, and... I couldn't help thinking about what you said. I know you were being honest with me about your concerns. All this must be so much to take in."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting04_3"
    }
    {
      Id = "Zagreus_0455"
      InheritFrom = "BaseNarrative"
      DisplayName = "Believe me I'm absorbing it as quickly as I can. We have this sinister grandfather who's resorted to all-out war against the rest of the family! One way or another... he needs to be stopped."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting04_3"
    }
    {
      Id = "MelinoeField_5113"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's right. And I've been trained in how to stop him, though unfortunately it requires you to do some of the dirty-work. The worst of it, in fact. I... can understand why you would be reluctant."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting04_3"
    }
    {
      Id = "Zagreus_0456"
      InheritFrom = "BaseNarrative"
      DisplayName = "So what do we do? Say we proceed as planned. I get Gigaros to you, you do something to it, I use it to destroy Chronos in {#Emph}my {#Prev}time before he takes control in yours... then, everything would be all right?"
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting04_3"
    }
    {
      Id = "MelinoeField_5114"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well I assume so, yes! We can't anticipate exactly what shall happen in a world without Time, but it's existed in that state before... and can't be worse than letting him prevail."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting04_3"
    }
    {
      Id = "Zagreus_0458"
      InheritFrom = "BaseNarrative"
      DisplayName = "But if Chronos is gone... what happens to you? You're here because of everything he did."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting04_3"
    }
    {
      Id = "MelinoeField_5115"
      InheritFrom = "BaseNarrative"
      DisplayName = "No! If Chronos hadn't taken Father's throne, we'd be together as a family! He denied me a father, a mother, a three-headed dog... {#Emph}you! {#Prev}And some evening he'll deny you that and more if we don't act."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting04_3"
    }
    {
      Id = "Zagreus_0459"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}OK! {#Prev}OK. It's just... it turns out I have a sister, and I don't want to lose her over this is all."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting04_3"
    }
    {
      Id = "MelinoeField_5116"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't want to lose you either, Zagreus. I want you back. You and all the rest."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting04_3"
    }
    {
      Id = "Zagreus_0460"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Well then... I... better get you Father's spear. I'll have it for you next we meet. I promise."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting04_3"
    }
    {
      Id = "MelinoeField_5117"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thanks, Brother. Leave Gigaros in your chambers for me, and we'll go from there. For all our sakes."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting04_3"
    }
    {
      Id = "MelinoeField_5121"
      InheritFrom = "BaseNarrative"
      DisplayName = "Zagreus, you did it...! I found the traces of Gigaros here, which should be what I need for what comes next."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting05"
    }
    {
      Id = "Zagreus_0462"
      InheritFrom = "BaseNarrative"
      DisplayName = "Right. So, now I wait for you to contact me again, once you've infused our father's spear with some temporal nightmare curse, and... I'll descend into Grandfather's fetid lair where I'll drive said spear into his heart? Something like that?"
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting05"
    }
    {
      Id = "MelinoeField_5122"
      InheritFrom = "BaseNarrative"
      DisplayName = "Whatever it takes. But... I've been giving this a lot of thought, and... there's an alternative I wanted to propose. You said before you've never even met Chronos. Let's say you find him in his fetid lair. What are the outcomes then?"
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting05"
    }
    {
      Id = "Zagreus_0463"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, let's see. One, I could murder him as we discussed. Two, I could fail miserably in the attempt. Or three, we hit it off, have a rousing conversation, and become best mates?"
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting05"
    }
    {
      Id = "MelinoeField_5210"
      InheritFrom = "BaseNarrative"
      DisplayName = "My thoughts as well, more or less. Bear with me, but... what if, prior to striking, you first took that latter course? Got to know him. Endeared yourself to him, if possible."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting05"
    }
    {
      Id = "Zagreus_0464"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wait, what? We'd have ourselves a nice grandson-to-grandfather chat? I could invite him to the House for a bottle of Ambrosia! He's been festering awhile; perhaps he's keen for company. You're serious."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting05"
    }
    {
      Id = "MelinoeField_5124"
      InheritFrom = "BaseNarrative"
      DisplayName = "I am, but... he's been festering for far too long... and very bitter that our family broke ties with him. His ambitions likely can't be changed, even in your time. Though if nothing else, perhaps you can use such knowledge against him."
      DisplayNameMaxLength = 300
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting05"
    }
    {
      Id = "Zagreus_0465"
      InheritFrom = "BaseNarrative"
      DisplayName = "...You really {#Emph}do {#Prev}mean he and I should have a chat. So we become best mates, what then? Oh... {#Emph}huh. {#Prev}He wouldn't take over the House. He wouldn't have to! But, Father would absolutely lose his mind if he sees him again..."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting05"
    }
    {
      Id = "MelinoeField_5125"
      InheritFrom = "BaseNarrative"
      DisplayName = "Take Chronos in as prisoner! As Security Specialist, it ought to be within your right. He probably is far too proud to go quietly, but... it's a chance."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting05"
    }
    {
      Id = "Zagreus_0466"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, why not? He hasn't met {#Emph}me{#Prev}, right? Or {#Emph}you {#Prev}for that matter. And he can't be harder to talk to than Father. I like this plan, Sister! More than the kill-on-sight version, at least."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting05"
    }
    {
      Id = "MelinoeField_5126"
      InheritFrom = "BaseNarrative"
      DisplayName = "Good. But I need assurances that if the conversation does not go the way you wish, you will not hesitate to run him through."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting05"
    }
    {
      Id = "Zagreus_0467"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then, here are those assurances: If I meet him, can't get through to him, don't like him, and determine he's a threat to you and all of us... I'll kill him. Then and there."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting05"
    }
    {
      Id = "MelinoeField_5211"
      InheritFrom = "BaseNarrative"
      DisplayName = "I believe you. All my life, I had this task... {#Emph}Death to Chronos. {#Prev}But that was never the goal in its entirety... moreso the means to stop him, and for retribution. If there's another way to set this right... it's worth a shot."
      DisplayNameMaxLength = 300
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting05"
    }
    {
      Id = "Zagreus_0468"
      InheritFrom = "BaseNarrative"
      DisplayName = "Agreed. Well, then... I'd better brush up on my spearwork just in case. Besides, the sooner I wear myself out, the sooner I'll be able to get right back to sleep and see you again."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting05"
    }
    {
      Id = "MelinoeField_5128"
      InheritFrom = "BaseNarrative"
      DisplayName = "Be ready. Preparing Gigaros may take a little while, and... I may have difficulty reaching you until such time. But I'll return. Till then, be well, Zagreus. Big brother."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting05"
    }
    {
      Id = "Zagreus_0052"
      InheritFrom = "BaseNarrative"
      DisplayName = "Melinoë! You've returned. You've no idea how much difficulty I had falling asleep so I could see you here again. So what's the word, have you prepared the spear?"
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting06"
    }
    {
      Id = "MelinoeField_5129"
      InheritFrom = "BaseNarrative"
      DisplayName = "Take hold of Gigaros, and we'll find out. You'll have to go immediately to where Chronos resides. Speak to him, but do not mention me at all, as I've not yet been born. I'll be counting on you to succeed."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting06"
    }
    {
      Id = "Zagreus_0469"
      InheritFrom = "BaseNarrative"
      DisplayName = "And the plan is... once I find him... either we become best mates, or else it's {#Emph}Death to Chronos {#Prev}like you said. Do you... do you truly think there's any possibility he comes around? That I won't have to kill him?"
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting06"
    }
    {
      Id = "MelinoeField_5187"
      InheritFrom = "BaseNarrative"
      DisplayName = "Knowing there are infinite possibilities... then I suppose so, yes. But I'm so angry with him still, and frightened about what may come to pass. He's taken so much from me, from all of us, and yet... he wants his family back, too. One way or another, he'll get what's coming. We all will."
      DisplayNameMaxLength = 300
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting06"
    }
    {
      Id = "Zagreus_0470"
      InheritFrom = "BaseNarrative"
      DisplayName = "...All right. But we're getting {#Emph}your {#Prev}family back, not just {#Emph}his! Whew{#Prev}, this is a lot. To think this spear of Father's has the power to destroy a deathless Titan."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting06"
    }
    {
      Id = "MelinoeField_5131"
      InheritFrom = "BaseNarrative"
      DisplayName = "It shall in just a moment, so hold it close. {#Emph}May Earth and Night and Darkness hear me now: Bring true death to the deathless by my vow. Dissolution of Time!"
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting06"
    }
    {
      Id = "Zagreus_0055"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Gigaros... it's grown hot to the touch... but feels much lighter than before as well! I suppose I should be careful not to prod somebody with it... besides Chronos."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting06"
    }
    {
      Id = "MelinoeField_3886"
      InheritFrom = "BaseNarrative"
      DisplayName = "Go, Zagreus. I've done everything I can here. And we'll see each other again. Some other time than this, perhaps, but still. For now, farewell."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting06"
    }
    {
      Id = "Chronos_0967"
      InheritFrom = "BaseNarrative"
      DisplayName = "Who goes there?! You lack the clopping of the Satyr's hooves, and have a countenance which I know not."
      Speaker = "Chronos"
      Event = "ZagreusPastMeeting06"
    }
    {
      Id = "Zagreus_0471"
      InheritFrom = "BaseNarrative"
      DisplayName = "You must be Grandfather. I don't believe we've had the pleasure, I'm called Zagreus. I got a tip about your quite-suspicious cavern and decided to go take a look. What are you doing here, if I may ask?"
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting06"
    }
    {
      Id = "Chronos_0968"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Recuperating! {#Prev}What else would I possibly be doing in a place such as this? So I suppose Hades is to thank for this new grandchild of mine. I never thought that I would see the age when he became a father for himself."
      Speaker = "Chronos"
      Event = "ZagreusPastMeeting06"
    }
    {
      Id = "Zagreus_0472_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, he's a {#Emph}wonderful {#Prev}father, if you must know! My sole disappointment is that I'm an only child. But he and my dear mother Persephone the Underworld Queen truly love each other, so... down the line, one can hope!"
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting06"
    }
    {
      Id = "Chronos_0969"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why are you telling me all this? Answer immediately, lest my Satyrs tear you to shreds! Where {#Emph}are {#Prev}those blasted Satyrs anyhow...?"
      Speaker = "Chronos"
      Event = "ZagreusPastMeeting06"
    }
    {
      Id = "Zagreus_0473"
      InheritFrom = "BaseNarrative"
      DisplayName = "Grandfather... I'm telling you all this because I thought I'd make a little small talk here before I have to do you in. If you would bring pain and suffering upon my House, as our designated Security Specialist, I cannot allow that."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting06"
    }
    {
      Id = "Chronos_0970"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Pah! {#Prev}What would you know of my intent? You dare speak to me of pain and suffering? Here I have rotted since an aeon prior to when you were but a twinkle in your father's eye! He and his brothers, traitors and usurpers!"
      Speaker = "Chronos"
      Event = "ZagreusPastMeeting06"
    }
    {
      Id = "Zagreus_0474"
      InheritFrom = "BaseNarrative"
      DisplayName = "They're your children... Father and I also used to fight. He'd grown isolated from Olympus, and Persephone, and me. It didn't do him any good. What about you? We've only met! Are you prepared to sweep me into your old grudge?"
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting06"
    }
    {
      Id = "Chronos_1459"
      InheritFrom = "BaseNarrative"
      DisplayName = "If necessary, {#Emph}yes{#Prev}, of {#Emph}course! {#Prev}Your father and his brothers surely have already poisoned you and your entire generation against me!"
      Speaker = "Chronos"
      Event = "ZagreusPastMeeting06"
    }
    {
      Id = "Zagreus_0475"
      InheritFrom = "BaseNarrative"
      DisplayName = "Would I be speaking to you if that were the case? Here's the arrangement: Either come along quietly to a little surprise family reunion... or take this spear repeatedly. And you won't soon recuperate, I swear. Which is it going to be?"
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting06"
    }
    {
      Id = "Chronos_1460"
      InheritFrom = "BaseNarrative"
      DisplayName = "...You, who threaten me with annihilation, have not experienced a world without Time! You would come to dearly miss my influence! Nor shall I be shamed and ridiculed before my kin... what would you have me do, when they look upon me?!"
      Speaker = "Chronos"
      Event = "ZagreusPastMeeting06"
    }
    {
      Id = "Zagreus_0476"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh I don't know, perhaps just act like you're my grandfather, rather than sneaking underneath the House in some sort of profane chamber I ought have known about? You're Time. Why don't you extrapolate a bit?"
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting06"
    }
    {
      Id = "Chronos_1304"
      InheritFrom = "BaseNarrative"
      DisplayName = "Extrapolate {#Emph}what... {#Prev}a joy-filled life in which Grandfather Time is there to coddle the spoiled child of my rancorous son? Hades shall drive that accursed spear through me on sight if you do not!"
      Speaker = "Chronos"
      Event = "ZagreusPastMeeting06"
    }
    {
      Id = "Zagreus_0110"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, because you'll be under my protection. And also, no, it won't just be a joy-filled life, especially if you keep on. But it'll probably be better than whatever {#Emph}this {#Prev}is! Now make your choice already. I don't have all day or night."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting06"
    }
    {
      Id = "Chronos_1305"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Scoff> {#Prev}So then, a future with such grandchildren as you, or the eternal void... how can I possibly decide...?"
      Speaker = "Chronos"
      Event = "ZagreusPastMeeting06"
    }
    {
      Id = "Zagreus_0451"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, Sister! I know you might be ready to proceed with whatever you plan to do with Gigaros, but... I'm not. After I left it for you, I... started feeling some regrets."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting06_B"
    }
    {
      Id = "MelinoeField_5186"
      InheritFrom = "BaseNarrative"
      DisplayName = "All this must be so much to take in... I've been giving this a lot of thought, and... there's an alternative I wanted to propose. You said before you've never even met Chronos. Let's say you find him in his fetid lair. What are the outcomes then?"
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting06_B"
    }
    {
      Id = "MelinoeField_5123"
      InheritFrom = "BaseNarrative"
      DisplayName = "My thoughts as well, more or less. Bear with me but, what if... you {#Emph}could {#Prev}become best mates, as you say?"
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting06_B"
    }
    {
      Id = "MelinoeField_5127"
      InheritFrom = "BaseNarrative"
      DisplayName = "I believe you. All my life, I had this task... {#Emph}Death to Chronos. {#Prev}But that was never the goal... only the means. If there's another way that works for all of us... it's worth a shot."
      DisplayNameMaxLength = 300
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting06_B"
    }
    {
      Id = "MelinoeField_5130"
      InheritFrom = "BaseNarrative"
      DisplayName = "Knowing there are infinite possibilities... then I suppose so, yes. But I'm so angry with him still, and frightened about what may come to pass. He's taken so much from me, from all of us, and yet... he wants his family back, too. So go to him. One way or another, he'll get what's coming. We all will."
      DisplayNameMaxLength = 305
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting06_B"
    }
    {
      Id = "Zagreus_0472"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, he's a {#Emph}wonderful {#Prev}father, if you must know! My sole disappointment is that I'm an only child. But he and my dear mother Persephone the Underworld Queen truly love each other, so... down the line, one can hope!"
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting06_B"
    }
    {
      Id = "Zagreus_0059"
      InheritFrom = "BaseNarrative"
      DisplayName = "Is that {#Emph}you{#Prev}, Melinoë? I can hardly see you anymore. Blast..."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting07"
    }
    {
      Id = "MelinoeField_3909"
      InheritFrom = "BaseNarrative"
      DisplayName = "Zagreus, can you hear me? {#Emph}Answer me! {#Prev}Zagreus!"
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting07"
    }
    {
      Id = "Zagreus_0060"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I don't know what's going on with you, but I'm prepared to do my part as soon as you're prepared."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting07"
    }
    {
      Id = "MelinoeField_3910"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's no use. He can't hear me anymore. I have an incantation to complete, and mustn't remain here."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting07"
    }
    {
      Id = "Zagreus_0064"
      InheritFrom = "BaseNarrative"
      DisplayName = "Is that...? That's her, I think. Melinoë? Is that you? Can you hear me?"
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting08"
    }
    {
      Id = "MelinoeField_3911"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can hear you, but can you hear {#Emph}me? {#Prev}Hello, Zagreus? {#Emph}Hello?"
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting08"
    }
    {
      Id = "Zagreus_0065"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Blast. There has to be a more dependable means of communicating across dreams and time."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeeting08"
    }
    {
      Id = "MelinoeField_3912"
      InheritFrom = "BaseNarrative"
      DisplayName = "This is pointless. Until my incantation is complete, I don't think I'll get through to him again."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeeting08"
    }
    {
      Id = "Zagreus_0069"
      InheritFrom = "BaseNarrative"
      DisplayName = "Melinoë, where are you? It's me your brother! I'm just... standing around, apparently in a dream, waiting for you to show up... {#Emph}anytime?"
      Speaker = "Zagreus"
      Event = "ZagreusPastMeetingRepeatable01"
    }
    {
      Id = "MelinoeField_3913"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just hold on a little while longer, Brother..."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeetingRepeatable01"
    }
    {
      Id = "Zagreus_0071"
      InheritFrom = "BaseNarrative"
      DisplayName = "What if something happened to her... but then I wouldn't have this dream again, would I? Unless I'm {#Emph}not. {#Prev}And I'm just standing around, staring at a mirror..."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeetingRepeatable02"
    }
    {
      Id = "MelinoeField_3914"
      InheritFrom = "BaseNarrative"
      DisplayName = "He senses me but I'm unable to get through... just, wait a little while longer, Zagreus."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeetingRepeatable02"
    }
    {
      Id = "Zagreus_0073"
      InheritFrom = "BaseNarrative"
      DisplayName = "Am I really going to do this? Destroy our grandfather... surely it's what Father would want, and this sister of mine, too, but... {#Emph}eh{#Prev}, where is she anyway? Melinoë? Sister?"
      Speaker = "Zagreus"
      Event = "ZagreusPastMeetingRepeatable03"
    }
    {
      Id = "MelinoeField_3915"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm here, it's just... we can't communicate like this at all, until... I have to rebuild our connection."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeetingRepeatable03"
    }
    {
      Id = "Zagreus_0076"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hm{#Prev}, what to do... what's keeping her? Is she all right? {#Emph}Hello...? {#Prev}Are you all right out there?"
      Speaker = "Zagreus"
      Event = "ZagreusPastMeetingRepeatable04"
    }
    {
      Id = "MelinoeField_3917"
      InheritFrom = "BaseNarrative"
      DisplayName = "I am, it's just... I need a bit more time! Just don't lose hope, and... be ready."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeetingRepeatable04"
    }
    {
      Id = "Zagreus_0074"
      InheritFrom = "BaseNarrative"
      DisplayName = "Keep having this odd dream... or {#Emph}nightmare{#Prev}, I don't know. Not heard from her in quite a while..."
      Speaker = "Zagreus"
      Event = "ZagreusPastMeetingRepeatable05"
    }
    {
      Id = "MelinoeField_3916"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll be back for you, Brother, I swear... just not tonight."
      Speaker = "Melinoe"
      Event = "ZagreusPastMeetingRepeatable05"
    }
    {
      Id = "Melinoe_5059"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Be well, Brother."
      Speaker = "Melinoe"
      Event = "NPC_Zagreus_01.InteractVoiceLines"
    }
    {
      Id = "Melinoe_5060"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thank you for everything."
      Speaker = "Melinoe"
      Event = "NPC_Zagreus_01.InteractVoiceLines"
    }
    {
      Id = "Melinoe_5061"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Good to see you!"
      Speaker = "Melinoe"
      Event = "NPC_Zagreus_01.InteractVoiceLines"
    }
    {
      Id = "Melinoe_5062"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Prince Zagreus."
      Speaker = "Melinoe"
      Event = "NPC_Zagreus_01.InteractVoiceLines"
    }
    {
      Id = "Melinoe_5063"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Your Highness."
      Speaker = "Melinoe"
      Event = "NPC_Zagreus_01.InteractVoiceLines"
    }
    {
      Id = "Zagreus_0091"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Cheers."
      Speaker = "Zagreus"
      Event = "NPC_Zagreus_01.InteractVoiceLines"
    }
    {
      Id = "Zagreus_0092"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll take it."
      Speaker = "Zagreus"
      Event = "NPC_Zagreus_01.InteractVoiceLines"
    }
    {
      Id = "Zagreus_0093"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Why not!"
      Speaker = "Zagreus"
      Event = "NPC_Zagreus_01.InteractVoiceLines"
    }
    {
      Id = "Zagreus_0094"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We do need help."
      Speaker = "Zagreus"
      Event = "NPC_Zagreus_01.InteractVoiceLines"
    }
    {
      Id = "Zagreus_0096"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Princess Melinoë."
      Speaker = "Zagreus"
      Event = "NPC_Zagreus_01.InteractVoiceLines"
    }
    {
      Id = "Zagreus_0097"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No {#Emph}Your {#Prev}Highness."
      Speaker = "Zagreus"
      Event = "NPC_Zagreus_01.InteractVoiceLines"
    }
    {
      Id = "Zagreus_0089"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You too."
      Speaker = "Zagreus"
      Event = "NPC_Zagreus_01.InteractVoiceLines"
    }
    {
      Id = "Zagreus_0090"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No need."
      Speaker = "Zagreus"
      Event = "NPC_Zagreus_01.InteractVoiceLines"
    }
    {
      Id = "Zagreus_0085"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, I think we can fix up the rest of this place on our own. Thank you for all your help. Especially the part where you liberated us from our temporal prisons and whatnot!"
      Speaker = "Zagreus"
      Event = "ZagreusTrueEnding01"
    }
    {
      Id = "MelinoeField_4981"
      InheritFrom = "BaseNarrative"
      DisplayName = "Believe me, I had nothing better to do! Anyhow, we'll have to find a way to cross paths out there. And each keep an eye on Chronos as we tie up some loose ends."
      Speaker = "Melinoe"
      Event = "ZagreusTrueEnding01"
    }
    {
      Id = "Zagreus_0488"
      InheritFrom = "BaseNarrative"
      DisplayName = "It must be hard to even look at him after everything he did... I can't help but be glad we're all here, but that's easy for me to say, not having been locked in a lifelong conflict..."
      Speaker = "Zagreus"
      Event = "ZagreusTrueEnding01"
    }
    {
      Id = "MelinoeField_5155"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll manage. You helped me realize there even was a path toward this outcome. As I faced Chronos in this House... I started to sense that being cut off from this family was consuming him."
      Speaker = "Melinoe"
      Event = "ZagreusTrueEnding01"
    }
    {
      Id = "Zagreus_0490"
      InheritFrom = "BaseNarrative"
      DisplayName = "It might have consumed him completely. Good thing we make a decent brother-sister team! Past and present, real and imagined. And now we don't even need dream-time-witch-magick to stay in touch!"
      Speaker = "Zagreus"
      Event = "ZagreusTrueEnding01"
    }
    {
      Id = "MelinoeField_5215"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, I suppose not! Feels like we've been through thick and thin together, doesn't it? Even without the memories of a wholly different and generally more-pleasant life. Right now, I'd simply settle for a calmer one."
      Speaker = "Melinoe"
      Event = "ZagreusTrueEnding01"
    }
    {
      Id = "Zagreus_0482"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come on, you're not the settling sort. Anyway I know this isn't goodbye, and we'll be seeing each other... though, still... I'll miss you, Little Sister. And do send Hypnos back if he can't wake up on his own."
      Speaker = "Zagreus"
      Event = "ZagreusTrueEnding01"
    }
    {
      Id = "MelinoeField_4983"
      InheritFrom = "BaseNarrative"
      DisplayName = "He'll wake up. I'm going to miss you too, Big Brother. Take care of everyone, all right?"
      Speaker = "Melinoe"
      Event = "ZagreusTrueEnding01"
    }
    {
      Id = "Zagreus_0087"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I will. You take care, too."
      Speaker = "Zagreus"
      Event = "ZagreusTrueEnding01"
    }
    {
      Id = "Zeus_0310"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yes, thank you."
      Speaker = "Zeus"
      Event = "NPC_Zeus_Story_01.InteractVoiceLines"
    }
    {
      Id = "Zeus_0312"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We need no guide."
      Speaker = "Zeus"
      Event = "NPC_Zeus_Story_01.InteractVoiceLines"
    }
    {
      Id = "Zeus_0275"
      InheritFrom = "BaseNarrative"
      DisplayName = "Welcome, young lady, to our family's glorious abode! You have our thanks for seeing to it that the monster Typhon failed to reach us here."
      Speaker = "Zeus"
      Event = "ZeusPalaceFirstMeeting"
    }
    {
      Id = "Hera_0196"
      InheritFrom = "BaseNarrative"
      DisplayName = "And you have our regrets that my Lord Husband left you to confront that horrid creature on your own. Most of the others are still fortifying the Palace; forgive our rudeness."
      Speaker = "Hera"
      Event = "ZeusPalaceFirstMeeting"
    }
    {
      Id = "MelinoeField_3828"
      InheritFrom = "BaseNarrative"
      DisplayName = "There's nothing to forgive, Queen Hera. I am honored to have met you and King Zeus face to face, and seen the glory of Olympus firsthand. I owe it to your generous support these many nights."
      Speaker = "Melinoe"
      Event = "ZeusPalaceFirstMeeting"
    }
    {
      Id = "Zeus_0276"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come now, Melinoë, we have a shared objective after all! And so long as Chronos sits upon your father's throne, that objective remains incomplete."
      Speaker = "Zeus"
      Event = "ZeusPalaceFirstMeeting"
    }
    {
      Id = "Hera_0197"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hurrying her off when she only just arrived, Husband? Although we've little here for entertainment other than Apollo's plucking. At least our enemies shall be back at our gates before long!"
      Speaker = "Hera"
      Event = "ZeusPalaceFirstMeeting"
    }
    {
      Id = "MelinoeField_3829"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't think I can remain anyhow. I need to consult with the Witch of the Crossroads; she may have thoughts on how to rid ourselves of both our great foes at once."
      Speaker = "Melinoe"
      Event = "ZeusPalaceFirstMeeting"
    }
    {
      Id = "Zeus_0277"
      InheritFrom = "BaseNarrative"
      DisplayName = "We shall find a means, of that I have no doubt! And until then, we shall be better prepared to meet their charge."
      Speaker = "Zeus"
      Event = "ZeusPalaceFirstMeeting"
    }
    {
      Id = "Hera_0198"
      InheritFrom = "BaseNarrative"
      DisplayName = "Go on, my dear. We're unaccustomed to expressing gratitude as you can plainly see. Until such time as your Lord Father and his own Queen are restored, there's little cause for cheer, I think."
      Speaker = "Hera"
      Event = "ZeusPalaceFirstMeeting"
    }
    {
      Id = "MelinoeField_3830"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Perhaps soon enough."
      Speaker = "Melinoe"
      Event = "ZeusPalaceFirstMeeting"
    }
    {
      Id = "Zeus_0278"
      InheritFrom = "BaseNarrative"
      DisplayName = "We got that monstrous fiend once more, young lady, thanks most certainly to you! Such courage in the face of catastrophe, and our Palace remains safe and secure... and further reinforced, should Typhon try for us again."
      Speaker = "Zeus"
      Event = "ZeusPalaceMeeting02"
    }
    {
      Id = "Hera_0199"
      InheritFrom = "BaseNarrative"
      DisplayName = "You were splendid, my dear! Had things grown any more dire, we were preparing for a last resort a son of ours developed. But the cost of it is high indeed. Thus, you have saved us in more ways than one."
      Speaker = "Hera"
      Event = "ZeusPalaceMeeting02"
    }
    {
      Id = "MelinoeField_3840"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's my pleasure to have been of service to our family, Queen Hera, and to see the wonders of these halls once more. Perhaps we may yet permanently dissuade Typhon soon."
      Speaker = "Melinoe"
      Event = "ZeusPalaceMeeting02"
    }
    {
      Id = "Zeus_0279"
      InheritFrom = "BaseNarrative"
      DisplayName = "And what do you have in mind on that account? Our own research has yet to yield a force that could take Typhon without also taking this entire mountain down! He's even fiercer now than when he first attacked us long ago."
      Speaker = "Zeus"
      Event = "ZeusPalaceMeeting02"
    }
    {
      Id = "MelinoeField_3841"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've gathered useful specimens of Typhon's flesh, and we've been studying how we can use it in our craft. But we don't yet have meaningful progress to share..."
      Speaker = "Melinoe"
      Event = "ZeusPalaceMeeting02"
    }
    {
      Id = "Hera_0200"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, come now. Driving back that monster more than once is progress meaningful enough! My Lord Husband thought that your first such victory could have simply been a fluke."
      Speaker = "Hera"
      Event = "ZeusPalaceMeeting02"
    }
    {
      Id = "Zeus_0280"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now, what I said, dear wife, was that a single victory against Typhon did not prove more such victories could be achieved! But now you've demonstrated otherwise, Melinoë, and spurred our hope that we shall rid ourselves of this foul menace soon enough."
      Speaker = "Zeus"
      Event = "ZeusPalaceMeeting02"
    }
    {
      Id = "MelinoeField_3842"
      InheritFrom = "BaseNarrative"
      DisplayName = "King Zeus, Queen Hera, by your leave I ought return with what I found, in case it leads to new discoveries about how we can do just that. Thank you all for your continued aid."
      Speaker = "Melinoe"
      Event = "ZeusPalaceMeeting02"
    }
    {
      Id = "Zeus_0281"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You have our gratitude, in kind."
      Speaker = "Zeus"
      Event = "ZeusPalaceMeeting02"
    }
    {
      Id = "Hera_0201"
      InheritFrom = "BaseNarrative"
      DisplayName = "How my Lord Husband scoffed when first I brought forth that perhaps this {#Emph}deadly witch-niece {#Prev}of his, raised from infancy to vanquish Time itself, could also be of benefit against the Titan's siege! Glad I won {#Emph}that {#Prev} out."
      Speaker = "Hera"
      Event = "ZeusPalaceMeeting03"
    }
    {
      Id = "Zeus_0282"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hera dear, {#Emph}of course {#Prev}we reached agreement on that matter, else my good niece would not be here now! Though tell us, Melinoë, what news of a lasting solution to our predicament? Typhon shows no interest in turning away."
      Speaker = "Zeus"
      Event = "ZeusPalaceMeeting03"
    }
    {
      Id = "MelinoeField_3845"
      InheritFrom = "BaseNarrative"
      DisplayName = "We're getting closer to something. It's very likely that the means we use to rid ourselves of one of our great foes shall be the key to ridding ourselves of the other. Though we have not achieved those means as yet."
      Speaker = "Melinoe"
      Event = "ZeusPalaceMeeting03"
    }
    {
      Id = "Hera_0202"
      InheritFrom = "BaseNarrative"
      DisplayName = "You hear that, Zeus? The greatest inconveniences we face may be resolved at once. We so like doing things efficiently."
      Speaker = "Hera"
      Event = "ZeusPalaceMeeting03"
    }
    {
      Id = "Zeus_0283"
      InheritFrom = "BaseNarrative"
      DisplayName = "You need but tell us what else must be done to facilitate this outcome, Melinoë. Olympus stands at your disposal here."
      Speaker = "Zeus"
      Event = "ZeusPalaceMeeting03"
    }
    {
      Id = "MelinoeField_4268"
      InheritFrom = "BaseNarrative"
      DisplayName = "Please hold out as long as possible, for your blessings and support are invaluable. One way or another, I'll be back as soon as I can. Chronos may have reawakened Typhon, but that same power could unravel him."
      Speaker = "Melinoe"
      Event = "ZeusPalaceMeeting03"
    }
    {
      Id = "Hera_0203"
      InheritFrom = "BaseNarrative"
      DisplayName = "May it be thus. We'd ask you take your time, my dear, but there's no telling how much we can spare. Nevertheless, tread carefully and we shall be awaiting your return."
      Speaker = "Hera"
      Event = "ZeusPalaceMeeting03"
    }
    {
      Id = "MelinoeField_3847"
      InheritFrom = "BaseNarrative"
      DisplayName = "Please hold out as long as possible, for your blessings and support are invaluable. I may be gone for some nights as I turn my attention to Chronos; his power reawakened Typhon, and that same power could unravel {#Emph}him."
      Speaker = "Melinoe"
      Event = "ZeusPalaceMeeting03_A"
    }
    {
      Id = "MelinoeField_3846"
      InheritFrom = "BaseNarrative"
      DisplayName = "This is but a theory at the moment, though we believe it's likely that the means we use to rid ourselves of one of our great foes shall be the key to ridding ourselves of the other. Unfortunately, we have not achieved those means as yet."
      Speaker = "Melinoe"
      Event = "ZeusPalaceMeeting03_B"
    }
    {
      Id = "Zeus_0284"
      InheritFrom = "BaseNarrative"
      DisplayName = "Typhon is not backing down, though we shall drive him back each night he deigns to threaten us, if that is what it takes!"
      Speaker = "Zeus"
      Event = "ZeusPalaceMeeting04"
    }
    {
      Id = "Hera_0204"
      InheritFrom = "BaseNarrative"
      DisplayName = "Either that, or we could probably destroy him, along with this mountain and a good portion of the surrounding countryside... although, where would we live thereafter?"
      Speaker = "Hera"
      Event = "ZeusPalaceMeeting04"
    }
    {
      Id = "Zeus_0285"
      InheritFrom = "BaseNarrative"
      DisplayName = "We needn't weigh that possibility at all, Hera my dear! Best not to even speak of it. Melinoë assured us Typhon could be dealt with in a different way."
      Speaker = "Zeus"
      Event = "ZeusPalaceMeeting04"
    }
    {
      Id = "MelinoeField_3850"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd not intended to make promises on that account, Lord Uncle, though I shall do everything in my power to ensure Olympus stands while Typhon falls... I just need to concentrate on Chronos for a while."
      Speaker = "Melinoe"
      Event = "ZeusPalaceMeeting04"
    }
    {
      Id = "Hera_0205"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well then, pardon my bluntness, my dear, but why aren't you in your Underworld? We now can hold our own, you've seen. But we cannot reach the Titan ourselves."
      Speaker = "Hera"
      Event = "ZeusPalaceMeeting04"
    }
    {
      Id = "Zeus_0286"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do as you must, Melinoë. We shall be waiting to hear word of your success in Tartarus. And you can count on all our blessings on the way!"
      Speaker = "Zeus"
      Event = "ZeusPalaceMeeting04"
    }
    {
      Id = "MelinoeField_3850_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd not intended to make promises on that account, Lord Uncle, though I shall do everything in my power to ensure Olympus stands while Typhon falls..."
      Speaker = "Melinoe"
      Event = "ZeusPalaceMeeting04_B"
    }
    {
      Id = "Zeus_0286_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do as you must, Melinoë. We shall be waiting to hear word of your success. And you can count on all our blessings on the way!"
      Speaker = "Zeus"
      Event = "ZeusPalaceMeeting04_B"
    }
    {
      Id = "Zeus_0287"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, my good niece, you were extraordinary, truly! So far as we can tell, no trace of that monstrosity remains! The deed is {#Emph}done! {#Prev}Typhon is {#Emph}dead!"
      Speaker = "Zeus"
      Event = "ZeusPalaceAboutTyphonDeath01"
    }
    {
      Id = "Hera_0206"
      InheritFrom = "BaseNarrative"
      DisplayName = "My Lord Husband has been premature to declare victory before, so I shall not believe a {#Emph}word {#Prev}of this until I hear it from your lips; perhaps not even then!"
      Speaker = "Hera"
      Event = "ZeusPalaceAboutTyphonDeath01"
    }
    {
      Id = "MelinoeField_3866"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Father of All Monsters is undone... not merely dead, but eradicated, using the power of the Titan of Time, and a bit of assistance from Father's favored spear, Gigaros."
      Speaker = "Melinoe"
      Event = "ZeusPalaceAboutTyphonDeath01"
    }
    {
      Id = "Zeus_0288"
      InheritFrom = "BaseNarrative"
      DisplayName = "You hear {#Emph}that{#Prev}, Hera dear? I {#Emph}told {#Prev}you young Melinoë was certain to prevail on our behalf! Our family always triumphs when we stand together with a common purpose."
      Speaker = "Zeus"
      Event = "ZeusPalaceAboutTyphonDeath01"
    }
    {
      Id = "Hera_0207"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I remain utterly in shock. Well now, girl, if you have {#Emph}truly {#Prev}quashed that {#Emph}monstrous {#Prev}threat, then do prepare yourself for all of us to claim we never doubted you at any point. My Lord Husband is already starting."
      Speaker = "Hera"
      Event = "ZeusPalaceAboutTyphonDeath01"
    }
    {
      Id = "MelinoeField_3867"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you had not believed in me, Queen Hera, then perhaps Typhon would have been here in my stead. So thank you all... and now an even greater victory is within reach."
      Speaker = "Melinoe"
      Event = "ZeusPalaceAboutTyphonDeath01"
    }
    {
      Id = "Zeus_0289"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Titan Chronos... you mean to likewise destroy him using the methods you employed this very night?"
      Speaker = "Zeus"
      Event = "ZeusPalaceAboutTyphonDeath01"
    }
    {
      Id = "MelinoeField_3868"
      InheritFrom = "BaseNarrative"
      DisplayName = "If necessary. Though this power that you witnessed was for Typhon alone, and likewise what we plan for Chronos is fit only for him. The deathless cannot be destroyed unless they threaten the very fabric of the weavings of the Fates."
      Speaker = "Melinoe"
      Event = "ZeusPalaceAboutTyphonDeath01"
    }
    {
      Id = "Hera_0208"
      InheritFrom = "BaseNarrative"
      DisplayName = "No time for feasting till the other deed is done, then, yes? That's fine. The Titan's forces may grow far more desperate now, a possibility for which we ought prepare. We shall lend you all the strength we can for your own final assault."
      Speaker = "Hera"
      Event = "ZeusPalaceAboutTyphonDeath01"
    }
    {
      Id = "Chronos_1077"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Now do you see, my son? Although the Typhon with whom you already clashed is gone, there could have been certain circumstances under which he remained. One fewer {#Emph}now{#Prev}, of course!"
      Speaker = "Chronos"
      Event = "ZeusPalacePostTrueEnding01"
    }
    {
      Id = "Zeus_0290"
      InheritFrom = "BaseNarrative"
      DisplayName = "And how many of these circumstances {#Emph}are {#Prev}there, would you say, Father? For we cannot expect Melinoë to battle to our mountaintop for all eternity..."
      Speaker = "Zeus"
      Event = "ZeusPalacePostTrueEnding01"
    }
    {
      Id = "Hera_0209"
      InheritFrom = "BaseNarrative"
      DisplayName = "Speaking of which, welcome again, my dear! We were just having ourselves a bit of a chat with your grandfather. We've not decided what to do with him as yet, you see."
      Speaker = "Hera"
      Event = "ZeusPalacePostTrueEnding01"
    }
    {
      Id = "Chronos_1078"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, hello, Granddaughter! I had assured the King and Queen that you would be victorious again, for you had been victorious before! Thank you for validating my theories."
      Speaker = "Chronos"
      Event = "ZeusPalacePostTrueEnding01"
    }
    {
      Id = "MelinoeField_5076"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, you're welcome. King Zeus, Queen Hera... I can attest these possibilities of Typhon do appear to exist, having just found one with Grandfather's assistance and eradicated it."
      Speaker = "Melinoe"
      Event = "ZeusPalacePostTrueEnding01"
    }
    {
      Id = "Chronos_1079"
      InheritFrom = "BaseNarrative"
      DisplayName = "Typhon is closer to a Shade of himself now. The possibility of his dominion over Olympus has grown faint, and fainter still with each of your successes. But how {#Emph}many {#Prev}are required, I unfortunately cannot calculate..."
      Speaker = "Chronos"
      Event = "ZeusPalacePostTrueEnding01"
    }
    {
      Id = "Hera_0210"
      InheritFrom = "BaseNarrative"
      DisplayName = "And why not? Perhaps if we persuaded you sufficiently, Titan, you'd be inclined to answer in a more-straightforward way."
      Speaker = "Hera"
      Event = "ZeusPalacePostTrueEnding01"
    }
    {
      Id = "Chronos_1080"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have but recently learned of these possibilities myself. Time is flowing freely forth, for the most part; my granddaughter merely can ensure that there are no obstructions of concern, at her convenience of course."
      Speaker = "Chronos"
      Event = "ZeusPalacePostTrueEnding01"
    }
    {
      Id = "MelinoeField_5077"
      InheritFrom = "BaseNarrative"
      DisplayName = "And I would see to that, however long it takes. By your leave, of course, O King and Queen. I ask that you permit Grandfather to carry on. Thus far he's been true to his word."
      Speaker = "Melinoe"
      Event = "ZeusPalacePostTrueEnding01"
    }
    {
      Id = "Zeus_0291"
      InheritFrom = "BaseNarrative"
      DisplayName = "We do have something suitable for you in mind, Father. But due to matters of security, our Palace henceforth is to be sealed off. Melinoë, perhaps when your mother resumes her yearly travels here, you may, {#Emph}erm{#Prev}, come visit again."
      Speaker = "Zeus"
      Event = "ZeusPalacePostTrueEnding01"
    }
    {
      Id = "Hera_0211"
      InheritFrom = "BaseNarrative"
      DisplayName = "We've been such awful hosts to you, my dear. We never intended for any of this to occur! But we have pledged you our support before, and you shall have it for as long as you require. Even if we bicker over it now and again."
      Speaker = "Hera"
      Event = "ZeusPalacePostTrueEnding01"
    }
    {
      Id = "Zeus_0292"
      InheritFrom = "BaseNarrative"
      DisplayName = "We've rid ourselves of Typhon for the time, but not for good. If Chronos stands between us and that outcome, then we urge you to pursue {#Emph}him {#Prev}next."
      Speaker = "Zeus"
      Event = "ZeusPalaceMeetingRepeatable01"
    }
    {
      Id = "Hera_0212"
      InheritFrom = "BaseNarrative"
      DisplayName = "My Lord Husband does not mean to pressure you, I'm sure, my dear. But do feel free to leave the defense of the mountain to us whilst tending to any other matters."
      Speaker = "Hera"
      Event = "ZeusPalaceMeetingRepeatable01"
    }
    {
      Id = "MelinoeField_3853"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Your Majesty."
      Speaker = "Melinoe"
      Event = "ZeusPalaceMeetingRepeatable01"
    }
    {
      Id = "Zeus_0293"
      InheritFrom = "BaseNarrative"
      DisplayName = "Another victory is ours! We are most grateful for your service to our family, Melinoë. May your defeat of Chronos be as swift."
      Speaker = "Zeus"
      Event = "ZeusPalaceMeetingRepeatable02"
    }
    {
      Id = "Hera_0213"
      InheritFrom = "BaseNarrative"
      DisplayName = "And may we soon discover how to put that monstrous Typhon back into the earth where he belongs. Do keep us well-apprised!"
      Speaker = "Hera"
      Event = "ZeusPalaceMeetingRepeatable02"
    }
    {
      Id = "MelinoeField_3854"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yes, Queen Hera."
      Speaker = "Melinoe"
      Event = "ZeusPalaceMeetingRepeatable02"
    }
    {
      Id = "Hera_0214"
      InheritFrom = "BaseNarrative"
      DisplayName = "Again you sent that Typhon howling to the base of our mountain, though he is likely to return. But perhaps one of these nights shall be his last."
      Speaker = "Hera"
      Event = "ZeusPalaceMeetingRepeatable03"
    }
    {
      Id = "Zeus_0294"
      InheritFrom = "BaseNarrative"
      DisplayName = "We appreciate all of your aid, young lady, though do not leave Chronos unattended! Especially if his defeat is key to our final victory."
      Speaker = "Zeus"
      Event = "ZeusPalaceMeetingRepeatable03"
    }
    {
      Id = "MelinoeField_3855"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thank you all."
      Speaker = "Melinoe"
      Event = "ZeusPalaceMeetingRepeatable03"
    }
    {
      Id = "Hera_0215"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're always welcome on these grounds, my dear, but we are {#Emph}never {#Prev}going to be at our finest so long as the threat of Typhon looms large."
      Speaker = "Hera"
      Event = "ZeusPalaceMeetingRepeatable04"
    }
    {
      Id = "Zeus_0295"
      InheritFrom = "BaseNarrative"
      DisplayName = "He's gone at least for now, but he'll be back. That is unless Melinoë is able to get rid of him entirely, as she suggested should be possible!"
      Speaker = "Zeus"
      Event = "ZeusPalaceMeetingRepeatable04"
    }
    {
      Id = "MelinoeField_3856"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We're getting closer."
      Speaker = "Melinoe"
      Event = "ZeusPalaceMeetingRepeatable04"
    }
    {
      Id = "Hera_0224"
      InheritFrom = "BaseSubtitle"
      DisplayName = "If you insist!"
      Speaker = "Hera"
      Event = "NPC_Hera_Story_01.InteractVoiceLines"
    }
    {
      Id = "Hera_0225"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How fierce."
      Speaker = "Hera"
      Event = "NPC_Hera_Story_01.InteractVoiceLines"
    }
    {
      Id = "Hera_0226"
      InheritFrom = "BaseSubtitle"
      DisplayName = "To where?"
      Speaker = "Hera"
      Event = "NPC_Hera_Story_01.InteractVoiceLines"
    }
    {
      Id = "Hera_0227"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Of course."
      Speaker = "Hera"
      Event = "NPC_Hera_Story_01.InteractVoiceLines"
    }
    {
      Id = "Hera_0228"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Mm-hm."
      Speaker = "Hera"
      Event = "NPC_Hera_Story_01.InteractVoiceLines"
    }
    {
      Id = "Apollo_0178"
      InheritFrom = "BaseNarrative"
      DisplayName = "You did it, sunshine! I'd say I knew you would, but the truth is, I had an inkling of doubt... especially once I saw Typhon for myself."
      Speaker = "Apollo"
      Event = "ApolloPalaceFirstMeeting"
    }
    {
      Id = "MelinoeField_3831"
      InheritFrom = "BaseNarrative"
      DisplayName = "He was quite large, I'll give him that! It's a pleasure to finally meet you face-to-face like this, Cousin. You play most beautifully!"
      Speaker = "Melinoe"
      Event = "ApolloPalaceFirstMeeting"
    }
    {
      Id = "Apollo_0179"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, anything to take our minds off of what's happening. At least you bought us a bit of reprieve so I could play again at all. Typhon is going to be back, though, isn't he...?"
      Speaker = "Apollo"
      Event = "ApolloPalaceFirstMeeting"
    }
    {
      Id = "MelinoeField_3832"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd count on that. But I am going to be back as well. For now, please bolster your defenses, and make ready for the monster's next attack. Now I had better go... my headmistress is expecting my return."
      Speaker = "Melinoe"
      Event = "ApolloPalaceFirstMeeting"
    }
    {
      Id = "Apollo_0180"
      InheritFrom = "BaseNarrative"
      DisplayName = "Can't you just contact her by Boon? I'll bring one forth for you in case that works. And thanks for everything, Cousin."
      Speaker = "Apollo"
      Event = "ApolloPalaceFirstMeeting"
    }
    {
      Id = "Apollo_0182"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's good to see you again, Cousin. Just as I was beginning to fear my song would be tonight's sole source of cheer!"
      Speaker = "Apollo"
      Event = "ApolloPalaceMeeting02"
    }
    {
      Id = "MelinoeField_3843"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lord Apollo, good to see you too. Please give my regards to the others... I would have liked to meet, but had best be getting back."
      Speaker = "Melinoe"
      Event = "ApolloPalaceMeeting02"
    }
    {
      Id = "Apollo_0183"
      InheritFrom = "BaseNarrative"
      DisplayName = "Of course, you must be on your last legs. The others surely would have liked to see you too, especially your grandmother, but they couldn't leave their posts. Please accept our apologies, and let us help you to return."
      Speaker = "Apollo"
      Event = "ApolloPalaceMeeting02"
    }
    {
      Id = "MelinoeField_3844"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Tell Lady Demeter and everyone I wish them well."
      Speaker = "Melinoe"
      Event = "ApolloPalaceMeeting02"
    }
    {
      Id = "Apollo_0184"
      InheritFrom = "BaseNarrative"
      DisplayName = "You truly think we'll soon get blasted Typhon well out of our way for good? That'd be a welcome change."
      Speaker = "Apollo"
      Event = "ApolloPalaceMeeting03"
    }
    {
      Id = "MelinoeField_3848"
      InheritFrom = "BaseNarrative"
      DisplayName = "If we can rid ourselves of Chronos, then we should be able to rid ourselves of the Father of All Monsters, too. And I have not been training all my life for this only to fail now."
      Speaker = "Melinoe"
      Event = "ApolloPalaceMeeting03"
    }
    {
      Id = "Apollo_0185"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well! Remind me never to get on your bad side, sunshine. You ready to head home? Always good to see you, though I'd best get back to singing so that everyone stays calm."
      Speaker = "Apollo"
      Event = "ApolloPalaceMeeting03"
    }
    {
      Id = "MelinoeField_3849"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We have this."
      Speaker = "Melinoe"
      Event = "ApolloPalaceMeeting03"
    }
    {
      Id = "MelinoeField_3851"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your song is such a welcome sound after a hard night's climb, Cousin. It nearly makes me forget the troubles we're dealing with. All this light, however, I'm not used to yet..."
      Speaker = "Melinoe"
      Event = "ApolloPalaceMeeting04"
    }
    {
      Id = "Apollo_0186"
      InheritFrom = "BaseNarrative"
      DisplayName = "We're not much used to it here either for how dark it's been of late. Though let's get you back before it drains you more. Sounds like you have to pay Chronos a visit soon."
      Speaker = "Apollo"
      Event = "ApolloPalaceMeeting04"
    }
    {
      Id = "MelinoeField_3852"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That I do."
      Speaker = "Melinoe"
      Event = "ApolloPalaceMeeting04"
    }
    {
      Id = "Apollo_0186_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "We're not much used to it here either for how dark it's been of late. Though let's get you back before it drains you more."
      Speaker = "Apollo"
      Event = "ApolloPalaceMeeting04_B"
    }
    {
      Id = "Apollo_0187"
      InheritFrom = "BaseNarrative"
      DisplayName = "That monster, truly gone... you got him, forever! Not that my faith in you wavered since your initial victory, it's just... I still can't entirely believe it. So now for Chronos, then?"
      Speaker = "Apollo"
      Event = "ApolloPalaceAboutTyphonDeath01"
    }
    {
      Id = "MelinoeField_3869"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now for Chronos, then. One encouraging result can often spur another. And perhaps all of you shall have a brief reprieve. I'm certain you could use it."
      Speaker = "Melinoe"
      Event = "ApolloPalaceAboutTyphonDeath01"
    }
    {
      Id = "Apollo_0188"
      InheritFrom = "BaseNarrative"
      DisplayName = "With Prometheus and such still causing problems, we won't be getting all too comfortable just yet. Especially not while our main foe is out there still. Go get him, sunshine."
      Speaker = "Apollo"
      Event = "ApolloPalaceAboutTyphonDeath01"
    }
    {
      Id = "MelinoeField_3870"
      InheritFrom = "BaseSubtitle"
      DisplayName = "On it."
      Speaker = "Melinoe"
      Event = "ApolloPalaceAboutTyphonDeath01"
    }
    {
      Id = "Apollo_0189"
      InheritFrom = "BaseNarrative"
      DisplayName = "We ought to be feasting in your name as far as I'm concerned, sunshine. But no sign of Dionysus still, and our new guest has drawn most of the attention. Soon we also won't be letting anybody in from the outside."
      Speaker = "Apollo"
      Event = "ApolloPalacePostTrueEnding01"
    }
    {
      Id = "MelinoeField_3920"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's all right, Cousin, as I'm not much for feasting anyhow. And we do need to find a place for this grandfather of ours. Do you know what Lord Uncle Zeus has in store for him?"
      Speaker = "Melinoe"
      Event = "ApolloPalacePostTrueEnding01"
    }
    {
      Id = "Apollo_0190"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not entirely, but my impression is he's sending Chronos back into the Underworld, to Lord Hades. Apparently they've reached some sort of bargain. So, you truly think our grandfather has changed?"
      Speaker = "Apollo"
      Event = "ApolloPalacePostTrueEnding01"
    }
    {
      Id = "MelinoeField_3921"
      InheritFrom = "BaseNarrative"
      DisplayName = "I think he has a different outlook on things, yes. As for me, sounds like I may not be able to return anytime soon. This place truly is beyond compare, and with each visit you've made me feel welcome. Thank you for that and everything."
      Speaker = "Melinoe"
      Event = "ApolloPalacePostTrueEnding01"
    }
    {
      Id = "Apollo_0191"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, come on, it's all of us who should be thanking you, and quite profusely I should add. Anyhow, not like this is a permanent farewell. I'll keep in touch by Boon, all right?"
      Speaker = "Apollo"
      Event = "ApolloPalacePostTrueEnding01"
    }
    {
      Id = "MelinoeField_3922"
      InheritFrom = "BaseSubtitle"
      DisplayName = "All right."
      Speaker = "Melinoe"
      Event = "ApolloPalacePostTrueEnding01"
    }
    {
      Id = "Apollo_0192"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ready to head back again? Here, let me light the way."
      Speaker = "Apollo"
      Event = "ApolloPalacePostZeusChat01"
    }
    {
      Id = "Apollo_0193"
      InheritFrom = "BaseNarrative"
      DisplayName = "Splendid work as usual, sunshine. We're all grateful you made the trip."
      Speaker = "Apollo"
      Event = "ApolloPalacePostZeusChat02"
    }
    {
      Id = "Apollo_0194"
      InheritFrom = "BaseNarrative"
      DisplayName = "By now you'd probably much rather be where it isn't quite this bright."
      Speaker = "Apollo"
      Event = "ApolloPalacePostZeusChat03"
    }
    {
      Id = "Apollo_0195"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's only thanks to you that I can sit and strum here at a time like this."
      Speaker = "Apollo"
      Event = "ApolloPalacePostZeusChat04"
    }
    {
      Id = "Apollo_0181"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wish you could stay since you just got here, though I know it's not the time. Be safe out there."
      Speaker = "Apollo"
      Event = "ApolloPalacePostZeusChat05"
    }
    {
      Id = "Apollo_0196"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's good to see you, sunshine, but you'd best speak to Father first."
      Speaker = "Apollo"
      Event = "ApolloPalacePreZeusChat01"
    }
    {
      Id = "Apollo_0197"
      InheritFrom = "BaseNarrative"
      DisplayName = "Best not to keep your Lord Uncle waiting. I'll be right here."
      Speaker = "Apollo"
      Event = "ApolloPalacePreZeusChat02"
    }
    {
      Id = "Apollo_0198"
      InheritFrom = "BaseNarrative"
      DisplayName = "I, {#Emph}erm{#Prev}, think the King and Queen might like a word?"
      Speaker = "Apollo"
      Event = "ApolloPalacePreZeusChat03"
    }
    {
      Id = "MelinoeField_4326"
      InheritFrom = "BaseSubtitle"
      DisplayName = "So good to see you."
      Speaker = "Melinoe"
      Event = "NPC_Demeter_Story_01.InteractVoiceLines"
    }
    {
      Id = "MelinoeField_4327"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hail, Lady Demeter!"
      Speaker = "Melinoe"
      Event = "NPC_Demeter_Story_01.InteractVoiceLines"
    }
    {
      Id = "MelinoeField_4328"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Grandmother."
      Speaker = "Melinoe"
      Event = "NPC_Demeter_Story_01.InteractVoiceLines"
    }
    {
      Id = "Demeter_0205"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And you of course."
      Speaker = "Demeter"
      Event = "NPC_Demeter_Story_01.InteractVoiceLines"
    }
    {
      Id = "Demeter_0206"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Grandmother."
      Speaker = "Demeter"
      Event = "NPC_Demeter_Story_01.InteractVoiceLines"
    }
    {
      Id = "Demeter_0207"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hm."
      Speaker = "Demeter"
      Event = "NPC_Demeter_Story_01.InteractVoiceLines"
    }
    {
      Id = "Demeter_0208"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Let it be done."
      Speaker = "Demeter"
      Event = "NPC_Demeter_Story_01.InteractVoiceLines"
    }
    {
      Id = "Demeter_0209"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I know the way."
      Speaker = "Demeter"
      Event = "NPC_Demeter_Story_01.InteractVoiceLines"
    }
    {
      Id = "Demeter_0210"
      InheritFrom = "BaseSubtitle"
      DisplayName = "As you say."
      Speaker = "Demeter"
      Event = "NPC_Demeter_Story_01.InteractVoiceLines"
    }
    {
      Id = "Demeter_0211"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Very well."
      Speaker = "Demeter"
      Event = "NPC_Demeter_Story_01.InteractVoiceLines"
    }
    {
      Id = "Demeter_0196"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, flower, it's truly {#Emph}you! {#Prev}Forgive me, I... we must maintain decorum here, but... I am very pleased to see you here before me, rather than within the dimness of a Boon."
      Speaker = "Demeter"
      Event = "DemeterPalaceFirstMeeting"
    }
    {
      Id = "MelinoeField_4318"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lady Demeter, the honor is mine. I know that everyone's preoccupied contending with the siege, and it couldn't have been easy for you to be here now."
      Speaker = "Melinoe"
      Event = "DemeterPalaceFirstMeeting"
    }
    {
      Id = "Demeter_0197"
      InheritFrom = "BaseNarrative"
      DisplayName = "Please, call me grandmother; although perhaps not here. I was furious to have missed you when you visited before, and was not about to let that reoccur. But you cannot stay can you...?"
      Speaker = "Demeter"
      Event = "DemeterPalaceFirstMeeting"
    }
    {
      Id = "MelinoeField_4319"
      InheritFrom = "BaseNarrative"
      DisplayName = "Unfortunately not. With Typhon dealt with for the moment, I had best be getting back. I'm so grateful to have met you like this! Shall I see you again?"
      Speaker = "Melinoe"
      Event = "DemeterPalaceFirstMeeting"
    }
    {
      Id = "Demeter_0198"
      InheritFrom = "BaseSubtitle"
      DisplayName = "If the Fates have any mercy in their hearts, then yes."
      Speaker = "Demeter"
      Event = "DemeterPalaceFirstMeeting"
    }
    {
      Id = "Demeter_0200"
      InheritFrom = "BaseNarrative"
      DisplayName = "The storm has passed... that monster turned the weather such that not even Lord Zeus or I could stop it properly. But now he's gone, and we have you to thank."
      Speaker = "Demeter"
      Event = "DemeterPalaceAboutTyphonDeath01"
    }
    {
      Id = "MelinoeField_4321"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thanks are owed all around, Grandmother. Typhon gave in to the combined might of the gods. I merely concentrated our fell strength. Now to press this advantage."
      Speaker = "Melinoe"
      Event = "DemeterPalaceAboutTyphonDeath01"
    }
    {
      Id = "Demeter_0201"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps not even Chronos can withstand what you unleashed. But be careful, Granddaughter. Make certain we shall meet again."
      Speaker = "Demeter"
      Event = "DemeterPalaceAboutTyphonDeath01"
    }
    {
      Id = "MelinoeField_4322"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We will."
      Speaker = "Melinoe"
      Event = "DemeterPalaceAboutTyphonDeath01"
    }
    {
      Id = "MelinoeField_4323"
      InheritFrom = "BaseNarrative"
      DisplayName = "We did it, Grandmother! You've fought so hard for me... for all of us. But, it must be difficult, to see Chronos again."
      Speaker = "Melinoe"
      Event = "DemeterPalacePostTrueEnding01"
    }
    {
      Id = "Demeter_0203"
      InheritFrom = "BaseNarrative"
      DisplayName = "I shall not dignify him with so much as a passing glance, Melinoë. The Titan would have reached a different end were it for me to decide, but... I'm grateful that the outcome was not worse."
      Speaker = "Demeter"
      Event = "DemeterPalacePostTrueEnding01"
    }
    {
      Id = "MelinoeField_4324"
      InheritFrom = "BaseNarrative"
      DisplayName = "From what I gathered, this may be farewell for a while. At least face-to-face! I'll still be seeing you most nights, if you'll be able to keep aiding me by Boon."
      Speaker = "Melinoe"
      Event = "DemeterPalacePostTrueEnding01"
    }
    {
      Id = "Demeter_0204"
      InheritFrom = "BaseNarrative"
      DisplayName = "Of course. And there shall come a time again when your mother shall be visiting us half the year. Perhaps then you may come along, once every few seasons at least."
      Speaker = "Demeter"
      Event = "DemeterPalacePostTrueEnding01"
    }
    {
      Id = "Demeter_0281"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, and here... to keep you warm."
      Speaker = "Demeter"
      Event = "DemeterPalacePostTrueEnding01"
    }
    {
      Id = "MelinoeField_5019"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Grandmother, is this for me? Thank you..."
      Speaker = "Melinoe"
      Event = "DemeterPalacePostTrueEnding01"
    }
    {
      Id = "MelinoeField_4325"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I would like that."
      Speaker = "Melinoe"
      Event = "DemeterPalacePostTrueEnding01_B"
    }
    {
      Id = "Chronos_1419"
      InheritFrom = "BaseNarrative"
      DisplayName = "There you are, at last! You might have kept me searching for a while yet, that you found such a secure hiding-point amid those shadows!"
      Speaker = "Chronos"
      Event = "MelinoeHideAndSeek01"
    }
    {
      Id = "MelinoeField_5056"
      InheritFrom = "BaseNarrative"
      DisplayName = "It sure took you long enough! I was beginning to think I might never see you again!"
      Speaker = "Melinoe"
      Event = "MelinoeHideAndSeek01"
    }
    {
      Id = "Chronos_1420"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hah! {#Prev}That is precisely what your father said when Zagreus first brought me here! Well, are we to suffer through another round?"
      Speaker = "Chronos"
      Event = "MelinoeHideAndSeek01"
    }
    {
      Id = "MelinoeField_5057"
      InheritFrom = "BaseNarrative"
      DisplayName = "No... this game is too easy. Tell me another one of your tales! About the Golden Age!"
      Speaker = "Melinoe"
      Event = "MelinoeHideAndSeek01"
    }
    {
      Id = "Chronos_1421"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps when you are older, lest your father be displeased. If {#Emph}you {#Prev}defy him, you merely get a mild reprimand. If {#Emph}I {#Prev}defy him, I get cut to little bite-sized bits, which then are sprinkled throughout Tartarus!"
      Speaker = "Chronos"
      Event = "MelinoeHideAndSeek01"
    }
    {
      Id = "MelinoeField_5058"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Haha, ew! {#Prev}Well if Father ever does that, I shall simply go find all the bits and put you back together again!"
      Speaker = "Melinoe"
      Event = "MelinoeHideAndSeek01"
    }
    {
      Id = "Chronos_1422"
      InheritFrom = "BaseNarrative"
      DisplayName = "Spoken with the generosity of youth. You are the only one around here who would say such things, Melinoë."
      Speaker = "Chronos"
      Event = "MelinoeHideAndSeek01"
    }
    {
      Id = "MelinoeField_5059"
      InheritFrom = "BaseNarrative"
      DisplayName = "Truly? But, don't the others like you, Grandfather?"
      Speaker = "Melinoe"
      Event = "MelinoeHideAndSeek01"
    }
    {
      Id = "Chronos_1423"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, they can never get enough of me, my girl, except... we still have had our differences. But let me not concern you with the past. The only time that matters is right now. And right now..."
      Speaker = "Chronos"
      Event = "MelinoeHideAndSeek01"
    }
    {
      Id = "Chronos_1424"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Tag! {#Prev}You are it!"
      Speaker = "Chronos"
      Event = "MelinoeHideAndSeek01"
    }
    {
      Id = "MelinoeField_5060"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Haha! Hey! {#Prev}No fair!"
      Speaker = "Melinoe"
      Event = "MelinoeHideAndSeek01"
    }
    {
      Id = "MelinoeField_5165"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It's been an honor, sir."
      Speaker = "Melinoe"
      Event = "NPC_Achilles_01.InteractVoiceLines"
    }
    {
      Id = "Achilles_0006"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The honor is mine."
      Speaker = "Achilles"
      Event = "NPC_Achilles_01.InteractVoiceLines"
    }
    {
      Id = "Achilles_0003"
      InheritFrom = "BaseNarrative"
      DisplayName = "Heading out? Olympus doesn't like to be kept waiting, I know. We'll remember you here, lass! Somehow it still feels as if we've only met. What an unusual time..."
      Speaker = "Achilles"
      Event = "AchillesTrueEnding01"
    }
    {
      Id = "MelinoeField_5216"
      InheritFrom = "BaseNarrative"
      DisplayName = "That it is, Achilles sir. I have these glimpses now of cherished moments I might have spent with you and the other Houseservants, had the past but gone differently. Are the others doing well?"
      Speaker = "Melinoe"
      Event = "AchillesTrueEnding01"
    }
    {
      Id = "Achilles_0004"
      InheritFrom = "BaseNarrative"
      DisplayName = "They seem to be. Your relatives recovered the most swiftly, but I think we're all still feeling some effects... and catching up on everything we missed, and aiding where we can."
      Speaker = "Achilles"
      Event = "AchillesTrueEnding01"
    }
    {
      Id = "MelinoeField_5231"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll miss you all. This really does feel like a dream, at times! I fear I may forget it, as one tends to do with dreams."
      Speaker = "Melinoe"
      Event = "AchillesTrueEnding01"
    }
    {
      Id = "Achilles_0005"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Heh. {#Prev}I trust you'll still remember what I always told you about fear. Please don't worry... I know we may not see you for a while, but I shall await whenever we may meet again."
      Speaker = "Achilles"
      Event = "AchillesTrueEnding01"
    }
    {
      Id = "MelinoeField_5164"
      InheritFrom = "BaseSubtitle"
      DisplayName = "As shall I."
      Speaker = "Melinoe"
      Event = "AchillesTrueEnding01"
    }
    {
      Id = "Apollo_0199"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's for you."
      Speaker = "Apollo"
      Event = "GlobalVoiceLines.ApolloSendOffVoiceLines"
    }
    {
      Id = "Apollo_0200"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Should help you get home."
      Speaker = "Apollo"
      Event = "GlobalVoiceLines.ApolloSendOffVoiceLines"
    }
    {
      Id = "Apollo_0201"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Take care now."
      Speaker = "Apollo"
      Event = "GlobalVoiceLines.ApolloSendOffVoiceLines"
    }
    {
      Id = "Apollo_0202"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's your Boon."
      Speaker = "Apollo"
      Event = "GlobalVoiceLines.ApolloSendOffVoiceLines"
    }
    {
      Id = "MelinoeField_3833"
      InheritFrom = "BaseSubtitle"
      DisplayName = "May I...?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.ApolloSendOffVoiceLines"
    }
    {
      Id = "Zeus_0304"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Farewell!"
      Speaker = "Zeus"
      Event = "GlobalVoiceLines.ZeusSendOffVoiceLines"
    }
    {
      Id = "Zeus_0305"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Till we meet again."
      Speaker = "Zeus"
      Event = "GlobalVoiceLines.ZeusSendOffVoiceLines"
    }
    {
      Id = "Zeus_0307"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You have our blessings."
      Speaker = "Zeus"
      Event = "GlobalVoiceLines.ZeusSendOffVoiceLines"
    }
    {
      Id = "Zeus_0308"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Onward!"
      Speaker = "Zeus"
      Event = "GlobalVoiceLines.ZeusSendOffVoiceLines"
    }
    {
      Id = "Zeus_0309"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Be well."
      Speaker = "Zeus"
      Event = "GlobalVoiceLines.ZeusSendOffVoiceLines"
    }
    {
      Id = "Hera_0220"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Fare you well!"
      Speaker = "Hera"
      Event = "GlobalVoiceLines.HeraSendOffVoiceLines"
    }
    {
      Id = "Hera_0221"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Take care."
      Speaker = "Hera"
      Event = "GlobalVoiceLines.HeraSendOffVoiceLines"
    }
    {
      Id = "Hera_0222"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Goodbye."
      Speaker = "Hera"
      Event = "GlobalVoiceLines.HeraSendOffVoiceLines"
    }
    {
      Id = "Hera_0223"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come back soon!"
      Speaker = "Hera"
      Event = "GlobalVoiceLines.HeraSendOffVoiceLines"
    }
    {
      Id = "MelinoeField_3410"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not yet... In dream I shall remain Unseen."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MirrorInitialInspectLines"
    }
    {
      Id = "MelinoeField_3411"
      InheritFrom = "BaseNarrative"
      DisplayName = "So many dreams upon this very spot... then, one more."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DreamBedUsedLines"
    }
    {
      Id = "MelinoeField_3412"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}To the abyss of the subconscious I descend...!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DreamBedUsedLines"
    }
    {
      Id = "MelinoeField_3413"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}To the abyss of the subconscious I descend...!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DreamBedUsedLines"
    }
    {
      Id = "MelinoeField_5192"
      InheritFrom = "BaseNarrative"
      DisplayName = "OK. {#Emph}To the abyss of the subconscious I descend...!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DreamBedUsedLines"
    }
    {
      Id = "MelinoeField_5191"
      InheritFrom = "BaseNarrative"
      DisplayName = "Again. {#Emph}To the abyss of the subconscious I descend...!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DreamBedUsedLines"
    }
    {
      Id = "MelinoeField_5193"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Whew... To the abyss of the subconscious I descend...!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DreamBedUsedLines"
    }
    {
      Id = "MelinoeField_5042"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Whew{#Prev}, OK... focus..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DreamPresentationLines"
    }
    {
      Id = "MelinoeField_3414"
      InheritFrom = "BaseNarrative"
      DisplayName = "A connection... step one..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DreamPresentationLines"
    }
    {
      Id = "MelinoeField_3415"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now the Mirror..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DreamPresentationLines"
    }
    {
      Id = "MelinoeField_3416"
      InheritFrom = "BaseNarrative"
      DisplayName = "It worked..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DreamPresentationLines"
    }
    {
      Id = "MelinoeField_3409"
      InheritFrom = "BaseNarrative"
      DisplayName = "Something beside the bed...?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.DreamPresentationLines"
    }
    {
      Id = "MelinoeField_3417"
      InheritFrom = "BaseNarrative"
      DisplayName = "...And now step two."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MirrorUsedLines"
    }
    {
      Id = "MelinoeField_5196"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Night and Darkness? Guide me to my blood beyond the grasp of Time!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MirrorUsedLines"
    }
    {
      Id = "MelinoeField_3418"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Night and Darkness, guide me to my blood beyond the grasp of Time!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MirrorUsedLines"
    }
    {
      Id = "MelinoeField_3419"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Night and Darkness, guide me to my blood beyond the grasp of Time...!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MirrorUsedLines"
    }
    {
      Id = "MelinoeField_5194"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now. {#Emph}Night and Darkness, guide me to my blood beyond the grasp of Time...!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MirrorUsedLines"
    }
    {
      Id = "MelinoeField_5195"
      InheritFrom = "BaseNarrative"
      DisplayName = "Once more. {#Emph}Night and Darkness, guide me to my blood beyond the grasp of Time!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.MirrorUsedLines"
    }
    {
      Id = "MelinoeField_3420"
      InheritFrom = "BaseNarrative"
      DisplayName = "The mists of memory..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.TimeHallPresentationLines"
    }
    {
      Id = "MelinoeField_5205"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress... you always said to trust my instincts. So here goes..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.TimeHallPresentationLines"
    }
    {
      Id = "MelinoeField_5041"
      InheritFrom = "BaseNarrative"
      DisplayName = "All right, need to calm myself... can't make him more nervous than me..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.TimeHallPresentationLines"
    }
    {
      Id = "Zagreus_0002"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Augh {#Prev}stay down blast you! I've tried water, oil, Nectar, Ambrosia, but {#Emph}no!"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastMirrorLines"
    }
    {
      Id = "MelinoeField_3421"
      InheritFrom = "BaseNarrative"
      DisplayName = "That voice, it's..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.ZagreusPastMirrorLines"
    }
    {
      Id = "Zagreus_0003"
      InheritFrom = "BaseNarrative"
      DisplayName = "What about blood? Not tried blood... which would be utter madness, but I'm running out of reasonable options here."
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastMirrorLines"
    }
    {
      Id = "Zagreus_0004"
      InheritFrom = "BaseNarrative"
      DisplayName = "I could try asking nicely. {#Emph}Hair? {#Prev}Would you mind staying down a bit? {#Emph}Please? {#Prev}This is supposed to be a special occasion."
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastMirrorLines"
    }
    {
      Id = "Zagreus_0005"
      InheritFrom = "BaseNarrative"
      DisplayName = "You won't listen. You're mocking me! {#Emph}Fine. {#Prev}I see how it is. Well two can play at that you know!"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastMirrorLines"
    }
    {
      Id = "Zagreus_0006"
      InheritFrom = "BaseNarrative"
      DisplayName = "What if I simply chop you off? Would you like that? I'll go get Stygius again and cut you clean! You think on that a bit!"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastMirrorLines"
    }
    {
      Id = "Zagreus_0017"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just... stay... {#Emph}down! {#Prev}No... {#Emph}augh{#Prev}, blast... I thought I had you there. I {#Emph}had {#Prev}you there! You're weakening. Perhaps?"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastMirrorLines"
    }
    {
      Id = "MelinoeField_3422"
      InheritFrom = "BaseNarrative"
      DisplayName = "Brother...?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.ZagreusPastMirrorLines"
    }
    {
      Id = "Zagreus_0042"
      InheritFrom = "BaseNarrative"
      DisplayName = "This has to work... it has to... I mean why wouldn't it? If everything she says has happened will happen."
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastMirrorLines"
    }
    {
      Id = "Zagreus_0043"
      InheritFrom = "BaseNarrative"
      DisplayName = "I mean it just makes sense. Doesn't it? {#Emph}Augh. {#Prev}Well anyway we'll find out soon enough. If she shows up."
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastMirrorLines"
    }
    {
      Id = "Zagreus_0062"
      InheritFrom = "BaseNarrative"
      DisplayName = "She looks a bit like Mother, doesn't she... which means... oh, blast... I never thought... I look just like {#Emph}him{#Prev}, then? Only without the beard? {#Emph}Augh..."
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastMirrorLines"
    }
    {
      Id = "Zagreus_0026"
      InheritFrom = "BaseNarrative"
      DisplayName = "This is that dream... which means... she must be close... Melinoë? Melinoë... that's a nice name. Melinoë! Are you out there? No...?"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastMirrorLines"
    }
    {
      Id = "MelinoeField_3423"
      InheritFrom = "BaseNarrative"
      DisplayName = "Brother...!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.ZagreusPastMirrorLines"
    }
    {
      Id = "Zagreus_0034"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come on... come on, where is she...? Where {#Emph}is {#Prev}she? Don't leave me hanging like this Sister, come on... I want to get some proper sleep eventually..."
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastMirrorLines"
    }
    {
      Id = "MelinoeField_3424"
      InheritFrom = "BaseNarrative"
      DisplayName = "Brother..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.ZagreusPastMirrorLines"
    }
    {
      Id = "Zagreus_0442"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's strange, I... think I feel a little stressed. While I'm asleep? Supposed to be calm and relaxed. But then again this is more like a nightmare, I suppose. Well that makes much more sense! I'll just... calmly wait here..."
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastMirrorLines"
    }
    {
      Id = "Zagreus_0452"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Scoff> {#Prev}Haunt my dreams, she says. Well, come on then! This is hardly what I'd call a haunting... just standing around, {#Emph}waiting {#Prev}to be haunted. It's... mildly foreboding, at best. Nowhere near the unnerving sensation one would expect..."
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastMirrorLines"
    }
    {
      Id = "Zagreus_0050"
      InheritFrom = "BaseNarrative"
      DisplayName = "What if something happened... something must have happened... but then how am I still dreaming? If this even is a dream. Oh, blast, where is she... when is she...?"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastMirrorLines"
    }
    {
      Id = "Zagreus_0057"
      InheritFrom = "BaseNarrative"
      DisplayName = "This old Mirror certainly has come in handy, I must say... and I would very much appreciate if it would come in handy again now. Or now? Anytime...?"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastMirrorLines"
    }
    {
      Id = "Zagreus_0067"
      InheritFrom = "BaseNarrative"
      DisplayName = "Where is she... where {#Emph}is {#Prev}she... {#Emph}hrm... {#Prev}well... this isn't the most interesting dream so far, I have to say... although she's never {#Emph}not {#Prev}showed up eventually..."
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastMirrorLines"
    }
    {
      Id = "Zagreus_0068"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hello...? {#Emph}Hello! {#Prev}Sister? Where did she go... I sense her, but..."
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastMirrorLines"
    }
    {
      Id = "Zagreus_0070"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, is that...? I think it's {#Emph}her... {#Prev}Melinoë, can you hear me out there? Say something, would you?"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastMirrorLines"
    }
    {
      Id = "Zagreus_0072"
      InheritFrom = "BaseNarrative"
      DisplayName = "All these dreams of looking in the Mirror recently... oh wait, I think that's {#Emph}her... {#Prev}Melinoë, you there?"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastMirrorLines"
    }
    {
      Id = "Zagreus_0075"
      InheritFrom = "BaseNarrative"
      DisplayName = "Another one of these recurring dreams, is it... where {#Emph}are {#Prev}you, Sister? Come on, I don't want to look at my reflection here all day... night. Whenever."
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastMirrorLines"
    }
    {
      Id = "Zagreus_0056"
      InheritFrom = "BaseNarrative"
      DisplayName = "Goodbye, Melinoë! I hope this works..."
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastFollowUpLines"
    }
    {
      Id = "Zagreus_0007"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Wait, {#Emph}what...?"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastGreetingLines"
    }
    {
      Id = "Zagreus_0018"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Oh...!"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastGreetingLines"
    }
    {
      Id = "Zagreus_0027"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ah."
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastGreetingLines"
    }
    {
      Id = "Zagreus_0035"
      InheritFrom = "BaseNarrative"
      DisplayName = "There."
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastGreetingLines"
    }
    {
      Id = "Zagreus_0044"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey!"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastGreetingLines"
    }
    {
      Id = "Zagreus_0058"
      InheritFrom = "BaseNarrative"
      DisplayName = "Is that...?"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastGreetingLines"
    }
    {
      Id = "Zagreus_0063"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wait..."
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastGreetingLines"
    }
    {
      Id = "Zagreus_0443"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Gasp>"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastGreetingLines"
    }
    {
      Id = "Zagreus_0453"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}—Bwah!"
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastGreetingLines"
    }
    {
      Id = "Zagreus_0051"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Whew."
      Speaker = "Zagreus"
      Event = "GlobalVoiceLines.ZagreusPastGreetingLines"
    }
    {
      Id = "Chronos_0962"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Pah! {#Prev}What {#Emph}now...?"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosSanctumGreetingLines"
    }
    {
      Id = "Chronos_0963"
      InheritFrom = "BaseNarrative"
      DisplayName = "What is all that infernal {#Emph}racket?"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosSanctumGreetingLines"
    }
    {
      Id = "Chronos_0964"
      InheritFrom = "BaseNarrative"
      DisplayName = "Silence, fools, lest we be {#Emph}caught!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosSanctumGreetingLines"
    }
    {
      Id = "Chronos_0965"
      InheritFrom = "BaseNarrative"
      DisplayName = "Guards! Guards...? {#Emph}Guards!!"
      Speaker = "Chronos"
