    {
      Id = "Zeus_0200"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's quite enough, Typhon!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0241"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's {#Emph}me {#Prev}you want, monster!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0201"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have another lightning bolt for you, Typhon!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0202"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have something for you as well, Typhon!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0204"
      InheritFrom = "BaseNarrative"
      DisplayName = "How dare you show your face again, Typhon?!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0206"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have more lightning bolts to spare, Typhon!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0207"
      InheritFrom = "BaseNarrative"
      DisplayName = "You want vengeance, Typhon? Come {#Emph}take {#Prev}it!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0210"
      InheritFrom = "BaseNarrative"
      DisplayName = "Let's see how you like {#Emph}this{#Prev}, you monster!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0211"
      InheritFrom = "BaseNarrative"
      DisplayName = "Behold the wrath of Olympus, monstrous wretch!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0212"
      InheritFrom = "BaseNarrative"
      DisplayName = "You called for me, you misbegotten brute?!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0213"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hark, for it is I, you contemptible fiend!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0214"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have arrived, Melinoë! Now stand aside!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0215"
      InheritFrom = "BaseNarrative"
      DisplayName = "Young lady, I'll take this from here!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0216"
      InheritFrom = "BaseNarrative"
      DisplayName = "Our entire family is behind you, young lady!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0217"
      InheritFrom = "BaseNarrative"
      DisplayName = "That monster shall not climb another stone!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0218"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Everyone{#Prev}, lend me your strength!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0219"
      InheritFrom = "BaseNarrative"
      DisplayName = "Olympians, let's give him everything we've got!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0360"
      InheritFrom = "BaseNarrative"
      DisplayName = "Looking for me, Typhon?"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0361"
      InheritFrom = "BaseNarrative"
      DisplayName = "Remember my old lightning-bolt, Typhon?"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0356"
      InheritFrom = "BaseNarrative"
      DisplayName = "We've done this before, we shall do it again!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0357"
      InheritFrom = "BaseNarrative"
      DisplayName = "This mountaintop belongs only to gods!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0355"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come, remnant of monstrosity, I see you there!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0358"
      InheritFrom = "BaseNarrative"
      DisplayName = "We shall be rid of you in time, monster!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0359"
      InheritFrom = "BaseNarrative"
      DisplayName = "We'll destroy even the mere possibility of you!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0362"
      InheritFrom = "BaseNarrative"
      DisplayName = "Typhon! We'll leave no trace of you behind!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0205"
      InheritFrom = "BaseNarrative"
      DisplayName = "Have you not had enough of this, Typhon?!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0203"
      InheritFrom = "BaseNarrative"
      DisplayName = "You never seem to learn a thing, Typhon!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0208"
      InheritFrom = "BaseNarrative"
      DisplayName = "We shall defeat you every single time, monster!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0209"
      InheritFrom = "BaseNarrative"
      DisplayName = "Already forget about last night, monster?!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0236"
      InheritFrom = "BaseNarrative"
      DisplayName = "Are you all right?!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0237"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hold on, Melinoë!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0238"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do not give in!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0239"
      InheritFrom = "BaseNarrative"
      DisplayName = "Keep fighting!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
    {
      Id = "Zeus_0240"
      InheritFrom = "BaseNarrative"
      DisplayName = "Keep him occupied!"
      Speaker = "Zeus"
      Event = "TyphonAttackArrivalLines"
    }
