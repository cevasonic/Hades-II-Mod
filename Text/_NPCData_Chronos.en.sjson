{
  /*
  This file was autogenerated on 10/15/2025 at 5:41 PM
  by the BuildText tool.
  */
  lang = "en"
  Texts = [
    {
      Id = "Chronos_0147"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know who you are. I know where you go. You shall not get there."
      Speaker = "Chronos"
      Event = "ChronosAnomalyIntro01"
    }
    {
      Id = "MelinoeField_0246"
      InheritFrom = "BaseNarrative"
      DisplayName = "This magick... Chronos! I'll carve you limb from limb for this. For everything!"
      Speaker = "Melinoe"
      Event = "ChronosAnomalyIntro01"
    }
    {
      Id = "Chronos_0152"
      InheritFrom = "BaseNarrative"
      DisplayName = "How frightening. Unfortunately, we shall never know if yours was a mere-empty threat, for you are going on a little {#Emph}time out{#Prev}. At least until some other matters are resolved..."
      Speaker = "Chronos"
      Event = "ChronosAnomalyIntro01"
    }
    {
      Id = "MelinoeField_1682"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No!"
      Speaker = "Melinoe"
      Event = "ChronosAnomalyIntro01"
    }
    {
      Id = "Chronos_0209"
      InheritFrom = "BaseNarrative"
      DisplayName = "I am afraid I must ask you to cease this at once..."
      Speaker = "Chronos"
      Event = "ChronosAnomalyIntro01_B"
    }
    {
      Id = "Chronos_0142"
      InheritFrom = "BaseNarrative"
      DisplayName = "Pray, who might you be, my girl? And what compelled you to wander in and out of Erebus?"
      Speaker = "Chronos"
      Event = "ChronosFirstMeeting"
    }
    {
      Id = "Melinoe_0093"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm not your {#Emph}girl{#Prev}, old man. My name and business are not your concern."
      Speaker = "Melinoe"
      Event = "ChronosFirstMeeting"
    }
    {
      Id = "Chronos_0143"
      InheritFrom = "BaseNarrative"
      DisplayName = "So it seems. You appear to be quite pressed for time. Forgive this {#Emph}old man {#Prev}his transgressions..."
      Speaker = "Chronos"
      Event = "ChronosFirstMeeting"
    }
    {
      Id = "Chronos_0144"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have returned. Or lost your way, perhaps, in those interminable passageways beyond."
      Speaker = "Chronos"
      Event = "ChronosMeeting02"
    }
    {
      Id = "MelinoeField_0244"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know where I'm going. Whom do I address? And what are you doing here yourself, in such a place?"
      Speaker = "Melinoe"
      Event = "ChronosMeeting02"
    }
    {
      Id = "Chronos_0145"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}My name and business are not your concern{#Prev}, is that not what you said? {#Emph}Ahh{#Prev}, the impertinence of the youth of this age..."
      Speaker = "Chronos"
      Event = "ChronosMeeting02"
    }
    {
      Id = "MelinoeField_0245"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Wait..."
      Speaker = "Melinoe"
      Event = "ChronosMeeting02"
    }
    {
      Id = "Chronos_0146"
      InheritFrom = "BaseNarrative"
      DisplayName = "You seem to know your way around. I am master of this realm, yet even {#Emph}I {#Prev}would never venture into yonder woods. You even found your way back from your {#Emph}detour {#Prev}in Asphodel..."
      Speaker = "Chronos"
      Event = "ChronosReveal01"
    }
    {
      Id = "Melinoe_0035"
      InheritFrom = "BaseNarrative"
      DisplayName = "Damn you, Chronos...!"
      Speaker = "Melinoe"
      Event = "ChronosReveal01"
    }
    {
      Id = "Chronos_0020"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Fates cannot help you now..."
      Speaker = "Chronos"
      Event = "ChronosReveal01"
    }
    {
      Id = "Chronos_0591"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Then let us wait..."
      Speaker = "Chronos"
      Event = "ChronosReveal01"
    }
    {
      Id = "Chronos_0031"
      InheritFrom = "BaseNarrative"
      DisplayName = "You, my girl, are meddling in matters you do not understand. Your father made certain choices; he was bound by them, but you are not. You need not follow in his ruinous path."
      Speaker = "Chronos"
      Event = "ChronosMeeting03"
    }
    {
      Id = "Melinoe_0163"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ruinous?! You {#Prev}brought ruin to the Underworld and the surface! I'll never accept what you've done. Now, enough talk!"
      Speaker = "Melinoe"
      Event = "ChronosMeeting03"
    }
    {
      Id = "Chronos_0032"
      InheritFrom = "BaseNarrative"
      DisplayName = "How {#Emph}very {#Prev}spirited! You truly think you can stop Time. Well, then... I would like to see you try."
      Speaker = "Chronos"
      Event = "ChronosMeeting03"
    }
    {
      Id = "Melinoe_0164"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Then watch this!"
      Speaker = "Melinoe"
      Event = "ChronosMeeting03"
    }
    {
      Id = "Intercom_0023"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}<Laughter>"
      Speaker = "Intercom"
      Event = "ChronosMeeting03"
    }
    {
      Id = "Chronos_0034"
      InheritFrom = "BaseNarrative"
      DisplayName = "Which rock did you crawl out from under, {#Emph}hm? {#Prev}My forces, they are terribly confused! They have no idea where you live! So I thought I would {#Emph}attempt {#Prev}asking you nicely here."
      Speaker = "Chronos"
      Event = "ChronosMeeting04"
    }
    {
      Id = "Melinoe_0166"
      InheritFrom = "BaseNarrative"
      DisplayName = "I live in your nightmares, Titan. I thrive on them! I'll see you dead, and then destroyed. However long it takes."
      Speaker = "Melinoe"
      Event = "ChronosMeeting04"
    }
    {
      Id = "Chronos_0035"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}However long it takes? {#Prev}You speak of inevitability, little one. A subject on which I happen to be the expert. As to whomever sent you after me... I shall find them."
      Speaker = "Chronos"
      Event = "ChronosMeeting04"
    }
    {
      Id = "Melinoe_0167"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We'll see!"
      Speaker = "Melinoe"
      Event = "ChronosMeeting04"
    }
    {
      Id = "Chronos_0077"
      InheritFrom = "BaseNarrative"
      DisplayName = "You yet persist, despite my generous attempts to dissuade you. Then, very well! You carry on as the distraction which you are, whilst I turn my attention to matters of greater import..."
      Speaker = "Chronos"
      Event = "ChronosMeeting05"
    }
    {
      Id = "Chronos_0157"
      InheritFrom = "BaseNarrative"
      DisplayName = "I was beginning to think I had successfully dissuaded you, when it came to my attention you were trespassing some other place instead. You dared venture above?"
      Speaker = "Chronos"
      Event = "ChronosPostSurfaceMeeting01"
    }
    {
      Id = "MelinoeField_0494"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've seen your work up there firsthand. To have unsealed the very gates of hell! And brought disaster to mortals who've nothing to do with your petty vendetta."
      Speaker = "Melinoe"
      Event = "ChronosPostSurfaceMeeting01"
    }
    {
      Id = "Chronos_0158"
      InheritFrom = "BaseNarrative"
      DisplayName = "You speak of the bedraggled city of Ephyra, which once stood in sycophantic tribute to your upstart father. Perhaps what mortals yet remain there shall think twice next time before they put their faith in {#Emph}gods."
      Speaker = "Chronos"
      Event = "ChronosPostSurfaceMeeting01"
    }
    {
      Id = "MelinoeField_0495"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Coward..."
      Speaker = "Melinoe"
      Event = "ChronosPostSurfaceMeeting01"
    }
    {
      Id = "Chronos_0159"
      InheritFrom = "BaseNarrative"
      DisplayName = "You cannot help the gods above, you know. My legions are vast, and death means little to them anymore. Not that your efforts here shall be of much consequence, either."
      Speaker = "Chronos"
      Event = "ChronosPostSurfaceMeeting02"
    }
    {
      Id = "MelinoeField_0496"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your surface legions fight and die for you, yet you hide behind them here. If you're so certain of your victory, you'd be leading them."
      Speaker = "Melinoe"
      Event = "ChronosPostSurfaceMeeting02"
    }
    {
      Id = "Chronos_0160"
      InheritFrom = "BaseNarrative"
      DisplayName = "Leadership, my girl, is not about having to do everything oneself. It is about ensuring others share your same ideals and methodology. Wherever you may go, you shall encounter many who embrace my point of view, I think."
      Speaker = "Chronos"
      Event = "ChronosPostSurfaceMeeting02"
    }
    {
      Id = "MelinoeField_0497"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No shortage of fools..."
      Speaker = "Melinoe"
      Event = "ChronosPostSurfaceMeeting02"
    }
    {
      Id = "Chronos_0161"
      InheritFrom = "BaseNarrative"
      DisplayName = "No victories upon the surface as of yet? It appears you have {#Emph}two {#Prev}hopeless goals, rather than one."
      Speaker = "Chronos"
      Event = "ChronosPostSurfaceMeeting03"
    }
    {
      Id = "MelinoeField_0498"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've only one, and hope has nothing to do with it. I may not be able to stop you yet, but neither can you stop me. You've tried."
      Speaker = "Melinoe"
      Event = "ChronosPostSurfaceMeeting03"
    }
    {
      Id = "Chronos_0162"
      InheritFrom = "BaseNarrative"
      DisplayName = "You {#Emph}have {#Prev}been more resistant than {#Emph}some {#Prev}members of your family, I admit. Well then, see where your scattered ventures to the surface, or these depths, shall ultimately lead!"
      Speaker = "Chronos"
      Event = "ChronosPostSurfaceMeeting03"
    }
    {
      Id = "MelinoeField_0499"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We'll both see."
      Speaker = "Melinoe"
      Event = "ChronosPostSurfaceMeeting03"
    }
    {
      Id = "Chronos_0611"
      InheritFrom = "BaseNarrative"
      DisplayName = "At last you have returned to more-familiar environs, girl. Neither the gods nor the Fates want you upon the surface of this world! Yet you insist on fighting there, for them."
      Speaker = "Chronos"
      Event = "ChronosPostSurfaceMeeting04"
    }
    {
      Id = "MelinoeField_2022"
      InheritFrom = "BaseNarrative"
      DisplayName = "I suppose I'll be more welcome in my father's home later this eve? As you can see I'm willing to fight there as well."
      Speaker = "Melinoe"
      Event = "ChronosPostSurfaceMeeting04"
    }
    {
      Id = "Chronos_0612"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, but you have such a long way to go! Confined to making the journey by foot, like a pathetic mortal. Do be sure to conserve some of your strength for the {#Emph}final stretch."
      Speaker = "Chronos"
      Event = "ChronosPostSurfaceMeeting04"
    }
    {
      Id = "MelinoeField_2023"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ungh..."
      Speaker = "Melinoe"
      Event = "ChronosPostSurfaceMeeting04"
    }
    {
      Id = "Chronos_0210"
      InheritFrom = "BaseNarrative"
      DisplayName = "I thought that I might find you here, my girl. Such fire in your eyes! How obstinate the members of our family can be. Have you learned nothing from our previous exchange?"
      Speaker = "Chronos"
      Event = "ChronosPostBattleMeeting01"
    }
    {
      Id = "MelinoeField_1400"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, I learned plenty, and I'm eager to learn more. So why don't you get out of my way, since there's nothing you can do within these woods but try to slow me down?"
      Speaker = "Melinoe"
      Event = "ChronosPostBattleMeeting01"
    }
    {
      Id = "Chronos_0211"
      InheritFrom = "BaseNarrative"
      DisplayName = "Past the point of reason, and so very self-assured. Then, very well! Come find me if you must, and learn some more. You know where I reside. I do not hide from {#Emph}gods!"
      Speaker = "Chronos"
      Event = "ChronosPostBattleMeeting01"
    }
    {
      Id = "MelinoeField_1401"
      InheritFrom = "BaseSubtitle"
      DisplayName = "See you soon..."
      Speaker = "Melinoe"
      Event = "ChronosPostBattleMeeting01"
    }
    {
      Id = "Chronos_0004"
      InheritFrom = "BaseNarrative"
      DisplayName = "Little one, do not presume to think your movements are invisible to me! I see you plainly where you stand. A trespass for which you shall suffer, although, regrettably, not by my hand right now. Not yet."
      Speaker = "Chronos"
      Event = "ChronosPostBattleMeeting02"
    }
    {
      Id = "Chronos_0005"
      InheritFrom = "BaseNarrative"
      DisplayName = "I am Time itself. What are you? A thrall of those calling themselves gods, mindlessly serving at their whim. My children are crafty... to them, you are nothing but a common tool! And not an especially sharp one, it appears to me."
      Speaker = "Chronos"
      Event = "ChronosPostBattleMeeting03"
    }
    {
      Id = "Chronos_0006"
      InheritFrom = "BaseNarrative"
      DisplayName = "If there is one thing on which the accursed Fates and I agree, it is that all eventually shall decay. All sprang from nothingness, and back into that Chaos we shall all return. You merely hurry it along."
      Speaker = "Chronos"
      Event = "ChronosPostBattleMeeting04"
    }
    {
      Id = "Chronos_0613"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why, here comes our shadowy assassin on her nightly escapade to try and do me harm! Although perhaps the outcome shall not be so fortunate, this time."
      Speaker = "Chronos"
      Event = "ChronosPostWinStreakMeeting01"
    }
    {
      Id = "MelinoeField_2024"
      InheritFrom = "BaseNarrative"
      DisplayName = "We'll soon find out, won't we? I promise not to keep you waiting long. I'm well on my way already, as you can see."
      Speaker = "Melinoe"
      Event = "ChronosPostWinStreakMeeting01"
    }
    {
      Id = "Chronos_0614"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, that I {#Emph}can. {#Prev}Then, I had best return and make ready! We have to tidy up for your arrival, after all. Until later tonight."
      Speaker = "Chronos"
      Event = "ChronosPostWinStreakMeeting01"
    }
    {
      Id = "MelinoeField_2025"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Until then."
      Speaker = "Melinoe"
      Event = "ChronosPostWinStreakMeeting01"
    }
    {
      Id = "Chronos_0615"
      InheritFrom = "BaseNarrative"
      DisplayName = "My dear son Zeus is already abetting you this night? I fear not his famous thunderbolt, young fool that he is."
      Speaker = "Chronos"
      Event = "ChronosMeetingAboutZeus01"
    }
    {
      Id = "Chronos_0616"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, so Poseidon gave you his blessing, has he now? What are you going to do... pour water on me?"
      Speaker = "Chronos"
      Event = "ChronosMeetingAboutPoseidon01"
    }
    {
      Id = "Chronos_0619"
      InheritFrom = "BaseNarrative"
      DisplayName = "The goddess of the hearth has blessed you now? There is no flame which {#Emph}Time {#Prev}cannot extinguish soon enough."
      Speaker = "Chronos"
      Event = "ChronosMeetingAboutHestia01"
    }
    {
      Id = "Chronos_0617"
      InheritFrom = "BaseNarrative"
      DisplayName = "The frosty goddess Demeter is urging you along this eve? Alas, there are no {#Emph}seasons {#Prev}in the Underworld."
      Speaker = "Chronos"
      Event = "ChronosMeetingAboutDemeter01"
    }
    {
      Id = "Chronos_0618"
      InheritFrom = "BaseNarrative"
      DisplayName = "The self-made Queen of the Gods, bestowing you her Boon? Is there not some mortal wedding she ought to officiate?"
      Speaker = "Chronos"
      Event = "ChronosMeetingAboutHera01"
    }
    {
      Id = "Chronos_0620"
      InheritFrom = "BaseNarrative"
      DisplayName = "Try all you like, my girl; but the outcome of this night shall be no different from the last."
      Speaker = "Chronos"
      Event = "ChronosMeetingAboutOlympians01"
    }
    {
      Id = "Chronos_0911"
      InheritFrom = "BaseNarrative"
      DisplayName = "Has crafty Prometheus proven too much for you, that you believe you shall fare better against {#Emph}me?"
      Speaker = "Chronos"
      Event = "ChronosMeetingAboutPrometheus01"
    }
    {
      Id = "Chronos_0912"
      InheritFrom = "BaseNarrative"
      DisplayName = "As you yet flail against me here, the shrewd Prometheus has many of your relatives entirely preoccupied..."
      Speaker = "Chronos"
      Event = "ChronosMeetingAboutPrometheus02"
    }
    {
      Id = "Chronos_0908"
      InheritFrom = "BaseNarrative"
      DisplayName = "So you have seen what shall become of Mount Olympus, and abandoned that foolhardy path... soon, this one, too."
      Speaker = "Chronos"
      Event = "ChronosMeetingAboutTyphon01"
    }
    {
      Id = "Chronos_0909"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know not how you bested the Father of All Monsters, but all it did was make him angrier."
      Speaker = "Chronos"
      Event = "ChronosMeetingAboutTyphonW01"
    }
    {
      Id = "Chronos_0910"
      InheritFrom = "BaseNarrative"
      DisplayName = "I would be more concerned with that which now transpires on Olympus, were I you. I hear Typhon is rather upset..."
      Speaker = "Chronos"
      Event = "ChronosMeetingAboutTyphon02"
    }
    {
      Id = "Chronos_0913"
      InheritFrom = "BaseNarrative"
      DisplayName = "There is a thickness to the air tonight... such darkness is presumably {#Emph}your {#Prev}doing, but shall do you little good."
      Speaker = "Chronos"
      Event = "ChronosMeetingAboutShrine01"
    }
    {
      Id = "Chronos_0156"
      InheritFrom = "BaseNarrative"
      DisplayName = "Such rage! Lashing out like a petulant child. You wish to fight with me, then so be it...!"
      Speaker = "Chronos"
      Event = "ChronosReveal01B"
    }
    {
      Id = "Chronos_0075"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, stop. It is a pity that this granddaughter of mine is both a weakling and a fool, though an elusive one. I ought to thank the Fates that we have met at last."
      Speaker = "Chronos"
      Event = "ChronosRevealFollowUp"
    }
    {
      Id = "Melinoe_0095"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Fates had nothing to do with this. You took my family."
      Speaker = "Melinoe"
      Event = "ChronosRevealFollowUp"
    }
    {
      Id = "Chronos_0076"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Our {#Prev}family! Make not their same mistakes, and in time, we surely shall grow past this halted start to our relationship. I shall see you later."
      Speaker = "Chronos"
      Event = "ChronosRevealFollowUp"
    }
    {
      Id = "Melinoe_0096"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Wait! You..."
      Speaker = "Melinoe"
      Event = "ChronosRevealFollowUp"
    }
    {
      Id = "MelinoeField_5149"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This had better work."
      Speaker = "Melinoe"
      Event = "NPC_Chronos_Story_01.InteractVoiceLines"
    }
    {
      Id = "Chronos_0056"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ahh{#Prev}, there you are, my son. Grown a full beard and a broad frame, I see. And now you have a family of your own! How full of life they are, despite the dour environs."
      Speaker = "Chronos"
      Event = "ChronosNightmare01"
    }
    {
      Id = "Hades_0003"
      InheritFrom = "BaseNarrative"
      DisplayName = "Greetings, Father. I... was not expecting your arrival. You... must forgive us that the House was unprepared for guests. To what do we owe the pleasure of your company?"
      Speaker = "Hades"
      Event = "ChronosNightmare01"
    }
    {
      Id = "Chronos_0057"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, you know, for one thing, I was in the area! You might recall the time you, Zeus, and the rest of you little brats cut me to ribbons? Sprinkled all my bits, all throughout Tartarus?"
      Speaker = "Chronos"
      Event = "ChronosNightmare01"
    }
    {
      Id = "Hades_0004"
      InheritFrom = "BaseNarrative"
      DisplayName = "Father... that was a war {#Emph}you {#Prev}started, and you know it! We took no joy in what we had to do! But how can this be? I thought that you were gone...!"
      Speaker = "Hades"
      Event = "ChronosNightmare01"
    }
    {
      Id = "Chronos_0058"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do not sound so disappointed! It is {#Emph}I {#Prev}who should be disappointed here, not {#Emph}you. {#Prev}You thought I was gone? I was! But it turns out spite is a powerful motivator. Blood sacrifices also helped."
      Speaker = "Chronos"
      Event = "ChronosNightmare01"
    }
    {
      Id = "Hades_0021"
      InheritFrom = "BaseNarrative"
      DisplayName = "What do you intend to do? And... what have you done to the others? To my family?!"
      Speaker = "Hades"
      Event = "ChronosNightmare01"
    }
    {
      Id = "Chronos_0059"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your cries fall on deaf ears. Fear not, my son. I have not {#Emph}eaten {#Prev}them or anything. I have merely... set them aside. They stand imprisoned in a moment that shall never pass. My qualm is not with {#Emph}them."
      Speaker = "Chronos"
      Event = "ChronosNightmare01"
    }
    {
      Id = "Hades_0022"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Olympus shall have your head. You can take {#Emph}mine{#Prev}, for all I care, {#Emph}blast you! {#Prev}But don't you {#Emph}dare {#Prev}harm anybody in my House."
      Speaker = "Hades"
      Event = "ChronosNightmare01"
    }
    {
      Id = "Chronos_0071"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Tsk! {#Prev}You have grown so accustomed to issuing commands that you forget yourself. Though, I do have such a command for {#Emph}you: {#Prev}Tell me, exactly, where the Fates reside."
      Speaker = "Chronos"
      Event = "ChronosNightmare01"
    }
    {
      Id = "Hades_0023"
      InheritFrom = "BaseNarrative"
      DisplayName = "The {#Emph}Fates? {#Prev}How should {#Emph}I {#Prev}know? Not even Nyx herself knows where her daughters are! Why are you... asking {#Emph}me...?"
      Speaker = "Hades"
      Event = "ChronosNightmare01"
    }
    {
      Id = "Melinoe_5074"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hail, Grandfather."
      Speaker = "Melinoe"
      Event = "NPC_Chronos_02.InteractVoiceLines"
    }
    {
      Id = "Melinoe_5075"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Grandfather."
      Speaker = "Melinoe"
      Event = "NPC_Chronos_02.InteractVoiceLines"
    }
    {
      Id = "Melinoe_5166"
      InheritFrom = "BaseSubtitle"
      DisplayName = "May time flow freely forth."
      Speaker = "Melinoe"
      Event = "NPC_Chronos_02.InteractVoiceLines"
    }
    {
      Id = "Chronos_1297"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come now..."
      Speaker = "Chronos"
      Event = "NPC_Chronos_02.InteractVoiceLines"
    }
    {
      Id = "Chronos_1298"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Salutations..."
      Speaker = "Chronos"
      Event = "NPC_Chronos_02.InteractVoiceLines"
    }
    {
      Id = "Chronos_1299"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Oh{#Prev}, my..."
      Speaker = "Chronos"
      Event = "NPC_Chronos_02.InteractVoiceLines"
    }
    {
      Id = "Chronos_1300"
      InheritFrom = "BaseSubtitle"
      DisplayName = "To my former self, yes?"
      Speaker = "Chronos"
      Event = "NPC_Chronos_02.InteractVoiceLines"
    }
    {
      Id = "Chronos_1301"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I would like that."
      Speaker = "Chronos"
      Event = "NPC_Chronos_02.InteractVoiceLines"
    }
    {
      Id = "Chronos_1302"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Is that what you say?"
      Speaker = "Chronos"
      Event = "NPC_Chronos_02.InteractVoiceLines"
    }
    {
      Id = "Chronos_1096"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You are upset..."
      Speaker = "Chronos"
      Event = "NPC_Chronos_02.OnHitVoiceLines"
    }
    {
      Id = "Chronos_1097"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I cannot change the past..."
      Speaker = "Chronos"
      Event = "NPC_Chronos_02.OnHitVoiceLines"
    }
    {
      Id = "Chronos_1098"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I shall not retaliate..."
      Speaker = "Chronos"
      Event = "NPC_Chronos_02.OnHitVoiceLines"
    }
    {
      Id = "Chronos_1099"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Do as you must..."
      Speaker = "Chronos"
      Event = "NPC_Chronos_02.OnHitVoiceLines"
    }
    {
      Id = "Chronos_1100"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Such pain I caused..."
      Speaker = "Chronos"
      Event = "NPC_Chronos_02.OnHitVoiceLines"
    }
    {
      Id = "Chronos_1101"
      InheritFrom = "BaseSubtitle"
      DisplayName = "For old time's sake...?"
      Speaker = "Chronos"
      Event = "NPC_Chronos_02.OnHitVoiceLines"
    }
    {
      Id = "Chronos_1108"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}May time flow freely forth!"
      Speaker = "Chronos"
      Event = "NPC_Chronos_02.BossFinisherVoiceLines"
    }
    {
      Id = "Chronos_1109"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}May time flow freely forth...!"
      Speaker = "Chronos"
      Event = "NPC_Chronos_02.BossFinisherVoiceLines"
    }
    {
      Id = "Chronos_1110"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}May time flow freely forth."
      Speaker = "Chronos"
      Event = "NPC_Chronos_02.BossFinisherVoiceLines"
    }
    {
      Id = "Chronos_1111"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}May time flow freely forth..."
      Speaker = "Chronos"
      Event = "NPC_Chronos_02.BossFinisherVoiceLines"
    }
    {
      Id = "Chronos_1054"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}May time flow freely forward!"
      Speaker = "Chronos"
      Event = "NPC_Chronos_02.BossFinisherVoiceLines"
    }
    {
      Id = "Chronos_1055"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}May time flow freely forward...!"
      Speaker = "Chronos"
      Event = "NPC_Chronos_02.BossFinisherVoiceLines"
    }
    {
      Id = "Chronos_1056"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}May time flow freely forward."
      Speaker = "Chronos"
      Event = "NPC_Chronos_02.BossFinisherVoiceLines"
    }
    {
      Id = "Chronos_1057"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}May time flow freely forward..."
      Speaker = "Chronos"
      Event = "NPC_Chronos_02.BossFinisherVoiceLines"
    }
    {
      Id = "Chronos_1061"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Sorry there, old boy."
      Speaker = "Chronos"
      Event = "NPC_Chronos_02.BossFinisherVoiceLines"
    }
    {
      Id = "Chronos_1062"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This shall not hurt at all."
      Speaker = "Chronos"
      Event = "NPC_Chronos_02.BossFinisherVoiceLines"
    }
    {
      Id = "Chronos_1058"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Death to Chronos{#Prev}, was it?"
      Speaker = "Chronos"
      Event = "NPC_Chronos_02.BossFinisherVoiceLines"
    }
    {
      Id = "Chronos_1059"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Death to Chronos."
      Speaker = "Chronos"
      Event = "NPC_Chronos_02.BossFinisherVoiceLines"
    }
    {
      Id = "Chronos_1060"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Death to Chronos!"
      Speaker = "Chronos"
      Event = "NPC_Chronos_02.BossFinisherVoiceLines"
    }
    {
      Id = "Chronos_1480"
      InheritFrom = "BaseNarrative"
      DisplayName = "Would you permit that we occasionally meet thus, Granddaughter? I realize our prior conversations here in Erebus were fraught... but perhaps we may yet start anew, here in this life."
      Speaker = "Chronos"
      Event = "NeoChronosAboutErebus01"
    }
    {
      Id = "MelinoeField_4137"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll have to learn not to attack you here on sight, but let's give it a shot. What is it about this place that's so special?"
      Speaker = "Melinoe"
      Event = "NeoChronosAboutErebus01"
    }
    {
      Id = "Chronos_1481"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well I know how to find it, for one! And you tend to pass through it, for two! At any rate, you now have seen the real possibilities that linger on Olympus and below. Let us eliminate the ones that would have led to ruin."
      Speaker = "Chronos"
      Event = "NeoChronosAboutErebus01"
    }
    {
      Id = "MelinoeField_5181"
      InheritFrom = "BaseNarrative"
      DisplayName = "I do like preventing ruin. You'll be closely watched by Olympus and the Underworld every step of the way. Don't squander the chance you've been given."
      Speaker = "Melinoe"
      Event = "NeoChronosAboutErebus01"
    }
    {
      Id = "Chronos_1482"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I keep telling myself the same!"
      Speaker = "Chronos"
      Event = "NeoChronosAboutErebus01"
    }
    {
      Id = "Chronos_1085"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your father and his brother Zeus were generous enough to give me an opportunity to be of some small service to the Underworld. The Isles of the Blessed are the finest spots in all Elysium! And I shall certainly keep them that way."
      Speaker = "Chronos"
      Event = "NeoChronosAboutNewJob01"
    }
    {
      Id = "MelinoeField_4139"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's a high honor you've been given, Grandfather! Some of the greatest mortal heroes must be there. Shall the new responsibility leave you with time enough to meet like this?"
      Speaker = "Melinoe"
      Event = "NeoChronosAboutNewJob01"
    }
    {
      Id = "Chronos_1086"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh I should think it shall be more convenient than before. Elysium is really not that far; you shall have to visit at some point, once your father's Underworld renovations are complete. Which I suppose may take another age."
      Speaker = "Chronos"
      Event = "NeoChronosAboutNewJob01"
    }
    {
      Id = "MelinoeField_4140"
      InheritFrom = "BaseNarrative"
      DisplayName = "Father does seem the exacting type. Well, all the best in the new role. Fates willing, see you soon in Tartarus."
      Speaker = "Melinoe"
      Event = "NeoChronosAboutNewJob01"
    }
    {
      Id = "Chronos_1087"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Retrace your steps with care!"
      Speaker = "Chronos"
      Event = "NeoChronosAboutNewJob01"
    }
    {
      Id = "MelinoeField_5032"
      InheritFrom = "BaseNarrative"
      DisplayName = "One thing I've wondered, Grandfather... for all these possibilities we face... I understand what happens if I prevail, more or less. But if I fail there, what then?"
      Speaker = "Melinoe"
      Event = "NeoChronosAboutFailure01"
    }
    {
      Id = "Chronos_1390"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why, the possibility remains... nothing more! Do not concern yourself with that too much. We know there are a lot of these to go around! You may not prevail in them all."
      Speaker = "Chronos"
      Event = "NeoChronosAboutFailure01"
    }
    {
      Id = "MelinoeField_5033"
      InheritFrom = "BaseNarrative"
      DisplayName = "Will I have other chances to correct my mistakes? Return to the same possibility and clear it up?"
      Speaker = "Melinoe"
      Event = "NeoChronosAboutFailure01"
    }
    {
      Id = "Chronos_1391"
      InheritFrom = "BaseNarrative"
      DisplayName = "I do not know! Perhaps not! Perhaps even your {#Emph}failures{#Prev}, as you call them, shall have the desired result. There is much I do not fully understand... embarrassing as that may be."
      Speaker = "Chronos"
      Event = "NeoChronosAboutFailure01"
    }
    {
      Id = "MelinoeField_5034"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm learning, too."
      Speaker = "Melinoe"
      Event = "NeoChronosAboutFailure01"
    }
    {
      Id = "MelinoeField_4141"
      InheritFrom = "BaseNarrative"
      DisplayName = "Grandfather, what of the Three Fates? You truly sent them into exile without knowing where they went?"
      Speaker = "Melinoe"
      Event = "NeoChronosAboutFates01"
    }
    {
      Id = "Chronos_1088"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, yes. Another terrible mistake I dearly wish to rectify. I am attempting to locate them in the depths of possibility, except... they could be almost anywhere in there."
      Speaker = "Chronos"
      Event = "NeoChronosAboutFates01"
    }
    {
      Id = "MelinoeField_4142"
      InheritFrom = "BaseNarrative"
      DisplayName = "There must be something we can do. Are they in any danger? And don't you fear reprisal if we ever find them?"
      Speaker = "Melinoe"
      Event = "NeoChronosAboutFates01"
    }
    {
      Id = "Chronos_1089"
      InheritFrom = "BaseNarrative"
      DisplayName = "I must admit I do fear somewhat more for {#Emph}me {#Prev}than them. But my attempts to resist the workings of the Fates have never been successful in the past. Should they return, I shall accept whatsoever they may have in store..."
      Speaker = "Chronos"
      Event = "NeoChronosAboutFates01"
    }
    {
      Id = "MelinoeField_4143"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We'll figure something out."
      Speaker = "Melinoe"
      Event = "NeoChronosAboutFates01"
    }
    {
      Id = "MelinoeField_5029"
      InheritFrom = "BaseNarrative"
      DisplayName = "How did you reawaken Typhon, Grandfather? I always wondered about that. And to have caught the Olympians by surprise with such a monstrous being..."
      Speaker = "Melinoe"
      Event = "NeoChronosAboutTyphon01"
    }
    {
      Id = "Chronos_1387"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, I... would rather not discuss such bitter memories, but... that monster's reawakening was in some ways akin to mine, when Zagreus found me. On a much larger scale, of course."
      Speaker = "Chronos"
      Event = "NeoChronosAboutTyphon01"
    }
    {
      Id = "MelinoeField_5030"
      InheritFrom = "BaseNarrative"
      DisplayName = "I see, and I won't press you on it, but... this may be strange to ask, though did you and Typhon know each other well?"
      Speaker = "Melinoe"
      Event = "NeoChronosAboutTyphon01"
    }
    {
      Id = "Chronos_1388"
      InheritFrom = "BaseNarrative"
      DisplayName = "He was the Father of All Monsters... showing no concern for his own brood, much less others. He was a means to an end. We were using each other, one could say."
      Speaker = "Chronos"
      Event = "NeoChronosAboutTyphon01"
    }
    {
      Id = "MelinoeField_5031"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I understand. That's all."
      Speaker = "Melinoe"
      Event = "NeoChronosAboutTyphon01"
    }
    {
      Id = "Chronos_1389"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Very well."
      Speaker = "Chronos"
      Event = "NeoChronosAboutTyphon01"
    }
    {
      Id = "MelinoeField_5035"
      InheritFrom = "BaseNarrative"
      DisplayName = "Have you made contact with Prometheus after everything that's happened with us? He and I never really got along. Though I started to sense he wasn't really on your side..."
      Speaker = "Melinoe"
      Event = "NeoChronosAboutPrometheus01"
    }
    {
      Id = "Chronos_1392"
      InheritFrom = "BaseNarrative"
      DisplayName = "He is {#Emph}intelligent{#Prev}, that one. Perhaps even too much for his own good. I regret that you were forced to come to blows. But, he and I are no longer in touch... to keep conditions closer to the way they were."
      Speaker = "Chronos"
      Event = "NeoChronosAboutPrometheus01"
    }
    {
      Id = "MelinoeField_5036"
      InheritFrom = "BaseNarrative"
      DisplayName = "He has navigated this situation rather carefully, for all the trouble he's caused the gods. I suppose that all makes sense, if he truly could anticipate every outcome. "
      Speaker = "Melinoe"
      Event = "NeoChronosAboutPrometheus01"
    }
    {
      Id = "Chronos_1393"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That sounds like the Prometheus I know."
      Speaker = "Chronos"
      Event = "NeoChronosAboutPrometheus01"
    }
    {
      Id = "MelinoeField_5182"
      InheritFrom = "BaseNarrative"
      DisplayName = "For what it's worth, Grandfather... I think the bitter war you waged against Olympus may have been eye-opening for some of our relatives, at least. They may be gods... but they know they're not perfect."
      Speaker = "Melinoe"
      Event = "NeoChronosAboutGoldenAge01"
    }
    {
      Id = "Chronos_1483"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well... perfection, to my knowledge, cannot be achieved! Merely striven for. My children could be obstinate about their weaknesses, but most likely they inherited that trait from {#Emph}me."
      Speaker = "Chronos"
      Event = "NeoChronosAboutGoldenAge01"
    }
    {
      Id = "MelinoeField_5183"
      InheritFrom = "BaseNarrative"
      DisplayName = "Even still... with the war finally ended, there's much to be done on the surface as well as here. I'm realizing that our renovation effort in the Underworld to some extent is worldwide."
      Speaker = "Melinoe"
      Event = "NeoChronosAboutGoldenAge01"
    }
    {
      Id = "Chronos_1484"
      InheritFrom = "BaseNarrative"
      DisplayName = "When you get to be my age, you may yet wistfully recall the way the world used to be. It is a curse of growing old, perhaps! May our family yet guide this world into more-prosperous times."
      Speaker = "Chronos"
      Event = "NeoChronosAboutGoldenAge01"
    }
    {
      Id = "MelinoeField_5184"
      InheritFrom = "BaseSubtitle"
      DisplayName = "May that be so."
      Speaker = "Melinoe"
      Event = "NeoChronosAboutGoldenAge01"
    }
    {
      Id = "MelinoeField_4554"
      InheritFrom = "BaseNarrative"
      DisplayName = "These other possibilities of you whom I face... it's strange to speak with them as though none of this occurred."
      Speaker = "Melinoe"
      Event = "NeoChronosAboutChronos01"
    }
    {
      Id = "Chronos_1311"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh very much so, yes. However, that is the reason they are possibilities and nothing more. Thus you may humor them before proceeding with the quite unpleasant bit."
      Speaker = "Chronos"
      Event = "NeoChronosAboutChronos01"
    }
    {
      Id = "MelinoeField_4555"
      InheritFrom = "BaseNarrative"
      DisplayName = "And it doesn't trouble you to be involved? Personally eliminating something that looks just like you... that {#Emph}is {#Prev}you?"
      Speaker = "Melinoe"
      Event = "NeoChronosAboutChronos01"
    }
    {
      Id = "Chronos_1312"
      InheritFrom = "BaseNarrative"
      DisplayName = "But {#Emph}I {#Prev}am me. For are we not the sum of our experiences, Granddaughter? To reject one's stubborn old thoughts and ways... it can be quite invigorating! So let us carry on."
      Speaker = "Chronos"
      Event = "NeoChronosAboutChronos01"
    }
    {
      Id = "Chronos_1290"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why you have there the Time Piece which I gave to you. I thought you would sooner cast it into the lowest depths! The ever-turning clockwork is quite fascinating, is it not?"
      Speaker = "Chronos"
      Event = "NeoChronosAboutKeepsake01"
    }
    {
      Id = "MelinoeField_4369"
      InheritFrom = "BaseNarrative"
      DisplayName = "It is unusual. Is this something that Master Daedalus originally made? To have fitted all these little wheels together so that they could move in perfect harmony..."
      Speaker = "Melinoe"
      Event = "NeoChronosAboutKeepsake01"
    }
    {
      Id = "Chronos_1291"
      InheritFrom = "BaseNarrative"
      DisplayName = "The mechanisms governing the ever-shifting chambers of Tartarus were a source of inspiration, certainly. This sense of perfect harmony, which you describe... perhaps it can only be achieved in such a form! But it {#Emph}can {#Prev}be achieved."
      Speaker = "Chronos"
      Event = "NeoChronosAboutKeepsake01"
    }
    {
      Id = "MelinoeField_4370"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I suppose I agree."
      Speaker = "Melinoe"
      Event = "NeoChronosAboutKeepsake01"
    }
    {
      Id = "Chronos_1292"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh down in Oceanus, it is possible you may encounter remnants of my spell, which casts you to a vision out of time. I've not yet found the means to stop {#Emph}that {#Prev}one..."
      Speaker = "Chronos"
      Event = "NeoChronosAboutAnomaly01"
    }
    {
      Id = "MelinoeField_4371"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have no control over your own magick? I wondered whether that was you, or one of your less agreeable selves."
      Speaker = "Melinoe"
      Event = "NeoChronosAboutAnomaly01"
    }
    {
      Id = "Chronos_1293"
      InheritFrom = "BaseNarrative"
      DisplayName = "I cannot rightly deny all responsibility, but it is one of {#Emph}those{#Prev}, yes. And your susceptibility, why... perhaps it is some connection which we share. Resistances and sensitivities..."
      Speaker = "Chronos"
      Event = "NeoChronosAboutAnomaly01"
    }
    {
      Id = "Chronos_1313"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have my children's blessings even now. I am relieved they are still offering their aid, considering the crisis I created, and the harm I brought upon their home..."
      Speaker = "Chronos"
      Event = "NeoChronosAboutBoons01"
    }
    {
      Id = "MelinoeField_4556"
      InheritFrom = "BaseNarrative"
      DisplayName = "It seems we're all committed to setting this right, such as we can. The Olympians are no strangers to occasional fights anyhow, although perhaps not quite as bad as this last one."
      Speaker = "Melinoe"
      Event = "NeoChronosAboutBoons01"
    }
    {
      Id = "Chronos_1314"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes, well, if we are to exist in this small world together for eternity, we have incentive to alleviate the misery which we ourselves create... I thank you all for the support."
      Speaker = "Chronos"
      Event = "NeoChronosAboutBoons01"
    }
    {
      Id = "MelinoeField_4559"
      InheritFrom = "BaseNarrative"
      DisplayName = "Grandfather, Nemesis mentioned that she may have encountered you in Tartarus. How did that go?"
      Speaker = "Melinoe"
      Event = "NeoChronosAboutNemesis01"
    }
    {
      Id = "Chronos_1317"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, very well, indeed! I had presumed that only {#Emph}you {#Prev}would have capacity to face unwanted traces of myself, but as it happens, so can {#Emph}Nemesis! And {#Prev}she is very strong."
      Speaker = "Chronos"
      Event = "NeoChronosAboutNemesis01"
    }
    {
      Id = "MelinoeField_4560"
      InheritFrom = "BaseNarrative"
      DisplayName = "So she {#Emph}was {#Prev}serious! She confronted one of those traces with your aid, and was able to prevail? What, did she hack him to bits with the Stygian Blade?"
      Speaker = "Melinoe"
      Event = "NeoChronosAboutNemesis01"
    }
    {
      Id = "Chronos_1318"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well I prefer not to describe the details, but... she used effective means. This must be possible only because she was so near your path before!"
      Speaker = "Chronos"
      Event = "NeoChronosAboutNemesis01"
    }
    {
      Id = "MelinoeField_4561"
      InheritFrom = "BaseSubtitle"
      DisplayName = "She truly did it..."
      Speaker = "Melinoe"
      Event = "NeoChronosAboutNemesis01"
    }
    {
      Id = "Chronos_1315"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have a question for you, Granddaughter, if you would share your point of view. Do you suppose I ought permit myself to grow a beard? To fit in better with my children, I suppose..."
      Speaker = "Chronos"
      Event = "NeoChronosAboutBeard01"
    }
    {
      Id = "MelinoeField_4557"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, {#Emph}erm... {#Prev}that's largely a matter of taste. Personally, I think growing a beard would mostly make you look older. And, my father and uncles aren't expecting you to {#Emph}be {#Prev}like them."
      Speaker = "Melinoe"
      Event = "NeoChronosAboutBeard01"
    }
    {
      Id = "Chronos_1316"
      InheritFrom = "BaseNarrative"
      DisplayName = "I do suppose that you are right. I always did prefer a cleaner countenance. Perhaps that is the very reason that my children opted otherwise..."
      Speaker = "Chronos"
      Event = "NeoChronosAboutBeard01"
    }
    {
      Id = "MelinoeField_4558"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I could see that..."
      Speaker = "Melinoe"
      Event = "NeoChronosAboutBeard01"
    }
    {
      Id = "MelinoeField_4372"
      InheritFrom = "BaseNarrative"
      DisplayName = "Good news, Grandfather. The Three Fates have returned! And they didn't mention any reprisal when it comes to you. On the contrary, they promised a new age would dawn..."
      Speaker = "Melinoe"
      Event = "NeoChronosPostEpilogue01"
    }
    {
      Id = "Chronos_1294"
      InheritFrom = "BaseNarrative"
      DisplayName = "My, but that is good news! Particularly the no-reprisal part, and it is a relief to know the Three have navigated out of temporary exile. But what is this about a {#Emph}new age?"
      Speaker = "Chronos"
      Event = "NeoChronosPostEpilogue01"
    }
    {
      Id = "MelinoeField_4373"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well... it sounds as though they're not planning to weave as much as they used to. And at some point, the gods apparently will hold less sway over mortals' lives..."
      Speaker = "Melinoe"
      Event = "NeoChronosPostEpilogue01"
    }
    {
      Id = "Chronos_1295"
      InheritFrom = "BaseNarrative"
      DisplayName = "But that is reminiscent of the Golden Age in which {#Emph}I {#Prev}ruled...! Of course, once you have lived sufficient aeons you begin to see such patterns circulating constantly. That which is old becomes the new. How fares our family with all this?"
      Speaker = "Chronos"
      Event = "NeoChronosPostEpilogue01"
    }
    {
      Id = "MelinoeField_4374"
      InheritFrom = "BaseNarrative"
      DisplayName = "I think we're all having to give it some consideration, though we'll have plenty of time. This age may not be soon."
      Speaker = "Melinoe"
      Event = "NeoChronosPostEpilogue01"
    }
    {
      Id = "Chronos_1296"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps not... but even still, this age may arrive before you know it. Take it from me..."
      Speaker = "Chronos"
      Event = "NeoChronosPostEpilogue01"
    }
    {
      Id = "MelinoeField_4375"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Time can move swiftly..."
      Speaker = "Melinoe"
      Event = "NeoChronosPostEpilogue01"
    }
    {
      Id = "Chronos_1434"
      InheritFrom = "BaseNarrative"
      DisplayName = "I always did admire mortalkind... I am pleased the Fates decided they shall have a chance at doing things their way. I shall be curious to see what comes of it."
      Speaker = "Chronos"
      Event = "NeoChronosPostEpilogue02"
    }
    {
      Id = "MelinoeField_5074"
      InheritFrom = "BaseNarrative"
      DisplayName = "Prometheus must have wanted to work with you toward that common goal. Most of what I know of mortals is from the dead... what's the appeal of the living?"
      Speaker = "Melinoe"
      Event = "NeoChronosPostEpilogue02"
    }
    {
      Id = "Chronos_1435"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well it is simply that they understand the value of Time... some of them, anyhow. For they have so little, whilst they live and breathe. It is a pity in some ways, but quite inspiring in others."
      Speaker = "Chronos"
      Event = "NeoChronosPostEpilogue02"
    }
    {
      Id = "MelinoeField_5075"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I do see that in them."
      Speaker = "Melinoe"
      Event = "NeoChronosPostEpilogue02"
    }
    {
      Id = "MelinoeField_5071"
      InheritFrom = "BaseNarrative"
      DisplayName = "Grandfather, do you ever... experience your old feelings of bitterness and spite...? Toward the gods, about your bygone Golden Age, anything of the sort?"
      Speaker = "Melinoe"
      Event = "NeoChronosAboutPast01"
    }
    {
      Id = "Chronos_1432"
      InheritFrom = "BaseNarrative"
      DisplayName = "There is no undoing past mistakes. I held to those feelings for a very long time; they shall never leave me in their entirety. But you have given me this other chance."
      Speaker = "Chronos"
      Event = "NeoChronosAboutPast01"
    }
    {
      Id = "MelinoeField_5072"
      InheritFrom = "BaseNarrative"
      DisplayName = "You seemed so unyielding, so certain of your convictions. Sometimes I still cannot believe the memory of a better past was enough to change your mind."
      Speaker = "Melinoe"
      Event = "NeoChronosAboutPast01"
    }
    {
      Id = "Chronos_1433"
      InheritFrom = "BaseNarrative"
      DisplayName = "I was taken aback as well. My memories of seeing you grow up... they represent but a fraction of my existence. But an important one. Change can happen in an instant."
      Speaker = "Chronos"
      Event = "NeoChronosAboutPast01"
    }
    {
      Id = "MelinoeField_5073"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well may you stay like this."
      Speaker = "Melinoe"
      Event = "NeoChronosAboutPast01"
    }
    {
      Id = "Chronos_1073"
      InheritFrom = "BaseNarrative"
      DisplayName = "...To think the task of vanquishing me almost fell to you! I am most fortunate that it did not, for I could not have easily resisted Retribution Incarnate; I cannot imagine who could!"
      Speaker = "Chronos"
      Event = "NeoChronosWithNemesis01"
    }
    {
      Id = "Nemesis_0431"
      InheritFrom = "BaseNarrative"
      DisplayName = "Me neither, so don't try anything around here. And if you and the Princess need another helping hand cleaning up after yourself, let me know. Been wanting to pitch in."
      Speaker = "Nemesis"
      Event = "NeoChronosWithNemesis01"
    }
    {
      Id = "Chronos_1074"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then you have heard about the nature of our present course? There are so many possibilities which must be ruled out one by one. If you are truly willing to assist in this..."
      Speaker = "Chronos"
      Event = "NeoChronosWithNemesis01"
    }
    {
      Id = "Nemesis_0432"
      InheritFrom = "BaseNarrative"
      DisplayName = "Might as well. Set my mind to it a while back, and can get all the way to Tartarus, just not inside the House."
      Speaker = "Nemesis"
      Event = "NeoChronosWithNemesis01"
    }
    {
      Id = "Chronos_1075"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I can readily address that detail!"
      Speaker = "Chronos"
      Event = "NeoChronosWithNemesis01"
    }
    {
      Id = "Nemesis_0433"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Tell me more."
      Speaker = "Nemesis"
      Event = "NeoChronosWithNemesis01"
    }
    {
      Id = "Chronos_1030"
      InheritFrom = "BaseNarrative"
      DisplayName = "Good, you are here at last! Now that you faithfully re-traced your path, I ought be able to manipulate the course of time such that you find yourself within the House whilst a remnant self of mine sits on your father's throne. Ready?"
      Speaker = "Chronos"
      Event = "NeoChronosAboutTartarus01"
    }
    {
      Id = "MelinoeField_4128"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, not yet. What shall happen if I prevail, let alone fail? Are you certain any of this shall even {#Emph}work?"
      Speaker = "Melinoe"
      Event = "NeoChronosAboutTartarus01"
    }
    {
      Id = "Chronos_1031"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well I am relatively certain, yes! The visions I can conjure up of Asphodel; the principle of this is much the same! And you have likewise demonstrated aptitude at breaking free of temporal restraints."
      Speaker = "Chronos"
      Event = "NeoChronosAboutTartarus01"
    }
    {
      Id = "MelinoeField_4129"
      InheritFrom = "BaseNarrative"
      DisplayName = "So I'm to enter the House exactly as before, and deal with this remnant Chronos as I have in the past... then you shall do the rest?"
      Speaker = "Melinoe"
      Event = "NeoChronosAboutTartarus01"
    }
    {
      Id = "Chronos_1032"
      InheritFrom = "BaseNarrative"
      DisplayName = "Exactly so. First I shall create a shift whilst you enter, then you do as you must with the wrong-headed version of me in {#Emph}there! {#Prev}We shall be {#Emph}rid {#Prev}of the mere {#Emph}possibility {#Prev}of him!"
      Speaker = "Chronos"
      Event = "NeoChronosAboutTartarus01"
    }
    {
      Id = "MelinoeField_4130"
      InheritFrom = "BaseSubtitle"
      DisplayName = "All right, then... off I go!"
      Speaker = "Melinoe"
      Event = "NeoChronosAboutTartarus01"
    }
    {
      Id = "MelinoeField_4131"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not quite. Shall this go much like on the summit of Olympus? The way you conjured up a vision of a time that could have been... "
      Speaker = "Melinoe"
      Event = "NeoChronosAboutTartarus01_B"
    }
    {
      Id = "Chronos_1034"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well I certainly believe this ought transpire as you say! Of course, that which awaits within shall perhaps be a little different in each instance that we venture thus..."
      Speaker = "Chronos"
      Event = "NeoChronosAboutTartarus01_B"
    }
    {
      Id = "MelinoeField_4134"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Very well then."
      Speaker = "Melinoe"
      Event = "NeoChronosAboutTartarus01_B"
    }
    {
      Id = "Chronos_1046"
      InheritFrom = "BaseNarrative"
      DisplayName = "All right, my girl, this shall unfold exactly as before! You leap into the river, I ensure you end up in the proper stream."
      Speaker = "Chronos"
      Event = "NeoChronosAboutTartarus02"
    }
    {
      Id = "Chronos_1035"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, there you are, my girl. As you have faithfully re-traced your path, now I in turn may shift you to a different sort of time in which a remnant of the monstrous Typhon yet looms large over this very place. Ready?"
      Speaker = "Chronos"
      Event = "NeoChronosAboutOlympus01"
    }
    {
      Id = "MelinoeField_4132"
      InheritFrom = "BaseNarrative"
      DisplayName = "So I'm to launch toward the summit, where I'll find Typhon's forces from another time awaiting me, I'll deal with him as I once did, and you shall do the rest?"
      Speaker = "Melinoe"
      Event = "NeoChronosAboutOlympus01"
    }
    {
      Id = "Chronos_1036"
      InheritFrom = "BaseNarrative"
      DisplayName = "If all proceeds as planned, then yes! I shall create a shift as you depart; seek that monster and do battle, so that we may yet eliminate even the {#Emph}possibility {#Prev}of him."
      Speaker = "Chronos"
      Event = "NeoChronosAboutOlympus01"
    }
    {
      Id = "MelinoeField_4133"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not quite. Shall this go much like at my father's House? The way you conjured up a vision of a time that could have been..."
      Speaker = "Melinoe"
      Event = "NeoChronosAboutOlympus01_B"
    }
    {
      Id = "Chronos_1047"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now then, my girl, you know what to expect! Leap for the summit, all whilst I shall ensure you find the proper stream."
      Speaker = "Chronos"
      Event = "NeoChronosAboutOlympus02"
    }
    {
      Id = "MelinoeField_4204"
      InheritFrom = "BaseNarrative"
      DisplayName = "Grandfather...? The wounds our family has suffered perhaps shall never truly heal, but... you've at least tried to take some of the initial steps. So here, this is for you."
      Speaker = "Melinoe"
      Event = "NeoChronosGift01"
    }
    {
      Id = "Chronos_1284"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, what a precious bottle, thank you, Granddaughter! Nectar from Olympus... but, it does look rather good. The custom still is to provide some sort of gift in kind, is that not so? Then here, if you please."
      Speaker = "Chronos"
      Event = "NeoChronosGift01"
    }
    {
      Id = "Chronos_1285"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why, this is {#Emph}very {#Prev}generous of you. The House of Hades had a relatively small supply of this, but in my rancor, I... well, had it all smashed up. This bottle I'll be careful to preserve."
      Speaker = "Chronos"
      Event = "NeoChronosGift02"
    }
    {
      Id = "MelinoeField_4365"
      InheritFrom = "BaseNarrative"
      DisplayName = "Please keep it, knowing Nectar is also to be savored. As for those other bottles, their contents would have soaked into the Earth, so... perhaps the House is a bit brighter now."
      Speaker = "Melinoe"
      Event = "NeoChronosGift02"
    }
    {
      Id = "Chronos_1286"
      InheritFrom = "BaseNarrative"
      DisplayName = "This bottle's golden hue... I cannot imagine a more beauteous color, truly. In this life, I did not realize Olympus delighted in gold the way I do. Although you seem to prefer silver, Granddaughter..."
      Speaker = "Chronos"
      Event = "NeoChronosGift03"
    }
    {
      Id = "MelinoeField_4366"
      InheritFrom = "BaseNarrative"
      DisplayName = "I always have. We work under the Moon and stars... the sheen of silver reminds me of them. But gold now reminds me of Apollo I suppose, and he is quite approachable, in case you haven't met."
      Speaker = "Melinoe"
      Event = "NeoChronosGift03"
    }
    {
      Id = "Chronos_1287"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Apollo, the musician. He seemed a talented young lad..."
      Speaker = "Chronos"
      Event = "NeoChronosGift03"
    }
    {
      Id = "Chronos_1288"
      InheritFrom = "BaseNarrative"
      DisplayName = "I partook of the Nectar which you previously gave to me, and my, such a wondrous flavor... and so I thought, I've not yet rightly earned such privileges from you."
      Speaker = "Chronos"
      Event = "NeoChronosGift04"
    }
    {
      Id = "MelinoeField_4367"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's not a privilege, it's a simple gift. It's not even the fancy stuff! You'll have to try Ambrosia sometime, especially since you enjoy a nice golden hue."
      Speaker = "Melinoe"
      Event = "NeoChronosGift04"
    }
    {
      Id = "Chronos_1289"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ambrosia, yes... perhaps at some point I shall have opportunity to share in it along with this family. But that I know shall take considerable time. No more for now, please, Granddaughter. Not whilst so much is left undone."
      Speaker = "Chronos"
      Event = "NeoChronosGift04"
    }
    {
      Id = "MelinoeField_4368"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Some other time, then."
      Speaker = "Melinoe"
      Event = "NeoChronosGift04"
    }
    {
      Id = "MelinoeField_4205"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What an unusual device... and made of gold. Thank you."
      Speaker = "Melinoe"
      Event = "NPC_Chronos_02.GiftGivenVoiceLines"
    }
    {
      Id = "Chronos_1033"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Farewell!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosLaunchVoiceLines"
    }
    {
      Id = "Chronos_1037"
      InheritFrom = "BaseSubtitle"
      DisplayName = "See you later!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosLaunchVoiceLines"
    }
    {
      Id = "Chronos_1037_B"
      InheritFrom = "BaseSubtitle"
      DisplayName = "See you later!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosLaunchVoiceLines"
    }
    {
      Id = "Chronos_1040"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Another time!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosLaunchVoiceLines"
    }
    {
      Id = "Chronos_1041"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Do take care!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosLaunchVoiceLines"
    }
    {
      Id = "Chronos_1043"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Go get him!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosLaunchVoiceLines"
    }
    {
      Id = "Chronos_1045"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Go on then!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosLaunchVoiceLines"
    }
    {
      Id = "Chronos_1399"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Like {#Emph}clockwork!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosLaunchVoiceLines"
    }
    {
      Id = "Chronos_1397"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Do beware ahead!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosLaunchVoiceLines"
    }
    {
      Id = "Chronos_1398"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Go on my Time Keeper!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosLaunchVoiceLines"
    }
    {
      Id = "Chronos_1396"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Watch out for {#Emph}me {#Prev}up there!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosLaunchVoiceLines"
    }
    {
      Id = "Chronos_1336"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Time to go."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosLaunchVoiceLines"
    }
    {
      Id = "Chronos_1337"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Right! Time to go."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosLaunchVoiceLines"
    }
    {
      Id = "Chronos_1038"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hello! Goodbye!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosLaunchVoiceLines"
    }
    {
      Id = "Chronos_1039"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hello and goodbye!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosLaunchVoiceLines"
    }
    {
      Id = "Chronos_1042"
      InheritFrom = "BaseSubtitle"
      DisplayName = "There you are!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosLaunchVoiceLines"
    }
    {
      Id = "Chronos_1044"
      InheritFrom = "BaseSubtitle"
      DisplayName = "See you shortly!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosLaunchVoiceLines"
    }
    {
      Id = "Chronos_1340"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Solid Gold!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosGoldifyVoiceLines"
    }
    {
      Id = "Chronos_1338"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}To Gold!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosGoldifyVoiceLines"
    }
    {
      Id = "Chronos_1339"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}To Gold!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosGoldifyVoiceLines"
    }
    {
      Id = "Chronos_1341"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}A golden opportunity!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosGoldifyVoiceLines"
    }
    {
      Id = "Chronos_1342"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Gold."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosGoldifyVoiceLines"
    }
    {
      Id = "Chronos_1343"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Gold!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosGoldifyVoiceLines"
    }
    {
      Id = "Chronos_1344"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Boon? Gold!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosGoldifyVoiceLines"
    }
    {
      Id = "Chronos_1345"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Onion? Gold!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosGoldifyVoiceLines"
    }
    {
      Id = "Chronos_1346"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ashes? Gold!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosGoldifyVoiceLines"
    }
    {
      Id = "Chronos_1347"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Bones? Gold."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosGoldifyVoiceLines"
    }
    {
      Id = "Chronos_1348"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Nectar? Gold."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosGoldifyVoiceLines"
    }
    {
      Id = "Chronos_1349"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hammer? Gold."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosGoldifyVoiceLines"
    }
    {
      Id = "Chronos_1350"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Moon? Gold!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosGoldifyVoiceLines"
    }
    {
      Id = "Chronos_1351"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Tonic? Gold!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosGoldifyVoiceLines"
    }
    {
      Id = "Chronos_1352"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Centaur Heart? Centaur Gold!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosGoldifyVoiceLines"
    }
    {
      Id = "Chronos_1394"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Pom? Gold."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosGoldifyVoiceLines"
    }
    {
      Id = "Chronos_1395"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Armor? Gold!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosGoldifyVoiceLines"
    }
    {
      Id = "Nyx_0151"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh..."
      Speaker = "Nyx"
      Event = "GlobalVoiceLines.ChronosGoldifyVoiceLines"
    }
    {
      Id = "Nyx_0152"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Odd..."
      Speaker = "Nyx"
      Event = "GlobalVoiceLines.ChronosGoldifyVoiceLines"
    }
    {
      Id = "Nyx_0153"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Unusual..."
      Speaker = "Nyx"
      Event = "GlobalVoiceLines.ChronosGoldifyVoiceLines"
    }
    {
      Id = "Nyx_0154"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Creation..."
      Speaker = "Nyx"
      Event = "GlobalVoiceLines.ChronosGoldifyVoiceLines"
    }
    {
      Id = "Nyx_0155"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Chaos...?"
      Speaker = "Nyx"
      Event = "GlobalVoiceLines.ChronosGoldifyVoiceLines"
    }
    {
      Id = "Nyx_0156"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hmm..."
      Speaker = "Nyx"
      Event = "GlobalVoiceLines.ChronosGoldifyVoiceLines"
    }
    {
      Id = "Intercom_0884"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That Fear in the air... it is none other than your own."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0885"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You, who invoke the Night: Suffer the consequence."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0886"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Fear is growing in you, is it not?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0887"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You pledge yourself to a forgotten cause."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0083"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Weakling! You shall never be her equal."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0084"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Your master cannot best me; how could you?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0890"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You cannot even find your way out of those woods?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0891"
      InheritFrom = "BaseSubtitle"
      DisplayName = "So many lost souls in Erebus! You are but one."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0088"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Distracted by the Sirens' song, were you?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0089"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Like so many sailors sent to a watery grave..."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0713"
      InheritFrom = "BaseSubtitle"
      DisplayName = "May the Sirens' song torment you even beyond their vicinity."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0714"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Drowned out once more by the din of the Sirens' song!"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0715"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It seems that wretched cur is good for something after all!"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0716"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That three-headed beast has no kinship for you, or anyone."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0717"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Only a hollow fool would deign to tame such a monstrosity."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0718"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Your poor old family dog just wanted to be left alone."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0719"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Best not to come between a shepherd and his flock."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0720"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Even a sightless Cyclops saw through your pathetic plan."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0721"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You are nothing but a morsel to a peckish Cyclops, girl."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0722"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Merely another sheep that decided to step out of line."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0723"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Wherever you may voyage, Strife shall follow in your wake."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0724"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This could have ended quickly, but you had to invite Strife."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0725"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Perhaps {#Emph}you {#Prev}are the cause of all this strife, not Strife herself?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0726"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The sting of that infernal Rail of Adamant is {#Emph}painful{#Prev}, is it not?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0727"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A Titan's vengeance is a flame that cannot be quenched."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0728"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Why bother when Prometheus has seen that you shall fail?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0729"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Titan of Foresight chose the winning side; my own."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0730"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It seems you made our poor Prometheus very upset again."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0888"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The fall of Mount Olympus is inevitable, as you plainly see."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0889"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The gods are not so proud as they once were."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0090"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The surface is no place for you, my girl."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0091"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Should you have reached Olympus, what then?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0092"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The age of gods is drawing to a close."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0067"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You gods are too unfit to rule this world. That is apparent from a single glance."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0065"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You took everything from me, Hades. It's only fitting I should do the same."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0066"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What happened to your daughter, Hades, {#Emph}hm? {#Prev}I'll ask nicely only one last time."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0068"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You and my children stopped me once, Hades. But now, I've had plenty of time to prepare."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0069"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You speak of justice, Hades? How many mortal souls have you cruelly tortured, for how long?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0085"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Shall you remain forever lost in Erebus?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0093"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I foresee every one of your useless attempts."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0086"
      InheritFrom = "BaseSubtitle"
      DisplayName = "So fiercely fought, yet so far from your goal."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0087"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I have naught to fear from witches such as you."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0021"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}<Laughter>"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0022"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}<Laughter>"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0036"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You cannot stop Time."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0037"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Give up already, girl."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0038"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You appear to be a slow learner."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0039"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Another unsuccessful try."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0040"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Are you becoming used to this result?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0041"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You struggle ceaselessly, but to what end?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0042"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I almost pity you your wasted efforts."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0043"
      InheritFrom = "BaseSubtitle"
      DisplayName = "All of your efforts, once again in vain."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0044"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You are beginning to annoy me, girl."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0045"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Never trifle with a Titan, girl."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0046"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I ought to have you chained in Tartarus."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0047"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Cease with these pointless attempts of yours."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0048"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Your failure was inevitable."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0049"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You are spirited, but not invincible."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0050"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Fates shall be no kinder to you next time."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0051"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Was that the limit of your power, hm?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_0052"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You could have done better than that."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosDeathTauntVoiceLines"
    }
    {
      Id = "Intercom_1282"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wait, what is going on... how can this {#Emph}be?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalyLocatedVoiceLines[3]"
    }
    {
      Id = "Intercom_1283"
      InheritFrom = "BaseNarrative"
      DisplayName = "You, who stalks me as a nightmare... {#Emph}begone!"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalyLocatedVoiceLines[3]"
    }
    {
      Id = "Intercom_0100"
      InheritFrom = "BaseNarrative"
      DisplayName = "Where do you think you are going?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalyLocatedVoiceLines[3]"
    }
    {
      Id = "Intercom_0101"
      InheritFrom = "BaseNarrative"
      DisplayName = "Such mindless, flailing persistence on your part."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalyLocatedVoiceLines[3]"
    }
    {
      Id = "Intercom_0102"
      InheritFrom = "BaseNarrative"
      DisplayName = "You venture into {#Emph}my {#Prev}domain."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalyLocatedVoiceLines[3]"
    }
    {
      Id = "Intercom_0103"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know what you are attempting to achieve."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalyLocatedVoiceLines[3]"
    }
    {
      Id = "Intercom_0104"
      InheritFrom = "BaseNarrative"
      DisplayName = "My tolerance for you grows very thin."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalyLocatedVoiceLines[3]"
    }
    {
      Id = "Intercom_0105"
      InheritFrom = "BaseNarrative"
      DisplayName = "You wish to see your father's domain, do you?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalyLocatedVoiceLines[3]"
    }
    {
      Id = "Intercom_0106"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your efforts have not gone unnoticed, Granddaughter."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalyLocatedVoiceLines[3]"
    }
    {
      Id = "Intercom_0107"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps you should return some other {#Emph}time."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalyLocatedVoiceLines[3]"
    }
    {
      Id = "Intercom_0108"
      InheritFrom = "BaseNarrative"
      DisplayName = "This never was your father's realm."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalyLocatedVoiceLines[3]"
    }
    {
      Id = "Intercom_0109"
      InheritFrom = "BaseNarrative"
      DisplayName = "You speak to me of nightmares; here is one."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalyLocatedVoiceLines[3]"
    }
    {
      Id = "Intercom_0148"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You wish to traipse through this realm, then here! Bask in it."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalyEnteredVoiceLines"
    }
    {
      Id = "Intercom_0110"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Behold the splendor of your father's Underworld."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalyEnteredVoiceLines"
    }
    {
      Id = "Intercom_0112"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Underworld you never knew! But, you did not miss much..."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalyEnteredVoiceLines"
    }
    {
      Id = "Intercom_0113"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A glimpse of the past, or one of your nightmares?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalyEnteredVoiceLines"
    }
    {
      Id = "Intercom_0117"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Your father's wretches within Asphodel so hated trespassers."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalyEnteredVoiceLines"
    }
    {
      Id = "Intercom_0118"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Welcome to the verdant meadows of Asphodel."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalyEnteredVoiceLines"
    }
    {
      Id = "Intercom_0119"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Bask now in the intolerable heat of Asphodel."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalyEnteredVoiceLines"
    }
    {
      Id = "Intercom_0111"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This is your father's realm as once it was."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalyEnteredVoiceLines"
    }
    {
      Id = "MelinoeField_0248"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That old man... it was {#Emph}him..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.AnomalyEnteredVoiceLines"
    }
    {
      Id = "MelinoeField_0190"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Where am I... or {#Emph}when..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.AnomalyEnteredVoiceLines"
    }
    {
      Id = "MelinoeField_0191"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This isn't real..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.AnomalyEnteredVoiceLines"
    }
    {
      Id = "MelinoeField_0192"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Trapped..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.AnomalyEnteredVoiceLines"
    }
    {
      Id = "MelinoeField_0193"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This again..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.AnomalyEnteredVoiceLines"
    }
    {
      Id = "MelinoeField_0194"
      InheritFrom = "BaseSubtitle"
      DisplayName = "He's trying to slow me down..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.AnomalyEnteredVoiceLines"
    }
    {
      Id = "MelinoeField_0195"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Is this really Asphodel...?"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.AnomalyEnteredVoiceLines"
    }
    {
      Id = "Intercom_0149"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What witchery is this...?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalyCombatBeginsVoiceLines"
    }
    {
      Id = "Intercom_0130"
      InheritFrom = "BaseSubtitle"
      DisplayName = "So, you can see a pathway out..."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalyCombatBeginsVoiceLines"
    }
    {
      Id = "Intercom_0131"
      InheritFrom = "BaseSubtitle"
      DisplayName = "But you just got here..."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalyCombatBeginsVoiceLines"
    }
    {
      Id = "Intercom_0132"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Do you really have to go so soon?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalyCombatBeginsVoiceLines"
    }
    {
      Id = "Intercom_0133"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Why do you so wish to wake from such a beautiful dream?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalyCombatBeginsVoiceLines"
    }
    {
      Id = "Intercom_0134"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Who taught you to perform such trickery?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalyCombatBeginsVoiceLines"
    }
    {
      Id = "Intercom_0135"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You know something of Time and Dream, do you?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalyCombatBeginsVoiceLines"
    }
    {
      Id = "Intercom_0150"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You knew how to resist my little spell..."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalySurvivedVoiceLines"
    }
    {
      Id = "Intercom_0120"
      InheritFrom = "BaseSubtitle"
      DisplayName = "So what if you withstood all that..."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalySurvivedVoiceLines"
    }
    {
      Id = "Intercom_0121"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Is this truly that which you are fighting for?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalySurvivedVoiceLines"
    }
    {
      Id = "Intercom_0122"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You survive, but you do not learn."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalySurvivedVoiceLines"
    }
    {
      Id = "Intercom_0123"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That was, of course, a very different time."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalySurvivedVoiceLines"
    }
    {
      Id = "Intercom_0124"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The times can change, but often stay the same."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalySurvivedVoiceLines"
    }
    {
      Id = "Intercom_0125"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You wish your nightmares to become reality?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalySurvivedVoiceLines"
    }
    {
      Id = "Intercom_0126"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Continue at your peril, Granddaughter."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalySurvivedVoiceLines"
    }
    {
      Id = "Intercom_0127"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Such nightmares shall consume you, in the end."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalySurvivedVoiceLines"
    }
    {
      Id = "Intercom_0128"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Cease this whilst you have the opportunity."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalySurvivedVoiceLines"
    }
    {
      Id = "Intercom_0129"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Even still you rush headlong toward oblivion."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.AnomalySurvivedVoiceLines"
    }
    {
      Id = "MelinoeField_0216"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Made it back..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.AnomalyConcludedVoiceLines"
    }
    {
      Id = "MelinoeField_0217"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Like waking from a dream..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.AnomalyConcludedVoiceLines"
    }
    {
      Id = "MelinoeField_0218"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It'll take more than that, Chronos..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.AnomalyConcludedVoiceLines"
    }
    {
      Id = "MelinoeField_0219"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Merely a vision..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.AnomalyConcludedVoiceLines"
    }
    {
      Id = "MelinoeField_0220"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Back to reality..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.AnomalyConcludedVoiceLines"
    }
    {
      Id = "MelinoeField_1410"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just an illusion...!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.AnomalyConcludedVoiceLines"
    }
    {
      Id = "Chronos_1418"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ah-hah!"
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.ChronosHideAndSeekVoiceLines"
    }
    {
      Id = "MelinoeField_5055"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ah!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.ChronosHideAndSeekVoiceLines"
    }
    {
      Id = "Intercom_7352"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Who reconfigured Tartarus?! Oh, it is you, Daughter...!"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_7353"
      InheritFrom = "BaseSubtitle"
      DisplayName = "These disrespecting Satyrs and such are all in for it now."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_7354"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Everything proceeds as planned."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_7355"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Satyrs and their ilk yet remain dedicated to the Titan's cause."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_7356"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Daughter, you have full permission to ransack this place."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_7357"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Everything in the vicinity must go!"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_7358"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This blasted temporal decor can never stay destroyed!"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_7359"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We welcome you unto the lowest depths, Daughter."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_7360"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Permission granted to the Princess of the Underworld."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_7361"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Whatever it takes to ensure time flows freely from here on..."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_7362"
      InheritFrom = "BaseSubtitle"
      DisplayName = "These wretches shall not welcome you, Daughter, but I shall."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_7363"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hardly the first time violence broke out within Tartarus..."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_7364"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Your brother used to utterly destroy this place, so why not you?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_7365"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I shall be having a word with Father about the extent of this incursion."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_7366"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Your contributions to our clean-up effort are appreciated, Daughter."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_7367"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We have not seen you here in quite some time, Daughter."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_7368"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Where have you been, Melinoë? Not in the Underworld, that we know."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_7369"
      InheritFrom = "BaseSubtitle"
      DisplayName = "So even these are remnant forces from the Titan, then?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_7370"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Spare not a single wretch that dares to stand against you, Daughter."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_7371"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Proceed with caution, or whatever is the most efficient course."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_0473"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You are trespassing on private property..."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_0151"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Be very careful where you tread, my girl..."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_0136"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How interesting that you are able to resist..."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_0475"
      InheritFrom = "BaseSubtitle"
      DisplayName = "An infiltrator breached through our defenses...!"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_0476"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We seem to have a bit of an infestation here..."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_0477"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It seems we have an unscheduled visitor..."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_0478"
      InheritFrom = "BaseSubtitle"
      DisplayName = "My worshipers shall soften you up, if not stop you outright!"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_0481"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Perhaps we cannot find you in the Fields, but {#Emph}here?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_0483"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ah{#Prev}, Granddaughter! How kind of you to visit us again!"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_0484"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We bid you a warm welcome to the depths of Tartarus."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_0485"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Whatever brings you to my doorstep once again, my girl?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_0487"
      InheritFrom = "BaseSubtitle"
      DisplayName = "As predictable as the turning of the gears throughout this place..."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_0488"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Did you perhaps forget something when last you interfered?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_0490"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Anybody sensible would {#Emph}flee {#Prev}from Tartarus, not {#Emph}barge {#Prev}right in!"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_0491"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This place was once my tomb; shall it be yours?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_0479"
      InheritFrom = "BaseSubtitle"
      DisplayName = "She has returned. Muster our defenses!"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_0492"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I shall be anticipating your arrival, Granddaughter."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_0474"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Why must everybody in our family be such an irritant?"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_0480"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Confound it, but you are a difficult one to pin down..."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_0482"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Do tell Hades I said greetings if you happen to run into him!"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_0486"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We have not seen you in a little while, my girl."
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "Intercom_0489"
      InheritFrom = "BaseSubtitle"
      DisplayName = "She is heading for the House again. Stop her!"
      Speaker = "Intercom"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "MelinoeField_1538"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No more hiding in shadows...!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "MelinoeField_1539"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Try and stop me...!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "MelinoeField_1540"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Out of my way!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "MelinoeField_1541"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm not finished with you!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "MelinoeField_1542"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll see you soon, Titan!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
    {
      Id = "MelinoeField_1543"
      InheritFrom = "BaseSubtitle"
      DisplayName = "He hides behind these wretches!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.ChronosAlertVoiceLines"
    }
  ]
}
