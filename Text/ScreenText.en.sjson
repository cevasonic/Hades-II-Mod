  	  Id = "ShrineScreen_BountyAvailable_BelowPoints"
  	  DisplayName = "More {$Keywords.ShrinePoints} required for the next {$Keywords.Bounty}."
  	}
    {
  	  Id = "ShrineScreen_BountyAvailable_ExactPoints"
  	  DisplayName = "{$Keywords.Bounty} marked. Enact it, and earn Night's reward."
  	}
    {
  	  Id = "ShrineScreen_BountyAvailable_ExcessPoints1"
  	  DisplayName = "{$Keywords.Bounty} marked. {$Keywords.ShrinePoints} exceeds the requirement."
  	}
    {
  	  Id = "ShrineScreen_BountyAvailable_ExcessPoints2"
      DisplayName = "{$Keywords.Bounty} marked. {$Keywords.ShrinePoints} exceeds the requirement by a lot."
  	}
    {
  	  Id = "ShrineScreen_BountyAvailable_ExcessPoints3"
      DisplayName = "{$Keywords.Bounty} marked. {$Keywords.ShrinePoints} exceeds the requirement, not that you care."
  	}
    {
      Id = "ShrineScreen_BountyAvailable_MaxPoints"
      DisplayName = "{$Keywords.Bounty} marked. {$Keywords.ShrinePoints} is for the weak, is that what you think?"
    }

    /* WellShop / Well Shop */
    {
      Id = "WellShop_Title"
      DisplayName = "Well of Charon"
    }
    {
      Id = "UseWell_Unlocked"
      DisplayName = "{I} Shop"
    }
    {
      Id = "UseWell_Locked"
      DisplayName = "{I} {#UseTextDisabledFormat}Shop?"
    }
    {
      Id = "UseStore"
      DisplayName = "{I} Shop"
    }

    {
      Id = "WellShop_FlavorText01"
      DisplayName = "not even the ravages of time can spoil the boatman's quality goods."
    }
    {
      Id = "WellShop_FlavorText02"
      DisplayName = "the boundless riches of the underworld are never simple to secure."
    }
    {
      Id = "WellShop_FlavorText03"
      DisplayName = "the deathless boatman of the river styx yet plies his ancient trade."
    }

    /* Sell Trait Shop / SellTrait Shop / Trait Shop */
    {
      Id = "UseTraitShop_Unlocked"
      DisplayName = "{I} Sell"
    }
    {
      Id = "UseTraitShop_Locked"
      DisplayName = "{I} {#UseTextDisabledFormat}Sell?"
    }
    {
      Id = "SellTrait_Title"
      DisplayName = "Pool of Purging"
    }
    {
      Id = "SellTraitPrefix"
      DisplayName = "Purge"
    }
    {
      Id = "Sell_ItemCost"
      DisplayName = "+{$TempTextData.Amount} {!Icons.Currency}"
      OverwriteLocalization = true
    }
    {
      Id = "SellTrait_Hint"
      DisplayName = "sacrifice your boons in exchange for {!Icons.Currency}."
    }

    {
      Id = "SellTrait_FlavorText01"
      DisplayName = "one can free oneself from even the most compelling influences."
    }
    {
      Id = "SellTrait_FlavorText02"
      DisplayName = "the will of the olympians is tenuous, at best, within the underworld."
    }
    {
      Id = "SellTrait_FlavorText03"
      DisplayName = "the gift of the gods is worth a tidy sum in the land of the dead."
    }

    /* Surface Shop */
    {
      Id = "SurfaceShop_Title"
      DisplayName = "Shrine of Hermes"
    }
    {
      Id = "Store_Hint"
      DisplayName = "upon retreat, all {!Icons.Currency} will be lost. all sales final."
    }
    {
      Id = "PendingDeliveryDuration"
      DisplayName = "{#LockedFormat}In Stock. {#Prev}{#PropertyFormat}Delivered after {#BoldFormat}{$TempTextData.Delay} {#Prev}{$Keywords.Encounter}."
    }
    {
      Id = "SpeedUpDelivery"
      DisplayName = "{#LegendaryFormat}Ordered! {#Prev}{#PropertyFormat}Arriving after {#BoldFormat}{$TempTextData.Delay} {$Keywords.Encounter}{#Prev}, or Pay Extra to Get It {#BoldFormatGraft}Now{#Prev}!!"
    }

  ]
}