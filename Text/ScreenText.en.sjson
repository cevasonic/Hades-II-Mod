    }

    /* Zeus Boons */
    {
      Id = "ZeusUpgrade"
      DisplayName = "Zeus"
      Description = "King of the Olympians"
    }
    {
      Id = "ZeusUpgrade_FlavorText01"
      DisplayName = "once he led his fellow gods to victory against the titans, and so intends again."
    }
    {
      Id = "ZeusUpgrade_FlavorText02"
      DisplayName = "the heavens themselves could split asunder if he so willed."
    }
    {
      Id = "ZeusUpgrade_FlavorText03"
      DisplayName = "the patriarch of mount olympus did not rise to his station by mere happenstance."
    }

    /* Hera Boons */
    {
      Id = "HeraUpgrade"
      DisplayName = "Hera"
      Description = "Queen of the Olympians"
    }
    {
      Id = "HeraUpgrade_FlavorText01"
      DisplayName = "the goddess of unions knows even the strongest bonds can break."
    }
    {
      Id = "HeraUpgrade_FlavorText02"
      DisplayName = "she alone has the capacity to keep the other gods in check."
    }
    {
      Id = "HeraUpgrade_FlavorText03"
      DisplayName = "her powers over the intangible are never to be underestimated."
    }

    /* Poseidon Boons */
    {
      Id = "PoseidonUpgrade"
      DisplayName = "Poseidon"
      Description = "God of the Sea"
    }
    {
      Id = "PoseidonUpgrade_FlavorText01"
      DisplayName = "the vast seas roil when he wills it thus, and the mountains tremble."
    }
    {
      Id = "PoseidonUpgrade_FlavorText02"
      DisplayName = "the surface of the world in its entirety is his domain by fate."
    }
    {
      Id = "PoseidonUpgrade_FlavorText03"
      DisplayName = "the raw might of a crashing wave; a simple manifesting of his awesome strength."
    }

    /* Apollo Boons */
    {
      Id = "ApolloUpgrade"
      DisplayName = "Apollo"
      Description = "God of Light"
    }
    {
      Id = "ApolloUpgrade_FlavorText01"
      DisplayName = "brilliance without measure, talent without equal."
    }
    {
      Id = "ApolloUpgrade_FlavorText02"
      DisplayName = "he has yet to find a skill at which he does not excel."
    }
    {
      Id = "ApolloUpgrade_FlavorText03"
      DisplayName = "music and poetry would both be void of life if not for him."
    }

    /* Aphrodite Boons */
    {
      Id = "AphroditeUpgrade"
      DisplayName = "Aphrodite"
      Description = "Goddess of Love"
    }
    {
      Id = "AphroditeUpgrade_FlavorText01"
      DisplayName = "she instills in mortalkind the longing that inspires them and spurs them to action."
    }
    {
      Id = "AphroditeUpgrade_FlavorText02"
      DisplayName = "her power is such that, even in the realm of the dead, a certain beauty thrives."
    }
    {
      Id = "AphroditeUpgrade_FlavorText03"
      DisplayName = "mortals can perhaps survive without her power; but without it, cannot truly live."
    }

    /* Demeter Boons */
    {
      Id = "DemeterUpgrade"
      DisplayName = "Demeter"
      Description = "Goddess of Seasons"
    }
    {
      Id = "DemeterUpgrade_FlavorText01"
      DisplayName = "she controls the very cycle of life and death; of abundance and decay."
    }
    {
      Id = "DemeterUpgrade_FlavorText02"
      DisplayName = "with the turning of the seasons can come hope and renewal, or desolation beyond words."
    }
    {
      Id = "DemeterUpgrade_FlavorText03"
      DisplayName = "the mistress of seasons holds sway over everything between heaven and earth."
    }

    /* Hestia Boons */
    {
      Id = "HestiaUpgrade"
      DisplayName = "Hestia"
      Description = "Goddess of Flame"
    }
    {
      Id = "HestiaUpgrade_FlavorText01"
      DisplayName = "from the comfort of the hearth, to the rage of an inferno."
    }
    {
      Id = "HestiaUpgrade_FlavorText02"
      DisplayName = "the eldest, most reclusive olympian has fire in her heart."
    }
    {
      Id = "HestiaUpgrade_FlavorText03"
      DisplayName = "her flames bring quaint comfort, or ruinous destruction."
    }
    {
      Id = "HestiaUpgrade_SacrificeBoon"
      DisplayName = "Burnt Offering"
    }
    {
      Id = "HestiaUpgrade_SacrificeBoon_FlavorText"
      DisplayName = "make your sacrifice to the goddess of the hearth."
    }
    {
      Id = "Hestia_UpgradeChoice_Sacrifice"
      DisplayName = "{SL} CHOOSE"
    }

    /* Hephaestus Boons */
    {
      Id = "HephaestusUpgrade"
      DisplayName = "Hephaestus"
      Description = "God of the Forge"
    }
    {
      Id = "HephaestusUpgrade_FlavorText01"
      DisplayName = "the forge-god's volcanic furnace births the world's finest arms."
    }
    {
      Id = "HephaestusUpgrade_FlavorText02"
      DisplayName = "the strongest metal still bends effortlessly to his will."
    }
    {
      Id = "HephaestusUpgrade_FlavorText03"
      DisplayName = "the incomparable arms and armor that he fashions are prized even by gods."
    }

    /* Hermes Boons */
    {
      Id = "HermesUpgrade"
      DisplayName = "Hermes"
      Description = "God of Swiftness"
    }
    {
      Id = "HermesUpgrade_FlavorText01"
      DisplayName = "the family messenger is often tasked with spreading vital news, or keeping vital secrets."
    }
    {
      Id = "HermesUpgrade_FlavorText02"
      DisplayName = "none can travel as swiftly from the peaks of olympus to the depths of the underworld."
    }
    {
      Id = "HermesUpgrade_FlavorText03"
      DisplayName = "the herald of the gods is never one to sit idly by when opportunity awaits."
    }

    /* Artemis Boons */
    {
      Id = "ArtemisUpgrade"
      DisplayName = "Artemis"
      Description = "Goddess of the Hunt"
    }
    {
      Id = "ArtemisUpgrade_FlavorText01"
      DisplayName = "the lone huntress moves in moonlight to the rhythms of the earth."
    }
    {
      Id = "ArtemisUpgrade_FlavorText02"
      DisplayName = "she moves through the woods like a flash of silver, lethal to her prey."
    }
    {
      Id = "ArtemisUpgrade_FlavorText03"
      DisplayName = "the hunt means knowing when to be utterly still, and knowing when to strike."
    }

    /* Dionysus Boons */
    {
      Id = "DionysusUpgrade_FlavorText01"
      DisplayName = "mirth is needed more than ever in the darkest of times."
    }
    {
      Id = "DionysusUpgrade_FlavorText02"
      DisplayName = "the greatest joys cannot be contained and are to be shared."
    }
    {
      Id = "DionysusUpgrade_FlavorText03"
      DisplayName = "moments spent in good company and cheer are to be savored."
    }

    /* Athena Boons */
    {
      Id = "AthenaUpgrade_FlavorText01"
      DisplayName = "however fraught the path to victory may be, she always finds the way."
    }
    {
      Id = "AthenaUpgrade_FlavorText02"
      DisplayName = "with wisdom, many challenges may be overcome; and many more, avoided."
    }
    {
      Id = "AthenaUpgrade_FlavorText03"
      DisplayName = "she who bears the aegis is protector of the heavens and the righteous."
    }

    /* Ares Boons */
    {
      Id = "AresUpgrade"
      DisplayName = "Ares"
      Description = "God of War"
    }
    {
      Id = "AresUpgrade_FlavorText01"
      DisplayName = "he stokes his violent conflicts so that mortalkind can never multiply too quickly."
    }
    {
      Id = "AresUpgrade_FlavorText02"
      DisplayName = "violence is a force of nature in and of itself, and not merely a consequence."
    }
    {
      Id = "AresUpgrade_FlavorText03"
      DisplayName = "the impulse to harm and eliminate can be as powerful as the impulse to nurture and create."
    }

    /* Hades Boons */
    {
      Id = "HadesUpgrade_FlavorText01"
      DisplayName = "his is an infernal strength flowing from darkest depths."
    }
    {
      Id = "HadesUpgrade_FlavorText02"
      DisplayName = "the living and the dead yet fear his very name."
    }
    {
      Id = "HadesUpgrade_FlavorText03"
      DisplayName = "his surpassing might once overwhelmed the titans."
    }

    /* Selene Spells / SpellScreen */
    {
      Id = "SpellScreenMenu_Title"
      DisplayName = "Gifts of the Moon"
    }
    {
      Id = "SpellScreenMenu_Subtitle"
      DisplayName = "you received:"
    }
    {
      Id = "SpellDrop_FlavorText01"
      DisplayName = "she in her silver chariot conceals ferocious power known to few."
    }
    {
      Id = "SpellDrop_FlavorText02"
      DisplayName = "the eye of night watches silently, taking stock of all that transpires."
    }
    {
      Id = "SpellDrop_FlavorText03"
      DisplayName = "her distant silver light is a guiding beacon to all those who move in shadow."
    }
    {
      Id = "Spell_Select"
      DisplayName = "{SL} CHOOSE"
    }

    /* Chaos Boons */
    {
      Id = "TrialUpgrade"
      DisplayName = "Chaos"
      Description = "Primordial Originator"
    }
    {
      Id = "TrialUpgrade_FlavorText01"
      DisplayName = "all once sprang from the infinite void, even time itself."
    }
    {
      Id = "TrialUpgrade_FlavorText02"
      DisplayName = "from an unfathomable abyss emerged creation and life, gods and mortals."
    }
    {
      Id = "TrialUpgrade_FlavorText03"
      DisplayName = "the darkness from which all existence emerged yet remains."
    }

    /* WeaponUpgrade Screen / Daedalus Hammer Screen */
    {
      Id = "WeaponUpgrade_FlavorText01"
      DisplayName = "the ever-reclusive artisan lets his masterwork do the talking."
    }
    {
      Id = "WeaponUpgrade_FlavorText02"
      DisplayName = "no mere weaponsmith can hone the nocturnal arms; only one of talent to surpass the gods."
    }
    {
      Id = "WeaponUpgrade_FlavorText03"
      DisplayName = "his surpassing skill as craftsman and inventor was well-recognized even in death." 
    }

    {
      Id = "WeaponUpgradeScreen_Kills"
      DisplayName = "Foes Vanquished:"
    }
    {
      Id = "WeaponUpgradeScreen_Clears"
      DisplayName = "Nights Prevailed:"
    }
    {
      Id = "WeaponUpgradeScreen_ClearTimeRecord_Underworld"
      DisplayName = "{!Icons.UnderworldIcon} Swiftest Victory:"
    }
    {
      Id = "WeaponUpgradeScreen_ClearTimeRecord_Surface"
      DisplayName = "{!Icons.SurfaceIcon} Swiftest Victory:"
    }
    {
      Id = "WeaponUpgradeScreen_ShrinePointRecord_Underworld"
      DisplayName = "{!Icons.UnderworldIcon} Highest {!Icons.ShrinePoint}{#BoldFormatGraft}Fear{#Prev}:"
    }
    {
      Id = "WeaponUpgradeScreen_ShrinePointRecord_Surface"
      DisplayName = "{!Icons.SurfaceIcon} Highest {!Icons.ShrinePoint}{#BoldFormatGraft}Fear{#Prev}:"
    }

    /* StackUpgrade Screen / Pom of Power Screen */
    {
      Id = "StackUpgrade_FlavorText01"
      DisplayName = "its each and every seed, like a drop of blood; life as well as death."
    }
    {
      Id = "StackUpgrade_FlavorText02"
      DisplayName = "whether they sprang from the surface or from underworld, who now can say?"
    }
    {
      Id = "StackUpgrade_FlavorText03"
      DisplayName = "the power of the warmth of spring; the strength of dark of the earth."
    }

    /* TalentScreen / Path of the Stars / Path of Stars */
    {
      Id = "TalentScreenMenu_Title"
      DisplayName = "Path of Stars"
    }
    {
      Id = "TalentDrop_FlavorText01"
      DisplayName = "one's possibilities for growth are as innumerable as the stars."
    }
    {
      Id = "TalentDrop_FlavorText02"
      DisplayName = "the constant stars above, eternal in their multitude and possibility."
    }
    {
      Id = "TalentDrop_FlavorText03"
      DisplayName = "even the moon must find her way across the sky by certain means."
    }

    {
      Id = "AdditionalTalentPointDisplay"
      DisplayName = "Talent Point(s)"
    }

    /* QuestLog / Quest Log / Fated List */
    {
      Id = "UseQuestLog"
      DisplayName = "{I} Foresee"
    }
    {
      Id = "QuestLogScreen_Title"
      DisplayName = "The Fated List"
    }
    {
      Id = "QuestLogScreen_Flavor"
      DisplayName = "“The Weavings of the Three Fates Invariably Come to Pass”"
    }
    {
      Id = "QuestLogReward"
      DisplayName = "{#HighlightQuestReward}{#Prev}+{$TempTextData.Amount}{!TempTextData.Icon}"
    }
    {
      Id = "QuestLog_SelectHint"
      DisplayName = "A Prophecy Shall be Selected"
    }
    {
      Id = "QuestLog_SelectHintAllClear"
      DisplayName = "\n\n All Minor Prophecies Fulfilled \n\n Thank You For Ensuring Fate"
    }
    {
      Id = "QuestLog_ProgressCountIncomplete"
      DisplayName = "{!Icons.QuestProgressIncomplete} {$TempTextData.Current} {!Icons.SlashDark} {$TempTextData.Goal}"
      OverwriteLocalization = true
    }
    {
      Id = "QuestLog_ProgressCountComplete"
      DisplayName = "{!Icons.QuestProgressComplete} {$TempTextData.Current} {!Icons.Slash} {$TempTextData.Goal}"
      OverwriteLocalization = true
    }
    {
      Id = "QuestLog_QuestProgressIncomplete"
      DisplayName = "{!Icons.QuestProgressIncomplete}"
      OverwriteLocalization = true
    }
    {
      Id = "QuestLog_QuestProgressComplete"
      DisplayName = "{!Icons.QuestProgressComplete}"
      OverwriteLocalization = true
    }
    {
      Id = "QuestLog_QuestProgressRequirement"
      DisplayName = "{$TempTextData.Requirement}"
      OverwriteLocalization = true
    }
    {
      Id = "QuestLog_QuestAdded"
      DisplayName = "Prophecy Foretold..."
    }
    {
      Id = "QuestLog_QuestComplete"
      DisplayName = "Prophecy Fulfilled!!"
    }    

    /* BountyBoard / Bounty Board / Pitch-Black Stone */
    {
      Id = "UseBountyBoard"
      DisplayName = "{I} Scry"
    }
    {
      Id = "UseBountyBoard_Locked"
      DisplayName = "{I} {#LockedFormat}Check?"
    }

    {
      Id = "BountyIntro"
      DisplayName = "Chaos Trials"
      Description = """
      You now can see into the {#AlertBoldFormat}Pitch-Black Stone{#Prev}, revealing {#BountyHighlightFormat}Chaos Trials {#Prev}that influence reality as you know it. Consider the following:

      · {#BountyHighlightFormat}Chaos Trials {#Prev}are an alternate, optional way to pursue your task.

      · Each {#BountyHighlightFormat}Trial {#Prev}equips you with a certain loadout and has other twists.

      · Your previous loadout is always restored when you return.

      Note you will {#AlertItalicFormat}not {#Prev}find most of the usual resources on your way. Successfully clear {#BountyHighlightFormat}Chaos Trials {#Prev}to earn {!Icons.Mixer5CommonIcon}{#AlertBoldFormat}Star Dust{#Prev}, used in the {#AlertBoldFormat}Cauldron {#Prev}to brew powerful resources that let you unlock the potential of your {#AlertBoldFormat}Arcana Cards {#Prev}or bond with {#AlertBoldFormat}Animal Familiars{#Prev}!

      {!Icons.DivLong}

      {#AlertItalicFormat}Beware the Eyes! {#Prev}The more {!Icons.BountyEyeIcon} you see, the tougher the {#BountyHighlightFormat}Chaos Trial{#Prev}. New {#BountyHighlightFormat}Trials {#Prev}will be revealed as you progress. {#AlertItalicFormat}Go with Chaos!
    """
    }   

    {
      Id = "BountyLogScreen_Title"
      DisplayName = "Pitch-Black Stone"
    }
    {
      Id = "BountyLogScreen_Flavor"
      DisplayName = "“To Serve Chaos is to Improve One's Own Reality”"
    }

    {
      Id = "BountyBoard_StartChallenge"
      DisplayName = "{SL} COMMENCE"
    }
    {
      Id = "BountyBoard_RepeatChallenge"
      DisplayName = "{SL} RECOMMENCE"
    }
    {
      Id = "BountyBoard_ClearMessage"
      DisplayName = "clears: {$TempTextData.ClearCount}        best time: {$TempTextData.BestClearTimeString}"
    }
    {
      Id = "BountyBoard_ClearMessageStreaks"
      DisplayName = "current streak: {$TempTextData.CurrentStreak}        best streak: {$TempTextData.BestStreak}"
    }
    {
      Id = "BountyBoard_ClearMessage_NonRepeatable"
      DisplayName = "cleared!!"
    }
    {
      Id = "BountyBoard_RandomWeapon"
      DisplayName = "Random Weapon"
    }
    {
      Id = "BountyBoard_RandomKeepsake"
      DisplayName = "Random Keepsake"
    }
    {
      Id = "BountyBoard_UnderworldRun"
      DisplayName = "Underworld"
    }
    {
      Id = "BountyBoard_SurfaceRun"
      DisplayName = "Surface"
    }
    {
      Id = "BountyBoard_Reward"
      DisplayName = "{#HighlightFormatGraft}reward: {#Prev}{#LegendaryFormat}+{$TempTextData.Amount}{!TempTextData.Icon}"
    }
    {
      Id = "BountyBoard_RewardEarned"
      DisplayName = "{#HighlightFormatGraft}reward claimed"
    }

    /* InventoryScreen / Inventory */
    {
      Id = "InventoryScreen_Title"
      DisplayName = "Bag of Holding"
    }
    {
      Id = "InventoryScreen_ResourceNotFound"
      DisplayName = "Unavailable"
      Description = "You have not found this yet."
    }
    {
      Id = "InventoryScreen_GiftNotWanted"
      DisplayName = "Not Interested"
      Description = "This does not seem a suitable gift."
    }
    {
