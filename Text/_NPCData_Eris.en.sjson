{
  /*
  This file was autogenerated on 10/8/2025 at 3:34 PM
  by the BuildText tool.
  */
  lang = "en"
  Texts = [
    {
      Id = "Melinoe_2693"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hail, Strife."
      Speaker = "Melinoe"
      Event = "NPC_Eris_01.InteractVoiceLines"
    }
    {
      Id = "Eris_0134"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Same to you!"
      Speaker = "Eris"
      Event = "NPC_Eris_01.InteractVoiceLines"
    }
    {
      Id = "Eris_0135"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Kill 'em all."
      Speaker = "Eris"
      Event = "NPC_Eris_01.InteractVoiceLines"
    }
    {
      Id = "Eris_0136"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Don't need it!"
      Speaker = "Eris"
      Event = "NPC_Eris_01.InteractVoiceLines"
    }
    {
      Id = "Eris_0137"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll find my own way."
      Speaker = "Eris"
      Event = "NPC_Eris_01.InteractVoiceLines"
    }
    {
      Id = "Eris_0139"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You'll need it."
      Speaker = "Eris"
      Event = "NPC_Eris_01.InteractVoiceLines"
    }
    {
      Id = "Eris_0140"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I guess!"
      Speaker = "Eris"
      Event = "NPC_Eris_01.InteractVoiceLines"
    }
    {
      Id = "Eris_0141"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What's up, babe?"
      Speaker = "Eris"
      Event = "NPC_Eris_01.InteractVoiceLines"
    }
    {
      Id = "Eris_0168"
      InheritFrom = "BaseNarrative"
      DisplayName = "D'you miss me, Trouble? Thought I'd flit on over to your neck of the woods again, since I'm still {#Emph}welcome here and safe {#Prev}and everything. What you been up to lately?"
      Speaker = "Eris"
      Event = "ErisFirstMeeting"
    }
    {
      Id = "Melinoe_2419"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know, not much really, Eris! So, what brings you back? For a while there, I thought maybe you really were gone for good this time."
      Speaker = "Melinoe"
      Event = "ErisFirstMeeting"
    }
    {
      Id = "Eris_0169"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hate to disappoint, but I just couldn't stay away! Especially not with everything we're in the middle of right now. {#Emph}You {#Prev}have been {#Emph}real {#Prev}busy lately, {#Emph}huh?"
      Speaker = "Eris"
      Event = "ErisFirstMeeting"
    }
    {
      Id = "Melinoe_2653"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Whatever it is you heard, please keep it confidential."
      Speaker = "Melinoe"
      Event = "ErisFirstMeeting"
    }
    {
      Id = "Eris_0165"
      InheritFrom = "BaseNarrative"
      DisplayName = "Miss me, Trouble? Thought I'd flit on over for a bit again, and see how everybody's doing, since I'm {#Emph}welcome here and safe {#Prev}still, aren't I? Though it {#Emph}has {#Prev}been a little while."
      Speaker = "Eris"
      Event = "ErisFirstMeeting_B"
    }
    {
      Id = "Melinoe_3122"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's not been long enough. Much as I wished you'd grown past your childishness, Eris, I can't imagine you've returned for any reason other than to keep it up."
      Speaker = "Melinoe"
      Event = "ErisFirstMeeting_B"
    }
    {
      Id = "Eris_0166"
      InheritFrom = "BaseNarrative"
      DisplayName = "What, you can't imagine I just want to visit my big sister, if not you? I get it, you're still mad I slowed you down before, but... I will not do that again, I swear. So truce?"
      Speaker = "Eris"
      Event = "ErisFirstMeeting_B"
    }
    {
      Id = "Melinoe_3213"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We'll see."
      Speaker = "Melinoe"
      Event = "ErisFirstMeeting_B"
    }
    {
      Id = "Eris_0167"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Truce!"
      Speaker = "Eris"
      Event = "ErisFirstMeeting_B"
    }
    {
      Id = "Eris_0024"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know how come I'm {#Emph}really {#Prev}back, don't you, Trouble? Because things {#Emph}finally {#Prev}started getting {#Emph}interesting. {#Prev}But you're trying to put a stop to it...!"
      Speaker = "Eris"
      Event = "ErisAboutTask01"
    }
    {
      Id = "Melinoe_2421"
      InheritFrom = "BaseNarrative"
      DisplayName = "I won't let you cast doubt on my task. Surely you've better uses of your energy than this, and throwing all your rubbish everywhere?"
      Speaker = "Melinoe"
      Event = "ErisAboutTask01"
    }
    {
      Id = "Eris_0025"
      InheritFrom = "BaseNarrative"
      DisplayName = "What would {#Emph}you {#Prev}even know? I have {#Emph}every {#Prev}right to be here, and you're never getting rid of me! And you're never getting rid of Chronos, either. No going {#Emph}back {#Prev}to how things {#Emph}were!"
      Speaker = "Eris"
      Event = "ErisAboutTask01"
    }
    {
      Id = "Melinoe_2422"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We're going forward not back."
      Speaker = "Melinoe"
      Event = "ErisAboutTask01"
    }
    {
      Id = "Eris_0026"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't get you people, honestly. So set on making things the way they used to be. {#Emph}You{#Prev}, especially! You don't even know what you're missing!"
      Speaker = "Eris"
      Event = "ErisAboutPurpose01"
    }
    {
      Id = "Melinoe_0084"
      InheritFrom = "BaseNarrative"
      DisplayName = "We're trying to set things right, not make them how they used to be. Though, what's your point, Eris?"
      Speaker = "Melinoe"
      Event = "ErisAboutPurpose01"
    }
    {
      Id = "Eris_0027"
      InheritFrom = "BaseNarrative"
      DisplayName = "What's my point? What's {#Emph}your {#Prev}point? All of you are {#Emph}so {#Prev}obsessed with there being a {#Emph}Point {#Prev}to everything. You do know there isn't one, don't you? Can't just let loose and have a good time?"
      Speaker = "Eris"
      Event = "ErisAboutPurpose01"
    }
    {
      Id = "Melinoe_0085"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not under the present circumstances, no."
      Speaker = "Melinoe"
      Event = "ErisAboutPurpose01"
    }
    {
      Id = "Melinoe_2654"
      InheritFrom = "BaseNarrative"
      DisplayName = "Eris, you... you said before that I don't even know what I'm missing. What did you mean by that?"
      Speaker = "Melinoe"
      Event = "ErisAboutHeart01"
    }
    {
      Id = "Eris_0028"
      InheritFrom = "BaseNarrative"
      DisplayName = "Didn't mean your {#Emph}family{#Prev}, that's for sure! Come {#Emph}on{#Prev}, look at yourself. You've never lived a {#Emph}day {#Prev}in your {#Emph}life! {#Prev}That heart beating in your chest? You think it's only there to pump your blood! Just another muscle!"
      Speaker = "Eris"
      Event = "ErisAboutHeart01"
    }
    {
      Id = "Melinoe_2655"
      InheritFrom = "BaseNarrative"
      DisplayName = "The heart {#Emph}is {#Prev}a muscle. What, should I be out feasting? When Olympus is in peril, and the Underworld in utter disarray?"
      Speaker = "Melinoe"
      Event = "ErisAboutHeart01"
    }
    {
      Id = "Eris_0029"
      InheritFrom = "BaseNarrative"
      DisplayName = "Maybe! But you just want everything nice, and orderly, and predictable, and {#Emph}boring."
      Speaker = "Eris"
      Event = "ErisAboutHeart01"
    }
    {
      Id = "Melinoe_2656"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's not true."
      Speaker = "Melinoe"
      Event = "ErisAboutHeart01"
    }
    {
      Id = "Eris_0030"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You sure...?"
      Speaker = "Eris"
      Event = "ErisAboutHeart01"
    }
    {
      Id = "Melinoe_2657"
      InheritFrom = "BaseNarrative"
      DisplayName = "Look... you're right I've never known what it was like before Chronos returned. You keep insinuating it was worse than now. How so?"
      Speaker = "Melinoe"
      Event = "ErisAboutPast01"
    }
    {
      Id = "Eris_0031"
      InheritFrom = "BaseNarrative"
      DisplayName = "Already told you, babe! Your father, my mother, whole inner circle... they got off bossing everyone around! Didn't give me space to spread my wings. Bunch of Olympus wannabes, but with {#Emph}mood lighting!"
      Speaker = "Eris"
      Event = "ErisAboutPast01"
    }
    {
      Id = "Melinoe_2658"
      InheritFrom = "BaseNarrative"
      DisplayName = "...So you prefer living in a state of total disorder and constant mayhem to living under a principled set of rules?"
      Speaker = "Melinoe"
      Event = "ErisAboutPast01"
    }
    {
      Id = "Eris_0032"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's a really good way to put it!"
      Speaker = "Eris"
      Event = "ErisAboutPast01"
    }
    {
      Id = "Eris_0035"
      InheritFrom = "BaseNarrative"
      DisplayName = "You really want to know the way things used to be, Trouble? Think about everything that gets you to come out of your tent night after night. Gets you {#Emph}fired up! {#Prev}What comes to mind?"
      Speaker = "Eris"
      Event = "ErisAboutPast02"
    }
    {
      Id = "Melinoe_2662"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sure. Those I care about are counting on me. And, I wish to learn; to grow strong in body, mind, and spirit."
      Speaker = "Melinoe"
      Event = "ErisAboutPast02"
    }
    {
      Id = "Eris_0036"
      InheritFrom = "BaseNarrative"
      DisplayName = "Inspiring. Now, imagine having everything you want... so you're left wanting nothing at all...."
      Speaker = "Eris"
      Event = "ErisAboutPast02"
    }
    {
      Id = "Melinoe_2663"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, I can't imagine that. So, everyone besides you was self-indulgent and unmotivated? But now the roles are reversed, I suppose?"
      Speaker = "Melinoe"
      Event = "ErisAboutPast02"
    }
    {
      Id = "Eris_0037"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You don't get it. Fine."
      Speaker = "Eris"
      Event = "ErisAboutPast02"
    }
    {
      Id = "Eris_0041"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Whoa, haha! {#Prev}You startled me there, Trouble! Sneaking up on me like that, I almost blasted you. You gotta be more careful!"
      Speaker = "Eris"
      Event = "ErisAboutWeaponGun01"
    }
    {
      Id = "Melinoe_2667"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't appreciate you brandishing that thing about. Weapons remain prohibited outside the training grounds, in case you didn't know."
      Speaker = "Melinoe"
      Event = "ErisAboutWeaponGun01"
    }
    {
      Id = "Eris_0042"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Weapons? Ah-ha! Hello{#Prev}, this is the Adamant Rail you're talking about. This baby once took {#Emph}Titans {#Prev}down! It's a work of art. And {#Emph}no one's {#Prev}taking it from me!"
      Speaker = "Eris"
      Event = "ErisAboutWeaponGun01"
    }
    {
      Id = "Melinoe_2668"
      InheritFrom = "BaseNarrative"
      DisplayName = "You ever going to tell me how you got your hands on it to begin with? It was intended to be in my {#Emph}father's {#Prev}care... yet, somehow it's in {#Emph}yours."
      Speaker = "Melinoe"
      Event = "ErisAboutWeaponGun01"
    }
    {
      Id = "Eris_0043"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Turns out he wasn't so good at protecting his own!"
      Speaker = "Eris"
      Event = "ErisAboutWeaponGun01"
    }
    {
      Id = "Eris_0201"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Augh {#Prev}what {#Emph}gives? {#Prev}The Adamant Rail's back to normal! I must have hit a hidden switch on it or something, but... it doesn't even {#Emph}work {#Prev}here, let alone transform!"
      Speaker = "Eris"
      Event = "ErisAboutAltFight01"
    }
    {
      Id = "Melinoe_4275"
      InheritFrom = "BaseNarrative"
      DisplayName = "Take the hint, Eris. You may be the bearer of the Rail for the time being, but it doesn't answer to you alone. Even if it lets you aim and shoot."
      Speaker = "Melinoe"
      Event = "ErisAboutAltFight01"
    }
    {
      Id = "Eris_0202"
      InheritFrom = "BaseNarrative"
      DisplayName = "If only it let me aim and shoot right {#Emph}now! {#Prev}You better not be behind this, Trouble, or if you {#Emph}are... {#Prev}you change it {#Emph}back! {#Prev}I liked it more the other way!"
      Speaker = "Eris"
      Event = "ErisAboutAltFight01"
    }
    {
      Id = "Melinoe_4276"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It can hear you, you know."
      Speaker = "Melinoe"
      Event = "ErisAboutAltFight01"
    }
    {
      Id = "Melinoe_2669"
      InheritFrom = "BaseNarrative"
      DisplayName = "What compels you to fill this place with your rubbish, Eris? Do you wish to be welcome here only as a technicality?"
      Speaker = "Melinoe"
      Event = "ErisAboutTrash01"
    }
    {
      Id = "Eris_0044"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Um{#Prev}, since when am I supposed to care what anybody thinks? You're all about borrowing from the earth. I'm just giving something back!"
      Speaker = "Eris"
      Event = "ErisAboutTrash01"
    }
    {
      Id = "Melinoe_2670"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's... {#Emph}eugh..."
      Speaker = "Melinoe"
      Event = "ErisAboutTrash01"
    }
    {
      Id = "Melinoe_2671"
      InheritFrom = "BaseNarrative"
      DisplayName = "What is this stuff you're always littering about here, anyway? {#Emph}Cyclops Jerky? {#Prev}Did you happen on a limitless supply?"
      Speaker = "Melinoe"
      Event = "ErisAboutTrash02"
    }
    {
      Id = "Eris_0045"
      InheritFrom = "BaseNarrative"
      DisplayName = "Know what, as a matter of fact, I did! And you'll never guess where from. This stuff is {#Emph}so addictive {#Prev}once you get into it! Want to try some?"
      Speaker = "Eris"
      Event = "ErisAboutTrash02"
    }
    {
      Id = "Melinoe_2672"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No."
      Speaker = "Melinoe"
      Event = "ErisAboutTrash02"
    }
    {
      Id = "Eris_0190"
      InheritFrom = "BaseNarrative"
      DisplayName = "You don't need to pick up after me, you know. {#Emph}I {#Prev}was gonna get around to it! What do you {#Emph}do {#Prev}with all that, anyway?"
      Speaker = "Eris"
      Event = "ErisAboutTrash03"
    }
    {
      Id = "Melinoe_4231"
      InheritFrom = "BaseNarrative"
      DisplayName = "I present it to the Wretched Broker, through whom anything we no longer require can return to the Earth. You could do so yourself...! The Broker's right there..."
      Speaker = "Melinoe"
      Event = "ErisAboutTrash03"
    }
    {
      Id = "Eris_0191"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, that's all right. I wouldn't want to impose! Though maybe I'll go through {#Emph}your {#Prev}things next time you're out, and have the Broker there return {#Emph}them {#Prev}to the Earth!"
      Speaker = "Eris"
      Event = "ErisAboutTrash03"
    }
    {
      Id = "Melinoe_4232"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You wouldn't dare."
      Speaker = "Melinoe"
      Event = "ErisAboutTrash03"
    }
    {
      Id = "Eris_0046"
      InheritFrom = "BaseNarrative"
      DisplayName = "First I thought you stumbled back here by mistake. But {#Emph}you {#Prev}just keep on showing up. Something you want to tell me, babe?"
      Speaker = "Eris"
      Event = "ErisAboutAlley01"
    }
    {
      Id = "Melinoe_2673"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, I... was just drawn here to you. By your trail of rubbish! You're luring me, aren't you."
      Speaker = "Melinoe"
      Event = "ErisAboutAlley01"
    }
    {
      Id = "Eris_0047"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're an easy target."
      Speaker = "Eris"
      Event = "ErisAboutAlley01"
    }
    {
      Id = "Melinoe_2674"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why are you really here, Eris? Tell me Chronos didn't put you up to this. You've made quite clear that you don't want me to succeed."
      Speaker = "Melinoe"
      Event = "ErisAboutLoyalty01"
    }
    {
      Id = "Eris_0048"
      InheritFrom = "BaseNarrative"
      DisplayName = "Babe, I'm almost hurt! You don't get me at all, do you? Just because I'm not rooting for {#Emph}you {#Prev}doesn't mean I'm rooting for the {#Emph}other {#Prev}guy."
      Speaker = "Eris"
      Event = "ErisAboutLoyalty01"
    }
    {
      Id = "Melinoe_2675"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then who exactly are you rooting for, pray tell?"
      Speaker = "Melinoe"
      Event = "ErisAboutLoyalty01"
    }
    {
      Id = "Eris_0049"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll let you puzzle that one out."
      Speaker = "Eris"
      Event = "ErisAboutLoyalty01"
    }
    {
      Id = "Melinoe_2681"
      InheritFrom = "BaseNarrative"
      DisplayName = "Eris, how come you're always back here on your own? You never struck me as particularly reticent, and seem to enjoy interacting with others, in your own way...."
      Speaker = "Melinoe"
      Event = "ErisAboutSolitude01"
    }
    {
      Id = "Eris_0056"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, babe, it's a bit of a weird explanation, and you're not going to like it if I tell you. Which makes me {#Emph}really {#Prev}want to tell you! But then I think about how you must really want to know, which makes me {#Emph}not {#Prev}want to tell you anymore."
      Speaker = "Eris"
      Event = "ErisAboutSolitude01"
    }
    {
      Id = "Melinoe_2682"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm fairly certain it's not that you're just a figment of my imagination. Little voice in my head that keeps leading me astray."
      Speaker = "Melinoe"
      Event = "ErisAboutSolitude01"
    }
    {
      Id = "Eris_0057"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Long as you're not {#Emph}completely {#Prev}certain!"
      Speaker = "Eris"
      Event = "ErisAboutSolitude01"
    }
    {
      Id = "Melinoe_2683"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've seen firsthand the suffering out there, from all the endless warring between Chronos and the gods. But you're entirely unmoved?"
      Speaker = "Melinoe"
      Event = "ErisAboutDisorder01"
    }
    {
      Id = "Eris_0058"
      InheritFrom = "BaseNarrative"
      DisplayName = "Who says I'm {#Emph}unmoved? {#Prev}On the contrary, it makes me all {#Emph}emotional! {#Prev}I'm trying to live in the moment and everything, but... I just know I'm going to look back on this and think, {#Emph}these were the best of times."
      Speaker = "Eris"
      Event = "ErisAboutDisorder01"
    }
    {
      Id = "Melinoe_2684"
      InheritFrom = "BaseSubtitle"
      DisplayName = "For you; not for anybody else."
      Speaker = "Melinoe"
      Event = "ErisAboutDisorder01"
    }
    {
      Id = "Eris_0059"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yes, and...?"
      Speaker = "Eris"
      Event = "ErisAboutDisorder01"
    }
    {
      Id = "Eris_0060"
      InheritFrom = "BaseNarrative"
      DisplayName = "You don't know how good you've got it, Trouble. I grew up surrounded by siblings all thinking they were better than me. There's hoity-toity {#Emph}Retribution{#Prev}, over there! And {#Emph}Death{#Prev}, and {#Emph}Doom! {#Prev}Nobody wanted anything to do with {#Emph}Strife."
      Speaker = "Eris"
      Event = "ErisAboutStrife01"
    }
    {
      Id = "Melinoe_2685"
      InheritFrom = "BaseNarrative"
      DisplayName = "Moros could relate more than you know. You children of Nyx are widely feared, but so what? You don't need a lot of friends. You just need a few good ones. And the very meaning of {#Emph}Strife {#Prev}is for {#Emph}you {#Prev}to define, isn't it?"
      Speaker = "Melinoe"
      Event = "ErisAboutStrife01"
    }
    {
      Id = "Eris_0061"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I mean, I {#Emph}guess..."
      Speaker = "Eris"
      Event = "ErisAboutStrife01"
    }
    {
      Id = "Eris_0125"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't hate me, babe, OK? It's not my fault I keep lying to you, manipulating you, shooting you with the Rail, making you clean up after me, saying awful things behind your back..."
      Speaker = "Eris"
      Event = "ErisAboutStrife02"
    }
    {
      Id = "Melinoe_3131"
      InheritFrom = "BaseNarrative"
      DisplayName = "While I cannot shake the sense that this is a personal failing of mine, in spite of everything, I {#Emph}don't {#Prev}hate you, Eris. Not entirely. Although... whose fault {#Emph}is {#Prev}all of that, if not your own?"
      Speaker = "Melinoe"
      Event = "ErisAboutStrife02"
    }
    {
      Id = "Eris_0126"
      InheritFrom = "BaseNarrative"
      DisplayName = "My {#Emph}mother's! {#Prev}It's Nyx's fault, {#Emph}that's {#Prev}whose! Because she literally made me what I am, and what I'll always be. I could have been {#Emph}Old Age{#Prev}, or {#Emph}Friendship! {#Prev}But, no! And I can't change my nature. No matter {#Emph}how {#Prev}hard I try."
      Speaker = "Eris"
      Event = "ErisAboutStrife02"
    }
    {
      Id = "Melinoe_3132"
      InheritFrom = "BaseNarrative"
      DisplayName = "And, approximately how hard would you say you've tried?"
      Speaker = "Melinoe"
      Event = "ErisAboutStrife02"
    }
    {
      Id = "Eris_0127"
      InheritFrom = "BaseNarrative"
      DisplayName = "I mean, I haven't {#Emph}really{#Prev}, yet! But I'm going to this time, I swear!"
      Speaker = "Eris"
      Event = "ErisAboutStrife02"
    }
    {
      Id = "Melinoe_3133"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And I encourage you."
      Speaker = "Melinoe"
      Event = "ErisAboutStrife02"
    }
    {
      Id = "Eris_0064"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're {#Emph}so {#Prev}worked up about this war, like it's some {#Emph}huge thing. {#Prev}Olympus {#Emph}loves {#Prev}a good war! Have 'em all the time up there, got a whole {#Emph}god {#Prev}dedicated to 'em and everything. Know how {#Emph}easy {#Prev}it is to get 'em to start fighting?"
      Speaker = "Eris"
      Event = "ErisAboutWar01"
    }
    {
      Id = "Melinoe_2688"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, Eris, please, enlighten me. Just how easy is it to get my relatives to descend into acts of unconscionable violence and destruction?"
      Speaker = "Melinoe"
      Event = "ErisAboutWar01"
    }
    {
      Id = "Eris_0065"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well this one time, they all flew into a tizzy over a single Golden Apple. A mysterious offering, marked for the {#Emph}fairest one of all! {#Prev}They had a little dispute over who the secret admirer meant, one thing led to another, and {#Emph}boom!"
      Speaker = "Eris"
      Event = "ErisAboutWar01"
    }
    {
      Id = "Melinoe_2689"
      InheritFrom = "BaseNarrative"
      DisplayName = "That sounds like a simple misunderstanding, if not a prank. But you say it grew into a full-scale war? What happened then?"
      Speaker = "Melinoe"
      Event = "ErisAboutWar01"
    }
    {
      Id = "Eris_0066"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Eh{#Prev}, long story..."
      Speaker = "Eris"
      Event = "ErisAboutWar01"
    }
    {
      Id = "Eris_0062"
      InheritFrom = "BaseNarrative"
      DisplayName = "Speaking as someone with no small experience starting wars, I gotta say... just 'cause I'm not working for Chronos, doesn't mean I don't respect what he's been able to achieve."
      Speaker = "Eris"
      Event = "ErisAboutWar02"
    }
    {
      Id = "Melinoe_2686"
      InheritFrom = "BaseNarrative"
      DisplayName = "Eris... that was one of the worst sentences I think I've ever heard."
      Speaker = "Melinoe"
      Event = "ErisAboutWar02"
    }
    {
      Id = "Eris_0063"
      InheritFrom = "BaseNarrative"
      DisplayName = "Go look at what he's done, objectively, and tell me I'm wrong!"
      Speaker = "Eris"
      Event = "ErisAboutWar02"
    }
    {
      Id = "Melinoe_2687"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No, thank you..."
      Speaker = "Melinoe"
      Event = "ErisAboutWar02"
    }
    {
      Id = "Eris_0096"
      InheritFrom = "BaseNarrative"
      DisplayName = "Know what your problem is, Trouble? You're too green. Not done enough hard living to tease apart the truth from whatever it is you're told."
      Speaker = "Eris"
      Event = "ErisAboutTruth01"
    }
    {
      Id = "Melinoe_2717"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thank you for the feedback, Eris. You've given me a lot to think about. I regret our living here in this embattled camp just isn't hard enough."
      Speaker = "Melinoe"
      Event = "ErisAboutTruth01"
    }
    {
      Id = "Eris_0097"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Gasp> {#Prev}Sarcasm! Good, I like it. You've got a mean streak in you, I just know it, babe. And I wouldn't want you keeping it all to {#Emph}yourself! {#Prev}Share your gift with the world!"
      Speaker = "Eris"
      Event = "ErisAboutTruth01"
    }
    {
      Id = "Melinoe_2718"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Whatever you say..."
      Speaker = "Melinoe"
      Event = "ErisAboutTruth01"
    }
    {
      Id = "Eris_0098"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Tsch! {#Prev}No! Whatever {#Emph}you {#Prev}say!"
      Speaker = "Eris"
      Event = "ErisAboutTruth01"
    }
    {
      Id = "Eris_0099"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know what it's like, being pushed away. Having everybody {#Emph}smile {#Prev}to your face then {#Emph}stab {#Prev}you in the back. Well, for what it's worth... I don't believe a word they're saying about you."
      Speaker = "Eris"
      Event = "ErisAboutRumors01"
    }
    {
      Id = "Melinoe_2719"
      InheritFrom = "BaseNarrative"
      DisplayName = "I see. And to whom exactly are you referring, and can you cite an example of the words purportedly said?"
      Speaker = "Melinoe"
      Event = "ErisAboutRumors01"
    }
    {
      Id = "Eris_0100"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, it's just... Odysseus and Hecate. I can't believe they think you're gonna {#Emph}fail{#Prev}, that you don't have what it {#Emph}takes...! {#Prev}I mean, I don't want you to succeed, but... I never pretended otherwise!"
      Speaker = "Eris"
      Event = "ErisAboutRumors01"
    }
    {
      Id = "Melinoe_2720"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're trying to undermine them."
      Speaker = "Melinoe"
      Event = "ErisAboutRumors01"
    }
    {
      Id = "Eris_0101"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm just trying to help!"
      Speaker = "Eris"
      Event = "ErisAboutRumors01"
    }
    {
      Id = "Eris_0102"
      InheritFrom = "BaseNarrative"
      DisplayName = "I heard you went up top! Got to breathe some fresh surface air. What made you go and do a thing like that? Thought you were single-mindedly going after Chronos!"
      Speaker = "Eris"
      Event = "ErisAboutSurface01"
    }
    {
      Id = "Melinoe_2721"
      InheritFrom = "BaseNarrative"
      DisplayName = "Figured that I might do well with a change of scenery for a bit. Though, I'm surprised you're not up there yourself, considering how things are."
      Speaker = "Melinoe"
      Event = "ErisAboutSurface01"
    }
    {
      Id = "Eris_0103"
      InheritFrom = "BaseNarrative"
      DisplayName = "It does sound pretty exciting! But, I'd probably just be getting in the way. From what I hear, Ares has things well in hand up there. {#Emph}Imagine {#Prev}being the god of war right now. You'd be {#Emph}thrilled!"
      Speaker = "Eris"
      Event = "ErisAboutSurface01"
    }
    {
      Id = "Melinoe_2722"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Your whole family would be in peril."
      Speaker = "Melinoe"
      Event = "ErisAboutSurface01"
    }
    {
      Id = "Eris_0104"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...So?"
      Speaker = "Eris"
      Event = "ErisAboutSurface01"
    }
    {
      Id = "Eris_0105"
      InheritFrom = "BaseNarrative"
      DisplayName = "I figured it out! All these visits topside. {#Emph}You're {#Prev}trying to get to {#Emph}Olympus! {#Prev}Come to the family's rescue! Put an end to the war up there, is that it?"
      Speaker = "Eris"
      Event = "ErisAboutSurface02"
    }
    {
      Id = "Melinoe_2723"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, I just go up there to gather fresh reagents, really. Moss, bits of bronze. Comes in handy! The Olympians are very good at taking care of themselves."
      Speaker = "Melinoe"
      Event = "ErisAboutSurface02"
    }
    {
      Id = "Eris_0106"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sure they are. And they're too proud to ask for help. Just don't go ruining it for Ares when you're up there {#Emph}picking Moss. {#Prev}He's on a real hot streak lately!"
      Speaker = "Eris"
      Event = "ErisAboutSurface02"
    }
    {
      Id = "Melinoe_2724"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sounds like you and the god of war are still pretty close. Been very busy lately, hasn't he?"
      Speaker = "Melinoe"
      Event = "ErisAboutSurface02"
    }
    {
      Id = "Eris_0107"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Sure has!"
      Speaker = "Eris"
      Event = "ErisAboutSurface02"
    }
    {
      Id = "Eris_0092"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, {#Emph}um{#Prev}, babe? I kind of got you something... didn't want to make it a big deal or anything, so... here! For always being sweet."
      Speaker = "Eris"
      Event = "ErisPostGift01"
    }
    {
      Id = "Melinoe_2804"
      InheritFrom = "BaseNarrative"
      DisplayName = "A Nectar bottle... thank you, Eris. Though, we're breaking from tradition here. What if we just kept giving each other this same bottle back and forth, what then?"
      Speaker = "Melinoe"
      Event = "ErisPostGift01"
    }
    {
      Id = "Eris_0093"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It'd be {#Emph}total {#Prev}anarchy!"
      Speaker = "Eris"
      Event = "ErisPostGift01"
    }
    {
      Id = "Melinoe_3124"
      InheritFrom = "BaseNarrative"
      DisplayName = "You traitor! How dare you stand against me and our cause? And, of all the nerve to show your face again here! You'll be cast out for what you've done!"
      Speaker = "Melinoe"
      Event = "ErisFoughtAgainstHer01"
    }
    {
      Id = "Eris_0117"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sorry, babe, but I'm not going anywhere. Thank Nyx and Hecate and their {#Emph}unbreakable oaths! {#Prev}Besides, you got me all wrong."
      Speaker = "Eris"
      Event = "ErisFoughtAgainstHer01"
    }
    {
      Id = "Melinoe_3125"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh? Perhaps I merely mistook you for one of Nyx's {#Emph}other {#Prev}daughters who readily shot at me using the Rail of Adamant!"
      Speaker = "Melinoe"
      Event = "ErisFoughtAgainstHer01"
    }
    {
      Id = "Eris_0118"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, that was me all right, and I had a {#Emph}great {#Prev}time! But I take umbrage with the {#Emph}traitor {#Prev}thing. Think I made clear I wasn't on your side."
      Speaker = "Eris"
      Event = "ErisFoughtAgainstHer01"
    }
    {
      Id = "Melinoe_3126"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Then you serve Chronos!"
      Speaker = "Melinoe"
      Event = "ErisFoughtAgainstHer01"
    }
    {
      Id = "Eris_0119"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ahahaha{#Prev}, sure!"
      Speaker = "Eris"
      Event = "ErisFoughtAgainstHer01"
    }
    {
      Id = "Eris_0120"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hoo{#Prev}, babe, you know what? You put up more of a fight out there than I figured! The Rail was so hot to the touch, I could hardly {#Emph}stand {#Prev}it!"
      Speaker = "Eris"
      Event = "ErisFoughtAgainstHer02"
    }
    {
      Id = "Melinoe_3127"
      InheritFrom = "BaseNarrative"
      DisplayName = "Pleased to be of entertainment for your benefit. Is that all this is to you, then? You jeopardize our continued existence, just for a cheap thrill?"
      Speaker = "Melinoe"
      Event = "ErisFoughtAgainstHer02"
    }
    {
      Id = "Eris_0121"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't go acting like there wasn't part of you that felt a little {#Emph}thrill {#Prev}out there, yourself. And now that you've had a taste, you want {#Emph}more{#Prev}, don't you?"
      Speaker = "Eris"
      Event = "ErisFoughtAgainstHer02"
    }
    {
      Id = "Melinoe_3128"
      InheritFrom = "BaseNarrative"
      DisplayName = "I want you out of these Crossroads, and out of my blasted path."
      Speaker = "Melinoe"
      Event = "ErisFoughtAgainstHer02"
    }
    {
      Id = "Eris_0122"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Eh{#Prev}, too bad we can't have it all..."
      Speaker = "Eris"
      Event = "ErisFoughtAgainstHer02"
    }
    {
      Id = "Melinoe_3129"
      InheritFrom = "BaseNarrative"
      DisplayName = "Is this what you want, Eris? To have our aimless clashes, only then to sneer at one another here, again and again? Such a worthy cause."
      Speaker = "Melinoe"
      Event = "ErisFoughtAgainstHer03"
    }
    {
      Id = "Eris_0123"
      InheritFrom = "BaseNarrative"
      DisplayName = "Who are {#Emph}you {#Prev}to say what makes a worthy cause? 'Cause, {#Emph}yeah! {#Prev}I happen to be quite all right with {#Emph}everything! {#Prev}It's genuinely been a real blast!"
      Speaker = "Eris"
      Event = "ErisFoughtAgainstHer03"
    }
    {
      Id = "Melinoe_3130"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're unbelievable."
      Speaker = "Melinoe"
      Event = "ErisFoughtAgainstHer03"
    }
    {
      Id = "Eris_0124"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thanks, Trouble!"
      Speaker = "Eris"
      Event = "ErisFoughtAgainstHer03"
    }
    {
      Id = "Eris_0170"
      InheritFrom = "BaseNarrative"
      DisplayName = "I really thought you had me that time, babe, but... I guess not. Maybe later. You must be mad you can't get back at me right now."
      Speaker = "Eris"
      Event = "ErisAboutCloseMatch01"
    }
    {
      Id = "Melinoe_3214"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wouldn't break the peace here even if I could, Eris. But you really test my self-control. When next I see you at the edge of the Rift, I'll not hold back."
      Speaker = "Melinoe"
      Event = "ErisAboutCloseMatch01"
    }
    {
      Id = "Eris_0171"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ooh{#Prev}, she's {#Emph}angry! {#Prev}Just the way I like it."
      Speaker = "Eris"
      Event = "ErisAboutCloseMatch01"
    }
    {
      Id = "Eris_0172"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got me fair and square again, Trouble. More than a couple times! Starting to think maybe I'm losing it, you know?"
      Speaker = "Eris"
      Event = "ErisAboutRematches01"
    }
    {
      Id = "Melinoe_3215"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, you poor thing. Please, let me cheer you up, so you'll proceed to fight against me even harder than before."
      Speaker = "Melinoe"
      Event = "ErisAboutRematches01"
    }
    {
      Id = "Eris_0173"
      InheritFrom = "BaseNarrative"
      DisplayName = "You mock me when I'm vulnerable, fine. But don't expect to cry on {#Emph}this {#Prev}shoulder when things take a turn for the worse, when it comes to {#Emph}your {#Prev}stuff. Outta my {#Emph}face!"
      Speaker = "Eris"
      Event = "ErisAboutRematches01"
    }
    {
      Id = "Melinoe_3216"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}<Scoff>"
      Speaker = "Melinoe"
      Event = "ErisAboutRematches01"
    }
    {
      Id = "Eris_0196"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can't believe you stood me up last night, Trouble! Do you know how {#Emph}demeaning {#Prev}it is having to wait around for you at a beach, in the middle of the night, all {#Emph}alone?"
      Speaker = "Eris"
      Event = "ErisAboutNotFighting01"
    }
    {
      Id = "Melinoe_4236"
      InheritFrom = "BaseNarrative"
      DisplayName = "What? We had no plans to meet as I recall, else I'd have honored them. You truly expect me to abandon the main focus of my task, just to fight with you again and again?"
      Speaker = "Melinoe"
      Event = "ErisAboutNotFighting01"
    }
    {
      Id = "Eris_0197"
      InheritFrom = "BaseNarrative"
      DisplayName = "I thought I felt something was all... that our times at the beach might be just a little more special to you than your boring job. But I guess I was wrong..."
      Speaker = "Eris"
      Event = "ErisAboutNotFighting01"
    }
    {
      Id = "Melinoe_4237"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You guess correctly."
      Speaker = "Melinoe"
      Event = "ErisAboutNotFighting01"
    }
    {
      Id = "Eris_0198"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not seen you topside in a while, babe. I didn't want to say anything but it's starting to feel a little {#Emph}personal{#Prev}, you know?"
      Speaker = "Eris"
      Event = "ErisAboutNotFighting02"
    }
    {
      Id = "Melinoe_4238"
      InheritFrom = "BaseNarrative"
      DisplayName = "Eris, have you considered the possibility that when I pursue my task within the Underworld, you could not be further from my mind?"
      Speaker = "Melinoe"
      Event = "ErisAboutNotFighting02"
    }
    {
      Id = "Eris_0199"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's what they all say. You know what {#Emph}I {#Prev}think? You're {#Emph}afraid. {#Prev}Not just to face me, but to face your feelings. Fine! Go run away into the Underworld some more."
      Speaker = "Eris"
      Event = "ErisAboutNotFighting02"
    }
    {
      Id = "Melinoe_4239"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Why do I speak to you?"
      Speaker = "Melinoe"
      Event = "ErisAboutNotFighting02"
    }
    {
      Id = "Eris_0200"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Only to hurt us both..."
      Speaker = "Eris"
      Event = "ErisAboutNotFighting02"
    }
    {
      Id = "Eris_0185"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Great job last night, babe! {#Prev}Is that what you want to hear? Well tough, because you won't be hearing it from {#Emph}me. {#Prev}Other than that one time."
      Speaker = "Eris"
      Event = "ErisAboutRunCleared01"
    }
    {
      Id = "Melinoe_4205"
      InheritFrom = "BaseNarrative"
      DisplayName = "As much as I probably would appreciate the occasional bit of encouragement from you now that you mention it, Eris, I know it's not your tendency. I was just checking up on you."
      Speaker = "Melinoe"
      Event = "ErisAboutRunCleared01"
    }
    {
      Id = "Eris_0186"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Aw, thanks! {#Prev}Whenever you accomplish something important it's like you're putting a {#Emph}knife {#Prev}right in my heart. Though, good to know you'll come around and check up on my {#Emph}corpse!"
      Speaker = "Eris"
      Event = "ErisAboutRunCleared01"
    }
    {
      Id = "Melinoe_4206"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh don't be so dramatic."
      Speaker = "Melinoe"
      Event = "ErisAboutRunCleared01"
    }
    {
      Id = "Eris_0187"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Shut up!"
      Speaker = "Eris"
      Event = "ErisAboutRunCleared01"
    }
    {
      Id = "Eris_0188"
      InheritFrom = "BaseNarrative"
      DisplayName = "They're saying you beat Typhon single-handedly last night. One step closer to putting everything back to normal, huh?"
      Speaker = "Eris"
      Event = "ErisAboutSurfaceRunCleared01"
    }
    {
      Id = "Melinoe_4207"
      InheritFrom = "BaseNarrative"
      DisplayName = "I did not beat Typhon single-handedly, but we managed to defeat him, yes. Though I don't think you need to fear a return to normalcy anytime soon..."
      Speaker = "Melinoe"
      Event = "ErisAboutSurfaceRunCleared01"
    }
    {
      Id = "Eris_0189"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know you're trying to reassure me, but I can't help the way I {#Emph}feel! {#Prev}I ought to be enjoying all this while it {#Emph}lasts! {#Prev}The future might be boring as dirt, but right now? Things are OK."
      Speaker = "Eris"
      Event = "ErisAboutSurfaceRunCleared01"
    }
    {
      Id = "Melinoe_4208"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Things are not OK."
      Speaker = "Melinoe"
      Event = "ErisAboutSurfaceRunCleared01"
    }
    {
      Id = "Melinoe_4362"
      InheritFrom = "BaseNarrative"
      DisplayName = "Eris, what's the matter? Are you... have you been weeping?"
      Speaker = "Melinoe"
      Event = "ErisAboutRelationship01"
    }
    {
      Id = "Eris_0255"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}No! {#Prev}And... what if I was, {#Emph}huh? {#Prev}It's not like you care about me! Not you or anybody in this whole damn place."
      Speaker = "Eris"
      Event = "ErisAboutRelationship01"
    }
    {
      Id = "Melinoe_4363"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh stop it. If you made even the slightest effort not to be a scourge on these Crossroads, perhaps you'd have more companions. I keep foolishly believing that you'll change."
      Speaker = "Melinoe"
      Event = "ErisAboutRelationship01"
    }
    {
      Id = "Eris_0256"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're not my companion. No one is! No one I'm close to... no one I can depend on... share my secrets with..."
      Speaker = "Eris"
      Event = "ErisAboutRelationship01"
    }
    {
      Id = "Melinoe_4364"
      InheritFrom = "BaseNarrative"
      DisplayName = "Look... I'll not betray your trust if you need someone to confide in. Provided what you share won't put the others whom I care about in any sort of peril."
      Speaker = "Melinoe"
      Event = "ErisAboutRelationship01"
    }
    {
      Id = "Eris_0257"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Tsch... {#Prev}others whom you care about. You lump me in with {#Emph}them? {#Prev}Come on, babe, all we do is {#Emph}fight! {#Prev}Which I don't mind, of course! But there's much more to a relationship."
      Speaker = "Eris"
      Event = "ErisAboutRelationship01"
    }
    {
      Id = "Melinoe_4365"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've told you to speak plain with me before. What sort of relationship are you expecting us to have when all you do is interfere with me?"
      Speaker = "Melinoe"
      Event = "ErisAboutRelationship01"
    }
    {
      Id = "Eris_0258"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're so stupid sometimes! Look, I can't help the way I feel, and I'm not exactly a good judge of character. Whatever's wrong with me, I know it can't be fixed."
      Speaker = "Eris"
      Event = "ErisAboutRelationship01"
    }
    {
      Id = "Melinoe_4366"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How could you possibly know that?"
      Speaker = "Melinoe"
      Event = "ErisAboutRelationship01"
    }
    {
      Id = "Eris_0259"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I just {#Emph}do!"
      Speaker = "Eris"
      Event = "ErisAboutRelationship01"
    }
    {
      Id = "Melinoe_4369"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Eris...!"
      Speaker = "Melinoe"
      Event = "ErisAboutRelationship02"
    }
    {
      Id = "Melinoe_4502"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey about the other night, are we... I mean, are you all right with everything? I don't know what I'm trying to say..."
      Speaker = "Melinoe"
      Event = "ErisAboutRelationship03"
    }
    {
      Id = "Eris_0286"
      InheritFrom = "BaseNarrative"
      DisplayName = "Babe, {#Emph}stop. {#Prev}You said you never had any regrets about me. Probably lying to yourself, but still. We had our fun, so what?"
      Speaker = "Eris"
      Event = "ErisAboutRelationship03"
    }
    {
      Id = "Melinoe_4503"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps I'm just not yet accustomed to what you consider {#Emph}fun. {#Prev}I've had a lot of other things to think about."
      Speaker = "Melinoe"
      Event = "ErisAboutRelationship03"
    }
    {
      Id = "Eris_0287"
      InheritFrom = "BaseNarrative"
      DisplayName = "And you always {#Emph}will! {#Prev}But if you don't leave room for any mayhem in your life, it's gonna be a real drag. I swear."
      Speaker = "Eris"
      Event = "ErisAboutRelationship03"
    }
    {
      Id = "Melinoe_4504"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Mayhem? We were talking about fun."
      Speaker = "Melinoe"
      Event = "ErisAboutRelationship03"
    }
    {
      Id = "Eris_0288"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Same thing."
      Speaker = "Eris"
      Event = "ErisAboutRelationship03"
    }
    {
      Id = "Eris_0289"
      InheritFrom = "BaseNarrative"
      DisplayName = "Babe, stop. As much as I like messing with your head, I can't stand it when you act all pathetic. What, you're worried you hurt my little feelings, or just having second thoughts?"
      Speaker = "Eris"
      Event = "ErisAboutRelationship03_B"
    }
    {
      Id = "Melinoe_4505"
      InheritFrom = "BaseNarrative"
      DisplayName = "Mostly the former. If I've somehow earned some of your trust, it's not my wish to ruin that, in spite of everything."
      Speaker = "Melinoe"
      Event = "ErisAboutRelationship03_B"
    }
    {
      Id = "Eris_0290"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then all you have to do is shut up about it! It's only a big deal if you decide to make it one, right?"
      Speaker = "Eris"
      Event = "ErisAboutRelationship03_B"
    }
    {
      Id = "Melinoe_4506"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Right."
      Speaker = "Melinoe"
      Event = "ErisAboutRelationship03_B"
    }
    {
      Id = "Eris_0291"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're really turning heads around here, babe. I've seen the way Nemmie and Moros look at you! What do you think, maybe it's time we finally told them about {#Emph}us?"
      Speaker = "Eris"
      Event = "ErisAboutRelationship04"
    }
    {
      Id = "Melinoe_4507"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh cut it out, Eris. No serious commitments, right? You happen to come from an attractive family, and we have all the time in the world. Especially once all of this is over."
      Speaker = "Melinoe"
      Event = "ErisAboutRelationship04"
    }
    {
      Id = "Eris_0292"
      InheritFrom = "BaseNarrative"
      DisplayName = "I mean, I guess! Assuming this {#Emph}will {#Prev}be over at some point, or something worse doesn't come up! Anyway just messing with your head. I like how gullible you are...!"
      Speaker = "Eris"
      Event = "ErisAboutRelationship04"
    }
    {
      Id = "Melinoe_4510"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What are you talking about?"
      Speaker = "Melinoe"
      Event = "ErisAboutRelationship04"
    }
    {
      Id = "Eris_0293"
      InheritFrom = "BaseSubtitle"
      DisplayName = "See, that was {#Emph}it!"
      Speaker = "Eris"
      Event = "ErisAboutRelationship04"
    }
    {
      Id = "Eris_0247"
      InheritFrom = "BaseNarrative"
      DisplayName = "So what's been going on with you and Chronos anyway? You keep {#Emph}beating {#Prev}him but he keeps coming {#Emph}back! {#Prev}I like how pointless it seems, but... there has to be more to it, right?"
      Speaker = "Eris"
      Event = "ErisAboutChronos01"
    }
    {
      Id = "Melinoe_4357"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come on, Eris. I'm not about to reveal the critical details of my task, especially to someone who had every opportunity to be part of it to begin with. Go about your business."
      Speaker = "Melinoe"
      Event = "ErisAboutChronos01"
    }
    {
      Id = "Eris_0248"
      InheritFrom = "BaseNarrative"
      DisplayName = "How about you just give me a little hint. Are you planning to use his own powers against him? Break free our family members one by one? Anything like that?"
      Speaker = "Eris"
      Event = "ErisAboutChronos01"
    }
    {
      Id = "Melinoe_4358"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not telling you!"
      Speaker = "Melinoe"
      Event = "ErisAboutChronos01"
    }
    {
      Id = "Eris_0249"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Mean!"
      Speaker = "Eris"
      Event = "ErisAboutChronos01"
    }
    {
      Id = "Eris_0250"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sounds like there was a big commotion on Olympus last night! And I wasn't even around, thanks to you. How'd it go?"
      Speaker = "Eris"
      Event = "ErisAboutTyphon01"
    }
    {
      Id = "Melinoe_4359"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just great! Almost got eaten by the Father of All Monsters trying to distract him from destroying everything in sight! You really had to be there."
      Speaker = "Melinoe"
      Event = "ErisAboutTyphon01"
    }
    {
      Id = "Eris_0251"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know, babe, when somebody misses out on a good time, you ought to play it {#Emph}down{#Prev}, like, {#Emph}oh it wasn't anything that great. {#Prev}Or they'll feel {#Emph}bad {#Prev}they couldn't {#Emph}make it!"
      Speaker = "Eris"
      Event = "ErisAboutTyphon01"
    }
    {
      Id = "Melinoe_4360"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You {#Emph}should {#Prev}feel bad."
      Speaker = "Melinoe"
      Event = "ErisAboutTyphon01"
    }
    {
      Id = "Eris_0252"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well now, I {#Emph}don't!"
      Speaker = "Eris"
      Event = "ErisAboutTyphon01"
    }
    {
      Id = "Melinoe_2659"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've such disdain for what we're trying to achieve. You act as though nothing was lost. Don't you want to see Nyx again? Or Thanatos?"
      Speaker = "Melinoe"
      Event = "ErisAboutNyx01"
    }
    {
      Id = "Eris_0033"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't I want to see my mother again, or brother number-I-have-no-idea? {#Emph}Pff, hahaha{#Prev}, no. They were even more stuck up than you. {#Emph}No offense."
      Speaker = "Eris"
      Event = "ErisAboutNyx01"
    }
    {
      Id = "Melinoe_2660"
      InheritFrom = "BaseNarrative"
      DisplayName = "...How can you say such things about your relatives? Were they crueler to you than this?"
      Speaker = "Melinoe"
      Event = "ErisAboutNyx01"
    }
    {
      Id = "Eris_0034"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nyx always wanted things {#Emph}her {#Prev}way. Why should she, or anybody, have that kind of power over {#Emph}me? {#Prev}Because she {#Emph}made {#Prev}me? She didn't ask {#Emph}my {#Prev}permission. And I don't need hers."
      Speaker = "Eris"
      Event = "ErisAboutNyx01"
    }
    {
      Id = "Melinoe_2661"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm sorry..."
      Speaker = "Melinoe"
      Event = "ErisAboutNyx01"
    }
    {
      Id = "Eris_0395"
      InheritFrom = "BaseNarrative"
      DisplayName = "So what'd you think of Nyx? You met her, right? Now you know where Nemmie gets her looks, and where {#Emph}I {#Prev}get my personality."
      Speaker = "Eris"
      Event = "ErisAboutNyx02"
    }
    {
      Id = "Melinoe_4924"
      InheritFrom = "BaseNarrative"
      DisplayName = "What? I hardly got to know her but even still, Nyx didn't seem anything like you at all. She was very elegant."
      Speaker = "Melinoe"
      Event = "ErisAboutNyx02"
    }
    {
      Id = "Eris_0396"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Aw{#Prev}, thanks, babe. But beneath that cold exterior she's got a wild side, I swear. Why {#Emph}else {#Prev}would she have so many kids all by herself? She's out of her {#Emph}mind!"
      Speaker = "Eris"
      Event = "ErisAboutNyx02"
    }
    {
      Id = "Melinoe_4925"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Or just you, perhaps."
      Speaker = "Melinoe"
      Event = "ErisAboutNyx02"
    }
    {
      Id = "Melinoe_2664"
      InheritFrom = "BaseNarrative"
      DisplayName = "You don't even speak with Headmistress anymore, do you? Makes her relationship with Nemesis look positively healthy by comparison."
      Speaker = "Melinoe"
      Event = "ErisAboutHecate01"
    }
    {
      Id = "Eris_0038"
      InheritFrom = "BaseNarrative"
      DisplayName = "She said a {#Emph}lot {#Prev}of nasty things about me, babe. And not just to my face. All because I didn't {#Emph}fit her model {#Prev}of a {#Emph}star disciple! {#Prev}I had to move on. It's just, I don't need anybody like that in my life."
      Speaker = "Eris"
      Event = "ErisAboutHecate01"
    }
    {
      Id = "Melinoe_2665"
      InheritFrom = "BaseNarrative"
      DisplayName = "Eris, you repeatedly stole from her, kept using the cauldron to create explosives, and my tent for target practice, vandalized Hypnos in his slumber, salted the garden, and continually harassed Shades about the way they died..."
      Speaker = "Melinoe"
      Event = "ErisAboutHecate01"
    }
    {
      Id = "Eris_0039"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, Miss Perfect, so I made a few slip-ups! Doesn't make it OK for Hecate to lecture me, in {#Emph}private{#Prev}, where I couldn't even get full credit for the things I did. You don't know the half of it!"
      Speaker = "Eris"
      Event = "ErisAboutHecate01"
    }
    {
      Id = "Melinoe_2666"
      InheritFrom = "BaseSubtitle"
      DisplayName = "She silence-warded you, didn't she?"
      Speaker = "Melinoe"
      Event = "ErisAboutHecate01"
    }
    {
      Id = "Eris_0040"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I think maybe she did..."
      Speaker = "Eris"
      Event = "ErisAboutHecate01"
    }
    {
      Id = "Eris_0052"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're {#Emph}really {#Prev}getting under Nemmie's skin lately! Saw her run out in a huff, {#Emph}clanky clank{#Prev}, not long after talking to you. What'd you say that got her so worked up? I'll have to add it to my arsenal."
      Speaker = "Eris"
      Event = "ErisAboutNemesis01"
    }
    {
      Id = "Melinoe_2677"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wouldn't know. We've discussed my task from time to time, and she's interested in helping out however she can. I think she's just very determined to see our plans succeed."
      Speaker = "Melinoe"
      Event = "ErisAboutNemesis01"
    }
    {
      Id = "Eris_0053"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, I hear you! Fine. A witch never reveals her tricks, something like that? Well, just watch yourself with Sis, is all I'll say. She won't let {#Emph}anybody {#Prev}get too far ahead!"
      Speaker = "Eris"
      Event = "ErisAboutNemesis01"
    }
    {
      Id = "Melinoe_2678"
      InheritFrom = "BaseSubtitle"
      DisplayName = "She sure won't."
      Speaker = "Melinoe"
      Event = "ErisAboutNemesis01"
    }
    {
      Id = "Eris_0050"
      InheritFrom = "BaseNarrative"
      DisplayName = "If I have to listen to another one of your conversations with Moros, I am going to vomit. Though, you'll just clean that up too, won't you?"
      Speaker = "Eris"
      Event = "ErisAboutMoros01"
    }
    {
      Id = "Melinoe_2676"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're not to eavesdrop on my private conversations. Particularly if they induce in you a sense of nausea! You might do well to speak with your brother yourself, sometime."
      Speaker = "Melinoe"
      Event = "ErisAboutMoros01"
    }
    {
      Id = "Eris_0051"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'd much rather see how long he'll keep pretending I'm not here."
      Speaker = "Eris"
      Event = "ErisAboutMoros01"
    }
    {
      Id = "Melinoe_4233"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've been back a while yet still isolate yourself. Your brother makes more of an effort to fit in, but he struggles too... you may have more in common than you think."
      Speaker = "Melinoe"
      Event = "ErisAboutMoros02"
    }
    {
      Id = "Eris_0193"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh {#Prev}really? Maybe I'll go over and tell him you said that! What, you think just because most of the world hates {#Emph}his {#Prev}guts same as mine that we're {#Emph}alike?"
      Speaker = "Eris"
      Event = "ErisAboutMoros02"
    }
    {
      Id = "Melinoe_4234"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, I'd not put it that way at all... though I do think each of you has been misunderstood in your own right."
      Speaker = "Melinoe"
      Event = "ErisAboutMoros02"
    }
    {
      Id = "Eris_0194"
      InheritFrom = "BaseNarrative"
      DisplayName = "What's not to understand? I'm {#Emph}Strife{#Prev}; he's {#Emph}Doom{#Prev}. These are simple concepts, babe! Though granted, most of the world {#Emph}is {#Prev}pretty stupid..."
      Speaker = "Eris"
      Event = "ErisAboutMoros02"
    }
    {
      Id = "Melinoe_4235"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You shouldn't say such things."
      Speaker = "Melinoe"
      Event = "ErisAboutMoros02"
    }
    {
      Id = "Eris_0195"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You mean the truth?"
      Speaker = "Eris"
      Event = "ErisAboutMoros02"
    }
    {
      Id = "Eris_0417"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Aw{#Prev}, Hypnos is {#Emph}gone? {#Prev}I had big plans for him involving a bag of cats and a couple bottles of Nectar you gave me."
      Speaker = "Eris"
      Event = "ErisAboutHypnosWakeUp01"
    }
    {
      Id = "Melinoe_4939"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then I saved him from a terrible fate of some sort. Perhaps at some point down the line he'll thank me properly, as he was in a bit of a hurry to depart."
      Speaker = "Melinoe"
      Event = "ErisAboutHypnosWakeUp01"
    }
    {
      Id = "Eris_0418"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why don't you let me kill you next time we're out there on the Rift, and chances are, you'll wash on down into the River Styx, and wind up right in front of him again? He's the greeter at the House of Hades isn't he?"
      Speaker = "Eris"
      Event = "ErisAboutHypnosWakeUp01"
    }
    {
      Id = "Melinoe_4940"
      InheritFrom = "BaseNarrative"
      DisplayName = "He's not a {#Emph}greeter. {#Prev}He holds a position of high honor."
      Speaker = "Melinoe"
      Event = "ErisAboutHypnosWakeUp01"
    }
    {
      Id = "Eris_0419"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Welcome to the House of Hades! {#Prev}He's a greeter, babe."
      Speaker = "Eris"
      Event = "ErisAboutHypnosWakeUp01"
    }
    {
      Id = "Eris_0054"
      InheritFrom = "BaseNarrative"
      DisplayName = "That Heracles sure is {#Emph}something{#Prev}, isn't he? Too bad there's not much going on between his ears. That lion pelt he likes to strut around in probably has got more smarts than {#Emph}him."
      Speaker = "Eris"
      Event = "ErisAboutHeracles01"
    }
    {
      Id = "Melinoe_2679"
      InheritFrom = "BaseNarrative"
      DisplayName = "What makes you say that? Other than your general tendency to speak ill of others. Heracles seems no fool to me; a bit disillusioned, maybe."
      Speaker = "Melinoe"
      Event = "ErisAboutHeracles01"
    }
    {
      Id = "Eris_0055"
      InheritFrom = "BaseNarrative"
      DisplayName = "His club does all the thinking for him, and most of the talking, too. {#Emph}Ehh{#Prev}, you're both gullible! Maybe that's why you think he's so great. Or, maybe he's just your type?"
      Speaker = "Eris"
      Event = "ErisAboutHeracles01"
    }
    {
      Id = "Melinoe_2680"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}<Scoff> {#Prev}No...!"
      Speaker = "Melinoe"
      Event = "ErisAboutHeracles01"
    }
    {
      Id = "Eris_0276"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ungh{#Prev}, I'm still worked up after last night. When did you get so strong? I don't stand a chance against you anymore. Hey, want to go someplace with me, blow off some steam?"
      Speaker = "Eris"
      Event = "ErisBecomingCloser01"
    }
    {
      Id = "Melinoe_4491"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm not entirely certain I do. At the taverna at least there are plenty of witnesses in case you try anything untoward."
      Speaker = "Melinoe"
      Event = "ErisBecomingCloser01"
    }
    {
      Id = "Eris_0277"
      InheritFrom = "BaseNarrative"
      DisplayName = "C'mon, what are you afraid of? Not like you can't take me in a {#Emph}fight! {#Prev}Anyway, it's not too far. I swear."
      Speaker = "Eris"
      Event = "ErisBecomingCloser01"
    }
    {
      Id = "Melinoe_4493"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Wait this is it? You weren't jesting when you said it wasn't far. What's so special about this spot?"
      Speaker = "Melinoe"
      Event = "ErisBecomingCloser01"
    }
    {
      Id = "Eris_0278"
      InheritFrom = "BaseNarrative"
      DisplayName = "I like it here is all. No frogs croaking, no Shades wandering around... no one to catch us if we fool around a little bit..."
      Speaker = "Eris"
      Event = "ErisBecomingCloser01"
    }
    {
      Id = "Melinoe_4494"
      InheritFrom = "BaseNarrative"
      DisplayName = "By fool around a little bit you mean... {#Emph}oh{#Prev}, right. Eris, look, I'm not prepared for any serious commitment here."
      Speaker = "Melinoe"
      Event = "ErisBecomingCloser01"
    }
    {
      Id = "Eris_0279"
      InheritFrom = "BaseNarrative"
      DisplayName = "Babe, I've never made a serious commitment in my {#Emph}life. {#Prev}I just like to have a little fun from time to time after a hard night trying to shoot you to pieces! What do you say?"
      Speaker = "Eris"
      Event = "ErisBecomingCloser01"
    }
    {
      Id = "Melinoe_4496"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Please don't."
      Speaker = "Melinoe"
      Event = "ErisBecomingCloser01"
    }
    {
      Id = "Eris_0281"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Aw..."
      Speaker = "Eris"
      Event = "ErisBecomingCloser01"
    }
    {
      Id = "Melinoe_4501"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Whew..."
      Speaker = "Melinoe"
      Event = "ErisBecomingCloser01"
    }
    {
      Id = "Melinoe_4495"
      InheritFrom = "BaseNarrative"
      DisplayName = "It means a lot that you would ask, because I know it's not been easy to get close to anybody here. But this isn't something that I'm looking for right now. Whatever it is we have between us... I've come to like it just the way it is."
      Speaker = "Melinoe"
      Event = "ErisBecomingCloser01"
    }
    {
      Id = "Eris_0280"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's how {#Emph}I {#Prev}feel! And I get it, long as you're doing what {#Emph}you {#Prev}want instead of what everybody else wants. Though, mind if I tell everybody that we fooled around here anyway?"
      Speaker = "Eris"
      Event = "ErisBecomingCloser01"
    }
    {
      Id = "Melinoe_4497"
      InheritFrom = "BaseNarrative"
      DisplayName = "...While I should probably regret a great many things about our relationship, the truth is, I never have. And besides... I like to learn from my mistakes."
      Speaker = "Melinoe"
      Event = "ErisBecomingCloser01"
    }
    {
      Id = "Melinoe_4498"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well! I think I learned a lot this evening, all in all. Though I should probably get back. If anybody asks, we were at the fishing pier."
      Speaker = "Melinoe"
      Event = "ErisBecomingCloser01"
    }
    {
      Id = "Eris_0283"
      InheritFrom = "BaseNarrative"
      DisplayName = "We {#Emph}are {#Prev}at the fishing pier, babe. And what does it even matter if anybody asks? Who {#Emph}cares? {#Prev}We were just having a good time! That's not forbidden here, is it?"
      Speaker = "Eris"
      Event = "ErisBecomingCloser01"
    }
    {
      Id = "Melinoe_4499"
      InheritFrom = "BaseNarrative"
      DisplayName = "It isn't, no. So I suppose you now go back to trying to shoot me to pieces night after night like nothing happened?"
      Speaker = "Melinoe"
      Event = "ErisBecomingCloser01"
    }
    {
      Id = "Eris_0284"
      InheritFrom = "BaseNarrative"
      DisplayName = "You got it! What, did you really think I was gonna fall so hard that I'd give up on everything that makes me {#Emph}me? {#Prev}Please. No serious commitments, remember?"
      Speaker = "Eris"
      Event = "ErisBecomingCloser01"
    }
    {
      Id = "Melinoe_4500"
      InheritFrom = "BaseNarrative"
      DisplayName = "I do. And I don't mean to think like mortals here, it's just... I don't understand you sometimes, Eris. To be so... carefree."
      Speaker = "Melinoe"
      Event = "ErisBecomingCloser01"
    }
    {
      Id = "Eris_0285"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll let you in on a little secret, babe: We like what we don't understand or can't have. Anyway that's always {#Emph}my {#Prev}excuse! See you around!"
      Speaker = "Eris"
      Event = "ErisBecomingCloser01"
    }
    {
      Id = "Eris_0379"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm warning you, you better cut this out, Trouble. Messing with {#Emph}Chronos{#Prev}, messing with {#Emph}Typhon{#Prev}, messing everything {#Emph}up! {#Prev}That's supposed to be {#Emph}my job!"
      Speaker = "Eris"
      Event = "ErisAboutUltimateProgress01"
    }
    {
      Id = "Melinoe_4911"
      InheritFrom = "BaseNarrative"
      DisplayName = "You clearly did your job already. I'm in the process of undoing it. Much like how I often pick up after you here."
      Speaker = "Melinoe"
      Event = "ErisAboutUltimateProgress01"
    }
    {
      Id = "Eris_0380"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well you're not gonna. And even if you {#Emph}do{#Prev}, you'll look back on this and wish things were as {#Emph}interesting {#Prev}as they are now!"
      Speaker = "Eris"
      Event = "ErisAboutUltimateProgress01"
    }
    {
      Id = "Melinoe_4912"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wouldn't mind if things were boring for a change."
      Speaker = "Melinoe"
      Event = "ErisAboutUltimateProgress01"
    }
    {
      Id = "Eris_0381"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I {#Emph}would!"
      Speaker = "Eris"
      Event = "ErisAboutUltimateProgress01"
    }
    {
      Id = "Eris_0382"
      InheritFrom = "BaseNarrative"
      DisplayName = "Say it isn't so, Trouble! The Chronos stuff I'm hearing? He's really calling it quits? And he let Nyx and everybody off? Wh-what did you {#Emph}do {#Prev}to him?!"
      Speaker = "Eris"
      Event = "ErisPostTrueEnding01"
    }
    {
      Id = "Melinoe_4913"
      InheritFrom = "BaseNarrative"
      DisplayName = "Working with my brother in a bygone time, we flooded our grandfather's mind with a cascade of new memories of the family he then realized he always had, creating in him a profound and sudden change. Why, what's your concern?"
      Speaker = "Melinoe"
      Event = "ErisPostTrueEnding01"
    }
    {
      Id = "Eris_0383"
      InheritFrom = "BaseNarrative"
      DisplayName = "My {#Emph}concern {#Prev}is that you ruined everything. So {#Emph}now {#Prev}we'll all have peace and harmony, joyful reunions, apologies, promises to never let this type of thing happen {#Emph}again?! Ungh!"
      Speaker = "Eris"
      Event = "ErisPostTrueEnding01"
    }
    {
      Id = "Melinoe_4914"
      InheritFrom = "BaseNarrative"
      DisplayName = "Have you met our families, Eris? It's never that simple."
      Speaker = "Melinoe"
      Event = "ErisPostTrueEnding01"
    }
    {
      Id = "Eris_0384"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It {#Emph}better {#Prev}not be, or I'll {#Emph}never {#Prev}forgive you!"
      Speaker = "Eris"
      Event = "ErisPostTrueEnding01"
    }
    {
      Id = "Eris_0385"
      InheritFrom = "BaseNarrative"
      DisplayName = "What are you even {#Emph}doing {#Prev}in this dump still, anyway? If your mom and pop are back in charge, you ought to be living in style with them down in Tartarus. Are they {#Emph}that {#Prev}bad?"
      Speaker = "Eris"
      Event = "ErisPostTrueEnding02"
    }
    {
      Id = "Melinoe_4915"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}No! {#Prev}I may have been born in Tartarus, but my home is here, as well as my responsibilities. And the Crossroads are {#Emph}not {#Prev}a dump, or at least wouldn't be if you could mind your rubbish."
      Speaker = "Melinoe"
      Event = "ErisPostTrueEnding02"
    }
    {
      Id = "Eris_0386"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Whatever! {#Prev}Though at least that's one good thing that came out of all this. I really thought I was gonna lose you, babe."
      Speaker = "Eris"
      Event = "ErisPostTrueEnding02"
    }
    {
      Id = "Melinoe_4916"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Very touching."
      Speaker = "Melinoe"
      Event = "ErisPostTrueEnding02"
    }
    {
      Id = "Eris_0387"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm serious!"
      Speaker = "Eris"
      Event = "ErisPostTrueEnding02"
    }
    {
      Id = "Eris_0388"
      InheritFrom = "BaseNarrative"
      DisplayName = "How come you have to keep on doing all of this? I thought you {#Emph}won! {#Prev}But, you're still fighting! {#Emph}We're {#Prev}still fighting! I keep telling myself this is {#Emph}way {#Prev}too good to be true...!"
      Speaker = "Eris"
      Event = "ErisPostTrueEnding03"
    }
    {
      Id = "Melinoe_4917"
      InheritFrom = "BaseNarrative"
      DisplayName = "Suffice it to say we have some lingering matters to resolve, which require continuing the process that got us here. So congratulations! Things are going to stay messy for a while."
      Speaker = "Melinoe"
      Event = "ErisPostTrueEnding03"
    }
    {
      Id = "Eris_0389"
      InheritFrom = "BaseNarrative"
      DisplayName = "You don't {#Emph}mean {#Prev}that! You're just trying to get my {#Emph}hopes {#Prev}up! Well, don't you worry. Whatever it is you're planning, sooner or later I'll get involved."
      Speaker = "Eris"
      Event = "ErisPostTrueEnding03"
    }
    {
      Id = "Melinoe_4918"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I've learned to count on it."
      Speaker = "Melinoe"
      Event = "ErisPostTrueEnding03"
    }
    {
      Id = "Melinoe_4921"
      InheritFrom = "BaseNarrative"
      DisplayName = "So was it worth it, Eris? Impeding me, making my task more difficult at every turn? You didn't prevent this outcome... you could have just aided me like so many others."
      Speaker = "Melinoe"
      Event = "ErisPostTrueEnding04"
    }
    {
      Id = "Eris_0392"
      InheritFrom = "BaseNarrative"
      DisplayName = "And why would I have wanted to do that? Although I {#Emph}am {#Prev}a little disappointed in myself. Looking back, I could have caused {#Emph}so {#Prev}much more mayhem along the way..."
      Speaker = "Eris"
      Event = "ErisPostTrueEnding04"
    }
    {
      Id = "Melinoe_4922"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well look at you, reflecting on how you could improve! Even if it's at making things worse for everybody else."
      Speaker = "Melinoe"
      Event = "ErisPostTrueEnding04"
    }
    {
      Id = "Eris_0393"
      InheritFrom = "BaseNarrative"
      DisplayName = "You taught me that yourself, you know, Trouble? Not that I ever really learn, but... if I don't stay on top of things, maybe sometime in the future, everything will turn out {#Emph}fine..."
      Speaker = "Eris"
      Event = "ErisPostTrueEnding04"
    }
    {
      Id = "Melinoe_4923"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We can't have {#Emph}that."
      Speaker = "Melinoe"
      Event = "ErisPostTrueEnding04"
    }
    {
      Id = "Eris_0394"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}No."
      Speaker = "Eris"
      Event = "ErisPostTrueEnding04"
    }
    {
      Id = "Eris_0397"
      InheritFrom = "BaseNarrative"
      DisplayName = "Something's up with you lately, babe! But you're not gonna tell me, so I'm just gonna start guessing. Is it Hecate? I bet it is, because something's up with {#Emph}her {#Prev}lately, too."
      Speaker = "Eris"
      Event = "ErisPostEpilogue01"
    }
    {
      Id = "Melinoe_4926"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's nothing, it's just... I've not had opportunity to speak with Headmistress at length since all of this drew to a close. We had... a lot we needed to sort out. And still do."
      Speaker = "Melinoe"
      Event = "ErisPostEpilogue01"
    }
    {
      Id = "Eris_0398"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Aw{#Prev}, too {#Emph}bad! {#Prev}Even with all those scary issues you've been dealing with now mostly gone, turns out you've both got plenty of issues left. It's like they never go {#Emph}away!"
      Speaker = "Eris"
      Event = "ErisPostEpilogue01"
    }
    {
      Id = "Melinoe_4927"
      InheritFrom = "BaseSubtitle"
      DisplayName = "At least you don't have issues, Eris."
      Speaker = "Melinoe"
      Event = "ErisPostEpilogue01"
    }
    {
      Id = "Eris_0399"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not a one."
      Speaker = "Eris"
      Event = "ErisPostEpilogue01"
    }
    {
      Id = "Eris_0400"
      InheritFrom = "BaseNarrative"
      DisplayName = "Moros was all giddy recently, at least for {#Emph}him. {#Prev}So you finally got a hold of his sisters, huh? {#Emph}You {#Prev}should feel {#Emph}lucky! {#Prev}They're {#Emph}my {#Prev}sisters too and we've never even {#Emph}met."
      Speaker = "Eris"
      Event = "ErisPostEpilogue02"
    }
    {
      Id = "Melinoe_4928"
      InheritFrom = "BaseNarrative"
      DisplayName = "I saw a bit of {#Emph}you {#Prev}in them, perhaps, Eris. If their past work is any indication, they seem to value spontaneity... making things up as they go."
      Speaker = "Melinoe"
      Event = "ErisPostEpilogue02"
    }
    {
      Id = "Eris_0401"
      InheritFrom = "BaseNarrative"
      DisplayName = "So {#Emph}bizarre{#Prev}, right? I mean why be like that when you could try and meticulously plan for every little {#Emph}detail {#Prev}in advance?"
      Speaker = "Eris"
      Event = "ErisPostEpilogue02"
    }
    {
      Id = "Melinoe_4929"
      InheritFrom = "BaseNarrative"
      DisplayName = "They're weavers... they {#Emph}do {#Prev}have to plan. That and spontaneity are not inherently opposed. Speaking of which, you must have heard they're planning an extended break."
      Speaker = "Melinoe"
      Event = "ErisPostEpilogue02"
    }
    {
      Id = "Eris_0402"
      InheritFrom = "BaseNarrative"
      DisplayName = "Meaning {#Emph}we {#Prev}get to make things up as we go, for a change!"
      Speaker = "Eris"
      Event = "ErisPostEpilogue02"
    }
    {
      Id = "Melinoe_4930"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We'll see how that turns out..."
      Speaker = "Melinoe"
      Event = "ErisPostEpilogue02"
    }
    {
      Id = "Eris_0245"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thanks for the suggestion, ma'am, but I'll be sticking around as {#Emph}long {#Prev}as I want. Last I checked, you can't do anything about that, right?"
      Speaker = "Eris"
      Event = "ErisWithHecate01"
    }
    {
      Id = "Hecate_0603"
      InheritFrom = "BaseNarrative"
      DisplayName = "You are {#Emph}correct{#Prev}, Eris, I cannot stop you from going where you please. But, I {#Emph}can {#Prev}make your life profoundly difficult, in ways you cannot possibly begin to imagine... I refrain only for the vow I made to your mother."
      Speaker = "Hecate"
      Event = "ErisWithHecate01"
    }
    {
      Id = "Eris_0246"
      InheritFrom = "BaseNarrative"
      DisplayName = "You can't intimidate me. Nyx tried before and look where {#Emph}that {#Prev}got her!"
      Speaker = "Eris"
      Event = "ErisWithHecate01"
    }
    {
      Id = "Eris_0004"
      InheritFrom = "BaseNarrative"
      DisplayName = "Think you might have missed a spot back there, Trouble?"
      Speaker = "Eris"
      Event = "ErisChat01"
    }
    {
      Id = "Eris_0005"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just keep at it, whatever it is you think you've got to prove!"
      Speaker = "Eris"
      Event = "ErisChat02"
    }
    {
      Id = "Eris_0006"
      InheritFrom = "BaseNarrative"
      DisplayName = "What's the big rush? We've got all the time in the world!"
      Speaker = "Eris"
      Event = "ErisChat03"
    }
    {
      Id = "Eris_0007"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know this whole place is turning into a real dump..."
      Speaker = "Eris"
      Event = "ErisChat04"
    }
    {
      Id = "Eris_0008"
      InheritFrom = "BaseNarrative"
      DisplayName = "Real shame what's been happening between us lately, Trouble."
      Speaker = "Eris"
      Event = "ErisChat05"
    }
    {
      Id = "Eris_0009"
      InheritFrom = "BaseNarrative"
      DisplayName = "See Nemmie around, tell her I {#Emph}really {#Prev}wanted to talk to her, OK?"
      Speaker = "Eris"
      Event = "ErisChat06"
    }
    {
      Id = "Eris_0010"
      InheritFrom = "BaseNarrative"
      DisplayName = "Life sure moves fast, even for deathless goddesses, {#Emph}huh{#Prev}, Trouble?"
      Speaker = "Eris"
      Event = "ErisChat07"
    }
    {
      Id = "Eris_0011"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ahh{#Prev}, don't give me that look. {#Emph}I {#Prev}belong here just as much as {#Emph}you."
      Speaker = "Eris"
      Event = "ErisChat08"
    }
    {
      Id = "Eris_0012"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're not getting anywhere, babe. None of us are!"
      Speaker = "Eris"
      Event = "ErisChat09"
    }
    {
      Id = "Eris_0013"
      InheritFrom = "BaseNarrative"
      DisplayName = "How about you mind your own business, Trouble, and lemme mind mine."
      Speaker = "Eris"
      Event = "ErisChat10"
    }
    {
      Id = "Eris_0014"
      InheritFrom = "BaseNarrative"
      DisplayName = "Uh-oh, she's here! I'd better fly away and hide!"
      Speaker = "Eris"
      Event = "ErisChat11"
    }
    {
      Id = "Eris_0015"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thought I'd drop in again and check up on everything, y'know?"
      Speaker = "Eris"
      Event = "ErisChat12"
    }
    {
      Id = "Eris_0016"
      InheritFrom = "BaseNarrative"
      DisplayName = "You must be {#Emph}really {#Prev}making a difference out there, huh?"
      Speaker = "Eris"
      Event = "ErisChat13"
    }
    {
      Id = "Eris_0017"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Whew{#Prev}, it's all just been a little much lately, y'know?"
      Speaker = "Eris"
      Event = "ErisChat14"
    }
    {
      Id = "Eris_0018"
      InheritFrom = "BaseNarrative"
      DisplayName = "Move along there, Trouble, I don't really want to talk to you right now."
      Speaker = "Eris"
      Event = "ErisChat15"
    }
    {
      Id = "Eris_0019"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come {#Emph}on{#Prev}, babe! You know rumors gonna fly if they catch us like this!"
      Speaker = "Eris"
      Event = "ErisChat16"
    }
    {
      Id = "Eris_0020"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Eugh{#Prev}, looks like {#Emph}you {#Prev}just woke up! Couldn't wait to see me again, huh?"
      Speaker = "Eris"
      Event = "ErisChat17"
    }
    {
      Id = "Eris_0021"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got my eye on you, Trouble. So you better keep your nose clean."
      Speaker = "Eris"
      Event = "ErisChat18"
    }
    {
      Id = "Eris_0022"
      InheritFrom = "BaseNarrative"
      DisplayName = "All this stress, it isn't getting to you, is it, babe?"
      Speaker = "Eris"
      Event = "ErisChat19"
    }
    {
      Id = "Eris_0023"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why talk to me? Do what you want! {#Emph}Nobody {#Prev}cares!"
      Speaker = "Eris"
      Event = "ErisChat20"
    }
    {
      Id = "Eris_0068"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know I can't accept this, now. Not after everything that's {#Emph}happened {#Prev}between us. Let's just... move on with our lives?"
      Speaker = "Eris"
      Event = "ErisGiftDecline01"
    }
    {
      Id = "Melinoe_2692"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Huh? {#Prev}And, what exactly happened between us, would you say, if you had to summarize...? You're just... mocking me as usual, aren't you..."
      Speaker = "Melinoe"
      Event = "ErisGiftDecline01"
    }
    {
      Id = "Eris_0069"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just {#Emph}<sniff> {#Prev}have a good life!"
      Speaker = "Eris"
      Event = "ErisGiftDecline01"
    }
    {
      Id = "Melinoe_2690"
      InheritFrom = "BaseNarrative"
      DisplayName = "Look, I... do want you to feel welcome here and safe. It's not just something that we say. May this gift of Nectar show my words are true."
      Speaker = "Melinoe"
      Event = "ErisGift01"
    }
    {
      Id = "Eris_0067"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Wow... {#Prev}made with real Golden Apples! {#Emph}Thanks{#Prev}, babe. You're the only one who's made a real effort to bring me into the fold! Say, why don't you take this? It isn't much, but I've been holding onto it, in case I found a friend..."
      Speaker = "Eris"
      Event = "ErisGift01"
    }
    {
      Id = "Eris_0088"
      InheritFrom = "BaseNarrative"
      DisplayName = "But, you already got me one of these. Don't you have anything else? {#Emph}Mmhmhmhm{#Prev}, only messing with you, babe! I'll get you back for this sometime, OK?"
      Speaker = "Eris"
      Event = "ErisGift02"
    }
    {
      Id = "Melinoe_2801"
      InheritFrom = "BaseNarrative"
      DisplayName = "Please, don't... I mean, I just wanted you to have it since I know you have a taste for this stuff, but it's been harder to come by. Anyway...!"
      Speaker = "Melinoe"
      Event = "ErisGift02"
    }
    {
      Id = "Eris_0089"
      InheritFrom = "BaseNarrative"
      DisplayName = "Babe, no one ever gets me anything like this! Except the last couple of times you got me the exact same thing. But oh, I feel so bad I don't have anything for {#Emph}you!"
      Speaker = "Eris"
      Event = "ErisGift03"
    }
    {
      Id = "Melinoe_2802"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's only a gift, to make you feel a little better, not worse! Don't mention it, just... you enjoy. But, please don't leave the empty bottle on the ground."
      Speaker = "Melinoe"
      Event = "ErisGift03"
    }
    {
      Id = "Eris_0090"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just had to see my reaction to another one of these, huh? You say it's only a gift, but you're {#Emph}probably {#Prev}keeping {#Emph}meticulous {#Prev}track of every Nectar you dole out. Hoping whoever {#Emph}gets {#Prev}one's gonna like you just a little more each time."
      Speaker = "Eris"
      Event = "ErisGift04"
    }
    {
      Id = "Melinoe_2803"
      InheritFrom = "BaseNarrative"
      DisplayName = "Congratulations on making this weird, Eris... Fine, you figured me out! I'm {#Emph}desperate {#Prev}for your approval and affection. Yours and everyone's! Is {#Emph}that {#Prev}what you think?"
      Speaker = "Melinoe"
      Event = "ErisGift04"
    }
    {
      Id = "Eris_0091"
      InheritFrom = "BaseNarrative"
      DisplayName = "You said it, babe, not me. Now, come off it. Though, if you can keep a secret...? I {#Emph}do {#Prev}like you just a little more, I think."
      Speaker = "Eris"
      Event = "ErisGift04"
    }
    {
      Id = "Eris_0203"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know I've tried brewing Nectar myself. Got most of the key ingredients, except my batches never tasted right! Not like the stuff you get {#Emph}your {#Prev}hands on."
      Speaker = "Eris"
      Event = "ErisGift05"
    }
    {
      Id = "Melinoe_4288"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nectar's always best when it's a gift. Ever had somebody else give yours a try? Perhaps it's better than you think."
      Speaker = "Melinoe"
      Event = "ErisGift05"
    }
    {
      Id = "Eris_0204"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, {#Emph}no{#Prev}, because... for that I'd need a {#Emph}friend. {#Prev}Though I {#Emph}could {#Prev}always {#Emph}trick {#Prev}somebody into drinking it..."
      Speaker = "Eris"
      Event = "ErisGift05"
    }
    {
      Id = "Melinoe_4289"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Eris!"
      Speaker = "Melinoe"
      Event = "ErisGift05"
    }
    {
      Id = "Eris_0205"
      InheritFrom = "BaseNarrative"
      DisplayName = "Right when you trotted over to me here, I wished you'd bring another Nectar, since I'm out. And, {#Emph}lo and behold! {#Prev}It's like you're a {#Emph}mind-reader... {#Prev}or a {#Emph}dream-weaver!"
      Speaker = "Eris"
      Event = "ErisGift06"
    }
    {
      Id = "Melinoe_4290"
      InheritFrom = "BaseNarrative"
      DisplayName = "Advanced techniques I haven't mastered yet. Besides, pure intuition still is our most powerful tool in cases such as this! I simply had a feeling you were up for another bottle."
      Speaker = "Melinoe"
      Event = "ErisGift06"
    }
    {
      Id = "Eris_0206"
      InheritFrom = "BaseNarrative"
      DisplayName = "Way to make it sound like I'm some big experiment for you! Keep {#Emph}poking {#Prev}and {#Emph}prodding {#Prev}and eventually you'll get through my defenses and see the real {#Emph}me? {#Prev}Well this is {#Emph}it. {#Prev}And you know {#Emph}what? {#Prev}I don't want your Nectar anymore."
      Speaker = "Eris"
      Event = "ErisGift06"
    }
    {
      Id = "Melinoe_4291"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Including the one I just gave you?"
      Speaker = "Melinoe"
      Event = "ErisGift06"
    }
    {
      Id = "Eris_0207"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No I'll keep that one."
      Speaker = "Eris"
      Event = "ErisGift06"
    }
    {
      Id = "Melinoe_4476"
      InheritFrom = "BaseNarrative"
      DisplayName = "You said you didn't want my Nectar anymore but said nothing of Ambrosia, Eris, so... what do you say we visit the taverna once again?"
      Speaker = "Melinoe"
      Event = "ErisGift07"
    }
    {
      Id = "Eris_0262"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh I might visit the taverna, thanks! Though this time I'll be doing it alone. Don't take this the wrong way, but... I don't think we should be seen together anymore."
      Speaker = "Eris"
      Event = "ErisGift07"
    }
    {
      Id = "Melinoe_4477"
      InheritFrom = "BaseNarrative"
      DisplayName = "What, because you're concerned some baseless rumors will begin to spread? I thought Strife Incarnate wasn't supposed to care what anybody thought."
      Speaker = "Melinoe"
      Event = "ErisGift07"
    }
    {
      Id = "Eris_0263"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's for your own good. You're the one who's got a reputation to uphold. Really doesn't take much for me to live up to mine. I can just tell you to get out of my {#Emph}face!"
      Speaker = "Eris"
      Event = "ErisGift07"
    }
    {
      Id = "Melinoe_4478"
      InheritFrom = "BaseNarrative"
      DisplayName = "You sure you won't come with me to the taverna anymore? Here's some Ambrosia for you either way. You'll know from its flavor that my intentions are true."
      Speaker = "Melinoe"
      Event = "ErisGift08"
    }
    {
      Id = "Eris_0264"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yeah, well! Not if I never {#Emph}try {#Prev}it! What if I just smash the bottle on the ground right here? What would you say to {#Emph}that?"
      Speaker = "Eris"
      Event = "ErisGift08"
    }
    {
      Id = "Melinoe_4479"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd probably just offer you another. You get on my nerves all the time; Nemesis herself would say it's only fair that I occasionally get on yours."
      Speaker = "Melinoe"
      Event = "ErisGift08"
    }
    {
      Id = "Eris_0265"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Occasionally? {#Prev}Babe, you've been on my {#Emph}nerves {#Prev}for basically the whole time I've been back. I'm not falling for your tricks!"
      Speaker = "Eris"
      Event = "ErisGift08"
    }
    {
      Id = "Melinoe_4480"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What tricks...?"
      Speaker = "Melinoe"
      Event = "ErisGift08"
    }
    {
      Id = "Melinoe_4481"
      InheritFrom = "BaseNarrative"
      DisplayName = "For your stockpile of Ambrosia, Strife. Whether you choose to partake of it at the taverna with me, or someone else, or in a quiet moment on your own."
      Speaker = "Melinoe"
      Event = "ErisGift09"
    }
    {
      Id = "Eris_0266"
      InheritFrom = "BaseNarrative"
      DisplayName = "You should know better than to mess with me like this. You know {#Emph}exactly {#Prev}what I am. I happen to kind of like you, but... I can make your life {#Emph}so {#Prev}miserable, you don't even know."
      Speaker = "Eris"
      Event = "ErisGift09"
    }
    {
      Id = "Melinoe_4482"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps it's your own influence on me but I'm prepared to take my chances. Why else would I keep speaking to you here? As part of some elaborate jest?"
      Speaker = "Melinoe"
      Event = "ErisGift09"
    }
    {
      Id = "Eris_0267"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't {#Emph}know {#Prev}why, but the nicer you act with me, the {#Emph}stupider {#Prev}I think you are, and the more {#Emph}suspicious {#Prev}I get! And you've been acting {#Emph}real nice. {#Prev}This whole taverna thing, would you just... ask me {#Emph}normally {#Prev}next time?!"
      Speaker = "Eris"
      Event = "ErisGift09"
    }
    {
      Id = "Melinoe_4483"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Can I get that Ambrosia back at least?"
      Speaker = "Melinoe"
      Event = "ErisGift09"
    }
    {
      Id = "Eris_0268"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No!"
      Speaker = "Eris"
      Event = "ErisGift09"
    }
    {
      Id = "Melinoe_3474"
      InheritFrom = "BaseNarrative"
      DisplayName = "Please don't make me regret this, Eris, but... would you like to join me at the hot springs for a bit? Helps ease the tension."
      Speaker = "Melinoe"
      Event = "ErisBathHouse01"
    }
    {
      Id = "Eris_0176"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wait, the springs are purified again? I've been out of the loop! Surprised I'd get another invite after last time, but... {#Emph}OK!"
      Speaker = "Eris"
      Event = "ErisBathHouse01"
    }
    {
      Id = "Eris_0180"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ungh{#Prev}, so {#Emph}this {#Prev}is what you still do to relax? Hot as magma in this thing! Can we get out yet?"
      Speaker = "Eris"
      Event = "ErisBathHouse01"
    }
    {
      Id = "Melinoe_3475"
      InheritFrom = "BaseNarrative"
      DisplayName = "Permission denied. You'll quickly grow accustomed to the heat. Just try to concentrate on any tensions that you feel, and let the waters take them."
      Speaker = "Melinoe"
      Event = "ErisBathHouse01"
    }
    {
      Id = "Eris_0181"
      InheritFrom = "BaseNarrative"
      DisplayName = "Tensions, {#Emph}me? {#Prev}Babe. I don't need to {#Emph}boil alive {#Prev}in order to cut loose. Though good to know you've found a way to bottle tensions up. What happens if you drink this stuff?"
      Speaker = "Eris"
      Event = "ErisBathHouse01"
    }
    {
      Id = "Melinoe_3476"
      InheritFrom = "BaseNarrative"
      DisplayName = "These springs are pure thanks partly to the Salts we use. Though even still, I wouldn't recommend imbibing them. Next thing you know, {#Emph}you {#Prev}might be purified as well."
      Speaker = "Melinoe"
      Event = "ErisBathHouse01"
    }
    {
      Id = "Eris_0182"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh I'm not worried about that! This is the way I am down to my very core. And if {#Emph}you {#Prev}don't like it, and brought me in here hoping a nice hot bath was all it'd take for me to change, well then... I hate to disappoint."
      Speaker = "Eris"
      Event = "ErisBathHouse01"
    }
    {
      Id = "Melinoe_3477"
      InheritFrom = "BaseNarrative"
      DisplayName = "Looks like the waters haven't rid you of your tensions yet...! Sometimes a hot spring is just a hot spring, Eris. Not everything is an assault on your ideals."
      Speaker = "Melinoe"
      Event = "ErisBathHouse01"
    }
    {
      Id = "Eris_0183"
      InheritFrom = "BaseNarrative"
      DisplayName = "With all of you, I never can be sure. Though, this is nicer than the last time, and the heat isn't so bad right now, I guess..."
      Speaker = "Eris"
      Event = "ErisBathHouse01"
    }
    {
      Id = "Eris_0184"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Eugh{#Prev}... think I drank {#Emph}way {#Prev}too much bath water back there. Is this what being purified feels like? {#Emph}Whew!"
      Speaker = "Eris"
      Event = "ErisBathHouse01"
    }
    {
      Id = "Melinoe_3479"
      InheritFrom = "BaseSubtitle"
      DisplayName = "See you, Eris..."
      Speaker = "Melinoe"
      Event = "ErisBathHouse01"
    }
    {
      Id = "Melinoe_4292"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey how about another visit to the springs? You seemed to enjoy yourself last time, and I find it truly helps."
      Speaker = "Melinoe"
      Event = "ErisBathHouse02"
    }
    {
      Id = "Eris_0208"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well as long as it {#Emph}helps! {#Prev}Look, I don't get my wings wet for just {#Emph}anybody{#Prev}, babe, but you're special. So let's go?"
      Speaker = "Eris"
      Event = "ErisBathHouse02"
    }
    {
      Id = "Melinoe_4293"
      InheritFrom = "BaseNarrative"
      DisplayName = "...What is it like having so many siblings? I have but one and didn't even know him growing up. Though I often tried confiding in him anyway, like an imaginary friend."
      Speaker = "Melinoe"
      Event = "ErisBathHouse02"
    }
    {
      Id = "Eris_0212"
      InheritFrom = "BaseNarrative"
      DisplayName = "The more brothers and sisters you have, the bigger the disappointment you can be! And it is so embarrassing when you forget their {#Emph}names. {#Prev}Just look how us kids of Nyx get on. The only family more messed up than mine is {#Emph}yours!"
      Speaker = "Eris"
      Event = "ErisBathHouse02"
    }
    {
      Id = "Melinoe_4294"
      InheritFrom = "BaseNarrative"
      DisplayName = "You mean the Olympians. How do you figure? They have their differences to be sure. But they still work together to maintain the natural order of the realms."
      Speaker = "Melinoe"
      Event = "ErisBathHouse02"
    }
    {
      Id = "Eris_0213"
      InheritFrom = "BaseNarrative"
      DisplayName = "Work {#Emph}together? {#Prev}Come {#Emph}on{#Prev}, they can barely stand each other, from the very top on down! They never should have gone into business. Always caught between their blood commitments and their jobs!"
      Speaker = "Eris"
      Event = "ErisBathHouse02"
    }
    {
      Id = "Melinoe_4295"
      InheritFrom = "BaseNarrative"
      DisplayName = "I won't deny that family adds a complicated layer to their responsibilities. But it's also a source of solidarity and strength. Look at them now, standing together against a common foe. {#Emph}This {#Prev}is the Olympus mortals love and fear."
      Speaker = "Melinoe"
      Event = "ErisBathHouse02"
    }
    {
      Id = "Eris_0214"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sorry, not impressed. They say family is a bond that can never be broken, but... as is so often the case, they're {#Emph}wrong. {#Prev}Just because someone's related to you doesn't make them {#Emph}special {#Prev}or deserving of respect."
      Speaker = "Eris"
      Event = "ErisBathHouse02"
    }
    {
      Id = "Melinoe_4296"
      InheritFrom = "BaseNarrative"
      DisplayName = "What {#Emph}does {#Prev}it take to earn respect from you, Eris?"
      Speaker = "Melinoe"
      Event = "ErisBathHouse02"
    }
    {
      Id = "Eris_0215"
      InheritFrom = "BaseNarrative"
      DisplayName = "I actually don't even know the answer to that right now. Though, sitting naked with me in half-boiling water helps!"
      Speaker = "Eris"
      Event = "ErisBathHouse02"
    }
    {
      Id = "Eris_0216"
      InheritFrom = "BaseNarrative"
      DisplayName = "I had a blast there, babe. And look how {#Emph}clean {#Prev}my wings are now! Won't stay like this for long, but... still."
      Speaker = "Eris"
      Event = "ErisBathHouse02"
    }
    {
      Id = "Melinoe_3553"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey... what would you say about a visit to the hot springs, to cleanse yourself of all your foul deeds? And me of mine?"
      Speaker = "Melinoe"
      Event = "ErisBathHouseDecline01"
    }
    {
      Id = "Eris_0094"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, {#Emph}haha{#Prev}, well... you know, I'd feel way too self-conscious there with anybody else. Sorry!"
      Speaker = "Eris"
      Event = "ErisBathHouseDecline01"
    }
    {
      Id = "Melinoe_4277"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're always in this corner on your own. Come to the taverna for a bit! We can {#Emph}let loose and have a good time{#Prev}, as you say. Got a bottle of Ambrosia right here."
      Speaker = "Melinoe"
      Event = "ErisTaverna01"
    }
    {
      Id = "Eris_0238"
      InheritFrom = "BaseNarrative"
      DisplayName = "Babe that's so {#Emph}spontaneous {#Prev}of you! How could I say {#Emph}no? {#Prev}As long as I'm still allowed in there after what {#Emph}happened..."
      Speaker = "Eris"
      Event = "ErisTaverna01"
    }
    {
      Id = "Eris_0239"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ahh! {#Prev}That stuff does go down {#Emph}smooth! {#Prev}How 'bout another? And {#Emph}nice job {#Prev}with this place! Really looks like you all fixed everything up!"
      Speaker = "Eris"
      Event = "ErisTaverna01"
    }
    {
      Id = "Melinoe_4278"
      InheritFrom = "BaseNarrative"
      DisplayName = "This entire area was off limits for some time. It took a rather complex purification ritual and the efforts of a great many Shades to restore it, so... well, I won't even ask."
      Speaker = "Melinoe"
      Event = "ErisTaverna01"
    }
    {
      Id = "Eris_0240"
      InheritFrom = "BaseNarrative"
      DisplayName = "Good, I'm glad you won't even ask! Means we're {#Emph}really {#Prev}starting to get to know each other. Though, aren't you worried what the Shades are gonna say? I mean, about us...?"
      Speaker = "Eris"
      Event = "ErisTaverna01"
    }
    {
      Id = "Melinoe_4279"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, I hadn't considered that there might be some regrettable way to misconstrue our meeting; although in retrospect that was foolish. What do you expect they'll say?"
      Speaker = "Melinoe"
      Event = "ErisTaverna01"
    }
    {
      Id = "Eris_0241"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, {#Emph}you {#Prev}know! They see the way you talk to me, pick up after me, take me to the hot springs, give me Nectar, even Ambrosia. I mean, {#Emph}heh{#Prev}, come on! They're not {#Emph}stupid!"
      Speaker = "Eris"
      Event = "ErisTaverna01"
    }
    {
      Id = "Melinoe_4280"
      InheritFrom = "BaseNarrative"
      DisplayName = "What? Eris, none of those things... an outing at the taverna is not some sort of... {#Emph}ungh. {#Prev}This simply was an opportunity to speak at greater length for once."
      Speaker = "Melinoe"
      Event = "ErisTaverna01"
    }
    {
      Id = "Eris_0242"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hate to disappoint, but I didn't come here to {#Emph}speak. {#Prev}Now pour up! I don't have all night and this Ambrosia's {#Emph}way {#Prev}too bitter just for taking little swigs."
      Speaker = "Eris"
      Event = "ErisTaverna01"
    }
    {
      Id = "Eris_0243"
      InheritFrom = "BaseNarrative"
      DisplayName = "...That was so sweet of you to bring me along! And not a single piece of property destroyed! Glad we could do this."
      Speaker = "Eris"
      Event = "ErisTaverna01"
    }
    {
      Id = "Melinoe_4282"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Same here..."
      Speaker = "Melinoe"
      Event = "ErisTaverna01"
    }
    {
      Id = "Melinoe_4484"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Erm{#Prev}, Eris? Care to join me over at the taverna for a quick break? If you're not otherwise preoccupied."
      Speaker = "Melinoe"
      Event = "ErisTaverna02"
    }
    {
      Id = "Eris_0269"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wait babe are you asking me out? After {#Emph}all {#Prev}we've been through together, you're {#Emph}still {#Prev}trying to make a fresh start."
      Speaker = "Eris"
      Event = "ErisTaverna02"
    }
    {
      Id = "Melinoe_4485"
      InheritFrom = "BaseNarrative"
      DisplayName = "Last time you suggested I ask normally, so I attempted to. Now are we going for a blasted drink or not?"
      Speaker = "Melinoe"
      Event = "ErisTaverna02"
    }
    {
      Id = "Eris_0270"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sure! I'm... into it if you are, though... I don't see the point."
      Speaker = "Eris"
      Event = "ErisTaverna02"
    }
    {
      Id = "Eris_0271"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Whew! {#Prev}Now pour another one, come on. Both got a busy night ahead, so let's move it along!"
      Speaker = "Eris"
      Event = "ErisTaverna02"
    }
    {
      Id = "Melinoe_4486"
      InheritFrom = "BaseNarrative"
      DisplayName = "All right, it's just... Ambrosia is meant more for sipping and savoring than gulping down in one incredibly long tilt."
      Speaker = "Melinoe"
      Event = "ErisTaverna02"
    }
    {
      Id = "Eris_0272"
      InheritFrom = "BaseNarrative"
      DisplayName = "What makes you think I care? I won't feel {#Emph}anything {#Prev}if I take little tiny sips. Hardly feel anything right now!"
      Speaker = "Eris"
      Event = "ErisTaverna02"
    }
    {
      Id = "Melinoe_4487"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps you simply haven't given it a shot the proper way. You lift it to your lips like so. Briefly inhale, consider the aroma, and then drink. But only a bit."
      Speaker = "Melinoe"
      Event = "ErisTaverna02"
    }
    {
      Id = "Eris_0273"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Oh. {#Emph}Ohhh. {#Prev}That's different, isn't it. I... didn't even know that's how it worked. Why {#Emph}are {#Prev}you being nice to me?"
      Speaker = "Eris"
      Event = "ErisTaverna02"
    }
    {
      Id = "Melinoe_4488"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm not entirely certain. Just to see what happens I suppose? You said before that you happen to kind of like me. I kind of like you, too! Even though I know I shouldn't..."
      Speaker = "Melinoe"
      Event = "ErisTaverna02"
    }
    {
      Id = "Eris_0274"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, I feel sorry for you, babe. Really do. We always want what we can never have. Now show me how you sip this stuff again! Aren't you supposed to say something first?"
      Speaker = "Eris"
      Event = "ErisTaverna02"
    }
    {
      Id = "Eris_0275"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Look that was fun and all but next I spot you at the Rift of Thessaly, I'm still gonna hit you with everything I've got! And you better keep showing up."
      Speaker = "Eris"
      Event = "ErisTaverna02"
    }
    {
      Id = "Melinoe_4490"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm planning on it. Don't ever change, Eris."
      Speaker = "Melinoe"
      Event = "ErisTaverna02"
    }
    {
      Id = "Melinoe_4283"
      InheritFrom = "BaseNarrative"
      DisplayName = "What if we head to the taverna for a little while? You don't seem particularly busy and we probably should talk..."
      Speaker = "Melinoe"
      Event = "ErisTavernaDecline01"
    }
    {
      Id = "Eris_0244"
      InheritFrom = "BaseNarrative"
      DisplayName = "What if you get out of my {#Emph}face {#Prev}for a little while? Don't feel like seeing you and all those Shades judging me, thanks."
      Speaker = "Eris"
      Event = "ErisTavernaDecline01"
    }
    {
      Id = "Melinoe_4284"
      InheritFrom = "BaseNarrative"
      DisplayName = "How about we head down to the fishing pier a bit? Not like it's far out of the way or anything, and it's a change of pace."
      Speaker = "Melinoe"
      Event = "ErisFishing01"
    }
    {
      Id = "Eris_0217"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Sure{#Prev}, I'm easy, babe! Except when I'm not, but right now I could go for {#Emph}anything! {#Prev}Even stand around for fish to bite!"
      Speaker = "Eris"
      Event = "ErisFishing01"
    }
    {
      Id = "Eris_0218"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Know what I hate more than just about anything else? Having to be perfectly quiet while standing perfectly still. What have I done to deserve this {#Emph}torture?!"
      Speaker = "Eris"
      Event = "ErisFishing01"
    }
    {
      Id = "Melinoe_4285"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know it's difficult, which is part of the reason to do it from time to time... just concentrate on being who you are and being here. A fishing pier isn't strictly required."
      Speaker = "Melinoe"
      Event = "ErisFishing01"
    }
    {
      Id = "Eris_0219"
      InheritFrom = "BaseNarrative"
      DisplayName = "Being focused in on the moment, come {#Emph}on! {#Prev}How can you not {#Emph}always {#Prev}be doing that? At least in other moments I'd be doing what I {#Emph}want. {#Prev}Not caving to your every demand!"
      Speaker = "Eris"
      Event = "ErisFishing01"
    }
    {
      Id = "Melinoe_4286"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you don't find anything worthwhile in this, you don't have to do it again. But since we're here, why not find out if we can catch something?"
      Speaker = "Melinoe"
      Event = "ErisFishing01"
    }
    {
      Id = "Eris_0220"
      InheritFrom = "BaseNarrative"
      DisplayName = "All {#Emph}you {#Prev}are gonna catch is my {#Emph}fist {#Prev}in your {#Emph}face {#Prev}if you keep on mouthing off to me, babe! Though wait, {#Emph}shut up! {#Prev}Think I just saw something swim by!"
      Speaker = "Eris"
      Event = "ErisFishing01"
    }
    {
      Id = "Eris_0237"
      InheritFrom = "BaseNarrative"
      DisplayName = "Babe I had a {#Emph}totally {#Prev}amazing time, I {#Emph}swear! {#Prev}And, you don't stink at {#Emph}all!"
      Speaker = "Eris"
      Event = "ErisFishing01"
    }
    {
      Id = "Melinoe_4692"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Nor do you."
      Speaker = "Melinoe"
      Event = "ErisFishing01"
    }
    {
      Id = "Melinoe_3554"
      InheritFrom = "BaseNarrative"
      DisplayName = "The fishing pier's wide open as you can see... any impulse to make use of it a while?"
      Speaker = "Melinoe"
      Event = "ErisFishingDecline01"
    }
    {
      Id = "Eris_0095"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Mmm{#Prev}, a trip to the fishing-hole involves a lot more being still and quiet than I think I can handle right now, thanks."
      Speaker = "Eris"
      Event = "ErisFishingDecline01"
    }
    {
      Id = "Melinoe_1158"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Eris is gone..."
      Speaker = "Melinoe"
      Event = "NPC_Eris_01.MissingDistanceTrigger.VoiceLines"
    }
    {
      Id = "Melinoe_2854"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What's Eris up to now..."
      Speaker = "Melinoe"
      Event = "NPC_Eris_01.MissingDistanceTrigger.VoiceLines"
    }
    {
      Id = "Melinoe_2691"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, this really isn't necessary but, {#Emph}erm{#Prev}... thanks."
      Speaker = "Melinoe"
      Event = "NPC_Eris_01.GiftGivenVoiceLines"
    }
    {
      Id = "MelinoeField_1709"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Go... {#Emph}away!"
      Speaker = "Melinoe"
      Event = "NPC_Eris_01.OnHitVoiceLines"
    }
    {
      Id = "MelinoeField_1710"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm warning you!"
      Speaker = "Melinoe"
      Event = "NPC_Eris_01.OnHitVoiceLines"
    }
    {
      Id = "MelinoeField_1711"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not talking to you!"
      Speaker = "Melinoe"
      Event = "NPC_Eris_01.OnHitVoiceLines"
    }
    {
      Id = "MelinoeField_1712"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Argh!"
      Speaker = "Melinoe"
      Event = "NPC_Eris_01.OnHitVoiceLines"
    }
    {
      Id = "ErisField_0019"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, one last thing..."
      Speaker = "Eris"
      Event = "NPC_Eris_01.ExitVoiceLines"
    }
    {
      Id = "ErisField_0032"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Oopsie!"
      Speaker = "Eris"
      Event = "NPC_Eris_01.ExitVoiceLines"
    }
    {
      Id = "ErisField_0033"
      InheritFrom = "BaseSubtitle"
      DisplayName = "See you later!"
      Speaker = "Eris"
      Event = "NPC_Eris_01.ExitVoiceLines"
    }
    {
      Id = "ErisField_0034"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Bye now!"
      Speaker = "Eris"
      Event = "NPC_Eris_01.ExitVoiceLines"
    }
    {
      Id = "ErisField_0035"
      InheritFrom = "BaseSubtitle"
      DisplayName = "My work here is done!"
      Speaker = "Eris"
      Event = "NPC_Eris_01.ExitVoiceLines"
    }
    {
      Id = "ErisField_0036"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Death to {#Emph}Chronos!"
      Speaker = "Eris"
      Event = "NPC_Eris_01.ExitVoiceLines"
    }
    {
      Id = "ErisField_0037"
      InheritFrom = "BaseSubtitle"
      DisplayName = "OK, gotta go!"
      Speaker = "Eris"
      Event = "NPC_Eris_01.ExitVoiceLines"
    }
    {
      Id = "MelinoeField_1703"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What did she do to me...?"
      Speaker = "Melinoe"
      Event = "NPC_Eris_01.ExitVoiceLines"
    }
    {
      Id = "MelinoeField_1704"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Eugh{#Prev}, great..."
      Speaker = "Melinoe"
      Event = "NPC_Eris_01.ExitVoiceLines"
    }
    {
      Id = "MelinoeField_1705"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Curses..."
      Speaker = "Melinoe"
      Event = "NPC_Eris_01.ExitVoiceLines"
    }
    {
      Id = "MelinoeField_1706"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Trying to slow me down..."
      Speaker = "Melinoe"
      Event = "NPC_Eris_01.ExitVoiceLines"
    }
    {
      Id = "MelinoeField_1707"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This again?"
      Speaker = "Melinoe"
      Event = "NPC_Eris_01.ExitVoiceLines"
    }
    {
      Id = "MelinoeField_1708"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I don't appreciate this, Eris...!"
      Speaker = "Melinoe"
      Event = "NPC_Eris_01.ExitVoiceLines"
    }
    {
      Id = "ErisField_0017"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}You're {#Prev}a long way from the Crossroads, Trouble! So, this is where the real action is, {#Emph}huh? {#Prev}Weren't you supposed to still be practicing?"
      Speaker = "Eris"
      Event = "ErisGrantsCurse01"
    }
    {
      Id = "MelinoeField_1698"
      InheritFrom = "BaseNarrative"
      DisplayName = "Things took a turn, Eris...! You know how it goes. Now, if you'll excuse me, I have some urgent business to attend to."
      Speaker = "Melinoe"
      Event = "ErisGrantsCurse01"
    }
    {
      Id = "ErisField_0018"
      InheritFrom = "BaseNarrative"
      DisplayName = "Always in such a rush! I'd really hate to slow you down, though let's hang out sometime, OK? Have a great night."
      Speaker = "Eris"
      Event = "ErisGrantsCurse01"
    }
    {
      Id = "MelinoeField_1699"
      InheritFrom = "BaseNarrative"
      DisplayName = "Here to set another curse on me, Eris? For all your {#Emph}idiosyncrasies{#Prev}, I never took you for a traitor."
      Speaker = "Melinoe"
      Event = "ErisGrantsCurse02"
    }
    {
      Id = "ErisField_0020"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm not, {#Emph}I swear! {#Prev}It's just... {#Emph}ugh{#Prev}, you'll never understand. I wanted this to be a {#Emph}special moment{#Prev}, but you had to go and {#Emph}ruin {#Prev}it!"
      Speaker = "Eris"
      Event = "ErisGrantsCurse02"
    }
    {
      Id = "MelinoeField_1700"
      InheritFrom = "BaseNarrative"
      DisplayName = "You again. What, are you concerned my task just isn't difficult enough? Going a bit too swimmingly?"
      Speaker = "Melinoe"
      Event = "ErisGrantsCurse03"
    }
    {
      Id = "ErisField_0021"
      InheritFrom = "BaseNarrative"
      DisplayName = "Actually {#Emph}yes{#Prev}, I was a little worried about that. You got past the {#Emph}Sirens! {#Prev}What next, you'll go kill Chronos, and then what? Come on, babe. Let's not do anything rash."
      Speaker = "Eris"
      Event = "ErisGrantsCurse03"
    }
    {
      Id = "MelinoeField_1701"
      InheritFrom = "BaseNarrative"
      DisplayName = "Out of my way, Eris! I won't be wasting any further breath on you while you perpetuate this nonsense."
      Speaker = "Melinoe"
      Event = "ErisGrantsCurse04"
    }
    {
      Id = "ErisField_0022"
      InheritFrom = "BaseNarrative"
      DisplayName = "You never understood me, Trouble. Fine! You don't have to. Just remember that I'm doing this for your own good. And actually, mine too!"
      Speaker = "Eris"
      Event = "ErisGrantsCurse04"
    }
    {
      Id = "ErisField_0023"
      InheritFrom = "BaseNarrative"
      DisplayName = "What's all the commotion, anyway, {#Emph}huh? {#Prev}Chronos started bashing on Olympus again, sure. But it's not like you have to go after him now, do you?"
      Speaker = "Eris"
      Event = "ErisGrantsCurse05"
    }
    {
      Id = "MelinoeField_1702"
      InheritFrom = "BaseNarrative"
      DisplayName = "Believe me, I'd much rather stay and chitchat with you than sully my hands in Titan blood. But you have a choice, Eris. You can help me finish this, rather than hinder me."
      Speaker = "Melinoe"
      Event = "ErisGrantsCurse05"
    }
    {
      Id = "ErisField_0024"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know, babe... when you're right, you're {#Emph}right. {#Prev}You've given me a lot to chew on. Now you chew on {#Emph}this."
      Speaker = "Eris"
      Event = "ErisGrantsCurse05"
    }
    {
      Id = "MelinoeField_1925"
      InheritFrom = "BaseNarrative"
      DisplayName = "What are you doing here in Tartarus? There's no way you could have access to this place, unless..."
      Speaker = "Melinoe"
      Event = "ErisGrantsCurse06"
    }
    {
      Id = "ErisField_0025"
      InheritFrom = "BaseNarrative"
      DisplayName = "Unless I could, like, {#Emph}fly? {#Prev}Come off it, babe, you're {#Emph}way {#Prev}too stuck in your own head. You'll probably be stuck here too!"
      Speaker = "Eris"
      Event = "ErisGrantsCurse06"
    }
  ]
}
