      Event = "ZeusUpgrade.RarityUpgradeVoiceLines"
    }
    {
      Id = "Zeus_0306"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Be safe."
      Speaker = "Zeus"
      Event = "ZeusUpgrade.RarityUpgradeVoiceLines"
    }
    {
      Id = "Zeus_0104"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Greetings to you!"
