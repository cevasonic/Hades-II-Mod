      DisplayName = "I already have plans this evening, sorry..."
      Speaker = "Melinoe"
      Event = "NPC_Dionysus_01.UpgradeMenuOpenVoiceLines"
    }
    {
      Id = "MelinoeField_2400"
      InheritFrom = "BaseSubtitle"
      DisplayName = "He's great, I'm sure..."
      Speaker = "Melinoe"
      Event = "NPC_Dionysus_01.UpgradeMenuOpenVoiceLines"
    }
    {
      Id = "MelinoeField_2897"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...I'm going to have to pass."
