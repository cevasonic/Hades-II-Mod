    }
    {
      Id = "Dora_0567"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No touching."
      Speaker = "Dora"
      Event = "PostTriggerFunctionArgs.ThreadedVoiceLines"
    }
    {
      Id = "Dora_0568"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Back off a bit?"
      Speaker = "Dora"
      Event = "PostTriggerFunctionArgs.ThreadedVoiceLines"
    }
    {
      Id = "Dora_0570"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Excuse {#Emph}you."
      Speaker = "Dora"
      Event = "PostTriggerFunctionArgs.ThreadedVoiceLines"
    }
    {
      Id = "Dora_0573"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Kind of felt that."
      Speaker = "Dora"
      Event = "PostTriggerFunctionArgs.ThreadedVoiceLines"
    }
    {
      Id = "Dora_0571"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's a curse!"
      Speaker = "Dora"
      Event = "PostTriggerFunctionArgs.ThreadedVoiceLines"
    }
    {
      Id = "Dora_0572"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's a curse."
      Speaker = "Dora"
      Event = "PostTriggerFunctionArgs.ThreadedVoiceLines"
    }
    {
      Id = "Dora_0574"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}You dare?"
      Speaker = "Dora"
      Event = "PostTriggerFunctionArgs.ThreadedVoiceLines"
    }
    {
      Id = "Dora_0575"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}A curse upon you!"
      Speaker = "Dora"
      Event = "PostTriggerFunctionArgs.ThreadedVoiceLines"
    }
    {
      Id = "Melinoe_1885"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hail, spirit!"
      Speaker = "Melinoe"
      Event = "NPC_Dora_01.InteractVoiceLines"
    }
    {
      Id = "Dora_0202"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}You invoke me?"
      Speaker = "Dora"
      Event = "NPC_Dora_01.InteractVoiceLines"
    }
    {
      Id = "Dora_0203"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Who summons me?"
      Speaker = "Dora"
      Event = "NPC_Dora_01.InteractVoiceLines"
    }
    {
      Id = "Dora_0204"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Kneel, witch!"
      Speaker = "Dora"
      Event = "NPC_Dora_01.InteractVoiceLines"
    }
    {
      Id = "Dora_0205"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Death to all!"
      Speaker = "Dora"
      Event = "NPC_Dora_01.InteractVoiceLines"
    }
    {
      Id = "Dora_0206"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Suffer a thousand torments!"
      Speaker = "Dora"
      Event = "NPC_Dora_01.InteractVoiceLines"
    }
    {
      Id = "Dora_0207"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}And the sun bleach your bones!"
      Speaker = "Dora"
      Event = "NPC_Dora_01.InteractVoiceLines"
    }
    {
      Id = "Dora_0208"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Terror engulf us!"
      Speaker = "Dora"
      Event = "NPC_Dora_01.InteractVoiceLines"
    }
    {
      Id = "Dora_0209"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Whatever works."
      Speaker = "Dora"
      Event = "NPC_Dora_01.InteractVoiceLines"
    }
    {
      Id = "Dora_0210"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm staying right here."
      Speaker = "Dora"
      Event = "NPC_Dora_01.InteractVoiceLines"
    }
    {
      Id = "Dora_0211"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come on, Mel."
      Speaker = "Dora"
      Event = "NPC_Dora_01.InteractVoiceLines"
    }
    {
      Id = "Dora_0212"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, lighten up..."
      Speaker = "Dora"
      Event = "NPC_Dora_01.InteractVoiceLines"
    }
    {
      Id = "Dora_0004_01_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Who dares disturb my eternal rest? You trifle with powers far beyond your comprehension, witch!"
      Speaker = "Dora"
      Event = "DoraFirstMeeting"
    }
    {
      Id = "Dora_0646"
      InheritFrom = "BaseNarrative"
      DisplayName = " {#Prev}That was pretty decent, right, Mel? Maybe pushing it, calling you witch like that."
      Speaker = "Dora"
      Event = "DoraFirstMeeting"
    }
    {
      Id = "Melinoe_5191"
      InheritFrom = "BaseNarrative"
      DisplayName = "Solid haunting all in all, Dora, and I thought the witch part worked. But, I'd better go. Something I have to do."
      Speaker = "Melinoe"
      Event = "DoraFirstMeeting"
    }
    {
      Id = "Dora_0005"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Then begone!"
      Speaker = "Dora"
      Event = "DoraFirstMeeting"
    }
    {
      Id = "Melinoe_1302"
      InheritFrom = "BaseNarrative"
      DisplayName = "Dora, I've a favor, if you're not too busy. My task means I no longer can oversee the renewal project around here. Would you attend to it?"
      Speaker = "Melinoe"
      Event = "DoraGrantsCosmeticsShop01"
    }
    {
      Id = "Dora_0170"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wait, you're asking {#Emph}me {#Prev}to watch over the total transformation of this entire encampment into some ultimate haven for Shades and outcasts?"
      Speaker = "Dora"
      Event = "DoraGrantsCosmeticsShop01"
    }
    {
      Id = "Melinoe_1303"
      InheritFrom = "BaseNarrative"
      DisplayName = "I {#Emph}know {#Prev}I can count on you. I'll provide the materials, you'll be the main point of contact."
      Speaker = "Melinoe"
      Event = "DoraGrantsCosmeticsShop01"
    }
    {
      Id = "Dora_0171"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Mmmmmm {#Prev}OK fine."
      Speaker = "Dora"
      Event = "DoraGrantsCosmeticsShop01"
    }
    {
      Id = "Melinoe_1304"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Great!"
      Speaker = "Melinoe"
      Event = "DoraGrantsCosmeticsShop01"
    }
    {
      Id = "Melinoe_2021"
      InheritFrom = "BaseNarrative"
      DisplayName = "The renewal project's off to a fine start! How are you managing with all the new responsibility?"
      Speaker = "Melinoe"
      Event = "DoraAboutCosmetics01"
    }
    {
      Id = "Dora_0172"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Uh {#Prev}OK, I guess! Sometimes I think I'd rather not be doing anything... but, I get that somebody's got to do this stuff, and it's not like any of {#Emph}those {#Prev}slackers out there are gonna do it."
      Speaker = "Dora"
      Event = "DoraAboutCosmetics01"
    }
    {
      Id = "Melinoe_2022"
      InheritFrom = "BaseNarrative"
      DisplayName = "The other Shades have their own duties. The work needn't be onerous, it can be fulfilling! Helping others, having a sense of purpose..."
      Speaker = "Melinoe"
      Event = "DoraAboutCosmetics01"
    }
    {
      Id = "Dora_0173"
      InheritFrom = "BaseSubtitle"
      DisplayName = "My {#Emph}purpose{#Prev}, Mel, is only to hang out."
      Speaker = "Dora"
      Event = "DoraAboutCosmetics01"
    }
    {
      Id = "Dora_0310"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know what you're up to with all this decoration stuff you've got me doing, Mel. What, you think I'm about to find my true calling in death just by updating some old light fixtures?"
      Speaker = "Dora"
      Event = "DoraAboutCosmetics02"
    }
    {
      Id = "Melinoe_3697"
      InheritFrom = "BaseNarrative"
      DisplayName = "You already found your calling, as the best haunter in all the Crossroads, if not the entire world. The renewal project is simply a way to give something back to this place."
      Speaker = "Melinoe"
      Event = "DoraAboutCosmetics02"
    }
    {
      Id = "Dora_0311"
      InheritFrom = "BaseNarrative"
      DisplayName = "Maybe... but I'd make a lousy haunter if my existence wasn't utterly devoid of meaning. So don't let me catch you trying to help me find some purpose... 'cause I don't want any."
      Speaker = "Dora"
      Event = "DoraAboutCosmetics02"
    }
    {
      Id = "Melinoe_3698"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Perish the thought."
      Speaker = "Melinoe"
      Event = "DoraAboutCosmetics02"
    }
    {
      Id = "Dora_0307"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sometimes I hardly recognize this place... the tent, I mean. Just {#Emph}look {#Prev}at all this stuff! It's practically a palace now."
      Speaker = "Dora"
      Event = "DoraAboutCosmetics03"
    }
    {
      Id = "Melinoe_3695"
      InheritFrom = "BaseNarrative"
      DisplayName = "I never thought I'd want to live in a palace. Though when you put it that way, I have second thoughts. Are all the latest decorative touches to your liking?"
      Speaker = "Melinoe"
      Event = "DoraAboutCosmetics03"
    }
    {
      Id = "Dora_0308"
      InheritFrom = "BaseNarrative"
      DisplayName = "More stuff to mess with means more haunting opportunities, so yeah! I think it's fine. It's {#Emph}you {#Prev}I'm worried about... not quite as {#Emph}neat {#Prev}and {#Emph}sparse {#Prev}in here as it used to be..."
      Speaker = "Dora"
      Event = "DoraAboutCosmetics03"
    }
    {
      Id = "Melinoe_3696"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We could always neaten it up again."
      Speaker = "Melinoe"
      Event = "DoraAboutCosmetics03"
    }
    {
      Id = "Dora_0309"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Please no..."
      Speaker = "Dora"
      Event = "DoraAboutCosmetics03"
    }
    {
      Id = "Dora_0612"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know, back when you got me on your whole {#Emph}Renewal Project {#Prev}thing... I knew what you were up to, Mel. Nothing like a bunch of busywork to make you stop thinking about the pointlessness of your existence, right?"
      Speaker = "Dora"
      Event = "DoraAboutCosmetics04"
    }
    {
      Id = "Melinoe_4681"
      InheritFrom = "BaseNarrative"
      DisplayName = "I never saw it as a bunch of busywork. Look at how much we've been able to accomplish here! This place is flourishing, the other Shades seem energized... you had a lot to do with that!"
      Speaker = "Melinoe"
      Event = "DoraAboutCosmetics04"
    }
    {
      Id = "Dora_0613"
      InheritFrom = "BaseNarrative"
      DisplayName = "You really think so...? What I was going to say is, at some point the busywork started to kind of grow on me. It stopped feeling pointless, even if it is."
      Speaker = "Dora"
      Event = "DoraAboutCosmetics04"
    }
    {
      Id = "Melinoe_4682"
      InheritFrom = "BaseSubtitle"
      DisplayName = "If it doesn't {#Emph}feel {#Prev}pointless, it isn't."
      Speaker = "Melinoe"
      Event = "DoraAboutCosmetics04"
    }
    {
      Id = "Dora_0614"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I don't know. Maybe."
      Speaker = "Dora"
      Event = "DoraAboutCosmetics04"
    }
    {
      Id = "Dora_0649"
      InheritFrom = "BaseNarrative"
      DisplayName = "You got every last one of those Chthonic Chid figures, {#Emph}huh? {#Prev}Never took you for the sort to hoard a bunch of useless stuff."
      Speaker = "Dora"
      Event = "DoraAboutCosmetics05"
    }
    {
      Id = "Melinoe_5470"
      InheritFrom = "BaseNarrative"
      DisplayName = "They are {#Emph}not {#Prev}useless! I {#Emph}enjoyed {#Prev}collecting them all, and have them neatly organized. And they'll likely grow even more valuable with time!"
      Speaker = "Melinoe"
      Event = "DoraAboutCosmetics05"
    }
    {
      Id = "Dora_0650"
      InheritFrom = "BaseNarrative"
      DisplayName = "What, you planning to sell 'em for {#Emph}profit? {#Prev}I don't see who's gonna take them off your hands! But... I wasn't trying to be mean. I think it's cute you got a bunch of children's toys."
      Speaker = "Dora"
      Event = "DoraAboutCosmetics05"
    }
    {
      Id = "Melinoe_5471"
      InheritFrom = "BaseSubtitle"
      DisplayName = "They're not suitable for children!"
      Speaker = "Melinoe"
      Event = "DoraAboutCosmetics05"
    }
    {
      Id = "Dora_0652"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Mm-hmm."
      Speaker = "Dora"
      Event = "DoraAboutCosmetics05"
    }
    {
      Id = "Dora_0305"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, how's the old Ghost Onion working out? Figured you'd make better use of something that helps keep you alive than I can at this point... also it's kind of gross."
      Speaker = "Dora"
      Event = "DoraAboutKeepsake01"
    }
    {
      Id = "Melinoe_3694"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's been very helpful, thank you, Dora. Though your Onion means I'm staying out longer than usual most nights, while you're here on your own..."
      Speaker = "Melinoe"
      Event = "DoraAboutKeepsake01"
    }
    {
      Id = "Dora_0306"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I see everything is proceeding as planned..."
      Speaker = "Dora"
      Event = "DoraAboutKeepsake01"
    }
    {
      Id = "Dora_0002"
      InheritFrom = "BaseNarrative"
      DisplayName = "Mel! Thought I finally had the place to myself, then next I know, you're back. Damn near scared me to life. Rough night again?"
      Speaker = "Dora"
      Event = "DoraAboutReturning01"
    }
    {
      Id = "Melinoe_0011"
      InheritFrom = "BaseNarrative"
      DisplayName = "Rough night, Dora. Fear not, you'll have the tent to yourself yet! See you."
      Speaker = "Melinoe"
      Event = "DoraAboutReturning01"
    }
    {
      Id = "Dora_0003"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yeah, you too."
      Speaker = "Dora"
      Event = "DoraAboutReturning01"
    }
    {
      Id = "Dora_0189"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know, it's kind of spooky how you never come in through the front flap anymore. Ever think of taking up haunting, yourself?"
      Speaker = "Dora"
      Event = "DoraAboutReturning02"
    }
    {
      Id = "Melinoe_1827"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, yes! I figure if none of this works out, the lot of us can wander the earth, striking fear into the hearts of any mortals who dare look upon us."
      Speaker = "Melinoe"
      Event = "DoraAboutReturning02"
    }
    {
      Id = "Dora_0190"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}<Gasp> {#Prev}Now we're talking..."
      Speaker = "Dora"
      Event = "DoraAboutReturning02"
    }
    {
      Id = "Dora_0191"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Whew! {#Prev}Thought you'd never snap out of it. You OK?"
      Speaker = "Dora"
      Event = "DoraAboutReturning03"
    }
    {
      Id = "Melinoe_2018"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes, thank you, Dora. I hope I didn't cause you any concern. Have you been by my side here all this time?"
      Speaker = "Melinoe"
      Event = "DoraAboutReturning03"
    }
    {
      Id = "Dora_0192"
      InheritFrom = "BaseNarrative"
      DisplayName = "What, me? No. Just out for a breather."
      Speaker = "Dora"
      Event = "DoraAboutReturning03"
    }
    {
      Id = "Melinoe_2819"
      InheritFrom = "BaseSubtitle"
      DisplayName = "But you don't even breathe..."
      Speaker = "Melinoe"
      Event = "DoraAboutReturning03"
    }
    {
      Id = "Dora_0152"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Cut it out...!"
      Speaker = "Dora"
      Event = "DoraAboutReturning03"
    }
    {
      Id = "Dora_0303"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know you can tell me anything, Mel. I won't judge! Well... maybe a little more than the other small green squishy thing you bare your soul to every night, but still."
      Speaker = "Dora"
      Event = "DoraAboutFrinos01"
    }
    {
      Id = "Melinoe_3692"
      InheritFrom = "BaseNarrative"
      DisplayName = "I never made that particular connection between you and Frinos before. I speak to him about my setbacks and mistakes... but I'm happy to save some for you if you like!"
      Speaker = "Melinoe"
      Event = "DoraAboutFrinos01"
    }
    {
      Id = "Dora_0304"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yep, just lay 'em on me! And the bigger the screw-up, the more I want to know {#Emph}every juicy detail."
      Speaker = "Dora"
      Event = "DoraAboutFrinos01"
    }
    {
      Id = "Melinoe_3693"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I appreciate your service."
      Speaker = "Melinoe"
      Event = "DoraAboutFrinos01"
    }
    {
      Id = "Melinoe_3375"
      InheritFrom = "BaseNarrative"
      DisplayName = "Dora, couldn't help but notice that my jar collection wasn't sorted properly. Are you trying to subtly drive me mad?"
      Speaker = "Melinoe"
      Event = "DoraAboutTent01"
    }
    {
      Id = "Dora_0158"
      InheritFrom = "BaseNarrative"
      DisplayName = "No.... Although, now that you put it that way, maybe in the future, {#Emph}yes{#Prev}. I was working on minor possessions and your mushroom bottle kind of slipped. So I put it back!"
      Speaker = "Dora"
      Event = "DoraAboutTent01"
    }
    {
      Id = "Melinoe_0964"
      InheritFrom = "BaseNarrative"
      DisplayName = "You put it {#Emph}incorrectly {#Prev}back. I... {#Emph}augh{#Prev}. Just tell me of such things next time, would you?"
      Speaker = "Melinoe"
      Event = "DoraAboutTent01"
    }
    {
      Id = "Dora_0159"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Maybe I will, maybe I won't."
      Speaker = "Dora"
      Event = "DoraAboutTent01"
    }
    {
      Id = "Dora_0160"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know, Mel, you can be a bit uptight sometimes. Where'd you even get that from? Even the head witch is more relaxed than you."
      Speaker = "Dora"
      Event = "DoraAboutTent02"
    }
    {
      Id = "Melinoe_1820"
      InheritFrom = "BaseNarrative"
      DisplayName = "Look I'm under a lot of pressure right now, all right? Everybody's counting on me to literally {#Emph}kill Time... {#Prev}so I would like this tent to be an orderly place! Seeing as I'm having to return so often..."
      Speaker = "Melinoe"
      Event = "DoraAboutTent02"
    }
    {
      Id = "Dora_0161"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Eh{#Prev}, so what? Killing time's my specialty, don't see {#Emph}me {#Prev}gettin' all worked up."
      Speaker = "Dora"
      Event = "DoraAboutTent02"
    }
    {
      Id = "Melinoe_1821"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ungh..."
      Speaker = "Melinoe"
      Event = "DoraAboutTent02"
    }
    {
      Id = "Melinoe_1822"
      InheritFrom = "BaseNarrative"
      DisplayName = "Dora, I was thinking... if I promise not to be so {#Emph}uptight{#Prev}, as you call it... would you promise not to move my belongings about when I'm away?"
      Speaker = "Melinoe"
      Event = "DoraAboutTent03"
    }
    {
      Id = "Dora_0162"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}How dare you make demands of me, you insignificant fleck? Mmm{#Prev}, nope, no deal. Want to be uptight, go ahead, don't stop on my account."
      Speaker = "Dora"
      Event = "DoraAboutTent03"
    }
    {
      Id = "Melinoe_1823"
      InheritFrom = "BaseNarrative"
      DisplayName = "You just want to keep messing with my stuff!"
      Speaker = "Melinoe"
      Event = "DoraAboutTent03"
    }
    {
      Id = "Dora_0163"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Mmm{#Prev}, that's right."
      Speaker = "Dora"
      Event = "DoraAboutTent03"
    }
    {
      Id = "Dora_0051"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, the head witch isn't busting your chops too bad, is she? What with you coming back here pretty often lately and all."
      Speaker = "Dora"
      Event = "DoraAboutHecate01"
    }
    {
      Id = "Melinoe_0428"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know Headmistress can be very demanding. I'm sure she hopes I would have encountered more success by now, but... she's been nothing but patient."
      Speaker = "Melinoe"
      Event = "DoraAboutHecate01"
    }
    {
      Id = "Dora_0052"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Really? Well I hope {#Emph}that {#Prev}sticks!"
      Speaker = "Dora"
      Event = "DoraAboutHecate01"
    }
    {
      Id = "Melinoe_0435"
      InheritFrom = "BaseNarrative"
      DisplayName = "Have you ever even spoken with Commander Schelemeus, Dora? Or Odysseus? We have these great masters on our side, who know so much of history. So much they can teach us."
      Speaker = "Melinoe"
      Event = "DoraAboutCompanions01"
    }
    {
      Id = "Dora_0154"
      InheritFrom = "BaseNarrative"
      DisplayName = "History? That what they call it nowadays? Well, I don't have big plans to go to war with the rest of you anytime soon, though if I change my mind, I'll probably check in with those guys."
      Speaker = "Dora"
      Event = "DoraAboutCompanions01"
    }
    {
      Id = "Melinoe_0436"
      InheritFrom = "BaseSubtitle"
      DisplayName = "They're good people!"
      Speaker = "Melinoe"
      Event = "DoraAboutCompanions01"
    }
    {
      Id = "Melinoe_0429"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't you have friends among the other Shades, Dora? You could join them for some activity out there. It's picked up a lot of late."
      Speaker = "Melinoe"
      Event = "DoraAboutShades01"
    }
    {
      Id = "Dora_0059"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Foolish witch! {#Prev}Haunting this tent is a full-time obsession. We lesser Shades can be a little single-minded! I guess kind of like mortals."
      Speaker = "Dora"
      Event = "DoraAboutShades01"
    }
    {
      Id = "Melinoe_0430"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not just mortals..."
      Speaker = "Melinoe"
      Event = "DoraAboutShades01"
    }
    {
      Id = "Dora_0044"
      InheritFrom = "BaseNarrative"
      DisplayName = "How'd you get all those other Shades out there to do the busywork around here, anyway? They practically worship the ground you walk on."
      Speaker = "Dora"
      Event = "DoraAboutShades02"
    }
    {
      Id = "Melinoe_0433"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress took them in. I helped train and communicate with them. Many came from being trapped between the realms. Some never got a proper burial. Others died unfulfilled, or violently. They never made it to the Underworld."
      Speaker = "Melinoe"
      Event = "DoraAboutShades02"
    }
    {
      Id = "Dora_0045"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oof{#Prev}... that's rough. Say, you don't think {#Emph}I {#Prev}fall into one of those categories, there, do you? I'd hate to think I didn't get a {#Emph}proper burial{#Prev}."
      Speaker = "Dora"
      Event = "DoraAboutShades02"
    }
    {
      Id = "Melinoe_0434"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It's not a laughing matter, Dora."
      Speaker = "Melinoe"
      Event = "DoraAboutShades02"
    }
    {
      Id = "Dora_0168"
      InheritFrom = "BaseNarrative"
      DisplayName = "Getting crowded out there! More Shades, guy with the horns. I don't like it, Mel! Not one bit."
      Speaker = "Dora"
      Event = "DoraAboutShades03"
    }
    {
      Id = "Melinoe_1824"
      InheritFrom = "BaseNarrative"
      DisplayName = "As we grow in numbers, we grow in strength. What's your concern with that?"
      Speaker = "Melinoe"
      Event = "DoraAboutShades03"
    }
    {
      Id = "Dora_0169"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't like to share. Except this tent, I don't mind sharing it with you! Most of the time."
      Speaker = "Dora"
      Event = "DoraAboutShades03"
    }
    {
      Id = "Melinoe_1825"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm honored."
      Speaker = "Melinoe"
      Event = "DoraAboutShades03"
    }
    {
      Id = "Melinoe_2034"
      InheritFrom = "BaseNarrative"
      DisplayName = "Dora! {#Emph}Wow! {#Prev}What brings you all the way out here? The taverna's just about the last place I expected to find you."
      Speaker = "Melinoe"
      Event = "DoraAboutShades04"
    }
    {
      Id = "Dora_0196_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Um{#Prev}, way to make me feel incredibly self-conscious, thanks, Mel! But, yeah I'm, I'm trying to put myself out there a bit more, I guess...!"
      Speaker = "Dora"
      Event = "DoraAboutShades04"
    }
    {
      Id = "Melinoe_2035"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well I think that's great. Though, I know how difficult it is. I used to never be able to approach others, but I kept doing it, and... it's easier now."
      Speaker = "Melinoe"
      Event = "DoraAboutShades04"
    }
    {
      Id = "Dora_0197"
      InheritFrom = "BaseNarrative"
      DisplayName = "Easier, but... never {#Emph}easy{#Prev}, right? {#Emph}Ehh{#Prev}, don't know why I bother... most of these Shades are pretty boring."
      Speaker = "Dora"
      Event = "DoraAboutShades04"
    }
    {
      Id = "Melinoe_2036"
      InheritFrom = "BaseSubtitle"
      DisplayName = "They haven't met {#Emph}you {#Prev}yet!"
      Speaker = "Melinoe"
      Event = "DoraAboutShades04"
    }
    {
      Id = "Dora_0196"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Um{#Prev}, way to make me feel incredibly self-conscious, thanks, Mel! But, yeah I'm, I'm trying to put myself out there a bit more, I guess...! Now that you've saddled me with my big important task."
      Speaker = "Dora"
      Event = "DoraAboutShades04_B"
    }
    {
      Id = "Melinoe_2032"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's been nice to see you out and about a little more often lately, not just cooped up in here. How are you managing? "
      Speaker = "Melinoe"
      Event = "DoraAboutOutside01"
    }
    {
      Id = "Dora_0174"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Eh{#Prev}, I'm managing. Those other Shades don't know the first thing about haunting, and it turns out they've got the dirt on {#Emph}everybody {#Prev}here... including {#Emph}you."
      Speaker = "Dora"
      Event = "DoraAboutOutside01"
    }
    {
      Id = "Melinoe_2033"
      InheritFrom = "BaseNarrative"
      DisplayName = "Comforting to know the brunt of our resistance is enjoying themselves a good bit of gossip."
      Speaker = "Melinoe"
      Event = "DoraAboutOutside01"
    }
    {
      Id = "Dora_0175"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ohh {#Prev}yeah."
      Speaker = "Dora"
      Event = "DoraAboutOutside01"
    }
    {
      Id = "Melinoe_0431"
      InheritFrom = "BaseNarrative"
      DisplayName = "You must remember something of life on the surface, right, Dora? Anything at all? I wonder what it must have been like."
      Speaker = "Melinoe"
      Event = "DoraAboutSurface01"
    }
    {
      Id = "Dora_0060"
      InheritFrom = "BaseNarrative"
      DisplayName = "I {#Emph}don't {#Prev}remember, and I {#Emph}don't {#Prev}wonder! Who cares? {#Emph}This {#Prev}is the life, right here."
      Speaker = "Dora"
      Event = "DoraAboutSurface01"
    }
    {
      Id = "Dora_0342"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, you were talking in your sleep a little bit. Not that I paid too close attention, but... where were you last night, anyway? You seem a little off."
      Speaker = "Dora"
      Event = "DoraAboutSurface02"
    }
    {
      Id = "Melinoe_3724"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, just... I was up there, on the surface. I never thought I'd see it for myself, and now I'm there night after night. It's cold, damp... overrun with the dead."
      Speaker = "Melinoe"
      Event = "DoraAboutSurface02"
    }
    {
      Id = "Dora_0343"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're really selling me on the whole thing. If it's that bad, how come you keep on going over there? I'd just stay here if I were you... or me."
      Speaker = "Dora"
      Event = "DoraAboutSurface02"
    }
    {
      Id = "Melinoe_3725"
      InheritFrom = "BaseNarrative"
      DisplayName = "You don't understand. I have to go that way. It's part of my task. Well, not officially, but... look I won't bore you with the details. I should go."
      Speaker = "Melinoe"
      Event = "DoraAboutSurface02"
    }
    {
      Id = "Dora_0344"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Have fun being all cold and damp."
      Speaker = "Dora"
      Event = "DoraAboutSurface02"
    }
    {
      Id = "Dora_0155"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, you're up. You were out a while. See anything good down there that time?"
      Speaker = "Dora"
      Event = "DoraAboutOceanus01"
    }
    {
      Id = "Melinoe_0437"
      InheritFrom = "BaseNarrative"
      DisplayName = "I fought past Erebus, down into Oceanus. It was so strange, being underneath the sea. Do you remember the sea, Dora?"
      Speaker = "Melinoe"
      Event = "DoraAboutOceanus01"
    }
    {
      Id = "Dora_0156"
      InheritFrom = "BaseNarrative"
      DisplayName = "The sea... the sea, the sea, the sea, {#Emph}that's {#Prev}the thing with all the {#Emph}water {#Prev}in it, {#Emph}right? {#Prev}Heard it's nice {#Emph}sometimes! {#Prev}Also {#Emph}kills {#Prev}a bunch of people, death by drowning, so — I've been getting mixed messages, I guess."
      Speaker = "Dora"
      Event = "DoraAboutOceanus01"
    }
    {
      Id = "Melinoe_0438"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It's a big place..."
      Speaker = "Melinoe"
      Event = "DoraAboutOceanus01"
    }
    {
      Id = "Dora_0295"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oof{#Prev}, you look rough, if we're being honest, Mel. Want to talk about it, or at least tell me the juicy bits because I'm bored?"
      Speaker = "Dora"
      Event = "DoraAboutFields01"
    }
    {
      Id = "Melinoe_3380"
      InheritFrom = "BaseNarrative"
      DisplayName = "Last night I visited the Mourning Fields, and... being surrounded by that much despair... I think I must have brought some of it home."
      Speaker = "Melinoe"
      Event = "DoraAboutFields01"
    }
    {
      Id = "Dora_0296"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well why don't I just {#Emph}scare it out of you, you wretched worm?"
      Speaker = "Dora"
      Event = "DoraAboutFields01"
    }
    {
      Id = "Melinoe_3381"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hey, that worked!"
      Speaker = "Melinoe"
      Event = "DoraAboutFields01"
    }
    {
      Id = "Dora_0297"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I know, right?"
      Speaker = "Dora"
      Event = "DoraAboutFields01"
    }
    {
      Id = "Dora_0298"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey where've you been? You {#Emph}smell! {#Prev}Not in a bad way necessarily, and I don't know how I {#Emph}can {#Prev}smell, or remember any smell, so... that is weird."
      Speaker = "Dora"
      Event = "DoraAboutThessaly01"
    }
    {
      Id = "Melinoe_3382"
      InheritFrom = "BaseNarrative"
      DisplayName = "I was up top. Must be the sea air and the salt, distinct from Oceanus down below. I sailed across the waters, toward Olympus, on a ship! "
      Speaker = "Melinoe"
      Event = "DoraAboutThessaly01"
    }
    {
      Id = "Dora_0299"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Exciting! I was right here the whole time."
      Speaker = "Dora"
      Event = "DoraAboutThessaly01"
    }
    {
      Id = "Dora_0317"
      InheritFrom = "BaseNarrative"
      DisplayName = "I try {#Emph}not {#Prev}to listen to what the Shades out there are warbling about, but they make it sound like lately you've been through some pretty hairy times?"
      Speaker = "Dora"
      Event = "DoraAboutOlympus01"
    }
    {
      Id = "Melinoe_3703"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's hard to know exactly what they're referring to, but... I've managed to reach Mount Olympus, for one thing. Never thought I'd see it. The fighting there is very fierce..."
      Speaker = "Melinoe"
      Event = "DoraAboutOlympus01"
    }
    {
      Id = "Dora_0318"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Olympus... {#Prev}where the other members of your family have all been hanging out! What are they fighting over now?"
      Speaker = "Dora"
      Event = "DoraAboutOlympus01"
    }
    {
      Id = "Melinoe_3704"
      InheritFrom = "BaseNarrative"
      DisplayName = "Their reign over the heavens and the Earth, and the continued existence of their home."
      Speaker = "Melinoe"
      Event = "DoraAboutOlympus01"
    }
    {
      Id = "Dora_0319"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh! That's nothing new."
      Speaker = "Dora"
      Event = "DoraAboutOlympus01"
    }
    {
      Id = "Dora_0496"
      InheritFrom = "BaseNarrative"
      DisplayName = "So, how's it going on Olympus recently? Or wherever you were last night. See anything good up there besides the snow? Not sure how come I know about snow..."
      Speaker = "Dora"
      Event = "DoraAboutTyphon01"
    }
    {
      Id = "Melinoe_4419"
      InheritFrom = "BaseNarrative"
      DisplayName = "I made it all the way to the summit, where I confronted the ancient monster called {#Emph}Typhon. {#Prev}It's said that all other monsters can be traced directly to him... but, he's by far the biggest and the worst I've ever seen."
      Speaker = "Melinoe"
      Event = "DoraAboutTyphon01"
    }
    {
      Id = "Dora_0497"
      InheritFrom = "BaseNarrative"
      DisplayName = "Mel, {#Emph}I'm {#Prev}the one who's supposed to scare {#Emph}you{#Prev}, not the other way around. So, did you beat this guy, or what?"
      Speaker = "Dora"
      Event = "DoraAboutTyphon01"
    }
    {
      Id = "Melinoe_4421"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Erm... {#Prev}not quite. But I intend to."
      Speaker = "Melinoe"
      Event = "DoraAboutTyphon01"
    }
    {
      Id = "Dora_0499"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well let me know if I can help!"
      Speaker = "Dora"
      Event = "DoraAboutTyphon01"
    }
    {
      Id = "Melinoe_4420"
      InheritFrom = "BaseSubtitle"
      DisplayName = "As a matter of fact, I did!"
      Speaker = "Melinoe"
      Event = "DoraAboutTyphon01_B"
    }
    {
      Id = "Dora_0498"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well then he's not so scary after all."
      Speaker = "Dora"
      Event = "DoraAboutTyphon01_B"
    }
    {
      Id = "Dora_0035"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Gah! A scourge upon your bloodline for re-summoning me, witch! {#Prev}Hey, {#Emph}uh, {#Prev}everything OK, there, Mel?"
      Speaker = "Dora"
      Event = "DoraRunProgress01"
    }
    {
      Id = "Melinoe_0407"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, yes Dora, it's just... I should have gone farther that time. I'll give more notes on your haunting later, all right?"
      Speaker = "Melinoe"
      Event = "DoraRunProgress01"
    }
    {
      Id = "Dora_0036"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh. Sure..."
      Speaker = "Dora"
      Event = "DoraRunProgress01"
    }
    {
      Id = "Melinoe_0416"
      InheritFrom = "BaseNarrative"
      DisplayName = "Dora, don't you pay any attention to what's been happening out there? The rise of the Titan of Time? The siege of Olympus?"
      Speaker = "Melinoe"
      Event = "DoraAboutChronos01"
    }
    {
      Id = "Dora_0057"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nope. Can't say any of that rings a bell. Olympus, that's where the family members you {#Emph}don't {#Prev}like live, right? And the Titan of Time, I {#Emph}get {#Prev}that he's bad, but he's never done anything to me personally, as far as I know, so..."
      Speaker = "Dora"
      Event = "DoraAboutChronos01"
    }
    {
      Id = "Melinoe_0417"
      InheritFrom = "BaseNarrative"
      DisplayName = "This entire encampment exists to resist his efforts to overthrow the gods and rule the world?"
      Speaker = "Melinoe"
      Event = "DoraAboutChronos01"
    }
    {
      Id = "Dora_0058"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well then! Maybe I should thank him because I happen to like this encampment."
      Speaker = "Dora"
      Event = "DoraAboutChronos01"
    }
    {
      Id = "Melinoe_0418"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh shush!"
      Speaker = "Melinoe"
      Event = "DoraAboutChronos01"
    }
    {
      Id = "Dora_0292"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Whoa{#Prev}, hold on, what's going on with you? Never seen you so excited in my life. Death. Whatever. What, did you discover a new species of root vegetable or something?"
      Speaker = "Dora"
      Event = "DoraAboutChronosBossW01"
    }
    {
      Id = "Melinoe_3378"
      InheritFrom = "BaseNarrative"
      DisplayName = "Dora, I found him... Chronos... and I {#Emph}beat {#Prev}him! Withstood every trick he had, until he yielded and expired."
      Speaker = "Melinoe"
      Event = "DoraAboutChronosBossW01"
    }
    {
      Id = "Dora_0293"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, {#Emph}nice! {#Prev}So then it's {#Emph}over{#Prev}, right? Or what...?"
      Speaker = "Dora"
      Event = "DoraAboutChronosBossW01"
    }
    {
      Id = "Melinoe_3379"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, no, he isn't {#Emph}dead... {#Prev}I mean, he isn't {#Emph}gone{#Prev}. Not yet. I have to go... all right?"
      Speaker = "Melinoe"
      Event = "DoraAboutChronosBossW01"
    }
    {
      Id = "Dora_0294"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yeah. All good."
      Speaker = "Dora"
      Event = "DoraAboutChronosBossW01"
    }
    {
      Id = "Dora_0340"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}You think that you achieved a victory, witch? You merely prolonged your demise. For the Titan whom you vanquished possesses but the smallest fraction of my power!"
      Speaker = "Dora"
      Event = "DoraAboutChronosBossW02"
    }
    {
      Id = "Melinoe_3722"
      InheritFrom = "BaseNarrative"
      DisplayName = "So you heard! I'm surprised and humbled that you deigned to pay my meager accomplishments any heed, O Spirit. How did you know?"
      Speaker = "Melinoe"
      Event = "DoraAboutChronosBossW02"
    }
    {
      Id = "Dora_0341"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}I am all-knowing! {#Prev}Also the Shades out there were going off about it. Some of them are right outside the tent, told 'em can't come in, but they're still out there I think..."
      Speaker = "Dora"
      Event = "DoraAboutChronosBossW02"
    }
    {
      Id = "Melinoe_3723"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thank you for keeping them at bay."
      Speaker = "Melinoe"
      Event = "DoraAboutChronosBossW02"
    }
    {
      Id = "Dora_0320"
      InheritFrom = "BaseNarrative"
      DisplayName = "So hold on, how is it you're going after the Titan of Time way down below, but he's also attacking Olympus way up top? Is he two separate guys or just the one?"
      Speaker = "Dora"
      Event = "DoraAboutPrometheus01"
    }
    {
      Id = "Melinoe_3705"
      InheritFrom = "BaseNarrative"
      DisplayName = "Chronos isn't attacking Olympus personally, Dora. He's just sending his legions there. He has a dangerous commander leading the assault... a different Titan called Prometheus."
      Speaker = "Melinoe"
      Event = "DoraAboutPrometheus01"
    }
    {
      Id = "Dora_0321"
      InheritFrom = "BaseNarrative"
      DisplayName = "A different Titan called... Prometheus...? {#Emph}Prometheus... {#Prev}huh..."
      Speaker = "Dora"
      Event = "DoraAboutPrometheus01"
    }
    {
      Id = "Melinoe_3706"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes, the Titan of Foresight. Even you probably know the tale of his punishment for stealing from the gods."
      Speaker = "Melinoe"
      Event = "DoraAboutPrometheus01"
    }
    {
      Id = "Dora_0322"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, it's... I think... {#Emph}ah{#Prev}, don't worry about it. See you later Mel!"
      Speaker = "Dora"
      Event = "DoraAboutPrometheus01"
    }
    {
      Id = "Melinoe_3707"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You sure...?"
      Speaker = "Melinoe"
      Event = "DoraAboutPrometheus01"
    }
    {
      Id = "Dora_0323"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Prometheus... hrm..."
      Speaker = "Dora"
      Event = "DoraAboutPrometheus01"
    }
    {
      Id = "Melinoe_5192"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well it's not really him I'm going after anymore. But in any case, Chronos appointed someone else to lead the assault on Olympus... a different Titan called Prometheus."
      Speaker = "Melinoe"
      Event = "DoraAboutPrometheus01_B"
    }
    {
      Id = "Dora_0324"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Prometheus... Titan of... Foresight...? {#Emph}Tsk... yeah..."
      Speaker = "Dora"
      Event = "OnQueuedFunctionArgs.VoiceLines"
    }
    {
      Id = "Melinoe_3708"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey is everything all right with you, Dora? I didn't mean to upset you with talks of Titans when last we spoke."
      Speaker = "Melinoe"
      Event = "DoraAboutPrometheus02"
    }
    {
      Id = "Dora_0325"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ahh {#Prev}I'm good, Mel. I don't get mad much anymore really, and don't get weirded out either, it's just... something about the name {#Emph}Prometheus? {#Prev}It's like... it meant something to me...?"
      Speaker = "Dora"
      Event = "DoraAboutPrometheus02"
    }
    {
      Id = "Melinoe_3709"
      InheritFrom = "BaseNarrative"
      DisplayName = "But, Prometheus was imprisoned for aeons prior to this point. If you remember him... it's from a while back."
      Speaker = "Melinoe"
      Event = "DoraAboutPrometheus02"
    }
    {
      Id = "Dora_0326"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd be ancient history! But, I hardly remember yesterday, don't know how come I'd remember something from that long ago. Not that I {#Emph}do {#Prev}remember anything from then... except..."
      Speaker = "Dora"
      Event = "DoraAboutPrometheus02"
    }
    {
      Id = "Melinoe_3710"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Except what?"
      Speaker = "Melinoe"
      Event = "DoraAboutPrometheus02"
    }
    {
      Id = "Dora_0327"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ah{#Prev}, just a feeling... but, it isn't great."
      Speaker = "Dora"
      Event = "DoraAboutPrometheus02"
    }
    {
      Id = "Melinoe_3711"
      InheritFrom = "BaseNarrative"
      DisplayName = "Dora, I hope you don't mind, but I asked Prometheus himself about this old connection that you feel. He's cagey with his words, but does seem to remember you, in turn."
      Speaker = "Melinoe"
      Event = "DoraAboutPrometheus03"
    }
    {
      Id = "Dora_0328"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh! {#Prev}Kind of weird of you to do that especially since it sounds like he's trying to kill your family up there, but thanks! What'd he say?"
      Speaker = "Dora"
      Event = "DoraAboutPrometheus03"
    }
    {
      Id = "Melinoe_3712"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, he said... he's not to blame for mortalkind's failings and such, and that... neither are you. And asked I tell you so, on his behalf. Before attacking me per usual, of course."
      Speaker = "Melinoe"
      Event = "DoraAboutPrometheus03"
    }
    {
      Id = "Dora_0329"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Whew, that's {#Prev}a relief! All this time, I figured if there's any two individuals responsible for all the badness mortals have to deal with, it's {#Emph}Prometheus and me! {#Prev}We're talking stomach aches, heartaches, taxation, lying, cheating... you name it."
      Speaker = "Dora"
      Event = "DoraAboutPrometheus03"
    }
    {
      Id = "Melinoe_3713"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's utter nonsense, but... do you have any idea what he could have meant?"
      Speaker = "Melinoe"
      Event = "DoraAboutPrometheus03"
    }
    {
      Id = "Dora_0330"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nope! But since you're the one who's talking to him on the regular, maybe you could ask. Now that we're curious."
      Speaker = "Dora"
      Event = "DoraAboutPrometheus03"
    }
    {
      Id = "Melinoe_3714"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...We'll figure this out."
      Speaker = "Melinoe"
      Event = "DoraAboutPrometheus03"
    }
    {
      Id = "Melinoe_3715"
      InheritFrom = "BaseNarrative"
      DisplayName = "Prometheus refuses to elaborate about your past with him, Dora. But he believes you're going to remember soon enough. My worry is... you're better off not knowing."
      Speaker = "Melinoe"
      Event = "DoraAboutPrometheus04"
    }
    {
      Id = "Dora_0331"
      InheritFrom = "BaseNarrative"
      DisplayName = "And, what makes you say that? Besides the part where I've already told you I get a not-great feeling just from sounding out his name? {#Emph}Prometheus... eugh{#Prev}, yeah! There it is!"
      Speaker = "Dora"
      Event = "DoraAboutPrometheus04"
    }
    {
      Id = "Melinoe_3716"
      InheritFrom = "BaseNarrative"
      DisplayName = "He gave me the impression you forgot about him, and much more, by choice. If that's true, perhaps it's for the best. If only for the sake of your past self."
      Speaker = "Melinoe"
      Event = "DoraAboutPrometheus04"
    }
    {
      Id = "Dora_0332"
      InheritFrom = "BaseNarrative"
      DisplayName = "Forget my {#Emph}past {#Prev}self, Mel, my {#Emph}current {#Prev}self is pretty caught up now in getting to the bottom of all this! Isn't there some sort of {#Emph}witch-spell {#Prev}you could do to jog my memory, or something?"
      Speaker = "Dora"
      Event = "DoraAboutPrometheus04"
    }
    {
      Id = "Melinoe_3717"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well... now that I know of this specific connection you seem to have, it's something to work with. But, are you absolutely sure it's what you want?"
      Speaker = "Melinoe"
      Event = "DoraAboutPrometheus04"
    }
    {
      Id = "Dora_0333"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh yeah! It's gonna be something {#Emph}good..."
      Speaker = "Dora"
      Event = "DoraAboutPrometheus04"
    }
    {
      Id = "Melinoe_2093"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll take your word for it..."
      Speaker = "Melinoe"
      Event = "DoraAboutPrometheus04"
    }
    {
      Id = "Dora_0334"
      InheritFrom = "BaseNarrative"
      DisplayName = "Any luck making some magick that'll jog my memory, or what? No pressure, I can wait, but... thought I'd ask!"
      Speaker = "Dora"
      Event = "DoraAboutMemorySpell01"
    }
    {
      Id = "Melinoe_3718"
      InheritFrom = "BaseNarrative"
      DisplayName = "Incantations involving memory and the past require great care, so it's not something we are going to rush into. And if you have any second thoughts, you tell me right away."
      Speaker = "Melinoe"
      Event = "DoraAboutMemorySpell01"
    }
    {
      Id = "Dora_0335"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Don't worry so much, Mel!"
      Speaker = "Dora"
      Event = "DoraAboutMemorySpell01"
    }
    {
      Id = "Melinoe_4830"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Dora..."
      Speaker = "Melinoe"
      Event = "OnQueuedFunctionArgs.VoiceLines"
    }
    {
      Id = "Dora_0577"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I remember everything... about why I {#Emph}forgot {#Prev}everything... {#Emph}I {#Prev}did something pretty bad, Mel."
      Speaker = "Dora"
      Event = "DoraAboutMemories01"
    }
    {
      Id = "Melinoe_4654"
      InheritFrom = "BaseNarrative"
      DisplayName = "Whatever it was, you don't have to tell me, unless of course you wish to in which case I'm listening."
      Speaker = "Melinoe"
      Event = "DoraAboutMemories01"
    }
    {
      Id = "Dora_0578"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Yeah, the thing is I just kind of ruined everything, for everyone. For everyone who's mortal anyway."
      Speaker = "Dora"
      Event = "DoraAboutMemories01"
    }
    {
      Id = "Melinoe_4655"
      InheritFrom = "BaseNarrative"
      DisplayName = "What are you talking about? That couldn't possibly be true!"
      Speaker = "Melinoe"
      Event = "DoraAboutMemories01"
    }
    {
      Id = "Dora_0579"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, imagine there was once this big storage jar, right? Like you'd keep pickles in, except the gods loaded it full of everything that could possibly go wrong. Hate, heartbreak, hair loss, halitosis... you name it."
      Speaker = "Dora"
      Event = "DoraAboutMemories01"
    }
    {
      Id = "Melinoe_4656"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm not following. Why would all mortal vices and failings be placed within this particular jar? It sounds like you may be thinking of some sort of figurative representation."
      Speaker = "Melinoe"
      Event = "DoraAboutMemories01"
    }
    {
      Id = "Dora_0580"
      InheritFrom = "BaseNarrative"
      DisplayName = "No it was a real jar with all that stuff, and I... well, I'm still shaky on the details. Let's chat about it more some other time, I'm beat."
      Speaker = "Dora"
      Event = "DoraAboutMemories01"
    }
    {
      Id = "Melinoe_4657"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Whatever you like..."
      Speaker = "Melinoe"
      Event = "DoraAboutMemories01"
    }
    {
      Id = "Dora_0581"
      InheritFrom = "BaseNarrative"
      DisplayName = "...That jar I mentioned, filled with all the {#Emph}bad {#Prev}stuff? {#Emph}I {#Prev}opened it. Wanted to know what was inside! And it went {#Emph}whoosh... {#Prev}I let {#Emph}just {#Prev}about everything out, into the world. Into our lives."
      Speaker = "Dora"
      Event = "DoraAboutMemories02"
    }
    {
      Id = "Melinoe_4658"
      InheritFrom = "BaseNarrative"
      DisplayName = "What? Why would you have done a thing like that? How did you even come across this jar?"
      Speaker = "Melinoe"
      Event = "DoraAboutMemories02"
    }
    {
      Id = "Dora_0582"
      InheritFrom = "BaseNarrative"
      DisplayName = "It was a wedding gift, from the Olympians. Prometheus, whom I remember now, {#Emph}interesting {#Prev}guy, he had a hunky brother and we sort of hit it off..."
      Speaker = "Dora"
      Event = "DoraAboutMemories02"
    }
    {
      Id = "Melinoe_4659"
      InheritFrom = "BaseNarrative"
      DisplayName = "So the gods wanted you to have a jar full of terrible things. That seems an odd sort of present to give to... who even {#Emph}were {#Prev}you?"
      Speaker = "Melinoe"
      Event = "DoraAboutMemories02"
    }
    {
      Id = "Dora_0583"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Eh{#Prev}, just some woman! But there weren't too many of us then, and I don't think the gods {#Emph}liked {#Prev}Prometheus much? So anyway the next time any mortal stubs their toe, pays taxes, gets the sweats, anything like that... it's on me."
      Speaker = "Dora"
      Event = "DoraAboutMemories02"
    }
    {
      Id = "Melinoe_4660"
      InheritFrom = "BaseNarrative"
      DisplayName = "Even if what you say is true, you make it sound as though you'd no intention to do it. So it's not your fault."
      Speaker = "Melinoe"
      Event = "DoraAboutMemories02"
    }
    {
      Id = "Dora_0584"
      InheritFrom = "BaseNarrative"
      DisplayName = "The thing is I {#Emph}did {#Prev}do it, so it {#Emph}is {#Prev}my fault... I'm gonna go."
      Speaker = "Dora"
      Event = "DoraAboutMemories02"
    }
    {
      Id = "Melinoe_4661_B"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Dora...!"
      Speaker = "Melinoe"
      Event = "DoraAboutMemories02"
    }
    {
      Id = "Dora_0585"
      InheritFrom = "BaseNarrative"
      DisplayName = "...So, yeah, I guess I cursed all mortalkind a while back. So what if I {#Emph}didn't mean it? {#Prev}Intent doesn't matter."
      Speaker = "Dora"
      Event = "DoraAboutMemories03"
    }
    {
      Id = "Melinoe_4662"
      InheritFrom = "BaseNarrative"
      DisplayName = "Intent absolutely matters. So then you drank from the River Lethe to rid yourself of the memory of what transpired, to try and rid yourself of the guilt?"
      Speaker = "Melinoe"
      Event = "DoraAboutMemories03"
    }
    {
      Id = "Dora_0586"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Pretty much. But you want to know the one thing I didn't let out of the jar? It was Hope. I was scrambling, and locked it in. The one thing I {#Emph}should {#Prev}have set loose, I didn't."
      Speaker = "Dora"
      Event = "DoraAboutMemories03"
    }
    {
      Id = "Melinoe_4663"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm not so certain. We experience Hope all the time, gods and mortals alike. If you had set it loose... perhaps it would have been smothered by all the other forces, and then what?"
      Speaker = "Melinoe"
      Event = "DoraAboutMemories03"
    }
    {
      Id = "Dora_0587"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then mortals wouldn't be quite so delusional maybe? Anyway... I think I want to be alone now for a bit. Thanks for talking through it with me, Mel. And making me remember."
      Speaker = "Dora"
      Event = "DoraAboutMemories03"
    }
    {
      Id = "Melinoe_4664"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Are you going to be all right?"
      Speaker = "Melinoe"
      Event = "DoraAboutMemories03"
    }
    {
      Id = "Dora_0588"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yeah... probably."
      Speaker = "Dora"
      Event = "DoraAboutMemories03"
    }
    {
      Id = "Melinoe_4665"
      InheritFrom = "BaseNarrative"
      DisplayName = "Dora, I just can't believe the gods set you up to curse all mortalkind... is there any possibility your memory's at fault?"
      Speaker = "Melinoe"
      Event = "DoraAboutMemories04"
    }
    {
      Id = "Dora_0589"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I guess? But I remember pretty clearly now, even if it was a long while ago. Though the other thing is, don't all you gods go through most of this stuff yourselves? I mean, you don't die like mortals, but... you get the other bad things..."
      Speaker = "Dora"
      Event = "DoraAboutMemories04"
    }
    {
      Id = "Melinoe_4666"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, certainly not all of it, but most. So then... perhaps this jar was merely some means of bringing mortals and gods closer together...? To reality, such as we know it."
      Speaker = "Melinoe"
      Event = "DoraAboutMemories04"
    }
    {
      Id = "Dora_0590"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sounds kind of like the Hope that I left in the jar talking, Mel. You don't think the gods were just... getting back at Prometheus, his brother, and his gorgeous wife?"
      Speaker = "Dora"
      Event = "DoraAboutMemories04"
    }
    {
      Id = "Melinoe_4667"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps, but... what would they possibly gain from doing such a monstrous thing?"
      Speaker = "Melinoe"
      Event = "DoraAboutMemories04"
    }
    {
      Id = "Dora_0591"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Gods can be jerks sometimes. Like mortals, but stronger."
      Speaker = "Dora"
      Event = "DoraAboutMemories04"
    }
    {
      Id = "Dora_0592"
      InheritFrom = "BaseNarrative"
      DisplayName = "You haven't told anyone about me and the {#Emph}jar{#Prev}, have you? I'd rather keep it between us. Glad I remember now, but... wouldn't want the attention from the details getting out..."
      Speaker = "Dora"
      Event = "DoraAboutMemories05"
    }
    {
      Id = "Melinoe_4668"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've spoken only to Prometheus of it, for he had knowledge of the circumstances from before. But I won't tell another soul."
      Speaker = "Melinoe"
      Event = "DoraAboutMemories05"
    }
    {
      Id = "Dora_0593"
      InheritFrom = "BaseNarrative"
      DisplayName = "Good. Maybe, eventually, I'll go tell everyone myself if I really want to mess with 'em? And even if not, this {#Emph}has {#Prev}given me a {#Emph}ton {#Prev}of new material for my hauntings! It's scary stuff."
      Speaker = "Dora"
      Event = "DoraAboutMemories05"
    }
    {
      Id = "Melinoe_4669"
      InheritFrom = "BaseNarrative"
      DisplayName = "Please don't make light of it, Dora. But confronting your past is better than erasing it, I think. For that, you're very brave."
      Speaker = "Melinoe"
      Event = "DoraAboutMemories05"
    }
    {
      Id = "Dora_0594"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}And you are very foolish! Leave me be."
      Speaker = "Dora"
      Event = "DoraAboutMemories05"
    }
    {
      Id = "Dora_0620"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, wanted to tell you, thanks for bringing back all of my terrible old memories I tried desperately to erase... I'm serious! I'd rather chew on 'em than spit 'em out."
      Speaker = "Dora"
      Event = "DoraAboutMemoryQuest01"
    }
    {
      Id = "Melinoe_4687"
      InheritFrom = "BaseNarrative"
      DisplayName = "As far as I'm concerned, that was your choice more so than mine. I wanted to support you as a friend. We both knew what you would discover had potential to be painful."
      Speaker = "Melinoe"
      Event = "DoraAboutMemoryQuest01"
    }
    {
      Id = "Dora_0621"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Eh{#Prev}, I don't know about {#Emph}painful. {#Prev}That's one of the good things about being a Shade! No more pain! Some rotten thoughts about the way things {#Emph}were{#Prev}, sure... maybe some of those."
      Speaker = "Dora"
      Event = "DoraAboutMemoryQuest01"
    }
    {
      Id = "Melinoe_4688"
      InheritFrom = "BaseNarrative"
      DisplayName = "I do count that as pain. It's not the same as being struck full-force by Nemesis, but it can hurt more deeply, and the healing process can take longer, by a lot. Though, do you remember more than just the painful memories, at least?"
      Speaker = "Melinoe"
      Event = "DoraAboutMemoryQuest01"
    }
    {
      Id = "Dora_0622"
      InheritFrom = "BaseNarrative"
      DisplayName = "I guess so, but the other stuff's just not as interesting, you know? Anyway it's all just history. This is me now."
      Speaker = "Dora"
      Event = "DoraAboutMemoryQuest01"
    }
    {
      Id = "Melinoe_4689"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm glad."
      Speaker = "Melinoe"
      Event = "DoraAboutMemoryQuest01"
    }
    {
      Id = "Dora_0287"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, what happened, you look weird or something, I don't know. Weren't out too long. Took someone to the woods...?"
      Speaker = "Dora"
      Event = "DoraAboutPackagedBounties01"
    }
    {
      Id = "Melinoe_3373"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, Dora, though I don't think I can sufficiently explain. You know the Pitch-Black Stone? Turns out it can... do things."
      Speaker = "Melinoe"
      Event = "DoraAboutPackagedBounties01"
    }
    {
      Id = "Dora_0288"
      InheritFrom = "BaseNarrative"
      DisplayName = "The purple rock can {#Emph}do things{#Prev}, you say. Know what? I don't even {#Emph}want {#Prev}to know the rest, just gonna let my imagination take over for you, thanks."
      Speaker = "Dora"
      Event = "DoraAboutPackagedBounties01"
    }
    {
      Id = "Melinoe_3374"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Anytime?"
      Speaker = "Melinoe"
      Event = "DoraAboutPackagedBounties01"
    }
    {
      Id = "Dora_0289"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've been staring at that picture more and more. {#Emph}Happy family! {#Prev}Well it's starting to get to me, because I think it's starting to get to {#Emph}you. {#Prev}Don't get all misty on me, Mel."
      Speaker = "Dora"
      Event = "DoraAboutPainting01"
    }
    {
      Id = "Melinoe_3376"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thank you, Dora. Though you needn't worry. I won't get lost in memories because there isn't much for me to remember. I just wonder what my brother and my birthparents were like."
      Speaker = "Melinoe"
      Event = "DoraAboutPainting01"
    }
    {
      Id = "Dora_0290"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Uh-huh! {#Prev}Sounds awful lot like dwelling on the past to me. Nothing you could have done! Hey... you could be doing nothing right {#Emph}now."
      Speaker = "Dora"
      Event = "DoraAboutPainting01"
    }
    {
      Id = "Melinoe_3377"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll give it some thought."
      Speaker = "Melinoe"
      Event = "DoraAboutPainting01"
    }
    {
      Id = "Dora_0291"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Or don't!"
      Speaker = "Dora"
      Event = "DoraAboutPainting01"
    }
    {
      Id = "Dora_0039"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ahh {#Prev}hey Mel, I was just... floating! Floating around, I guess. And existing! Just kind of existing a lot lately. You?"
      Speaker = "Dora"
      Event = "DoraAboutExisting01"
    }
    {
      Id = "Melinoe_0409"
      InheritFrom = "BaseNarrative"
      DisplayName = "Failing. Making progress, I don't know. Speaking of, shouldn't you be practicing your haunting, Dora?"
      Speaker = "Melinoe"
      Event = "DoraAboutExisting01"
    }
    {
      Id = "Dora_0040"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh! Yeah, no, I thought maybe I'd take a break from that. Why do now what you could do later, right?"
      Speaker = "Dora"
      Event = "DoraAboutExisting01"
    }
    {
      Id = "Melinoe_0410"
      InheritFrom = "BaseSubtitle"
      DisplayName = "For the sense of accomplishment?"
      Speaker = "Melinoe"
      Event = "DoraAboutExisting01"
    }
    {
      Id = "Dora_0041"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Pffsh!"
      Speaker = "Dora"
      Event = "DoraAboutExisting01"
    }
    {
      Id = "Dora_0126"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hey..."
      Speaker = "Dora"
      Event = "OnQueuedFunctionArgs.VoiceLines"
    }
    {
      Id = "Dora_0046"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not going to lie, Mel, sometimes I wish {#Emph}I {#Prev}had a big important task. Not that floating isn't one."
      Speaker = "Dora"
      Event = "DoraListless01"
    }
    {
      Id = "Melinoe_0064"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know my stance on this, Dora. You need to get out of this tent. You're very talented! I've never met a Shade that speaks like you!"
      Speaker = "Melinoe"
      Event = "DoraListless01"
    }
    {
      Id = "Dora_0047"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ooh{#Prev}, I can talk, makes me {#Emph}so special. Tsch! {#Prev}I'm sure any lowly Shade could do it after being stuck here listening to {#Emph}you people {#Prev}long enough."
      Speaker = "Dora"
      Event = "DoraListless01"
    }
    {
      Id = "Melinoe_4272"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Or you could teach them?"
      Speaker = "Melinoe"
      Event = "DoraListless01"
    }
    {
      Id = "Dora_0495"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Nah!"
      Speaker = "Dora"
      Event = "DoraListless01"
    }
    {
      Id = "Dora_0532"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hey Mel."
      Speaker = "Dora"
      Event = "OnQueuedFunctionArgs.VoiceLines"
    }
    {
      Id = "Melinoe_0414"
      InheritFrom = "BaseNarrative"
      DisplayName = "Everything all right, Dora? Any new hauntings need evaluation or anything?"
      Speaker = "Melinoe"
      Event = "DoraListless02"
    }
    {
      Id = "Dora_0050"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Nah! {#Prev}I — I'm — I'm fine, it's just... think I've hit a bit of a slump is all. {#Emph}Happens{#Prev}, right? I'll get over it."
      Speaker = "Dora"
      Event = "DoraListless02"
    }
    {
      Id = "Melinoe_0415"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Good."
      Speaker = "Melinoe"
      Event = "DoraListless02"
    }
    {
      Id = "Dora_0048"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, if I were you I'd... well, come to think of it, I'd... I'd do a lot of things. Go for a jog! That seems nice. Having legs! Getting the heart rate going, a heart seems nice!"
      Speaker = "Dora"
      Event = "DoraListless03"
    }
    {
      Id = "Melinoe_0066"
      InheritFrom = "BaseNarrative"
      DisplayName = "Stop it, Dora. I don't like it when you get like this."
      Speaker = "Melinoe"
      Event = "DoraListless03"
    }
    {
      Id = "Dora_0049"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Make something with my hands! I don't know, a cup? A bowl. I'd eat! Eating seems {#Emph}nice. {#Prev}Or even just remembering what that was like..."
      Speaker = "Dora"
      Event = "DoraListless03"
    }
    {
      Id = "Melinoe_0067"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Take care, Dora..."
      Speaker = "Melinoe"
      Event = "DoraListless03"
    }
    {
      Id = "Dora_0037"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ever think maybe we're just not cut out for this, Mel? Me with the haunting, you with the... what're you trying to do, again?"
      Speaker = "Dora"
      Event = "DoraAboutTask01"
    }
    {
      Id = "Melinoe_0408"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Find the Titan of Time. Punish him for his crimes against my family. Restore the rightful ruler of the Underworld.... {#Prev}Hey, you're cut out for haunting, Dora!"
      Speaker = "Melinoe"
      Event = "DoraAboutTask01"
    }
    {
      Id = "Dora_0038"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Aw{#Prev}, thanks! Just like I'm sure you're cut out for all that other stuff."
      Speaker = "Dora"
      Event = "DoraAboutTask01"
    }
    {
      Id = "Dora_0312"
      InheritFrom = "BaseNarrative"
      DisplayName = "So what do you even do when you're out, collect more plants and stuff like that? You used to stay in all the time."
      Speaker = "Dora"
      Event = "DoraAboutTask02"
    }
    {
      Id = "Melinoe_3699"
      InheritFrom = "BaseNarrative"
      DisplayName = "Dora, I was training in secrecy all that time! While I'm out each night, mostly I have to fight my way to Chronos... past a variety of things that don't like having me around."
      Speaker = "Melinoe"
      Event = "DoraAboutTask02"
    }
    {
      Id = "Dora_0313"
      InheritFrom = "BaseNarrative"
      DisplayName = "Can't imagine why. And you just keep trying to do the same thing, huh. I would've given up so long ago! You should try it. Giving up."
      Speaker = "Dora"
      Event = "DoraAboutTask02"
    }
    {
      Id = "Melinoe_3700"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No thank you."
      Speaker = "Melinoe"
      Event = "DoraAboutTask02"
    }
    {
      Id = "Melinoe_0411"
      InheritFrom = "BaseNarrative"
      DisplayName = "What would you do if you had the tent all to yourself anyway, Dora? You could invite all the other Shades and absolutely trash the place, I suppose..."
      Speaker = "Melinoe"
      Event = "DoraAboutHaunting01"
    }
    {
      Id = "Dora_0042"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wh, what, you mean {#Emph}share {#Prev}it? Mel, {#Emph}not sharing {#Prev}the tent is the entire point, a proper haunting has a one-to-one ratio between the haun{#Emph}ted {#Prev}and the haun{#Emph}tee{#Prev}. Even {#Emph}I {#Prev}haven't forgotten the basics."
      Speaker = "Dora"
      Event = "DoraAboutHaunting01"
    }
    {
      Id = "Melinoe_0412"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can't imagine all you want to do is float around in here, minus the part where we get to speak."
      Speaker = "Melinoe"
      Event = "DoraAboutHaunting01"
    }
    {
      Id = "Dora_0043"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then you simply lack imagination, friend!"
      Speaker = "Dora"
      Event = "DoraAboutHaunting01"
    }
    {
      Id = "Melinoe_0413"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Heh."
      Speaker = "Melinoe"
      Event = "DoraAboutHaunting01"
    }
    {
      Id = "Dora_0187"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Everlasting pain and suffering upon you, witch! You trespass on my hallowed ground. Your cries for mercy shall drown in your throat!"
      Speaker = "Dora"
      Event = "DoraAboutHaunting02"
    }
    {
      Id = "Melinoe_2019"
      InheritFrom = "BaseNarrative"
      DisplayName = "Please! Forgive my careless indiscretion, madam-spirit, I beg of you! I intended no offense..."
      Speaker = "Melinoe"
      Event = "DoraAboutHaunting02"
    }
    {
      Id = "Dora_0188"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ho-hoh, wow! {#Prev}You're really into this stuff, huh?"
      Speaker = "Dora"
      Event = "DoraAboutHaunting02"
    }
    {
      Id = "Melinoe_2020"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, come on!"
      Speaker = "Melinoe"
      Event = "DoraAboutHaunting02"
    }
    {
      Id = "Dora_0314"
      InheritFrom = "BaseNarrative"
      DisplayName = "What would you say is the most frightening thing you've encountered out there lately, Mel? It's important for someone in my position to keep up with the latest on this front."
      Speaker = "Dora"
      Event = "DoraAboutHaunting03"
    }
    {
      Id = "Melinoe_3701"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well... I'd have to go with the raging infernal beast guarding the only viable way into Tartarus. Absolutely massive, countless sharp fangs, three fire-spitting maws... though he's also my family's dog."
      Speaker = "Melinoe"
      Event = "DoraAboutHaunting03"
    }
    {
      Id = "Dora_0315"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ahh{#Prev}, you had me going! Well if you're telling me there's nothing scarier out there than a pet dog... it means I've got no competition! Time to rest on these laurels some more."
      Speaker = "Dora"
      Event = "DoraAboutHaunting03"
    }
    {
      Id = "Melinoe_3702"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Please make yourself comfortable."
      Speaker = "Melinoe"
      Event = "DoraAboutHaunting03"
    }
    {
      Id = "Dora_0316"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}All that you see is my domain."
      Speaker = "Dora"
      Event = "DoraAboutHaunting03"
    }
    {
      Id = "Dora_0336"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}You, who ventured into my abode, shall suffer an eternity of torment for what you have done! Unless, of course, you are prepared to grant my dying wish..."
      Speaker = "Dora"
      Event = "DoraAboutHaunting04"
    }
    {
      Id = "Melinoe_3719"
      InheritFrom = "BaseNarrative"
      DisplayName = "Forgive my insolence, Spirit, and name your price! I am prepared to do your bidding! Within reason, anyway."
      Speaker = "Melinoe"
      Event = "DoraAboutHaunting04"
    }
    {
      Id = "Dora_0337"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Then swear to me that you shall do my bidding, now! Specifically... {#Prev}I haven't worked out the dying-wish part yet. Ask you to fetch my lover's bones, something like that?"
      Speaker = "Dora"
      Event = "DoraAboutHaunting04"
    }
    {
      Id = "Melinoe_3720"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just keep me posted."
      Speaker = "Melinoe"
      Event = "DoraAboutHaunting04"
    }
    {
      Id = "Dora_0338"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Stand forth, witch! Beyond these thrice-cursed grounds lies only death. Are you prepared to relinquish your own life's blood for that which you seek? Or shall you turn back?"
      Speaker = "Dora"
      Event = "DoraAboutHaunting05"
    }
    {
      Id = "Melinoe_3721"
      InheritFrom = "BaseNarrative"
      DisplayName = "If I turn back, it's basically a dead end, Spirit. Sounds like I face a dead end either way! I have to check with some of the others, so..."
      Speaker = "Melinoe"
      Event = "DoraAboutHaunting05"
    }
    {
      Id = "Dora_0339"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ah! {#Prev}Go for it, then."
      Speaker = "Dora"
      Event = "DoraAboutHaunting05"
    }
    {
      Id = "Dora_0164"
      InheritFrom = "BaseNarrative"
      DisplayName = "Whoa, what gives there, Mel? Y-you look like you've seen a... {#Emph}ungh{#Prev}, I don't know, but... whatever it was it got under your skin. {#Emph}<Gasp> Oh! {#Prev}Skin seems nice!"
      Speaker = "Dora"
      Event = "DoraAboutNightmares01"
    }
    {
      Id = "Melinoe_2015"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm all right, just a little shaken. First nightmare since all this started."
      Speaker = "Melinoe"
      Event = "DoraAboutNightmares01"
    }
    {
      Id = "Dora_0165"
      InheritFrom = "BaseNarrative"
      DisplayName = "About time, you were past due. Oh, how scary would you say it was, compared to, {#Emph}um, the terrifying visage that you see before you now?"
      Speaker = "Dora"
      Event = "DoraAboutNightmares01"
    }
    {
      Id = "Melinoe_2016"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not even close."
      Speaker = "Melinoe"
      Event = "DoraAboutNightmares01"
    }
    {
      Id = "Dora_0166"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wonder if I ever used to have nightmares... so, so you can just... {#Emph}imagine {#Prev}yourself in these {#Emph}completely {#Prev}different {#Emph}horrible {#Prev}situations?"
      Speaker = "Dora"
      Event = "DoraAboutNightmares02"
    }
    {
      Id = "Melinoe_2017"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes. And sometimes I'm not even there, which can make them even more unsettling. Though they don't trouble me as much anymore..."
      Speaker = "Melinoe"
      Event = "DoraAboutNightmares02"
    }
    {
      Id = "Dora_0167"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well... at least you've got {#Emph}me."
      Speaker = "Dora"
      Event = "DoraAboutNightmares02"
    }
    {
      Id = "Dora_0053"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey if you showed up just a bit sooner, you could have heard Nemesis complaining up a storm again!"
      Speaker = "Dora"
      Event = "DoraAboutNemesis01"
    }
    {
      Id = "Melinoe_1602"
      InheritFrom = "BaseNarrative"
      DisplayName = "Best not mock Retribution Incarnate if you know what's good for you. She and Headmistress have been at each other's throats..."
      Speaker = "Melinoe"
      Event = "DoraAboutNemesis01"
    }
    {
      Id = "Dora_0054"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know I could, like, {#Emph}possess {#Prev}her for you, right? Just kind of... swoop in there, rattle around in her head a little bit, make her do some {#Emph}bad {#Prev}stuff... {#Emph}<Gasp> embarrassing {#Prev}stuff! Just for a little while, I mean. If I got caught in there..."
      Speaker = "Dora"
      Event = "DoraAboutNemesis01"
    }
    {
      Id = "Melinoe_0069"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Dora, don't..."
      Speaker = "Melinoe"
      Event = "DoraAboutNemesis01"
    }
    {
      Id = "Dora_0157"
      InheritFrom = "BaseNarrative"
      DisplayName = "Get any sleep at least while you're zonked out back there? {#Emph}Huh{#Prev}, can't even wrap my head around what it must be like for you. Sleeping? They... they say it's like being dead, right? But I'm dead, and I'm always awake."
      Speaker = "Dora"
      Event = "DoraAboutHypnos01"
    }
    {
      Id = "Melinoe_0070"
      InheritFrom = "BaseNarrative"
      DisplayName = "I think the only one getting good sleep of late is Hypnos, himself. Still hasn't even stirred, no matter what Headmistress has tried."
      Speaker = "Melinoe"
      Event = "DoraAboutHypnos01"
    }
    {
      Id = "Dora_0056"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Lucky him."
      Speaker = "Dora"
      Event = "DoraAboutHypnos01"
    }
    {
      Id = "Dora_0176"
      InheritFrom = "BaseNarrative"
      DisplayName = "So, what's the deal with the horned guy, anyway? Saw him and Nemesis chatting like they were an item, or something. It was weird."
      Speaker = "Dora"
      Event = "DoraAboutMoros01"
    }
    {
      Id = "Melinoe_1826"
      InheritFrom = "BaseNarrative"
      DisplayName = "They're siblings, Dora. The horned one is Lord Moros, emissary of the Three Fates. Our distinguished guest, and a valuable ally."
      Speaker = "Melinoe"
      Event = "DoraAboutMoros01"
    }
    {
      Id = "Dora_0177"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yeah! Looks like we really put him up in style..."
      Speaker = "Dora"
      Event = "DoraAboutMoros01"
    }
    {
      Id = "Dora_0178"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wait, so the horned guy over there... {#Emph}he's {#Prev}the one who shows up whenever some mere mortal is about to {#Emph}die {#Prev}in some horrific, unexpected way?"
      Speaker = "Dora"
      Event = "DoraAboutMoros02"
    }
    {
      Id = "Melinoe_2029"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, yes. He ensures the will of the Three Fates is done. But don't misjudge him for it, and there's no need to be afraid of him, either."
      Speaker = "Melinoe"
      Event = "DoraAboutMoros02"
    }
    {
      Id = "Dora_0179"
      InheritFrom = "BaseNarrative"
      DisplayName = "Are you kidding? I think that's awesome, I... I wonder if he saw {#Emph}me {#Prev}die! Maybe I got crushed by a boulder! Struck by lightning! {#Emph}<Gasp> {#Prev}Murdered by my own lover...! Could you introduce us?"
      Speaker = "Dora"
      Event = "DoraAboutMoros02"
    }
    {
      Id = "Melinoe_2030"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Erm... {#Prev}sure?"
      Speaker = "Melinoe"
      Event = "DoraAboutMoros02"
    }
    {
      Id = "Dora_0185"
      InheritFrom = "BaseNarrative"
      DisplayName = "Saw you chatting up Horns again! Yeah, he's a bit of a stiff, but I guess he's not so bad. Think maybe I {#Emph}met {#Prev}him before, back when I died..."
      Speaker = "Dora"
      Event = "DoraAboutMoros03"
    }
    {
      Id = "Melinoe_2023"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh I doubt it. You'd remember having met someone like that. And he'd remember you as well! Though, you have been dead a while..."
      Speaker = "Melinoe"
      Event = "DoraAboutMoros03"
    }
    {
      Id = "Dora_0186"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yeah. Maybe I was one of his first jobs. Just an innocent young woman, doomed to a cruel inevitable future she never deserved..."
      Speaker = "Dora"
      Event = "DoraAboutMoros03"
    }
    {
      Id = "Melinoe_2024"
      InheritFrom = "BaseSubtitle"
      DisplayName = "OK, Dora."
      Speaker = "Melinoe"
      Event = "DoraAboutMoros03"
    }
    {
      Id = "Dora_0198"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey Mel! The good {#Emph}Commander {#Prev}there has offered to train me as one of his {#Emph}disciples. {#Prev}It's a big decision, so I'm kind of mulling it over..."
      Speaker = "Dora"
      Event = "DoraAboutSkelly01"
    }
    {
      Id = "Melinoe_2025"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've learned so much from him, Dora. Headmistress taught me my craft. But Commander Schelemeus taught me... {#Emph}erm..."
      Speaker = "Melinoe"
      Event = "DoraAboutSkelly01"
    }
    {
      Id = "Dora_0199"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How to beat up an old man...?"
      Speaker = "Dora"
      Event = "DoraAboutSkelly01"
    }
    {
      Id = "Melinoe_2026"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No!"
      Speaker = "Melinoe"
      Event = "DoraAboutSkelly01"
    }
    {
      Id = "Dora_0618"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey meant to ask you, {#Emph}what {#Prev}is with those statues in the training grounds? Are those supposed to be you, {#Emph}because... {#Prev}well... they're a lot {#Emph}bigger {#Prev}than you..."
      Speaker = "Dora"
      Event = "DoraAboutStatues01"
    }
    {
      Id = "Melinoe_4685"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Statues sometimes portray their subjects in an unnaturally flattering or dramatic light! But in any case, I earned the title of Night's Champion, and... those were my reward."
      Speaker = "Melinoe"
      Event = "DoraAboutStatues01"
    }
    {
      Id = "Dora_0619"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I'll never look at you the same way again! I {#Emph}really {#Prev}like the one with the huge axe."
      Speaker = "Dora"
      Event = "DoraAboutStatues01"
    }
    {
      Id = "Melinoe_4686"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh {#Emph}do {#Prev}you?"
      Speaker = "Melinoe"
      Event = "DoraAboutStatues01"
    }
    {
      Id = "Melinoe_2027"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do you remember the name {#Emph}Heracles? {#Prev}The greatest half-god hero of the surface, slayer of the Nemean Lion, and so on?"
      Speaker = "Melinoe"
      Event = "DoraAboutHeracles01"
    }
    {
      Id = "Dora_0194"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nah, not really. But I hear the other Shades go {#Emph}on {#Prev}and {#Emph}on {#Prev}about him every now and then. Why do you ask?"
      Speaker = "Dora"
      Event = "DoraAboutHeracles01"
    }
    {
      Id = "Melinoe_2028"
      InheritFrom = "BaseNarrative"
      DisplayName = "I encountered him. He's as big as they say, that much is sure. He has such a storied past, I thought maybe you'd recall one of the tales."
      Speaker = "Melinoe"
      Event = "DoraAboutHeracles01"
    }
    {
      Id = "Dora_0195"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well, you thought wrong, my friend."
      Speaker = "Dora"
      Event = "DoraAboutHeracles01"
    }
    {
      Id = "Dora_0615"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, {#Emph}uh{#Prev}, you and that guy, one with the wings, what was his name? Thought he was long {#Emph}dead{#Prev}, though when {#Emph}I {#Prev}saw him here with you, he seemed, shall we say, very much alive? How'd he do that?"
      Speaker = "Dora"
      Event = "DoraAboutIcarusRelationship01"
    }
    {
      Id = "Melinoe_4683"
      InheritFrom = "BaseNarrative"
      DisplayName = "You mean Icarus, and did you... were you eavesdropping on what very clearly was a private moment between longtime acquaintances? I thought you were elsewhere!"
      Speaker = "Melinoe"
      Event = "DoraAboutIcarusRelationship01"
    }
    {
      Id = "Dora_0616"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, no, I was just over {#Emph}there. {#Prev}Didn't want to interrupt. So did you bring him back using a necromantic ritual, or what?"
      Speaker = "Dora"
      Event = "DoraAboutIcarusRelationship01"
    }
    {
      Id = "Melinoe_4684"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's entirely my private business, thanks!"
      Speaker = "Melinoe"
      Event = "DoraAboutIcarusRelationship01"
    }
    {
      Id = "Dora_0617"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Trust me you have {#Emph}nothing {#Prev}to be ashamed of."
      Speaker = "Dora"
      Event = "DoraAboutIcarusRelationship01"
    }
    {
      Id = "Dora_0606"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey so what exactly {#Emph}happened {#Prev}around here? Did you complete your big important task? Because that's what I'm hearing from the other Shades."
      Speaker = "Dora"
      Event = "DoraPostTrueEnding01"
    }
    {
      Id = "Melinoe_4873"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, for the most part, yes! My family is back! My mother and father are restored to the Underworld throne, and my brother's back too! But we have many details to sort out, and... the Titan Chronos is going to be assisting us with that."
      Speaker = "Melinoe"
      Event = "DoraPostTrueEnding01"
    }
    {
      Id = "Dora_0607"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Titan you said you were going to slay this whole time... {#Emph}assisting us. {#Prev}Hate to say it, Mel, but sounds to me like you totally blew it. At least the Titan part."
      Speaker = "Dora"
      Event = "DoraPostTrueEnding01"
    }
    {
      Id = "Melinoe_4874"
      InheritFrom = "BaseNarrative"
      DisplayName = "He's no longer himself, or rather... no longer the way he used to be. And we'll be closely watching him."
      Speaker = "Melinoe"
      Event = "DoraPostTrueEnding01"
    }
    {
      Id = "Dora_0608"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sure. So then... congratulations are in order, basically?"
      Speaker = "Dora"
      Event = "DoraPostTrueEnding01"
    }
    {
      Id = "Melinoe_4875"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well if you like..."
      Speaker = "Melinoe"
      Event = "DoraPostTrueEnding01"
    }
    {
      Id = "Dora_0609"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I do. Congratulations, Mel."
      Speaker = "Dora"
      Event = "DoraPostTrueEnding01"
    }
    {
      Id = "Dora_0623"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got a new picture there I see. That from your mom and dad? Looks newer than the other one. You're all grown up!"
      Speaker = "Dora"
      Event = "DoraPostTrueEnding02"
    }
    {
      Id = "Melinoe_4876"
      InheritFrom = "BaseNarrative"
      DisplayName = "It was a bit of a parting gift, considering I won't be staying at the House of Hades with the rest of them. Though I'll be seeing them around, I think."
      Speaker = "Melinoe"
      Event = "DoraPostTrueEnding02"
    }
    {
      Id = "Dora_0624"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oof, harsh! {#Prev}How come they didn't want you living in their subterranean stronghold with {#Emph}them? {#Prev}You're their {#Emph}kid!"
      Speaker = "Dora"
      Event = "DoraPostTrueEnding02"
    }
    {
      Id = "Melinoe_4877"
      InheritFrom = "BaseNarrative"
      DisplayName = "They did want me to stay, it's just... my home is here. They're my family, but so is this."
      Speaker = "Melinoe"
      Event = "DoraPostTrueEnding02"
    }
    {
      Id = "Dora_0625"
      InheritFrom = "BaseNarrative"
      DisplayName = "What have you lost your mind? Wait, I'm your family too, {#Emph}that's {#Prev}what you're saying?"
      Speaker = "Dora"
      Event = "DoraPostTrueEnding02"
    }
    {
      Id = "Melinoe_4878"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Sure, if you're up for it."
      Speaker = "Melinoe"
      Event = "DoraPostTrueEnding02"
    }
    {
      Id = "Dora_0626"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Oh {#Prev}all right, I guess why not?"
      Speaker = "Dora"
      Event = "DoraPostTrueEnding02"
    }
    {
      Id = "Melinoe_4879"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey Dora, what if hypothetically there were to be the dawning of another age at some point, and the gods then truly did leave mortals more or less alone? More than before."
      Speaker = "Melinoe"
      Event = "DoraPostEpilogue01"
    }
    {
      Id = "Dora_0627"
      InheritFrom = "BaseNarrative"
      DisplayName = "What are you making me some kind of {#Emph}offer {#Prev}here? I know you're a big deal lately but not even {#Emph}you {#Prev}have the power to pull something like {#Emph}that {#Prev}off, Mel. Why would the gods give up their gig?"
      Speaker = "Dora"
      Event = "DoraPostEpilogue01"
    }
    {
      Id = "Melinoe_4880"
      InheritFrom = "BaseNarrative"
      DisplayName = "Even the gods are subject to the will of the Three Fates. None of us can entirely control what shall come to pass, and there are prophecies that cannot change no matter what."
      Speaker = "Melinoe"
      Event = "DoraPostEpilogue01"
    }
    {
      Id = "Dora_0628"
      InheritFrom = "BaseNarrative"
      DisplayName = "You really believe that stuff, even after everything you did? I mean, was there {#Emph}really {#Prev}some kind of prophecy about Chronos, and how you'd end up beating him eventually, once you realized your true potential thanks to me?"
      Speaker = "Dora"
      Event = "DoraPostEpilogue01"
    }
    {
      Id = "Melinoe_4881"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, no, because the Fates went missing throughout most of this ordeal, but... they don't tend to be mistaken."
      Speaker = "Melinoe"
      Event = "DoraPostEpilogue01"
    }
    {
      Id = "Dora_0629"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Right. I'll believe it when it happens."
      Speaker = "Dora"
      Event = "DoraPostEpilogue01"
    }
    {
      Id = "Dora_0180"
      InheritFrom = "BaseNarrative"
      DisplayName = "...And so I say, {#Emph}begone accursed witch! I have occupied this grove for aeons, long before your pitiable tent came to rest upon it! {#Prev}Oh hey Mel."
      Speaker = "Dora"
      Event = "DoraWithMoros01"
    }
    {
      Id = "Melinoe_2031"
      InheritFrom = "BaseNarrative"
      DisplayName = "I see the two of you have met! Lord Moros, Dora speaks the truth as always. She's been here longer than I have, if you can believe it!"
      Speaker = "Melinoe"
      Event = "DoraWithMoros01"
    }
    {
      Id = "Moros_0184"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can, indeed. For I know an old soul when I see one. It's a pleasure to meet you, Dora. Do let me know if I can be of service in some way."
      Speaker = "Moros"
      Event = "DoraWithMoros01"
    }
    {
      Id = "Dora_0181"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Haha. {#Prev}Count on it, Horns! Now then, {#Emph}I bid your leave. Farewell!"
      Speaker = "Dora"
      Event = "DoraWithMoros01"
    }
    {
      Id = "Moros_0185"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Farewell!"
      Speaker = "Moros"
      Event = "DoraWithMoros01"
    }
    {
      Id = "Dora_0182"
      InheritFrom = "BaseNarrative"
      DisplayName = "...His own {#Emph}brother? Eugh, {#Prev}no way, that is twisted! Your sisters are sick!"
      Speaker = "Dora"
      Event = "DoraWithMoros02"
    }
    {
      Id = "Moros_0186"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well... they have many mortal lives to untangle, so to speak. The work can grow repetitive, lose its spark. So they liven things up from time to time."
      Speaker = "Moros"
      Event = "DoraWithMoros02"
    }
    {
      Id = "Dora_0183"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh totally I, I would completely do the same if I were them. I wonder what they did to {#Emph}me.... {#Prev}Could you, like, look me up, or something...?"
      Speaker = "Dora"
      Event = "DoraWithMoros02"
    }
    {
      Id = "Moros_0187"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Heh! {#Prev}I fear I'm not at liberty to do such things."
      Speaker = "Moros"
      Event = "DoraWithMoros02"
    }
    {
      Id = "Dora_0184"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ah{#Prev}, come on..."
      Speaker = "Dora"
      Event = "DoraWithMoros02"
    }
    {
      Id = "Dora_0655"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Now kneel before me, O Horned King, and know your place! Lest I reduce you and that flowing mane of yours to dust and scatter it to the four winds!"
      Speaker = "Dora"
      Event = "DoraWithMoros03"
    }
    {
      Id = "Moros_0697"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Yes, that was truly excellent, Dora. Although, {#Emph}Horned King? {#Prev}That made it sound as though I was important in some way, when I think you were going for sheer dominance."
      Speaker = "Moros"
      Event = "DoraWithMoros03"
    }
    {
      Id = "Dora_0656"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Yeah{#Prev}, that's a good note. Just kind of popped into my head, you know? The antlers... they {#Emph}are {#Prev}striking! They real?"
      Speaker = "Dora"
      Event = "DoraWithMoros03"
    }
    {
      Id = "Moros_0698"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Don't you touch them."
      Speaker = "Moros"
      Event = "DoraWithMoros03"
    }
    {
      Id = "Dora_0657"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm gonna."
      Speaker = "Dora"
      Event = "DoraWithMoros03"
    }
    {
      Id = "Moros_0699"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I said don't."
      Speaker = "Moros"
      Event = "DoraWithMoros03"
    }
    {
      Id = "Dora_0658"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm gonna!"
      Speaker = "Dora"
      Event = "DoraWithMoros03"
    }
    {
      Id = "Moros_0700"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Please?"
      Speaker = "Moros"
      Event = "DoraWithMoros03"
    }
    {
      Id = "Dora_0200"
      InheritFrom = "BaseNarrative"
      DisplayName = "...So you basically just stand here, saying stuff, whatever pops in your head, and those {#Emph}other {#Prev}Shades, and Mel... they eat it up?"
      Speaker = "Dora"
      Event = "DoraWithSkelly01"
    }
    {
      Id = "Skelly_0171"
      InheritFrom = "BaseNarrative"
      DisplayName = "They {#Emph}do {#Prev}eat it up, Disciple, for it is nourishment borne of the wisdom of a vast experience, well-informing that which pops into my head! Now could you please give me a break...?"
      Speaker = "Skelly"
      Event = "DoraWithSkelly01"
    }
    {
      Id = "Dora_0201"
      InheritFrom = "BaseSubtitle"
      DisplayName = "OK. I hear you. {#Emph}Commander."
      Speaker = "Dora"
      Event = "DoraWithSkelly01"
    }
    {
      Id = "Skelly_0173"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Where were we?"
      Speaker = "Skelly"
      Event = "DoraWithSkelly01"
    }
    {
      Id = "Dora_0006"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll keep an eye on all your stuff while you're away."
      Speaker = "Dora"
      Event = "DoraChat01"
    }
    {
      Id = "Dora_0007"
      InheritFrom = "BaseNarrative"
      DisplayName = "Good to chat, but I better get back to haunting."
      Speaker = "Dora"
      Event = "DoraChat02"
    }
    {
      Id = "Dora_0008"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got a lot of weird stuff in here, you know that?"
      Speaker = "Dora"
      Event = "DoraChat03"
    }
    {
      Id = "Dora_0009"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just haunting up the place. Don't worry about me..."
      Speaker = "Dora"
      Event = "DoraChat04"
    }
    {
      Id = "Dora_0010"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, Mel. I mean, {#Emph}Ravens shall feast on your eyes!"
      Speaker = "Dora"
      Event = "DoraChat05"
    }
    {
      Id = "Dora_0011"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, Mel. I mean, {#Emph}In seeking me you seek only your doom!"
      Speaker = "Dora"
      Event = "DoraChat06"
    }
    {
      Id = "Dora_0012"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Disturb me thus and I shall torment you for three eternities!"
      Speaker = "Dora"
      Event = "DoraChat07"
    }
    {
      Id = "Dora_0013"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}May your days be filled with dread, your nights with fear!"
      Speaker = "Dora"
      Event = "DoraChat08"
    }
    {
      Id = "Dora_0014"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}A thousand curses on you for invoking me!"
      Speaker = "Dora"
      Event = "DoraChat09"
    }
    {
      Id = "Dora_0015"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Do not presume to tarry o'erlong within my tent, witch!"
      Speaker = "Dora"
      Event = "DoraChat10"
    }
    {
      Id = "Dora_0017"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do what you got to do. I'm not even here."
      Speaker = "Dora"
      Event = "DoraChat11"
    }
    {
      Id = "Dora_0018"
      InheritFrom = "BaseNarrative"
      DisplayName = "Juuust floatin' around, don't mind me."
      Speaker = "Dora"
      Event = "DoraChat12"
    }
    {
      Id = "Dora_0019"
      InheritFrom = "BaseNarrative"
      DisplayName = "Feel free to stay in your own tent as long as you like."
      Speaker = "Dora"
      Event = "DoraChat13"
    }
    {
      Id = "Dora_0020"
      InheritFrom = "BaseNarrative"
      DisplayName = "Let me know if there's somebody I can torment for you, OK?"
      Speaker = "Dora"
      Event = "DoraChat14"
    }
    {
      Id = "Dora_0021"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hope your big task thing's been going all right!"
      Speaker = "Dora"
      Event = "DoraChat15"
    }
    {
      Id = "Dora_0022"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll try not to muck everything up while you're out."
      Speaker = "Dora"
      Event = "DoraChat16"
    }
    {
      Id = "Dora_0023"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Uhh{#Prev}, can I get a little privacy, here, Mel?"
      Speaker = "Dora"
      Event = "DoraChat17"
    }
    {
      Id = "Dora_0024"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sooner you get out of here, sooner I can go through all your stuff."
      Speaker = "Dora"
      Event = "DoraChat18"
    }
    {
      Id = "Dora_0025"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}You {#Prev}exist, {#Emph}I {#Prev}exist... could be worse, right?"
      Speaker = "Dora"
      Event = "DoraChat19"
    }
    {
      Id = "Dora_0026"
      InheritFrom = "BaseNarrative"
      DisplayName = "Have a good whatever time it is doing whatever it is you do!"
      Speaker = "Dora"
      Event = "DoraChat20"
    }
    {
      Id = "Dora_0027"
      InheritFrom = "BaseNarrative"
      DisplayName = "Go knock 'em dead for me, or back to life! Whatever's worse."
      Speaker = "Dora"
      Event = "DoraChat21"
    }
    {
      Id = "Dora_0028"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm going to haunt this tent {#Emph}so bad {#Prev}once you get out of here..."
      Speaker = "Dora"
      Event = "DoraChat22"
    }
    {
      Id = "Dora_0029"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just go with the flow out there! It's what I do!"
      Speaker = "Dora"
      Event = "DoraChat23"
    }
    {
      Id = "Dora_0030"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Damn{#Prev}, Mel! {#Emph}Wow. {#Prev}If only looks could kill, am I right?"
      Speaker = "Dora"
      Event = "DoraChat24"
    }
    {
      Id = "Dora_0031"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hope nothing horrible happens to you out there!"
      Speaker = "Dora"
      Event = "DoraChat25"
    }
    {
      Id = "Dora_0032"
      InheritFrom = "BaseNarrative"
      DisplayName = "Mel, you've inspired me... to float right here, for the time being."
      Speaker = "Dora"
      Event = "DoraChat26"
    }
    {
      Id = "Dora_0033"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, Mel! I mean, {#Emph}You hold no sway over me, witch!"
      Speaker = "Dora"
      Event = "DoraChat27"
    }
    {
      Id = "Dora_0034"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Your incessant reappearances have come to be acceptable, witch!"
      Speaker = "Dora"
      Event = "DoraChat28"
    }
    {
      Id = "Dora_0630"
      InheritFrom = "BaseNarrative"
      DisplayName = "Think maybe there's anything we ought to change around in terms of furnishings and all that?"
      Speaker = "Dora"
      Event = "DoraChat29"
    }
    {
      Id = "Dora_0631"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sometimes I just want to, like, {#Emph}possess {#Prev}someone, you know? Only for a little bit."
      Speaker = "Dora"
      Event = "DoraChat30"
    }
    {
      Id = "Dora_0632"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't mind me! Just doing my thing over here, Mel."
      Speaker = "Dora"
      Event = "DoraChat31"
    }
    {
      Id = "Dora_0633"
      InheritFrom = "BaseNarrative"
      DisplayName = "Those Shades out there been saying you did good again tonight I guess?"
      Speaker = "Dora"
      Event = "DoraChat32"
    }
    {
      Id = "Dora_0634"
      InheritFrom = "BaseNarrative"
      DisplayName = "Want anyone around here tormented for a little while, just give me the signal."
      Speaker = "Dora"
      Event = "DoraChat33"
    }
    {
      Id = "Dora_0635"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}You deign to look upon me, witch? I shall haunt your every waking moment!"
      Speaker = "Dora"
      Event = "DoraChat34"
    }
    {
      Id = "Dora_0636"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Those who gaze into my eyes are forever doomed to suffer as I did!"
      Speaker = "Dora"
      Event = "DoraChat35"
    }
    {
      Id = "Dora_0637"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}An eternity of suffering and insect-bites await all those who dare to cross my path."
      Speaker = "Dora"
      Event = "DoraChat36"
    }
    {
      Id = "Dora_0638"
      InheritFrom = "BaseNarrative"
      DisplayName = "Been keeping an eye on things while you're away, and {#Emph}terrifying anyone who dares approach!"
      Speaker = "Dora"
      Event = "DoraChat37"
    }
    {
      Id = "Dora_0639"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll be keeping an eye on the tent for you while you're out all night, Mel."
      Speaker = "Dora"
      Event = "DoraChat38"
    }
    {
      Id = "Dora_0640"
      InheritFrom = "BaseNarrative"
      DisplayName = "Need anything from me, I'll be right here. Or one of the other places you go."
      Speaker = "Dora"
      Event = "DoraChat40"
    }
    {
      Id = "Dora_0641"
      InheritFrom = "BaseNarrative"
      DisplayName = "One of the other Shades said hi to me earlier, {#Emph}for the first and final time!"
      Speaker = "Dora"
      Event = "DoraChat41"
    }
    {
      Id = "Dora_0642"
      InheritFrom = "BaseNarrative"
      DisplayName = "Everything's been good enough here lately, long as you can say the same."
      Speaker = "Dora"
      Event = "DoraChat42"
    }
    {
      Id = "Melinoe_0441"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wanted you to have this, Dora. To the best haunter in all the Crossroads!"
      Speaker = "Melinoe"
      Event = "DoraGift01"
    }
    {
      Id = "Dora_0102"
      InheritFrom = "BaseNarrative"
      DisplayName = "See, I {#Emph}knew {#Prev}you were going to pull this gift-custom thing on me sooner or later, so I have come prepared. Catch!"
      Speaker = "Dora"
      Event = "DoraGift01"
    }
    {
      Id = "Dora_0103"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, you don't need to get this kind of stuff for me! I can just take whatever stuff of yours I want when you're out!"
      Speaker = "Dora"
      Event = "DoraGift02"
    }
    {
      Id = "Melinoe_0443"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well you can't take {#Emph}this {#Prev}while I'm out! I keep it on me at all times, for just such an occasion."
      Speaker = "Melinoe"
      Event = "DoraGift02"
    }
    {
      Id = "Dora_0104"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Fool! I am not susceptible to mere baubles such as this! Ah{#Prev}, just kidding. {#Emph}Totally {#Prev}susceptible. Gimme!"
      Speaker = "Dora"
      Event = "DoraGift03"
    }
    {
      Id = "Melinoe_0444"
      InheritFrom = "BaseNarrative"
      DisplayName = "At last, I have discovered a vulnerable point in your defenses!"
      Speaker = "Melinoe"
      Event = "DoraGift03"
    }
    {
      Id = "Dora_0105"
      InheritFrom = "BaseNarrative"
      DisplayName = "Starting to get the feeling maybe I liked this stuff back when I had eyeballs and so on."
      Speaker = "Dora"
      Event = "DoraGift04"
    }
    {
      Id = "Melinoe_0445"
      InheritFrom = "BaseNarrative"
      DisplayName = "Doesn't matter whether you liked it then, what matters is you like it now."
      Speaker = "Melinoe"
      Event = "DoraGift04"
    }
    {
      Id = "Dora_0106"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ungh{#Prev}, on the one hand, I really don't know what I did to deserve this. But on the other hand, I really don't care! It's mine now."
      Speaker = "Dora"
      Event = "DoraGift05"
    }
    {
      Id = "Melinoe_0446"
      InheritFrom = "BaseNarrative"
      DisplayName = "It most certainly is! And there's more in it for you if you keep on haunting this tent!"
      Speaker = "Melinoe"
      Event = "DoraGift05"
    }
    {
      Id = "Dora_0107"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Such pitiable offerings as this are hardly worth my notice, witch! {#Prev}No, but, seriously, thanks. Nobody ever gets me anything! Besides you, I mean. It's nice, you know?"
      Speaker = "Dora"
      Event = "DoraGift06"
    }
    {
      Id = "Melinoe_0447"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's nice for me as well! Having you here as company means a lot, so it really is the least I could do."
      Speaker = "Melinoe"
      Event = "DoraGift06"
    }
    {
      Id = "Dora_0595"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, {#Emph}cool it {#Prev}with the Nectar, would you, Mel? Ever since we tried Ambrosia, I've been cultivating a {#Emph}much {#Prev}more sophisticated palate, for a Shade. No more cheap stuff."
      Speaker = "Dora"
      Event = "DoraGift07"
    }
    {
      Id = "Melinoe_4670"
      InheritFrom = "BaseNarrative"
      DisplayName = "Dora, the Nectar of the gods can hardly be considered {#Emph}cheap! {#Prev}Most mortals go through the entirety of their existence without so much as a {#Emph}taste! {#Prev}And you don't like it?"
      Speaker = "Melinoe"
      Event = "DoraGift07"
    }
    {
      Id = "Dora_0596"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know, I {#Emph}do{#Prev}, but it's a little on the sweet side for me? Though, I appreciate you treating me like royalty... {#Emph}like a spirit of unfathomable power...!"
      Speaker = "Dora"
      Event = "DoraGift07"
    }
    {
      Id = "Melinoe_4671"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've met many great and noble Shades, Dora, though I can confidently say that none of them are anything like {#Emph}you. {#Prev}This Ambrosia is yours; shall we open it at the taverna?"
      Speaker = "Melinoe"
      Event = "DoraGift08"
    }
    {
      Id = "Dora_0597"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}I shall accept your offering this time, witch. {#Prev}But I'd rather hang onto it for now. Unless you want to have it with me here? I just don't want to go anywhere is all."
      Speaker = "Dora"
      Event = "DoraGift08"
    }
    {
      Id = "Melinoe_4672"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh! {#Prev}Of course. Here, the aroma alone should do most of the work. To your continued hauntings!"
      Speaker = "Melinoe"
      Event = "DoraGift08"
    }
    {
      Id = "Dora_0598"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thanks. This stuff is definitely pretty good. How come you have {#Emph}both {#Prev}Nectar and Ambrosia, anyway? It's weird. Two different godly beverages, only one's an even bigger deal."
      Speaker = "Dora"
      Event = "DoraGift08"
    }
    {
      Id = "Melinoe_4673"
      InheritFrom = "BaseNarrative"
      DisplayName = "They're suitable for different occasions. It would never do to offer Ambrosia to a newer acquaintance, for example. It's reserved mainly for feasting between close friends or lovers."
      Speaker = "Melinoe"
      Event = "DoraGift08"
    }
    {
      Id = "Dora_0599"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well that sounds just like {#Emph}us! {#Prev}But, I think I might be over this stuff too..."
      Speaker = "Dora"
      Event = "DoraGift08"
    }
    {
      Id = "Melinoe_4674"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh..."
      Speaker = "Melinoe"
      Event = "DoraGift08"
    }
    {
      Id = "Melinoe_3814"
      InheritFrom = "BaseNarrative"
      DisplayName = "Would you be interested in visiting the springs with me, Dora? A warm soak can be good for the soul."
      Speaker = "Melinoe"
      Event = "DoraBathHouseDecline01"
    }
    {
      Id = "Dora_0351"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nah. Kind of busy doing nothing whatsoever at the moment, though I might be up for a soak some other time."
      Speaker = "Dora"
      Event = "DoraBathHouseDecline01"
    }
    {
      Id = "Melinoe_3815"
      InheritFrom = "BaseNarrative"
      DisplayName = "What would you say to a brief trip to the fishing pier with me? It's nice and quiet over there!"
      Speaker = "Melinoe"
      Event = "DoraFishingDecline01"
    }
    {
      Id = "Dora_0352"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Eh{#Prev}, don't really want to move right now. And those fish would probably scare {#Emph}way {#Prev}too easily for a haunter of my skill."
      Speaker = "Dora"
      Event = "DoraFishingDecline01"
    }
    {
      Id = "Melinoe_3816"
      InheritFrom = "BaseNarrative"
      DisplayName = "Want to join me at the Taverna for a bottle of Ambrosia? I enjoyed our previous outing."
      Speaker = "Melinoe"
      Event = "DoraTavernaDecline01"
    }
    {
      Id = "Dora_0353"
      InheritFrom = "BaseNarrative"
      DisplayName = "I enjoyed it too but it was kind of a {#Emph}lot{#Prev}, being in that crowd... still a little drained from last time, I think."
      Speaker = "Dora"
      Event = "DoraTavernaDecline01"
    }
    {
      Id = "Melinoe_0440"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, if you're not busy, up for a little visit with me to the riverside? I've got a twin lure we could use right here."
      Speaker = "Melinoe"
      Event = "DoraFishing01"
    }
    {
      Id = "Dora_0081"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't know that I'll be doing you much good, between my inability to use a rod of fishing and my inability to keep quiet, but hey! You asked for it."
      Speaker = "Dora"
      Event = "DoraFishing01"
    }
    {
      Id = "Dora_0300"
      InheritFrom = "BaseNarrative"
      DisplayName = "The River of Lamentation. Nothing but a bunch of sad stuff floating around in there. Sure you wouldn't rather leave it be?"
      Speaker = "Dora"
      Event = "DoraFishing01"
    }
    {
      Id = "Melinoe_3690"
      InheritFrom = "BaseNarrative"
      DisplayName = "Whatever's wallowing in there is going to stay put, unless it's finally decided it's had enough. For any such souls, we'll be doing them a favor, I think."
      Speaker = "Melinoe"
      Event = "DoraFishing01"
    }
    {
      Id = "Dora_0301"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not like we owe them, and not like they'll do us any favors back. And if all they can do now is feel sad for themselves at the bottom of a mucky river, fishing them out might not do them any good anyway."
      Speaker = "Dora"
      Event = "DoraFishing01"
    }
    {
      Id = "Melinoe_3691"
      InheritFrom = "BaseNarrative"
      DisplayName = "We're not fishing them out, really. It's more like we're giving them an opportunity to escape their circumstances. It's a bit different from the mortal way of fishing in that sense."
      Speaker = "Melinoe"
      Event = "DoraFishing01"
    }
    {
      Id = "Dora_0302"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then if they don't like it any better up here, that's on them..."
      Speaker = "Dora"
      Event = "DoraFishing01"
    }
    {
      Id = "Dora_0099"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, that definitely was a thing that happened. Thanks!"
      Speaker = "Dora"
      Event = "DoraFishing01"
    }
    {
      Id = "Melinoe_0063"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Bye."
      Speaker = "Melinoe"
      Event = "DoraFishing01"
    }
    {
      Id = "Dora_0141"
      InheritFrom = "BaseSubtitle"
      DisplayName = "OK bye."
      Speaker = "Dora"
      Event = "DoraFishing01"
    }
    {
      Id = "Melinoe_0419"
      InheritFrom = "BaseNarrative"
      DisplayName = "Say Dora? Would you mind accompanying me over to the baths? I'd hate to think they aren't haunted."
      Speaker = "Melinoe"
      Event = "DoraBathHouse01"
    }
    {
      Id = "Dora_0061"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do I want to float aimlessly in some near-boiling water? Do I ever! What are we waiting for?"
      Speaker = "Dora"
      Event = "DoraBathHouse01"
    }
    {
      Id = "Dora_0063"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wonder if I was ever shy about this kind of stuff..."
      Speaker = "Dora"
      Event = "DoraBathHouse01"
    }
    {
      Id = "Melinoe_0421"
      InheritFrom = "BaseNarrative"
      DisplayName = "You still can sense something of the waters' warmth, can't you, Dora?"
      Speaker = "Melinoe"
      Event = "DoraBathHouse01"
    }
    {
      Id = "Dora_0071"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, I can see all the steam rising, which I associate with warmth, so... I guess it kind of tricks me into thinking warm thoughts."
      Speaker = "Dora"
      Event = "DoraBathHouse01"
    }
    {
      Id = "Melinoe_0422"
      InheritFrom = "BaseNarrative"
      DisplayName = "That doesn't sound so bad. Though, you do remember what warmth was like, then? From your mortal days?"
      Speaker = "Melinoe"
      Event = "DoraBathHouse01"
    }
    {
      Id = "Dora_0072"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ohh{#Prev}, not really, no. I, I guess I've just heard so much about it, it's like I've experienced it myself."
      Speaker = "Dora"
      Event = "DoraBathHouse01"
    }
    {
      Id = "Dora_0077"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Whew! {#Prev}That was basically like floating around in your tent, though I appreciate it nonetheless!"
      Speaker = "Dora"
      Event = "DoraBathHouse01"
    }
    {
      Id = "Melinoe_0420"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey I've got these bath salts here that are more than enough for me, if you're not busy at the moment...?"
      Speaker = "Melinoe"
      Event = "DoraBathHouse02"
    }
    {
      Id = "Dora_0062"
      InheritFrom = "BaseNarrative"
      DisplayName = "Mel, you know I like doing nothing. Sitting in the bathhouse with you? Well that's got to be the next best thing so, shall we?"
      Speaker = "Dora"
      Event = "DoraBathHouse02"
    }
    {
      Id = "Dora_0065"
      InheritFrom = "BaseNarrative"
      DisplayName = "Like being cooked in a cauldron, isn't it?"
      Speaker = "Dora"
      Event = "DoraBathHouse02"
    }
    {
      Id = "Melinoe_0424"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't you ever wonder how you used to be, Dora? When you were flesh and blood? I bet you were very beautiful."
      Speaker = "Melinoe"
      Event = "DoraBathHouse02"
    }
    {
      Id = "Dora_0073"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hah! Whaaat{#Prev}, seriously? Is it because of my voice or because of my curves? Nah, you're just messing with me."
      Speaker = "Dora"
      Event = "DoraBathHouse02"
    }
    {
      Id = "Melinoe_0425"
      InheritFrom = "BaseNarrative"
      DisplayName = "I am not! It's because of your confidence, I suppose. You're very self-assured! Some Shades cower before me, but you and I always got on."
      Speaker = "Melinoe"
      Event = "DoraBathHouse02"
    }
    {
      Id = "Dora_0074"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, some Shades are total buffoons. Anyway, it doesn't really matter to me how I used to be. If I was happy about it, I figure I'd remember."
      Speaker = "Dora"
      Event = "DoraBathHouse02"
    }
    {
      Id = "Melinoe_0426"
      InheritFrom = "BaseNarrative"
      DisplayName = "You think you've deliberately forgotten your past?"
      Speaker = "Melinoe"
      Event = "DoraBathHouse02"
    }
    {
      Id = "Dora_0075"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yeah. Why else would I have forgotten everything? Probably took a couple swigs from the River Lethe, and that was that! Clean slate."
      Speaker = "Dora"
      Event = "DoraBathHouse02"
    }
    {
      Id = "Melinoe_0427"
      InheritFrom = "BaseNarrative"
      DisplayName = "The River of Forgetfulness... you think you were down in Elysium?"
      Speaker = "Melinoe"
      Event = "DoraBathHouse02"
    }
    {
      Id = "Dora_0078"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know, if I'm not mistaken I think I had a good time with you back there. Thanks, Mel!"
      Speaker = "Dora"
      Event = "DoraBathHouse02"
    }
    {
      Id = "Melinoe_4675"
      InheritFrom = "BaseNarrative"
      DisplayName = "Forget about the Nectar and Ambrosia, what if we go to the springs again? It's quiet there. Seems more your style... and for that matter, mine."
      Speaker = "Melinoe"
      Event = "DoraBathHouse03"
    }
    {
      Id = "Dora_0600"
      InheritFrom = "BaseNarrative"
      DisplayName = "I was planning to say no to whatever you had in mind just to mess with you, but the springs {#Emph}do {#Prev}sound OK. So let's go."
      Speaker = "Dora"
      Event = "DoraBathHouse03"
    }
    {
      Id = "Melinoe_4676"
      InheritFrom = "BaseNarrative"
      DisplayName = "Aren't you angry with the gods...? For what they did to you, and all of mortalkind, apparently. So what if it was a long time ago! The more I think about it, the angrier I get..."
      Speaker = "Melinoe"
      Event = "DoraBathHouse03"
    }
    {
      Id = "Dora_0602"
      InheritFrom = "BaseNarrative"
      DisplayName = "I mean, {#Emph}honestly{#Prev}, it was a pretty good prank! But, it was nasty, too. I don't know which one of you all was responsible, but don't really care. Not big on the whole anger thing."
      Speaker = "Dora"
      Event = "DoraBathHouse03"
    }
    {
      Id = "Melinoe_4677"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're too kind... more than {#Emph}my {#Prev}family at least. I don't think there's any taking back what happened, but... for what it's worth, once all this is over, I'm going to do all I can to make it so we gods act more decently with mortals from now on."
      Speaker = "Melinoe"
      Event = "DoraBathHouse03"
    }
    {
      Id = "Dora_0603"
      InheritFrom = "BaseNarrative"
      DisplayName = "Speaking on behalf of all mortals who ever lived or ever will, I think we'd mostly like it if you left us alone. Might be a lot of evils in this world, but... we have ways of figuring things out."
      Speaker = "Dora"
      Event = "DoraBathHouse03"
    }
    {
      Id = "Melinoe_4678"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Can you and I remain as friends, at least?"
      Speaker = "Melinoe"
      Event = "DoraBathHouse03"
    }
    {
      Id = "Dora_0604"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well let me think about it for a little while and get back to you, all right?"
      Speaker = "Dora"
      Event = "DoraBathHouse03"
    }
    {
      Id = "Dora_0605"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Done a lot of thinking, and we're good to go on that remain-as-friends thing, Mel. Though I'll keep you posted if anything comes up!"
      Speaker = "Dora"
      Event = "DoraBathHouse03"
    }
    {
      Id = "Melinoe_4680"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Sounds good, Dora."
      Speaker = "Melinoe"
      Event = "DoraBathHouse03"
    }
    {
      Id = "Melinoe_3726"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, now that the taverna's back, how about I treat you to a bit of the Ambrosia of the gods? You have my word it's good!"
      Speaker = "Melinoe"
      Event = "DoraTaverna01"
    }
    {
      Id = "Dora_0345"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, I guess I'm not in the middle of anything, and since you {#Emph}did {#Prev}give me your word... know what, I'm in."
      Speaker = "Dora"
      Event = "DoraTaverna01"
    }
    {
      Id = "Dora_0346"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Considered a delicacy, that figures. Kind of a weird consistency, are you supposed to {#Emph}drink {#Prev}this stuff or {#Emph}eat {#Prev}it?"
      Speaker = "Dora"
      Event = "DoraTaverna01"
    }
    {
      Id = "Melinoe_3727"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're mainly just supposed to savor it with friends. I agree it's a bit unusual, but then, it's intended for extraordinary circumstances."
      Speaker = "Melinoe"
      Event = "DoraTaverna01"
    }
    {
      Id = "Dora_0347"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yeah? What makes this so extraordinary? We're just... lounging around. Not in the tent, which granted isn't normal in my case, but... still."
      Speaker = "Dora"
      Event = "DoraTaverna01"
    }
    {
      Id = "Melinoe_3728"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's ours to decide what's special, don't you think? Yes, we see each other night in and night out. But we have never shared a fancy bottle like this, just the two of us."
      Speaker = "Melinoe"
      Event = "DoraTaverna01"
    }
    {
      Id = "Dora_0348"
      InheritFrom = "BaseNarrative"
      DisplayName = "I guess I see your point, but... bit of a paradox or something, right? Ambrosia's meant for extraordinary events, but it's the Ambrosia itself making things... unnaturally festive."
      Speaker = "Dora"
      Event = "DoraTaverna01"
    }
    {
      Id = "Melinoe_3729"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Supernaturally{#Prev}, even. My skin, it's beginning to crawl, as though... something is here with us! Oh, gods..."
      Speaker = "Melinoe"
      Event = "DoraTaverna01"
    }
    {
      Id = "Dora_0349"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The gods themselves shall quake with fear, the likes of which your frail consciousness shall never comprehend!"
      Speaker = "Dora"
      Event = "DoraTaverna01"
    }
    {
      Id = "Dora_0350"
      InheritFrom = "BaseNarrative"
      DisplayName = "...All right so then Ambrosia's not that bad. I got to go unwind, but... that was fun."
      Speaker = "Dora"
      Event = "DoraTaverna01"
    }
    {
      Id = "Melinoe_3731"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Do it, Dora."
      Speaker = "Melinoe"
      Event = "DoraTaverna01"
    }
    {
      Id = "Melinoe_1154"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You there, Dora...?"
      Speaker = "Melinoe"
      Event = "NPC_Dora_01.MissingDistanceTrigger.VoiceLines"
    }
    {
      Id = "Melinoe_1155"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Dora must be hiding for a bit."
      Speaker = "Melinoe"
      Event = "NPC_Dora_01.MissingDistanceTrigger.VoiceLines"
    }
    {
      Id = "Dora_0148"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hey quit it."
      Speaker = "Dora"
      Event = "NPC_Dora_01.OnHitVoiceLines"
    }
    {
      Id = "Dora_0149"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hah! {#Prev}No."
      Speaker = "Dora"
      Event = "NPC_Dora_01.OnHitVoiceLines"
    }
    {
      Id = "Dora_0150"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Kind of tickles."
      Speaker = "Dora"
      Event = "NPC_Dora_01.OnHitVoiceLines"
    }
    {
      Id = "Dora_0151"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Sorry, can't die."
      Speaker = "Dora"
      Event = "NPC_Dora_01.OnHitVoiceLines"
    }
    {
      Id = "Dora_0153"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Seriously?"
      Speaker = "Dora"
      Event = "NPC_Dora_01.OnHitVoiceLines"
    }
    {
      Id = "Melinoe_0442"
      InheritFrom = "BaseSubtitle"
      DisplayName = "For me? Thank you, Dora!"
      Speaker = "Melinoe"
      Event = "NPC_Dora_01.GiftGivenVoiceLines"
    }
    {
      Id = "Dora_0129"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Boo!!"
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0146"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Umm..."
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0147"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hey, so..."
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0133"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Who dares?"
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0228"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Kneel before me!"
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0144"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Approach, witch!"
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0226"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}You have returned."
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0125"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hey."
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0224"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh hey..."
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0220"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How's it going?"
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0533"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I hate it out here!"
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0535"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Look at all this stuff..."
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0537"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What am I doing here..."
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0539"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I miss the tent."
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0541"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Need something?"
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0546"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This place is weird."
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0538"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Save me, Mel."
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0542"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Inside I'm screaming."
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0540"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Gotten crowded..."
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0534"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Lot of Shades around..."
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0536"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Far as I'll go."
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0543"
      InheritFrom = "BaseSubtitle"
      DisplayName = "There's the {#Emph}Commander..."
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0544"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Don't go just yet."
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0545"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You {#Emph}could {#Prev}just leave..."
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0547"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Can I go home?"
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0229"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Took you long enough."
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0230"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You know how late it is?"
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0231"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Out late again huh."
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0232"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh, finally!"
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0489"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Whoa, you're back!"
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0490"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You were out awhile."
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0491"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How'd it go, OK?"
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0492"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh you're up."
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0530"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Did you do it?"
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0531"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Made it back."
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0493"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}How can this be?"
      Speaker = "Dora"
      Event = "GlobalVoiceLines.DoraSummonedVoiceLines"
    }
    {
      Id = "Dora_0494"
