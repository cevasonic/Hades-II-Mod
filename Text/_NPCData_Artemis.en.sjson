      InheritFrom = "BaseSubtitle"
      DisplayName = "All right, I'm off."
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.ExitVoiceLines"
    }
    {
      Id = "Artemis_0127"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Farewell for now."
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.ExitVoiceLines"
    }
    {
      Id = "Artemis_0128"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Fight on, Sister."
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.ExitVoiceLines"
    }
    {
      Id = "Artemis_0129"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Go find your mark."
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.ExitVoiceLines"
    }
    {
      Id = "Artemis_0131"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Till we meet again."
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.ExitVoiceLines"
    }
    {
      Id = "Artemis_0133"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Good hunting."
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.ExitVoiceLines"
    }
    {
      Id = "Artemis_0134"
      InheritFrom = "BaseSubtitle"
      DisplayName = "See you."
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.ExitVoiceLines"
    }
    {
      Id = "Artemis_0135"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Got to go."
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.ExitVoiceLines"
    }
    {
      Id = "Artemis_0309"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Good to see you!"
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.ExitVoiceLines"
    }
    {
      Id = "Artemis_0310"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Watch your step!"
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.ExitVoiceLines"
    }
    {
      Id = "Artemis_0311"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Steady out there."
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.ExitVoiceLines"
    }
    {
      Id = "Artemis_0312"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I was never here."
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.ExitVoiceLines"
    }
    {
      Id = "Artemis_0313"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Go unseen."
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.ExitVoiceLines"
    }
    {
      Id = "Artemis_0308"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Moonlight guide you home tonight!"
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.ExitVoiceLines"
    }
    {
      Id = "Melinoe_1254"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Good hunting."
      Speaker = "Melinoe"
      Event = "NPC_Artemis_01.ExitVoiceLines"
    }
    {
      Id = "Melinoe_1255"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Fight on."
      Speaker = "Melinoe"
      Event = "NPC_Artemis_01.ExitVoiceLines"
    }
    {
      Id = "Melinoe_1256_C"
      InheritFrom = "BaseSubtitle"
      DisplayName = "See you."
      Speaker = "Melinoe"
      Event = "NPC_Artemis_01.ExitVoiceLines"
    }
    {
      Id = "Melinoe_1257"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Go unseen."
      Speaker = "Melinoe"
      Event = "NPC_Artemis_01.ExitVoiceLines"
    }
    {
      Id = "Artemis_0105"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Sister?"
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.OnHitVoiceLines"
    }
    {
      Id = "Artemis_0106"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come off it."
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.OnHitVoiceLines"
    }
    {
      Id = "Artemis_0107"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No time to spar."
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.OnHitVoiceLines"
    }
    {
      Id = "Artemis_0108"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Don't take it out on me."
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.OnHitVoiceLines"
    }
    {
      Id = "Artemis_0109"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Focus, Sister."
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.OnHitVoiceLines"
    }
    {
      Id = "Artemis_0110"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}<Sigh...>"
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.OnHitVoiceLines"
    }
    {
      Id = "Artemis_0359"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Save it for Chronos?"
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.OnHitVoiceLines"
    }
    {
      Id = "Artemis_0360"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come on."
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.OnHitVoiceLines"
    }
    {
      Id = "Artemis_0361"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Really?"
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.OnHitVoiceLines"
    }
    {
      Id = "Artemis_0362"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Stop it."
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.OnHitVoiceLines"
    }
    {
      Id = "MelinoeField_3403"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}I see your threefold shadow with the Phantom Queen."
      Speaker = "Melinoe"
      Event = "NPC_Artemis_Field_01.UpgradeMenuOpenVoiceLines"
    }
    {
      Id = "MelinoeField_4108"
      InheritFrom = "BaseSubtitle"
      DisplayName = "If we must."
      Speaker = "Melinoe"
      Event = "NPC_Artemis_Field_01.UpgradeMenuOpenVoiceLines"
    }
    {
      Id = "Artemis_0111"
      InheritFrom = "BaseSubtitle"
      DisplayName = "For your journey."
      Speaker = "Artemis"
      Event = "NPC_Artemis_Field_01.UpgradeMenuOpenVoiceLines"
    }
    {
      Id = "Artemis_0112"
      InheritFrom = "BaseSubtitle"
      DisplayName = "My blessings..."
      Speaker = "Artemis"
      Event = "NPC_Artemis_Field_01.UpgradeMenuOpenVoiceLines"
    }
    {
      Id = "Artemis_0113"
      InheritFrom = "BaseSubtitle"
      DisplayName = "For you."
      Speaker = "Artemis"
      Event = "NPC_Artemis_Field_01.UpgradeMenuOpenVoiceLines"
    }
    {
      Id = "Artemis_0114"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Here's what I have."
      Speaker = "Artemis"
      Event = "NPC_Artemis_Field_01.UpgradeMenuOpenVoiceLines"
    }
    {
      Id = "Artemis_0115"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The choice is yours."
      Speaker = "Artemis"
      Event = "NPC_Artemis_Field_01.UpgradeMenuOpenVoiceLines"
    }
    {
      Id = "Artemis_0116"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Here."
      Speaker = "Artemis"
      Event = "NPC_Artemis_Field_01.UpgradeMenuOpenVoiceLines"
    }
    {
      Id = "Artemis_0167"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's been too long, Sister. Look at you, on your great hunt! Not ideal circumstances but you've finally begun. Know that the family has your back, surprised as they are about this."
      Speaker = "Artemis"
      Event = "ArtemisFirstMeeting"
    }
    {
      Id = "Melinoe_1179"
      InheritFrom = "BaseNarrative"
      DisplayName = "No shortage lately of surprises on Olympus or below. It's good to see you, Artemis. But, I must be off. Time's against us, and all that."
      Speaker = "Melinoe"
      Event = "ArtemisFirstMeeting"
    }
    {
      Id = "Artemis_0168"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Time{#Prev}'s an old fool too busy besieging the mountain of the gods to sense the threat headed his way. Go get him."
      Speaker = "Artemis"
      Event = "ArtemisFirstMeeting"
    }
    {
      Id = "Artemis_0151"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, you look like {#Emph}hell{#Prev}, Sister. Don't have anything to patch you up, but I {#Emph}can {#Prev}help you kill the wretches that did this to you!"
      Speaker = "Artemis"
      Event = "ArtemisLowHealth01"
    }
    {
      Id = "Artemis_0259"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're barely on your feet, Sister. Let's save our breath and concentrate on getting through the rest of this intact. Far as we can, at least."
      Speaker = "Artemis"
      Event = "ArtemisLowHealth02"
    }
    {
      Id = "Artemis_0300"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sorry I couldn't keep them all at bay. I try to pack a few recovery supplies, but have to travel light."
      Speaker = "Artemis"
      Event = "ArtemisLowHealth03"
    }
    {
      Id = "Artemis_0301"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Eugh{#Prev}, one of these evenings where nothing's gone right. Have to push through to the next! Or turn {#Emph}this {#Prev}one around."
      Speaker = "Artemis"
      Event = "ArtemisLowHealth04"
    }
    {
      Id = "Artemis_0171"
      InheritFrom = "BaseNarrative"
      DisplayName = "Has my little brother lived up to his shining reputation so far? At least he did his part. Soon as I told him about {#Emph}you{#Prev}, sure enough he was plenty eager to let all Olympus know."
      Speaker = "Artemis"
      Event = "ArtemisAboutApollo01"
    }
    {
      Id = "Melinoe_1180"
      InheritFrom = "BaseNarrative"
      DisplayName = "Apollo was very kind. Though, easy for me to say, I'm not his twin. What'd you tell him anyway?"
      Speaker = "Melinoe"
      Event = "ArtemisAboutApollo01"
    }
    {
      Id = "Artemis_0172"
      InheritFrom = "BaseNarrative"
      DisplayName = "Only the truth! That I ran into the reclusive Witch of the Crossroads while scouting out our foe... and that she introduced me to a secret {#Emph}Titan killer {#Prev}she's been training up."
      Speaker = "Artemis"
      Event = "ArtemisAboutApollo01"
    }
    {
      Id = "Melinoe_1181"
      InheritFrom = "BaseNarrative"
      DisplayName = "You just didn't tell him how long ago that was. So now they really think this long-lost relative of theirs is going to find Chronos and slay him?"
      Speaker = "Melinoe"
      Event = "ArtemisAboutApollo01"
    }
    {
      Id = "Artemis_0173"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, they think you don't stand a chance! But they don't have a lot of options, so... they'll support you anyway, especially since you're family and all. And you know {#Emph}I {#Prev}will."
      Speaker = "Artemis"
      Event = "ArtemisAboutApollo01"
    }
    {
      Id = "Artemis_0424"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wait, how did you already get Athena's blessing way out {#Emph}here? {#Prev}She's practically a world apart and has been too busy to send messages by Boon..."
      Speaker = "Artemis"
      Event = "ArtemisAboutAthena01"
    }
    {
      Id = "MelinoeField_4119"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have her Gorgon Amulet. Perhaps it's a bit rude of me but with it, she can drop in on whichever unfortunate foes I happen to be facing at the time."
      Speaker = "Melinoe"
      Event = "ArtemisAboutAthena01"
    }
    {
      Id = "Artemis_0425"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, right. She {#Emph}does {#Prev}like her dramatic entrances, and probably doesn't mind giving hints of her power here and there. Well, here's another {#Emph}hint {#Prev}for you."
      Speaker = "Artemis"
      Event = "ArtemisAboutAthena01"
    }
    {
      Id = "Artemis_0159"
      InheritFrom = "BaseNarrative"
      DisplayName = "You bested Sister Hecate! She told me so herself, and with dare-I-say more than a hint of pride. Though, she's intent on testing you still?"
      Speaker = "Artemis"
      Event = "ArtemisAboutHecate01"
    }
    {
      Id = "Melinoe_1192"
      InheritFrom = "BaseNarrative"
      DisplayName = "She always said I can't beat Chronos if I can't beat her. And so we spar. I think she's gone easy on me, to boost my confidence."
      Speaker = "Melinoe"
      Event = "ArtemisAboutHecate01"
    }
    {
      Id = "Artemis_0160"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, I can plainly see she failed. Gone {#Emph}easy? {#Prev}If there's one thing the Witch of the Crossroads hasn't ever done, it's that."
      Speaker = "Artemis"
      Event = "ArtemisAboutHecate01"
    }
    {
      Id = "Artemis_0146"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can often depend on Sister Selene's light to guide me on my hunts. But where you're going, she can't follow, can she? Nor can I."
      Speaker = "Artemis"
      Event = "ArtemisAboutSelene01"
    }
    {
      Id = "Melinoe_1184"
      InheritFrom = "BaseNarrative"
      DisplayName = "And Headmistress Hecate is needed at the Crossroads. I alone have the authority to enter the House of Hades. If I can make it there."
      Speaker = "Melinoe"
      Event = "ArtemisAboutSelene01"
    }
    {
      Id = "Artemis_0147"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, what do you mean {#Emph}if? {#Prev}It's a matter of {#Emph}when{#Prev}, as far as I'm concerned. I'm thinking maybe very {#Emph}soon{#Prev}, in fact."
      Speaker = "Artemis"
      Event = "ArtemisAboutSelene01"
    }
    {
      Id = "Artemis_0198"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can often depend on Sister Selene's light to guide me on my hunts. But where you're going, she can't follow easily, can she? Nor can I."
      Speaker = "Artemis"
      Event = "ArtemisAboutSelene01_B"
    }
    {
      Id = "MelinoeField_2138"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sister Selene has her ways, though I know it's difficult for her, and Headmistress is needed at the Crossroads. I alone have the authority to enter the House of Hades. But I'd have never gotten there without you all."
      Speaker = "Melinoe"
      Event = "ArtemisAboutSelene01_B"
    }
    {
      Id = "Artemis_0199"
      InheritFrom = "BaseNarrative"
      DisplayName = "Could {#Emph}really {#Prev}use a proper hunting party for this one! Fortunately it's kind of our thing as Silver Sisters to not have to be in the same place at the same time."
      Speaker = "Artemis"
      Event = "ArtemisAboutSelene01_B"
    }
    {
      Id = "Artemis_0148"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hermes finally got a hold of you, did he? Sounds like things have really taken a turn on Olympus. Glad I'm not there!"
      Speaker = "Artemis"
      Event = "ArtemisAboutHermes01"
    }
    {
      Id = "Melinoe_1185"
      InheritFrom = "BaseNarrative"
      DisplayName = "Artemis, how can you say that? It's your home. I'm going to see if I can head up there and lend a hand."
      Speaker = "Melinoe"
      Event = "ArtemisAboutHermes01"
    }
    {
      Id = "Artemis_0149"
      InheritFrom = "BaseNarrative"
      DisplayName = "Is that even possible for you, born of the Underworld and all that? Then again, you're a {#Emph}witch! {#Prev}Must have a remedy for everything!"
      Speaker = "Artemis"
      Event = "ArtemisAboutHermes01"
    }
    {
      Id = "MelinoeField_2141"
      InheritFrom = "BaseNarrative"
      DisplayName = "You haven't seen Nemesis tonight, have you? Not that she should be anywhere near here, as opposed to keeping watch over the gateways at the Crossroads."
      Speaker = "Melinoe"
      Event = "ArtemisAboutNemesis01"
    }
    {
      Id = "Artemis_0206"
      InheritFrom = "BaseNarrative"
      DisplayName = "I haven't seen her, no. But I was tracking her! Those footprints are only slightly harder to spot than {#Emph}she {#Prev}is. She's not supposed to be out here, is she..."
      Speaker = "Artemis"
      Event = "ArtemisAboutNemesis01"
    }
    {
      Id = "MelinoeField_2142"
      InheritFrom = "BaseNarrative"
      DisplayName = "...That she is not. She's just trying to make herself useful, I get it. And the Fates themselves know that I could probably use the help. Though, how have you two been?"
      Speaker = "Melinoe"
      Event = "ArtemisAboutNemesis01"
    }
    {
      Id = "Artemis_0207"
      InheritFrom = "BaseNarrative"
      DisplayName = "We each need company, we each need solitude, the same old thing. She's frustrated, which can go a couple of ways depending on the night. Anyway, she's a big girl!"
      Speaker = "Artemis"
      Event = "ArtemisAboutNemesis01"
    }
    {
      Id = "MelinoeField_3371"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey Artemis, if Nemesis and I... if we were closer, would that be all right? I mean with {#Emph}you. {#Prev}Because if not, just say the word. It's probably not going anywhere anyway..."
      Speaker = "Melinoe"
      Event = "ArtemisAboutNemesis02"
    }
    {
      Id = "Artemis_0378"
      InheritFrom = "BaseNarrative"
      DisplayName = "What am I, Sister Hecate? You don't need my permission, not like Nemesis belongs to me, though I've considered trapping her. In all seriousness, good hunting with that one."
      Speaker = "Artemis"
      Event = "ArtemisAboutNemesis02"
    }
    {
      Id = "Artemis_0417"
      InheritFrom = "BaseNarrative"
      DisplayName = "So how has Nemesis been doing, she all right? Seems to finally be getting farther in her own stubborn attempts."
      Speaker = "Artemis"
      Event = "ArtemisAboutNemesis03"
    }
    {
      Id = "MelinoeField_4116"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh she's been well, for her. We've been seeing each other more, and... it's good. As good as she can probably permit."
      Speaker = "Melinoe"
      Event = "ArtemisAboutNemesis03"
    }
    {
      Id = "Artemis_0418"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's great! She did seem a little lighter on her feet, but not {#Emph}too {#Prev}light, of course. You'll have to tell me how you got through her defenses sometime."
      Speaker = "Artemis"
      Event = "ArtemisAboutNemesis03"
    }
    {
      Id = "Artemis_0169"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, is it really true Moros himself showed up at your Crossroads because you {#Emph}summoned {#Prev}him? As in, you {#Emph}literally invited Doom...?"
      Speaker = "Artemis"
      Event = "ArtemisAboutMoros01"
    }
    {
      Id = "MelinoeField_2019"
      InheritFrom = "BaseNarrative"
      DisplayName = "It doesn't seem the wisest course when you put it that way. Chronos once was brought low by a prophecy of the Three Fates. I felt they might be willing to intervene again."
      Speaker = "Melinoe"
      Event = "ArtemisAboutMoros01"
    }
    {
      Id = "Artemis_0170"
      InheritFrom = "BaseNarrative"
      DisplayName = "And they did so by sending you the embodiment of misfortune and unforeseen consequences. Well if that's what the Fates have in store, you're going to need {#Emph}this."
      Speaker = "Artemis"
      Event = "ArtemisAboutMoros01"
    }
    {
      Id = "Artemis_0376"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, do you {#Emph}really {#Prev}understand what Charon's moaning about, or is it all an act... like how creatures sometimes make themselves look bigger, as a form of self defense?"
      Speaker = "Artemis"
      Event = "ArtemisAboutCharon01"
    }
    {
      Id = "MelinoeField_3370"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Artemis! {#Prev}I can't exactly parse each syllable but Charon has spent a great deal of time around souls of the dead. It's really not that different. {#Emph}You {#Prev}can communicate with {#Emph}beasts!"
      Speaker = "Melinoe"
      Event = "ArtemisAboutCharon01"
    }
    {
      Id = "Artemis_0377"
      InheritFrom = "BaseNarrative"
      DisplayName = "I guess, it's just... beasts usually don't have too much to say! Except for cats. Anyway, the boatman probably makes better conversation than some gods I know."
      Speaker = "Artemis"
      Event = "ArtemisAboutCharon01"
    }
    {
      Id = "Artemis_0298"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I hate to even ask, but... have you picked up any trace of Zagreus, by any chance, while in your father's House?"
      Speaker = "Artemis"
      Event = "ArtemisAboutZagreus01"
    }
    {
      Id = "MelinoeField_3369"
      InheritFrom = "BaseNarrative"
      DisplayName = "Artemis, it's... hard for me to say. My brother isn't there, but... I sense his presence; our connection. He's not gone."
      Speaker = "Melinoe"
      Event = "ArtemisAboutZagreus01"
    }
    {
      Id = "Artemis_0299"
      InheritFrom = "BaseNarrative"
      DisplayName = "I guess that's good enough for me, for now. Although it's much more {#Emph}cryptic {#Prev}than I'd like! Well, wherever he is... he better be all right. And not alone."
      Speaker = "Artemis"
      Event = "ArtemisAboutZagreus01"
    }
    {
      Id = "Artemis_0202"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's really true about the Fates, that Chronos somehow got to them? Doesn't want to take any chances anymore. Did the Fates prophesize their own captivity...?"
      Speaker = "Artemis"
      Event = "ArtemisAboutFates01"
    }
    {
      Id = "MelinoeField_2139"
      InheritFrom = "BaseNarrative"
      DisplayName = "How can you be so casual about this? If the Fates themselves couldn't stop Chronos, we won't have an easy time! We're beholden to chance ourselves."
      Speaker = "Melinoe"
      Event = "ArtemisAboutFates01"
    }
    {
      Id = "Artemis_0203"
      InheritFrom = "BaseNarrative"
      DisplayName = "So what if we are! You know not even {#Emph}I {#Prev}always hit my mark. What do I do if I miss? {#Emph}I take another shot. {#Prev}The greater the skill, the less is up to chance."
      Speaker = "Artemis"
      Event = "ArtemisAboutFates01"
    }
    {
      Id = "Artemis_0157"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's strange, isn't it? He's our own grandfather... Chronos, I mean. But, I feel no connection to him at all! I just want him gone."
      Speaker = "Artemis"
      Event = "ArtemisAboutChronos01"
    }
    {
      Id = "Melinoe_1191"
      InheritFrom = "BaseNarrative"
      DisplayName = "Doesn't matter who he is; he's a threat. We're the Silver Sisters. We'll {#Emph}make {#Prev}him gone. For the sake of the realms."
      Speaker = "Melinoe"
      Event = "ArtemisAboutChronos01"
    }
    {
      Id = "Artemis_0158"
      InheritFrom = "BaseNarrative"
      DisplayName = "Strictly business then, is it? Even still, funny how it falls on {#Emph}us {#Prev}to settle the older generation's scores."
      Speaker = "Artemis"
      Event = "ArtemisAboutChronos01"
    }
    {
      Id = "Artemis_0194"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got all the way down to the House of Hades, so I heard. Must be nice having fated authority over the lowest reaches of the Underworld... unless you're Chronos."
      Speaker = "Artemis"
      Event = "ArtemisAboutChronosBossL01"
    }
    {
      Id = "MelinoeField_2136"
      InheritFrom = "BaseNarrative"
      DisplayName = "He was most certainly annoyed. Wields a scythe that's twice my height, surrounds himself with feral Satyr-worshipers ready to die for him. I'm not surprised it once took both our fathers and more to bring him down."
      Speaker = "Melinoe"
      Event = "ArtemisAboutChronosBossL01"
    }
    {
      Id = "Artemis_0195"
      InheritFrom = "BaseNarrative"
      DisplayName = "No reason to compare yourself. They're high and mighty lords of the heavens and the Underworld, but they fought Chronos by necessity. You were trained to do {#Emph}precisely this."
      Speaker = "Artemis"
      Event = "ArtemisAboutChronosBossL01"
    }
    {
      Id = "Artemis_0196"
      InheritFrom = "BaseNarrative"
      DisplayName = "You found Chronos... sank your fangs into his throat. Sister Hecate gave me the gist. How'd you do it...? Found some exploitable weakness, something like that?"
      Speaker = "Artemis"
      Event = "ArtemisAboutChronosBossW01"
    }
    {
      Id = "MelinoeField_2137"
      InheritFrom = "BaseNarrative"
      DisplayName = "Mostly I just kept evading a lot. He's very powerful, but must have underestimated my ability to resist his tricks."
      Speaker = "Melinoe"
      Event = "ArtemisAboutChronosBossW01"
    }
    {
      Id = "Artemis_0197"
      InheritFrom = "BaseNarrative"
      DisplayName = "He won't always underestimate you, though. Must have his vulnerabilities. {#Emph}The old are seldom wise, and often weak{#Prev}, right? He's bloodied... go for the kill."
      Speaker = "Artemis"
      Event = "ArtemisAboutChronosBossW01"
    }
    {
      Id = "Artemis_0407"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're close, aren't you? To putting Chronos down for good. I know you mustn't share the details even with me, but... you'd tell me if I'm wrong."
      Speaker = "Artemis"
      Event = "ArtemisAboutChronosBossW02"
    }
    {
      Id = "MelinoeField_4111"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd tell you, yes. Now then, I hate to make our meetings brief, but I've a certain matter to resolve."
      Speaker = "Melinoe"
      Event = "ArtemisAboutChronosBossW02"
    }
    {
      Id = "Artemis_0408"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then go resolve it, by all means. Tread softly, and strike true, Sister."
      Speaker = "Artemis"
      Event = "ArtemisAboutChronosBossW02"
    }
    {
      Id = "Artemis_0405"
      InheritFrom = "BaseNarrative"
      DisplayName = "Seen Heracles stomping about? As much as I am normally the trusting sort, I don't quite know about that one. He's been on my bad side for a while. Quite rough with animals."
      Speaker = "Artemis"
      Event = "ArtemisAboutHeracles01"
    }
    {
      Id = "MelinoeField_4110"
      InheritFrom = "BaseNarrative"
      DisplayName = "Artemis, you're goddess of the {#Emph}hunt. {#Prev}Animals must be far more afraid of you than him."
      Speaker = "Melinoe"
      Event = "ArtemisAboutHeracles01"
    }
    {
      Id = "Artemis_0406"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now don't you even start with that, Sister. Animals {#Emph}adore {#Prev}me, except when it's their time. But Heracles goes after them whenever he needs. Just watch it with him, OK?"
      Speaker = "Artemis"
      Event = "ArtemisAboutHeracles01"
    }
    {
      Id = "Artemis_0212"
      InheritFrom = "BaseNarrative"
      DisplayName = "You saw we're up against Prometheus. His whole thing is how he knows what's going to take place... makes him quite an elusive one, I guess."
      Speaker = "Artemis"
      Event = "ArtemisAboutPrometheus01"
    }
    {
      Id = "MelinoeField_2449"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Titan of Foresight, fighting for the Titan of Time... perhaps merely against the gods who punished him. He may have his reasons, but he's in my way."
      Speaker = "Melinoe"
      Event = "ArtemisAboutPrometheus01"
    }
    {
      Id = "Artemis_0213"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know precisely what you mean. Though if he really knows the future, wouldn't he choose the winning side...? Careful with him, Sister..."
      Speaker = "Artemis"
      Event = "ArtemisAboutPrometheus01"
    }
    {
      Id = "Artemis_0290"
      InheritFrom = "BaseNarrative"
      DisplayName = "One disadvantage to my being all the way out here is I'm unable to put arrows through Prometheus from such a range. Apollo says he's been a real bother."
      Speaker = "Artemis"
      Event = "ArtemisAboutPrometheus02"
    }
    {
      Id = "MelinoeField_3365"
      InheritFrom = "BaseNarrative"
      DisplayName = "He's a problem and a threat... even unarmed, and seemingly not even at full strength, for he still bears old wounds. He has more than enough fury to make up."
      Speaker = "Melinoe"
      Event = "ArtemisAboutPrometheus02"
    }
    {
      Id = "Artemis_0291"
      InheritFrom = "BaseNarrative"
      DisplayName = "Great, another angry Titan. Well if he's {#Emph}seething {#Prev}all the time, he's liable to make mistakes. It wouldn't be the first time."
      Speaker = "Artemis"
      Event = "ArtemisAboutPrometheus02"
    }
    {
      Id = "MelinoeField_3366"
      InheritFrom = "BaseNarrative"
      DisplayName = "You don't truly believe Prometheus can see the future, do you? He probably just has heightened instincts like yours."
      Speaker = "Melinoe"
      Event = "ArtemisAboutPrometheus03"
    }
    {
      Id = "Artemis_0292"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Excuse me? {#Prev}Nobody has instincts as heightened as {#Emph}these{#Prev}, Sister! But I've never claimed to know {#Emph}precisely {#Prev}what's to come. Even if I could, I think I'd miss all the suspense."
      Speaker = "Artemis"
      Event = "ArtemisAboutPrometheus03"
    }
    {
      Id = "Artemis_0293"
      InheritFrom = "BaseNarrative"
      DisplayName = "We've bigger problems on Olympus than we counted on, I hear. Our worst fears realized and so on? You'd think I'd be more capable of tracking prey that's Typhon's size..."
      Speaker = "Artemis"
      Event = "ArtemisAboutTyphon01"
    }
    {
      Id = "MelinoeField_3367"
      InheritFrom = "BaseNarrative"
      DisplayName = "You were tracking Chronos... me, perhaps. But if it's any consolation, finding Typhon ought to be quite easy at this point! Bringing him down... less so."
      Speaker = "Melinoe"
      Event = "ArtemisAboutTyphon01"
    }
    {
      Id = "Artemis_0294"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll take your word for it. My father's much too proud to call me back to aid in our defense. Says I'm still needed here. If he wants Typhon to himself so badly, he can have him."
      Speaker = "Artemis"
      Event = "ArtemisAboutTyphon01"
    }
    {
      Id = "Artemis_0295"
      InheritFrom = "BaseNarrative"
      DisplayName = "Olympus managed to take Typhon down...? I figure with {#Emph}your {#Prev}aid, probably Sister Selene's too. I guess I wasn't needed up there after all."
      Speaker = "Artemis"
      Event = "ArtemisAboutTyphon02"
    }
    {
      Id = "MelinoeField_3368"
      InheritFrom = "BaseNarrative"
      DisplayName = "We drove the monster back, but I don't think we've properly discouraged him. Not yet, at least. Though I've a few ideas..."
      Speaker = "Melinoe"
      Event = "ArtemisAboutTyphon02"
    }
    {
      Id = "Artemis_0296"
      InheritFrom = "BaseNarrative"
      DisplayName = "If your ideas involve an {#Emph}arrow {#Prev}in his eye, of which I hear he has a {#Emph}lot{#Prev}, let me know... moonlight guide you home tonight."
      Speaker = "Artemis"
      Event = "ArtemisAboutTyphon02"
    }
    {
      Id = "Artemis_0413"
      InheritFrom = "BaseNarrative"
      DisplayName = "I meant to thank you, since our woods and mountains are no longer likely to be crushed beneath a monster's foot or slithering appendages. That's been a big relief."
      Speaker = "Artemis"
      Event = "ArtemisAboutTyphon03"
    }
    {
      Id = "MelinoeField_4114"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, anytime. I wouldn't have liked being crushed that way, either. Sounds like Lord Zeus and Queen Hera had some contingency in mind that was best avoided."
      Speaker = "Melinoe"
      Event = "ArtemisAboutTyphon03"
    }
    {
      Id = "Artemis_0414"
      InheritFrom = "BaseNarrative"
      DisplayName = "Our woods and mountains would have been in even {#Emph}worse {#Prev}shape then. Your way shook Father and Stepmother up a bit... the power to destroy immortals and all that? But it's best they respect you. That's how you get them to be nice!"
      Speaker = "Artemis"
      Event = "ArtemisAboutTyphon03"
    }
    {
      Id = "MelinoeField_2131"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why has Olympus sent you all the way out here, anyway? I thought you'd have gone back by now. You're always welcome in the Crossroads!"
      Speaker = "Melinoe"
      Event = "ArtemisAboutMission01"
    }
    {
      Id = "Artemis_0297"
      InheritFrom = "BaseNarrative"
      DisplayName = "Appreciate it, Sister, and I do have to report back soon enough. As for why I'm all the way out here, mostly to spy on you! Olympus likes to be informed."
      Speaker = "Artemis"
      Event = "ArtemisAboutMission01"
    }
    {
      Id = "MelinoeField_2132"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm certain that they do. Do you ever slip up with them? By now the other gods must have their suspicions about you and Hermes."
      Speaker = "Melinoe"
      Event = "ArtemisAboutMission01"
    }
    {
      Id = "Artemis_0180"
      InheritFrom = "BaseNarrative"
      DisplayName = "Depends on who you're talking about I guess, but for the most part they just think we're young and flighty. But we're the best they've got."
      Speaker = "Artemis"
      Event = "ArtemisAboutMission01"
    }
    {
      Id = "Artemis_0181"
      InheritFrom = "BaseNarrative"
      DisplayName = "When I became one of the Silver Sisters, I figured all we'd really do was stalk in shadows, make occasional reports... but this is a full-on {#Emph}worst-case scenario!"
      Speaker = "Artemis"
      Event = "ArtemisAboutSilverSisters01"
    }
    {
      Id = "MelinoeField_2133"
      InheritFrom = "BaseNarrative"
      DisplayName = "You sound excited rather than dismayed. You must have known it'd come to this eventually. Not like Headmistress would band us together just for ceremony's sake."
      Speaker = "Melinoe"
      Event = "ArtemisAboutSilverSisters01"
    }
    {
      Id = "Artemis_0182"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, I guess you're right. Still, we've been together biding our time for so long... I got to thinking we might never get the opportunity to strike. Yet here we are!"
      Speaker = "Artemis"
      Event = "ArtemisAboutSilverSisters01"
    }
    {
      Id = "Artemis_0386"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey you have an animal companion now! Mine would be with me too, except they won't set foot in the Underworld while they still draw breath... except these birds, which do not seem to care."
      Speaker = "Artemis"
      Event = "ArtemisAboutFamiliars01"
    }
    {
      Id = "MelinoeField_3328"
      InheritFrom = "BaseNarrative"
      DisplayName = "And I suppose they have other excuses for Ephyra? Some companions they are, leaving you to your devices here."
      Speaker = "Melinoe"
      Event = "ArtemisAboutFamiliars01"
    }
    {
      Id = "Artemis_0258"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hah! {#Prev}They're just like us for the most part, except quieter usually. You take good care of yours for me, all right?"
      Speaker = "Artemis"
      Event = "ArtemisAboutFamiliars01"
    }
    {
      Id = "Artemis_0284"
      InheritFrom = "BaseNarrative"
      DisplayName = "Good being in the Crossroads earlier. My aim is steadier, nerves calm again. I don't get any real peace at home... but it's there to be found in the woods."
      Speaker = "Artemis"
      Event = "ArtemisAboutSinging01"
    }
    {
      Id = "MelinoeField_3362"
      InheritFrom = "BaseNarrative"
      DisplayName = "No place to practice singing at home either, I expect. Is it truly that concerning if Apollo hears? He can't be {#Emph}that {#Prev}much better! And he'd probably be proud of you."
      Speaker = "Melinoe"
      Event = "ArtemisAboutSinging01"
    }
    {
      Id = "Artemis_0285"
      InheritFrom = "BaseNarrative"
      DisplayName = "Or he'd tease me incessantly... I'd likely have to put an arrow through him and get into a heap of trouble. Not prepared to take that sort of risk, Sister."
      Speaker = "Artemis"
      Event = "ArtemisAboutSinging01"
    }
    {
      Id = "Artemis_0260"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've tried all my latest Boons by now. Got others I've been mulling, although lately nothing seems to stick! Likely you'd rather have something tried-and-true anyway."
      Speaker = "Artemis"
      Event = "ArtemisAboutBoons01"
    }
    {
      Id = "MelinoeField_3329"
      InheritFrom = "BaseNarrative"
      DisplayName = "From you, Sister, I'll take whatever I can get! A bit of extra precision in my strikes often makes all the difference."
      Speaker = "Melinoe"
      Event = "ArtemisAboutBoons01"
    }
    {
      Id = "Artemis_0261"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I'm not just all about {#Emph}precision {#Prev}here, am I? We gods get cast as one thing and that's it. Father Zeus and his thunder, Uncle Poseidon and his water, Apollo and his... {#Emph}hair."
      Speaker = "Artemis"
      Event = "ArtemisAboutBoons01"
    }
    {
      Id = "Melinoe_1186"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've been so far from home for so long. Don't you miss being on Olympus? If not now, then... back before the Titan's siege?"
      Speaker = "Melinoe"
      Event = "ArtemisAboutFamily01"
    }
    {
      Id = "Artemis_0150"
      InheritFrom = "BaseNarrative"
      DisplayName = "What, you mean being with my father and stepmother, my perfect twin brother, and all the rest? Just because I'm willing to aid them doesn't mean I'm willing to live with them again."
      Speaker = "Artemis"
      Event = "ArtemisAboutFamily01"
    }
    {
      Id = "Artemis_0165"
      InheritFrom = "BaseNarrative"
      DisplayName = "So what do you think of the family? Most of them are stuck on their mountaintop, though... you've seen what they're like."
      Speaker = "Artemis"
      Event = "ArtemisAboutFamily02"
    }
    {
      Id = "Melinoe_2340"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh they don't seem so bad! Especially things being as they are. But you can't stand any of them..."
      Speaker = "Melinoe"
      Event = "ArtemisAboutFamily02"
    }
    {
      Id = "Artemis_0166"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey I wouldn't go {#Emph}that {#Prev}far! Though, yes, they can get under my skin. They're going to owe us {#Emph}big {#Prev}once all of this is over."
      Speaker = "Artemis"
      Event = "ArtemisAboutFamily02"
    }
    {
      Id = "Melinoe_1189"
      InheritFrom = "BaseNarrative"
      DisplayName = "So when you're not aiding me in my repeated failures, what else have you been up to, Artemis? Some special quarry you're after?"
      Speaker = "Melinoe"
      Event = "ArtemisAboutMission02"
    }
    {
      Id = "Artemis_0154"
      InheritFrom = "BaseNarrative"
      DisplayName = "There might be. Olympus has been shaking, for reasons unknown. Sister Selene asked that I look into it. Surely it's nothing, right?"
      Speaker = "Artemis"
      Event = "ArtemisAboutMission02"
    }
    {
      Id = "Artemis_0183"
      InheritFrom = "BaseNarrative"
      DisplayName = "Poor wretches, left to linger here. Could be relaxing in Elysium, or Asphodel at least. No wonder they're upset."
      Speaker = "Artemis"
      Event = "ArtemisAboutErebus01"
    }
    {
      Id = "MelinoeField_2134"
      InheritFrom = "BaseNarrative"
      DisplayName = "Chronos claimed it was an act of magnanimity, unsealing the Underworld gates, letting the dead roam free. This can't possibly be better than when my father ruled."
      Speaker = "Melinoe"
      Event = "ArtemisAboutErebus01"
    }
    {
      Id = "Artemis_0184"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, at least it means I can set foot in these parts without inciting some huge territorial dispute! Setting aside the fact that we're already in the middle of one."
      Speaker = "Artemis"
      Event = "ArtemisAboutErebus01"
    }
    {
      Id = "Artemis_0204"
      InheritFrom = "BaseNarrative"
      DisplayName = "Fine mess we made! Not many hiding-places here compared to Erebus. Might be the end of the line for me... I'm a huntress, not a fisher."
      Speaker = "Artemis"
      Event = "ArtemisAboutOceanus01"
    }
    {
      Id = "MelinoeField_2140"
      InheritFrom = "BaseNarrative"
      DisplayName = "Fishing is a form of hunting, isn't it? Anyway I appreciate the backup, and understand if you're now at the limit of your range. Olympus probably expects you back."
      Speaker = "Melinoe"
      Event = "ArtemisAboutOceanus01"
    }
    {
      Id = "Artemis_0205"
      InheritFrom = "BaseNarrative"
      DisplayName = "They'll want to hear from me! About the situation, and about {#Emph}you{#Prev}, too. You know they still take me and Hermes for their spies? Although, we do tell them a lot..."
      Speaker = "Artemis"
      Event = "ArtemisAboutOceanus01"
    }
    {
      Id = "Artemis_0174"
      InheritFrom = "BaseNarrative"
      DisplayName = "You made it quite a ways up on the surface recently, Sister Selene said. Did it live up to all your hopes and dreams?"
      Speaker = "Artemis"
      Event = "ArtemisAboutSurface01"
    }
    {
      Id = "Melinoe_2339"
      InheritFrom = "BaseNarrative"
      DisplayName = "I tend to have a lot of nightmares, and it did live up to those. The dead are left to linger there. They should be safely in the Underworld!"
      Speaker = "Melinoe"
      Event = "ArtemisAboutSurface01"
    }
    {
      Id = "Artemis_0175"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, Chronos evidently has other ideas for how things should be governed. I know your main objective is below, though... thank you for any aid you can provide up top."
      Speaker = "Artemis"
      Event = "ArtemisAboutSurface01"
    }
    {
      Id = "Artemis_0185"
      InheritFrom = "BaseNarrative"
      DisplayName = "So much for visiting the surface, huh? Not seen a trace of you up there! Don't feel bad. You have nice woods here, too!"
      Speaker = "Artemis"
      Event = "ArtemisAboutSurfacePenalty01"
    }
    {
      Id = "MelinoeField_2135"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm not supposed to be up there... could hardly breathe. But there might be something I can do. Hermes wouldn't have asked me to go if it wasn't important."
      Speaker = "Melinoe"
      Event = "ArtemisAboutSurfacePenalty01"
    }
    {
      Id = "Artemis_0186"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, I guess not. I'd offer to escort you though Olympus wants me to stay out of sight. And I won't bother saying not to push yourself too hard..."
      Speaker = "Artemis"
      Event = "ArtemisAboutSurfacePenalty01"
    }
    {
      Id = "Artemis_0176"
      InheritFrom = "BaseNarrative"
      DisplayName = "Look at {#Emph}you{#Prev}, Sister! Your brother once had us all convinced he was trying to fight his way to Olympus. Now none of us can believe you're trying to do it for real."
      Speaker = "Artemis"
      Event = "ArtemisAboutEphyra01"
    }
    {
      Id = "MelinoeField_2020"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've known Hermes about as long as you, and can count the number of favors he's asked of me on one hand. Besides, I could use the change of scenery."
      Speaker = "Melinoe"
      Event = "ArtemisAboutEphyra01"
    }
    {
      Id = "Artemis_0177"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then by all means! What a time, that you're on your way up to the mountain while I'm on my way down to the Underworld. At least we crossed paths!"
      Speaker = "Artemis"
      Event = "ArtemisAboutEphyra01"
    }
    {
      Id = "MelinoeField_2020_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hermes wouldn't have asked me to go if it wasn't important. Besides, I could use the change of scenery."
      Speaker = "Melinoe"
      Event = "ArtemisAboutEphyra01_B"
    }
    {
      Id = "Artemis_0250"
      InheritFrom = "BaseNarrative"
      DisplayName = "That massive Cyclops Polyphemus... saw him fast asleep the other night! Then {#Emph}you {#Prev}were able to sneak up and incapacitate him, just like {#Emph}that! {#Prev}I stay far downwind of him, myself."
      Speaker = "Artemis"
      Event = "ArtemisAboutPolyphemus01"
    }
    {
      Id = "MelinoeField_2145"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm tempted to just smile and nod through this one, Artemis, but my dealings with the Cyclops haven't involved much stealth. Though at least I can get past him, at this point."
      Speaker = "Melinoe"
      Event = "ArtemisAboutPolyphemus01"
    }
    {
      Id = "Artemis_0251"
      InheritFrom = "BaseNarrative"
      DisplayName = "And how do you get through the Rift beyond the docks, you {#Emph}swim? {#Prev}You still like doing things the hard way. The {#Emph}only {#Prev}way!"
      Speaker = "Artemis"
      Event = "ArtemisAboutPolyphemus01"
    }
    {
      Id = "Artemis_0208"
      InheritFrom = "BaseNarrative"
      DisplayName = "You probably know {#Emph}Eris {#Prev}has been buzzing around Olympus recently? One good lightning bolt from Father Zeus would normally take {#Emph}care {#Prev}of that, but... he's been occupied."
      Speaker = "Artemis"
      Event = "ArtemisAboutEris01"
    }
    {
      Id = "MelinoeField_2143"
      InheritFrom = "BaseNarrative"
      DisplayName = "One good lightning bolt, how about one good arrow? We'd be saved a lot of trouble if Eris were to be plucked from the sky one of these nights."
      Speaker = "Melinoe"
      Event = "ArtemisAboutEris01"
    }
    {
      Id = "Artemis_0209"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd gladly volunteer, it's just that Father has everything {#Emph}well under control. {#Prev}Says I'm needed way out here instead. But if I do spot the wings of Strife... they're going down."
      Speaker = "Artemis"
      Event = "ArtemisAboutEris01"
    }
    {
      Id = "Artemis_0155"
      InheritFrom = "BaseNarrative"
      DisplayName = "Those blades of yours doing you any good? Let me know if you need any, {#Emph}erm... pointers...?"
      Speaker = "Artemis"
      Event = "ArtemisAboutDagger01"
    }
    {
      Id = "Melinoe_1190"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Sister Blades are almost like having you by my side in every fight. Though, you can shoot a lot farther than I can throw..."
      Speaker = "Melinoe"
      Event = "ArtemisAboutDagger01"
    }
    {
      Id = "Artemis_0156"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, don't be so hard on yourself, I can shoot farther than anybody! Especially Apollo. Well, just keep going for their vitals, and you'll be fine."
      Speaker = "Artemis"
      Event = "ArtemisAboutDagger01"
    }
    {
      Id = "Artemis_0210"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, I recognize those blades! Didn't want to let on before, but... now I guess you know. You best be taking care of them! "
      Speaker = "Artemis"
      Event = "ArtemisAboutArtemisAspect01"
    }
    {
      Id = "MelinoeField_2144"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not to worry. I am, I swear! So, {#Emph}you {#Prev}were the bearer of the Sister Blades yourself? Did you have to give them up because of me...?"
      Speaker = "Melinoe"
      Event = "ArtemisAboutArtemisAspect01"
    }
    {
      Id = "Artemis_0211"
      InheritFrom = "BaseNarrative"
      DisplayName = "I gave them up because I did what needed to be done. Hecate so likes her little tests. Anyway I'm glad to see old Lim and Oros in good hands."
      Speaker = "Artemis"
      Event = "ArtemisAboutArtemisAspect01"
    }
    {
      Id = "Artemis_0419"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's strange... I work so closely with Sister Selene, but I've never been any good with her Hexes. Not like {#Emph}you."
      Speaker = "Artemis"
      Event = "ArtemisGrantsReward01"
    }
    {
      Id = "MelinoeField_4117"
      InheritFrom = "BaseNarrative"
      DisplayName = "And I am woefully incompetent with bow-and-arrow, not like {#Emph}you. {#Prev}It's probably Nemesis ensuring none of us have it all."
      Speaker = "Melinoe"
      Event = "ArtemisGrantsReward01"
    }
    {
      Id = "Artemis_0420"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, you're about to get a little {#Emph}closer {#Prev}to that enviable point. Here, a little extra Moon magick for all you've done, and still intend to do. In case you need it."
      Speaker = "Artemis"
      Event = "ArtemisGrantsReward01"
    }
    {
      Id = "Artemis_0252"
      InheritFrom = "BaseNarrative"
      DisplayName = "We Silver Sisters, we're the keepers of the Nocturnal Arms. The blades of Lim and Oros serve Night's will at your command, but there is more to them."
      Speaker = "Artemis"
      Event = "ArtemisGrantsHiddenAspect01"
    }
    {
      Id = "MelinoeField_3401"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're serious? I'm listening. What would you have me do?"
      Speaker = "Melinoe"
      Event = "ArtemisGrantsHiddenAspect01"
    }
    {
      Id = "Artemis_0253"
      InheritFrom = "BaseNarrative"
      DisplayName = "At the Silver Pool, invoke the blades with this: {#Emph}I see your threefold shadow with the Phantom Queen. {#Prev}I think you're ready now. It should be good!"
      Speaker = "Artemis"
      Event = "ArtemisGrantsHiddenAspect01"
    }
    {
      Id = "MelinoeField_3402"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}I see your threefold shadow with the Phantom Queen. {#Prev}A waking-phrase... thank you for the honor, Artemis. Whose Aspect is this, do you know?"
      Speaker = "Melinoe"
      Event = "ArtemisGrantsHiddenAspect01"
    }
    {
      Id = "Artemis_0385"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, no one in particular, just another threefold goddess of shadow, like Sister Hecate but of a different age and place. I shouldn't say more, you'll see for yourself soon enough."
      Speaker = "Artemis"
      Event = "ArtemisGrantsHiddenAspect01"
    }
    {
      Id = "Artemis_0255_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "Those are the Sister Blades... then, that must be the Aspect of the Morrigan. Looks like it suits you pretty well! Maybe we Night-Moon goddesses {#Emph}are {#Prev}all alike."
      Speaker = "Artemis"
      Event = "ArtemisAboutHiddenAspect01"
    }
    {
      Id = "MelinoeField_3497"
      InheritFrom = "BaseNarrative"
      DisplayName = "You mean you never got to wield this Aspect yourself? How did you even learn the waking-phrase you shared?"
      Speaker = "Melinoe"
      Event = "ArtemisAboutHiddenAspect01"
    }
    {
      Id = "Artemis_0256"
      InheritFrom = "BaseNarrative"
      DisplayName = "One too many questions, Melinoë, but no. That Aspect wasn't for me. Maybe some evening you, too, will have the opportunity to pass along some secret knowledge!"
      Speaker = "Artemis"
      Event = "ArtemisAboutHiddenAspect01"
    }
    {
      Id = "Artemis_0426"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know, I set up Zagreus with his {#Emph}own {#Prev}waking-phrase one time, for a hidden Aspect of a bow called Coronacht, which Stepmother once used. He was pretty good with it!"
      Speaker = "Artemis"
      Event = "ArtemisAboutHiddenAspect02"
    }
    {
      Id = "MelinoeField_4120"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh {#Emph}truly? {#Prev}And what else would you say he did better than me, Artemis? Certainly he had more charm, but could he sprint faster than me, too?"
      Speaker = "Melinoe"
      Event = "ArtemisAboutHiddenAspect02"
    }
    {
      Id = "Artemis_0427"
      InheritFrom = "BaseNarrative"
      DisplayName = "Absolutely, {#Emph}much {#Prev}faster. {#Emph}Anyway{#Prev}, the point being, I'm pleased to have seen each of you grow strong, and done my part for the Infernal and Nocturnal Arms alike. "
      Speaker = "Artemis"
      Event = "ArtemisAboutHiddenAspect02"
    }
    {
      Id = "Artemis_0200"
      InheritFrom = "BaseNarrative"
      DisplayName = "Brought the White Antler with you just in case! The stag who gave it up, it was his time. And I vowed to him I'd make it quick. His Shade and I, we still commune every so often!"
      Speaker = "Artemis"
      Event = "ArtemisAboutKeepsake01"
    }
    {
      Id = "MelinoeField_2146"
      InheritFrom = "BaseNarrative"
      DisplayName = "Artemis, your tales have this remarkable capacity to warm the heart and yet disturb the mind. In case you ever need a calling other than the hunt."
      Speaker = "Melinoe"
      Event = "ArtemisAboutKeepsake01"
    }
    {
      Id = "Artemis_0201"
      InheritFrom = "BaseNarrative"
      DisplayName = "If none of this works out, I was thinking {#Emph}songs {#Prev}and {#Emph}music-making? {#Prev}If Apollo can do it, so can {#Emph}I. {#Prev}Though we've not tired of the hunter's life just yet."
      Speaker = "Artemis"
      Event = "ArtemisAboutKeepsake01"
    }
    {
      Id = "Artemis_0403"
      InheritFrom = "BaseNarrative"
      DisplayName = "Glad the old Antler there has served you well. Keep pushing {#Emph}that {#Prev}thing and you're liable to bring the stag who gave it up back to life! Or take over for {#Emph}me {#Prev}on the hunt."
      Speaker = "Artemis"
      Event = "ArtemisAboutKeepsake02"
    }
    {
      Id = "MelinoeField_4109"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh I wouldn't want {#Emph}that... {#Prev}just to be hell-bent on repeatedly hitting my foes in their vital regions. And for some reason your White Antler helps!"
      Speaker = "Melinoe"
      Event = "ArtemisAboutKeepsake02"
    }
    {
      Id = "Artemis_0404"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Some reason? {#Prev}Our {#Emph}bond's {#Prev}the reason, and the Antler's the connection. Just don't get carried away. I take most shots while out of sight, but {#Emph}you {#Prev}are not as shy."
      Speaker = "Artemis"
      Event = "ArtemisAboutKeepsake02"
    }
    {
      Id = "Artemis_0286"
      InheritFrom = "BaseNarrative"
      DisplayName = "There's a particular {#Emph}chill {#Prev}in the air tonight. I almost broke a {#Emph}sweat! {#Prev}Though our foes were partly to blame. I think I know what's going on, Melinoë, but what is going {#Emph}on?"
      Speaker = "Artemis"
      Event = "ArtemisAboutShrine01"
    }
    {
      Id = "MelinoeField_3363"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Testament of Night is what. The Fear and Darkness spread... which may not seem to our immediate benefit, but the Nocturnal Arms grow stronger through it; and the realm."
      Speaker = "Melinoe"
      Event = "ArtemisAboutShrine01"
    }
    {
      Id = "Artemis_0287"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well then! {#Emph}In shadow, we serve; to shadow, we return. {#Prev}Olympus figured it was Chronos up to something. I had my doubts, but... wanted to be sure."
      Speaker = "Artemis"
      Event = "ArtemisAboutShrine01"
    }
    {
      Id = "Artemis_0288"
      InheritFrom = "BaseNarrative"
      DisplayName = "I had more trouble getting here than usual. The Testament of Night again? Nyx herself would surely be impressed with all you've done, spreading {#Emph}fear{#Prev}, creating {#Emph}nightmares..."
      Speaker = "Artemis"
      Event = "ArtemisAboutShrine02"
    }
    {
      Id = "MelinoeField_3364"
      InheritFrom = "BaseNarrative"
      DisplayName = "Through fear comes respect and obedience. Once we're finished, then perhaps the next would-be usurpers with designs on either of our realms are going to think twice."
      Speaker = "Melinoe"
      Event = "ArtemisAboutShrine02"
    }
    {
      Id = "Artemis_0289"
      InheritFrom = "BaseNarrative"
      DisplayName = "That was a rather good impression of your father, Sister. Well, let's go terrify our foes some more, shall we?"
      Speaker = "Artemis"
      Event = "ArtemisAboutShrine02"
    }
    {
      Id = "Artemis_0162"
      InheritFrom = "BaseNarrative"
      DisplayName = "A full Moon... Sister Selene's power at its peak. On nights like this, I really feel my immortality. May our combined strength be enough."
      Speaker = "Artemis"
      Event = "ArtemisAboutMoon01"
    }
    {
      Id = "Melinoe_1193"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, Artemis. Is everything all right?"
      Speaker = "Melinoe"
      Event = "ArtemisSendOff01"
    }
    {
      Id = "Artemis_0161"
      InheritFrom = "BaseNarrative"
      DisplayName = "So much to talk about, so little time, Sister. I'm needed elsewhere, but I wanted to make sure to send you off."
      Speaker = "Artemis"
      Event = "ArtemisSendOff01"
    }
    {
      Id = "Melinoe_1182"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've likely heard I didn't get there, Artemis. Didn't even come close."
      Speaker = "Melinoe"
      Event = "ArtemisAboutRetrying01"
    }
    {
      Id = "Artemis_0143"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sister, I have {#Emph}every {#Prev}faith in you, but not even {#Emph}I {#Prev}believed you were going to vanquish Chronos straightaway. Let's be a little realistic here?"
      Speaker = "Artemis"
      Event = "ArtemisAboutRetrying01"
    }
    {
      Id = "Melinoe_1055"
      InheritFrom = "BaseNarrative"
      DisplayName = "Any progress yet with your investigation?"
      Speaker = "Melinoe"
      Event = "ArtemisAboutProgress01"
    }
    {
      Id = "Artemis_0178"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not near as much as I'd like. Here, let me give you a boost. Maybe you'll get somewhere even if I don't."
      Speaker = "Artemis"
      Event = "ArtemisAboutProgress01"
    }
    {
      Id = "Artemis_0248"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not seen each other in how many nights, Sister? {#Emph}Eugh{#Prev}, I know that's just the way it goes. You're busy, I'm busy, bunch of time goes by, and... here we are."
      Speaker = "Artemis"
      Event = "ArtemisAboutTimePassing01"
    }
    {
      Id = "MelinoeField_2450"
      InheritFrom = "BaseNarrative"
      DisplayName = "Doubtless we've crossed paths repeatedly, just not quite close enough. I feel like a lot's transpired since last we met like this. Where to even begin?"
      Speaker = "Melinoe"
      Event = "ArtemisAboutTimePassing01"
    }
    {
      Id = "Artemis_0249"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh no need, we haven't seen each other but I've still been keeping up. Olympus knows of all your latest exploits! The ones you wouldn't mind me sharing, anyway."
      Speaker = "Artemis"
      Event = "ArtemisAboutTimePassing01"
    }
    {
      Id = "Artemis_0387"
      InheritFrom = "BaseNarrative"
      DisplayName = "We're quite the team, aren't we? And that's {#Emph}without {#Prev}Sisters Hecate and Selene backing us up. Shame that we all have to spread out most of the time."
      Speaker = "Artemis"
      Event = "ArtemisAboutTeamwork01"
    }
    {
      Id = "MelinoeField_4092"
      InheritFrom = "BaseNarrative"
      DisplayName = "We do have several realms to watch. But yes, I have to say it's been a pleasure working with you recently. Singing with you. Having your friendship."
      Speaker = "Melinoe"
      Event = "ArtemisAboutTeamwork01"
    }
    {
      Id = "Artemis_0388"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now don't get sentimental on me, Sister. This is business. And though the world we live in may be looking a bit bleak, at least business is good."
      Speaker = "Artemis"
      Event = "ArtemisAboutTeamwork01"
    }
    {
      Id = "Artemis_0399"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, look what I unearthed from out of a certain hollowed stump! Beneath this thick layer of dirt is the Ambrosia bottle you had me stash away, and we're having it now."
      Speaker = "Artemis"
      Event = "ArtemisAboutAmbrosia01"
    }
    {
      Id = "MelinoeField_4105"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wait, {#Emph}now? {#Prev}Why not save it for the Crossroads where, for instance, we're not spattered with the remnants of our foes?"
      Speaker = "Melinoe"
      Event = "ArtemisAboutAmbrosia01"
    }
    {
      Id = "Artemis_0400"
      InheritFrom = "BaseNarrative"
      DisplayName = "Speak for yourself, I use a bow, I'm {#Emph}clean! {#Prev}But yes, right now. Because if we keep waiting for the perfect time, we'll wait forever. More importantly, you achieved your task, and we barely got to celebrate!"
      Speaker = "Artemis"
      Event = "ArtemisAboutAmbrosia01"
    }
    {
      Id = "MelinoeField_4106"
      InheritFrom = "BaseNarrative"
      DisplayName = "And the moon {#Emph}is {#Prev}new. You make persuasive points, so fine, let's have ourselves a bit. What shall we drink to?"
      Speaker = "Melinoe"
      Event = "ArtemisAboutAmbrosia01"
    }
    {
      Id = "Artemis_0401"
      InheritFrom = "BaseNarrative"
      DisplayName = "To the Silver Sisters... if I'm to skulk in shadow with several other goddesses, I couldn't have asked for a better pack."
      Speaker = "Artemis"
      Event = "ArtemisAboutAmbrosia01"
    }
    {
      Id = "Artemis_0402"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Whew! {#Prev}That was good, and our work hasn't gone anywhere in the meantime. I suppose we should be getting back to it?"
      Speaker = "Artemis"
      Event = "ArtemisAboutAmbrosia01"
    }
    {
      Id = "Artemis_0410"
      InheritFrom = "BaseNarrative"
      DisplayName = "The deed is done, or should I say the {#Emph}task {#Prev}is finally complete. But, you're right back to work!"
      Speaker = "Artemis"
      Event = "ArtemisPostTrueEnding01"
    }
    {
      Id = "MelinoeField_4112"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes, well... call it a habit, or an opportunity to check up on some things. And thank you, Artemis. I won't forget the flight of the Silver Sisters."
      Speaker = "Melinoe"
      Event = "ArtemisPostTrueEnding01"
    }
    {
      Id = "Artemis_0411"
      InheritFrom = "BaseNarrative"
      DisplayName = "Apollo just {#Emph}had {#Prev}to come along, though I won't soon forget it either. Not felt a victory like that in ages. Wait, why {#Emph}are {#Prev}we still fighting?"
      Speaker = "Artemis"
      Event = "ArtemisPostTrueEnding01"
    }
    {
      Id = "MelinoeField_4113"
      InheritFrom = "BaseNarrative"
      DisplayName = "To destroy every last trace of the threat we faced, apparently. So I still need you around as much as ever."
      Speaker = "Melinoe"
      Event = "ArtemisPostTrueEnding01"
    }
    {
      Id = "Artemis_0412"
      InheritFrom = "BaseNarrative"
      DisplayName = "You mean we get to keep {#Emph}this {#Prev}up, and I will have as much target practice as I want? Well {#Emph}OK!"
      Speaker = "Artemis"
      Event = "ArtemisPostTrueEnding01"
    }
    {
      Id = "Artemis_0415"
      InheritFrom = "BaseNarrative"
      DisplayName = "Things are better than I would have thought back home. Still odd to see us dealing with the remnants of the siege, but Father Zeus has been a lot less temperamental, finally."
      Speaker = "Artemis"
      Event = "ArtemisPostTrueEnding02"
    }
    {
      Id = "MelinoeField_4115"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's good to hear, and I'm glad you had the opportunity to be there yourself. So does this mean I won't be seeing you as much out here? They must want you back."
      Speaker = "Melinoe"
      Event = "ArtemisPostTrueEnding02"
    }
    {
      Id = "Artemis_0416"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, between us, they still want me to keep an eye on you, powerful witch that you are. But, I do have to check in now and again, which I don't mind. They've been glad to see {#Emph}me{#Prev}, and to hear all about {#Emph}you{#Prev}, and... I can say hi to the Nymphs!"
      Speaker = "Artemis"
      Event = "ArtemisPostTrueEnding02"
    }
    {
      Id = "Artemis_0421"
      InheritFrom = "BaseNarrative"
      DisplayName = "Everybody on the mountain's going on about the Fates finally turning up. Father wouldn't even be in charge if not for them, so he must not have liked the thought that they were gone..."
      Speaker = "Artemis"
      Event = "ArtemisPostEpilogue01"
    }
    {
      Id = "MelinoeField_4118"
      InheritFrom = "BaseNarrative"
      DisplayName = "But now the Fates have said the influence of gods shall wane to an extent. I can't imagine Lord Uncle Zeus and the rest are too pleased about {#Emph}that."
      Speaker = "Melinoe"
      Event = "ArtemisPostEpilogue01"
    }
    {
      Id = "Artemis_0422"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, but as major prophecies are concerned, it's really not that bad. And besides, it sounds like this new age of theirs might not be for a while, so... we'll worry about it then!"
      Speaker = "Artemis"
      Event = "ArtemisPostEpilogue01"
    }
    {
      Id = "Artemis_0423"
      InheritFrom = "BaseNarrative"
      DisplayName = "Clean and efficient, just the way I like it, Sister. Not been too much to report on my side, and it seems like things are well on yours. Let's keep it moving then, shall we?"
      Speaker = "Artemis"
      Event = "ArtemisAboutSayingLittle01"
    }
    {
      Id = "Artemis_0004"
      InheritFrom = "BaseNarrative"
      DisplayName = "Take this, Sister, and go find your mark."
      Speaker = "Artemis"
      Event = "ArtemisChat01"
    }
    {
      Id = "Artemis_0005"
      InheritFrom = "BaseNarrative"
      DisplayName = "Tread ever softly and strike swift and true, Sister."
      Speaker = "Artemis"
      Event = "ArtemisChat02"
    }
    {
      Id = "Artemis_0006"
      InheritFrom = "BaseNarrative"
      DisplayName = "Happened to be in the area again, so thought I'd stop on by."
      Speaker = "Artemis"
      Event = "ArtemisChat03"
    }
    {
      Id = "Artemis_0007"
      InheritFrom = "BaseNarrative"
      DisplayName = "May Moonlight guide you to your prey, and expose his every weakness."
      Speaker = "Artemis"
      Event = "ArtemisChat04"
    }
    {
      Id = "Artemis_0008"
      InheritFrom = "BaseNarrative"
      DisplayName = "Another night, another duty for the Silver Sisters."
      Speaker = "Artemis"
      Event = "ArtemisChat05"
    }
    {
      Id = "Artemis_0009"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have to say, these woods are not my favorite..."
      Speaker = "Artemis"
      Event = "ArtemisChat06"
    }
    {
      Id = "Artemis_0010"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can't venture any further below, though I can give you this."
      Speaker = "Artemis"
      Event = "ArtemisChat07"
    }
    {
      Id = "Artemis_0011"
      InheritFrom = "BaseNarrative"
      DisplayName = "The skilled huntress keeps her bag of tricks full and with her at all times."
      Speaker = "Artemis"
      Event = "ArtemisChat08"
    }
    {
      Id = "Artemis_0012"
      InheritFrom = "BaseNarrative"
      DisplayName = "Steady yourself, Sister. You have my full support and more."
      Speaker = "Artemis"
      Event = "ArtemisChat09"
    }
    {
      Id = "Artemis_0013"
      InheritFrom = "BaseNarrative"
      DisplayName = "May your aim ever be true. Not unlike mine!"
      Speaker = "Artemis"
      Event = "ArtemisChat10"
    }
    {
      Id = "Artemis_0014"
      InheritFrom = "BaseNarrative"
      DisplayName = "I still think you should try a bow again sometime..."
      Speaker = "Artemis"
      Event = "ArtemisChat11"
    }
    {
      Id = "Artemis_0015"
      InheritFrom = "BaseNarrative"
      DisplayName = "We hunt alone. Although these run-ins aren't so bad!"
      Speaker = "Artemis"
      Event = "ArtemisChat12"
    }
    {
      Id = "Artemis_0016"
      InheritFrom = "BaseNarrative"
      DisplayName = "Always a pleasure working with you, Sister."
      Speaker = "Artemis"
      Event = "ArtemisChat13"
    }
    {
      Id = "Artemis_0017"
      InheritFrom = "BaseNarrative"
      DisplayName = "Go cut that wretched Titan down to size for me, would you?"
      Speaker = "Artemis"
      Event = "ArtemisChat14"
    }
    {
      Id = "Artemis_0018"
      InheritFrom = "BaseNarrative"
      DisplayName = "May none dare stand between a witch and her prey."
      Speaker = "Artemis"
      Event = "ArtemisChat15"
    }
    {
      Id = "Artemis_0019"
      InheritFrom = "BaseNarrative"
      DisplayName = "Fine night for hunting Titans, don't you think?"
      Speaker = "Artemis"
      Event = "ArtemisChat16"
    }
    {
      Id = "Artemis_0020"
      InheritFrom = "BaseNarrative"
      DisplayName = "Picked up the scent of a few stragglers I'll take care of after this..."
      Speaker = "Artemis"
      Event = "ArtemisChat17"
    }
    {
      Id = "Artemis_0021"
      InheritFrom = "BaseNarrative"
      DisplayName = "You'll find your mark. I know you will."
      Speaker = "Artemis"
      Event = "ArtemisChat18"
    }
    {
      Id = "Artemis_0022"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yours is the most dangerous prey of all. I'm a bit envious!"
      Speaker = "Artemis"
      Event = "ArtemisChat19"
    }
    {
      Id = "Artemis_0023"
      InheritFrom = "BaseNarrative"
      DisplayName = "Here's a little something to go with those witching arts of yours."
      Speaker = "Artemis"
      Event = "ArtemisChat20"
    }
    {
      Id = "Artemis_0024"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've got your back, Sister, so just keep moving forward."
      Speaker = "Artemis"
      Event = "ArtemisChat21"
    }
    {
      Id = "Artemis_0025"
      InheritFrom = "BaseNarrative"
      DisplayName = "We're the Silver Sisters, and we never miss our mark."
      Speaker = "Artemis"
      Event = "ArtemisChat22"
    }
    {
      Id = "Artemis_0026"
      InheritFrom = "BaseNarrative"
      DisplayName = "We are the Silver Sisters, and this is our time to shine."
      Speaker = "Artemis"
      Event = "ArtemisChat23"
    }
    {
      Id = "Artemis_0027"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got to say it's nice to get away from it all like this."
      Speaker = "Artemis"
      Event = "ArtemisChat24"
    }
    {
      Id = "Artemis_0028"
      InheritFrom = "BaseNarrative"
      DisplayName = "Fancy running into you again, and here of all places!"
      Speaker = "Artemis"
      Event = "ArtemisChat25"
    }
    {
      Id = "Artemis_0029"
      InheritFrom = "BaseNarrative"
      DisplayName = "You tracked {#Emph}me {#Prev}down this time, I'll have you know!"
      Speaker = "Artemis"
      Event = "ArtemisChat26"
    }
    {
      Id = "Artemis_0030"
      InheritFrom = "BaseNarrative"
      DisplayName = "You were born to do this, Sister, and you're going to succeed."
      Speaker = "Artemis"
      Event = "ArtemisChat27"
    }
    {
      Id = "Artemis_0031"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sure beats being back on that mountaintop, let me tell you."
      Speaker = "Artemis"
      Event = "ArtemisChat28"
    }
    {
      Id = "Artemis_0032"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Moon is full again. May our combined might take you far."
      Speaker = "Artemis"
      Event = "ArtemisChat29"
    }
    {
      Id = "Artemis_0033"
      InheritFrom = "BaseNarrative"
      DisplayName = "A new moon marks a new beginning, so take heart, Sister."
      Speaker = "Artemis"
      Event = "ArtemisChat30"
    }
    {
      Id = "Artemis_0034"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Moon's light wanes again, but your strength needn't falter."
      Speaker = "Artemis"
      Event = "ArtemisChat31"
    }
    {
      Id = "Artemis_0035"
      InheritFrom = "BaseNarrative"
      DisplayName = "As the light of the waxing Moon intensifies, so too does our potential, Sister."
      Speaker = "Artemis"
      Event = "ArtemisChat32"
    }
    {
      Id = "Artemis_0449"
      InheritFrom = "BaseNarrative"
      DisplayName = "Good hunting on the way up to the mountain, Sister."
      Speaker = "Artemis"
      Event = "ArtemisChat33"
    }
    {
      Id = "Artemis_0450"
      InheritFrom = "BaseNarrative"
      DisplayName = "Father better have expressed his gratitude for all you've done."
      Speaker = "Artemis"
      Event = "ArtemisChat34"
    }
    {
      Id = "Artemis_0451"
      InheritFrom = "BaseNarrative"
      DisplayName = "Good of you to deal with Typhon so that we don't have to anymore!"
      Speaker = "Artemis"
      Event = "ArtemisChat35"
    }
    {
      Id = "Artemis_0452"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll cover your tracks, but first, here's something for the road."
      Speaker = "Artemis"
      Event = "ArtemisChat36"
    }
    {
      Id = "Artemis_0453"
      InheritFrom = "BaseNarrative"
      DisplayName = "Next time leave more of them for me, would you?"
      Speaker = "Artemis"
      Event = "ArtemisChat37"
    }
    {
      Id = "Artemis_0467"
      InheritFrom = "BaseNarrative"
      DisplayName = "Clean and efficient, just the way I like it, Sister."
      Speaker = "Artemis"
      Event = "ArtemisChat39"
    }
    {
      Id = "Artemis_0468"
      InheritFrom = "BaseNarrative"
      DisplayName = "Here, a little extra Moon magick for all you've done, and still intend to do."
      Speaker = "Artemis"
      Event = "ArtemisChat40"
    }
    {
      Id = "Artemis_0320"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're clear."
      Speaker = "Artemis"
      Event = "GlobalVoiceLines.ArtemisGatherReactionVoiceLines"
    }
    {
      Id = "Artemis_0321"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Find something?"
