      Event = "GlobalVoiceLines.ArtemisGatherReactionVoiceLines"
    }
    {
      Id = "Artemis_0324"
      InheritFrom = "BaseSubtitle"
      DisplayName = "For the cauldron?"
      Speaker = "Artemis"
      Event = "GlobalVoiceLines.ArtemisGatherReactionVoiceLines"
    }
    {
      Id = "Artemis_0325"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I saw it first."
      Speaker = "Artemis"
      Event = "GlobalVoiceLines.ArtemisGatherReactionVoiceLines"
    }
    {
      Id = "Artemis_0314"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Focus{#Prev}, Sister!"
      Speaker = "Artemis"
      Event = "GlobalVoiceLines.ArtemisGatherReactionVoiceLines"
    }
    {
      Id = "Artemis_0315"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Eyes up, Sister!"
      Speaker = "Artemis"
      Event = "GlobalVoiceLines.ArtemisGatherReactionVoiceLines"
    }
    {
      Id = "Artemis_0316"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Couldn't wait?"
      Speaker = "Artemis"
      Event = "GlobalVoiceLines.ArtemisGatherReactionVoiceLines"
    }
    {
      Id = "Artemis_0317"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Back in the fight!"
      Speaker = "Artemis"
      Event = "GlobalVoiceLines.ArtemisGatherReactionVoiceLines"
    }
    {
      Id = "Artemis_0318"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Now, {#Emph}really?"
      Speaker = "Artemis"
      Event = "GlobalVoiceLines.ArtemisGatherReactionVoiceLines"
    }
    {
      Id = "Artemis_0319"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Got you covered!"
      Speaker = "Artemis"
      Event = "GlobalVoiceLines.ArtemisGatherReactionVoiceLines"
    }
    {
      Id = "Artemis_0371"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How about these?"
