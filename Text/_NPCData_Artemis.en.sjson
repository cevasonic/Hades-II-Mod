{
  /*
  This file was autogenerated on 10/15/2025 at 5:41 PM
  by the BuildText tool.
  */
  lang = "en"
  Texts = [
    {
      Id = "Melinoe_1711"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Together we shine, Sister."
      Speaker = "Melinoe"
      Event = "NPC_Artemis_01.InteractVoiceLines"
    }
    {
      Id = "Melinoe_1697"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Together we shine."
      Speaker = "Melinoe"
      Event = "NPC_Artemis_01.InteractVoiceLines"
    }
    {
      Id = "Artemis_0130"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Moonlight guide you."
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.InteractVoiceLines"
    }
    {
      Id = "Artemis_0132"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Stay safe, Sister."
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.InteractVoiceLines"
    }
    {
      Id = "Artemis_0137"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Erm{#Prev}, hey?"
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.InteractVoiceLines"
    }
    {
      Id = "Artemis_0241"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Together we shine!"
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.InteractVoiceLines"
    }
    {
      Id = "Artemis_0242"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hello again."
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.InteractVoiceLines"
    }
    {
      Id = "Artemis_0243"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hey."
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.InteractVoiceLines"
    }
    {
      Id = "Artemis_0244"
      InheritFrom = "BaseSubtitle"
      DisplayName = "He's marked."
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.InteractVoiceLines"
    }
    {
      Id = "Artemis_0245"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You, too."
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.InteractVoiceLines"
    }
    {
      Id = "Artemis_0246"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You as well."
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.InteractVoiceLines"
    }
    {
      Id = "Artemis_0247"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And our aim be true."
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.InteractVoiceLines"
    }
    {
      Id = "Artemis_0302"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Go{#Prev}, Sister!"
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.SingingReactionVoiceLines"
    }
    {
      Id = "Artemis_0303"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Sing {#Prev}it!"
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.SingingReactionVoiceLines"
    }
    {
      Id = "Artemis_0304"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's it!"
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.SingingReactionVoiceLines"
    }
    {
      Id = "Artemis_0305"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Together now!"
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.SingingReactionVoiceLines"
    }
    {
      Id = "Artemis_0306"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Melinoë!"
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.SingingReactionVoiceLines"
    }
    {
      Id = "Artemis_0307"
      InheritFrom = "BaseSubtitle"
      DisplayName = "There we go!"
      Speaker = "Artemis"
      Event = "NPC_Artemis_01.SingingReactionVoiceLines"
    }
    {
      Id = "Artemis_0152"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey Melinoë, I just wrapped a debrief here with Sister Hecate. This place has changed a {#Emph}lot {#Prev}since last I checked!"
      Speaker = "Artemis"
      Event = "ArtemisHubFirstMeeting01"
    }
    {
      Id = "Melinoe_1187"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hi Artemis, welcome! We've had to scramble a bit to make ready for everything. Can I show you around? Have you said hi to Nemesis?"
      Speaker = "Melinoe"
      Event = "ArtemisHubFirstMeeting01"
    }
    {
      Id = "Artemis_0153"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, {#Emph}no{#Prev}, I have to go. Olympus needs me back up top, at least a little while. Maybe next time, all right?"
      Speaker = "Artemis"
      Event = "ArtemisHubFirstMeeting01"
    }
    {
      Id = "Melinoe_1188"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I hear you. Bye for now."
      Speaker = "Melinoe"
      Event = "ArtemisHubFirstMeeting01"
    }
    {
      Id = "Artemis_0187"
      InheritFrom = "BaseNarrative"
      DisplayName = "Good, there you are! I'm late getting back but couldn't bring myself to leave before you were up and about again. How are you feeling?"
      Speaker = "Artemis"
      Event = "ArtemisHubAboutChronosBoss01"
    }
    {
      Id = "Melinoe_3598"
      InheritFrom = "BaseNarrative"
      DisplayName = "Considering the Titan of Time almost sliced me in two last night with a scythe twice my size that cuts through the air itself, I could be worse. Thank you for waiting up for me."
      Speaker = "Melinoe"
      Event = "ArtemisHubAboutChronosBoss01"
    }
    {
      Id = "Artemis_0188"
      InheritFrom = "BaseNarrative"
      DisplayName = "Of course! I like what you've done to this place. It's like a proper war camp now! With a taverna, hot springs... I ought to stop in more often. Shine on without me for now!"
      Speaker = "Artemis"
      Event = "ArtemisHubAboutChronosBoss01"
    }
    {
      Id = "Melinoe_3497"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Shine on yourself!"
      Speaker = "Melinoe"
      Event = "ArtemisHubAboutChronosBoss01"
    }
    {
      Id = "Melinoe_4028"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, didn't mean to interrupt. I'd not expected this to be a time for song, though neither am I complaining."
      Speaker = "Melinoe"
      Event = "ArtemisHubSinging01"
    }
    {
      Id = "Artemis_0262"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nor should you be! Hey, since you're here, why not lend me your voice for old time's sake? Let go your burdens for a bit. Not like they're going anywhere."
      Speaker = "Artemis"
      Event = "ArtemisHubSinging01"
    }
    {
      Id = "Artemis_0263"
      InheritFrom = "BaseNarrative"
      DisplayName = "I see that look and know you must be going through a lot, Melinoë. But don't forget what we decided here."
      Speaker = "Artemis"
      Event = "ArtemisHubSinging02"
    }
    {
      Id = "Melinoe_4029"
      InheritFrom = "BaseNarrative"
      DisplayName = "We leave our worries at the threshold to this little clearing, yes... though, don't you ever slip? Catch your mind drifting back to your concerns?"
      Speaker = "Melinoe"
      Event = "ArtemisHubSinging02"
    }
    {
      Id = "Artemis_0264"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's what the song is for! It doesn't make our troubles go away; it's so we can face them as best we can."
      Speaker = "Artemis"
      Event = "ArtemisHubSinging02"
    }
    {
      Id = "Melinoe_4030"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sister Artemis. I really have to talk to you about something of the utmost importance, right now."
      Speaker = "Melinoe"
      Event = "ArtemisHubSinging03"
    }
    {
      Id = "Artemis_0265"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nice try, Sister Melinoë, but I won't break that easily. Not {#Emph}here! {#Prev}Now are you going to join in or not?"
      Speaker = "Artemis"
      Event = "ArtemisHubSinging03"
    }
    {
      Id = "Artemis_0266"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've heard about the latest happenings, Sister, but we'll discuss them out there on the hunt. Not while we're here."
      Speaker = "Artemis"
      Event = "ArtemisHubSinging04"
    }
    {
      Id = "Artemis_0430"
      InheritFrom = "BaseNarrative"
      DisplayName = "Who is that Shade across the river over there, with all the parchment stacks? Never looks directly at me but keeps glancing over, as though it isn't obvious."
      Speaker = "Artemis"
      Event = "ArtemisHubSingingAboutRecordKeeper01"
    }
    {
      Id = "Melinoe_4941"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, you must mean the Record Keeper, who's probably just intrigued by your beautiful song. And likely is keeping meticulous track somewhere of each time you sing."
      Speaker = "Melinoe"
      Event = "ArtemisHubSingingAboutRecordKeeper01"
    }
    {
      Id = "Artemis_0431"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well it's a good thing I am not self-conscious in the least."
      Speaker = "Artemis"
      Event = "ArtemisHubSingingAboutRecordKeeper01"
    }
    {
      Id = "Artemis_0432"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hey Record Keeper! This one's for you!"
      Speaker = "Artemis"
      Event = "ArtemisHubSingingAboutRecordKeeper01"
    }
    {
      Id = "Artemis_0428"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll admit it, Apollo had a lot to do with this one. But I still like it... and it reminds me of how we all got to soar together through the sky. Join me a bit?"
      Speaker = "Artemis"
      Event = "ArtemisHubSingingEndTheme01"
    }
    {
      Id = "Artemis_0267"
      InheritFrom = "BaseNarrative"
      DisplayName = "On a bit of a break, Sister. Join me for a verse or two?"
      Speaker = "Artemis"
      Event = "ArtemisHubSingingRepeatable01"
    }
    {
      Id = "Artemis_0268"
      InheritFrom = "BaseNarrative"
      DisplayName = "Apollo gets to do the singing on Olympus, I get to do it here."
      Speaker = "Artemis"
      Event = "ArtemisHubSingingRepeatable02"
    }
    {
      Id = "Artemis_0269"
      InheritFrom = "BaseNarrative"
      DisplayName = "We all have our little rituals to calm our nerves."
      Speaker = "Artemis"
      Event = "ArtemisHubSingingRepeatable03"
    }
    {
      Id = "Artemis_0270"
      InheritFrom = "BaseNarrative"
      DisplayName = "I always liked it here, and the Shades don't seem to mind."
      Speaker = "Artemis"
      Event = "ArtemisHubSingingRepeatable04"
    }
    {
      Id = "Artemis_0271"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not concerned about a thing, nor should you be. Not here."
      Speaker = "Artemis"
      Event = "ArtemisHubSingingRepeatable05"
    }
    {
      Id = "Artemis_0272"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your body has recovered, sure. But what about your mind?"
      Speaker = "Artemis"
      Event = "ArtemisHubSingingRepeatable06"
    }
    {
      Id = "Artemis_0273"
      InheritFrom = "BaseNarrative"
      DisplayName = "This is our song of victory; or any occasion, really. Want in?"
      Speaker = "Artemis"
      Event = "ArtemisHubSingingRepeatable07"
    }
    {
      Id = "Artemis_0274"
      InheritFrom = "BaseNarrative"
      DisplayName = "When things don't go our way, we sing... if only for a little bit."
      Speaker = "Artemis"
      Event = "ArtemisHubSingingRepeatable08"
    }
    {
      Id = "Artemis_0275"
      InheritFrom = "BaseNarrative"
      DisplayName = "Things did not go well last night, but that's all in the past."
      Speaker = "Artemis"
      Event = "ArtemisHubSingingRepeatable09"
    }
    {
      Id = "Artemis_0276"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have to get back to the hunt here soon, though... not just yet."
      Speaker = "Artemis"
      Event = "ArtemisHubSingingRepeatable10"
    }
    {
      Id = "Artemis_0277"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, I can't exactly practice like this on Olympus, you know!"
      Speaker = "Artemis"
      Event = "ArtemisHubSingingRepeatable11"
    }
    {
      Id = "Artemis_0278"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't think too much about it, Sister, just join in a little while."
      Speaker = "Artemis"
      Event = "ArtemisHubSingingRepeatable12"
    }
    {
      Id = "Artemis_0279"
      InheritFrom = "BaseNarrative"
      DisplayName = "No need to use our plain old speaking voices here, Sister."
      Speaker = "Artemis"
      Event = "ArtemisHubSingingRepeatable13"
    }
    {
      Id = "Artemis_0280"
      InheritFrom = "BaseNarrative"
      DisplayName = "I feel self-conscious singing on Olympus, but not here."
      Speaker = "Artemis"
      Event = "ArtemisHubSingingRepeatable14"
    }
    {
      Id = "Artemis_0281"
      InheritFrom = "BaseNarrative"
      DisplayName = "This song is dedicated to all the Shades out there!"
      Speaker = "Artemis"
      Event = "ArtemisHubSingingRepeatable15"
    }
    {
      Id = "Artemis_0282"
      InheritFrom = "BaseNarrative"
      DisplayName = "Each night brings us new possibility, and I will sing to that!"
      Speaker = "Artemis"
      Event = "ArtemisHubSingingRepeatable16"
    }
    {
      Id = "Artemis_0283"
      InheritFrom = "BaseNarrative"
      DisplayName = "Done with singing already...? Well I'm done with chatting!"
      Speaker = "Artemis"
      Event = "ArtemisHubSingingRepeatable17"
    }
    {
      Id = "Artemis_0429"
      InheritFrom = "BaseNarrative"
      DisplayName = "Apollo's not around to sing the other part, but you sure are!"
      Speaker = "Artemis"
      Event = "ArtemisHubSingingRepeatable18"
    }
    {
      Id = "Melinoe_1194"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's been a pleasure to have worked more closely with you, Sister Artemis. This is hardly worth the gift of impeccable precision, though I wanted you to have it."
      Speaker = "Melinoe"
      Event = "ArtemisGift01"
    }
    {
      Id = "Artemis_0163"
      InheritFrom = "BaseNarrative"
      DisplayName = "Doing the old traditions now, are we? Well sure, then I accept your offering, Sister Melinoë. And I've an offering for {#Emph}you{#Prev}, in kind!"
      Speaker = "Artemis"
      Event = "ArtemisGift01"
    }
    {
      Id = "Artemis_0164"
      InheritFrom = "BaseNarrative"
      DisplayName = "You do know we have {#Emph}barrels {#Prev}of this stuff up on Olympus, right? Used to, at least. Damn near forgotten what it tastes like, come to think..."
      Speaker = "Artemis"
      Event = "ArtemisGift02"
    }
    {
      Id = "Melinoe_1195"
      InheritFrom = "BaseNarrative"
      DisplayName = "May the good memories come flooding back! Whenever you have the time for it, of course."
      Speaker = "Melinoe"
      Event = "ArtemisGift02"
    }
    {
      Id = "Artemis_0189"
      InheritFrom = "BaseNarrative"
      DisplayName = "What's all this extra generosity from you lately? It's putting me on edge. Don't you go acting like this is goodbye...!"
      Speaker = "Artemis"
      Event = "ArtemisGift03"
    }
    {
      Id = "Melinoe_2341"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's merely that the arrow-riddled remnants of my foes give me occasion to reflect! I tell myself never to take my dear friends for granted."
      Speaker = "Melinoe"
      Event = "ArtemisGift03"
    }
    {
      Id = "Artemis_0190"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can't exactly drink this on the hunt, you know! But I can squirrel it away for safekeeping. Maybe once all this is settled, we can share a bottle and get properly caught up."
      Speaker = "Artemis"
      Event = "ArtemisGift04"
    }
    {
      Id = "Melinoe_2342"
      InheritFrom = "BaseNarrative"
      DisplayName = "Or, failing that, we could always keep on teaming against vengeful spirits and the like! Although it's nice to keep the possibility in mind."
      Speaker = "Melinoe"
      Event = "ArtemisGift04"
    }
    {
      Id = "Artemis_0191"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, thank you! Olympus started running a little low on this stuff. I'll be sure to lord it over the others, as long as you don't mind me exploiting your good graces."
      Speaker = "Artemis"
      Event = "ArtemisGift05"
    }
    {
      Id = "Melinoe_3502"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't recall anything about exploiting one another's good graces in the bylaws of the Silver Sisters, so you should be fine! May you enjoy it either way."
      Speaker = "Melinoe"
      Event = "ArtemisGift05"
    }
    {
      Id = "Artemis_0192"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Hard making friends with goddesses, but I have what {#Emph}I {#Prev}need. We can be on our own without feeling alone, you know? I hope you know. That's how it is for me."
      Speaker = "Artemis"
      Event = "ArtemisGift06"
    }
    {
      Id = "Melinoe_3503"
      InheritFrom = "BaseNarrative"
      DisplayName = "I do know, and feel much the same. When we're not watching one another's backs, we have Selene and Headmistress watching over us. Still, it's always good to see you face-to-face."
      Speaker = "Melinoe"
      Event = "ArtemisGift06"
    }
    {
      Id = "Artemis_0193"
      InheritFrom = "BaseNarrative"
      DisplayName = "You, too. Most of my family I can do without most of the time. You're an exception! We may not be sisters by blood, but... you'll always be Sister Melinoë to me."
      Speaker = "Artemis"
      Event = "ArtemisGift06"
    }
    {
      Id = "Melinoe_3504"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Likewise, Sister Artemis."
      Speaker = "Melinoe"
      Event = "ArtemisGift06"
    }
    {
      Id = "MelinoeField_4093"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, thought I'd get you some of the good stuff. I suppose there's a real possibility it's become somewhat easier to come by here than where you call home."
      Speaker = "Melinoe"
      Event = "ArtemisGift07"
    }
    {
      Id = "Artemis_0389"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, Ambrosia! Callisto always used to love this stuff. Maybe I'll call on her again once things cool off a bit."
      Speaker = "Artemis"
      Event = "ArtemisGift07"
    }
    {
      Id = "MelinoeField_4094"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your assignment must have taken you away from her... I'm sorry, I didn't even consider that till just now. She isn't angry with you, is she?"
      Speaker = "Melinoe"
      Event = "ArtemisGift07"
    }
    {
      Id = "Artemis_0390"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well when she turns into a bear it usually means she is, and she'd been doing that a lot. So it's good we're on a little break! It means I'm {#Emph}much {#Prev}less likely to get mauled."
      Speaker = "Artemis"
      Event = "ArtemisGift07"
    }
    {
      Id = "MelinoeField_4095"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got something for you and perhaps Callisto here, if you decide to brave the dangers of approaching her again."
      Speaker = "Melinoe"
      Event = "ArtemisGift08"
    }
    {
      Id = "Artemis_0391"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, thank you very much! I haven't yet decided whether to share this stuff with my Nymph friends, when I {#Emph}could {#Prev}just hoard it all for {#Emph}myself..."
      Speaker = "Artemis"
      Event = "ArtemisGift08"
    }
    {
      Id = "MelinoeField_4096"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wouldn't taste any better that way, so you might as well share it or at least pass it on to someone who shall. Not getting on with the Nymphs as much lately?"
      Speaker = "Melinoe"
      Event = "ArtemisGift08"
    }
    {
      Id = "Artemis_0392"
      InheritFrom = "BaseNarrative"
      DisplayName = "They're not keen about me going off to war. It's like I'm not even the goddess of the hunt to them, which is part of the appeal, granted. But, you and I, we have a job to do."
      Speaker = "Artemis"
      Event = "ArtemisGift08"
    }
    {
      Id = "MelinoeField_4097"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We do."
      Speaker = "Melinoe"
      Event = "ArtemisGift08"
    }
    {
      Id = "MelinoeField_4098"
      InheritFrom = "BaseNarrative"
      DisplayName = "This one is just for you, Artemis, so don't even think about giving it to your Nymph friends. Not even Callisto, no matter how threatening her bear form may be."
      Speaker = "Melinoe"
      Event = "ArtemisGift09"
    }
    {
      Id = "Artemis_0393"
      InheritFrom = "BaseNarrative"
      DisplayName = "OK, OK, if you insist! But, what am I supposed to do with it? I travel light, and lately haven't often stopped by home."
      Speaker = "Artemis"
      Event = "ArtemisGift09"
    }
    {
      Id = "MelinoeField_4099"
      InheritFrom = "BaseNarrative"
      DisplayName = "How about you stash it away, under a rock, or in a hollowed stump or somesuch place? And one of these nights, we can enjoy it for ourselves."
      Speaker = "Melinoe"
      Event = "ArtemisGift09"
    }
    {
      Id = "Artemis_0394"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now {#Emph}that {#Prev}is a proper plan, Sister Melinoë. I'll hold you to it though, you realize. How about we wait until the Moon is new... don't want Sister Selene getting the wrong idea."
      Speaker = "Artemis"
      Event = "ArtemisGift09"
    }
    {
      Id = "MelinoeField_4100"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hahah{#Prev}, fine."
      Speaker = "Melinoe"
      Event = "ArtemisGift09"
    }
    {
      Id = "MelinoeField_4101"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey, I did want to hand over one last bottle, and by {#Emph}last {#Prev}I mean until we find ourselves in different circumstances finally. But {#Emph}this {#Prev}one is for your Nymph friends, {#Emph}not {#Prev}you."
      Speaker = "Melinoe"
      Event = "ArtemisGift10"
    }
    {
      Id = "Artemis_0395"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh! {#Prev}Have all my tales of Callisto piqued your interest there, Melinoë? Because I'm open to sharing, and I know {#Emph}she {#Prev}is."
      Speaker = "Artemis"
      Event = "ArtemisGift10"
    }
    {
      Id = "MelinoeField_4102"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}No! {#Prev}I mean, that wasn't my intent, it's just... if they've been close with you, and raised your spirits, then I'm grateful for them. They must be worried about you."
      Speaker = "Melinoe"
      Event = "ArtemisGift10"
    }
    {
      Id = "Artemis_0396"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't know {#Emph}why{#Prev}, when I constantly tell them not to. Though thank you, really. And I'll pass this on next chance I get, with your compliments. But first, promise me one thing."
      Speaker = "Artemis"
      Event = "ArtemisGift10"
    }
    {
      Id = "MelinoeField_4103"
      InheritFrom = "BaseNarrative"
      DisplayName = "I just gave you multiple Ambrosia bottles and you want a promise, too? What is it, then?"
      Speaker = "Melinoe"
      Event = "ArtemisGift10"
    }
    {
      Id = "Artemis_0397"
      InheritFrom = "BaseNarrative"
      DisplayName = "You can survive on the surface for a while, so... come join us in our woods sometime. Doesn't have to be soon, wait till all this is over. I just think you'd enjoy it."
      Speaker = "Artemis"
      Event = "ArtemisGift10"
    }
    {
      Id = "MelinoeField_4104"
      InheritFrom = "BaseNarrative"
      DisplayName = "...All right. When all this is over, I promise to meet your Nymph friends in your woods, and enjoy it."
      Speaker = "Melinoe"
      Event = "ArtemisGift10"
    }
    {
      Id = "Artemis_0398"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll hold you to that."
      Speaker = "Artemis"
      Event = "ArtemisGift10"
    }
    {
