{
  /*
  This file was autogenerated on 10/21/2025 at 4:08 PM
  by the BuildText tool.
  */
  lang = "en"
  Texts = [
    {
      Id = "Melinoe_0633"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The trident sigil..."
      Speaker = "Melinoe"
      Event = "PoseidonUpgrade.FirstSpawnVoiceLines"
    }
    {
      Id = "Melinoe_1474"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It's Poseidon..."
      Speaker = "Melinoe"
      Event = "PoseidonUpgrade.OnSpawnVoiceLines"
    }
    {
      Id = "Melinoe_1475"
      InheritFrom = "BaseSubtitle"
      DisplayName = "He's back..."
      Speaker = "Melinoe"
      Event = "PoseidonUpgrade.OnSpawnVoiceLines"
    }
    {
      Id = "Poseidon_0082"
      InheritFrom = "BaseNarrative"
      DisplayName = "Our combined might was once {#Emph}more {#Prev}than enough to vanquish Chronos, little Niece! Although it also took the wisdom of my noble brother, Zeus, who formed our plan! We've quite the plan this time as well, don't we, Brother?!"
      Speaker = "Poseidon"
      Event = "PoseidonWithZeus01"
    }
    {
      Id = "Zeus_0087"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, Poseidon, always raring to go. A good plan needn't be discussed out in the open. For now, young Melinoë? We offer you that combined might of ours! Please complicate things for our foes, would you?"
      Speaker = "Zeus"
      Event = "PoseidonWithZeus01"
    }
    {
      Id = "Poseidon_0265"
      InheritFrom = "BaseNarrative"
      DisplayName = "The only greater strength than that belonging to Lord Zeus, my niece, is his combined with mine! Lightning can surge across my waters even faster than it ravages the land! And now, my kingly brother and I grant our terrifying might to you!"
      Speaker = "Poseidon"
      Event = "PoseidonWithZeus02"
    }
    {
      Id = "Zeus_0156"
      InheritFrom = "BaseNarrative"
      DisplayName = "We {#Emph}lend {#Prev}our terrifying might to you, that is, Melinoë. For our family is a partnership, and we give as well as take. Now go and use our united strength to take back what's ours!"
      Speaker = "Zeus"
      Event = "PoseidonWithZeus02"
    }
    {
      Id = "Poseidon_0267"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ahoy{#Prev}, my little niece, I'm here with the spectacular Queen Hera, fairest wife of my distinguished brother, and all that! Shame I have never found myself a perfect mate as she! {#Emph}You{#Prev}'d bless us if I did, wouldn't you, Hera?"
      Speaker = "Poseidon"
      Event = "PoseidonWithHera01"
    }
    {
      Id = "Hera_0102"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, I'll assuredly bless you {#Emph}and {#Prev}your beloved mate whomever they may be, Poseidon. Perhaps when all of this is over, you may resume your search in earnest! But until such time, get your mind out of the gutter."
      Speaker = "Hera"
      Event = "PoseidonWithHera01"
    }
    {
      Id = "Poseidon_0041"
      InheritFrom = "BaseNarrative"
      DisplayName = "Have you yet come to know golden Apollo, Niece? He's so well known and loved among the mortals that he had no choice but to involve himself in our most recent family affair! Bending to mortal pressure like a bow, {#Emph}hah!"
      Speaker = "Poseidon"
      Event = "PoseidonWithApollo01"
    }
    {
      Id = "Apollo_0092"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, come now, Uncle, I don't yield to pressure quite so easily. I just knew this situation would be more than you could handle on your own! We're not just family, we're a team, aren't we?"
      Speaker = "Apollo"
      Event = "PoseidonWithApollo01"
    }
    {
      Id = "Poseidon_0186"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, my niece, you ought to know that Elder Goddess Demeter and I, we may jeer and jest at one another, but it's never out of spite! Isn't that right, dear foster-sister?"
      Speaker = "Poseidon"
      Event = "PoseidonWithDemeter01"
    }
    {
      Id = "Demeter_0072"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, Poseidon! You needn't lie to young Melinoë like that. It sends a terrible impression, and may make her hold you in as much contempt as do I! But let's cooperate for now, why not?"
      Speaker = "Demeter"
      Event = "PoseidonWithDemeter01"
    }
    {
      Id = "Poseidon_0269"
      InheritFrom = "BaseNarrative"
      DisplayName = "When battle rages all around, there's little time for love, little room for beauty! Yet Aphrodite here, she never loses heart! It's almost precious how she strives with all her might, brandishing that decorative spear of hers!"
      Speaker = "Poseidon"
      Event = "PoseidonWithAphrodite01"
    }
    {
      Id = "Aphrodite_0145"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, good Lord Poseidon, I'm pleased to know how I {#Emph}inspire {#Prev}you. Though perhaps you ought pay more attention to our {#Emph}foes {#Prev}than to what {#Emph}I {#Prev}do with my spear, so we can turn this battle in our favor, finally!"
      Speaker = "Aphrodite"
      Event = "PoseidonWithAphrodite01"
    }
    {
      Id = "Poseidon_0271"
      InheritFrom = "BaseNarrative"
      DisplayName = "My niece, we all must tirelessly work to counteract the harm Chronos has wrought! Some even more tirelessly than the rest! Take, for instance, my nephew Hephaestus here! I told him he could have a word if he got back to hammering after!"
      Speaker = "Poseidon"
      Event = "PoseidonWithHephaestus01"
    }
    {
      Id = "Hephaestus_0124"
      InheritFrom = "BaseNarrative"
      DisplayName = "See how generous our Lord Poseidon is? {#Emph}Everybody {#Prev}needs a decent uncle, I say! Let me know should you ever find one. Now... {#Emph}we {#Prev}here best get back to hammering things out."
      Speaker = "Hephaestus"
      Event = "PoseidonWithHephaestus01"
    }
    {
      Id = "Poseidon_0273"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have known Hestia practically since the cataclysmic day that I was born! Although when things are normal we avoid each other at all costs, she's like an old, wise sister to me at this point, and I am glad she's here! {#Emph}Right {#Prev}here!"
      Speaker = "Poseidon"
      Event = "PoseidonWithHestia01"
    }
    {
      Id = "Hestia_0150"
      InheritFrom = "BaseNarrative"
      DisplayName = "You {#Emph}best {#Prev}be glad I'm here, you lug! Lest I leave all of you again to fend for your own damn selves. You won't be putting Chronos back into the ground without me, anyhow! That goes for you, too, hot stuff."
      Speaker = "Hestia"
      Event = "PoseidonWithHestia01"
    }
    {
      Id = "Poseidon_0353"
      InheritFrom = "BaseNarrative"
      DisplayName = "He may not always make for the most {#Emph}pleasant {#Prev}company, but times of {#Emph}peace {#Prev}don't always last, and my good nephew Ares here is excellent to have around for {#Emph}that! {#Prev}Now don't be shy, Ares! Come greet my niece would you?"
      Speaker = "Poseidon"
      Event = "PoseidonWithAres01"
    }
    {
      Id = "Ares_0082"
      InheritFrom = "BaseNarrative"
      DisplayName = "My kin and I are already acquainted, Lord Uncle. Though she may not be overly familiar yet with what we can achieve when we combine your influence over the raging sea with what I do."
      Speaker = "Ares"
      Event = "PoseidonWithAres01"
    }
    {
      Id = "Melinoe_0634"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're one of my father's brothers, aren't you? Then, help him! {#Emph}In the name of Hades! Olympus, I accept this message!"
      Speaker = "Melinoe"
      Event = "PoseidonFirstPickUp"
    }
    {
      Id = "Poseidon_0212"
      InheritFrom = "BaseNarrative"
      DisplayName = "My long-lost niece, {#Emph}you live! {#Prev}We thought you met the same fate as your father! And your mother, {#Emph}and {#Prev}your brother, {#Emph}augh! {#Prev}Well how about we turn the tide, and exact terrible revenge for poor old Hades and his kin?!"
      Speaker = "Poseidon"
      Event = "PoseidonFirstPickUp"
    }
    {
      Id = "Poseidon_0038"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why, Niece, you're bleeding everywhere! I can't keep watch over your every move, you know! You must be careful, at least until you have some of my might!"
      Speaker = "Poseidon"
      Event = "PoseidonLowHealth01"
    }
    {
      Id = "Poseidon_0039"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, little Niece, you're {#Emph}hurt! {#Prev}But pain builds character, now, does it not? And you are shaping up to be quite a character in all this!"
      Speaker = "Poseidon"
      Event = "PoseidonLowHealth02"
    }
    {
      Id = "Poseidon_0073"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your injuries shall make you stronger, Niece! Not right away, you're clearly in bad shape right now, but you shall {#Emph}grow {#Prev}from this, I'm sure!"
      Speaker = "Poseidon"
      Event = "PoseidonLowHealth03"
    }
    {
      Id = "Poseidon_0074"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Augh{#Prev}, you must have hit rough waters from the looks of it, but there's good news: {#Emph}I'm {#Prev}here!"
      Speaker = "Poseidon"
      Event = "PoseidonLowHealth04"
    }
    {
      Id = "Poseidon_0175"
      InheritFrom = "BaseNarrative"
      DisplayName = "I had this feeling you were just about to set forth on another of your fateful escapades! Figured you could use a surge of strength!"
      Speaker = "Poseidon"
      Event = "PoseidonRunStart01"
    }
    {
      Id = "Poseidon_0176"
      InheritFrom = "BaseNarrative"
      DisplayName = "A long and treacherous journey begins with a single step, my niece! Or if you're swimming, with a single {#Emph}stroke! {#Prev}Would that swimming were an option, I could aid you even more!"
      Speaker = "Poseidon"
      Event = "PoseidonRunStart02"
    }
    {
      Id = "Poseidon_0177"
      InheritFrom = "BaseNarrative"
      DisplayName = "As you set forth, I bid you do as does the shark, my niece! Surely you know the shark? A hunting-fish that swiftly surges ever-forward, in relentless pursuit of its prey!"
      Speaker = "Poseidon"
      Event = "PoseidonRunStart03"
    }
    {
      Id = "Poseidon_0178"
      InheritFrom = "BaseNarrative"
      DisplayName = "Let me be first among my kin this eve to bid you a safe voyage through the dark! Not that it's going to be safe, but that's my sentiment, nevertheless!"
      Speaker = "Poseidon"
      Event = "PoseidonRunStart04"
    }
    {
      Id = "Poseidon_0375"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've been so focused on setting the Underworld right that I am hesitant to bring it up, Niece, {#Emph}but! {#Prev}Your contributions on the surface would be also welcome here, at any point!"
      Speaker = "Poseidon"
      Event = "PoseidonUnderworldStartStreak01"
    }
    {
      Id = "Poseidon_0376"
      InheritFrom = "BaseNarrative"
      DisplayName = "So many of the Titan's legions you have wiped from the face of the earth, my niece! But more must gather in your father's Underworld! Do give them my {#Emph}blessings {#Prev}one of these nights, if you catch my drift!"
      Speaker = "Poseidon"
      Event = "PoseidonSurfaceStartStreak01"
    }
    {
      Id = "Poseidon_0016"
      InheritFrom = "BaseNarrative"
      DisplayName = "We never used to have much contact with your father. So when Hades ceased communicating with Olympus, we figured he was back to his old ways! Turns out that old sneak Chronos got him! There was nothing we could do!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutHades01"
    }
    {
      Id = "Poseidon_0018"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your father Hades and I didn't always get along. My crusty elder brother, I called him! Water under the bridge now. {#Emph}Ah{#Prev}, how I miss his dour cheerlessness, my niece!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutHades02"
    }
    {
      Id = "Poseidon_0211"
      InheritFrom = "BaseNarrative"
      DisplayName = "I scarce recall when last we spoke with your grim father, Niece! He never was the most sociable sort! When we stopped hearing from him, we figured he was simply in one of his {#Emph}moods{#Prev}, not in the clutches of Chronos!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutHades03"
    }
    {
      Id = "Poseidon_0424"
      InheritFrom = "BaseNarrative"
      DisplayName = "How fares my crusty elder brother, is his home redecoration going well? Hades and I, we never used to talk too much since he moved underneath the earth! But now's the time for us to change all that!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutHadesReturn01"
    }
    {
      Id = "Poseidon_0298"
      InheritFrom = "BaseNarrative"
      DisplayName = "We heard the news that you found old Hades, Niece! The {#Emph}most-excellent {#Prev}news, I should say! Except the part that he is bound in Tartarus, that isn't excellent at all. {#Emph}We'll get you out of this, Brother!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutFindingHades01"
    }
    {
      Id = "Poseidon_0303"
      InheritFrom = "BaseNarrative"
      DisplayName = "My crusty elder brother, you found him? In one piece?! I feared Hades would end up much like Chronos did once we were through with him way back. But Chronos simply chained him up in Tartarus? That's rather twisted actually..."
      Speaker = "Poseidon"
      Event = "PoseidonAboutFindingHades01_B"
    }
    {
      Id = "Poseidon_0044"
      InheritFrom = "BaseNarrative"
      DisplayName = "You would have liked your brother, little Niece! Just about everybody did! He showered me with praise just like a mortal would. A little awkward, yes, but {#Emph}quite endearing{#Prev}, too!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutZagreus01"
    }
    {
      Id = "Poseidon_0429"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's good to have your brother back, my niece! How he would scurry through your father's Underworld, like a rat fleeing a sinking ship! But now that ship is bound to be {#Emph}repaired! And {#Prev}it'll be a fine ship after all is said and done!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutZagreus02"
    }
    {
      Id = "Poseidon_0019"
      InheritFrom = "BaseNarrative"
      DisplayName = "So you were raised in some dark hidden recess of the Underworld, something like that, my niece? Raised to find and vanquish the usurper of your father's throne? {#Emph}Haha{#Prev}, that's rich!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutMelinoe01"
    }
    {
      Id = "Poseidon_0025"
      InheritFrom = "BaseNarrative"
      DisplayName = "My niece, you needn't be a witch to see your family is in dire straits right now. You needn't be a witch at all, if you ask me! I'd choose another way of life if I were you!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutMelinoe02"
    }
    {
      Id = "Poseidon_0013"
      InheritFrom = "BaseNarrative"
      DisplayName = "When first I heard our last, best hope for stopping Chronos was the secondborn of Hades and his Queen, I said: wait, {#Emph}who? {#Prev}So then they had a {#Emph}girl! {#Prev}The Titan must have struck your father's House right after you were born!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutChronos01"
    }
    {
      Id = "Poseidon_0012"
      InheritFrom = "BaseNarrative"
      DisplayName = "That wily old Titan, Chronos! I won't sink to calling him my father! We had it out with him before, a while back. Thought we had settled it for good! {#Emph}Ah{#Prev}, but we were young and foolish then!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutChronos02"
    }
    {
      Id = "Poseidon_0014"
      InheritFrom = "BaseNarrative"
      DisplayName = "It once took {#Emph}six {#Prev}of us to bring the Titan Chronos down! Myself, your father, Brother Zeus, his lovely Hera, Demeter, and Hestia as well! We'd mighty weapons for the job and everything!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutChronos03"
    }
    {
      Id = "Poseidon_0015"
      InheritFrom = "BaseNarrative"
      DisplayName = "Old Chronos never had even a drop of love for me, or any of his children, Niece. Imagine, hating your own offspring! And not just {#Emph}some {#Prev}of them, but {#Emph}all!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutChronos04"
    }
    {
      Id = "Poseidon_0017"
      InheritFrom = "BaseNarrative"
      DisplayName = "Once wily Chronos took your father's House, he mustered forces to besiege us here! We can't see anything down in that Underworld, so he plain caught us out! But still, we held him off!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutChronos05"
    }
    {
      Id = "Poseidon_0032"
      InheritFrom = "BaseNarrative"
      DisplayName = "As soon as Chronos attacked, why, we retaliated! A cataclysm like you've never seen! Ripped half this land apart. Left all the Titan's armies high and dry!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutChronos06"
    }
    {
      Id = "Poseidon_0364"
      InheritFrom = "BaseNarrative"
      DisplayName = "Old Chronos warrants every bit of justice you dispensed and more, my niece! I was already angry with him after everything he'd done, and that was {#Emph}prior {#Prev}to my realizing that he'd unleashed terrifying Typhon on us all!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutChronosPlan01"
    }
    {
      Id = "Poseidon_0427"
      InheritFrom = "BaseNarrative"
      DisplayName = "As much I do welcome this now-gentler Father Chronos, who seems less desirous to see our home destroyed, I still am wary of that old coot! He's been cooperative, though...!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutNeoChronos01"
    }
    {
      Id = "Poseidon_0184"
      InheritFrom = "BaseNarrative"
      DisplayName = "What's all this flotsam about Chronos abducting the Three Fates? {#Emph}Impossible! {#Prev}A ploy to take us off our guard! Don't go believing everything you hear, my niece!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutFates01"
    }
    {
      Id = "Poseidon_0065"
      InheritFrom = "BaseNarrative"
      DisplayName = "Our family's scattered to the winds a bit, my niece! You've heard from those of us upon this mountaintop, but Zeus sent several of his children to take care of things down closer to the base! They're probably just fine!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutFamily01"
    }
    {
      Id = "Poseidon_0208"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know it can be difficult, but now we all must stand together, Niece! An uncommon family with a common goal! A crashing wave to wash away these troubled times!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutFamily02"
    }
    {
      Id = "Poseidon_0223"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ask {#Emph}any {#Prev}god upon Olympus whether we think you ought to join in our defense here, or take the fight to Chronos in your father's realm, and you'll get a {#Emph}range of views! {#Prev}A range of {#Emph}highly civil {#Prev}views, which we don't fight about {#Emph}at all!"
      Speaker = "Poseidon"
      Event = "PoseidonDevotionIntro01"
    }
    {
      Id = "Poseidon_0224"
      InheritFrom = "BaseNarrative"
      DisplayName = "Remember how I said that we don't ever fight with one another on Olympus, little Niece? Well, that might have been a slight exaggeration on my part. But I stand with Hera on this one! We think your efforts are best spent up here!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutInFighting01"
    }
    {
      Id = "Poseidon_0031"
      InheritFrom = "BaseNarrative"
      DisplayName = "You made it to the surface, little niece! Too bad we couldn't scour the place before you got here, though! We're right in the middle of a big shake-up!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutSurface01"
    }
    {
      Id = "Poseidon_0086"
      InheritFrom = "BaseNarrative"
      DisplayName = "All that you look upon, both land and sea, that's {#Emph}my {#Prev}domain, you know! Long as you don't look up toward the heavens. That's the territory of your uncle Zeus! Though, I got the {#Emph}better {#Prev}share, I think!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutSurface02"
    }
    {
      Id = "Poseidon_0181"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wait, how is it that you live and breathe out here? I thought your father's line was doomed to linger underneath the earth, something like that? Ah, how the times have changed!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutSurface03"
    }
    {
      Id = "Poseidon_0312"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're getting closer to the snowy peaks that we call home! The biting chill is all part of our natural defenses, courtesy of Elder Goddess Demeter! We even have wondrous Automatons holding our foes at bay. You'll be {#Emph}amazed!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutSurface04"
    }
    {
      Id = "Poseidon_0036"
      InheritFrom = "BaseNarrative"
      DisplayName = "Where are you, Niece, the bottom of the sea?! Or very close to it! Must be even darker than what you're accustomed to. And the {#Emph}terrible {#Prev}pressure! Not even {#Emph}I {#Prev}can stand it for too long! So how can {#Emph}you?"
      Speaker = "Poseidon"
      Event = "PoseidonAboutOceanus01"
    }
    {
      Id = "Poseidon_0037"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your father never told me that his realm had all those twisting passageways right next to my domain! A {#Emph}drainage system {#Prev}of some sort, is it? Pouring right into my waters? Oh, I'd have words for Hades about {#Emph}this!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutOceanus02"
    }
    {
      Id = "Poseidon_0263"
      InheritFrom = "BaseNarrative"
      DisplayName = "Those watery horrors you face... I just want you to know, they're not my fault! I don't abide such monsters in my realm. And so they sneak inside the Underworld to take their rancor out on you!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutOceanus03"
    }
    {
      Id = "Poseidon_0404"
      InheritFrom = "BaseNarrative"
      DisplayName = "All that trudging through the Oceanus waters must have made you strong and {#Emph}swift{#Prev}, my niece! Now that's aquatic exercise for you! What better way to stay in {#Emph}perfect {#Prev}shape?"
      Speaker = "Poseidon"
      Event = "PoseidonAboutOceanus04"
    }
    {
      Id = "Poseidon_0258"
      InheritFrom = "BaseNarrative"
      DisplayName = "Where on our green Earth do you reside {#Emph}now{#Prev}, Niece? It near resembles some of Demeter's rolling fields of grain! Who knew old Hades had a pasture growing in the Underworld, if but a rather dismal-looking one, near as I can tell!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutFields01"
    }
    {
      Id = "Poseidon_0087"
      InheritFrom = "BaseNarrative"
      DisplayName = "Welcome to my boundless terrifying seas, my niece! Unfortunately teeming with invaders now. Got my hands full dealing with {#Emph}them{#Prev}, if you must know! But see if you can break through their blockade!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutThessaly01"
    }
    {
      Id = "Poseidon_0088"
      InheritFrom = "BaseNarrative"
      DisplayName = "Right on that very spot once stood a massive army headed for our mountain, Niece! So I just split the earth right under them, {#Emph}haha! {#Prev}So now we have a massive {#Emph}navy {#Prev}to contend with, and contend we shall!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutThessaly02"
    }
    {
      Id = "Poseidon_0299"
      InheritFrom = "BaseNarrative"
      DisplayName = "You braved the waters in the Rift of Thessaly! A nautical experience not for the faint of heart, fraught as it is with deathless ships hell-bent on your family's destruction! May you have smoother sailing there next time!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutThessaly03"
    }
    {
      Id = "Poseidon_0300"
      InheritFrom = "BaseNarrative"
      DisplayName = "When next you sail across the Rift, know this: I shall do my utmost to ensure a water-current speeds you mightily along! Though how to do it without benefiting the opposing ships...?"
      Speaker = "Poseidon"
      Event = "PoseidonAboutThessaly04"
    }
    {
      Id = "Poseidon_0425"
      InheritFrom = "BaseNarrative"
      DisplayName = "I promised I would close that Rift of Thessaly right up as soon as our war ended, {#Emph}but! {#Prev}Apparently we need for everything to be the way it was in order for your sorcery to work. Sounds like a promise I shall have to break!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutThessaly05"
    }
    {
      Id = "Poseidon_0309"
      InheritFrom = "BaseNarrative"
      DisplayName = "What, my niece, you're here?! I'd come down and welcome you myself, except our mountain home is crawling with invaders as you've probably observed! So we are at the summit... like a bunch of turtles hiding in their shells!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutOlympus01"
    }
    {
      Id = "Poseidon_0310"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've seen it: Our mountain's like a cross between a luxurious palace and an impregnable fortress! The so-called {#Emph}legions of Chronos {#Prev}won't be getting through {#Emph}these {#Prev}walls!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutOlympus02"
    }
    {
      Id = "Poseidon_0311"
      InheritFrom = "BaseNarrative"
      DisplayName = "Olympus, gutted like a {#Emph}fish! {#Prev}Used to be all sorts of Nymphs and such that had a standing invitation here to make themselves at home! Surely they'll return once the dust settles a bit!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutOlympus03"
    }
    {
      Id = "Poseidon_0405"
      InheritFrom = "BaseNarrative"
      DisplayName = "These {#Emph}bothersome {#Prev}Satyrs, befouling our fair mountain! We've shored up our defenses against them, but by the time we clean up all the mess, they're {#Emph}back!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutOlympus04"
    }
    {
      Id = "Poseidon_0426"
      InheritFrom = "BaseNarrative"
      DisplayName = "Even with Chronos having gone all soft, the battle on Olympus clearly isn't over yet! But we've shored up our defenses and are keeping all the remnant forces of Prometheus at bay! It's almost like a little {#Emph}ecosystem {#Prev}here!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutOlympus05"
    }
    {
      Id = "Poseidon_0363"
      InheritFrom = "BaseNarrative"
      DisplayName = "How did you like our fortress at this mountain's peak? It once stood proud and alabaster white before sinister Typhon corrupted it with all his grime and brood! But it's a sturdy structure and held fast so far!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutFortress01"
    }
    {
      Id = "Poseidon_0313"
      InheritFrom = "BaseNarrative"
      DisplayName = "About the wondrous Automatons that I described before... I ought have also mentioned that they currently cannot distinguish friend from foe! Hephaestus probably is working on that detail, but until then, best to give them a wide berth!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutAutomatons01"
    }
    {
      Id = "Poseidon_0314"
      InheritFrom = "BaseNarrative"
      DisplayName = "Our powerful Automaton defenses that Hephaestus has been busy churning out are excellent at killing anything that moves! So don't take their behavior as a personal affront! We weren't counting on you getting all the way up here!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutAutomatons02"
    }
    {
      Id = "Poseidon_0315"
      InheritFrom = "BaseNarrative"
      DisplayName = "How disrespectful that our own Automatons would treat you like our common foe! Unfortunately they don't understand the meaning of respect at all! Last time I told them {#Emph}don't you dare attack my niece{#Prev}, they attacked {#Emph}me!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutAutomatons03"
    }
    {
      Id = "Poseidon_0260"
      InheritFrom = "BaseNarrative"
      DisplayName = "Did you do it, Niece?! Strange things have happened since the other night; {#Emph}good {#Prev}things, if you are not one of our enemies! We think perhaps you cut old Chronos down to size! But he just grows right back, as I recall!"
      Speaker = "Poseidon"
      Event = "PoseidonUnderworldRunCleared01"
    }
    {
      Id = "Poseidon_0261"
      InheritFrom = "BaseNarrative"
      DisplayName = "We've all been counting on you, little Niece, but {#Emph}still! {#Prev}I'd not expected you could take on Chronos and prevail! I thought at best you'd keep him busy for a while. You must be very strong, like {#Emph}me!"
      Speaker = "Poseidon"
      Event = "PoseidonUnderworldRunCleared02"
    }
    {
      Id = "Poseidon_0428"
      InheritFrom = "BaseNarrative"
      DisplayName = "When we first met, I promised terrible revenge for what had happened to your kin! And I think what we've done would qualify! So what if Chronos wasn't {#Emph}permanently slain? {#Prev}Neither was old Hades, after all!"
      Speaker = "Poseidon"
      Event = "PoseidonUnderworldRunCleared03"
    }
    {
      Id = "Poseidon_0358"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, thank you, Niece! For we've defeated Typhon with your aid! Although {#Emph}defeated {#Prev}is a bit of a strong word, for it appears we merely knocked him down. Most likely made him angrier. {#Emph}Do {#Prev}make your way back when you can!"
      Speaker = "Poseidon"
      Event = "PoseidonSurfaceRunCleared01"
    }
    {
      Id = "Poseidon_0359"
      InheritFrom = "BaseNarrative"
      DisplayName = "What shall it take to put horrendous Typhon down for good?! He can't be reasoned with, recuperates his strength night after night, and has us cornered like a sturgeon in a net! But unlike {#Emph}fish{#Prev}, we can fight tirelessly back!"
      Speaker = "Poseidon"
      Event = "PoseidonSurfaceRunCleared02"
    }
    {
      Id = "Poseidon_0294"
      InheritFrom = "BaseNarrative"
      DisplayName = "Grown frustrated trying to take down Chronos, Niece? I know the feeling all too well! But now you're here upon the surface, where Olympus reigns supreme! At least for now!"
      Speaker = "Poseidon"
      Event = "PoseidonSurfaceRunStartPostUnderworldL01"
    }
    {
      Id = "Poseidon_0295"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now that you've given Chronos something to really think about, you're headed back our way? First, an Underworld victory, and next perhaps one {#Emph}here!"
      Speaker = "Poseidon"
      Event = "PoseidonSurfaceRunStartPostUnderworldW01"
    }
    {
      Id = "Poseidon_0296"
      InheritFrom = "BaseNarrative"
      DisplayName = "Returned for now to more-familiar depths, I see! Well, don't feel bad... the surface-world is not for everyone! Although the risen dead increasingly {#Emph}pretend {#Prev}it is for them!"
      Speaker = "Poseidon"
      Event = "PoseidonUnderworldRunStartPostSurfaceL01"
    }
    {
      Id = "Poseidon_0374"
      InheritFrom = "BaseNarrative"
      DisplayName = "Night after night, victory after victory, {#Emph}haha! {#Prev}You're making all of this look rather {#Emph}easy{#Prev}, Niece! Well then, sail on! And may my blessing make things easier still!"
      Speaker = "Poseidon"
      Event = "PoseidonWinStreak01"
    }
    {
      Id = "Poseidon_0221"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Cyclops Polyphemus bars your passage to the channel cutting through the countryside?! That spoilsport! Once played a little jape to make him think he was my son, and he's been sore about it since!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutPolyphemus01"
    }
    {
      Id = "Poseidon_0222"
      InheritFrom = "BaseNarrative"
      DisplayName = "To think that {#Emph}anybody {#Prev}could have thought I sired such a monstrous scamp as Polyphemus! Still, I used to look out for him. Not like he could look out for himself with just one eye, {#Emph}hahaha!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutPolyphemus02"
    }
    {
      Id = "Poseidon_0089"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you got past Polyphemus before, you can do it again, can't you, my niece? Once you make it past the docks, it's a straight shot down the channel to Olympus! Treacherous waters, yes, but I can help you navigate, I'm sure!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutPolyphemus03"
    }
    {
      Id = "Poseidon_0377"
      InheritFrom = "BaseNarrative"
      DisplayName = "You must not think too much of Cyclopes if Polyphemus is the only one you've met! They were our mighty allies once, you know! A shame what all has happened to their kind!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutPolyphemus04"
    }
    {
      Id = "Poseidon_0378"
      InheritFrom = "BaseNarrative"
      DisplayName = "To think I once felt pity for that Polyphemus, Niece! A Cyclops losing his good eye to a mere mortal voyager? Oh how I {#Emph}boiled {#Prev}over it back then, seeking the vengeance he was not going to find! But {#Emph}this {#Prev}is how he repays me?"
      Speaker = "Poseidon"
      Event = "PoseidonAboutPolyphemus05"
    }
    {
      Id = "Poseidon_0183"
      InheritFrom = "BaseNarrative"
      DisplayName = "Word has reached me that you clashed with Scylla and her Siren followers! So {#Emph}that's {#Prev}where they ended up! They once were the torment of many a sailor, till I took care of {#Emph}them!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutScylla01"
    }
    {
      Id = "Poseidon_0259"
      InheritFrom = "BaseNarrative"
      DisplayName = "I like to keep up with current events, and I hear you gave that loud-mouth Scylla and her Siren hangers-on quite the performance of your own! Too bad their godlike nature means they can't be killed! But they can certainly be shamed!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutScylla02"
    }
    {
      Id = "Poseidon_0432"
      InheritFrom = "BaseNarrative"
      DisplayName = "Vast is my knowledge of the sea, and even {#Emph}still {#Prev}it has its many mysteries! For instance, how can such a horrifying monster as Charybdis come from such a wondrous place? {#Emph}And {#Prev}what's it doing in my {#Emph}Rift? {#Prev}Besides gorging itself!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutCharybdis01"
    }
    {
      Id = "Poseidon_0291"
      InheritFrom = "BaseNarrative"
      DisplayName = "Most of you Underworld gods are more than welcome on Olympus here, when we are not at war; but not {#Emph}Eris! {#Prev}Her antics ruined one too many feasts! And now she flaps about our borders, mocking us and making matters {#Emph}worse!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutEris01"
    }
    {
      Id = "Poseidon_0308"
      InheritFrom = "BaseNarrative"
      DisplayName = "What I would like to know, my niece, is many things, such as: Just {#Emph}how {#Prev}did devious Prometheus slip from his bonds? {#Emph}Ah{#Prev}, these Titans! We can't seem to get rid of them for good. But we can douse the flames they stole at least!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutPrometheus01"
    }
    {
      Id = "Poseidon_0371"
      InheritFrom = "BaseNarrative"
      DisplayName = "That scoundrel Prometheus got a proper {#Emph}punishment {#Prev}from you last night, Athena says! We've been unable to subdue him, as he's sneaky like the forces he commands! But now you've drawn him out!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutPrometheus02"
    }
    {
      Id = "Poseidon_0369"
      InheritFrom = "BaseNarrative"
      DisplayName = "Some sort of {#Emph}dangerous phenomenon {#Prev}is taking place here on the summit, Niece! We dare not get too close to it as yet... so if you've heard the others speculate about its origin, those are mere unsubstantiated {#Emph}rumors{#Prev}, nothing more!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutSurfaceThreat01"
    }
    {
      Id = "Poseidon_0370"
      InheritFrom = "BaseNarrative"
      DisplayName = "The others say we face enormous {#Emph}Typhon {#Prev}as a threat, but I've seen no such thing! Of course I've lately not seen much of anything due to the cataclysmic storm up here! Though I {#Emph}am {#Prev}hearing a lot of low guttural roars!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutSurfaceThreat02"
    }
    {
      Id = "Poseidon_0433"
      InheritFrom = "BaseNarrative"
      DisplayName = "Whatever you have done to rile up old Chronos, he's taking it out on {#Emph}us! {#Prev}At least his forces on this mountain are! But fear not, for I have called for reinforcements! Several times!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutSurfaceHelp01"
    }
    {
      Id = "Poseidon_0380"
      InheritFrom = "BaseNarrative"
      DisplayName = "My brother Zeus, he says you made it all the way up to our Palace, Niece! And sent the monster Typhon howling to the earth! Forgive my absence, all too many water-bodies to defend...!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutPalace01"
    }
    {
      Id = "Poseidon_0423"
      InheritFrom = "BaseNarrative"
      DisplayName = "Terrible Typhon left his imprint on this mountainside, of that you can be sure! Even our Palace buckled under his immeasurable weight! But in the end, our Palace stands! Not he."
      Speaker = "Poseidon"
      Event = "PoseidonAboutPalace02"
    }
    {
      Id = "Poseidon_0355"
      InheritFrom = "BaseNarrative"
      DisplayName = "Did you see the {#Emph}size {#Prev}of that terrible Typhon, my niece?! It has been so long since last we fought that I daresay he's grown still larger in the intervening time! And {#Emph}sneakier {#Prev}as well! All of that shaking here... it was from {#Emph}him!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutTyphon01"
    }
    {
      Id = "Poseidon_0356"
      InheritFrom = "BaseNarrative"
      DisplayName = "Much like old Chronos, we have vanquished awful Typhon once before! Your Lord Uncle, he struck the final blow himself, a bolt of lightning right between the eyes! The two {#Emph}main {#Prev}eyes at least! He has so many of those eyes..."
      Speaker = "Poseidon"
      Event = "PoseidonAboutTyphon02"
    }
    {
      Id = "Poseidon_0357"
      InheritFrom = "BaseNarrative"
      DisplayName = "You may be wondering what wisdom we can share in how to deal with horrid Typhon, since we battled him before. You'll have to ask Athena about that! Or perhaps Zeus. I played a more supporting role during that clash is all!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutTyphon03"
    }
    {
      Id = "Poseidon_0430"
      InheritFrom = "BaseNarrative"
      DisplayName = "The quaking on Olympus finally ceased! One of many benefits to awful Typhon being cast away! Apparently you have to face him somewhere still? At least some hallucinated revenant of him? Well I'm glad {#Emph}I {#Prev}don't!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutTyphon04"
    }
    {
      Id = "Poseidon_0381"
      InheritFrom = "BaseNarrative"
      DisplayName = "You somehow did it, Niece, Typhon is {#Emph}gone! {#Prev}There is no longer any trace of him up here! So now to do the same to {#Emph}Chronos{#Prev}, then? Go on, let's give him everything we've got!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutTyphonDeath01"
    }
    {
      Id = "Poseidon_0360"
      InheritFrom = "BaseNarrative"
      DisplayName = "At least you made the awful Typhon's life more difficult last night, my niece! He almost crushed you like a {#Emph}shellfish{#Prev}, didn't he? But you created just enough annoyance that we pushed him back after you ran away! Or whatever you did!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutTyphonL01"
    }
    {
      Id = "Poseidon_0361"
      InheritFrom = "BaseNarrative"
      DisplayName = "You were most brave to face gigantic Typhon as you did! And fortunate to have escaped, because I could have sworn he {#Emph}flattened {#Prev}you! We'll hold him off as long as possible, but if you're not too busy, we still need all hands on deck!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutTyphonL02"
    }
    {
      Id = "Poseidon_0362"
      InheritFrom = "BaseNarrative"
      DisplayName = "Where are you {#Emph}going{#Prev}, little niece?! The opposite direction of terrifying Typhon, that's how it appears to {#Emph}me! {#Prev}Which, come to think, seems like a reasonable course! But we assuredly could use your aid up here!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutTyphonL03"
    }
    {
      Id = "Poseidon_0043"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your brother, Niece, I used to call him little Hades... I, I think that fits you, {#Emph}too! {#Prev}Especially since {#Emph}he's {#Prev}gone! It should be clear whom I'm referring to, right, little Hades?"
      Speaker = "Poseidon"
      Event = "PoseidonAboutLittleHades01"
    }
    {
      Id = "Poseidon_0182"
      InheritFrom = "BaseNarrative"
      DisplayName = "One thing about me, Niece, is I've a keen eye for amphibians; and that one with you there is a fine specimen indeed! Mislikes briny waters, but no beast is perfect!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutFrogFamiliar01"
    }
    {
      Id = "Poseidon_0304"
      InheritFrom = "BaseNarrative"
      DisplayName = "What is that creature with you there, a {#Emph}cat? {#Prev}You should know something about cats, Niece: They hate water! And yet those {#Emph}fools {#Prev}require it to live! Perhaps that cat knows better, though, if it has the sense to follow you through {#Emph}hell!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutCatFamiliar01"
    }
    {
      Id = "Poseidon_0305"
      InheritFrom = "BaseNarrative"
      DisplayName = "I take back all the horrid things I said regarding cats! For yours is an excellent fisherman. Fisher-{#Emph}cat? {#Prev}The point is I'd not known such creatures could appreciate the sea... which means {#Emph}they {#Prev}can be appreciated by {#Emph}me!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutCatFamiliar02"
    }
    {
      Id = "Poseidon_0297"
      InheritFrom = "BaseNarrative"
      DisplayName = "I must say that's a most-substantial labrys that you wield! The Moonstone Axe, Hephaestus says? Well nothing bests a trusty trident! The tongs of this little fork of mine have wrenched free many a blade!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutAxe01"
    }
    {
      Id = "Poseidon_0318"
      InheritFrom = "BaseNarrative"
      DisplayName = "Though I have wielded virtually every type of weapon in my day, I have never seen such armaments as you now use, to quite spectacular effect! You'll be an even match for our Automatons with {#Emph}that!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutSuit01"
    }
    {
      Id = "Poseidon_0062"
      InheritFrom = "BaseNarrative"
      DisplayName = "Water's a fascinating substance, Niece! Cuts through the tallest mountains with sufficient time, and yet mortals need to drink the stuff to live! You're multitalented as well, aren't you?"
      Speaker = "Poseidon"
      Event = "PoseidonAboutWater01"
    }
    {
      Id = "Poseidon_0214"
      InheritFrom = "BaseNarrative"
      DisplayName = "Is that a bit of rainfall in your whereabouts? {#Emph}Ah{#Prev}, you should see old Demeter and Zeus fight over who's responsible! I merely watch and laugh, for either way, it's more water for me!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutRain01"
    }
    {
      Id = "Poseidon_0063"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know what dams are, Niece? Ramshackle structures mortals use to hold my waters back! But when I'm angry, {#Emph}bwaah{#Prev}, my water crashes through! Be like that water, don't hold back, all right?"
      Speaker = "Poseidon"
      Event = "PoseidonAboutDams01"
    }
    {
      Id = "Poseidon_0064"
      InheritFrom = "BaseNarrative"
      DisplayName = "A shame you had to grow up in the middle of nowhere, my niece! We gods require certain luxuries. Even your stodgy old father liked his gems and such! But you got by with nothing of the sort!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutLuxuries01"
    }
    {
      Id = "Poseidon_0022"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wonder, my good Niece, are you prepared to sink? Or are you prepared to swim? {#Emph}Swim{#Prev}, I say! Swim like our very livelihoods depend on it!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutSwimming01"
    }
    {
      Id = "Poseidon_0023"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ahoy, my magick-using niece, for it is I! We have the Titan in a stalemate, so you take all the time you need bailing us out!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutStalemate01"
    }
    {
      Id = "Poseidon_0024"
      InheritFrom = "BaseNarrative"
      DisplayName = "Here, my niece, what say we make a trade? My bountiful blessing in exchange for your fierce battle-skills! How fair a trade is that?!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutTrading01"
    }
    {
      Id = "Poseidon_0026"
      InheritFrom = "BaseNarrative"
      DisplayName = "We're positively {#Emph}drowning {#Prev}in the Titan's wretched forces, Niece! But we are {#Emph}gods! {#Prev}We've might enough to hold them off I think!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutStalemate02"
    }
    {
      Id = "Poseidon_0027"
      InheritFrom = "BaseNarrative"
      DisplayName = "No telling when a storm's about to hit up here, my niece! Not even a big dangerous one such as this! You'd think I could have seen it coming, but you'd be wrong!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutStorms01"
    }
    {
      Id = "Poseidon_0028"
      InheritFrom = "BaseNarrative"
      DisplayName = "I trust your battles are proceeding well down there? As for our battles here, why, they are going swimmingly I'd say! We barely need your help!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutStalemate03"
    }
    {
      Id = "Poseidon_0029"
      InheritFrom = "BaseNarrative"
      DisplayName = "How you must thirst for vengeance, Niece! I know the feeling only all too well! {#Emph}Vengeance! {#Prev}As cold and dark as the bottom of the sea!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutVengeance01"
    }
    {
      Id = "Poseidon_0030"
      InheritFrom = "BaseNarrative"
      DisplayName = "Within my oceans, Niece, the deeper you go, the fiercer the pressure! It's almost like you're in too deep yourself!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutPressure01"
    }
    {
      Id = "Poseidon_0084"
      InheritFrom = "BaseNarrative"
      DisplayName = "As gods, we {#Emph}all {#Prev}must make hard choices, Niece. Just earlier, I was unable to decide between causing a massive earthquake or a deadly tidal wave! Ended up doing both, but you catch my meaning, right?"
      Speaker = "Poseidon"
      Event = "PoseidonAboutChoices01"
    }
    {
      Id = "Poseidon_0085"
      InheritFrom = "BaseNarrative"
      DisplayName = "Much as I'd hate to see the world's surface devastated in the wake of our great war, I'm prepared to do whatever it takes! Even if it means causing much of that devastation myself!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutDisasters01"
    }
    {
      Id = "Poseidon_0179"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why, you possess a Rod of Fishing there! What lingering doubts I had of you just vaporized. What are we even fighting for, if not the right to fish whensoever we desire?"
      Speaker = "Poseidon"
      Event = "PoseidonAboutFishing01"
    }
    {
      Id = "Poseidon_0180"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know, Niece, the Cocytus River flowing through those musty woods of yours is quite the fishing-spot! You'd be doing all those river denizens a favor getting them out of there!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutFishing02"
    }
    {
      Id = "Poseidon_0262"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've something freshly caught thanks to that Rod of Fishing, I can tell! I don't permit just {#Emph}anybody {#Prev}to dredge up my denizens of the deep! Yet it's almost as though they wish to hop right out of there for you!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutFishing03"
    }
    {
      Id = "Poseidon_0319"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, hurry up and take my Boon, for there's an opportunity to use your trusty Rod of Fishing right nearby! I sense such things down in the very fiber of my being, and shall observe your catch-attempts with keen interest!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutFishing04"
    }
    {
      Id = "Poseidon_0398"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now {#Emph}that {#Prev}is quite the handsome Rod of Fishing you possess, my niece! Premium materials, delicate proportions, sturdy grip; a {#Emph}masterwork! {#Prev}If I were a fish myself, I'd desire to be caught by nothing less!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutFishingUpgrade01"
    }
    {
      Id = "Poseidon_0400"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why, you have caught practically all the water denizens under the sun, and underneath the earth! At least all the ones in all the regions that you normally traverse! That is perhaps your greatest feat thus far...!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutManyFish01"
    }
    {
      Id = "Poseidon_0372"
      InheritFrom = "BaseNarrative"
      DisplayName = "You caught a Starsailor here on our mountaintop, did you? And of none-too-modest size! Oh, I know every fish within my seas! And other smaller bodies of water as well!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutLegendaryFish01"
    }
    {
      Id = "Poseidon_0399"
      InheritFrom = "BaseNarrative"
      DisplayName = "You caught one of those ugly Chimaerids from the heart of Typhon's endless storm! A true {#Emph}abomination{#Prev}, not a true {#Emph}fish! {#Prev}But it has enough fishlike parts that we shall let it slide!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutLegendaryFish02"
    }
    {
      Id = "Poseidon_0373"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Stormgullets and such within the stagnant pools here on the mountain's summit, Niece... I am surprised your Rod of Fishing does not snap retrieving them, such is their monstrous strength!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutRareFish01"
    }
    {
      Id = "Poseidon_0396"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've some experience with witchery, fine! But you have much to learn about the fishing arts! That you have demonstrated interest is the first step toward mastery; catching a huge variety of water denizens is the {#Emph}next!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutFishingQuest01"
    }
    {
      Id = "Poseidon_0397"
      InheritFrom = "BaseNarrative"
      DisplayName = "That you set aside such ample time to fish has not been lost on {#Emph}me{#Prev}, my niece! And you caught more types of water denizens than I can {#Emph}easily {#Prev}count! You already have my finest blessings; you now also have my deep respect."
      Speaker = "Poseidon"
      Event = "PoseidonAboutFishingQuest02"
    }
    {
      Id = "Poseidon_0256"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah, haha! {#Prev}I see the tide's come in! Well, my niece... what do you say we sweep clean through those cheerless woods of yours as might a cataclysmic flood?"
      Speaker = "Poseidon"
      Event = "PoseidonAboutKeepsake01"
    }
    {
      Id = "Poseidon_0264"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know well that impressive glimmer of the Vivid Sea that I bestowed to you, my niece! Not all my seas are quite as clear and blue; you have yourself a sample of the very best!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutKeepsake02"
    }
    {
      Id = "Poseidon_0403"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, there's the unmistakable refracting gleam of that Vivid Sea of mine, or I should say of {#Emph}yours! {#Prev}How it has flourished traveling with you! Your respect for my waters has not gone unnoticed here by me!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutKeepsake03"
    }
    {
      Id = "Poseidon_0401"
      InheritFrom = "BaseNarrative"
      DisplayName = "I couldn't help but notice how you seem to keep taking that Cloud Bangle with you from my brother Zeus! He is a very {#Emph}busy {#Prev}god, you understand, while I may aid you readily if you but use the Vivid Sea instead!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutZeusKeepsake01"
    }
    {
      Id = "Poseidon_0257"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't know what you did, exactly, Niece, but you have summoned me, and I am here! In spirit, anyway, and with such Boons as ought to practically ensure your victory!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutPackageBounty01"
    }
    {
      Id = "Poseidon_0255"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why, little Niece, you sailed down there faster than the trimmest mortal ship! Well then, what say we scour clean this little corner of the sea!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutPackageBounty02"
    }
    {
      Id = "Poseidon_0367"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Eugh{#Prev}, what is it about this night, my niece? Our foes all seem to have redoubled their efforts! Even {#Emph}retripled {#Prev}in some cases I daresay! As long as it's all due to your strange Underworld practices, according to our little Artemis!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutShrine01"
    }
    {
      Id = "Poseidon_0368"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, what a horrifying night this is, as though our very nightmares walk the earth, or swim across the sea! Our foes are taken with such frenzy that this couldn't possibly be {#Emph}your {#Prev}doing, unless you've lost your senses like the rest?"
      Speaker = "Poseidon"
      Event = "PoseidonAboutShrine02"
    }
    {
      Id = "Poseidon_0080"
      InheritFrom = "BaseNarrative"
      DisplayName = "No point in holding back even a smidge when we're in such a serious predicament, is there? So here, some of my raw unbridled power ought to {#Emph}tide {#Prev}you over, I should think!"
      Speaker = "Poseidon"
      Event = "PoseidonLegendaryPickUp01"
    }
    {
      Id = "Poseidon_0081"
      InheritFrom = "BaseNarrative"
      DisplayName = "So many of our enemies once feared us gods, but turned their backs on us! I'd say a show of overwhelming force ought to remind them who's the captain of the ship, however, no?"
      Speaker = "Poseidon"
      Event = "PoseidonLegendaryPickUp02"
    }
    {
      Id = "Poseidon_0379"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have discovered by now all my many Boons! I'm always thinking about more, of course! Used to have lots of different ones if you must know! But times have changed, and Brother Zeus says we must concentrate!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutBoons01"
    }
    {
      Id = "Poseidon_0406"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps some of the newfangled Boons we've offered haven't always swept you off your feet, but we {#Emph}do {#Prev}still have certain {#Emph}older {#Prev}blessings closer to ones your brother used to get! Why here's a few right now!"
      Speaker = "Poseidon"
      Event = "PoseidonLegacyBoonIntro01"
    }
    {
      Id = "Poseidon_0382"
      InheritFrom = "BaseNarrative"
      DisplayName = "Chronos surrendered to us, Niece! You must have heard, you helped {#Emph}deliver {#Prev}him! Yet there remains some mess that must be cleaned? I could not follow what he rambled on about, but if you simply need my Boons, then {#Emph}here!"
      Speaker = "Poseidon"
      Event = "PoseidonPostTrueEnding01"
    }
    {
      Id = "Poseidon_0383"
      InheritFrom = "BaseNarrative"
      DisplayName = "What is this about having to confront Chronos in other times? And even Typhon {#Emph}too?! {#Prev}I'll not pretend to understand, but if this is the cost of peace, I'll pay my share without a second thought!"
      Speaker = "Poseidon"
      Event = "PoseidonPostTrueEnding02"
    }
    {
      Id = "Poseidon_0421"
      InheritFrom = "BaseNarrative"
      DisplayName = "An age of mortals is to come? Not if I open up a few more rifts, it won't! {#Emph}Hah! {#Prev}The earth itself could swallow all of those ungrateful little louts, if the seas don't do it first!"
      Speaker = "Poseidon"
      Event = "PoseidonPostEpilogue01"
    }
    {
      Id = "Poseidon_0422"
      InheritFrom = "BaseNarrative"
      DisplayName = "I was upset when first I heard the Fates decided they would change things up on us! Have my brothers and I not ruled our realms with strength and gusto? But no use in fighting prophecy... though I may still complain!"
      Speaker = "Poseidon"
      Event = "PoseidonPostEpilogue02"
    }
    {
      Id = "Poseidon_0040"
      InheritFrom = "BaseNarrative"
      DisplayName = "I see that my great brother Zeus already blessed you with his incomparable strength! Well, perhaps not {#Emph}incomparable. {#Prev}Here! Have some of {#Emph}mine{#Prev}, and you can weigh the benefits!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutZeus01"
    }
    {
      Id = "Poseidon_0071"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're favored by Queen Hera, little Niece! That's her blessing, all right! High honor to have gotten it, especially for one who to my knowledge is unwed! She never favors {#Emph}me!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutHera01"
    }
    {
      Id = "Poseidon_0020"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've met the brilliant Apollo, have you, Niece? He's near as popular with mortals as am I! Perhaps among his many talents he can help you get us out of this!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutApollo01"
    }
    {
      Id = "Poseidon_0070"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, you seem lovelier than ever, Niece! As though the splendorous Aphrodite herself bestowed to you her gifts! She did so, didn't she, the scamp!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutAphrodite01"
    }
    {
      Id = "Poseidon_0072"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh-hoh{#Prev}, I haven't seen old Hestia this energized in ages, Niece! And now her fiery ability is yours! As to whoever said that fire and water don't mix, I'm here to prove them wrong!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutHestia01"
    }
    {
      Id = "Poseidon_0171"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, you've earned the frosty blessing of {#Emph}Elder Goddess Demeter{#Prev}, as I like to call her! To which she threatens to freeze my oceans! To which I apologize profusely, and we move on!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutDemeter01"
    }
    {
      Id = "Poseidon_0173"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why, even from this vantage point, I see that silver of yours gleaming like the abalone shell! The mark of talented Hephaestus, isn't it? At least his {#Emph}handiwork {#Prev}looks good, {#Emph}hahahah ha-hah!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutHephaestus01"
    }
    {
      Id = "Poseidon_0172"
      InheritFrom = "BaseNarrative"
      DisplayName = "Niece, you ever get a ringing in your ears? Well I do, and not from the water pressure, but from hearing good Hephaestus go {#Emph}a-clang, a-clang, a-clang! {#Prev}Why it's enough to drive me {#Emph}mad!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutHephaestus02"
    }
    {
      Id = "Poseidon_0174"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Whoa{#Prev}, my niece, you seem possessed of an uncanny haste! Such swiftness as to be the envy of that rascal Hermes, who as per usual is nowhere to be found. Some messenger {#Emph}he {#Prev}is!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutHermes01"
    }
    {
      Id = "Poseidon_0021"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're shining like the Moon herself, my niece! Selene's aid, is it? Here I thought all she did was drive her pretty steeds over my ocean waves! She's dipping into other hobbies, then!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutSelene01"
    }
    {
      Id = "Poseidon_0209"
      InheritFrom = "BaseNarrative"
      DisplayName = "Apollo said you met your flighty cousin Artemis! Now that's some tracking skill, I must admit! She's gone so often, figured she was merely lollygagging with her woodland friends again!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutArtemis01"
    }
    {
      Id = "Poseidon_0210"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Whaa—! {#Prev}So precisely did you dispatch your foes that I near mistook you for independent Artemis, my niece! I've no idea where {#Emph}that {#Prev}rascal is!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutArtemis02"
    }
    {
      Id = "Poseidon_0317"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wise Athena noted that the two of you have finally met! It ought have been the lot of us gathered here to welcome you with open arms, not just a bit of curt formality from that one! Not the warmest welcoming committee, is she?"
      Speaker = "Poseidon"
      Event = "PoseidonAboutAthena01"
    }
    {
      Id = "Poseidon_0316"
      InheritFrom = "BaseNarrative"
      DisplayName = "It ought to be all-hands-on-deck here when we have the Titan's armies battering our gates! But wine-loving Dionysus, he so desires {#Emph}peace{#Prev}, yet refuses to {#Emph}fight {#Prev}for it! Oh I'd drown his sorrows myself if I but knew where he went!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutDionysus01"
    }
    {
      Id = "Poseidon_0351"
      InheritFrom = "BaseNarrative"
      DisplayName = "At last, you've met militant {#Emph}Ares{#Prev}, little niece! Sometimes I think that {#Emph}he's {#Prev}to blame for everything, in all his warring ways! But then if not for him we'd have more difficulty fighting back. So I consider it a wash!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutAres01"
    }
    {
      Id = "Poseidon_0352"
      InheritFrom = "BaseNarrative"
      DisplayName = "Is that the so-called blessing of my nephew Ares that you have already, or are you simply in the mood for some unmitigated wrath? Well don't forget the seas can be quite moody, too!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutAres02"
    }
    {
      Id = "Poseidon_0320"
      InheritFrom = "BaseNarrative"
      DisplayName = "A goddess of considerable stature sometimes storms down through those depths, my niece! A friend of yours perhaps? For she bears fearsome Stygius, a blade that's served our family well! No match for this {#Emph}trident{#Prev}, of course!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutNemesis01"
    }
    {
      Id = "Poseidon_0321"
      InheritFrom = "BaseNarrative"
      DisplayName = "We {#Emph}do {#Prev}appreciate your intervention, though we've others pitching in! Such as stout-shouldered Heracles, you've seen him lately, yes? Even upon our snowy mountain here! I like you better, but he's {#Emph}good{#Prev}, I'll give him that!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutHeracles01"
    }
    {
      Id = "Poseidon_0322"
      InheritFrom = "BaseNarrative"
      DisplayName = "We've powerful defenses on the ground, but face attackers from the skies as well! Harpies, Dracons, {#Emph}more! {#Prev}Also this little winged mortal fellow buzzing all about! Brother Zeus near-bolted him before we realized that he was on {#Emph}our {#Prev}side!"
      Speaker = "Poseidon"
      Event = "PoseidonAboutIcarus01"
    }
    {
      Id = "Poseidon_0431"
      InheritFrom = "BaseNarrative"
      DisplayName = "My brother Zeus recently turned to me and said, {#Emph}Poseidon? There are times you talk too much! {#Prev}To which I said, {#Emph}you take that back! {#Prev}To which he said, {#Emph}no I shall not. {#Prev}To which I said, {#Emph}then fine! How about I talk less starting now?"
      Speaker = "Poseidon"
      Event = "PoseidonAboutSayingLittle01"
    }
    {
      Id = "Poseidon_0003"
      InheritFrom = "BaseNarrative"
      DisplayName = "My winsome niece, it is I! And I bring bounties to you from the seas themselves!"
      Speaker = "Poseidon"
      Event = "PoseidonChat01"
    }
    {
      Id = "Poseidon_0004"
      InheritFrom = "BaseNarrative"
      DisplayName = "The greatest acts of vengeance don't come easily, my niece! So take heart, and also {#Emph}this!"
      Speaker = "Poseidon"
      Event = "PoseidonChat02"
    }
    {
      Id = "Poseidon_0005"
      InheritFrom = "BaseNarrative"
      DisplayName = "That blasted Titan thinks he's got us, but we'll show him he's all wet, won't we, my niece?"
      Speaker = "Poseidon"
      Event = "PoseidonChat03"
    }
    {
      Id = "Poseidon_0006"
      InheritFrom = "BaseNarrative"
      DisplayName = "Remind that good-for-nothing Titan that Olympus is in charge, would you, my niece?"
      Speaker = "Poseidon"
      Event = "PoseidonChat04"
    }
    {
      Id = "Poseidon_0007"
      InheritFrom = "BaseNarrative"
      DisplayName = "Look, we could use all the help we can get. And we can't be choosy when there's none-too-many fish in the sea!"
      Speaker = "Poseidon"
      Event = "PoseidonChat05"
    }
    {
      Id = "Poseidon_0008"
      InheritFrom = "BaseNarrative"
      DisplayName = "I owe your father for his generosity. But since he's gone, I'll pay {#Emph}you {#Prev}back instead!"
      Speaker = "Poseidon"
      Event = "PoseidonChat06"
    }
    {
      Id = "Poseidon_0009"
      InheritFrom = "BaseNarrative"
      DisplayName = "Go show those Titans who's in charge, all right? If you catch my meaning, {#Emph}hahahaha!"
      Speaker = "Poseidon"
      Event = "PoseidonChat07"
    }
    {
      Id = "Poseidon_0010"
      InheritFrom = "BaseNarrative"
      DisplayName = "The seas aren't going anywhere, and neither are we, right, my niece?"
      Speaker = "Poseidon"
      Event = "PoseidonChat08"
    }
    {
      Id = "Poseidon_0011"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hoh{#Prev}, my little niece, your greatest uncle's here! Here to make sure you really make a {#Emph}splash!"
      Speaker = "Poseidon"
      Event = "PoseidonChat09"
    }
    {
      Id = "Poseidon_0045"
      InheritFrom = "BaseNarrative"
      DisplayName = "A storm is brewing, Niece. Big one, this time, why, even bigger than the last! Prepare!"
      Speaker = "Poseidon"
      Event = "PoseidonChat10"
    }
    {
      Id = "Poseidon_0046"
      InheritFrom = "BaseNarrative"
      DisplayName = "Flow forth, my niece, and overwhelm all those who stand against us, would you there?"
      Speaker = "Poseidon"
      Event = "PoseidonChat11"
    }
    {
      Id = "Poseidon_0047"
      InheritFrom = "BaseNarrative"
      DisplayName = "My waves can slam into the land with massive force, especially when I give them a little push!"
      Speaker = "Poseidon"
      Event = "PoseidonChat12"
    }
    {
      Id = "Poseidon_0048"
      InheritFrom = "BaseNarrative"
      DisplayName = "We're in the middle of a war here, little Hades, so we'll chitchat later! Now, we fight!"
      Speaker = "Poseidon"
      Event = "PoseidonChat13"
    }
    {
      Id = "Poseidon_0049"
      InheritFrom = "BaseNarrative"
      DisplayName = "All right, Niece, I've little patience left to spare right now, but that's good news for you!"
      Speaker = "Poseidon"
      Event = "PoseidonChat14"
    }
    {
      Id = "Poseidon_0050"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're here upon my surface, aren't you? Why, welcome back, and pardon all the mess!"
      Speaker = "Poseidon"
      Event = "PoseidonChat15"
    }
    {
      Id = "Poseidon_0051"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come on, Niece, let's go batter down our enemies like ships within a storm!"
      Speaker = "Poseidon"
      Event = "PoseidonChat16"
    }
    {
      Id = "Poseidon_0052"
      InheritFrom = "BaseNarrative"
      DisplayName = "The tides are turning, can't you feel it, Niece? I can, of course, but surely you can, too!"
      Speaker = "Poseidon"
      Event = "PoseidonChat17"
    }
    {
      Id = "Poseidon_0053"
      InheritFrom = "BaseNarrative"
      DisplayName = "High tide has come again, my niece! Which is my little way of saying, {#Emph}here we go!"
      Speaker = "Poseidon"
      Event = "PoseidonChat18"
    }
    {
      Id = "Poseidon_0054"
      InheritFrom = "BaseNarrative"
      DisplayName = "No holding back this time, you hear me down there, Niece! Now let's get {#Emph}shaking!"
      Speaker = "Poseidon"
      Event = "PoseidonChat19"
    }
    {
      Id = "Poseidon_0055"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have the power of the seas right at your beck and call!"
      Speaker = "Poseidon"
      Event = "PoseidonChat20"
    }
    {
      Id = "Poseidon_0056"
      InheritFrom = "BaseNarrative"
      DisplayName = "The untold bounties of the sea are yours! Well, one of them, at least!"
      Speaker = "Poseidon"
      Event = "PoseidonChat21"
    }
    {
      Id = "Poseidon_0057"
      InheritFrom = "BaseNarrative"
      DisplayName = "If only your father could see you now! Fortunately, I still sort of can!"
      Speaker = "Poseidon"
      Event = "PoseidonChat22"
    }
    {
      Id = "Poseidon_0058"
      InheritFrom = "BaseNarrative"
      DisplayName = "The strength of earth and sea is yours again, if you can handle it, my niece!"
      Speaker = "Poseidon"
      Event = "PoseidonChat23"
    }
    {
      Id = "Poseidon_0059"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll never stop fighting for you! Not until the fighting stops! Perhaps not even then!"
      Speaker = "Poseidon"
      Event = "PoseidonChat24"
    }
    {
      Id = "Poseidon_0060"
      InheritFrom = "BaseNarrative"
      DisplayName = "You remind me of crusty old Hades more and more! In a good way!"
      Speaker = "Poseidon"
      Event = "PoseidonChat25"
    }
    {
      Id = "Poseidon_0061"
      InheritFrom = "BaseNarrative"
      DisplayName = "One sudden surge of awesome might, coming right up!"
      Speaker = "Poseidon"
      Event = "PoseidonChat26"
    }
    {
      Id = "Poseidon_0075"
      InheritFrom = "BaseNarrative"
      DisplayName = "Arise, my niece! As would a fierce sea-creature of some sort! One blessed by {#Emph}me!"
      Speaker = "Poseidon"
      Event = "PoseidonChat27"
    }
    {
      Id = "Poseidon_0076"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nothing beats doling out terrible consequences to our enemies, now, does it, Niece?"
      Speaker = "Poseidon"
      Event = "PoseidonChat28"
    }
    {
      Id = "Poseidon_0077"
      InheritFrom = "BaseNarrative"
      DisplayName = "Many great battles have been fought upon my seas, but they'll all pale in comparison to {#Emph}this!"
      Speaker = "Poseidon"
      Event = "PoseidonChat29"
    }
    {
      Id = "Poseidon_0078"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come, Niece, let us crash upon our enemies as great waves upon a shore!"
      Speaker = "Poseidon"
      Event = "PoseidonChat30"
    }
    {
      Id = "Poseidon_0079"
      InheritFrom = "BaseNarrative"
      DisplayName = "Even the mortals know the sea is bountiful, yet also capable of deadly force!"
      Speaker = "Poseidon"
      Event = "PoseidonChat31"
    }
    {
      Id = "Poseidon_0407"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't let the pressure get to you as you dive down into those depths once more!"
      Speaker = "Poseidon"
      Event = "PoseidonChat32"
    }
    {
      Id = "Poseidon_0408"
      InheritFrom = "BaseNarrative"
      DisplayName = "Most of my land and sea is far more beauteous than {#Emph}that {#Prev}embattled stretch!"
      Speaker = "Poseidon"
      Event = "PoseidonChat33"
    }
    {
      Id = "Poseidon_0409"
      InheritFrom = "BaseNarrative"
      DisplayName = "I bid smooth sailing to you, Niece, and awful shipwrecks to our many foes!"
      Speaker = "Poseidon"
      Event = "PoseidonChat34"
    }
    {
      Id = "Poseidon_0410"
      InheritFrom = "BaseNarrative"
      DisplayName = "Much cleaning up to do both in your father's realm and mine, and I have {#Emph}just {#Prev}the thing!"
      Speaker = "Poseidon"
      Event = "PoseidonChat35"
    }
    {
      Id = "Poseidon_0411"
      InheritFrom = "BaseNarrative"
      DisplayName = "May you see {#Emph}this {#Prev}voyage to the destination you desire as with the night before!"
      Speaker = "Poseidon"
      Event = "PoseidonChat36"
    }
    {
      Id = "Poseidon_0412"
      InheritFrom = "BaseNarrative"
      DisplayName = "The seas themselves tremble on fearsome nights as this, but you take heart!"
      Speaker = "Poseidon"
      Event = "PoseidonChat37"
    }
    {
      Id = "Poseidon_0413"
      InheritFrom = "BaseNarrative"
      DisplayName = "Again you have embarked towards our shores, so here's a little wind in your sails!"
      Speaker = "Poseidon"
      Event = "PoseidonChat38"
    }
    {
      Id = "Poseidon_0414"
      InheritFrom = "BaseNarrative"
      DisplayName = "I daresay our enemies shall not be getting off the hook anytime soon!"
      Speaker = "Poseidon"
      Event = "PoseidonChat39"
    }
    {
      Id = "Poseidon_0415"
      InheritFrom = "BaseNarrative"
      DisplayName = "My heart swells with pride seeing you navigate troubled waters with such ease!"
      Speaker = "Poseidon"
      Event = "PoseidonChat40"
    }
    {
      Id = "Poseidon_0416"
      InheritFrom = "BaseNarrative"
      DisplayName = "I take no responsibility at all for those fishlike monstrosities you have to face down there!"
      Speaker = "Poseidon"
      Event = "PoseidonChat41"
    }
    {
      Id = "Poseidon_0417"
      InheritFrom = "BaseNarrative"
      DisplayName = "The waters may become a little rough but you have found your sea-legs, right, my niece?"
      Speaker = "Poseidon"
      Event = "PoseidonChat42"
    }
    {
      Id = "Poseidon_0418"
      InheritFrom = "BaseNarrative"
      DisplayName = "As you embark on your fateful voyage yet again, my niece, know that I am with you, in {#Emph}Boon form!"
      Speaker = "Poseidon"
      Event = "PoseidonChat43"
    }
    {
      Id = "Poseidon_0419"
      InheritFrom = "BaseNarrative"
      DisplayName = "You go sock that Typhon in the eye for me tonight would you? In {#Emph}all {#Prev}his foul eyes!"
      Speaker = "Poseidon"
      Event = "PoseidonChat44"
    }
    {
      Id = "Poseidon_0420"
      InheritFrom = "BaseNarrative"
      DisplayName = "We've navigated through rough waters many times! And it never seems to get any easier!"
      Speaker = "Poseidon"
      Event = "PoseidonChat45"
    }
    {
      Id = "Poseidon_0292"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hoy, for it is I {#Emph}again{#Prev}, good Niece! Although presumably you must have known, as likely all the unmarked packaging concealing this Boon was soaked all the way through!"
      Speaker = "Poseidon"
      Event = "PoseidonBlindBox01"
    }
    {
      Id = "Poseidon_0293"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Surprise! {#Prev}You are the fortunate recipient of my almighty Boon! Which means the legions of Chronos are in for an even {#Emph}bigger {#Prev}surprise... and not the {#Emph}good {#Prev}kind!"
      Speaker = "Poseidon"
      Event = "PoseidonBlindBox02"
    }
    {
      Id = "Poseidon_0187"
      InheritFrom = "BaseNarrative"
      DisplayName = "That old Underworld Boatman yet eludes the grasp of Chronos, does he? Turned to a life of the piratical smuggler in these dark times, {#Emph}augh!"
      Speaker = "Poseidon"
      Event = "PoseidonLootBought01"
    }
    {
      Id = "Poseidon_0188"
      InheritFrom = "BaseNarrative"
      DisplayName = "I fail to see why coin need change hands for a blessing from your uncle, though come to think, such blessings are most valuable indeed!"
      Speaker = "Poseidon"
      Event = "PoseidonLootBought02"
    }
    {
      Id = "Poseidon_0189"
      InheritFrom = "BaseNarrative"
      DisplayName = "Whatever Gold you paid ought to be at the bottom of the sea! Who does that Chronos think he is, showering mortals with shiny metals?"
      Speaker = "Poseidon"
      Event = "PoseidonLootBought03"
    }
    {
      Id = "Poseidon_0190"
      InheritFrom = "BaseNarrative"
      DisplayName = "I trust your Boatman there appreciates that the smooth sailing he's experienced in his mercantile routes is no coincidence at all?"
      Speaker = "Poseidon"
      Event = "PoseidonLootBought04"
    }
    {
      Id = "Poseidon_0365"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now that's a trim ship, with the Underworld Boatman at the helm! Perhaps I ought not call him Underworld Boatman anymore, for he's become a proper captain now! I'll have to keep the currents clear for him!"
      Speaker = "Poseidon"
      Event = "PoseidonLootBought05"
    }
    {
      Id = "Poseidon_0366"
      InheritFrom = "BaseNarrative"
      DisplayName = "That Underworld Boatman, he can't sail to this mountaintop! Unless he fashions for himself a craft that sails on air, he shall be relegated to my waters! But how then did he get his goods up here...?"
      Speaker = "Poseidon"
      Event = "PoseidonLootBought06"
    }
    {
      Id = "Poseidon_0191"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Augh! {#Prev}You have wounded me, my niece! Not physically, of course, but {#Emph}mentally! {#Prev}Such wounds as heal only with {#Emph}revenge!"
      Speaker = "Poseidon"
      Event = "PoseidonRejection01"
    }
    {
      Id = "Poseidon_0192"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sailors know the sea can be a moody mistress indeed, and you know why, my little niece? Because {#Emph}I {#Prev}can be a moody {#Emph}mister!"
      Speaker = "Poseidon"
      Event = "PoseidonRejection02"
    }
    {
      Id = "Poseidon_0193"
      InheritFrom = "BaseNarrative"
      DisplayName = "You reject my blessing, Niece? Well then I'll just have to offer it to whomever else drifts by. Perhaps {#Emph}they'll {#Prev}appreciate it!"
      Speaker = "Poseidon"
      Event = "PoseidonRejection03"
    }
    {
      Id = "Poseidon_0194"
      InheritFrom = "BaseNarrative"
      DisplayName = "Friendly bit of advice, you turn your back on the sea, you're going to regret it. And the sea in this case is {#Emph}myself!"
      Speaker = "Poseidon"
      Event = "PoseidonRejection04"
    }
    {
      Id = "Poseidon_0275"
      InheritFrom = "BaseNarrative"
      DisplayName = "There you go again, brushing me aside like a bit of seaweed clinging to your leg! Is that what you take me for, Niece?!"
      Speaker = "Poseidon"
      Event = "PoseidonRejection05"
    }
    {
      Id = "Poseidon_0276"
      InheritFrom = "BaseNarrative"
      DisplayName = "I {#Emph}see{#Prev}, you want my blessing {#Emph}still{#Prev}, except a little {#Emph}less {#Prev}than that one you just {#Emph}took! {#Prev}And you want it after a very rousing {#Emph}fight!"
      Speaker = "Poseidon"
      Event = "PoseidonRejection06"
    }
    {
      Id = "Poseidon_0277"
      InheritFrom = "BaseNarrative"
      DisplayName = "You are swimming in dangerous waters with such antics, Niece. If you so wish to see what lurks in these depths, {#Emph}fine!"
      Speaker = "Poseidon"
      Event = "PoseidonRejection07"
    }
    {
      Id = "Poseidon_0278"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh come {#Emph}on{#Prev}, little niece, it's like you pick against me every single time! It cannot possibly be worth it to incur my wrath!"
      Speaker = "Poseidon"
      Event = "PoseidonRejection08"
    }
    {
      Id = "Poseidon_0279"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd not have made that choice if I were you, but then, if I were {#Emph}you {#Prev}I wouldn't still be {#Emph}me{#Prev}, so... {#Emph}augh{#Prev}, you get my drift!"
      Speaker = "Poseidon"
      Event = "PoseidonRejection09"
    }
    {
      Id = "Poseidon_0280"
      InheritFrom = "BaseNarrative"
      DisplayName = "So, my many different potent blessings just aren't good enough for you? Is that what you would like me to believe?!"
      Speaker = "Poseidon"
      Event = "PoseidonRejection10"
    }
    {
      Id = "Poseidon_0281"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now, strictly speaking, Niece, you chose correctly in deferring to my brother Zeus. But I must still save face!"
      Speaker = "Poseidon"
      Event = "PoseidonRejection11"
    }
    {
      Id = "Poseidon_0282"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ladies first, is that the way of it, young Niece? I'm sure Queen Hera is most pleased with you, but I, for one, am not!"
      Speaker = "Poseidon"
      Event = "PoseidonRejection12"
    }
    {
      Id = "Poseidon_0195"
      InheritFrom = "BaseNarrative"
      DisplayName = "Fear not, Niece, all my anger's washed away as quickly as it swelled. That's emotions for you! The seas themselves are simpler to control!"
      Speaker = "Poseidon"
      Event = "PoseidonMakeUp01"
    }
    {
      Id = "Poseidon_0196"
      InheritFrom = "BaseNarrative"
      DisplayName = "I got a little heated there I think, but I've cooled off! No lasting harm, though to be fair, my blessing here won't last too long either!"
      Speaker = "Poseidon"
      Event = "PoseidonMakeUp02"
    }
    {
      Id = "Poseidon_0197"
      InheritFrom = "BaseNarrative"
      DisplayName = "All right, that's enough splashing around, I think! My wrath has ebbed back into the sea that is wherever my wrath is stored!"
      Speaker = "Poseidon"
      Event = "PoseidonMakeUp03"
    }
    {
      Id = "Poseidon_0198"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Eh! {#Prev}Had so much vengeance on the mind, I let you have a little taste back there. Fear not! Only our enemies shall be getting the full course!"
      Speaker = "Poseidon"
      Event = "PoseidonMakeUp04"
    }
    {
      Id = "Poseidon_0283"
      InheritFrom = "BaseNarrative"
      DisplayName = "I shall count this one as an honest mistake on your part, for I can fathom no other explanation for what transpired here!"
      Speaker = "Poseidon"
      Event = "PoseidonMakeUp05"
    }
    {
      Id = "Poseidon_0284"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now {#Emph}that {#Prev}is how I like to settle a dispute! Using whichever impressionable creatures are around to make my dissatisfaction known!"
      Speaker = "Poseidon"
      Event = "PoseidonMakeUp06"
    }
    {
      Id = "Poseidon_0285"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Augh! {#Prev}There I go, fighting my kin again, when I ought turn my wrath against our common enemy, who is our kin as well!"
      Speaker = "Poseidon"
      Event = "PoseidonMakeUp07"
    }
    {
      Id = "Poseidon_0286"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why, you just wiped the {#Emph}floor {#Prev}with all of those has-beens! And just like that, my fury's ebbed away as well!"
      Speaker = "Poseidon"
      Event = "PoseidonMakeUp08"
    }
    {
      Id = "Poseidon_0287"
      InheritFrom = "BaseNarrative"
      DisplayName = "All right, Niece, I'll let you off with a warning just this once. Or however many times it's been! I've really no idea..."
      Speaker = "Poseidon"
      Event = "PoseidonMakeUp09"
    }
    {
      Id = "Poseidon_0288"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh-hoh{#Prev}, this little fishie can bite back! Perhaps I shouldn't be rewarding you for this! But I just cannot help myself!"
      Speaker = "Poseidon"
      Event = "PoseidonMakeUp10"
    }
    {
      Id = "Poseidon_0289"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Augh{#Prev}, all is forgiven, Niece, no need to fret! I was just testing your resolve, and evidently, you have plenty of it still!"
      Speaker = "Poseidon"
      Event = "PoseidonMakeUp11"
    }
    {
      Id = "Poseidon_0290"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why are we dallying when we have bigger fish to fry? Oh right, because you picked a fight with me! Though does this mean I lost...?"
      Speaker = "Poseidon"
      Event = "PoseidonMakeUp12"
    }
    {
      Id = "Melinoe_0505"
      InheritFrom = "BaseNarrative"
      DisplayName = "I heard so much about you, Uncle, but you're not just very strong, you're generous as well. I am grateful, and would give you this."
      Speaker = "Melinoe"
      Event = "PoseidonGift01"
    }
    {
      Id = "Poseidon_0066"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, little Niece, how {#Emph}thoughtful{#Prev}, but {#Emph}deeply {#Prev}unnecessary! Yet now {#Emph}I'm {#Prev}feeling generous, so here! This one's for you!"
      Speaker = "Poseidon"
      Event = "PoseidonGift01"
    }
    {
      Id = "Melinoe_0504"
      InheritFrom = "BaseNarrative"
      DisplayName = "Uncle Poseidon, it is an honor to have earned your blessing. Especially for all the battles still to come."
      Speaker = "Melinoe"
      Event = "PoseidonGift02"
    }
    {
      Id = "Poseidon_0067"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hah{#Prev}, well I am left to wonder who it was that taught you such good manners, Niece? You're like a proper little lady, I'm impressed!"
      Speaker = "Poseidon"
      Event = "PoseidonGift02"
    }
    {
      Id = "MelinoeField_1764"
      InheritFrom = "BaseNarrative"
      DisplayName = "A little something to soothe the senses, Uncle Poseidon! I know it's hardly the occasion now, but isn't there always some cause to celebrate?"
      Speaker = "Melinoe"
      Event = "PoseidonGift03"
    }
    {
      Id = "Poseidon_0068"
      InheritFrom = "BaseNarrative"
      DisplayName = "You praise your uncle, and your uncle, why, he thinks it's really great! {#Emph}I {#Prev}think it's great, that is! That you would think of gifts in times like these!"
      Speaker = "Poseidon"
      Event = "PoseidonGift03"
    }
    {
      Id = "MelinoeField_1765"
      InheritFrom = "BaseNarrative"
      DisplayName = "This one's for you, Uncle! May you shake all our foes from the land, and your seas swallow them, that they rue the day they rose against us!"
      Speaker = "Melinoe"
      Event = "PoseidonGift04"
    }
    {
      Id = "Poseidon_0069"
      InheritFrom = "BaseNarrative"
      DisplayName = "Of all the many sacrifices I have been receiving as of late, and there have been a lot, yours have been the very best of all, my niece!"
      Speaker = "Poseidon"
      Event = "PoseidonGift04"
    }
    {
      Id = "MelinoeField_3724"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lord Poseidon! So many mortals know you as the Earth-Shaker, for the land and sea alike bend to your will. But I'm so deeply fortunate to know you as my uncle. I won't forget your kindness and spirit."
      Speaker = "Melinoe"
      Event = "PoseidonGift05"
    }
    {
      Id = "Poseidon_0301"
      InheritFrom = "BaseNarrative"
      DisplayName = "You needn't waste your Nectar on me, Niece! Not like I can drink it all the way from here. Perhaps that's just how it is with offerings! Mortals, they leave us strips of fresh-cooked meat, and things like that...! What was I on about?"
      Speaker = "Poseidon"
      Event = "PoseidonGift05"
    }
    {
      Id = "MelinoeField_3725"
      InheritFrom = "BaseNarrative"
      DisplayName = "I heard the tales of my father's brothers long before we met, Uncle. And you're as mighty and courageous as they say! But I also feel as though you have been looking out for me. Thank you for making me feel welcome and safe."
      Speaker = "Melinoe"
      Event = "PoseidonGift06"
    }
    {
      Id = "Poseidon_0302"
      InheritFrom = "BaseNarrative"
      DisplayName = "Such a voyage we have had, haven't we, Niece? And you're not even in my same vicinity! Just how it is with relatives. They're with you even when they're not! Know that I'm with you, too, and always making certain that the coast is clear! At least after you find one of my Boons..."
      Speaker = "Poseidon"
      Event = "PoseidonGift06"
    }
    {
      Id = "MelinoeField_3826"
      InheritFrom = "BaseNarrative"
      DisplayName = "Dear Uncle Poseidon, this offering of sweet Ambrosia is for you! My father must have been so fortunate to have grown up with such a big-hearted and caring brother. May all your seas and land soon know tranquility again!"
      Speaker = "Melinoe"
      Event = "PoseidonGift07"
    }
    {
      Id = "Poseidon_0402"
      InheritFrom = "BaseNarrative"
      DisplayName = "However did you find such an extravagance amid our tempestuous times, Niece?! All I expected you to do is furiously fight but you have done much more! I move the earth itself; yet you move {#Emph}me."
      Speaker = "Poseidon"
      Event = "PoseidonGift07"
    }
    {
      Id = "Melinoe_1735"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well this is quite a catch."
      Speaker = "Melinoe"
      Event = "PoseidonUpgrade.GiftGivenVoiceLines"
    }
    {
      Id = "Poseidon_0384"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The tide's come in!"
      Speaker = "Poseidon"
      Event = "PoseidonUpgrade.FullSuperActivatedVoiceLines"
    }
    {
      Id = "Poseidon_0385"
      InheritFrom = "BaseSubtitle"
      DisplayName = "At once, my niece!"
      Speaker = "Poseidon"
      Event = "PoseidonUpgrade.FullSuperActivatedVoiceLines"
    }
    {
      Id = "Poseidon_0386"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You called, my niece?!"
      Speaker = "Poseidon"
      Event = "PoseidonUpgrade.FullSuperActivatedVoiceLines"
    }
    {
      Id = "Poseidon_0387"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Here's some water-power, Niece!"
      Speaker = "Poseidon"
      Event = "PoseidonUpgrade.FullSuperActivatedVoiceLines"
    }
    {
      Id = "Poseidon_0388"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Get ready to get {#Emph}wet!"
      Speaker = "Poseidon"
      Event = "PoseidonUpgrade.FullSuperActivatedVoiceLines"
    }
    {
      Id = "Poseidon_0389"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Here comes the {#Emph}wave!"
      Speaker = "Poseidon"
      Event = "PoseidonUpgrade.FullSuperActivatedVoiceLines"
    }
    {
      Id = "Poseidon_0390"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Your uncle's here, my niece!"
      Speaker = "Poseidon"
      Event = "PoseidonUpgrade.FullSuperActivatedVoiceLines"
    }
    {
      Id = "Poseidon_0391"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Let's clean up this mess!"
      Speaker = "Poseidon"
      Event = "PoseidonUpgrade.FullSuperActivatedVoiceLines"
    }
    {
      Id = "Poseidon_0393"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Oh {#Emph}now {#Prev}you seek my aid?!"
      Speaker = "Poseidon"
      Event = "PoseidonUpgrade.FullSuperActivatedVoiceLines"
    }
    {
      Id = "Poseidon_0392"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well I {#Emph}never!"
      Speaker = "Poseidon"
      Event = "PoseidonUpgrade.FullSuperActivatedVoiceLines"
    }
    {
      Id = "Poseidon_0394"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Whose side am I {#Emph}on?!"
      Speaker = "Poseidon"
      Event = "PoseidonUpgrade.FullSuperActivatedVoiceLines"
    }
    {
      Id = "Poseidon_0395"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How {#Emph}rude {#Prev}of you to ask!"
      Speaker = "Poseidon"
      Event = "PoseidonUpgrade.FullSuperActivatedVoiceLines"
    }
    {
      Id = "Chronos_1257"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That seafaring {#Emph}brat..."
      Speaker = "Chronos"
      Event = "PoseidonUpgrade.FullSuperActivatedVoiceLines"
    }
    {
      Id = "Chronos_1258"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That water-loving {#Emph}scamp..."
      Speaker = "Chronos"
      Event = "PoseidonUpgrade.FullSuperActivatedVoiceLines"
    }
    {
      Id = "Zagreus_0356"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Uncle Poseidon!"
      Speaker = "Zagreus"
      Event = "PoseidonUpgrade.FullSuperActivatedVoiceLines"
    }
    {
      Id = "Zagreus_0357"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Uncle, it's {#Emph}me!"
