      Event = "NPC_Hecate_01.InteractVoiceLines"
    }
    {
      Id = "Hecate_0467"
      InheritFrom = "BaseSubtitle"
      DisplayName = "All of us."
      Speaker = "Hecate"
      Event = "NPC_Hecate_01.InteractVoiceLines"
    }
    {
      Id = "Hecate_0468"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And may shadows conceal us."
      Speaker = "Hecate"
      Event = "NPC_Hecate_01.InteractVoiceLines"
    }
    {
      Id = "Hecate_0469"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And you, Melinoë."
      Speaker = "Hecate"
      Event = "NPC_Hecate_01.InteractVoiceLines"
    }
    {
      Id = "Hecate_0867"
      InheritFrom = "BaseSubtitle"
      DisplayName = "And you."
      Speaker = "Hecate"
      Event = "NPC_Hecate_01.InteractVoiceLines"
    }
    {
      Id = "Hecate_0192_01"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Upon this cauldron, by the will of Night,"
      Speaker = "Hecate"
      Event = "NPC_Hecate_01.CauldronWitchcraftVoiceLines"
    }
    {
      Id = "Melinoe_2465"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Upon this cauldron, by the will of Night,"
      Speaker = "Melinoe"
      Event = "PlayedThreadedFunctionArgs.VoiceLines"
    }
    {
      Id = "Hecate_0192_02"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hear me, Shades of the dead, and listen well,"
      Speaker = "Hecate"
      Event = "NPC_Hecate_01.CauldronWitchcraftVoiceLines"
    }
    {
      Id = "Melinoe_2466"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Hear me, Shades of the dead, and listen well,"
      Speaker = "Melinoe"
      Event = "PlayedThreadedFunctionArgs.VoiceLines"
    }
    {
      Id = "Hecate_0192_03"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Your strength is needed now to join our fight,"
      Speaker = "Hecate"
      Event = "NPC_Hecate_01.CauldronWitchcraftVoiceLines"
    }
    {
      Id = "Melinoe_2467"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Your strength is needed now to join our fight,"
      Speaker = "Melinoe"
      Event = "PlayedThreadedFunctionArgs.VoiceLines"
    }
    {
      Id = "Hecate_0192_04"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Upon Olympus and in depths of hell."
      Speaker = "Hecate"
      Event = "NPC_Hecate_01.CauldronWitchcraftVoiceLines"
    }
    {
      Id = "Melinoe_2468"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Upon Olympus and in depths of hell."
      Speaker = "Melinoe"
      Event = "PlayedThreadedFunctionArgs.VoiceLines"
    }
    {
      Id = "Hecate_0192_05"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Within these Crossroads you are safe with us,"
      Speaker = "Hecate"
      Event = "NPC_Hecate_01.CauldronWitchcraftVoiceLines"
    }
    {
      Id = "Melinoe_2469"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Within these Crossroads you are safe with us,"
      Speaker = "Melinoe"
      Event = "PlayedThreadedFunctionArgs.VoiceLines"
    }
    {
      Id = "Hecate_0192_06"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Yet we would ask your service to our cause."
      Speaker = "Hecate"
      Event = "NPC_Hecate_01.CauldronWitchcraftVoiceLines"
    }
    {
      Id = "Melinoe_2470"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Yet we would ask your service to our cause."
      Speaker = "Melinoe"
      Event = "PlayedThreadedFunctionArgs.VoiceLines"
    }
    {
      Id = "Hecate_0192_07"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Your will is yours, your choice is given thus:"
      Speaker = "Hecate"
      Event = "NPC_Hecate_01.CauldronWitchcraftVoiceLines"
    }
    {
      Id = "Melinoe_2471"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Your will is yours, your choice is given thus:"
      Speaker = "Melinoe"
      Event = "PlayedThreadedFunctionArgs.VoiceLines"
    }
    {
      Id = "Hecate_0192_08"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Together, let us rise above our flaws."
      Speaker = "Hecate"
      Event = "NPC_Hecate_01.CauldronWitchcraftVoiceLines"
    }
    {
      Id = "Melinoe_2472"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Together, let us rise above our flaws."
      Speaker = "Melinoe"
      Event = "PlayedThreadedFunctionArgs.VoiceLines"
    }
    {
      Id = "Hecate_0192_09"
      InheritFrom = "BaseSubtitle"
      DisplayName = "So mote it be."
      Speaker = "Hecate"
      Event = "NPC_Hecate_01.CauldronWitchcraftVoiceLines"
    }
    {
      Id = "Melinoe_2473"
      InheritFrom = "BaseSubtitle"
      DisplayName = "So mote it be."
      Speaker = "Melinoe"
      Event = "PlayedThreadedFunctionArgs.VoiceLines"
    }
    {
      Id = "Hecate_0397"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}By light of Moon, in darkest Erebus,"
      Speaker = "Hecate"
      Event = "NPC_Hecate_01.CauldronWitchcraftVoiceLines"
    }
    {
      Id = "Melinoe_2577"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}By light of Moon, in darkest Erebus,"
      Speaker = "Melinoe"
      Event = "PlayedThreadedFunctionArgs.VoiceLines"
    }
    {
      Id = "Hecate_0398"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}I urge ye Spirits of the Crossroads thus:"
      Speaker = "Hecate"
      Event = "NPC_Hecate_01.CauldronWitchcraftVoiceLines"
    }
    {
      Id = "Melinoe_2578"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}I urge ye Spirits of the Crossroads thus:"
      Speaker = "Melinoe"
      Event = "PlayedThreadedFunctionArgs.VoiceLines"
    }
    {
      Id = "Hecate_0399"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Look well upon the wards about this place,"
      Speaker = "Hecate"
      Event = "NPC_Hecate_01.CauldronWitchcraftVoiceLines"
    }
    {
      Id = "Melinoe_2579"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Look well upon the wards about this place,"
      Speaker = "Melinoe"
      Event = "PlayedThreadedFunctionArgs.VoiceLines"
    }
    {
      Id = "Hecate_0400"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Which keep us hidden within Night's embrace."
      Speaker = "Hecate"
      Event = "NPC_Hecate_01.CauldronWitchcraftVoiceLines"
    }
    {
      Id = "Melinoe_2580"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Which keep us hidden within Night's embrace."
      Speaker = "Melinoe"
      Event = "PlayedThreadedFunctionArgs.VoiceLines"
    }
    {
      Id = "Hecate_0401"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ensure that each is whole, its strength secure,"
      Speaker = "Hecate"
      Event = "NPC_Hecate_01.CauldronWitchcraftVoiceLines"
    }
    {
      Id = "Melinoe_2581"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Ensure that each is whole, its strength secure,"
      Speaker = "Melinoe"
      Event = "PlayedThreadedFunctionArgs.VoiceLines"
    }
    {
      Id = "Hecate_0402"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}As we hold out against our common foe;"
      Speaker = "Hecate"
      Event = "NPC_Hecate_01.CauldronWitchcraftVoiceLines"
    }
    {
      Id = "Melinoe_2582"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}As we hold out against our common foe;"
      Speaker = "Melinoe"
      Event = "PlayedThreadedFunctionArgs.VoiceLines"
    }
    {
      Id = "Hecate_0403"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}To achieve victory we must endure"
      Speaker = "Hecate"
      Event = "NPC_Hecate_01.CauldronWitchcraftVoiceLines"
    }
    {
      Id = "Melinoe_2583"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}To achieve victory we must endure"
      Speaker = "Melinoe"
      Event = "PlayedThreadedFunctionArgs.VoiceLines"
    }
    {
      Id = "Hecate_0404"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}The ravages on us Time would bestow."
      Speaker = "Hecate"
      Event = "NPC_Hecate_01.CauldronWitchcraftVoiceLines"
    }
    {
      Id = "Melinoe_2584"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}The ravages on us Time would bestow."
      Speaker = "Melinoe"
      Event = "PlayedThreadedFunctionArgs.VoiceLines"
    }
    {
      Id = "Hecate_0405"
      InheritFrom = "BaseSubtitle"
      DisplayName = "So mote it be."
      Speaker = "Hecate"
      Event = "NPC_Hecate_01.CauldronWitchcraftVoiceLines"
    }
    {
      Id = "Melinoe_2585"
      InheritFrom = "BaseSubtitle"
      DisplayName = "So mote it be."
      Speaker = "Melinoe"
      Event = "PlayedThreadedFunctionArgs.VoiceLines"
    }
    {
      Id = "Hecate_0725"
      InheritFrom = "BaseNarrative"
      DisplayName = "Time forced our hand, Melinoë. Nary a soul expected you to slay our enemy last night, on a new moon, no less!"
      Speaker = "Hecate"
      Event = "HecateFirstMeeting"
    }
    {
      Id = "Melinoe_2906_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "I lack such forgiveness for my failure, Headmistress Hecate. The Titan yet lives, and Olympus yet burns, while I'm back where I started!"
      Speaker = "Melinoe"
      Event = "HecateFirstMeeting"
    }
    {
      Id = "Hecate_0726"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes; recovered bodily if not in spirit, and grown wiser for it. You've not failed... merely begun! This is all part of the task. {#Emph}Death to Chronos."
      Speaker = "Hecate"
      Event = "HecateFirstMeeting"
    }
    {
      Id = "Melinoe_0014_V3"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Death to Chronos."
      Speaker = "Melinoe"
      Event = "HecateFirstMeeting"
    }
    {
      Id = "Hecate_0621"
      InheritFrom = "BaseNarrative"
      DisplayName = "This cauldron's filthy still, alas. But there's something at our Altar you may use, and I've unsealed the Silver Pool as well."
      Speaker = "Hecate"
      Event = "HecateFirstMeetingCont1"
    }
    {
      Id = "Hecate_0622"
      InheritFrom = "BaseNarrative"
      DisplayName = "We shall await your safe return. May moonlight guide you."
      Speaker = "Hecate"
      Event = "HecateFirstMeetingCont2"
    }
    {
      Id = "Hecate_0411"
      InheritFrom = "BaseNarrative"
      DisplayName = "'Twas a worthwhile first attempt, Melinoë. I trust you'd have gone farther still had I not obstructed your path. Quite unsuccessfully, I concede."
      Speaker = "Hecate"
      Event = "HecateFirstMeeting_B"
    }
    {
      Id = "Melinoe_1802"
      InheritFrom = "BaseNarrative"
      DisplayName = "You needed to ensure I was prepared. And I know there is much left to prove."
      Speaker = "Melinoe"
      Event = "HecateFirstMeeting_B"
    }
    {
      Id = "Hecate_0412"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just so. Trust well your instincts and your craft, and continue the task. {#Emph}Death to Chronos."
      Speaker = "Hecate"
      Event = "HecateFirstMeeting_B"
    }
    {
      Id = "Hecate_0210"
      InheritFrom = "BaseNarrative"
      DisplayName = "What troubles you, Melinoë? Your brow is furrowed not with fierceness but with doubt... the one emotion we cannot afford."
      Speaker = "Hecate"
      Event = "HecateAboutTask01"
    }
    {
      Id = "Melinoe_0582"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ungh{#Prev}, Headmistress, it's just... I'm struggling to muster the rage I should feel. I'm tasked with slaying a Titan I do not even know, to avenge a family I cannot remember..."
      Speaker = "Melinoe"
      Event = "HecateAboutTask01"
    }
    {
      Id = "Hecate_0211"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your feelings never lie to you; 'tis their origins that may deceive. You feel no rage? Then {#Emph}you {#Prev}are in control. Tell me, do you question the need to complete our task?"
      Speaker = "Hecate"
      Event = "HecateAboutTask01"
    }
    {
      Id = "Melinoe_0583"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, Headmistress. Treachery against the House of Hades cannot go unpunished."
      Speaker = "Melinoe"
      Event = "HecateAboutTask01"
    }
    {
      Id = "Hecate_0212"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just so. Center yourself on that."
      Speaker = "Hecate"
      Event = "HecateAboutTask01"
    }
    {
      Id = "Hecate_0019"
      InheritFrom = "BaseNarrative"
      DisplayName = "How fares the task thus far, Melinoë? Our enemy yet remains indisposed with more pressing matters. The time to strike at him is now."
      Speaker = "Hecate"
      Event = "HecateAboutTask02"
    }
    {
      Id = "Melinoe_0046"
      InheritFrom = "BaseNarrative"
      DisplayName = "There is much left to do, Headmistress. You must know that. How much time do I have?"
      Speaker = "Melinoe"
      Event = "HecateAboutTask02"
    }
    {
      Id = "Hecate_0020"
      InheritFrom = "BaseNarrative"
      DisplayName = "Who can say? Our enemy is Time itself. Time's passage seems to bear little meaning anymore. Do not rush needlessly. The task shall only take longer that way."
      Speaker = "Hecate"
      Event = "HecateAboutTask02"
    }
    {
      Id = "Hecate_0529"
      InheritFrom = "BaseNarrative"
      DisplayName = "Much is expected of you. The pressure that you feel; you never speak of it, and yet full well I know it's there. Your constant companion."
      Speaker = "Hecate"
      Event = "HecateAboutPressure01"
    }
    {
      Id = "Melinoe_2133"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can hardly distinguish between pressure and faith anymore. My entire life has led to this, and all of you are counting on me. Are you truly so certain in my inevitable success, Headmistress?"
      Speaker = "Melinoe"
      Event = "HecateAboutPressure01"
    }
    {
      Id = "Hecate_0530"
      InheritFrom = "BaseNarrative"
      DisplayName = "Pressure and faith are intertwined, 'tis true. Ever in conflict. Should the pressure utterly prevail, out comes despair. Only then do we truly falter."
      Speaker = "Hecate"
      Event = "HecateAboutPressure01"
    }
    {
      Id = "Melinoe_2134"
      InheritFrom = "BaseNarrative"
      DisplayName = "You didn't answer my question. The combined might of the gods was not enough to stop Chronos before. And you know the Fates are unpredictable. My success is not a certainty..."
      Speaker = "Melinoe"
      Event = "HecateAboutPressure01"
    }
    {
      Id = "Hecate_0531"
      InheritFrom = "BaseNarrative"
      DisplayName = "My faith is not in outcomes, 'tis in you! And I've enough of it to last. Should you find yours lacking, I shall always spare you some of mine."
      Speaker = "Hecate"
      Event = "HecateAboutPressure01"
    }
    {
      Id = "Melinoe_2135"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Thank you for believing in me."
      Speaker = "Melinoe"
      Event = "HecateAboutPressure01"
    }
    {
      Id = "Hecate_0532"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No need."
      Speaker = "Hecate"
      Event = "HecateAboutPressure01"
    }
    {
      Id = "Hecate_0623"
      InheritFrom = "BaseNarrative"
      DisplayName = "At least our cauldron's finally purified, praise the Fates! Speaking of which, are you as yet considering an invocation to them? I have my doubts that they would listen, even now..."
      Speaker = "Hecate"
      Event = "HecateAboutQuestLog01"
    }
    {
      Id = "Melinoe_2900"
      InheritFrom = "BaseNarrative"
      DisplayName = "If there's any chance the Three Fates shall aid us, I'll take it. Thank you for preparing things for me. Though, I'm well short of freshly picked reagents still."
      Speaker = "Melinoe"
      Event = "HecateAboutQuestLog01"
    }
    {
      Id = "Hecate_0416"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Mm. {#Prev}I'd offer such reagents if I could but, as you venture past this glade look carefully along your path and you shall find them. Fates willing..."
      Speaker = "Hecate"
      Event = "HecateAboutQuestLog01"
    }
    {
      Id = "Melinoe_0585"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yes, Headmistress."
      Speaker = "Melinoe"
      Event = "HecateAboutQuestLog01"
    }
    {
      Id = "Hecate_0419"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Fates indulged you after all. That is their scroll beside your tent; it followed you out of the shadows. Perhaps it can provide some answers."
      Speaker = "Hecate"
      Event = "HecateAboutQuestLog02"
    }
    {
      Id = "Melinoe_0968"
      InheritFrom = "BaseNarrative"
      DisplayName = "Would that it does. The Fated List has tasked me with ensuring certain minor prophecies are fulfilled, though says little else as yet."
      Speaker = "Melinoe"
      Event = "HecateAboutQuestLog02"
    }
    {
      Id = "Hecate_0420"
      InheritFrom = "BaseNarrative"
      DisplayName = "May it reward your efforts, at least. But do not expect the Fates to always favor you; the bane of our enemy is not necessarily our friend."
      Speaker = "Hecate"
      Event = "HecateAboutQuestLog02"
    }
    {
      Id = "Melinoe_1800"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We'll have to take our chances..."
      Speaker = "Melinoe"
      Event = "HecateAboutQuestLog02"
    }
    {
      Id = "Hecate_0625"
      InheritFrom = "BaseNarrative"
      DisplayName = "Those paths and possibilities are real, like as not; as are the splendors that await, should you indulge our primordial benefactor. There always is uncertainty where Chaos is concerned... yet I trust that Nyx's parent is an ally, not a threat."
      Speaker = "Hecate"
      Event = "HecateAboutBountyBoard01"
    }
    {
      Id = "Melinoe_2902"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I trust so too."
      Speaker = "Melinoe"
      Event = "HecateAboutBountyBoard01"
    }
    {
      Id = "Hecate_0273"
      InheritFrom = "BaseNarrative"
      DisplayName = "Have you had opportunity to glean much from the Book of Shadows yet, Melinoë? Our task shall take you far beyond these Crossroads; you've much to learn as yet."
      Speaker = "Hecate"
      Event = "HecateAboutCodex01"
    }
    {
      Id = "Melinoe_1011"
      InheritFrom = "BaseNarrative"
      DisplayName = "As I begin to have insights into my experiences, the Book reveals more. Are they {#Emph}your {#Prev}teachings within, Headmistress?"
      Speaker = "Melinoe"
      Event = "HecateAboutCodex01"
    }
    {
      Id = "Hecate_0274"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not mine alone, though heed them anyway..."
      Speaker = "Hecate"
      Event = "HecateAboutCodex01"
    }
    {
      Id = "Melinoe_5287"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Book of Shadows... I wasn't always certain who the author was. I suspected it was you, the way it sometimes anticipated my own thoughts before they were fully formed."
      Speaker = "Melinoe"
      Event = "HecateAboutCodex02"
    }
    {
      Id = "Hecate_0848"
      InheritFrom = "BaseNarrative"
      DisplayName = "You weren't entirely correct, though were on to something as to why the author understood your thoughts so well. 'Tis quite an old book... do take care of it for me."
      Speaker = "Hecate"
      Event = "HecateAboutCodex02"
    }
    {
      Id = "Melinoe_5288"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I swear I will."
      Speaker = "Melinoe"
      Event = "HecateAboutCodex02"
    }
    {
      Id = "Hecate_0642"
      InheritFrom = "BaseNarrative"
      DisplayName = "I recall when I myself first grasped the Flames of Ygnium. I must have been about your age. Now you are possessed of their power."
      Speaker = "Hecate"
      Event = "HecateAboutTorch01"
    }
    {
      Id = "Melinoe_1014"
      InheritFrom = "BaseNarrative"
      DisplayName = "All it takes is a bit of light to cast a long shadow; isn't that so, Headmistress? I'll do my best to wield the Flames as you have taught."
      Speaker = "Melinoe"
      Event = "HecateAboutTorch01"
    }
    {
      Id = "Hecate_0643"
      InheritFrom = "BaseSubtitle"
      DisplayName = "In your {#Emph}own {#Prev}way, Melinoë."
      Speaker = "Hecate"
      Event = "HecateAboutTorch01"
    }
    {
      Id = "Melinoe_0970"
      InheritFrom = "BaseNarrative"
      DisplayName = "I dreamt of Father once again. When Chronos came for him, and you took me to safety. Except this time, I remained there longer than before."
      Speaker = "Melinoe"
      Event = "HecateAboutFates01"
    }
    {
      Id = "Hecate_0271"
      InheritFrom = "BaseNarrative"
      DisplayName = "'Tis more than a dream, of course. And what else did you learn whilst you lingered thus?"
      Speaker = "Hecate"
      Event = "HecateAboutFates01"
    }
    {
      Id = "Melinoe_2916"
      InheritFrom = "BaseNarrative"
      DisplayName = "I learned Chronos wanted for Father to tell him where to locate the Three Fates. Chronos hates them, or feels threatened by them. He's been searching for them all this time, hasn't he? And finally found them."
      Speaker = "Melinoe"
      Event = "HecateAboutFates01"
    }
    {
      Id = "Hecate_0640"
      InheritFrom = "BaseNarrative"
      DisplayName = "Which means they may not take our side if forced to choose. I feared as much, yet didn't wish to lend the possibility my voice. Well, this certainly fits the spirit of the news swift Hermes relayed when he spurred us to act! {#Emph}Something real real bad{#Prev}, I believe were his words?"
      Speaker = "Hecate"
      Event = "HecateAboutFates01"
    }
    {
      Id = "Melinoe_2917"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Real real bad{#Prev}, yes..."
      Speaker = "Melinoe"
      Event = "HecateAboutFates01"
    }
    {
      Id = "Hecate_0285"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your dreams have troubled you again, I see. Despite your brave attempts to conceal it."
      Speaker = "Hecate"
      Event = "HecateAboutNightmares01"
    }
    {
      Id = "Melinoe_1021"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can manage them, Headmistress, it's just... it's Chronos. I now hear him even when I'm still as death."
      Speaker = "Melinoe"
      Event = "HecateAboutNightmares01"
    }
    {
      Id = "Hecate_0286"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then turn your nightmares into his. Your subconscious self is your greatest refuge. Let none there remain whom you do not permit."
      Speaker = "Hecate"
      Event = "HecateAboutNightmares01"
    }
    {
      Id = "Hecate_0014"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sister Selene tells me that she lent you her brilliance and might. You were able to draw her down even within this place?"
      Speaker = "Hecate"
      Event = "HecateAboutSelene01"
    }
    {
      Id = "Melinoe_0043"
      InheritFrom = "BaseNarrative"
      DisplayName = "I found a source of moonlight and invoked Selene's aid using the Words, Headmistress. I can't imagine the extent of her power."
      Speaker = "Melinoe"
      Event = "HecateAboutSelene01"
    }
    {
      Id = "Hecate_0015"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know her power perfectly well. You simply haven't had the opportunities to wield it. You shall have them very soon, I think."
      Speaker = "Hecate"
      Event = "HecateAboutSelene01"
    }
    {
      Id = "Melinoe_0152"
      InheritFrom = "BaseNarrative"
      DisplayName = "This task... why does it fall solely to me, Headmistress? Because, Nemesis, she..."
      Speaker = "Melinoe"
      Event = "HecateAboutNemesis01"
    }
    {
      Id = "Hecate_0035"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}She {#Prev}is a burden. Had I not sworn to Nyx that I would watch over her children, I'd have cast her out for insubordination long ago."
      Speaker = "Hecate"
      Event = "HecateAboutNemesis01"
    }
    {
      Id = "Melinoe_0153"
      InheritFrom = "BaseNarrative"
      DisplayName = "She's frustrated you haven't given her a chance. Her strength far surpasses mine and she's trained at least as hard; I've seen it!"
      Speaker = "Melinoe"
      Event = "HecateAboutNemesis01"
    }
    {
      Id = "Hecate_0036"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why defend her thus, Melinoë? Her attitude speaks far louder than she. I shall entrust nothing of import to one such as that."
      Speaker = "Hecate"
      Event = "HecateAboutNemesis01"
    }
    {
      Id = "Melinoe_2244"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}<Scoff>"
      Speaker = "Melinoe"
      Event = "HecateAboutNemesis01"
    }
    {
      Id = "Hecate_0853"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hypnos certainly left in a hurry. It took you longer to wake him than I initially surmised, but 'twas for the best."
      Speaker = "Hecate"
      Event = "HecateAboutHypnosWakeUp01"
    }
    {
      Id = "Melinoe_5292"
      InheritFrom = "BaseNarrative"
      DisplayName = "What, you {#Emph}knew {#Prev}this would happen? Why didn't you say anything for all the times I tried to break him out of his slumber? I thought you were ignoring him."
      Speaker = "Melinoe"
      Event = "HecateAboutHypnosWakeUp01"
    }
    {
      Id = "Hecate_0854"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh I was, after I saw that you had learned sufficiently. Your affinity toward dreams and the like proved necessary to the task, and Hypnos, in his way, was an accessory to that."
      Speaker = "Hecate"
      Event = "HecateAboutHypnosWakeUp01"
    }
    {
      Id = "Melinoe_5293"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You brought him here for me to practice on?"
      Speaker = "Melinoe"
      Event = "HecateAboutHypnosWakeUp01"
    }
    {
      Id = "Hecate_0855"
      InheritFrom = "BaseSubtitle"
      DisplayName = "He did require a place to stay."
      Speaker = "Hecate"
      Event = "HecateAboutHypnosWakeUp01"
    }
    {
      Id = "Melinoe_2914"
      InheritFrom = "BaseNarrative"
      DisplayName = "Last night, Headmistress, I traversed a gate that led me to the depths of Chaos... where I met its host! I've heard so much from you of Nyx, yet somehow I never expected to meet her mother and father."
      Speaker = "Melinoe"
      Event = "HecateAboutChaos01"
    }
    {
      Id = "Hecate_0638"
      InheritFrom = "BaseNarrative"
      DisplayName = "An audience with Primordial Chaos... I'd not entirely expected that! Although given Nyx herself has not been seen since Chronos took the House of Hades, I am unsurprised. There is no fury like that of a parent bereft of their child. Does Chaos seem an ally to us, then?"
      Speaker = "Hecate"
      Event = "HecateAboutChaos01"
    }
    {
      Id = "Melinoe_2915"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I believe so."
      Speaker = "Melinoe"
      Event = "HecateAboutChaos01"
    }
    {
      Id = "Hecate_0639"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Well, thank you Nyx for that..."
      Speaker = "Hecate"
      Event = "HecateAboutChaos01"
    }
    {
      Id = "Hecate_0601"
      InheritFrom = "BaseNarrative"
      DisplayName = "Eris has returned to us, I trust you've seen? 'Twas my dearest hope that leaving all her rubbish here would soon enough inspire her to pick it up, but alas.... You stay away from her."
      Speaker = "Hecate"
      Event = "HecateAboutEris01"
    }
    {
      Id = "Melinoe_2528"
      InheritFrom = "BaseNarrative"
      DisplayName = "I thought perhaps you'd finally relieved her of her entry privileges. I won't let Eris turn this place into a sty for pigs, even if it means having to clean up after her myself."
      Speaker = "Melinoe"
      Event = "HecateAboutEris01"
    }
    {
      Id = "Hecate_0602"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, how she'd chortle could she see now the frustration on your face. I know, ignoring things is seldom how one makes them go away, but... when it comes to Eris, I fear it's our best shot..."
      Speaker = "Hecate"
      Event = "HecateAboutEris01"
    }
    {
      Id = "Hecate_0645"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sister Selene notified me it was Eris herself who barred you from gaining the heights of Olympus. She never should have got her hands on the Rail of Adamant again, that {#Emph}wretch."
      Speaker = "Hecate"
      Event = "HecateAboutErisFight01"
    }
    {
      Id = "Melinoe_3445"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress, is there truly nothing we can do? Your oath to Nyx means Eris can come and go here as she pleases, only to try and blast me to bits when I approach my goal?"
      Speaker = "Melinoe"
      Event = "HecateAboutErisFight01"
    }
    {
      Id = "Hecate_0646"
      InheritFrom = "BaseNarrative"
      DisplayName = "One must carefully consider the terms of binding contracts, Melinoë. A mistake on my part you are paying for firsthand, {#Emph}heh. {#Prev}And I apologize. Do bring her hell when next you meet?"
      Speaker = "Hecate"
      Event = "HecateAboutErisFight01"
    }
    {
      Id = "Melinoe_3446"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Sounds good..."
      Speaker = "Melinoe"
      Event = "HecateAboutErisFight01"
    }
    {
      Id = "Hecate_0706"
      InheritFrom = "BaseNarrative"
      DisplayName = "You flushed Prometheus out from his hiding-spot. Slipped from his chains somehow! Whether he's a pure idealist or merely in it for rebellion's sake, I've yet to ascertain."
      Speaker = "Hecate"
      Event = "HecateAboutPrometheus01"
    }
    {
      Id = "Melinoe_3895"
      InheritFrom = "BaseNarrative"
      DisplayName = "His reasons for siding with Chronos seem plain enough; for one, he wants his vengeance on Lord Uncle Zeus and the rest. And for another, he's a Titan himself."
      Speaker = "Melinoe"
      Event = "HecateAboutPrometheus01"
    }
    {
      Id = "Hecate_0707"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}I {#Prev}am a Titaness as well, as is Sister Selene, lest you forget! Our lineage need not dictate our loyalties or principles. Although perhaps Prometheus sees otherwise."
      Speaker = "Hecate"
      Event = "HecateAboutPrometheus01"
    }
    {
      Id = "Melinoe_3896"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Is it true he can see all that is to come?"
      Speaker = "Melinoe"
      Event = "HecateAboutPrometheus01"
    }
    {
      Id = "Hecate_0708"
      InheritFrom = "BaseSubtitle"
      DisplayName = "He's merely mad, perhaps. And in more ways than one."
      Speaker = "Hecate"
      Event = "HecateAboutPrometheus01"
    }
    {
      Id = "Hecate_0709"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hermes informed me that Prometheus redoubled his attacks upon Olympus, after he fended you aside. Have I not trained you how to withstand flames?"
      Speaker = "Hecate"
      Event = "HecateAboutPrometheusL01"
    }
    {
      Id = "Melinoe_3897"
      InheritFrom = "BaseNarrative"
      DisplayName = "If only all he had was flames, but no, he has a vicious Eagle pet and more. What of Olympus, what has he done?"
      Speaker = "Melinoe"
      Event = "HecateAboutPrometheusL01"
    }
    {
      Id = "Hecate_0710"
      InheritFrom = "BaseNarrative"
      DisplayName = "He's kept the gods on their back foot. Never fully committing his forces, avoiding fights he cannot win! Frustrating adversary, even if he shall not prevail."
      Speaker = "Hecate"
      Event = "HecateAboutPrometheusL01"
    }
    {
      Id = "Melinoe_3898"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Why not?"
      Speaker = "Melinoe"
      Event = "HecateAboutPrometheusL01"
    }
    {
      Id = "Hecate_0711"
      InheritFrom = "BaseSubtitle"
      DisplayName = "He's but one Titan 'gainst a dozen or more gods."
      Speaker = "Hecate"
      Event = "HecateAboutPrometheusL01"
    }
    {
      Id = "Hecate_0760"
      InheritFrom = "BaseNarrative"
      DisplayName = "The fire-thief Prometheus insists on barring your path toward the mountain summit still. What nonsense has he filled your head with recently?"
      Speaker = "Hecate"
      Event = "HecateAboutPrometheus02"
    }
    {
      Id = "Melinoe_4048"
      InheritFrom = "BaseNarrative"
      DisplayName = "He seems to bear a deep sense of responsibility and guilt for mortalkind. I'm concerned he aims to spread dissension in our ranks... some Shades who serve our cause must harbor sympathies."
      Speaker = "Melinoe"
      Event = "HecateAboutPrometheus02"
    }
    {
      Id = "Hecate_0761"
      InheritFrom = "BaseNarrative"
      DisplayName = "It sounds to me as though you are beginning to harbor such sympathies yourself. Do not be deceived by his lofty claims; he's sided with our enemy, and made that clear."
      Speaker = "Hecate"
      Event = "HecateAboutPrometheus02"
    }
    {
      Id = "Melinoe_4049"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yes... understood."
      Speaker = "Melinoe"
      Event = "HecateAboutPrometheus02"
    }
    {
      Id = "Hecate_0774"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hermes indicated you were instrumental in releasing Typhon's grip on Mount Olympus recently. I trust that your embattled relatives contributed their share to that result?"
      Speaker = "Hecate"
      Event = "HecateAboutTyphonW02"
    }
    {
      Id = "Melinoe_4355"
      InheritFrom = "BaseNarrative"
      DisplayName = "I may be just a frontline diversion in stopping the monster's attacks, but it worked. Lord Zeus at least was able to remind Typhon about the power of his lightning bolt. The others had their hands full someplace else..."
      Speaker = "Melinoe"
      Event = "HecateAboutTyphonW02"
    }
    {
      Id = "Hecate_0775"
      InheritFrom = "BaseNarrative"
      DisplayName = "The gods must be grateful for such an effective {#Emph}frontline diversion{#Prev}, and Chronos must be grateful for the brief reprieve as well. But carry on as you see fit; this was all part of the Titan's plan, and shall likewise factor into ours."
      Speaker = "Hecate"
      Event = "HecateAboutTyphonW02"
    }
    {
      Id = "Melinoe_4356"
      InheritFrom = "BaseSubtitle"
      DisplayName = "My thoughts exactly."
      Speaker = "Melinoe"
      Event = "HecateAboutTyphonW02"
    }
    {
      Id = "Hecate_0849"
      InheritFrom = "BaseNarrative"
      DisplayName = "Selene indicates that you seemingly withstood the Vow of Rivals all the way to the end. She's not exactly prone to error, but such a claim I need to verify."
      Speaker = "Hecate"
      Event = "HecateAboutTyphonAltFightW01"
    }
    {
      Id = "Melinoe_5289"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then consider the claim verified. I almost expected some great feast or ceremony considering all it took. Though I suppose that's not the way the will of Night is done. "
      Speaker = "Melinoe"
      Event = "HecateAboutTyphonAltFightW01"
    }
    {
      Id = "Hecate_0850"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nyx herself would say, {#Emph}seek to be valuable, not to be known. {#Prev}Selene and I at least know what you achieved. But if 'tis glory you desire, you were born in the wrong realm."
      Speaker = "Hecate"
      Event = "HecateAboutTyphonAltFightW01"
    }
    {
      Id = "Melinoe_5290"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This was glory enough."
      Speaker = "Melinoe"
      Event = "HecateAboutTyphonAltFightW01"
    }
    {
      Id = "Hecate_0777"
      InheritFrom = "BaseNarrative"
      DisplayName = "Were the heights of Olympus all that you imagined, at the Palace of Lord Zeus? If you're to overcome such hardships to reach that point, the view had best be worth the while."
      Speaker = "Hecate"
      Event = "HecateAboutPalace01"
    }
    {
      Id = "Melinoe_4726"
      InheritFrom = "BaseNarrative"
      DisplayName = "The palace grounds were like nothing I've ever beheld. Though everything was so vivid, I scarce could see at all. I felt as though I didn't belong there."
      Speaker = "Melinoe"
      Event = "HecateAboutPalace01"
    }
    {
      Id = "Hecate_0778"
      InheritFrom = "BaseNarrative"
      DisplayName = "That you do not. Well, as long as your mountain relatives showed you a bit of hospitality in the brief time you had!"
      Speaker = "Hecate"
      Event = "HecateAboutPalace01"
    }
    {
      Id = "Melinoe_4727"
      InheritFrom = "BaseSubtitle"
      DisplayName = "They did but... I'm glad I'm back."
      Speaker = "Melinoe"
      Event = "HecateAboutPalace01"
    }
    {
      Id = "Hecate_0762"
      InheritFrom = "BaseNarrative"
      DisplayName = "Each of the two great enemies we face, you have laid low, one after the other. Thus, we begin to take the upper hand..."
      Speaker = "Hecate"
      Event = "HecateAboutUltimateProgress01"
    }
    {
      Id = "Melinoe_4050"
      InheritFrom = "BaseNarrative"
      DisplayName = "I may be able to beat Chronos or Typhon in a fight, but at times I feel as though I've come no closer to stopping either of them. It's reassuring you think otherwise."
      Speaker = "Melinoe"
      Event = "HecateAboutUltimateProgress01"
    }
    {
      Id = "Hecate_0763"
      InheritFrom = "BaseNarrative"
      DisplayName = "I more than think; you've demonstrated that you have the strength and knowledge to complete your task. As to whether you have the patience, that we shall have to see."
      Speaker = "Hecate"
      Event = "HecateAboutUltimateProgress01"
    }
    {
      Id = "Melinoe_4051"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Patience, then..."
      Speaker = "Melinoe"
      Event = "HecateAboutUltimateProgress01"
    }
    {
      Id = "Hecate_0791"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Dissolution of Time. Disintegration of Monstrosity. {#Prev}Connected incantations, negating that which has already come to pass, and violently. A terrible use of our craft..."
      Speaker = "Hecate"
      Event = "HecateAboutUltimateProgress02"
    }
    {
      Id = "Melinoe_5777"
      InheritFrom = "BaseNarrative"
      DisplayName = "It is. You always said such power ought never to be used, save when no other possibility avails itself... perhaps not even then. How did you discover such incantations? You practically know more of Chronos than he does himself."
      Speaker = "Melinoe"
      Event = "HecateAboutUltimateProgress02"
    }
    {
      Id = "Hecate_0792"
      InheritFrom = "BaseNarrative"
      DisplayName = "When I learned of what Chronos had done to you and the rest... I refused to accept it. But I studied him nevertheless. Power always contains the secrets of its own undoing."
      Speaker = "Hecate"
      Event = "HecateAboutUltimateProgress02"
    }
    {
      Id = "Melinoe_4742"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Even his and Typhon's..."
      Speaker = "Melinoe"
      Event = "HecateAboutUltimateProgress02"
    }
    {
      Id = "Hecate_0793"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Even his and Typhon's."
      Speaker = "Hecate"
      Event = "HecateAboutUltimateProgress02"
    }
    {
      Id = "Melinoe_4733"
      InheritFrom = "BaseNarrative"
      DisplayName = "My father's spear, Gigaros... it was there in the Prince's chambers for me to find. Zagreus must have gotten access to it in his time, as I have now. One final step, then?"
      Speaker = "Melinoe"
      Event = "HecateAboutUltimateProgress03_A"
    }
    {
      Id = "Hecate_0788_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not quite. We have one opportunity to use it against Chronos, and shall take every precaution to ensure it shall have the intended result."
      Speaker = "Hecate"
      Event = "HecateAboutUltimateProgress03_A"
    }
    {
      Id = "Melinoe_5016"
      InheritFrom = "BaseNarrative"
      DisplayName = "Entropy is the last reagent we require for the Dissolution of Time, but... where am I supposed to find it? I've found no trace as yet... even from Typhon."
      Speaker = "Melinoe"
      Event = "HecateAboutUltimateProgress03_A"
    }
    {
      Id = "Hecate_0795"
      InheritFrom = "BaseNarrative"
      DisplayName = "Where are you supposed to {#Emph}create {#Prev}it is the correct question to be asking. A powerful enough force must be put entirely to rest. Do you catch my meaning?"
      Speaker = "Hecate"
      Event = "HecateAboutUltimateProgress03_A"
    }
    {
      Id = "Melinoe_5017"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...I believe so. Back to the surface, then."
      Speaker = "Melinoe"
      Event = "HecateAboutUltimateProgress03_A"
    }
    {
      Id = "Melinoe_5730"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...I believe so. First step, Disintegration of Monstrosity."
      Speaker = "Melinoe"
      Event = "HecateAboutUltimateProgress03_A"
    }
    {
      Id = "Hecate_0752"
      InheritFrom = "BaseNarrative"
      DisplayName = "That we do, and you had best keep reminding yourself of it ere you confront the Father of All Monsters again. Do not take unnecessary risks, or lose sight of the task."
      Speaker = "Hecate"
      Event = "HecateAboutTyphonFight01"
    }
    {
      Id = "Melinoe_4047"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We do as we must."
      Speaker = "Melinoe"
      Event = "HecateAboutTyphonFight01"
    }
    {
      Id = "Hecate_0753"
      InheritFrom = "BaseNarrative"
      DisplayName = "I would commend you for the outcome were I not so utterly aghast. The Father of All Monsters may not be quite so easy to surprise ere you confront him again. Do not take unnecessary risks or lose sight of the task."
      Speaker = "Hecate"
      Event = "HecateAboutTyphonFight01_B"
    }
    {
      Id = "Hecate_0754"
      InheritFrom = "BaseNarrative"
      DisplayName = "'Tis a wonder that your mountain relatives are still able to be of benefit to you whilst having Typhon at their gates. Do they have any sort of strategy to stop him, do you know?"
      Speaker = "Hecate"
      Event = "HecateAboutTyphonFight02"
    }
    {
      Id = "Melinoe_4044"
      InheritFrom = "BaseNarrative"
      DisplayName = "They're working together to drive him back, along with the Titan's legions. But if they have a greater plan to put an end to the assault, they've not yet let on."
      Speaker = "Melinoe"
      Event = "HecateAboutTyphonFight02"
    }
    {
      Id = "Hecate_0755"
      InheritFrom = "BaseNarrative"
      DisplayName = "Let us assume then that they've no such plan. However, I'm beginning to think the Father of All Monsters may yet figure into ours. Collect what samples that you can from him."
      Speaker = "Hecate"
      Event = "HecateAboutTyphonFight02"
    }
    {
      Id = "Melinoe_0042"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I shall, Headmistress."
      Speaker = "Melinoe"
      Event = "HecateAboutTyphonFight02"
    }
    {
      Id = "Hecate_0756"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your victories against Typhon... have you there anything to show for it? Any sort of specimens or samples of his flesh?"
      Speaker = "Hecate"
      Event = "HecateAboutTyphonFight03"
    }
    {
      Id = "Melinoe_4045"
      InheritFrom = "BaseNarrative"
      DisplayName = "I hope you like hideous eyes, Headmistress. Is there an incantation that you have in mind requiring such filth?"
      Speaker = "Melinoe"
      Event = "HecateAboutTyphonFight03"
    }
    {
      Id = "Hecate_0757"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps. Hold onto all of that for now. But when the time is right, we shall turn all that monstrous power back against itself. And rid this world of that fiend for good."
      Speaker = "Hecate"
      Event = "HecateAboutTyphonFight03"
    }
    {
      Id = "Melinoe_2519_A"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Yes, Headmistress."
      Speaker = "Melinoe"
      Event = "HecateAboutTyphonFight03"
    }
    {
      Id = "Hecate_0756_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your victory 'gainst Typhon... have you there anything to show for it? Any sort of specimens or samples of his flesh?"
      Speaker = "Hecate"
      Event = "HecateAboutTyphonFight03_B"
    }
    {
      Id = "Melinoe_1177"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress, I saw him. {#Emph}Chronos! {#Prev}He was in the pathways beyond Erebus. I struck as soon as I realized who he was, but to no avail."
      Speaker = "Melinoe"
      Event = "HecateAboutChronos01"
    }
    {
      Id = "Hecate_0776"
      InheritFrom = "BaseNarrative"
      DisplayName = "He thinks himself clever, the arrogant wretch. So then he knows of you. What did he say?"
      Speaker = "Hecate"
      Event = "HecateAboutChronos01"
    }
    {
      Id = "Melinoe_1178"
      InheritFrom = "BaseNarrative"
      DisplayName = "He thanked the Fates that we had finally met, as though he'd been searching for me all this time... and told me to not make the same mistakes as my family."
      Speaker = "Melinoe"
      Event = "HecateAboutChronos01"
    }
    {
      Id = "Hecate_0034"
      InheritFrom = "BaseNarrative"
      DisplayName = "Eject that poisoned memory from your mind; he knows nothing of the Fates' designs. I shall reinforce all our protective sorceries, and {#Emph}you: {#Prev}Fear not your enemy; {#Emph}slay him!"
      Speaker = "Hecate"
      Event = "HecateAboutChronos01"
    }
    {
      Id = "Melinoe_2520"
      InheritFrom = "BaseNarrative"
      DisplayName = "Chronos was waiting for me again outside of Erebus. This time I recognized him right away, but I could do nothing against him..."
      Speaker = "Melinoe"
      Event = "HecateAboutChronos02"
    }
    {
      Id = "Hecate_0033_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wily bastard. Arrogant to the last.... What did he say?"
      Speaker = "Hecate"
      Event = "HecateAboutChronos02"
    }
    {
      Id = "Melinoe_2903"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress, I found him! {#Emph}Chronos! {#Prev}Deep within Tartarus, just as you said. I did everything as practiced and as planned, except... he was too strong."
      Speaker = "Melinoe"
      Event = "HecateAboutChronosBossEarlyL01"
    }
    {
      Id = "Hecate_0591"
      InheritFrom = "BaseNarrative"
      DisplayName = "Still your heart, Melinoë, you're safe. And you were able to return again, which means that all your training served you well.... So then... he realizes who you are?"
      Speaker = "Hecate"
      Event = "HecateAboutChronosBossEarlyL01"
    }
    {
      Id = "Melinoe_2904"
      InheritFrom = "BaseNarrative"
      DisplayName = "He does. We've lost the element of surprise now, haven't we? Damn it... how could I fail?"
      Speaker = "Melinoe"
      Event = "HecateAboutChronosBossEarlyL01"
    }
    {
      Id = "Hecate_0592"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nothing has changed; you're to confront him down where he resides. Where your mother and father rightly ought to be. But go with patience, not with haste. He may know something of your power now, yet not enough."
      Speaker = "Hecate"
      Event = "HecateAboutChronosBossEarlyL01"
    }
    {
      Id = "Melinoe_2905"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...I'll get him."
      Speaker = "Melinoe"
      Event = "HecateAboutChronosBossEarlyL01"
    }
    {
      Id = "Melinoe_2797"
      InheritFrom = "BaseNarrative"
      DisplayName = "I reached the House, Headmistress. Did everything as practiced and as planned, except... he was too strong."
      Speaker = "Melinoe"
      Event = "HecateAboutChronosBossL01"
    }
    {
      Id = "Hecate_0630"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}No{#Prev}, this is an {#Emph}excellent {#Prev}result! You are still here, having learned more of what it takes to reach our enemy, and what {#Emph}he {#Prev}can do to resist! Do you feel ready to continue your pursuit?"
      Speaker = "Hecate"
      Event = "HecateAboutChronosBossL01"
    }
    {
      Id = "Melinoe_2798"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes. If I can reach him... I can take him."
      Speaker = "Melinoe"
      Event = "HecateAboutChronosBossL01"
    }
    {
      Id = "Hecate_0631"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Take him."
      Speaker = "Hecate"
      Event = "HecateAboutChronosBossL01"
    }
    {
      Id = "Melinoe_3469"
      InheritFrom = "BaseNarrative"
      DisplayName = "Again I've failed to destroy the Titan, Headmistress. Night after night he thwarts me, expecting I'll eventually give in..."
      Speaker = "Melinoe"
      Event = "HecateAboutChronosBossL02"
    }
    {
      Id = "Hecate_0668"
      InheritFrom = "BaseNarrative"
      DisplayName = "But you've no such intent, correct? You cannot stop him, and neither has he been able to stop {#Emph}you. {#Prev}You are resistant to his power and he cannot bar you from {#Emph}your realm."
      Speaker = "Hecate"
      Event = "HecateAboutChronosBossL02"
    }
    {
      Id = "Melinoe_3470"
      InheritFrom = "BaseNarrative"
      DisplayName = "You make it sound as though I've beaten him."
      Speaker = "Melinoe"
      Event = "HecateAboutChronosBossL02"
    }
    {
      Id = "Hecate_0669"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not yet; but soon enough, I trust."
      Speaker = "Hecate"
      Event = "HecateAboutChronosBossL02"
    }
    {
      Id = "Hecate_0632"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're back...! Now tell me everything. You found your mark? What then?"
      Speaker = "Hecate"
      Event = "HecateAboutChronosBossW01"
    }
    {
      Id = "Melinoe_2799"
      InheritFrom = "BaseNarrative"
      DisplayName = "I reached the edge of Tartarus and made my way into the House, just as we planned. Chronos was there, on my father's throne. We clashed. He lost. But I know he isn't gone. And I was unable to linger there for long."
      Speaker = "Melinoe"
      Event = "HecateAboutChronosBossW01"
    }
    {
      Id = "Hecate_0779"
      InheritFrom = "BaseNarrative"
      DisplayName = "I trust you made each moment count. We were never going to destroy the Titan with brute force alone, but soon enough, he may yet be undone entirely. Provided you have more good tidings to report...?"
      Speaker = "Hecate"
      Event = "HecateAboutChronosBossW01"
    }
    {
      Id = "Melinoe_4728"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Mirror was intact... abandoned in the Prince's chambers. And the incantation worked! I found my brother in the past and spoke to him, but had so little time. I barely managed to convince him as to who I am."
      Speaker = "Melinoe"
      Event = "HecateAboutChronosBossW01"
    }
    {
      Id = "Hecate_0780"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then speak swiftly the next opportunity you get. And continue not to overstay, lest the task end in failure. As for the Titan... study him, as I shall study what you found."
      Speaker = "Hecate"
      Event = "HecateAboutChronosBossW01"
    }
    {
      Id = "Hecate_0635"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, by the way... something awaits you in the training grounds. You proved beyond a doubt that you're prepared."
      Speaker = "Hecate"
      Event = "HecateAboutChronosBossW01Cont1"
    }
    {
      Id = "Hecate_0781"
      InheritFrom = "BaseNarrative"
      DisplayName = "You brought the Titan low again, but what transpired after that? Was your bygone brother more cooperative than before?"
      Speaker = "Hecate"
      Event = "HecateAboutChronosBossW02"
    }
    {
      Id = "Melinoe_4729"
      InheritFrom = "BaseNarrative"
      DisplayName = "He doesn't know where to find Chronos, though seems willing to investigate. Perhaps he'll turn something up. I still scarce believe it's truly his past self I've spoken to..."
      Speaker = "Melinoe"
      Event = "HecateAboutChronosBossW02"
    }
    {
      Id = "Hecate_0782"
      InheritFrom = "BaseNarrative"
      DisplayName = "Imagine how {#Emph}he {#Prev}feels. Continue to check up on him, but not a word of this to anybody else. Time flows ever forward, and we are not meant to travel opposite that stream."
      Speaker = "Hecate"
      Event = "HecateAboutChronosBossW02"
    }
    {
      Id = "Melinoe_4730"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It shouldn't be possible..."
      Speaker = "Melinoe"
      Event = "HecateAboutChronosBossW02"
    }
    {
      Id = "Hecate_0783"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}We {#Prev}determine what is possible, Melinoë."
      Speaker = "Hecate"
      Event = "HecateAboutChronosBossW02"
    }
    {
      Id = "Hecate_0784"
      InheritFrom = "BaseNarrative"
      DisplayName = "We heard about the Titan's latest misfortune by your hand. Is all else proceeding as intended, by your estimation?"
      Speaker = "Hecate"
      Event = "HecateAboutChronosBossW03"
    }
    {
      Id = "Melinoe_4731"
      InheritFrom = "BaseNarrative"
      DisplayName = "I think so. We just need to find a suitable weapon now, and then... everything that's come to pass can be undone."
      Speaker = "Melinoe"
      Event = "HecateAboutChronosBossW03"
    }
    {
      Id = "Hecate_0785"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps not {#Emph}everything{#Prev}, but plenty. You know the rest by heart and I'll not pry for further details. But should an unexpected setback come to pass, tell me at once."
      Speaker = "Hecate"
      Event = "HecateAboutChronosBossW03"
    }
    {
      Id = "Melinoe_4732"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I shall."
      Speaker = "Melinoe"
      Event = "HecateAboutChronosBossW03"
    }
    {
      Id = "Hecate_0786"
      InheritFrom = "BaseNarrative"
      DisplayName = "First let us put what you discovered to the test. Once the incantation I shall teach you is complete, seek out Typhon... and use the spear essence after his strength has waned."
      Speaker = "Hecate"
      Event = "HecateAboutChronosBossW04"
    }
    {
      Id = "Melinoe_4734"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What shall become of Typhon once I do?"
      Speaker = "Melinoe"
      Event = "HecateAboutChronosBossW04"
    }
    {
      Id = "Hecate_0787"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...He'll be nothing."
      Speaker = "Hecate"
      Event = "HecateAboutChronosBossW04"
    }
    {
      Id = "Melinoe_4735"
      InheritFrom = "BaseNarrative"
      DisplayName = "You wish for me to turn my attention to Olympus for a while, so that we can test the Temporal Spear there first?"
      Speaker = "Melinoe"
      Event = "HecateAboutChronosBossW04_A"
    }
    {
      Id = "Hecate_0789"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yes. You need to prove that this shall work."
      Speaker = "Hecate"
      Event = "HecateAboutChronosBossW04_A"
    }
    {
      Id = "Hecate_0788"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not quite. We have one opportunity to use it against Chronos, and shall take every precaution to ensure it shall have the intended result. Perhaps whatever ails your Olympian relatives shall provide a suitable target."
      Speaker = "Hecate"
      Event = "HecateAboutChronosBossW04_B"
    }
    {
      Id = "Hecate_0796"
      InheritFrom = "BaseNarrative"
      DisplayName = "The foul deed is done. Have no pity for that monster, only gratitude... for yielding his power in his absence. Now you are ready for the final phase."
      Speaker = "Hecate"
      Event = "HecateAboutTyphonDeath01"
    }
    {
      Id = "Melinoe_5018"
      InheritFrom = "BaseNarrative"
      DisplayName = "Before I depart... my brother asked something I didn't know how to answer. If Chronos is destroyed before all this... what exactly happens to us here and now?"
      Speaker = "Melinoe"
      Event = "HecateAboutTyphonDeath01"
    }
    {
      Id = "Hecate_0797"
      InheritFrom = "BaseNarrative"
      DisplayName = "Let us discover the truth of it together. I am certain only that this is not goodbye. The conclusion of your task is at hand. {#Emph}Go{#Prev}, end this."
      Speaker = "Hecate"
      Event = "HecateAboutTyphonDeath01"
    }
    {
      Id = "Melinoe_5019"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...I'll see you again soon."
      Speaker = "Melinoe"
      Event = "HecateAboutTyphonDeath01"
    }
    {
      Id = "Hecate_0421"
      InheritFrom = "BaseNarrative"
      DisplayName = "One more of Nyx's kin is here for us to mind. Your incantation tracked him after all! {#Emph}Doom {#Prev}typically arrives {#Emph}uninvited{#Prev}, of course."
      Speaker = "Hecate"
      Event = "HecateAboutMoros01"
    }
    {
      Id = "Melinoe_1591"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lord Moros is to be our guest. I know his presence must seem an ill portent, but if the Fates wanted him here, who are we to fight it?"
      Speaker = "Melinoe"
      Event = "HecateAboutMoros01"
    }
    {
      Id = "Hecate_0422"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Who, indeed."
      Speaker = "Hecate"
      Event = "HecateAboutMoros01"
    }
    {
      Id = "Melinoe_1029"
      InheritFrom = "BaseNarrative"
      DisplayName = "I found him, Headmistress! My father! Chronos has him locked away in Tartarus. But, I couldn't save him... he asked I leave him be..."
      Speaker = "Melinoe"
      Event = "HecateAboutHades01"
    }
    {
      Id = "Hecate_0295"
      InheritFrom = "BaseNarrative"
      DisplayName = "Truly? How utterly predictable of Chronos to gloat in such a way. I regret that your reunion with Lord Hades thus transpired... though, I am gladdened you discovered him. How does he fare?"
      Speaker = "Hecate"
      Event = "HecateAboutHades01"
    }
    {
      Id = "Melinoe_1030"
      InheritFrom = "BaseNarrative"
      DisplayName = "He... {#Emph}ungh. {#Prev}I really wouldn't know. He seemed sound of mind and body, and he knew me soon enough. Gave me what blessing he could still bestow. What can we do?"
      Speaker = "Melinoe"
      Event = "HecateAboutHades01"
    }
    {
      Id = "Hecate_0296"
      InheritFrom = "BaseNarrative"
      DisplayName = "If he asked you leave him be, then 'tis evidence he wishes to remain unseen. Use full discretion and be brief, should you encounter him again; and {#Emph}I {#Prev}shall see about ensuring Chronos remains ignorant of your newfound connection."
      Speaker = "Hecate"
      Event = "HecateAboutHades01"
    }
    {
      Id = "Melinoe_1031"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...By your leave."
      Speaker = "Melinoe"
      Event = "HecateAboutHades01"
    }
    {
      Id = "Melinoe_5474"
      InheritFrom = "BaseNarrative"
      DisplayName = "I ought have told you by now but I found him, Headmistress... my father. Chronos has him locked in Tartarus like a common prisoner... he asked I leave him be."
      Speaker = "Melinoe"
      Event = "HecateAboutHades01_B"
    }
    {
      Id = "Melinoe_3456"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress, I've a message from my father that he asked me to relay: He sends his deepest gratitude..."
      Speaker = "Melinoe"
      Event = "HecateAboutHades02"
    }
    {
      Id = "Hecate_0654"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lord Hades told you this? {#Emph}Whyever for? {#Prev}He {#Emph}rots {#Prev}in his own prison whilst the Titan ransacks his domain! My charge was to safeguard the realm and I did not."
      Speaker = "Hecate"
      Event = "HecateAboutHades02"
    }
    {
      Id = "Melinoe_3457"
      InheritFrom = "BaseNarrative"
      DisplayName = "Father spoke of when he left me in your care, when Chronos struck. He must have feared the worst. Now he knows I'm well... all thanks to you."
      Speaker = "Melinoe"
      Event = "HecateAboutHades02"
    }
    {
      Id = "Hecate_0655"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, Melinoë, all this is thanks to {#Emph}Chronos. {#Prev}Your father would do well to save his gratitude ere we settle certain scores. Though... speak not to him of this... undignified response. I merely was taken aback."
      Speaker = "Hecate"
      Event = "HecateAboutHades02"
    }
    {
      Id = "Melinoe_3458"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Of course. I understand."
      Speaker = "Melinoe"
      Event = "HecateAboutHades02"
    }
    {
      Id = "Melinoe_2909"
      InheritFrom = "BaseNarrative"
      DisplayName = "At the edge of the Mourning Fields... I faced some sort of dark, infernal beast. Three monstrous canine maws, bellowing with fury and sorrow. It was my father's... my {#Emph}family's {#Prev}old dog... wasn't it?"
      Speaker = "Melinoe"
      Event = "HecateAboutCerberus01"
    }
    {
      Id = "Hecate_0628"
      InheritFrom = "BaseNarrative"
      DisplayName = "Through Odysseus we have a few reports about a creature fitting that description, more or less, but... Cerberus was {#Emph}red {#Prev}in hue, as blood. Nevertheless, a stay within the Fields could have transformative effects. {#Emph}Tsk{#Prev}, wretched thing. Torn from its home."
      Speaker = "Hecate"
      Event = "HecateAboutCerberus01"
    }
    {
      Id = "Melinoe_2910"
      InheritFrom = "BaseNarrative"
      DisplayName = "He doesn't seem to know who I am. Whether because it's been too long, or there's too much on his mind. Minds? But I felt a flash of recognition. He isn't too far gone, is he...?"
      Speaker = "Melinoe"
      Event = "HecateAboutCerberus01"
    }
    {
      Id = "Hecate_0629"
      InheritFrom = "BaseNarrative"
      DisplayName = "The nature of a beast can never change. Like us, however, they at times must fight the Daemons that torment them... a battle in which you can assist! Trust your training, and perhaps he can yet shake the spell that's overtaken him."
      Speaker = "Hecate"
      Event = "HecateAboutCerberus01"
    }
    {
      Id = "Melinoe_2911"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm certain that he can."
      Speaker = "Melinoe"
      Event = "HecateAboutCerberus01"
    }
    {
      Id = "Hecate_0666"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've not escaped the Mourning Fields as yet. The beast guarding the entrance into Tartarus seems insurmountable. 'Tis the effect of the Fields themselves."
      Speaker = "Hecate"
      Event = "HecateAboutCerberus02"
    }
    {
      Id = "Melinoe_3468"
      InheritFrom = "BaseNarrative"
      DisplayName = "What hope I have begins to drain from me as soon as I set foot in there. I know it's just a trick of the mind, but..."
      Speaker = "Melinoe"
      Event = "HecateAboutCerberus02"
    }
    {
      Id = "Hecate_0667"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...but an effective trick it is, I know."
      Speaker = "Hecate"
      Event = "HecateAboutCerberus02"
    }
    {
      Id = "Melinoe_0946"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress, Lord Zeus requested {#Emph}prompt reports{#Prev}, his words, from you about the situation in the Underworld. He seemed a little frustrated. Asked me to let you know."
      Speaker = "Melinoe"
      Event = "HecateAboutZeus01"
    }
    {
      Id = "Hecate_0262"
      InheritFrom = "BaseNarrative"
      DisplayName = "And you're as dutiful as ever, aren't you? Exactly as Lord Zeus wants us to be. Think you he truly cherishes these Underworld reports?"
      Speaker = "Hecate"
      Event = "HecateAboutZeus01"
    }
    {
      Id = "Melinoe_0947"
      InheritFrom = "BaseNarrative"
      DisplayName = "I... hadn't considered that he might not. He seems the sort to want to know about all goings-on, especially ones dangerous to him."
      Speaker = "Melinoe"
      Event = "HecateAboutZeus01"
    }
    {
      Id = "Hecate_0263"
      InheritFrom = "BaseNarrative"
      DisplayName = "Correct! He grows uneasy when the silence thickens. He'll get his prompt reports; though, just remember, he already {#Emph}has {#Prev}a messenger."
      Speaker = "Hecate"
      Event = "HecateAboutZeus01"
    }
    {
      Id = "Melinoe_1592"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress, I found Artemis out there. I'd not expected her so soon, but then, she's quick. Speaking of which, what of Hermes, any word?"
      Speaker = "Melinoe"
      Event = "HecateAboutArtemis01"
    }
    {
      Id = "Hecate_0417"
      InheritFrom = "BaseNarrative"
      DisplayName = "Alas, not yet. However, those two are resourceful and discreet... and Olympus remains none the wiser to our long-standing connection with them, if that is your concern."
      Speaker = "Hecate"
      Event = "HecateAboutArtemis01"
    }
    {
      Id = "Melinoe_1593"
      InheritFrom = "BaseNarrative"
      DisplayName = "My concern is their safety. May Hermes soon discover what exactly Chronos is scheming and return, though I know we can ill afford to wait."
      Speaker = "Melinoe"
      Event = "HecateAboutArtemis01"
    }
    {
      Id = "Hecate_0418"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No, we cannot. Hermes convinced me of that."
      Speaker = "Hecate"
      Event = "HecateAboutArtemis01"
    }
    {
      Id = "Hecate_0747"
      InheritFrom = "BaseNarrative"
      DisplayName = "The goddess of the hunt decided that the best use of her talents presently is to regale us with song! As you can hear, I managed to resist my inclination to forbid any such thing."
      Speaker = "Hecate"
      Event = "HecateAboutArtemisSinging01"
    }
    {
      Id = "Melinoe_4039"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm grateful that you did. I know Artemis sings to clear her mind and calm her nerves, but I think all the Shades about this place appreciate it, too."
      Speaker = "Melinoe"
      Event = "HecateAboutArtemisSinging01"
    }
    {
      Id = "Hecate_0748"
      InheritFrom = "BaseNarrative"
      DisplayName = "'Tis not how I myself prefer to face adversity, though I {#Emph}am {#Prev}open to whichever techniques work."
      Speaker = "Hecate"
      Event = "HecateAboutArtemisSinging01"
    }
    {
      Id = "Melinoe_1173"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hermes is back, Headmistress. He was able to lend some of his swiftness, and... also asked that I come to the aid of Olympus. Has the hour grown so desperate up there?"
      Speaker = "Melinoe"
      Event = "HecateAboutHermes01"
    }
    {
      Id = "Hecate_0423"
      InheritFrom = "BaseNarrative"
      DisplayName = "He would not ask otherwise. To be sure, this complicates the task. My view, however, is that you are not yet prepared for the surface. I'll not lift the wards barring that path."
      Speaker = "Hecate"
      Event = "HecateAboutHermes01"
    }
    {
      Id = "Melinoe_1174"
      InheritFrom = "BaseNarrative"
      DisplayName = "And if I were to lift them myself? I've seen you do it."
      Speaker = "Melinoe"
      Event = "HecateAboutHermes01"
    }
    {
      Id = "Hecate_0424"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Then you'll be more prepared than you are now."
      Speaker = "Hecate"
      Event = "HecateAboutHermes01"
    }
    {
      Id = "Hecate_0715"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Shades reporting to Odysseus suggest Athena herself appeared before you here? I mean not {#Emph}here{#Prev}, but in the Underworld. Is that something I ought believe, or no?"
      Speaker = "Hecate"
      Event = "HecateAboutAthena01"
    }
    {
      Id = "Melinoe_3902"
      InheritFrom = "BaseNarrative"
      DisplayName = "You ought. Athena gave her Gorgon Amulet, with which she's able to locate me far from where she normally resides. I trust I haven't inconvenienced her too much."
      Speaker = "Melinoe"
      Event = "HecateAboutAthena01"
    }
    {
      Id = "Hecate_0716"
      InheritFrom = "BaseNarrative"
      DisplayName = "Athena cannot go wherever she may please, no matter how it seems. But now you clearly have a stronger bond with her. And she, in turn, has a means to watch you."
      Speaker = "Hecate"
      Event = "HecateAboutAthena01"
    }
    {
      Id = "Melinoe_3903"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Watch {#Emph}over {#Prev}me, you mean...?"
      Speaker = "Melinoe"
      Event = "HecateAboutAthena01"
    }
    {
      Id = "Hecate_0717"
      InheritFrom = "BaseSubtitle"
      DisplayName = "She has her task, as you have yours."
      Speaker = "Hecate"
      Event = "HecateAboutAthena01"
    }
    {
      Id = "Melinoe_3134"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress, there must be something we can do for Arachne. Her curse torments her. What use is our craft if we cannot ease a friend's suffering?"
      Speaker = "Melinoe"
      Event = "HecateAboutArachne01"
    }
    {
      Id = "Hecate_0551"
      InheritFrom = "BaseNarrative"
      DisplayName = "Arachne's fate is not yours to undo. 'Tis a matter between her and Athena. I suggest you leave it well alone."
      Speaker = "Hecate"
      Event = "HecateAboutArachne01"
    }
    {
      Id = "Melinoe_3135"
      InheritFrom = "BaseNarrative"
      DisplayName = "How... did you know it was between her and Athena?"
      Speaker = "Melinoe"
      Event = "HecateAboutArachne01"
    }
    {
      Id = "Hecate_0552"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I do not care for your insinuations, Melinoë."
      Speaker = "Hecate"
      Event = "HecateAboutArachne01"
    }
    {
      Id = "Melinoe_3136"
      InheritFrom = "BaseNarrative"
      DisplayName = "Can you help me discover who created Arachne's curse, if it wasn't Athena herself?"
      Speaker = "Melinoe"
      Event = "HecateAboutArachne02"
    }
    {
      Id = "Hecate_0553"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why don't you ask {#Emph}her {#Prev}rather than me? I understand her hands are full, forestalling the destruction of Olympus... though surely she shall make some time for you."
      Speaker = "Hecate"
      Event = "HecateAboutArachne02"
    }
    {
      Id = "Hecate_0554"
      InheritFrom = "BaseNarrative"
      DisplayName = "Concerning your companion Arachne and her curse: Against my better judgment... I've done some searching, and have knowledge of the one who fashioned the poison."
      Speaker = "Hecate"
      Event = "HecateAboutArachne03"
    }
    {
      Id = "Melinoe_3137"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have? Excellent! Thank you, Headmistress! Who did you learn was responsible?"
      Speaker = "Melinoe"
      Event = "HecateAboutArachne03"
    }
    {
      Id = "Hecate_0555"
      InheritFrom = "BaseNarrative"
      DisplayName = "That matter is solely between me and the spider. Utmost discretion is required in such matters. If you wish to be an intermediary still, then let her know to seek me here."
      Speaker = "Hecate"
      Event = "HecateAboutArachne03"
    }
    {
      Id = "Melinoe_3138"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress... {#Emph}you {#Prev}cursed my friend... poisoned her! You taught me never to be quick to judge, so help me understand..."
      Speaker = "Melinoe"
      Event = "HecateAboutArachne04"
    }
    {
      Id = "Hecate_0593"
      InheritFrom = "BaseNarrative"
      DisplayName = "Understand, then, that my allegiance forcibly is with the gods, not with arrogant mortals. You did not know the Arachne of old; she has been humbled in her current form."
      Speaker = "Hecate"
      Event = "HecateAboutArachne04"
    }
    {
      Id = "Melinoe_3139"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then she has learned her lesson! Please help me change her back."
      Speaker = "Melinoe"
      Event = "HecateAboutArachne04"
    }
    {
      Id = "Hecate_0594"
      InheritFrom = "BaseNarrative"
      DisplayName = "I told you, 'tis a matter between her and Athena! For my part, I merely can express regret... to you, as well as her. Perhaps in time Athena herself may thus be swayed."
      Speaker = "Hecate"
      Event = "HecateAboutArachne04"
    }
    {
      Id = "Melinoe_3140"
      InheritFrom = "BaseSubtitle"
      DisplayName = "But... {#Emph}<scoff>"
      Speaker = "Melinoe"
      Event = "HecateAboutArachne04"
    }
    {
      Id = "Hecate_0851"
      InheritFrom = "BaseNarrative"
      DisplayName = "The woods have eyes and ears, thus I'm aware Arachne and Athena finally settled up their differences. To the extent they ever shall, I suppose."
      Speaker = "Hecate"
      Event = "HecateAboutArachne05"
    }
    {
      Id = "Melinoe_5291"
      InheritFrom = "BaseNarrative"
      DisplayName = "Arachne always had her pride, but... I think she may have found some sort of peace."
      Speaker = "Melinoe"
      Event = "HecateAboutArachne05"
    }
    {
      Id = "Hecate_0852"
      InheritFrom = "BaseNarrative"
      DisplayName = "Would that it were so. With time, feelings of scorn embed themselves deep in the flesh; in the heart. And they are not easily excised. But those two are stubborn enough to do it."
      Speaker = "Hecate"
      Event = "HecateAboutArachne05"
    }
    {
      Id = "Melinoe_2513"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd not expected Lady Medea to be stationed in Ephyra still, Headmistress. To think even a witch of her experience was unable to prevent the city's fall."
      Speaker = "Melinoe"
      Event = "HecateAboutMedea01"
    }
    {
      Id = "Hecate_0588"
      InheritFrom = "BaseNarrative"
      DisplayName = "'Twas not her responsibility to try. Medea was there to blend with the locals. It seems she's even more successful at it now, with most of them deceased. I trust she aided you in her own way?"
      Speaker = "Hecate"
      Event = "HecateAboutMedea01"
    }
    {
      Id = "Melinoe_2514"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That she did, yes."
      Speaker = "Melinoe"
      Event = "HecateAboutMedea01"
    }
    {
      Id = "Hecate_0589"
      InheritFrom = "BaseNarrative"
      DisplayName = "How fares Medea on the surface lately from your point of view? Having a grand old time by her account, and Sister Selene seems to think the same! Perhaps I should not be surprised."
      Speaker = "Hecate"
      Event = "HecateAboutMedea02"
    }
    {
      Id = "Melinoe_2515"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lady Medea does seem very much at home amid all the death and decay, which fuels her research. She's always toiling at one curse or another. Is that a concern?"
      Speaker = "Melinoe"
      Event = "HecateAboutMedea02"
    }
    {
      Id = "Hecate_0590"
      InheritFrom = "BaseNarrative"
      DisplayName = "My concern is only for her well-being, and it sounds as though she is all right for now. So long as her {#Emph}research {#Prev}does not come back to haunt her anytime soon."
      Speaker = "Hecate"
      Event = "HecateAboutMedea02"
    }
    {
      Id = "Melinoe_2516"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll be checking up on her."
      Speaker = "Melinoe"
      Event = "HecateAboutMedea02"
    }
    {
      Id = "Melinoe_3464"
      InheritFrom = "BaseNarrative"
      DisplayName = "I found Circe the Enchantress on my route toward Olympus; or likely, she found me. She hasn't changed a bit from what I recall. You have her keeping watch over the seas?"
      Speaker = "Melinoe"
      Event = "HecateAboutCirce01"
    }
    {
      Id = "Hecate_0661"
      InheritFrom = "BaseNarrative"
      DisplayName = "That I do. Selene takes to water like a cat, whilst Circe hails from the sea. Thus has it been a good arrangement for a while. I trust Circe's work retains its potency?"
      Speaker = "Hecate"
      Event = "HecateAboutCirce01"
    }
    {
      Id = "Melinoe_3465"
      InheritFrom = "BaseSubtitle"
      DisplayName = "She's been great."
      Speaker = "Melinoe"
      Event = "HecateAboutCirce01"
    }
    {
      Id = "Hecate_0662"
      InheritFrom = "BaseNarrative"
      DisplayName = "We have a bit of a personnel problem with our Circe the Enchantress. Her isle is poised to survey our enemy's fleet, reports of which ought go directly to Odysseus. Except they go to me."
      Speaker = "Hecate"
      Event = "HecateAboutCirce02"
    }
    {
      Id = "Melinoe_3466"
      InheritFrom = "BaseNarrative"
      DisplayName = "A gap in communication. By your leave, Headmistress, I can notify her of the proper protocol when next we meet."
      Speaker = "Melinoe"
      Event = "HecateAboutCirce02"
    }
    {
      Id = "Hecate_0663"
      InheritFrom = "BaseNarrative"
      DisplayName = "You shall not speak of this to her at all. I raise the point so you can be aware. Circe has long been a valuable asset and ally. Your visits to her isle may help keep it that way."
      Speaker = "Hecate"
      Event = "HecateAboutCirce02"
    }
    {
      Id = "Melinoe_3467"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Understood."
      Speaker = "Melinoe"
      Event = "HecateAboutCirce02"
    }
    {
      Id = "Melinoe_3899"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress, I saw Icarus up there, during my voyage toward Olympus. He flies free, but fights for us still... doing what he can to disrupt the Titan's legions."
      Speaker = "Melinoe"
      Event = "HecateAboutIcarus01"
    }
    {
      Id = "Hecate_0712"
      InheritFrom = "BaseNarrative"
      DisplayName = "And...? You need not make attempts to endear him to {#Emph}me. {#Prev}My judgment of one's character need not affect your own."
      Speaker = "Hecate"
      Event = "HecateAboutIcarus01"
    }
    {
      Id = "Melinoe_3900"
      InheritFrom = "BaseNarrative"
      DisplayName = "I just... sometimes I worry you think he abandoned us during a time of need, and wasn't a good influence on me..."
      Speaker = "Melinoe"
      Event = "HecateAboutIcarus01"
    }
    {
      Id = "Hecate_0713"
      InheritFrom = "BaseNarrative"
      DisplayName = "You need not speculate about my thoughts. The follies of young Icarus are positively mild in comparison to most. I harbor no ill will toward him; he'd not be flying if I did."
      Speaker = "Hecate"
      Event = "HecateAboutIcarus01"
    }
    {
      Id = "Melinoe_3901"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Is he still welcome here, at least?"
      Speaker = "Melinoe"
      Event = "HecateAboutIcarus01"
    }
    {
      Id = "Hecate_0714"
      InheritFrom = "BaseSubtitle"
      DisplayName = "If that is both your wish and his..."
      Speaker = "Hecate"
      Event = "HecateAboutIcarus01"
    }
    {
      Id = "Hecate_0037"
      InheritFrom = "BaseNarrative"
      DisplayName = "You always reminded me of your father, Melinoë, but lately you remind me of your mother... more and more. The concern for others that you sometimes show... it can be an exploitable weakness."
      Speaker = "Hecate"
      Event = "HecateAboutFamily01"
    }
    {
      Id = "Melinoe_0154"
      InheritFrom = "BaseNarrative"
      DisplayName = "I would never put any such concerns ahead of the task, Headmistress."
      Speaker = "Melinoe"
      Event = "HecateAboutFamily01"
    }
    {
      Id = "Hecate_0038"
      InheritFrom = "BaseNarrative"
      DisplayName = "See that you don't! Although my remark was not intended as admonishment; it was my honor to have known your family... even if merely from the shadows."
      Speaker = "Hecate"
      Event = "HecateAboutFamily01"
    }
    {
      Id = "Melinoe_0155"
      InheritFrom = "BaseSubtitle"
      DisplayName = "They'll be avenged."
      Speaker = "Melinoe"
      Event = "HecateAboutFamily01"
    }
    {
      Id = "Hecate_0021"
      InheritFrom = "BaseNarrative"
      DisplayName = "Vengeance for your family awaits you, far below. I'm certain they would be proud of what you have become. Bear them in your heart when you strike."
      Speaker = "Hecate"
      Event = "HecateAboutFamily02"
    }
    {
      Id = "Melinoe_0048"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress, I'll bear them in my heart but... I have no memory of them. How could I? You're the one who's always been there for me."
      Speaker = "Melinoe"
      Event = "HecateAboutFamily02"
    }
    {
      Id = "Hecate_0022"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Augh{#Prev}, don't say such things; I am {#Emph}not {#Prev}your mother, Melinoë. So much she could have taught you, I cannot. Never compare us."
      Speaker = "Hecate"
      Event = "HecateAboutFamily02"
    }
    {
      Id = "Melinoe_0049"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I... OK."
      Speaker = "Melinoe"
      Event = "HecateAboutFamily02"
    }
    {
      Id = "Melinoe_3459"
      InheritFrom = "BaseNarrative"
      DisplayName = "The family portrait in my tent... I have been thinking on it more and more, I... never asked you where you got it from."
      Speaker = "Melinoe"
      Event = "HecateAboutFamilyPortrait01"
    }
    {
      Id = "Hecate_0656"
      InheritFrom = "BaseNarrative"
      DisplayName = "'Twould be stranger if you did, for the answer ought be obvious to you. Though, you would know the circumstances?"
      Speaker = "Hecate"
      Event = "HecateAboutFamilyPortrait01"
    }
    {
      Id = "Melinoe_3460"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes, Headmistress, if you please. I know it was a time you would never wish to revisit, but it's important to me."
      Speaker = "Melinoe"
      Event = "HecateAboutFamilyPortrait01"
    }
    {
      Id = "Hecate_0657"
      InheritFrom = "BaseNarrative"
      DisplayName = "Of that I have no doubt. When Chronos stormed your father's House, I fled with but three things: Hypnos, because he was there; that family portrait, which pulled at my heart; and you."
      Speaker = "Hecate"
      Event = "HecateAboutFamilyPortrait01"
    }
    {
      Id = "Melinoe_3461"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Only the three...?"
      Speaker = "Melinoe"
      Event = "HecateAboutFamilyPortrait01"
    }
    {
      Id = "Hecate_0658"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I had but an instant, and I am threefold."
      Speaker = "Hecate"
      Event = "HecateAboutFamilyPortrait01"
    }
    {
      Id = "Hecate_0279"
      InheritFrom = "BaseNarrative"
      DisplayName = "With all your incanting as of late, I must needs caution you to not overextend. I know you want for every chant and glamour on the tip of your tongue, but they require space, and time."
      Speaker = "Hecate"
      Event = "HecateAboutWitchcraft01"
    }
    {
      Id = "Melinoe_1017"
      InheritFrom = "BaseNarrative"
      DisplayName = "Using the cauldron doesn't drain me as once it did. Though I know I mustn't be reckless."
      Speaker = "Melinoe"
      Event = "HecateAboutWitchcraft01"
    }
    {
      Id = "Hecate_0280"
      InheritFrom = "BaseNarrative"
      DisplayName = "Indeed, lest your fair {#Emph}right {#Prev}hand come to match your left. Although perhaps that boy-shade Icarus would fancy you more if that were so. Been gone awhile, hasn't he?"
      Speaker = "Hecate"
      Event = "HecateAboutWitchcraft01"
    }
    {
      Id = "Melinoe_1018"
      InheritFrom = "BaseSubtitle"
      DisplayName = "He has..."
      Speaker = "Melinoe"
      Event = "HecateAboutWitchcraft01"
    }
    {
      Id = "Hecate_0599"
      InheritFrom = "BaseNarrative"
      DisplayName = "Once you're quite finished with the cauldron for the eve, I may have need of it myself... protective charms to be refreshed, wards reinforced..."
      Speaker = "Hecate"
      Event = "HecateAboutCauldronWitchcraft01"
    }
    {
      Id = "Melinoe_2526"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you've a certain incantation in mind, might I be able to assist? {#Emph}The Invocation of the Dead, Concealment in Night's Embrace{#Prev}, whichever..."
      Speaker = "Melinoe"
      Event = "HecateAboutCauldronWitchcraft01"
    }
    {
      Id = "Hecate_0600"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've your own matters to consider now, Melinoë. Though if you're here in the vicinity whilst I'm chanting, your voice is always welcome, joined with mine."
      Speaker = "Hecate"
      Event = "HecateAboutCauldronWitchcraft01"
    }
    {
      Id = "Melinoe_2527"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Together we shine, Headmistress."
      Speaker = "Melinoe"
      Event = "HecateAboutCauldronWitchcraft01"
    }
    {
      Id = "Hecate_0215"
      InheritFrom = "BaseNarrative"
      DisplayName = "I must say, you've been putting our old cauldron to good use. I see and sense the changes in this place. Changes for all our betterment, not just your own."
      Speaker = "Hecate"
      Event = "HecateAboutCauldron01"
    }
    {
      Id = "Melinoe_0652"
      InheritFrom = "BaseNarrative"
      DisplayName = "A proper incantation is never to be used for selfish gain. Though, if I can help bring about positive change from which I benefit, isn't that selfish, still?"
      Speaker = "Melinoe"
      Event = "HecateAboutCauldron01"
    }
    {
      Id = "Hecate_0216"
      InheritFrom = "BaseNarrative"
      DisplayName = "Discard such doubts as that. You are not thinking solely of yourself, thus you are not thinking selfishly. I've not taught you to neglect your needs, have I?"
      Speaker = "Hecate"
      Event = "HecateAboutCauldron01"
    }
    {
      Id = "Melinoe_0653"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Of course not."
      Speaker = "Melinoe"
      Event = "HecateAboutCauldron01"
    }
    {
      Id = "Hecate_0217"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Then, good."
      Speaker = "Hecate"
      Event = "HecateAboutCauldron01"
    }
    {
      Id = "Hecate_0718"
      InheritFrom = "BaseNarrative"
      DisplayName = "I remain rather partial to our old cauldron. This one that you procured with all the stars... your magick shan't just magickally improve because of it."
      Speaker = "Hecate"
      Event = "HecateAboutAltCauldron01"
    }
    {
      Id = "Melinoe_3904"
      InheritFrom = "BaseNarrative"
      DisplayName = "We still retain the old cauldron, of course. Just say the word and I can change it back! As for this one, a new beginning can yield powerful results, isn't that so?"
      Speaker = "Melinoe"
      Event = "HecateAboutAltCauldron01"
    }
    {
      Id = "Hecate_0719"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, if this fancy bit of metalwork inspires you to greater acts, then 'tis worth its weight! I'll not ask you to change it back. And even if I did, heed {#Emph}your {#Prev}instincts, not mine."
      Speaker = "Hecate"
      Event = "HecateAboutAltCauldron01"
    }
    {
      Id = "Melinoe_3905"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I trust yours too."
      Speaker = "Melinoe"
      Event = "HecateAboutAltCauldron01"
    }
    {
      Id = "Hecate_0720"
      InheritFrom = "BaseNarrative"
      DisplayName = "A properly imposing cauldron, that. Perhaps more suitable for certain specialties... daemonic invocations, curses, and the like. Do you intend to further specialize?"
      Speaker = "Hecate"
      Event = "HecateAboutAltCauldron02"
    }
    {
      Id = "Melinoe_3906"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not necessarily, Headmistress. I... still have a lot of different ideas, sometimes several on a given night. It's my dream to pursue mastery in all dimensions of our craft."
      Speaker = "Melinoe"
      Event = "HecateAboutAltCauldron02"
    }
    {
      Id = "Hecate_0721"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your {#Emph}dream{#Prev}, you say. We each have our leanings and yours perhaps shall manifest in time. But I do recognize the desire to avoid becoming {#Emph}limited{#Prev}, so practice as you will. Using this Python cauldron or whichever one."
      Speaker = "Hecate"
      Event = "HecateAboutAltCauldron02"
    }
    {
      Id = "Melinoe_3907"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A cauldron for every occasion!"
      Speaker = "Melinoe"
      Event = "HecateAboutAltCauldron02"
    }
    {
      Id = "Hecate_0722"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Ever the dreamer."
      Speaker = "Hecate"
      Event = "HecateAboutAltCauldron02"
    }
    {
      Id = "Hecate_0723"
      InheritFrom = "BaseNarrative"
      DisplayName = "Cultivating all those many different types of greenery. We are in the realm of the dead, lest you forget, Melinoë! Yet here you tend your garden."
      Speaker = "Hecate"
      Event = "HecateAboutGarden01"
    }
    {
      Id = "Melinoe_3908"
      InheritFrom = "BaseNarrative"
      DisplayName = "No better place to grow reagents above or below. But more than that, it's something small I can look forward to whenever I return. Helps keep me centered."
      Speaker = "Melinoe"
      Event = "HecateAboutGarden01"
    }
    {
      Id = "Hecate_0724"
      InheritFrom = "BaseNarrative"
      DisplayName = "There's no need to explain. The Earth obliges you; 'tis wise to take advantage of good fortunes such as that."
      Speaker = "Hecate"
      Event = "HecateAboutGarden01"
    }
    {
      Id = "Melinoe_3909"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I merely borrow."
      Speaker = "Melinoe"
      Event = "HecateAboutGarden01"
    }
    {
      Id = "Hecate_0425"
      InheritFrom = "BaseNarrative"
      DisplayName = "Returning from the shadows restores your body, whilst meditating at your Altar emboldens your spirit. Such knowledge in the ashes of the past."
      Speaker = "Hecate"
      Event = "HecateAboutArcana01"
    }
    {
      Id = "Melinoe_0658"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm still struggling to internalize the Arcana, Headmistress. If I share the same potential as my predecessors, why don't I feel a stronger bond?"
      Speaker = "Melinoe"
      Event = "HecateAboutArcana01"
    }
    {
      Id = "Hecate_0426"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your bond can only be as strong as your understanding. One either learns from history or else repeats mistakes. I suggest the former."
      Speaker = "Hecate"
      Event = "HecateAboutArcana01"
    }
    {
      Id = "Melinoe_0659"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...I'll keep studying."
      Speaker = "Melinoe"
      Event = "HecateAboutArcana01"
    }
    {
      Id = "Hecate_0406"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have been fixed upon your Altar even more than usual of late. Have the Arcana shown you aught of note?"
      Speaker = "Hecate"
      Event = "HecateAboutArcana02"
    }
    {
      Id = "Melinoe_1169"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm beginning to see the cards in a new light... each depicts a significant choice made in the past. Such knowledge may help make better choices in the future."
      Speaker = "Melinoe"
      Event = "HecateAboutArcana02"
    }
    {
      Id = "Hecate_0407"
      InheritFrom = "BaseNarrative"
      DisplayName = "Indeed. We choose as wisely as we can, using what knowledge we have. So, you now clearer see into the {#Emph}cards{#Prev}, as you call them..."
      Speaker = "Hecate"
      Event = "HecateAboutArcana02"
    }
    {
      Id = "Melinoe_0596"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Indeed."
      Speaker = "Melinoe"
      Event = "HecateAboutArcana02"
    }
    {
      Id = "Hecate_0649"
      InheritFrom = "BaseNarrative"
      DisplayName = "I was curious to see if you would consecrate the Altar of Ashes on your own. It ought to be further attuned to you as a result; the secrets of the Arcana, nearer to your grasp."
      Speaker = "Hecate"
      Event = "HecateAboutCardUpgradeSystem01"
    }
    {
      Id = "Melinoe_3453"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Altar is a threshold through which we all pass, going to and from these Crossroads. A gateway to the past, present, and future. I know it isn't mine alone; it's ours. "
      Speaker = "Melinoe"
      Event = "HecateAboutCardUpgradeSystem01"
    }
    {
      Id = "Hecate_0650"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Correct, on all three counts."
      Speaker = "Hecate"
      Event = "HecateAboutCardUpgradeSystem01"
    }
    {
      Id = "Hecate_0233"
      InheritFrom = "BaseNarrative"
      DisplayName = "Have you been finding anything of use out there, in your forays? No point returning empty-handed. Though you may lack the necessary tools, I suppose."
      Speaker = "Hecate"
      Event = "HecateAboutResources01"
    }
    {
      Id = "Melinoe_0660"
      InheritFrom = "BaseNarrative"
      DisplayName = "Erebus still teems with hidden life. I'm finding all sorts of things we need out there. I'm very grateful for the purse! It never weighs me down."
      Speaker = "Melinoe"
      Event = "HecateAboutResources01"
    }
    {
      Id = "Hecate_0234"
      InheritFrom = "BaseNarrative"
      DisplayName = "A witch cannot afford to be encumbered. The blessings and such from your relatives may be fleeting, but whatever goes into that purse isn't going anywhere. Not till you use it, of course."
      Speaker = "Hecate"
      Event = "HecateAboutResources01"
    }
    {
      Id = "Melinoe_1022"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wanted to ask you something, Headmistress. All these reagents I've been gathering, taking from the Earth. From Mother Gaia. How can I make it up to her?"
      Speaker = "Melinoe"
      Event = "HecateAboutResources02"
    }
    {
      Id = "Hecate_0287"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, you can start by not wallowing in senseless guilt. Think you that Gaia would reveal her abundances to you if she believed you would not put them to good use?"
      Speaker = "Hecate"
      Event = "HecateAboutResources02"
    }
    {
      Id = "Melinoe_1023"
      InheritFrom = "BaseNarrative"
      DisplayName = "But you taught me never to take more than I need. Now I'm taking everything in sight."
      Speaker = "Melinoe"
      Event = "HecateAboutResources02"
    }
    {
      Id = "Hecate_0288"
      InheritFrom = "BaseNarrative"
      DisplayName = "And Gaia knows you'll need all that and more. Fear not, your plunder returns whence it came through your craft. If not your garden there."
      Speaker = "Hecate"
      Event = "HecateAboutResources02"
    }
    {
      Id = "Hecate_0289"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're frustrated, Melinoë. Why can't I simply furnish you with all of the reagents you require? So many incantations you could sooner cast..."
      Speaker = "Hecate"
      Event = "HecateAboutResources03"
    }
    {
      Id = "Melinoe_1024"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know full well the answer, Headmistress. Your own reagents bring power to your craft, as my own do to mine. Only through the effort of their procurement do they gain their properties."
      Speaker = "Melinoe"
      Event = "HecateAboutResources03"
    }
    {
      Id = "Hecate_0290"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just so. At times 'tis quite the pain, admittedly. Yet what is our craft but making our intentions manifest? For which there can be no shortcuts."
      Speaker = "Hecate"
      Event = "HecateAboutResources03"
    }
    {
      Id = "Melinoe_1025"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No shortcuts."
      Speaker = "Melinoe"
      Event = "HecateAboutResources03"
    }
    {
      Id = "Hecate_0858"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Tactician furnishes you with some of the reagents you require. Yet why not I? So many incantations you could sooner cast."
      Speaker = "Hecate"
      Event = "HecateAboutResources03_B"
    }
    {
      Id = "Hecate_0281"
      InheritFrom = "BaseNarrative"
      DisplayName = "That indolent little amphibian whom you keep... did my eyes deceive, or did I see him hopping rather energetically toward the egress?"
      Speaker = "Hecate"
      Event = "HecateAboutFamiliars01"
    }
    {
      Id = "Melinoe_1019"
      InheritFrom = "BaseNarrative"
      DisplayName = "You saw it true! I've compelled little Frinos to join me in my attempts out there. Surely you've taught me wards and charms enough to keep a Familiar safe?"
      Speaker = "Melinoe"
      Event = "HecateAboutFamiliars01"
    }
    {
      Id = "Hecate_0282"
      InheritFrom = "BaseNarrative"
      DisplayName = "One can but hope! And may your Familiar keep {#Emph}you {#Prev}safe, in turn. And perhaps scrounge up some more roots and such for us."
      Speaker = "Hecate"
      Event = "HecateAboutFamiliars01"
    }
    {
      Id = "Hecate_0283"
      InheritFrom = "BaseNarrative"
      DisplayName = "A cat recently strutted clear into our grove, as though my wards of shadow weren't even there! Please tell me that's a new Familiar of yours?"
      Speaker = "Hecate"
      Event = "HecateAboutFamiliars02"
    }
    {
      Id = "Melinoe_1020"
      InheritFrom = "BaseNarrative"
      DisplayName = "That would be Toula, Headmistress, and yes! I figured I could use a confident and independent companion such as that."
      Speaker = "Melinoe"
      Event = "HecateAboutFamiliars02"
    }
    {
      Id = "Hecate_0284"
      InheritFrom = "BaseNarrative"
      DisplayName = "As can we all. The beasts whom you entrust are welcome here. Would that all our acquaintances were such a welcome sight..."
      Speaker = "Hecate"
      Event = "HecateAboutFamiliars02"
    }
    {
      Id = "Melinoe_2523"
      InheritFrom = "BaseNarrative"
      DisplayName = "How fare Hecuba and Gale lately, Headmistress? They must be ill-at-ease with all of the bustle and new faces and the like."
      Speaker = "Melinoe"
      Event = "HecateAboutFamiliars03"
    }
    {
      Id = "Hecate_0597"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, they're fine. The hound and polecat make strange bedfellows, but are able to withstand more than their share of hardship or discomfort. Especially when you lavish them with attention!"
      Speaker = "Hecate"
      Event = "HecateAboutFamiliars03"
    }
    {
      Id = "Melinoe_2524_B"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm sure to win their hearts one of these nights!"
      Speaker = "Melinoe"
      Event = "HecateAboutFamiliars03"
    }
    {
      Id = "Hecate_0535"
      InheritFrom = "BaseNarrative"
      DisplayName = "These Crossroads flourish thanks to this {#Emph}renewal project {#Prev}of yours. You saw an opportunity to get it off the ground even now?"
      Speaker = "Hecate"
      Event = "HecateAboutCosmetics01"
    }
    {
      Id = "Melinoe_2162"
      InheritFrom = "BaseNarrative"
      DisplayName = "This is our home. It should be cared for, clean, and beautiful. I recruited Dora to assist me so that the work wouldn't have to wait forever."
      Speaker = "Melinoe"
      Event = "HecateAboutCosmetics01"
    }
    {
      Id = "Hecate_0536"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Dora? {#Prev}I've not once heard the invocation of {#Emph}her {#Prev}name and {#Emph}work {#Prev}in the same breath. To think that you persuaded {#Emph}that {#Prev}one to be of service."
      Speaker = "Hecate"
      Event = "HecateAboutCosmetics01"
    }
    {
      Id = "Melinoe_2163"
      InheritFrom = "BaseSubtitle"
      DisplayName = "She's pleased to help."
      Speaker = "Melinoe"
      Event = "HecateAboutCosmetics01"
    }
    {
      Id = "Hecate_0235"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Shades about this place are all abuzz in their support of you, you know. You have a gift for leaving an impression on them. And for compelling more of them to join with us."
      Speaker = "Hecate"
      Event = "HecateAboutShades01"
    }
    {
      Id = "Melinoe_0661"
      InheritFrom = "BaseNarrative"
      DisplayName = "They were just people once, or other living beings. All they ever needed was something to believe in, in death as well as life. And a way out of Erebus."
      Speaker = "Melinoe"
      Event = "HecateAboutShades01"
    }
    {
      Id = "Hecate_0236"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hm{#Prev}, well. They're sworn to you, that much is clear to me. I'd purge them all if I had any doubt! Perhaps they think they'll find a cushy spot within Elysium once all is said and done."
      Speaker = "Hecate"
      Event = "HecateAboutShades01"
    }
    {
      Id = "Melinoe_0662"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I think it's more than that."
      Speaker = "Melinoe"
      Event = "HecateAboutShades01"
    }
    {
      Id = "Melinoe_5046"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress, what is that you and Odysseus are planning? He's always with his charts and diagrams."
      Speaker = "Melinoe"
      Event = "HecateAboutSurface01"
    }
    {
      Id = "Hecate_0859"
      InheritFrom = "BaseNarrative"
      DisplayName = "Our Tactician always plans ahead, and is plotting a course from the nearest Underworld entrance all the way to Olympus, through the enemy's ranks... just in case."
      Speaker = "Hecate"
      Event = "HecateAboutSurface01"
    }
    {
      Id = "Melinoe_5047"
      InheritFrom = "BaseNarrative"
      DisplayName = "In case of what...? I can't go up there, and Chronos is the opposite way. Are matters on Olympus growing worse?"
      Speaker = "Melinoe"
      Event = "HecateAboutSurface01"
    }
    {
      Id = "Hecate_0860"
      InheritFrom = "BaseNarrative"
      DisplayName = "We are awaiting confirmation about that. These are mere possibilities for now; {#Emph}distractions{#Prev}, even. Remain focused."
      Speaker = "Hecate"
      Event = "HecateAboutSurface01"
    }
    {
      Id = "Melinoe_0148"
      InheritFrom = "BaseSubtitle"
      DisplayName = "But... {#Emph}mm."
      Speaker = "Melinoe"
      Event = "HecateAboutSurface01"
    }
    {
      Id = "Melinoe_0586"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress, if Olympus is besieged, then why am I not permitted on the surface? If I could aid the gods, then they could aid us even more!"
      Speaker = "Melinoe"
      Event = "HecateAboutSurface02"
    }
    {
      Id = "Hecate_0218"
      InheritFrom = "BaseNarrative"
      DisplayName = "Melinoë, however you complete the task is up to you; I have not barred you from the surface. But I caution, if you go, your strength shall fail you. Your birthright is to blame; no fault of yours."
      Speaker = "Hecate"
      Event = "HecateAboutSurface02"
    }
    {
      Id = "Melinoe_0587"
      InheritFrom = "BaseNarrative"
      DisplayName = "Born in the Underworld and here I'll stay, thank the Fates. I don't intend to live up there, I just.... Do you know how long I'd even have?"
      Speaker = "Melinoe"
      Event = "HecateAboutSurface02"
    }
    {
      Id = "Hecate_0219"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know your brother and father had a day at best ere they could not stand it any longer. Perhaps you're different, but don't count on it."
      Speaker = "Hecate"
      Event = "HecateAboutSurface02"
    }
    {
      Id = "Melinoe_0588"
      InheritFrom = "BaseSubtitle"
      DisplayName = "A day at best...?"
      Speaker = "Melinoe"
      Event = "HecateAboutSurface02"
    }
    {
      Id = "Hecate_0220"
      InheritFrom = "BaseNarrative"
      DisplayName = "You visited the surface. I can't imagine {#Emph}that {#Prev}played out particularly well. At least you made it back at all."
      Speaker = "Hecate"
      Event = "HecateAboutSurface03"
    }
    {
      Id = "Melinoe_0589"
      InheritFrom = "BaseNarrative"
      DisplayName = "It was draining... even at night, something about being under the stars, I... didn't know there were so many. It was more than I could take. You were right."
      Speaker = "Melinoe"
      Event = "HecateAboutSurface03"
    }
    {
      Id = "Hecate_0221"
      InheritFrom = "BaseNarrative"
      DisplayName = "A lesson learned, and an experience gained. The Fates themselves do not want you up there. What shall you do?"
      Speaker = "Hecate"
      Event = "HecateAboutSurface03"
    }
    {
      Id = "Melinoe_0590"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have an incantation to complete. I don't need to stay forever on the surface... I just need to hold on long enough to make it to Olympus..."
      Speaker = "Melinoe"
      Event = "HecateAboutSurface03"
    }
    {
      Id = "Hecate_0222"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, then you seek to improve this aspect of yourself, without rejecting it outright. I see how that may work..."
      Speaker = "Hecate"
      Event = "HecateAboutSurface03"
    }
    {
      Id = "Melinoe_0591"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It has to..."
      Speaker = "Melinoe"
      Event = "HecateAboutSurface03"
    }
    {
      Id = "Melinoe_2947"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Only my task."
      Speaker = "Melinoe"
      Event = "HecateAboutSurface03_B"
    }
    {
      Id = "Melinoe_0592"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress... Olympus seems reluctant to ask outright, but I can tell my family there needs me. I cannot shake the sense that I have to help them, before I can achieve our task."
      Speaker = "Melinoe"
      Event = "HecateAboutSurfaceSurvival01"
    }
    {
      Id = "Hecate_0223"
      InheritFrom = "BaseNarrative"
      DisplayName = "You needn't shake that sense, for it may well be accurate. Are you still thinking of an incantation that may help you to survive such a journey?"
      Speaker = "Hecate"
      Event = "HecateAboutSurfaceSurvival01"
    }
    {
      Id = "Melinoe_0593"
      InheritFrom = "BaseNarrative"
      DisplayName = "I am. Up there, I'll be like a fish out of water, right? Suffocating. But with a proper incantation, I was thinking maybe I could hold my breath. Until Olympus is secure."
      Speaker = "Melinoe"
      Event = "HecateAboutSurfaceSurvival01"
    }
    {
      Id = "Hecate_0224"
      InheritFrom = "BaseNarrative"
      DisplayName = "Such a spell shall not be simple. Though, if you demonstrate that you're sufficiently well traveled, then... perhaps magick such as that shall help you go farther still."
      Speaker = "Hecate"
      Event = "HecateAboutSurfaceSurvival01"
    }
    {
      Id = "Melinoe_0594"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'm counting on it."
      Speaker = "Melinoe"
      Event = "HecateAboutSurfaceSurvival01"
    }
    {
      Id = "Hecate_0225"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your recent travels to the surface. How were you able to survive up there? You were away for longer than I would have expected."
      Speaker = "Hecate"
      Event = "HecateAboutSurfaceSurvival02"
    }
    {
      Id = "Melinoe_0595"
      InheritFrom = "BaseNarrative"
      DisplayName = "My surface-breathing incantation made a difference after all, Headmistress. I still felt the oppressive atmosphere up there, weighing down on me... but not crushing me quite like before."
      Speaker = "Melinoe"
      Event = "HecateAboutSurfaceSurvival02"
    }
    {
      Id = "Hecate_0226"
      InheritFrom = "BaseNarrative"
      DisplayName = "Magick born of your resolve. I'm impressed, though not entirely surprised. May your craft thus protect you ere Olympus is secure."
      Speaker = "Hecate"
      Event = "HecateAboutSurfaceSurvival02"
    }
    {
      Id = "Hecate_0749"
      InheritFrom = "BaseNarrative"
      DisplayName = "It must be very difficult for you up there. My aim was to prepare you for the dangers of the Underworld, not those Olympus ought be able to take care of on its own."
      Speaker = "Hecate"
      Event = "HecateAboutSurfaceSurvival03"
    }
    {
      Id = "Melinoe_4040"
      InheritFrom = "BaseNarrative"
      DisplayName = "Every misstep on the surface is a harsher lesson even than below. I've become more used to it, but I'm constantly reminded I should not be able to set foot up there at all."
      Speaker = "Melinoe"
      Event = "HecateAboutSurfaceSurvival03"
    }
    {
      Id = "Hecate_0750"
      InheritFrom = "BaseNarrative"
      DisplayName = "And yet you carry on! Notice how I do not even attempt to cure you of that stubbornness; 'tis probably your family's most pervasive trait. Well, if you wish to keep making things even harder on yourself, at least you know the way."
      Speaker = "Hecate"
      Event = "HecateAboutSurfaceSurvival03"
    }
    {
      Id = "Melinoe_4041"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I like having options."
      Speaker = "Melinoe"
      Event = "HecateAboutSurfaceSurvival03"
    }
    {
      Id = "Hecate_0659"
      InheritFrom = "BaseNarrative"
      DisplayName = "How fares the ever-sinking fleet of ships within the Rift of Thessaly? 'Tis a wonder Chronos gathered as many followers as he has, using such shoddily built craft."
      Speaker = "Hecate"
      Event = "HecateAboutThessaly01"
    }
    {
      Id = "Melinoe_3462"
      InheritFrom = "BaseNarrative"
      DisplayName = "The fleet shows no real sign of slowing down. Fortunately, the same sorcery that seems to be holding those ships together lets me transfer quickly from one to the next. Are all surface ships so odd-looking?"
      Speaker = "Melinoe"
      Event = "HecateAboutThessaly01"
    }
    {
      Id = "Hecate_0660"
      InheritFrom = "BaseNarrative"
      DisplayName = "I certainly think not. {#Emph}These {#Prev}are merely emblematic of the Titan's false promises of a new age. They assault not just Olympus but our sensibilities as well."
      Speaker = "Hecate"
      Event = "HecateAboutThessaly01"
    }
    {
      Id = "Melinoe_3463"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We'll fight them off."
      Speaker = "Melinoe"
      Event = "HecateAboutThessaly01"
    }
    {
      Id = "Hecate_0703"
      InheritFrom = "BaseNarrative"
      DisplayName = "Odysseus and I... long has one of us been certain you would find your way to Mount Olympus and direct your efforts there. The other was certain you'd do no such thing."
      Speaker = "Hecate"
      Event = "HecateAboutOlympus01"
    }
    {
      Id = "Melinoe_3893"
      InheritFrom = "BaseNarrative"
      DisplayName = "Before you even ask, there's absolutely no way you're making me guess which one of you was which in that particular disagreement, Headmistress."
      Speaker = "Melinoe"
      Event = "HecateAboutOlympus01"
    }
    {
      Id = "Hecate_0704"
      InheritFrom = "BaseNarrative"
      DisplayName = "I always said how you achieve the task is up to you. 'Tis not for me to guide your every step! Then was it worth it, climbing to those heights?"
      Speaker = "Hecate"
      Event = "HecateAboutOlympus01"
    }
    {
      Id = "Melinoe_3894"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Entirely. And I intend to go again."
      Speaker = "Melinoe"
      Event = "HecateAboutOlympus01"
    }
    {
      Id = "Hecate_0705"
      InheritFrom = "BaseSubtitle"
      DisplayName = "May your intent be true."
      Speaker = "Hecate"
      Event = "HecateAboutOlympus01"
    }
    {
      Id = "Hecate_0514"
      InheritFrom = "BaseNarrative"
      DisplayName = "'Tis fortunate your father's realm is vast indeed, that you may circumnavigate it at the edge of Oceanus, where our enemy is relatively weak."
      Speaker = "Hecate"
      Event = "HecateAboutOceanus01"
    }
    {
      Id = "Melinoe_1027"
      InheritFrom = "BaseNarrative"
      DisplayName = "If we cannot pass directly through Elysium, then we shall make what way we can. Though the fiends that lurk the border of the sea care not for my presence."
      Speaker = "Melinoe"
      Event = "HecateAboutOceanus01"
    }
    {
      Id = "Hecate_0515"
      InheritFrom = "BaseNarrative"
      DisplayName = "God-hating monsters with salt in their veins; the seas covering the world's surface just were not enough for them. The sunken chambers they occupy have not yet fallen to Chronos, at least."
      Speaker = "Hecate"
      Event = "HecateAboutOceanus01"
    }
    {
      Id = "Melinoe_2517"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress, I saw him. Chronos! First beyond Erebus, in the guise of an old man. He then attempted to ensnare me in some vision out of time... the river of flame, everything ablaze..."
      Speaker = "Melinoe"
      Event = "HecateAboutChronosAnomaly01"
    }
    {
      Id = "Melinoe_2518"
      InheritFrom = "BaseNarrative"
      DisplayName = "So he claims. I broke free from his spell like it was second-nature, but... neither could I raise a hand against him. What must I do now?"
      Speaker = "Melinoe"
      Event = "HecateAboutChronosAnomaly01"
    }
    {
      Id = "Melinoe_2519"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Yes, Headmistress."
      Speaker = "Melinoe"
      Event = "HecateAboutChronosAnomaly01"
    }
    {
      Id = "Melinoe_2164"
      InheritFrom = "BaseNarrative"
      DisplayName = "The influence of Chronos is much stronger in Oceanus than here. He attempted to ensnare me in a vision of another time. A field of flame."
      Speaker = "Melinoe"
      Event = "HecateAboutChronosAnomaly02"
    }
    {
      Id = "Hecate_0537"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yet you were able to elude his grasp. An aspect of your condition we expected would come into play as you pushed closer to our foe. Continue with still-greater caution, nonetheless..."
      Speaker = "Hecate"
      Event = "HecateAboutChronosAnomaly02"
    }
    {
      Id = "Hecate_0636"
      InheritFrom = "BaseNarrative"
      DisplayName = "Those Sands that you recovered from our enemy. They've something of his nature in each tiny grain. A key of sorts, to the Dissolution of Time. Do you concur?"
      Speaker = "Hecate"
      Event = "HecateAboutTimeStop01"
    }
    {
      Id = "Melinoe_2912"
      InheritFrom = "BaseNarrative"
      DisplayName = "I do. That very incantation sprang to mind... an expression of all you taught me of his weaknesses. A means to unravel his very being... to bring death to Chronos at last. He doesn't seem to realize it's possible... still thinks I'm just an agent of Olympus."
      Speaker = "Melinoe"
      Event = "HecateAboutTimeStop01"
    }
    {
      Id = "Hecate_0637"
      InheritFrom = "BaseNarrative"
      DisplayName = "'Tis merely evidence that our concerted efforts have not been in vain. You cross the Underworld like a tempest, whilst I remain in shadows. But, when the Titan's time at last comes to an end, I {#Emph}dearly {#Prev}wish to be there myself. To see the look on his face."
      Speaker = "Hecate"
      Event = "HecateAboutTimeStop01"
    }
    {
      Id = "Melinoe_2913"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We'll get him, Headmistress..."
      Speaker = "Melinoe"
      Event = "HecateAboutTimeStop01"
    }
    {
      Id = "Hecate_0229"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Nocturnal Arms are beginning to awaken. May we yet see an age when they can slumber once again. Have you a favored sister yet among the lot?"
      Speaker = "Hecate"
      Event = "HecateAboutWeapons01"
    }
    {
      Id = "Melinoe_0656"
      InheritFrom = "BaseNarrative"
      DisplayName = "I am grateful that the weapons of Night have accepted me. I intend to treat them equally, Headmistress."
      Speaker = "Melinoe"
      Event = "HecateAboutWeapons01"
    }
    {
      Id = "Hecate_0230"
      InheritFrom = "BaseNarrative"
      DisplayName = "A commendable approach, but not a necessary one. The Nocturnal Arms share our purpose. They care little as to which of them you use, only that the task is completed."
      Speaker = "Hecate"
      Event = "HecateAboutWeapons01"
    }
    {
      Id = "Melinoe_0657"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We'll see it through."
      Speaker = "Melinoe"
      Event = "HecateAboutWeapons01"
    }
    {
      Id = "Hecate_0595"
      InheritFrom = "BaseNarrative"
      DisplayName = "So, the Arms of Night have revealed to you some of their former selves; or future selves, perhaps. Few have earned the right to bear such weapons. Much less take advantage of their different likenesses!"
      Speaker = "Hecate"
      Event = "HecateAboutAspects01"
    }
    {
      Id = "Melinoe_2521"
      InheritFrom = "BaseNarrative"
      DisplayName = "The various Aspects I've discovered... some of the bearers I know well. Medea, Artemis... they're all connected to {#Emph}you{#Prev}, aren't they?"
      Speaker = "Melinoe"
      Event = "HecateAboutAspects01"
    }
    {
      Id = "Hecate_0596"
      InheritFrom = "BaseNarrative"
      DisplayName = "'Tis not as simple as you may presume... you bear a set of artifacts whose aim is to safeguard the Underworld. Each Aspect is of somebody who played a part in this, or shall."
      Speaker = "Hecate"
      Event = "HecateAboutAspects01"
    }
    {
      Id = "Melinoe_2522"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It seems I'm in good company..."
      Speaker = "Melinoe"
      Event = "HecateAboutAspects01"
    }
    {
      Id = "Hecate_0023"
      InheritFrom = "BaseNarrative"
      DisplayName = "Melinoë. I held back against you out there. And even still, you could not surpass me. Do you know why?"
      Speaker = "Hecate"
      Event = "HecateLostAgainstHer01"
    }
    {
      Id = "Melinoe_1032"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I know I can grow stronger still, but... it's my lack of knowledge that betrayed me in the end. Some of your many tricks I've yet to learn."
      Speaker = "Melinoe"
      Event = "HecateLostAgainstHer01"
    }
    {
      Id = "Hecate_0297"
      InheritFrom = "BaseNarrative"
      DisplayName = "Correct! Strength; knowledge; patience. When faced with a seemingly indomitable adversary, all three are required. Or a stroke of fate..."
      Speaker = "Hecate"
      Event = "HecateLostAgainstHer01"
    }
    {
      Id = "Melinoe_1033"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll count on the former."
      Speaker = "Melinoe"
      Event = "HecateLostAgainstHer01"
    }
    {
      Id = "Hecate_0197"
      InheritFrom = "BaseNarrative"
      DisplayName = "I thwarted you again out there. 'Tis unfair, I know. I arrive fresh as rain in anticipation of our clash, whilst you may already be battle-worn."
      Speaker = "Hecate"
      Event = "HecateLostAgainstHer02"
    }
    {
      Id = "Melinoe_0655"
      InheritFrom = "BaseNarrative"
      DisplayName = "Fairness is a luxury, Headmistress. Though, I do sometimes envy your ability to travel such long distances in an instant."
      Speaker = "Melinoe"
      Event = "HecateLostAgainstHer02"
    }
    {
      Id = "Hecate_0198"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do not be quick to envy what you do not understand. Along your path are to be found resources and reagents we require. And if you cannot get past me, then you are unprepared for what awaits beyond."
      Speaker = "Hecate"
      Event = "HecateLostAgainstHer02"
    }
    {
      Id = "Hecate_0025"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have gone far, Melinoë, and you bested me. Gave me quite a scrape, at that! There is much left to be done. But, you are learning."
      Speaker = "Hecate"
      Event = "HecateWonAgainstHer01"
    }
    {
      Id = "Melinoe_0054"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thank you, Headmistress. Although, I know that I could not have bested you had you held nothing back."
      Speaker = "Melinoe"
      Event = "HecateWonAgainstHer01"
    }
    {
      Id = "Hecate_0026"
      InheritFrom = "BaseNarrative"
      DisplayName = "You {#Emph}know? {#Prev}Why do you self-impose such limits on your capability? {#Emph}Alter your thoughts{#Prev}. I shall see you again out there."
      Speaker = "Hecate"
      Event = "HecateWonAgainstHer01"
    }
    {
      Id = "Hecate_0408"
      InheritFrom = "BaseNarrative"
      DisplayName = "You prevailed in your attempt! But our enemy is Time itself, and 'twould seem that he is not prepared to abdicate his stolen throne as yet."
      Speaker = "Hecate"
      Event = "HecateUnderworldRunCleared01"
    }
    {
      Id = "Melinoe_5685"
      InheritFrom = "BaseNarrative"
      DisplayName = "I often fought back feelings that this task would be impossible. But we're getting somewhere, aren't we?"
      Speaker = "Melinoe"
      Event = "HecateUnderworldRunCleared01"
    }
    {
      Id = "Hecate_0409"
      InheritFrom = "BaseNarrative"
      DisplayName = "Impossibility tends to be transient. Time would wear us down, but with patience, we can withstand him until our night arrives at last."
      Speaker = "Hecate"
      Event = "HecateUnderworldRunCleared01"
    }
    {
      Id = "Melinoe_1799"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Patience, then..."
      Speaker = "Melinoe"
      Event = "HecateUnderworldRunCleared01"
    }
    {
      Id = "Melinoe_0144"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress, have you always been so fond of beasts? It seems you would do anything for each other."
      Speaker = "Melinoe"
      Event = "HecateAboutBeasts01"
    }
    {
      Id = "Hecate_0029"
      InheritFrom = "BaseNarrative"
      DisplayName = "Beasts... saddled with such an uncharitable name. Beasts are far more trusting than most any mortal or immortal I have met."
      Speaker = "Hecate"
      Event = "HecateAboutBeasts01"
    }
    {
      Id = "Melinoe_0145"
      InheritFrom = "BaseNarrative"
      DisplayName = "They make it seem so simple, don't they? To fully trust."
      Speaker = "Melinoe"
      Event = "HecateAboutBeasts01"
    }
    {
      Id = "Hecate_0030"
      InheritFrom = "BaseNarrative"
      DisplayName = "One knows where she stands with beasts, whether she is loved by them or doomed to sate their hunger. Would that the gods were so dependable."
      Speaker = "Hecate"
      Event = "HecateAboutBeasts01"
    }
    {
      Id = "Hecate_0018"
      InheritFrom = "BaseNarrative"
      DisplayName = "You look unwell. Returning is difficult, I know. Tell me if you need anything."
      Speaker = "Hecate"
      Event = "HecateAboutWellness01"
    }
    {
      Id = "Melinoe_0050"
      InheritFrom = "BaseNarrative"
      DisplayName = "I think I'm all right, thank you, Headmistress. How do you manage it when you are out of sorts?"
      Speaker = "Melinoe"
      Event = "HecateAboutWellness01"
    }
    {
      Id = "Hecate_0005"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh I've a draught for every mood, and more. Sorrow, pain, anxiety, love-sickness, dispassion, rage, fear, nausea, cowardice... all sensations one can rectify, whether with mental fortitude or, failing that, a potent drink."
      Speaker = "Hecate"
      Event = "HecateAboutWellness01"
    }
    {
      Id = "Melinoe_0051"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Perhaps some other time."
      Speaker = "Melinoe"
      Event = "HecateAboutWellness01"
    }
    {
      Id = "Hecate_0664"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have a flush about you I could see as you approached! No need to tell me of its source, if you prefer to keep whomever it is to yourself."
      Speaker = "Hecate"
      Event = "HecateAboutRelationships01"
    }
    {
      Id = "Melinoe_3472"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Whomever it is{#Prev}, Headmistress? Could it not have been the product of a balmy night, or lingering effect of my return?"
      Speaker = "Melinoe"
      Event = "HecateAboutRelationships01"
    }
    {
      Id = "Hecate_0665"
      InheritFrom = "BaseNarrative"
      DisplayName = "Unlikely. Look, Melinoë, I was much like you once. I've said to you before that feelings mustn't be ignored. Heed the ones that spur you on, they're good! Confront the rest."
      Speaker = "Hecate"
      Event = "HecateAboutRelationships01"
    }
    {
      Id = "Melinoe_3473"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Plenty of each..."
      Speaker = "Melinoe"
      Event = "HecateAboutRelationships01"
    }
    {
      Id = "Hecate_0644"
      InheritFrom = "BaseNarrative"
      DisplayName = "Grow not attached to such a place as this; you belong within the luxury of your great father's House."
      Speaker = "Hecate"
      Event = "HecateAboutCrossroads01"
    }
    {
      Id = "Melinoe_1667"
      InheritFrom = "BaseSubtitle"
      DisplayName = "As you say, Headmistress..."
      Speaker = "Melinoe"
      Event = "HecateAboutCrossroads01"
    }
    {
      Id = "Hecate_0694"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Nocturnal Arms you bear are strong, yet burden you with terrible responsibility. One that you are only beginning to understand."
      Speaker = "Hecate"
      Event = "HecateGrantsWeaponUpgradeSystem01"
    }
    {
      Id = "Melinoe_3830"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The bearer shall uphold the will of Night in service to the Underworld. {#Prev}Almost as though I'm at their command and not the other way around..."
      Speaker = "Melinoe"
      Event = "HecateGrantsWeaponUpgradeSystem01"
    }
    {
      Id = "Hecate_0695"
      InheritFrom = "BaseNarrative"
      DisplayName = "That is the correct way to look at it. And I would share with you a certain incantation that shall deepen this relationship of yours."
      Speaker = "Hecate"
      Event = "HecateGrantsWeaponUpgradeSystem01"
    }
    {
      Id = "Hecate_0794"
      InheritFrom = "BaseNarrative"
      DisplayName = "One further secret of the Oath of the Unseen I shall reveal now. When you feel suitably prepared, consider this. Then perhaps we shall clash under a new set of circumstances..."
      Speaker = "Hecate"
      Event = "HecateGrantsShrineUpgrade01"
    }
    {
      Id = "Melinoe_4600"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The secret to the Vow of Rivals..."
      Speaker = "Melinoe"
      Event = "HecateGrantsShrineUpgrade01"
    }
    {
      Id = "Hecate_0585"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've consistently ensured the safety of your Familiars, not that I had any doubt. We are here to protect such creatures more so than the other way around."
      Speaker = "Hecate"
      Event = "HecateGrantsFamiliars01"
    }
    {
      Id = "Melinoe_2511"
      InheritFrom = "BaseNarrative"
      DisplayName = "Familiars are family, Headmistress. Perhaps through this ordeal, my bond with mine shall come to be as strong as the one you share with yours."
      Speaker = "Melinoe"
      Event = "HecateGrantsFamiliars01"
    }
    {
      Id = "Hecate_0586"
      InheritFrom = "BaseNarrative"
      DisplayName = "Of that I have no doubt as well. I've discussed the matter with Hecuba and Gale both, and they are willing to watch over you. If you ask nicely, of course."
      Speaker = "Hecate"
      Event = "HecateGrantsFamiliars01"
    }
    {
      Id = "Melinoe_2512"
      InheritFrom = "BaseNarrative"
      DisplayName = "What, truly? But they're bound to {#Emph}you! {#Prev}Wait, who must I ask nicely, you or them?"
      Speaker = "Melinoe"
      Event = "HecateGrantsFamiliars01"
    }
    {
      Id = "Hecate_0587"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'd start with {#Emph}them!"
      Speaker = "Hecate"
      Event = "HecateGrantsFamiliars01"
    }
    {
      Id = "Hecate_0861"
      InheritFrom = "BaseNarrative"
      DisplayName = "Through your achievements, our status as the Unseen grows. So long as we do not become the subject of too many tales, other than the frightful kind."
      Speaker = "Hecate"
      Event = "HecateGrantsBadgeSeller01"
    }
    {
      Id = "Melinoe_5295"
      InheritFrom = "BaseNarrative"
      DisplayName = "Our Shades all seem to understand the need for continued discretion. They seem quite excited Nyx is back and watching over us."
      Speaker = "Melinoe"
      Event = "HecateGrantsBadgeSeller01"
    }
    {
      Id = "Hecate_0862"
      InheritFrom = "BaseNarrative"
      DisplayName = "They shall discover Night Incarnate is not easy to please."
      Speaker = "Hecate"
      Event = "HecateGrantsBadgeSeller01"
    }
    {
      Id = "Melinoe_5567"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Long Arm of the Unseen..."
      Speaker = "Melinoe"
      Event = "HecateGrantsBadgeSeller01"
    }
    {
      Id = "Hecate_0863"
      InheritFrom = "BaseNarrative"
      DisplayName = "At last we are the Unseen I, and feared across the realms. I thought 'twould surely take another age..."
      Speaker = "Hecate"
      Event = "HecateAboutBadgeProgress01"
    }
    {
      Id = "Melinoe_5296"
      InheritFrom = "BaseNarrative"
      DisplayName = "It wasn't a quick process but we got there, yes. For the Unseen do not relent."
      Speaker = "Melinoe"
      Event = "HecateAboutBadgeProgress01"
    }
    {
      Id = "Hecate_0864"
      InheritFrom = "BaseNarrative"
      DisplayName = "Apparently not. What shall you do now? Pursue some other nigh-impossible result?"
      Speaker = "Hecate"
      Event = "HecateAboutBadgeProgress01"
    }
    {
      Id = "Melinoe_5297"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We'll see!"
      Speaker = "Melinoe"
      Event = "HecateAboutBadgeProgress01"
    }
    {
      Id = "Hecate_0758"
      InheritFrom = "BaseNarrative"
      DisplayName = "Chronos must believe he has the upper hand now that Olympus has the Father of All Monsters bearing down on them night after night. But he has made a grave mistake..."
      Speaker = "Hecate"
      Event = "HecateAboutStormStop01"
    }
    {
      Id = "Melinoe_4046"
      InheritFrom = "BaseNarrative"
      DisplayName = "Typhon cannot be controlled... if he no longer had Olympus to contend with, he would probably come after Chronos next. There must be some way we can redirect his rage."
      Speaker = "Melinoe"
      Event = "HecateAboutStormStop01"
    }
    {
      Id = "Hecate_0759"
      InheritFrom = "BaseNarrative"
      DisplayName = "If not his rage, the very nature of his being... I have always taught you that our craft is never to be used for destruction alone. But, no rule is immutable. Let us use our enemies' strengths against them, to rid us of them all."
      Speaker = "Hecate"
      Event = "HecateAboutStormStop01"
    }
    {
      Id = "Melinoe_4737"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Disintegration of Monstrosity..."
      Speaker = "Melinoe"
      Event = "HecateAboutStormStop01"
    }
    {
      Id = "Melinoe_4736"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress, are we finally prepared? To use the Temporal Spear against Typhon... and then Chronos after that."
      Speaker = "Melinoe"
      Event = "HecateAboutStormStop01_B"
    }
    {
      Id = "Hecate_0790"
      InheritFrom = "BaseNarrative"
      DisplayName = "I do believe we are at last, Melinoë. Once the incantation I shall teach you is complete, seek that monster, and then use the spear essence after his strength has waned."
      Speaker = "Hecate"
      Event = "HecateAboutStormStop01_B"
    }
    {
      Id = "Hecate_0945"
      InheritFrom = "BaseNarrative"
      DisplayName = "Disintegration of Monstrosity is yours now to incant if you so choose, and yet you hesitate. Ought I to be concerned?"
      Speaker = "Hecate"
      Event = "HecateAboutStormStopNotCast01"
    }
    {
      Id = "Melinoe_5734"
      InheritFrom = "BaseNarrative"
      DisplayName = "No more than we all should be of late, Headmistress. I wish to make additional preparations before committing to the final phase of the task. Or shall I rush headlong into it now?"
      Speaker = "Melinoe"
      Event = "HecateAboutStormStopNotCast01"
    }
    {
      Id = "Hecate_0946"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do not be cheeky with me. 'Tis hardly the occasion to begin making light when you seldom have thus far. Get ready, then. As patiently as you must."
      Speaker = "Hecate"
      Event = "HecateAboutStormStopNotCast01"
    }
    {
      Id = "Melinoe_5735"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Working on it."
      Speaker = "Melinoe"
      Event = "HecateAboutStormStopNotCast01"
    }
    {
      Id = "Melinoe_4942"
      InheritFrom = "BaseNarrative"
      DisplayName = "How are you faring lately, Headmistress? You've been... well, more reserved than I expected since the House of Hades. You said we'd speak more later."
      Speaker = "Melinoe"
      Event = "HecatePostTrueEnding01"
    }
    {
      Id = "Hecate_0813"
      InheritFrom = "BaseNarrative"
      DisplayName = "How soon {#Emph}later {#Prev}turns to {#Emph}now. {#Prev}Look, Melinoë, I ought be in a more celebratory mood, given what you finally achieved. I am, above all, very proud of you. But being back at the House awakened memories that ought remain dormant."
      Speaker = "Hecate"
      Event = "HecatePostTrueEnding01"
    }
    {
      Id = "Melinoe_5683"
      InheritFrom = "BaseNarrative"
      DisplayName = "Even though... you got to see Mother and Father again, and Nyx? They were so grateful to you, I could tell! {#Emph}I {#Prev}am so grateful to you. Things may not have gone precisely as we planned, but the result {#Emph}is {#Prev}what we sought, isn't it?"
      Speaker = "Melinoe"
      Event = "HecatePostTrueEnding01"
    }
    {
      Id = "Hecate_0814"
      InheritFrom = "BaseNarrative"
      DisplayName = "...You refer to Chronos. I longed to see that wretch destroyed. My heart remains poisoned by the thought. I am attempting still to draw that poison out... do give me time."
      Speaker = "Hecate"
      Event = "HecatePostTrueEnding01"
    }
    {
      Id = "Melinoe_4944"
      InheritFrom = "BaseNarrative"
      DisplayName = "I remember you once told me that destroying Chronos would not change the past, and that the pain would linger."
      Speaker = "Melinoe"
      Event = "HecatePostTrueEnding01"
    }
    {
      Id = "Hecate_0815"
      InheritFrom = "BaseNarrative"
      DisplayName = "And, I was probably correct. Yet we cannot help but reassess the turns our lives take, through our own choices and otherwise. Anyhow, are you prepared to carry on?"
      Speaker = "Hecate"
      Event = "HecatePostTrueEnding01"
    }
    {
      Id = "Melinoe_4945"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nearly so. Retracing my steps should be interesting..."
      Speaker = "Melinoe"
      Event = "HecatePostTrueEnding01"
    }
    {
      Id = "Hecate_0816"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Of that, I have no doubt."
      Speaker = "Hecate"
      Event = "HecatePostTrueEnding01"
    }
    {
      Id = "Hecate_0818"
      InheritFrom = "BaseNarrative"
      DisplayName = "So is it working out thus far? This {#Emph}change of plan{#Prev}, as our Tactician would say. Should you see even the slightest trace of the old Chronos, do notify me at once."
      Speaker = "Hecate"
      Event = "HecatePostTrueEnding02"
    }
    {
      Id = "Melinoe_5020"
      InheritFrom = "BaseNarrative"
      DisplayName = "Grandfather appeared where and when we discussed. His claims about these remnant possibilities out of Time appear to be accurate. Shall we continue?"
      Speaker = "Melinoe"
      Event = "HecatePostTrueEnding02"
    }
    {
      Id = "Hecate_0819"
      InheritFrom = "BaseNarrative"
      DisplayName = "We may as well see where it leads. Also I wished to thank you, for your concern for me before. And express my gratitude that you decided to remain with us. I was... {#Emph}angry {#Prev}with your decision at first. But no longer."
      Speaker = "Hecate"
      Event = "HecatePostTrueEnding02"
    }
    {
      Id = "Melinoe_5021"
      InheritFrom = "BaseNarrative"
      DisplayName = "It was not a difficult decision for me, Headmistress. It would have been harder had I realized it might anger you. I've been to both the Palace of Zeus and the House of Hades... and neither has a cauldron, or soft earth beneath my feet."
      Speaker = "Melinoe"
      Event = "HecatePostTrueEnding02"
    }
    {
      Id = "Hecate_0820"
      InheritFrom = "BaseNarrative"
      DisplayName = "I understand only too well, Melinoë, and I would have chosen the same, except... I thought you'd have been the wiser. Now you are stuck here, another lost soul in the crossroads 'twixt heaven and hell..."
      Speaker = "Hecate"
      Event = "HecatePostTrueEnding02"
    }
    {
      Id = "Melinoe_5022"
      InheritFrom = "BaseNarrative"
      DisplayName = "But I'm not lost. I'm where I wish to be."
      Speaker = "Melinoe"
      Event = "HecatePostTrueEnding02"
    }
    {
      Id = "Hecate_0821"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Truly..."
      Speaker = "Hecate"
      Event = "HecatePostTrueEnding02"
    }
    {
      Id = "Melinoe_5742"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress... I wanted to say, I'm sorry that you couldn't share in all those memories of the House of Hades... of how I might have grown up had Chronos chosen differently."
      Speaker = "Melinoe"
      Event = "HecatePostTrueEnding03"
    }
    {
      Id = "Hecate_0947"
      InheritFrom = "BaseNarrative"
      DisplayName = "No need for consolation, but thank you. You experienced a course in which my intervention was unnecessary. 'Twas for the best. I am gladdened you experienced such visions."
      Speaker = "Hecate"
      Event = "HecatePostTrueEnding03"
    }
    {
      Id = "Melinoe_5743"
      InheritFrom = "BaseNarrative"
      DisplayName = "I just don't understand why you weren't there. It's odd to say, but... I think I always felt your absence, somehow. I never learned my craft... so much of what I hold dear."
      Speaker = "Melinoe"
      Event = "HecatePostTrueEnding03"
    }
    {
      Id = "Hecate_0948"
      InheritFrom = "BaseNarrative"
      DisplayName = "But you {#Emph}have {#Prev}learned. As for that other possibility... it sounds as though the Titan proved unexpectedly useful around the House. Thus I was not there because your mother never needed me."
      Speaker = "Hecate"
      Event = "HecatePostTrueEnding03"
    }
    {
      Id = "Melinoe_5744"
      InheritFrom = "BaseSubtitle"
      DisplayName = "But {#Emph}I {#Prev}did. And still do."
      Speaker = "Melinoe"
      Event = "HecatePostTrueEnding03"
    }
    {
      Id = "Hecate_0949"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Heh. {#Prev}Perhaps."
      Speaker = "Hecate"
      Event = "HecatePostTrueEnding03"
    }
    {
      Id = "Hecate_0950"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lest you be tempted otherwise, do keep the details of what transpired at the House of Hades closely guarded... such as what you now recall. Rumors of your command over dreams and time may spread, but {#Emph}not {#Prev}the truth."
      Speaker = "Hecate"
      Event = "HecatePostTrueEnding04"
    }
    {
      Id = "Melinoe_5745"
      InheritFrom = "BaseNarrative"
      DisplayName = "Because we achieved what should not have been possible... but, all these memories I've gained... perhaps I can tell {#Emph}you {#Prev}more about them sometime, at least? And others with whom I'm close."
      Speaker = "Melinoe"
      Event = "HecatePostTrueEnding04"
    }
    {
      Id = "Hecate_0951"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps, eventually... though for now, discretion's the priority by will of Night herself. You are saved some complicated explanations in so doing, as well."
      Speaker = "Hecate"
      Event = "HecatePostTrueEnding04"
    }
    {
      Id = "Melinoe_5746"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's certainly true."
      Speaker = "Melinoe"
      Event = "HecatePostTrueEnding04"
    }
    {
      Id = "Hecate_0798"
      InheritFrom = "BaseNarrative"
      DisplayName = "You had an audience with the Three Fates! Your incantation from so many nights ago must have taken effect. Hermes indicated they're in good spirits, but shall be continuing their leave. Well done drawing them out nevertheless."
      Speaker = "Hecate"
      Event = "HecateBathHouseEpilogue01"
    }
    {
      Id = "Melinoe_4884"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thank you, Headmistress. I get the impression that they sought {#Emph}me {#Prev}more so than the other way around, but at least we know they're safe. They... also mentioned {#Emph}you."
      Speaker = "Melinoe"
      Event = "HecateBathHouseEpilogue01"
    }
    {
      Id = "Hecate_0799"
      InheritFrom = "BaseNarrative"
      DisplayName = "They did, did they...? In what capacity?"
      Speaker = "Hecate"
      Event = "HecateBathHouseEpilogue01"
    }
    {
      Id = "Melinoe_4885"
      InheritFrom = "BaseNarrative"
      DisplayName = "They said you've... well... is there someplace more private where we can discuss this, do you think?"
      Speaker = "Melinoe"
      Event = "HecateBathHouseEpilogue01"
    }
    {
      Id = "Hecate_0800"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}<Sigh> {#Prev}Let's to the springs. You've earned the rest, and we can sit and talk about what's on your mind... and theirs."
      Speaker = "Hecate"
      Event = "HecateBathHouseEpilogue01"
    }
    {
      Id = "Hecate_0802"
      InheritFrom = "BaseNarrative"
      DisplayName = "So, what do the three weaving-sisters know of me, then, {#Emph}hm? {#Prev}You were about to say..."
      Speaker = "Hecate"
      Event = "HecateBathHouseEpilogue01"
    }
    {
      Id = "Melinoe_4886"
      InheritFrom = "BaseNarrative"
      DisplayName = "They told me... I believe the phrase they used was, you had {#Emph}pulled some strings. {#Prev}They didn't elaborate, but suggested I ask you about it."
      Speaker = "Melinoe"
      Event = "HecateBathHouseEpilogue01"
    }
    {
      Id = "Hecate_0803"
      InheritFrom = "BaseNarrative"
      DisplayName = "...{#Emph}Pulled strings. {#Prev}I know full well what they meant. But to this point I was uncertain whether {#Emph}they {#Prev}did. Let me twist your question back; what do {#Emph}you {#Prev}suppose they implied?"
      Speaker = "Hecate"
      Event = "HecateBathHouseEpilogue01"
    }
    {
      Id = "Melinoe_4887"
      InheritFrom = "BaseNarrative"
      DisplayName = "I got the sense they felt that you had altered their designs somehow. Pulling strings... changing their weavings. And not in a small way either, but... I merely guess."
      Speaker = "Melinoe"
      Event = "HecateBathHouseEpilogue01"
    }
    {
      Id = "Hecate_0804"
      InheritFrom = "BaseNarrative"
      DisplayName = "You don't {#Emph}merely {#Prev}anything, Melinoë. Well, if those three already know my past, you ought to know it, too. And 'tis easier to explain, I suppose, if you look upon me as I am."
      Speaker = "Hecate"
      Event = "HecateBathHouseEpilogue01"
    }
    {
      Id = "Melinoe_4888"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress, what... I... you're... you're beautiful... but what is this, I — I don't understand... some trick you're playing or some glamour, or...?"
      Speaker = "Melinoe"
      Event = "HecateBathHouseEpilogue01"
    }
    {
      Id = "Hecate_0805"
      InheritFrom = "BaseNarrative"
      DisplayName = "No. The trick is when the veil is {#Emph}on. {#Prev}Look upon me, and do not avert your eyes. I know those eyes better than you."
      Speaker = "Hecate"
      Event = "HecateBathHouseEpilogue01"
    }
    {
      Id = "Melinoe_4889"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm... you're... how is this possible...? Who {#Emph}are {#Prev}you?"
      Speaker = "Melinoe"
      Event = "HecateBathHouseEpilogue01"
    }
    {
      Id = "Hecate_0806"
      InheritFrom = "BaseNarrative"
      DisplayName = "When I was a mere babe, I washed up on the bank of the Cocytus with naught but moonlight to guide me. Selene looked out for me; informed me that the Titan Chronos took my family, and that I alone escaped. Thus I trained."
      Speaker = "Hecate"
      Event = "HecateBathHouseEpilogue01"
    }
    {
      Id = "Melinoe_4890"
      InheritFrom = "BaseNarrative"
      DisplayName = "You trained... for the task. {#Emph}Death to Chronos. {#Prev}You attempted all of that... before {#Emph}I {#Prev}did?"
      Speaker = "Melinoe"
      Event = "HecateBathHouseEpilogue01"
    }
    {
      Id = "Hecate_0807"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Before {#Prev}is not entirely correct. I was a capable student, but very raw; vengeance was my headmistress. And one night, I found the wretch. Spewed every curse that I knew... and descended into the abyss of his subconscious."
      Speaker = "Hecate"
      Event = "HecateBathHouseEpilogue01"
    }
    {
      Id = "Melinoe_4891"
      InheritFrom = "BaseNarrative"
      DisplayName = "But, I had {#Emph}you {#Prev}to teach me to descend to the abyss of the subconscious... you mean to say {#Emph}you {#Prev}figured it out entirely on your own? That's impossible!"
      Speaker = "Melinoe"
      Event = "HecateBathHouseEpilogue01"
    }
    {
      Id = "Hecate_0808"
      InheritFrom = "BaseNarrative"
      DisplayName = "Speaking from experience, I beg to differ. But at any rate, something did go awry. Time and nightmare fused, and I discovered I was someplace else. I sought the end of Time... but had arrived somewhere closer to the beginning."
      Speaker = "Hecate"
      Event = "HecateBathHouseEpilogue01"
    }
    {
      Id = "Melinoe_4892"
      InheritFrom = "BaseNarrative"
      DisplayName = "And then, you lived... for aeons... waiting, for the weavings of the Fates and me? For a second chance. Headmistress, I... gods..."
      Speaker = "Melinoe"
      Event = "HecateBathHouseEpilogue01"
    }
    {
      Id = "Hecate_0809"
      InheritFrom = "BaseNarrative"
      DisplayName = "I dared not tamper with the Fates' designs more than was strictly needed. In this form, I ingratiated myself to your father and mother; became handmaiden to the Queen, in fact. Thus when Chronos inevitably struck... they gave their newborn daughter not to the River Styx, but to me."
      Speaker = "Hecate"
      Event = "HecateBathHouseEpilogue01"
    }
    {
      Id = "Melinoe_4893"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then... you did everything in your power to prepare me, so that I might succeed where you failed..."
      Speaker = "Melinoe"
      Event = "HecateBathHouseEpilogue01"
    }
    {
      Id = "Hecate_0810"
      InheritFrom = "BaseNarrative"
      DisplayName = "Correct. 'Tis as I always told you, I am not your mother, Melinoë. Neither did I have one myself. However, I had reason to be confident in your abilities.... So, there you are! How you must hate me for all this..."
      Speaker = "Hecate"
      Event = "HecateBathHouseEpilogue01"
    }
    {
      Id = "Melinoe_4894"
      InheritFrom = "BaseNarrative"
      DisplayName = "No... how can you even say that still, Headmistress? I love you... and you {#Emph}are {#Prev}my mother, whether you can admit it or not. And even if... we're far too much alike."
      Speaker = "Melinoe"
      Event = "HecateBathHouseEpilogue01"
    }
    {
      Id = "Hecate_0811"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I love you, too, of course, Melinoë, with all my heart and soul. Far more than I could ever love myself. And I am so sorry... for all that you had to endure. For the family you never had."
      Speaker = "Hecate"
      Event = "HecateBathHouseEpilogue01"
    }
    {
      Id = "Hecate_0812"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Nary a soul must know of this, I trust you understand? The Three Fates, fine; and we, and no one else. Now then... shall we pretend that none of this transpired?"
      Speaker = "Hecate"
      Event = "HecateBathHouseEpilogue01"
    }
    {
      Id = "Melinoe_4896"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll be discreet of course... but won't pretend."
      Speaker = "Melinoe"
      Event = "HecateBathHouseEpilogue01"
    }
    {
      Id = "Hecate_0840"
      InheritFrom = "BaseNarrative"
      DisplayName = "How are you faring of late, Melinoë? You cannot hide your troubles from me forever, so I bid you reveal them at will."
      Speaker = "Hecate"
      Event = "HecatePostEpilogue01"
    }
    {
      Id = "Melinoe_5040"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm just... still thinking about our conversation at the springs, that's all. I know we mustn't speak of it, but... I understand now why you acted as you did while we were at the House."
      Speaker = "Melinoe"
      Event = "HecatePostEpilogue01"
    }
    {
      Id = "Hecate_0841"
      InheritFrom = "BaseNarrative"
      DisplayName = "Very well. Then spare me your sympathies. I am fortunate beyond compare. Most of us do not get second chances to amend our failures."
      Speaker = "Hecate"
      Event = "HecatePostEpilogue01"
    }
    {
      Id = "Melinoe_5041"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've had innumerable chances. Night after night, attempting to achieve the same result."
      Speaker = "Melinoe"
      Event = "HecatePostEpilogue01"
    }
    {
      Id = "Hecate_0842"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have not once failed. Only suffered temporary setbacks on your path to victory."
      Speaker = "Hecate"
      Event = "HecatePostEpilogue01"
    }
    {
      Id = "Melinoe_5042"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Then the same could be said of you."
      Speaker = "Melinoe"
      Event = "HecatePostEpilogue01"
    }
    {
      Id = "Hecate_0843"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Heh! {#Prev}Perhaps."
      Speaker = "Hecate"
      Event = "HecatePostEpilogue01"
    }
    {
      Id = "Hecate_0844"
      InheritFrom = "BaseNarrative"
      DisplayName = "The pressure still is getting to you, even with the task essentially complete. 'Twas my desire to see you shake that burden from your shoulders by now. Why does it remain?"
      Speaker = "Hecate"
      Event = "HecatePostEpilogue02"
    }
    {
      Id = "Melinoe_5043"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress, each night I confront these remnants of old Chronos or Typhon. Such possibilities apparently are both real and innumerable, representing so many scenarios in which, for one reason or another, I failed..."
      Speaker = "Melinoe"
      Event = "HecatePostEpilogue02"
    }
    {
      Id = "Hecate_0845"
      InheritFrom = "BaseNarrative"
      DisplayName = "Or merely have yet to succeed. I stand as living proof that you are not alone in what you aim to accomplish, Melinoë."
      Speaker = "Hecate"
      Event = "HecatePostEpilogue02"
    }
    {
      Id = "Melinoe_5044"
      InheritFrom = "BaseNarrative"
      DisplayName = "What are you saying, that there are others like you... like me? Attempting to achieve the same result?"
      Speaker = "Melinoe"
      Event = "HecatePostEpilogue02"
    }
    {
      Id = "Hecate_0846"
      InheritFrom = "BaseNarrative"
      DisplayName = "I merely ask you to consider how the efforts you go to, the {#Emph}lengths {#Prev}you go to, may {#Emph}reverberate. {#Prev}The energy we put into this world comes back to us. Simply put, I am only here because {#Emph}you {#Prev}are."
      Speaker = "Hecate"
      Event = "HecatePostEpilogue02"
    }
    {
      Id = "Melinoe_5045"
      InheritFrom = "BaseSubtitle"
      DisplayName = "But it's the other way around..."
      Speaker = "Melinoe"
      Event = "HecatePostEpilogue02"
    }
    {
      Id = "Hecate_0847"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Is it...?"
      Speaker = "Hecate"
      Event = "HecatePostEpilogue02"
    }
    {
      Id = "Hecate_0865"
      InheritFrom = "BaseNarrative"
      DisplayName = "This all has come to be a comfortable routine. Each night you return refreshed; tireless. But I, at least, ought take a bit of rest."
      Speaker = "Hecate"
      Event = "HecateAboutSayingLittle01"
    }
    {
      Id = "Melinoe_5298"
      InheritFrom = "BaseNarrative"
      DisplayName = "I think we have things under control lately, so please do. Will you be going anywhere?"
      Speaker = "Melinoe"
      Event = "HecateAboutSayingLittle01"
    }
    {
      Id = "Hecate_0866"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not yet. But I may be less talkative, as is my tendency."
      Speaker = "Hecate"
      Event = "HecateAboutSayingLittle01"
    }
    {
      Id = "Hecate_0002"
      InheritFrom = "BaseNarrative"
      DisplayName = "May moonlight guide you on your path and blind your enemies."
      Speaker = "Hecate"
      Event = "HecateChat01"
    }
    {
      Id = "Hecate_0042"
      InheritFrom = "BaseNarrative"
      DisplayName = "...heart of wormwood, earth-apple, spider silk, wax-stone..."
      Speaker = "Hecate"
      Event = "HecateChat03"
    }
    {
      Id = "Hecate_0043"
      InheritFrom = "BaseNarrative"
      DisplayName = "...mulberry, snake fang, sage blossom, scorpion-tail..."
      Speaker = "Hecate"
      Event = "HecateChat04"
    }
    {
      Id = "Hecate_0044"
      InheritFrom = "BaseNarrative"
      DisplayName = "Continue your task. Our enemy is distracted."
      Speaker = "Hecate"
      Event = "HecateChat05"
    }
    {
      Id = "Hecate_0045"
      InheritFrom = "BaseNarrative"
      DisplayName = "May you cast a tall shadow in the light of the Moon."
      Speaker = "Hecate"
      Event = "HecateChat06"
    }
    {
      Id = "Hecate_0046"
      InheritFrom = "BaseNarrative"
      DisplayName = "I leaden our enemies with the weight of my curse. So mote it be."
      Speaker = "Hecate"
      Event = "HecateChat07"
    }
    {
      Id = "Hecate_0047"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have returned to us, as has your strength. Go use it well."
      Speaker = "Hecate"
      Event = "HecateChat08"
    }
    {
      Id = "Hecate_0049"
      InheritFrom = "BaseNarrative"
      DisplayName = "Push yourself hard, Melinoë, but do not break."
      Speaker = "Hecate"
      Event = "HecateChat10"
    }
    {
      Id = "Hecate_0050"
      InheritFrom = "BaseNarrative"
      DisplayName = "Our enemy is distracted. Find him, and strike him down."
      Speaker = "Hecate"
      Event = "HecateChat11"
    }
    {
      Id = "Hecate_0051"
      InheritFrom = "BaseNarrative"
      DisplayName = "You learn and grow each time that you set out. Continue on."
      Speaker = "Hecate"
      Event = "HecateChat12"
    }
    {
      Id = "Hecate_0156"
      InheritFrom = "BaseNarrative"
      DisplayName = "Proceed at pace. No task of any consequence can be completed without effort."
      Speaker = "Hecate"
      Event = "HecateChat13"
    }
    {
      Id = "Hecate_0157"
      InheritFrom = "BaseNarrative"
      DisplayName = "Much left to do both on the surface and below..."
      Speaker = "Hecate"
      Event = "HecateChat14"
    }
    {
      Id = "Hecate_0158"
      InheritFrom = "BaseNarrative"
      DisplayName = "We witches oft are underestimated. But I am well aware how capable you are."
      Speaker = "Hecate"
      Event = "HecateChat15"
    }
    {
      Id = "Hecate_0159"
      InheritFrom = "BaseNarrative"
      DisplayName = "Chronos is old enough to think that he has nothing left to learn, the utter fool."
      Speaker = "Hecate"
      Event = "HecateChat16"
    }
    {
      Id = "Hecate_0160"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your power hinges on your confidence. Do not allow yourself to falter."
      Speaker = "Hecate"
      Event = "HecateChat17"
    }
    {
      Id = "Hecate_0161"
      InheritFrom = "BaseNarrative"
      DisplayName = "Recover as you must. Returning thus is not a backward step."
      Speaker = "Hecate"
      Event = "HecateChat18"
    }
    {
      Id = "Hecate_0162"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do not relent, Melinoë. Our enemy most certainly shall not."
      Speaker = "Hecate"
      Event = "HecateChat19"
    }
    {
      Id = "Hecate_0163"
      InheritFrom = "BaseNarrative"
      DisplayName = "...moly petal, cypress leaf, mandrake root, quartz dust, garlic..."
      Speaker = "Hecate"
      Event = "HecateChat20"
    }
    {
      Id = "Hecate_0164"
      InheritFrom = "BaseNarrative"
      DisplayName = "...moon-water, nettle, beetle-shell, nightshade..."
      Speaker = "Hecate"
      Event = "HecateChat21"
    }
    {
      Id = "Hecate_0165"
      InheritFrom = "BaseNarrative"
      DisplayName = "...willow bark, sulfur, wing of bat, onion-skin..."
      Speaker = "Hecate"
      Event = "HecateChat22"
    }
    {
      Id = "Melinoe_0663"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress, if it isn't inappropriate, I have a little gift. Seeing as your personal supply ran out a while back?"
      Speaker = "Melinoe"
      Event = "HecateGift01"
    }
    {
      Id = "Hecate_0457"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, the hounds shall lap this stuff right up I think! I shall safeguard it for them as a treat. And why don't you hold onto {#Emph}this{#Prev}, in kind?"
      Speaker = "Hecate"
      Event = "HecateGift01"
    }
    {
      Id = "Hecate_0041"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, come, Melinoë, you need not influence me with such gifts. We have a task. Let us stay focused on it, no?"
      Speaker = "Hecate"
      Event = "HecateGift02"
    }
    {
      Id = "Melinoe_0501"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have taught me to apply myself to many things at once, Headmistress. Why can't I stay on task while paying my respects?"
      Speaker = "Melinoe"
      Event = "HecateGift02"
    }
    {
      Id = "Hecate_0538"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Eh{#Prev}, well... I do have a bit of a taste for this stuff, I suppose. I once traveled much more often, to places where 'tis easier to procure. Perhaps you sensed in me some wistfulness about that."
      Speaker = "Hecate"
      Event = "HecateGift03"
    }
    {
      Id = "Melinoe_0500"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've learned from you, Headmistress. So, this is just a small token of my gratitude."
      Speaker = "Melinoe"
      Event = "HecateGift03"
    }
    {
      Id = "Hecate_0539"
      InheritFrom = "BaseNarrative"
      DisplayName = "Whilst I appreciate the gesture, and the drink, 'tis entirely unneeded on your part. Have I not conditioned you to resist the temptations of unspoken contracts such as this?"
      Speaker = "Hecate"
      Event = "HecateGift04"
    }
    {
      Id = "Melinoe_0664"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know not to expect anything in return, Headmistress. The act of giving needs to be sufficiently rewarding in itself. And please believe me that it is, with you."
      Speaker = "Melinoe"
      Event = "HecateGift04"
    }
    {
      Id = "Hecate_0458"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've little taste for the traditions of the gods, you know. Lest you forget, I am a Titaness. More in common with our old enemy I daresay, than with the likes of Zeus and his ilk."
      Speaker = "Hecate"
      Event = "HecateGift05"
    }
    {
      Id = "Melinoe_2166"
      InheritFrom = "BaseNarrative"
      DisplayName = "No matter your heritage, Headmistress, you have been a sure and steady guardian of mine throughout my life. A bit of tradition helps express the gratitude I feel."
      Speaker = "Melinoe"
      Event = "HecateGift05"
    }
    {
      Id = "Hecate_0459"
      InheritFrom = "BaseNarrative"
      DisplayName = "Tradition is all well and good lest 'tis followed blindly; senselessly, I should say, for the blind are often very much aware. But let me not belabor your kind gesture; I am grateful, truly."
      Speaker = "Hecate"
      Event = "HecateGift05"
    }
    {
      Id = "Hecate_0540"
      InheritFrom = "BaseNarrative"
      DisplayName = "I thought I said you needn't curry favor with me thus. I shall take this bottle, nonetheless; if but to penalize you for not offering it up instead to someone more deserving of your affection."
      Speaker = "Hecate"
      Event = "HecateGift06"
    }
    {
      Id = "Melinoe_2167"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can think of no one else I would rather have this than you, Headmistress. You've made me the goddess I am, and not a night goes by that I'm not grateful for it."
      Speaker = "Melinoe"
      Event = "HecateGift06"
    }
    {
      Id = "Hecate_0541"
      InheritFrom = "BaseNarrative"
      DisplayName = "How often must I say, I'm not your mother, Melinoë. You needn't lavish me with such unbridled praise. I raised you to destroy our common foe. You owe no gratitude to me."
      Speaker = "Hecate"
      Event = "HecateGift06"
    }
    {
      Id = "Melinoe_2168"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've often said, what we intend and what we do are not the same. I know you're not my birthmother, so what? You've cared for me; that's more than enough."
      Speaker = "Melinoe"
      Event = "HecateGift06"
    }
    {
      Id = "Hecate_0542"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've used you, and I'm using you still. Can't you see that? I've attempted not to hide this fact from you. Yet you turn it aside."
      Speaker = "Hecate"
      Event = "HecateGift06"
    }
    {
      Id = "Melinoe_2169"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have raised me in accordance with the promises you made to my father. He never asked you to coddle me, did he? Surely he wanted me to fend for myself."
      Speaker = "Melinoe"
      Event = "HecateGift06"
    }
    {
      Id = "Hecate_0543"
      InheritFrom = "BaseNarrative"
      DisplayName = "And do you think you can? You remain under my auspices, take aid from Olympus! You're not as independent as I planned. And furthermore, I've inadvertently caused you to think I've made you better off!"
      Speaker = "Hecate"
      Event = "HecateGift06"
    }
    {
      Id = "Melinoe_2170"
      InheritFrom = "BaseNarrative"
      DisplayName = "I believe you have. I know no other way. It fills me with sorrow, knowing you feel undeserving of the love I have for you."
      Speaker = "Melinoe"
      Event = "HecateGift06"
    }
    {
      Id = "Hecate_0544"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Set your sorrow well aside for now. I'll drink your Nectar and enjoy it, if you please."
      Speaker = "Hecate"
      Event = "HecateGift06"
    }
    {
      Id = "Melinoe_2171"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I would."
      Speaker = "Melinoe"
      Event = "HecateGift06"
    }
    {
      Id = "Melinoe_5029"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why don't we head to the taverna once again? You honored {#Emph}me {#Prev}before, and I would dearly like to honor {#Emph}you."
      Speaker = "Melinoe"
      Event = "HecateGift07"
    }
    {
      Id = "Hecate_0830"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then consider me honored. I've no desire to be worshiped thus; the Shades can leave their offerings for the hounds."
      Speaker = "Hecate"
      Event = "HecateGift07"
    }
    {
      Id = "Melinoe_5030"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress, you're the reason all of us are here. The Shades adore you, and wish to commemorate that this great task you devised is finally complete!"
      Speaker = "Melinoe"
      Event = "HecateGift07"
    }
    {
      Id = "Hecate_0831"
      InheritFrom = "BaseNarrative"
      DisplayName = "We achieved what needed to be done, and we commemorated it last we attended the taverna. Now, hand over that Ambrosia, and I'll keep it for the next occasion."
      Speaker = "Hecate"
      Event = "HecateGift07"
    }
    {
      Id = "Melinoe_5686"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It's yours..."
      Speaker = "Melinoe"
      Event = "HecateGift07"
    }
    {
      Id = "Melinoe_5032"
      InheritFrom = "BaseNarrative"
      DisplayName = "You mentioned holding onto Ambrosia for the next celebratory occasion, so I wanted to donate more for when the time comes. To the next great victory of the Unseen!"
      Speaker = "Melinoe"
      Event = "HecateGift08"
    }
    {
      Id = "Hecate_0832"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, {#Emph}stop{#Prev}, Melinoë! Evidently neither of us knows what to do with themselves now, as you are so {#Emph}insistent {#Prev}on these most-unnecessary gifts! Leave me in peace."
      Speaker = "Hecate"
      Event = "HecateGift08"
    }
    {
      Id = "Melinoe_5687"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wasn't trying to upset you.... Did you truly wish for me to stay there in the House that much? With Mother and Father... where I belong, you always said."
      Speaker = "Melinoe"
      Event = "HecateGift08"
    }
    {
      Id = "Hecate_0833"
      InheritFrom = "BaseNarrative"
      DisplayName = "Purge {#Emph}that {#Prev}poisoned thought at once. I taught you a great deal in some respects but to the detriment of your experience in other walks of life."
      Speaker = "Hecate"
      Event = "HecateGift08"
    }
    {
      Id = "Melinoe_5688"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...I learn quickly."
      Speaker = "Melinoe"
      Event = "HecateGift08"
    }
    {
      Id = "Melinoe_3886"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress? I've a bottle of Ambrosia here, and... thought perhaps that we could share it at the taverna, if you could step away with me a bit! I know it's an odd time..."
      Speaker = "Melinoe"
      Event = "HecateTaverna01"
    }
    {
      Id = "Hecate_0696"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Melinoë, I'm going to resist my impulse to tersely decline, so that I might remind myself as to whether the greatest of Olympian delicacies lives up to its reputation! Let's be off."
      Speaker = "Hecate"
      Event = "HecateTaverna01"
    }
    {
      Id = "Hecate_0697"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I had not given this taverna any real thought. Such gathering-places, where one can be unguarded... dare-I-say relaxed? A liability. We need our senses sharp."
      Speaker = "Hecate"
      Event = "HecateTaverna01"
    }
    {
      Id = "Melinoe_3887"
      InheritFrom = "BaseNarrative"
      DisplayName = "But now that you're here, you've come to realize that having such a place where we and Shades can comingle has its benefits? And that I didn't overstep when I restored it?"
      Speaker = "Melinoe"
      Event = "HecateTaverna01"
    }
    {
      Id = "Hecate_0698"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes I have, and no, you did not. The tension about these Crossroads has grown too palpable for my liking, as this much nervous energy does our cause no good. But, I digress. Discussion of our cause ought be off limits here."
      Speaker = "Hecate"
      Event = "HecateTaverna01"
    }
    {
      Id = "Melinoe_3888"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ah yes, more rules! Just what this taverna needs to ease the tensions of our small band of loyalists. I think you're onto something, Headmistress!"
      Speaker = "Melinoe"
      Event = "HecateTaverna01"
    }
    {
      Id = "Hecate_0699"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ohh{#Prev}, I see how it is. What, a sip or two of Ambrosia and suddenly your inhibitions are all gone? A powerful effect! We ought to use it in the cauldron if not here."
      Speaker = "Hecate"
      Event = "HecateTaverna01"
    }
    {
      Id = "Melinoe_3889"
      InheritFrom = "BaseNarrative"
      DisplayName = "...We're still talking about our cause, and our craft. Why don't you... tell me of a time when you were closer to my age, if you don't mind?"
      Speaker = "Melinoe"
      Event = "HecateTaverna01"
    }
    {
      Id = "Hecate_0700"
      InheritFrom = "BaseNarrative"
      DisplayName = "I mind. Though perhaps as we delve deeper into this bottle, I shall not mind as much! Shall we find out? To discovering the truth!"
      Speaker = "Hecate"
      Event = "HecateTaverna01"
    }
    {
      Id = "Hecate_0701"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Ignore my sullen turn back there, Melinoë. These evenings I am more concerned about the future than the past. I trust I did not overly affect the atmosphere."
      Speaker = "Hecate"
      Event = "HecateTaverna01"
    }
    {
      Id = "Melinoe_3891"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Nonsense, Headmistress. We're grateful you could join us."
      Speaker = "Melinoe"
      Event = "HecateTaverna01"
    }
    {
      Id = "Melinoe_5023"
      InheritFrom = "BaseNarrative"
      DisplayName = "Would you care to split this bottle of Ambrosia, Headmistress? We never truly celebrated the restoration of the Underworld's King and Queen here."
      Speaker = "Melinoe"
      Event = "HecateTaverna02"
    }
    {
      Id = "Hecate_0824"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sipping the drink of your mountain relatives hardly seems suitable festivity, though very well. You are correct that these Shades shall be expecting {#Emph}something."
      Speaker = "Hecate"
      Event = "HecateTaverna02"
    }
    {
      Id = "Hecate_0825"
      InheritFrom = "BaseNarrative"
      DisplayName = "...And so, I bid you all salute your Princess of the Underworld, who never relented against the threat of Time itself, and the Father of All Monsters, amongst many others!"
      Speaker = "Hecate"
      Event = "HecateTaverna02"
    }
    {
      Id = "Melinoe_5024"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thank you, Headmistress. {#Emph}Everyone! {#Prev}I never could have done this without you... without these Crossroads, the one place I could always return to in a moment of need."
      Speaker = "Melinoe"
      Event = "HecateTaverna02"
    }
    {
      Id = "Hecate_0826"
      InheritFrom = "BaseNarrative"
      DisplayName = "You are welcome here and safe, Melinoë. And whilst we had utmost faith in you, nevertheless what you accomplished was beyond imagining."
      Speaker = "Hecate"
      Event = "HecateTaverna02"
    }
    {
      Id = "Melinoe_5025"
      InheritFrom = "BaseNarrative"
      DisplayName = "I did what you trained me to do. I'm grateful for your patience through all the many setbacks I had to overcome."
      Speaker = "Melinoe"
      Event = "HecateTaverna02"
    }
    {
      Id = "Hecate_0827"
      InheritFrom = "BaseNarrative"
      DisplayName = "How else could we have stood against Time itself if not through patience? I knew you would be a capable student. 'Tis the only reason I pushed you as hard as I did."
      Speaker = "Hecate"
      Event = "HecateTaverna02"
    }
    {
      Id = "Melinoe_5026"
      InheritFrom = "BaseNarrative"
      DisplayName = "So then what happens now to the Unseen? Our Shades each have an honorary place in Elysium waiting for them..."
      Speaker = "Melinoe"
      Event = "HecateTaverna02"
    }
    {
      Id = "Hecate_0828"
      InheritFrom = "BaseNarrative"
      DisplayName = "That may be, if they decide to leave. But, I suspect they're in no greater hurry to abandon this place than are you. There is always more we may accomplish here, and we stand to go farther together than alone."
      Speaker = "Hecate"
      Event = "HecateTaverna02"
    }
    {
      Id = "Hecate_0829"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Well, 'twas not the most formal gathering, but my sense is that it was worthwhile? All these Shades... they arrived here for lack of anyplace to go. Now, 'tis a permanent home."
      Speaker = "Hecate"
      Event = "HecateTaverna02"
    }
    {
      Id = "Melinoe_5028"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Not just a place to stop... a place to stay."
      Speaker = "Melinoe"
      Event = "HecateTaverna02"
    }
    {
      Id = "Melinoe_3892"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't suppose I could persuade you to come join me at the taverna for a bottle of Ambrosia, could I, Headmistress?"
      Speaker = "Melinoe"
      Event = "HecateTavernaDecline01"
    }
    {
      Id = "Hecate_0702"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, I don't suppose you can, not now. I shan't darken the mood there amongst the Shades requiring respite."
      Speaker = "Hecate"
      Event = "HecateTavernaDecline01"
    }
    {
      Id = "Melinoe_2095"
      InheritFrom = "BaseSubtitle"
      DisplayName = "They're missing out I'm sure."
      Speaker = "Melinoe"
      Event = "HecateTavernaDecline01"
    }
    {
      Id = "Melinoe_0669"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Cocytus teems with life there by the riverbank again, Headmistress. Would you please join me for a look?"
      Speaker = "Melinoe"
      Event = "HecateFishing01"
    }
    {
      Id = "Hecate_0378"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, very well, why not! I suppose I could use a little walk, and we could use the fish."
      Speaker = "Hecate"
      Event = "HecateFishing01"
    }
    {
      Id = "Hecate_0651"
      InheritFrom = "BaseNarrative"
      DisplayName = "...'Twas not very long ago that you never would have permitted yourself this type of excursion. Nor had the mettle to request that I accompany you."
      Speaker = "Hecate"
      Event = "HecateFishing01"
    }
    {
      Id = "Melinoe_3454"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress, you're right. I could be hunting for our enemy this very moment, and you... you've so many responsibilities, yet I'm wasting your time. This was a mistake."
      Speaker = "Melinoe"
      Event = "HecateFishing01"
    }
    {
      Id = "Hecate_0652"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hold, lest you frighten the river denizens; only {#Emph}then {#Prev}should my time be wasted here, Melinoë! You mistook the meaning of my words. Your capacity to still your racing mind is not a detriment. 'Tis a growing strength!"
      Speaker = "Hecate"
      Event = "HecateFishing01"
    }
    {
      Id = "Melinoe_3455"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm... surprised you see it that way. Sometimes I feel I'm losing my focus. Why else would I have brought us here?"
      Speaker = "Melinoe"
      Event = "HecateFishing01"
    }
    {
      Id = "Hecate_0653"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps you reasoned that we each need occupy our minds with other matters for a little while. And we are failing at it by continuing to speak! Let us be still together and direct our focus on the waters there."
      Speaker = "Hecate"
      Event = "HecateFishing01"
    }
    {
      Id = "Hecate_0396"
      InheritFrom = "BaseNarrative"
      DisplayName = "The river always provides, and let no such task ever be beneath us."
      Speaker = "Hecate"
      Event = "HecateFishing01"
    }
    {
      Id = "Melinoe_5035"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't suppose you'd be willing to head to the fishing pier with me again? Good place to occupy our minds with other matters for a little while."
      Speaker = "Melinoe"
      Event = "HecateFishing02"
    }
    {
      Id = "Hecate_0834"
      InheritFrom = "BaseNarrative"
      DisplayName = "That it can be. Then very well. There is aught I wish to speak with you about, besides."
      Speaker = "Hecate"
      Event = "HecateFishing02"
    }
    {
      Id = "Hecate_0835"
      InheritFrom = "BaseNarrative"
      DisplayName = "...You truly believe I wish to rid myself of you? Either that or you sought to wound me more deeply with your words than you're able to with the Nocturnal Arms."
      Speaker = "Hecate"
      Event = "HecateFishing02"
    }
    {
      Id = "Melinoe_5036"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm sorry, Headmistress, it's just... at the House, I realized I didn't just want my family back... I wanted you to be happy. But I felt like you were pushing me away."
      Speaker = "Melinoe"
      Event = "HecateFishing02"
    }
    {
      Id = "Hecate_0836"
      InheritFrom = "BaseNarrative"
      DisplayName = "My happiness is neither your responsibility nor is it within your grasp. And 'tis I who ought apologize. For all that I put you through. Forgive me."
      Speaker = "Hecate"
      Event = "HecateFishing02"
    }
    {
      Id = "Melinoe_5037"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Never apologize when you are not at fault{#Prev}, you used to say. You were never easy on me, but also were never cruel. You taught me the difference, among so many things."
      Speaker = "Melinoe"
      Event = "HecateFishing02"
    }
    {
      Id = "Hecate_0837"
      InheritFrom = "BaseNarrative"
      DisplayName = "A lack of cruelty is not the highest standard. At any rate, evidently I've taught you enough. I still shall challenge you in Erebus for sake of fitness and attunement, but in time, perhaps you shall refer to me not by title, but by name..."
      Speaker = "Hecate"
      Event = "HecateFishing02"
    }
    {
      Id = "Melinoe_5038"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not as Headmistress, but as Hecate... that shall take a while. To think I used to use your name so casually when I was little. Much comes full circle with time."
      Speaker = "Melinoe"
      Event = "HecateFishing02"
    }
    {
      Id = "Hecate_0838"
      InheritFrom = "BaseNarrative"
      DisplayName = "More than you know. Now, let us shift our focus to the river denizens getting too close a listen for their own good..."
      Speaker = "Hecate"
      Event = "HecateFishing02"
    }
    {
      Id = "Hecate_0839"
      InheritFrom = "BaseNarrative"
      DisplayName = "That was a pleasant enough outing, but speak not to me of happiness again. 'Tis a foolish thing with which to be concerned; a byproduct of fulfillment, nothing more."
      Speaker = "Hecate"
      Event = "HecateFishing02"
    }
    {
      Id = "Melinoe_5039"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Of course. Thank you, Headmistress... Hecate."
      Speaker = "Melinoe"
      Event = "HecateFishing02"
    }
    {
      Id = "Melinoe_0665"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress, I was wondering if you might accompany me to the springs for a short while? If you're not overly preoccupied?"
      Speaker = "Melinoe"
      Event = "HecateBathHouse01"
    }
    {
      Id = "Hecate_0240"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Eugh{#Prev}, well, I do believe I could use a bit of a soak. I've more knots in my back than that tree! Let's be quick about it, then."
      Speaker = "Hecate"
      Event = "HecateBathHouse01"
    }
    {
      Id = "Hecate_0250"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, but this is all right. Thank you for replenishing these waters! One of those details I had been meaning to get to, but... alas."
      Speaker = "Hecate"
      Event = "HecateBathHouse01"
    }
    {
      Id = "Melinoe_0670"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're very welcome, Headmistress. I appreciate your saying so, as I half-thought you would admonish me for using magick and resources on this sort of thing."
      Speaker = "Melinoe"
      Event = "HecateBathHouse01"
    }
    {
      Id = "Hecate_0251"
      InheritFrom = "BaseNarrative"
      DisplayName = "Magick mostly {#Emph}is {#Prev}for self-improvement, Melinoë. Not a shortcut, mind you. And if an occasional scalding-hot soak in the springs isn't self-improvement, then my concept of it must be very flawed."
      Speaker = "Hecate"
      Event = "HecateBathHouse01"
    }
    {
      Id = "Melinoe_0671"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wish I could bring myself to relax. I feel like I'm wasting precious time while I'm here."
      Speaker = "Melinoe"
      Event = "HecateBathHouse01"
    }
    {
      Id = "Hecate_0252"
      InheritFrom = "BaseNarrative"
      DisplayName = "Time spent being good to oneself is never wasted... unless you overthink it overmuch! We are {#Emph}here. {#Prev}Seize the moment, ere it passes."
      Speaker = "Hecate"
      Event = "HecateBathHouse01"
    }
    {
      Id = "Hecate_0257"
      InheritFrom = "BaseNarrative"
      DisplayName = "A shame we cannot cook indefinitely in those springs, but... a brief dip is better than none at all."
      Speaker = "Hecate"
      Event = "HecateBathHouse01"
    }
    {
      Id = "Melinoe_0667"
      InheritFrom = "BaseNarrative"
      DisplayName = "I was thinking of putting these purifying salts to use, Headmistress. Call it a cleansing ritual. Would you accompany me?"
      Speaker = "Melinoe"
      Event = "HecateBathHouse02"
    }
    {
      Id = "Hecate_0241"
      InheritFrom = "BaseNarrative"
      DisplayName = "A visit to the springs ought rid us of unwanted thoughts for a while. Let us be cleansed together, then."
      Speaker = "Hecate"
      Event = "HecateBathHouse02"
    }
    {
      Id = "Hecate_0244"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Mm. {#Prev}We're like two nettles boiling in a cauldron, aren't we?"
      Speaker = "Hecate"
      Event = "HecateBathHouse02"
    }
    {
      Id = "Melinoe_0673"
      InheritFrom = "BaseNarrative"
      DisplayName = "I remember bathing in this spring when I was very small. You would ask me never to splash your hair, and I would do it anyway. You were so tolerant of me."
      Speaker = "Melinoe"
      Event = "HecateBathHouse02"
    }
    {
      Id = "Hecate_0253"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, now at least you know the reason that your training was so rigorous! There came a point when even my vast tolerance for all your splashing finally wore thin."
      Speaker = "Hecate"
      Event = "HecateBathHouse02"
    }
    {
      Id = "Melinoe_0674"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wait... you trained me to the height of my ability as a witch because I got your hair wet?"
      Speaker = "Melinoe"
      Event = "HecateBathHouse02"
    }
    {
      Id = "Hecate_0254"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Mm{#Prev}, was either that, or transform you into a newt, or something! Come off it, Melinoë. You are entirely too serious, sometimes."
      Speaker = "Hecate"
      Event = "HecateBathHouse02"
    }
    {
      Id = "Melinoe_3471"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Heh. {#Prev}A lesson I've been unable to take to heart, Headmistress. I suppose it's been a while since we talked like this."
      Speaker = "Melinoe"
      Event = "HecateBathHouse02"
    }
    {
      Id = "Hecate_0255"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes, well, that's growing up for you. And present circumstances haven't helped, either. This blasted hot-spring got all covered up with moss and had been stagnant, I don't know how long. Being here again... it takes me back."
      Speaker = "Hecate"
      Event = "HecateBathHouse02"
    }
    {
      Id = "Melinoe_0676"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do you think we'll be able to keep the moss from reclaiming this place again?"
      Speaker = "Melinoe"
      Event = "HecateBathHouse02"
    }
    {
      Id = "Hecate_0256"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll watch the moss, you watch the splashing. Deal?"
      Speaker = "Hecate"
      Event = "HecateBathHouse02"
    }
    {
      Id = "Hecate_0258"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Whew! {#Prev}Much better. Sometimes I think that hot-spring could raise the dead."
      Speaker = "Hecate"
      Event = "HecateBathHouse02"
    }
    {
      Id = "Melinoe_0668"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know it's a difficult time, Headmistress, but just in case, would you be interested in joining me for a brief while at the hot springs?"
      Speaker = "Melinoe"
      Event = "HecateBathHouseDecline01"
    }
    {
      Id = "Hecate_0239"
      InheritFrom = "BaseNarrative"
      DisplayName = "As much as I would enjoy basking in the springs, I've incantations to complete, wards to reinforce.... No, I cannot. Not now."
      Speaker = "Hecate"
      Event = "HecateBathHouseDecline01"
    }
    {
      Id = "Melinoe_5306"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do you suppose we could take a brief break from all this and stop by the river over at the pier?"
      Speaker = "Melinoe"
      Event = "HecateFishingDecline01"
    }
    {
      Id = "Hecate_0260"
      InheritFrom = "BaseNarrative"
      DisplayName = "I do wish to see firsthand whether your skill at fishing has improved, yet unfortunately I have other matters that I must attend to now."
      Speaker = "Hecate"
      Event = "HecateFishingDecline01"
    }
    {
      Id = "Melinoe_1725"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Headmistress is away."
      Speaker = "Melinoe"
      Event = "NPC_Hecate_01.MissingDistanceTrigger.VoiceLines"
    }
    {
      Id = "Melinoe_1726"
      InheritFrom = "BaseSubtitle"
      DisplayName = "No sign of Headmistress."
      Speaker = "Melinoe"
      Event = "NPC_Hecate_01.MissingDistanceTrigger.VoiceLines"
    }
    {
      Id = "Melinoe_1148"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Your Silver Wheel? I can have this?"
      Speaker = "Melinoe"
      Event = "NPC_Hecate_01.GiftGivenVoiceLines"
    }
    {
      Id = "Melinoe_2120"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got you, Hecate!! You're dead!"
      Speaker = "Melinoe"
      Event = "HecateHideAndSeek01"
    }
    {
      Id = "Hecate_0516"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Haha{#Prev}, got me you did, Melinoë. But I daresay I can escape your clutches yet!"
      Speaker = "Hecate"
      Event = "HecateHideAndSeek01"
    }
    {
      Id = "Melinoe_2121"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hey...!"
      Speaker = "Melinoe"
      Event = "HecateHideAndSeek01"
    }
    {
      Id = "Hecate_0522"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Awooo..."
      Speaker = "Hecate"
      Event = "HecateHideAndSeek01"
    }
    {
      Id = "Melinoe_2112"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Can't hide from me...!"
      Speaker = "Melinoe"
      Event = "HecateHideAndSeek01"
    }
    {
      Id = "Melinoe_2122"
      InheritFrom = "BaseNarrative"
      DisplayName = "There you are! Got you again!"
      Speaker = "Melinoe"
      Event = "HecateHideAndSeek02"
    }
    {
      Id = "Hecate_0517"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Aah! {#Prev}So persistent! Give up already, Witch! For I'm a Titaness! {#Emph}You {#Prev}cannot vanquish {#Emph}me!"
      Speaker = "Hecate"
      Event = "HecateHideAndSeek02"
    }
    {
      Id = "Melinoe_2123"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I can, and shall!"
      Speaker = "Melinoe"
      Event = "HecateHideAndSeek02"
    }
    {
      Id = "Melinoe_2124"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hahaha{#Prev}, I {#Emph}got {#Prev}you!! ...Hecate...? What's the matter?"
      Speaker = "Melinoe"
      Event = "HecateHideAndSeek03"
    }
    {
      Id = "Hecate_0518"
      InheritFrom = "BaseNarrative"
      DisplayName = "...{#Emph}Ah{#Prev}, it's merely that... {#Emph}tsk{#Prev}, I've not heard your laughter before. Reminded me of your mother! A much preferable sound to that of grief."
      Speaker = "Hecate"
      Event = "HecateHideAndSeek03"
    }
    {
      Id = "Melinoe_2343"
      InheritFrom = "BaseNarrative"
      DisplayName = "I promise not to cry again! I still get sad sometimes, but not as much..."
      Speaker = "Melinoe"
      Event = "HecateHideAndSeek03"
    }
    {
      Id = "Hecate_0519"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do not make promises you cannot keep. When tears well up, let them spill forth; they're not so precious that they need be contained."
      Speaker = "Hecate"
      Event = "HecateHideAndSeek03"
    }
    {
      Id = "Melinoe_2126"
      InheritFrom = "BaseNarrative"
      DisplayName = "But you never cry, Hecate! And I wish to become strong, like you! So that I might find Chronos, and destroy him for what he's done. And then you could hear my mother's laugh again!"
      Speaker = "Melinoe"
      Event = "HecateHideAndSeek03"
    }
    {
      Id = "Hecate_0520"
      InheritFrom = "BaseNarrative"
      DisplayName = "And I shall do everything in my power to prepare you, so that you may succeed where I failed. If not for your family's sake, then for your birthright... as the Princess of the Underworld."
      Speaker = "Hecate"
      Event = "HecateHideAndSeek03"
    }
    {
      Id = "Melinoe_2344"
      InheritFrom = "BaseNarrative"
      DisplayName = "What do you mean you failed? You tried to beat Chronos yourself? He hurt you?"
      Speaker = "Melinoe"
      Event = "HecateHideAndSeek03"
    }
    {
      Id = "Hecate_0521"
      InheritFrom = "BaseNarrative"
      DisplayName = "Concern yourself with your own pain, not mine. Destroying Chronos shall not change the past, and the pain shall linger, though assert itself less frequently with age... but enough of this! On the morrow, we shall teach you to hunt greater prey."
      Speaker = "Hecate"
      Event = "HecateHideAndSeek03"
    }
    {
      Id = "Melinoe_2128"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}<Gasp> {#Prev}Truly?"
      Speaker = "Melinoe"
      Event = "HecateHideAndSeek03"
    }
  ]
}
