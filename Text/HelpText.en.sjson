      Description = "{$Keywords.CosmeticAdd}: Smattering of small floating lights scattered about the main grounds."
    }
    {
      Id = "Cosmetic_MainTeaLights_Flavor"
      Description = "Bits of the stars themselves create the ever-lasting spark in these little bits of brightness."
    }

    {
      Id = "Cosmetic_MainLanterns01"
