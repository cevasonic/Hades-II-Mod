    }
    {
      Id = "Cosmetic_FishingSign01a_Flavor"
      Description = "When grains of gold began to flow through what once was the bank of the Styx, creatures such as these soon arrived."
    }
    {
      Id = "Cosmetic_FishingSign01b"
