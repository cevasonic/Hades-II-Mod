    /* Cauldron Spells / Cauldron Recipes / Incantations / Critical Items / World Upgrades */
    {
      Id = "WorldUpgradeQuestLog"
      DisplayName = "Fated Intervention"
      Description = "Beseech the {$Keywords.CharFates} to lend their aid in a time of great need."
    }
    {
      Id = "WorldUpgradeQuestLog_Flavor"
      Description = "Not even the Titan of Time ought be able to escape what the Fates may have in store for him... whatever that may be."
    }

    {
      Id = "WorldUpgradeStoryReset"
      DisplayName = "Returning to a Real Possibility"
      Description = "Reminisce at the {#BoldFormatGraftDark}Fountain of the Dead {#Prev}to return to an earlier point in your journey, if you wish."
    }
    {
      Id = "WorldUpgradeStoryReset_Flavor"
      Description = "Time marches ever forward. To what extent its course is predetermined, only the Fates can say."
    }

    {
      Id = "WorldUpgradeChangeNextRunRNG"
      DisplayName = "Acceptance of Another Fate"
      Description = "Salute the {$Keywords.Shrine} to change your {$Keywords.RNG} prior to setting forth this night, if you wish..."
    }
    {
      Id = "WorldUpgradeChangeNextRunRNG_Flavor"
      Description = "An incantation for the superstitious and the bold, for who can say what the Fates had in store for us to begin with?"
    }

    {
      Id = "WorldUpgradeToolsShop"
      DisplayName = "Night's Craftwork"
      Description = "Reveal {$Keywords.ToolPlural} within the {$Keywords.WeaponShop}. Unlock them to gather {!Icons.OreFSilverIcon}, {!Icons.MemPointsCommonIcon}, and more."
    }
    {
      Id = "WorldUpgradeToolsShop_Flavor"
      Description = "The Earth yields its splendors readily to those bearing Night's silver and a worthy purpose."
    }
    {
      Id = "WorldUpgradeWeaponUpgradeSystem"
      DisplayName = "Aspects of Night and Darkness"
      Description = "Reveal {$Keywords.AspectPlural} within the {$Keywords.WeaponShop} that further empower each {$Keywords.Weapon}."
    }
    {
      Id = "WorldUpgradeWeaponUpgradeSystem_Flavor"
      Description = "The Nocturnal Arms belong to no one, but may be persuaded to let trusted bearers choose their form."
    }
    {
      Id = "WorldUpgradeToolUpgradeSystem"
      DisplayName = "Greater Favor of Gaia"
      Description = "Reveal enhancements within the {$Keywords.WeaponShop} that further empower each {$Keywords.Tool}."
    }
    {
      Id = "WorldUpgradeToolUpgradeSystem_Flavor"
      Description = "The Tools of the Unseen avail their purest forms to those familiar with their connection to this world."
    }
    {
      Id = "WorldUpgradeCardUpgradeSystem"
      DisplayName = "Consecration of Ashes"
      Description = "Enhance the {$Keywords.CardTable} so that you can unlock the potential of your {$Keywords.CardPlural}. Grants {#UpgradeFormatDark}+{$WorldUpgradeData.WorldUpgradeCardUpgradeSystem.OnActivateFinishedFunctionArgs.ResourceAmount}{#Prev}{!Icons.CardUpgradePointsIcon}."
    }
    {
      Id = "WorldUpgradeCardUpgradeSystem_Flavor"
      Description = "The sufficiently experienced and well-traveled witch can draw still more from the past."
    }

    {
      Id = "WorldUpgradeMetaUpgradeSaveLayout"
      DisplayName = "Spreading of Ashes"
      Description = "Enhance the {$Keywords.CardTable} to preserve up to {#UpgradeFormatDark}{$MetaUpgradeSaveLayoutData.MaximumMetaUpgradeLayouts} {#Prev}different arrangements of your {$Keywords.CardPlural}."
    }
    {
      Id = "WorldUpgradeMetaUpgradeSaveLayout_Flavor"
      Description = "Various possibilities always exist, however unlikely; the experienced witch considers more and more."
    }

    {
      Id = "WorldUpgradeFamiliarSystem"
      DisplayName = "Faith of Familiar Spirits"
      Description = "Turn trusted beasts into your {$Keywords.FamiliarPlural}. Grants {#UpgradeFormatDark}+{$WorldUpgradeData.WorldUpgradeFamiliarSystem.OnActivateFinishedFunctionArgs.ResourceAmount}{#Prev}{!Icons.FamiliarPointsIcon}."
    }
    {
      Id = "WorldUpgradeFamiliarSystem_Flavor"
      Description = "While not all Familiars are beasts, the unwavering nature of such creatures often makes them suitable."
    }

    {
      Id = "WorldUpgradeFamiliarUpgradeSystem"
      DisplayName = "Bravery of Familiar Spirits"
      Description = "Grow your bond with {$Keywords.FamiliarPlural}, to make them stronger with each treat. Grants {#UpgradeFormatDark}+{$WorldUpgradeData.WorldUpgradeFamiliarUpgradeSystem.OnActivateFinishedFunctionArgs.ResourceAmount}{#Prev}{!Icons.FamiliarPointsIcon}."
    }
    {
      Id = "WorldUpgradeFamiliarUpgradeSystem_Flavor"
      Description = "Familiars, much like any of us, possess latent strength they may discover in due time."
    }

    {
      Id = "WorldUpgradeFamiliarCostumeSystem"
      DisplayName = "Alteration of Familiar Forms"
      Description = "Choose from other appearances for your {$Keywords.FamiliarPlural}, in exchange for {!Icons.CosmeticsPointsIcon}."
    }
    {
      Id = "WorldUpgradeFamiliarCostumeSystem_Flavor"
      Description = "How we imagine ourselves and how we appear in some cases may be conflated."
    }

    {
      Id = "WorldUpgradeMarket"
      DisplayName = "Summoning of Mercantile Fortune"
      Description = "Persuade the {$Keywords.Broker} to appear, with whom you may trade {!Icons.MetaCurrencyIcon} for various resources."
    }
    {
      Id = "WorldUpgradeMarket_Flavor"
      Description = "Bones of the dead remain a valuable commodity to those who know their secrets."
    }

    {
      Id = "WorldUpgradeRunHistory"
      DisplayName = "Summoning of Historic Travails"
      Description = "Persuade the {$Keywords.Historian} to appear, with whom you may review the outcomes of your every night."
    }
    {
      Id = "WorldUpgradeRunHistory_Flavor"
      Description = "With knowledge of the past, future outcomes still cannot be anticipated; but it can make one interesting."
    }
    {
      Id = "WorldUpgradeGameStats"
      DisplayName = "Summoning of Personal Insights"
      Description = "Persuade the {$Keywords.Statistican} to appear, from whom you may learn enlightening statistical details."
    }
    {
      Id = "WorldUpgradeGameStats_Flavor"
      Description = "The House of Hades kept meticulous track of things, an art still practiced here and there."
    }
    {
      Id = "WorldUpgradeMusicPlayer"
      DisplayName = "Summoning of Musical Rhapsody"
      Description = "Persuade the {$Keywords.MusicPlayer} to appear, who can perform a variety of renowned melodies."
    }
    {
      Id = "WorldUpgradeMusicPlayer_Flavor"
      Description = "Apollo, in his generosity, shared a wondrous talent for creating beautiful music with a select few."
    }
    {
      Id = "WorldUpgradeMusicPlayerShuffle"
      DisplayName = "Shuffling of Noted Ballads"
      Description = "Induce the {$Keywords.MusicPlayer} to optionally choose which melodies to play based on whim alone."
    }
    {
      Id = "WorldUpgradeMusicPlayerShuffle_Flavor"
      Description = "One cannot always know exactly what one wishes to hear unless one's soul is listening."
    }

    {
      Id = "WorldUpgradeAltRunDoor"
      DisplayName = "Permeation of Witching-Wards"
      Description = "Gain the ability to traverse {$Keywords.Warded} gateways, such as the one leading to the surface..."
    }
    {
      Id = "WorldUpgradeAltRunDoor_Flavor"
      Description = "The wards fend off no foe but rather prevent an inexperienced Princess from venturing too far."
    }
    {
      Id = "WorldUpgradeSurfacePenaltyCure"
      DisplayName = "Unraveling a Fateful Bond"
      Description = "Forestall the effects of your bloodline's ancient Life-draining curse that bars you from the surface."
    }
    {
      Id = "WorldUpgradeSurfacePenaltyCure_Flavor"
      Description = "The Fates deigned that those born of the Underworld are to be bound there; but that was then and this is now."
    }

    {
      Id = "WorldUpgradeElementalBoons"
      DisplayName = "Divination of the Elements"
      Description = "Reveal hidden elemental affinities of various {$Keywords.GodBoonPlural}; Olympians will offer {$Keywords.GodBoonPlural} that use these."
    }
    {
      Id = "WorldUpgradeElementalBoons_Flavor"
      Description = "The world's near-limitless possibilities are composed of a scarce few elementary particles."
    }

    {
      Id = "WorldUpgradeGiftsShop"
      DisplayName = "Kinship Fortune"
      Description = "Update the {$Keywords.Broker} inventory with exotic goods suitable for gifting. Grants {#UpgradeFormatDark}+1{#Prev}{!Icons.GiftPointsIcon}."
    }
    {
      Id = "WorldUpgradeGiftsShop_Flavor"
      Description = "Many traditions are difficult to break, and the Olympian gift-giving custom is one."
    }
    {
      Id = "WorldUpgradeSellShop"
      DisplayName = "Deathly Fortune"
      Description = "Update the {$Keywords.Broker} to bestow {!Icons.MetaCurrencyIcon} in exchange for your {!Icons.ToolRodIconNoTooltip} {$WeaponShopItemData.ToolFishingRod.Name} catches."
    }
    {
      Id = "WorldUpgradeSellShop_Flavor"
      Description = "No denizens of the deep are harmed as part of any such transaction."
    }
    {
      Id = "WorldUpgradeExchangeShop"
      DisplayName = "Earthly Fortune"
      Description = "Update the {$Keywords.Broker} to bestow {!Icons.CosmeticsPointsIcon} in exchange for recycling most any surplus resource."
    }
    {
      Id = "WorldUpgradeExchangeShop_Flavor"
      Description = "The experienced witch uses no more than what is required; the rest is for Gaia to keep safe."
    }

    {
      Id = "WorldUpgradeTaverna"
      DisplayName = "Rite of Social Solidarity"
      Description = "Restore the {$Keywords.Taverna}, where Shades and others rest and recover. Grants {#UpgradeFormatDark}+1{#Prev}{!Icons.SuperGiftPointsIcon}."
    }
    {
      Id = "WorldUpgradeTaverna_Flavor"
      Description = "After the House of Hades fell, those loyal to the Underworld King struggled to keep their spirits high."
    }
    {
      Id = "WorldUpgradeBathHouse"
      DisplayName = "Rite of Vapor-Cleansing"
      Description = "Restore the {$Keywords.HotSprings}, so they may be used {#ItalicFormat}(min. two guests at a time){#Prev}. Grants {#UpgradeFormatDark}+1{#Prev}{!Icons.GiftPointsRareIcon}."
    }
    {
      Id = "WorldUpgradeBathHouse_Flavor"
      Description = "The roiling and neglected waters of the springs draw heat from the River Phlegethon somewhere below."
    }
    {
      Id = "WorldUpgradeFishingPoint"
      DisplayName = "Rite of River-Fording"
      Description = "Restore the {$Keywords.FishingPier}, so it may be used {#ItalicFormat}(min. two guests at a time){#Prev}. Grants {#UpgradeFormatDark}+1{#Prev}{!Icons.GiftPointsEpicIcon}."
    }
    {
      Id = "WorldUpgradeFishingPoint_Flavor"
      Description = "It was an ill portent when the River Cocytus flooded, and the pier was sealed off in all due haste."
    }
    {
      Id = "CharFates"
      DisplayName = "Three Fates"
      Description = "Hidden daughters of {$Keywords.CharNyx}; each accidental bit of chance is likely their deliberate intent."
    }
    {
      Id = "CharNyx"
      DisplayName = "Nyx"
      Description = "Night Incarnate, by whose will and power much of the Underworld endures."
    }
    {
      Id = "CharHades"
      DisplayName = "Hades"
      Description = "The god of the dead, appointed by the Fates themselves to rule the Underworld."
    }
    {
      Id = "CharSelene"
      DisplayName = "Selene"
      Description = "The Moon Incarnate, who rides silently across the night sky, observing all."
    }
    {
      Id = "CharMoros"
      DisplayName = "Moros"
      Description = "Doom Incarnate, a feared son of {$Keywords.CharNyx}, and emissary-guardian of the Three Fates."
    }
    {
      Id = "CharCharon"
      DisplayName = "Charon"
      Description = "The feared Boatman of the River Styx serves the Underworld in his own way."
    }
    {
      Id = "CharChronos"
      DisplayName = "Chronos"
      Description = "The Titan of Time usurped the House of Hades in his plans for conquest."
    }
    {
      Id = "CharTyphon"
      DisplayName = "Typhon"
      Description = "The massive Father of All Monsters is worse than all his brood combined."
    }
    {
      Id = "CharOdysseus"
      DisplayName = "Odysseus"
      Description = "The Great Tactician, renowned for his wiles and daring escapes during his mortal days."
    }
    {
      Id = "CharIcarus"
      DisplayName = "Icarus"
      Description = "The Shade of the son and the apprentice of the greatest mortal artisan that ever lived."
    }
    {
      Id = "CharSkelly"
      DisplayName = "Schelemeus"
      Description = "The Crossroads training master once held a position of honor in the House of Hades."
    }
    {
      Id = "CharNemesis"
      DisplayName = "Nemesis"
      Description = "Retribution Incarnate, feared daughter of {$Keywords.CharNyx}, and sentry of the Crossroads."
    }
    {
      Id = "CharEris"
      DisplayName = "Eris"
      Description = "Strife Incarnate, the incendiary youngest daughter of {$Keywords.CharNyx}; uncontrollable."
    }
    {
      Id = "CharChaos"
      DisplayName = "Chaos"
      Description = "The sole being that gave rise to the primordial forces that still control this world."
    }
    {
      Id = "CharNarcissus"
      DisplayName = "Narcissus"
      Description = "His vanity wrought upon him a curse to stare forever at his own beautiful reflection."
    }
    {
      Id = "CharDora"
      DisplayName = "Dora"
      Description = "She drifts through the afterlife oblivious of others, even her past self."
    }
    {
      Id = "CharArachne"
      DisplayName = "Arachne"
      Description = "Her pride in her craft, though not unfounded, provoked the gods to cut her down to size."
    }
    {
      Id = "WorldUpgradeMorosUnlock"
      DisplayName = "Doomed Beckoning"
      Description = "Beseech {$Keywords.CharMoros} to reappear, in accordance with the will of the {$Keywords.CharFates}."
    }
    {
      Id = "WorldUpgradeMorosUnlock_Flavor"
      Description = "The Three Fates believe there is more for their brother to do, now that their List is delivered."
    }

    {
      Id = "WorldUpgradeErisTrashPickup"
      DisplayName = "Greater Removal of Rubbish"
      Description = "Make it so whenever you collect {!Icons.TrashPointsIcon}, you automatically collect the rest in the vicinity."
    }
    {
      Id = "WorldUpgradeErisTrashPickup_Flavor"
      Description = "The detrimental effects of Strife can never be entirely undone, but can be mitigated in various ways."
    }

    {
      Id = "WorldUpgradeBadgeSeller"
      DisplayName = "Long Arm of the Unseen"
      Description = "Proclaim this encampment's notoriety throughout the realms by donating {!Icons.CosmeticsPointsIcon} to the {$Keywords.Bartender}."
    }
    {
      Id = "WorldUpgradeBadgeSeller_Flavor"
      Description = "The deepest shadows are far from invisible and induce the greatest fear."
    }

    {
      Id = "WorldUpgradeNarcissusWaters"
      DisplayName = "Purification of Crystal Clarity"
      Description = "Restore the waters surrounding {$Keywords.CharNarcissus}, so that he may carry on fawning over himself."
    }
    {
      Id = "WorldUpgradeNarcissusWaters_Flavor"
      Description = "If to love oneself to such an extent truly is a curse, then those thusly cursed perhaps are the fortunate ones."
    }

    {
      Id = "WorldUpgradeMedeaTears"
      DisplayName = "Essence of Sorrow"
      Description = "Vaporize {!Icons.MixerHBoss} to their purest form, for use in some sort of concoction by the Witch of Shadows."
    }
    {
      Id = "WorldUpgradeMedeaTears_Flavor"
      InheritFrom = "MedeaPoints_Flavor"
    }

    {
      Id = "WorldUpgradeDoraMemory"
      DisplayName = "Return of Latent Memories"
      Description = "Compel the Shade called {$Keywords.CharDora} to remember something about her long-forgotten mortal days."
    }
    {
      Id = "WorldUpgradeDoraMemory_Flavor"
      Description = "One's memory can deceive, warping the record of reality to suit the mind's whims; restoring it is delicate work."
    }

    {
      Id = "WorldUpgradeTimeStop"
      DisplayName = "Dissolution of Time"
      Description = "Suppress the ability for {$Keywords.CharChronos} to reconstitute himself night after night."
    }
    {
      Id = "WorldUpgradeTimeStop_Flavor"
      Description = "It is said that Time cannot be stopped; but many such assertions are not always strictly true."
    }
    {
      Id = "WorldUpgradePauseChronosFight"
      DisplayName = "Power to Pause and Reflect"
      Description = "Suppress the ability for {$Keywords.CharChronos} to prevent you from pausing your {$MetaUpgradeData.BossDifficultyShrineUpgrade.Name} confrontations."
    }
    {
      Id = "WorldUpgradePauseChronosFight_Flavor"
      Description = "Conscious beings can never fully grasp all facets of their nature; not even the master and incarnate of Time itself."
    }

    {
      Id = "WorldUpgradeTimeSlowChronosFight"
      DisplayName = "Temporal Fluctuation"
      Description = "Remove immunity from {$Keywords.CharChronos} to time-altering effects such as the {$Keywords.Spell} of {$TraitData.SpellTimeSlowTrait.Name}."
    }
    {
      Id = "WorldUpgradeTimeSlowChronosFight_Flavor"
      Description = "Time marches ever forward, yet perception of its passage is susceptible to certain influence."
    }

    {
      Id = "WorldUpgradeStormStop"
      DisplayName = "Disintegration of Monstrosity"
      Description = "Turn the boundless strength and rage of {$Keywords.CharTyphon} against him when he is weakened."
    }
    {
      Id = "WorldUpgradeStormStop_Flavor"
      Description = "With sufficiently powerful reagents and intent, even immortality can be undone."
    }

    {
      Id = "WorldUpgradeSkellyHealth"
      DisplayName = "Augmentation of Bone Density"
      Description = "Significantly increase how much damage {$Keywords.CharSkelly} can take before falling to pieces."
    }
    {
      Id = "WorldUpgradeSkellyHealth_Flavor"
      Description = "Calcified remains that are animated not by muscle and sinew but by supernatural means can be likewise reinforced."
    }

    {
      Id = "WorldUpgradePostBossGiftRack"
      DisplayName = "Kindred Keepsakes"
      Description = "Manifest your collection of {$Keywords.Keepsakes} in the spaces separating each {$Keywords.Biome}."
    }
    {
      Id = "WorldUpgradePostBossGiftRack_Flavor"
      Description = "To keep those dear to you in your heart is to have the strength to press on."
    }
    {
      Id = "WorldUpgradeDoubleAdvanceKeepsakes"
      DisplayName = "Quickening of Sentimental Value"
      Description = "Cause your equipped {$Keywords.Keepsakes} to reach the next rank {#UpgradeFormatDark}{$WorldUpgradeData.WorldUpgradeDoubleAdvanceKeepsakes.BonusRate:F} {#Prev}faster than before."
    }
    {
      Id = "WorldUpgradeDoubleAdvanceKeepsakes_Flavor"
      Description = "The bond between comrades may grow stronger with time and, on occasion, even with distance."
    }
    {
      Id = "WorldUpgradeBountyBoard"
      DisplayName = "Abyssal Insight"
      Description = "Activate the {$Keywords.BountyBoard} in the Training Grounds, then attempt its {$Keywords.PackagedBounties} for {!Icons.Mixer5CommonIcon}."
    }
    {
      Id = "WorldUpgradeBountyBoard_Flavor"
      Description = "It is opaque, and yet the experienced witch knows there is a way to peer within."
    }
    {
      Id = "WorldUpgradeBountyBoardRepeat"
      DisplayName = "Abyssal Reflection"
      Description = "Gain the ability to re-attempt cleared {$Keywords.PackagedBounties} at the {$Keywords.BountyBoard} for rewards of {!Icons.MetaCurrencyIcon}."
    }
    {
      Id = "WorldUpgradeBountyBoardRepeat_Flavor"
      Description = "Creation is a process as well as a result; completion is an opportunity to start anew."
    }    

    {
      Id = "WorldUpgradeWakeHypnos"
      DisplayName = "End to Deepest Slumber"
      Description = "Attempt to stir {$Keywords.CharHypnos} from his dormant state. Grants {#UpgradeFormatDark}+1{#Prev}{!Icons.HypnosPointsIcon}."
    }
    {
      Id = "WorldUpgradeWakeHypnos_Flavor"
      Description = "Most slumber ends quickly and naturally, but a rare variety requires special care."
    }
    {
      Id = "CharHypnos"
      DisplayName = "Hypnos"
      Description = "Sleep Incarnate, a son of {$Keywords.CharNyx}; he was fast asleep when the House of Hades fell."
    }
    {
      Id = "WorldUpgradeWakeHypnosT2"
      DisplayName = "End to Dearest Slumber"
      Description = "Reach deep into the psyche of {$Keywords.CharHypnos} to perhaps stir him from his dormant state. Grants {#UpgradeFormatDark}+1{#Prev}{!Icons.HypnosPointsIcon}."
    }
    {
      Id = "WorldUpgradeWakeHypnosT2_Flavor"
      Description = "In the rarest cases of indefinite slumber, only the mind of the subject holds the key to its awakening."
    }

    {
      Id = "WorldUpgradeReviveIcarus"
      DisplayName = "Night Life for the Dead"
      Description = "Attempt to restore {$Keywords.CharIcarus} to his living form, temporarily. Grants {#UpgradeFormatDark}+1{#Prev}{!Icons.IcarusPointsIcon}."
    }
    {
      Id = "WorldUpgradeReviveIcarus_Flavor"
      Description = "Only the most experienced necromancers dare attempt turn Shades whole again as though they yet lived."
    }

    {
      Id = "WorldUpgradeRelationshipBar"
      DisplayName = "Empath's Intuition"
      Description = "Update the {$Keywords.Codex} with insight into relationship status with one's acquaintances."
    }
    {
      Id = "WorldUpgradeRelationshipBar_Flavor"
      Description = "If not even the deathless gods can fully understand the needs of others, what hope do mortals have?"
    }

    {
      Id = "WorldUpgradeWellShops"
      DisplayName = "Rise of Stygian Wells"
      Description = "Cause {$Keywords.RoomPlural} in the Underworld to sometimes contain a {$Keywords.WellShop}."
    }
    {
      Id = "WorldUpgradeWellShops_Flavor"
      Description = "The Titan of Time called for all the Boatman's wells to be buried, as they could not be destroyed."
    }
    {
      Id = "WorldUpgradePostBossWellShops"
      DisplayName = "Surge of Stygian Wells"
      Description = "Cause a {$Keywords.WellShop} to appear in the space between each Underworld {$Keywords.Biome}."
    }
    {
      Id = "WorldUpgradePostBossWellShops_Flavor"
      Description = "The Boatman's wells once were available only to those with the authority to cross the Underworld unfettered."
    }

    {
      Id = "WorldUpgradeRestoreSellTraitShop"
      DisplayName = "Revival of a Desecrating Pool"
      Description = "Reactivate the dormant {$Keywords.SellTraitShop} in the pathway leading to {$Keywords.BiomeI}."
    }
    {
      Id = "WorldUpgradeRestoreSellTraitShop_Flavor"
      Description = "Eventually fell into disrepair after the House of Hades Security Specialist ceased putting it to use."
    }

    {
      Id = "WorldUpgradePostBossSellTraitShops"
      DisplayName = "Surge of Desecrating Pools"
      Description = "Cause a {$Keywords.SellTraitShop} to always appear in the space between each Underworld {$Keywords.Biome}."
    }
    {
      Id = "WorldUpgradePostBossSellTraitShops_Flavor"
      Description = "The Underworld was never in the jurisdiction of the Olympian gods, and their influence was to be washed away."
    }

    {
      Id = "WorldUpgradeBreakableValue1"
      DisplayName = "Propensity Toward Gold"
      Description = "Reveal {#BoldFormatGraftDark}Golden Urns {#Prev}in various {$Keywords.RoomPlural}, which yield up to {#UpgradeFormatDark}+{$ObstacleData.BaseBreakable.BreakableValueOptions[1].MoneyDropOnDeath.MaxValue}{#Prev}{!Icons.Currency} once shattered."
    }
    {
      Id = "WorldUpgradeBreakableValue1_Flavor"
      Description = "Promises of unimaginable riches were enough to swell the ranks of the Titan's legions."
    }

    {
      Id = "WorldUpgradeSurfaceShops"
      DisplayName = "Rush of Fresh Air"
      Description = "Cause {$Keywords.RoomPlural} on the surface to sometimes contain a {$Keywords.SurfaceShop}."
    }
    {
      Id = "WorldUpgradeSurfaceShops_Flavor"
      Description = "A quick prayer to the god of swiftness can make all the difference in one's travels."
    }
    {
      Id = "WorldUpgradePostBossSurfaceShops"
      DisplayName = "Surge of Fresh Air"
      Description = "Cause a {$Keywords.SurfaceShop} to appear in the space between each Surface {$Keywords.Biome}."
    }
    {
      Id = "WorldUpgradePostBossSurfaceShops_Flavor"
      Description = "When traveling long distances, there are ways to make certain the god of swiftness takes notice."
    }

    {
      Id = "WorldUpgradeChallengeSwitches1"
      DisplayName = "Exhumed Troves"
      Description = "Cause {$Keywords.RoomPlural} throughout the Underworld to sometimes contain an {$Keywords.ChallengeSwitch}."
    }
    {
      Id = "WorldUpgradeChallengeSwitches1_Flavor"
      Description = "Riches pilfered from the Underworld are now in the Titan's hold, though his grip may be loosened."
    }

    {
      Id = "WorldUpgradeChallengeSwitchesSurface1"
      DisplayName = "Arisen Troves"
      Description = "Cause {$Keywords.RoomPlural} upon the Surface to sometimes contain an {$Keywords.ChallengeSwitch}."
    }
    {
      Id = "WorldUpgradeChallengeSwitchesSurface1_Flavor"
      Description = "A reminder to surface-dwellers that when gods and Titans are at war, the world entire pays the price."
    }

    {
      Id = "WorldUpgradeChallengeSwitchesExtra1"
      DisplayName = "Eyes of Night and Darkness"
      Description = "Cause {$Keywords.RoomPlural} to sometimes contain a {$Keywords.EliteChallengeSwitch} or an {$Keywords.PerfectClearChallengeSwitch}."
    }
    {
      Id = "WorldUpgradeChallengeSwitchesExtra1_Flavor"
      Description = "Long did the Unseen bide their time, but now the time for shadowplay is ended."
    }

    {
      Id = "WorldUpgradeMetaRewardStands"
      DisplayName = "Bounties of the Infinite Abyss"
      Description = "Cause {$Keywords.RoomPlural} in {$Keywords.BiomeI} or {$Keywords.BiomeQ} to sometimes contain a {$Keywords.ShrinePointReward}."
    }
    {
      Id = "WorldUpgradeMetaRewardStands_Flavor"
      Description = "Those in service to the will of Night serve not for sake of reward but for the deed itself; but treasure can be nice."
    }

    {
      Id = "WorldUpgradeMetaCardPointsCommonRunProgress"
      DisplayName = "Ashen Memories of Life"
      Description = "Whenever you claim rewards of {!Icons.MetaCardPointsCommonIcon}, gain {#UpgradeFormatDark}+{$ConsumableData.MetaCardPointsCommonDrop.RunProgress.PropertyChanges.AddMaxHealth}{!Icons.HealthUp}{#Prev}."
    }
    {
      Id = "WorldUpgradeMetaCardPointsCommonRunProgress_Flavor"
      Description = "Never again can ashes become that which they used to be, though faint traces of their past sometimes remain."
    }
    {
      Id = "WorldUpgradeMetaCurrencyRunProgress"
      DisplayName = "Bones of Arcane Wisdom"
      Description = "Whenever you claim rewards of {!Icons.MetaCurrencyIcon}, gain {#UpgradeFormatDark}+{$ConsumableData.MetaCurrencyDrop.RunProgress.PropertyChanges.AddMaxMana}{!Icons.ManaUp}{#Prev}."
    }
    {
      Id = "WorldUpgradeMetaCurrencyRunProgress_Flavor"
      Description = "Bones often are the sole remaining trace of a thing; of where its spirit used to be."
    }
    {
      Id = "WorldUpgradeGiftDropRunProgress"
      DisplayName = "Nectar of Godly Savor"
      Description = "Whenever you claim rewards of {!Icons.GiftPointsIcon}, gain {#UpgradeFormatDark}+1{#Prev}{!Icons.RandomPom}."
    }
    {
      Id = "WorldUpgradeGiftDropRunProgress_Flavor"
      Description = "The gods themselves use this drink to strengthen their connections with each other."
    }

    {
      Id = "WorldUpgradeErebusReprieve"
      DisplayName = "Woodsy Lifespring"
      Description = "Reveal a hidden glade in {$Keywords.BiomeF}, where you may restore some {!Icons.HealthRestoreHome} amid the gloom."
    }
    {
      Id = "WorldUpgradeErebusReprieve_Flavor"
      Description = "Infused with moonlight, some fresh water seeps from high above down into Erebus."
    }
    {
      Id = "WorldUpgradeOceanusReprieve"
      DisplayName = "Briny Lifespring"
      Description = "Reveal a hidden chamber in {$Keywords.BiomeG}, where you may restore some {!Icons.HealthRestoreHome} in peace."
    }
    {
      Id = "WorldUpgradeOceanusReprieve_Flavor"
      Description = "A purified spring can be difficult to locate in the depths of the sea."
    }
    {
      Id = "WorldUpgradeTartarusReprieve"
      DisplayName = "Golden Lifespring"
      Description = "Reveal a hidden chamber in {$Keywords.BiomeI}, where you may restore some {!Icons.HealthRestoreHome} and elude your foes."
    }
    {
      Id = "WorldUpgradeTartarusReprieve_Flavor"
      Description = "Among the countless interlocking chambers of Tartarus, few provided any sense of calm."
    }
    {
      Id = "WorldUpgradeThessalyReprieve"
      DisplayName = "Sandy Lifespring"
      Description = "Reveal a hidden isle in the {$Keywords.BiomeO}, where you may restore some {!Icons.HealthRestoreHome} amid the tumult."
    }
    {
      Id = "WorldUpgradeThessalyReprieve_Flavor"
      Description = "Once an enchanted glade, this bit of land survived when the surrounding countryside split in twain."
    }
    {
      Id = "WorldUpgradeOlympusReprieve"
      DisplayName = "Frozen Lifespring"
      Description = "Reveal a hidden chamber within {$Keywords.BiomeP}, where you may restore some {!Icons.HealthRestoreHome} in quiet solitude."
    }
    {
      Id = "WorldUpgradeOlympusReprieve_Flavor"
      Description = "Life-giving waters flow through the mountain, gathered in hidden aqueducts forgotten even by the gods."
    }

    {
      Id = "WorldUpgradeOlympusStatues"
      DisplayName = "Rage of the Elements"
      Description = "Re-energize the gods' statues on {$Keywords.BiomeP}, which you may then use to repel your foes."
    }
    {
      Id = "WorldUpgradeOlympusStatues_Flavor"
      Description = "Those who rule the world can turn the very essence of reality against their foes."
    }

    {
      Id = "WorldUpgradeFountainUpgrade1"
      DisplayName = "Cleansing of Fountain-Waters"
      Description = "Enhance {$Keywords.FountainPlural} so that they restore {#UpgradeFormatDark}{$ObstacleData.HealthFountain.SetupEvents.1.DisplayValue:P}{#Prev}{!Icons.HealthRestoreHome}."
    }
    {
      Id = "WorldUpgradeFountainUpgrade1_Flavor"
      Description = "Water is a source of life, even for immortals; yet must freely flow to achieve its potential."
    }
    {
      Id = "WorldUpgradeFountainUpgrade2"
      DisplayName = "Purification of Fountain-Waters"
      Description = "Enhance {$Keywords.FountainPlural} so that they restore an additional {#UpgradeFormatDark}{$ObstacleData.HealthFountain.SetupEvents.2.DisplayValue:P}{#Prev}{!Icons.HealthRestoreHome}."
    }
    {
      Id = "WorldUpgradeFountainUpgrade2_Flavor"
      Description = "Eliminating any traces of stagnation and contamination from water fulfills its life-giving purpose."
    }

    {
      Id = "WorldUpgradeEphyraZoomOut"
      DisplayName = "Summoning a Colony of Bats"
      Description = "Make use of {$Keywords.ZoomOutObject} in their cages around the {$Keywords.BiomeN}, to better orient yourself there."
    }
    {
      Id = "WorldUpgradeEphyraZoomOut_Flavor"
      Description = "These bats were not freed from their cages, so much as forced to flee their homes."
    }

    {
      Id = "WorldUpgradeFieldsRewardFinder"
      DisplayName = "Reviving a Mournful Husk"
      Description = "Make use of {$Keywords.RewardFinderObject} in the {$Keywords.BiomeH}, to better orient yourself there."
    }
    {
      Id = "WorldUpgradeFieldsRewardFinder_Flavor"
      Description = "Saplings of surface origin that once shone like gold, and instilled a clarity of purpose."
    }

    {
      Id = "WorldUpgradeErebusSafeZones"
      DisplayName = "Circles of Protection"
      Description = "Activate {$Keywords.SafeZone} found throughout {$Keywords.BiomeF}, to then use to your advantage."
    }
    {
      Id = "WorldUpgradeErebusSafeZones_Flavor"
      Description = "A shape as perfect as it is inconspicuous, and can ward off all that is not meant to be within."
    }

    {
      Id = "WorldUpgradeSafeZoneSpellCharge"
      DisplayName = "Circles of the Moon"
      Description = "Whenever you activate {$Keywords.SafeZone}, fully recharge your {$Keywords.Spell} if it is not ready."
    }
    {
      Id = "WorldUpgradeSafeZoneSpellCharge_Flavor"
      Description = "On some nights, the Moon forms a perfect circle in the sky. That very shape is key to a strong connection."
    }


    {
      Id = "WorldUpgradeShadeMercs"
      DisplayName = "Necromantic Influence"
      Description = "Gain the ability to {$Keywords.Sprint} into any {$Keywords.ShadeMerc} you encounter to turn them against your foes."
    }
    {
      Id = "WorldUpgradeShadeMercs_Flavor"
      Description = "The bloodline of the Underworld's true King and Queen as yet commands authority."
    }

    {
      Id = "WorldUpgradeUnusedWeaponBonus"
      DisplayName = "Gathering of Ancient Bones"
      Description = "Cause a random {$Keywords.Weapon} each night to have {$TraitData.UnusedWeaponBonusTrait.Name}, yielding {!Icons.MetaCurrencyIcon} in each {$Keywords.RoomAlt}."
    }
    {
      Id = "WorldUpgradeUnusedWeaponBonus_Flavor"
      Description = "Each night, one of the Nocturnal Arms nearby the {$Keywords.WeaponShop} shall take on a deathlike pallor."
    }
    {
      Id = "WorldUpgradeUnusedWeaponBonusT2"
      DisplayName = "Gathering of Subterranean Riches"
      Description = "Enhance {$Keywords.UnusedWeaponBonus} to also unearth {!Icons.GemPointsIcon} whenever you vanquish {$Keywords.BossPlural}."
    }
    {
      Id = "WorldUpgradeUnusedWeaponBonusT2_Flavor"
      Description = "Few can access the vast and hidden wealth of the Underworld, though a certain birthright helps."
    }

    {
      Id = "WorldUpgradeGarden"
      DisplayName = "Flourishing Soil"
      Description = "Create {#UpgradeFormatDark}{$WorldUpgradeData.WorldUpgradeGarden.NumPlots} {#Prev}{$Keywords.GardenPlots}, for growing {!Icons.PlantFNightshadeIcon} and other plants. Grants {#UpgradeFormatDark}+1{#Prev}{!Icons.PlantFNightshadeSeedIcon}."
    }
    {
      Id = "WorldUpgradeGarden_Flavor"
      Description = "The bounties of Gaia are hers to give or to withhold; asking nicely couldn't hurt."
    }
    {
      Id = "WorldUpgradeGardenT2"
      DisplayName = "Rich Soil"
      Description = "Create {#UpgradeFormatDark}+{$WorldUpgradeData.WorldUpgradeGardenT2.NumPlots} {#Prev}{$Keywords.GardenPlots} in the space next to the others near the grove."
    }
    {
      Id = "WorldUpgradeGardenT2_Flavor"
      Description = "From Earth herself, the miracle of everlasting life may flourish, climate permitting."
    }
    {
      Id = "WorldUpgradeGardenT3"
      DisplayName = "Verdant Soil"
      Description = "Create {#UpgradeFormatDark}+{$WorldUpgradeData.WorldUpgradeGardenT3.NumPlots} {#Prev}{$Keywords.GardenPlots} in the remaining space next to the others near the grove."
    }
    {
      Id = "WorldUpgradeGardenT3_Flavor"
      Description = "The support of a gardener often is the difference between a thriving plant and a mere husk."
    }
    {
      Id = "WorldUpgradeHarvestUpgrade"
      DisplayName = "Observance of Gaia's Secrets"
      Description = "Gain {#BoldFormatGraftDark}{$WorldUpgradeData.WorldUpgradeHarvestUpgrade.SeedChancePercent}% {#Prev}chance to find {#UpgradeFormatDark}+1 Seed {#Prev}for whatever you gather from {$Keywords.GardenPlots} whenever you harvest."
    }
    {
      Id = "WorldUpgradeHarvestUpgrade_Flavor"
      Description = "Like most other living things, plants and funguses have a desire to persist above all else."
    }
    {
      Id = "WorldUpgradeGardenHarvestAll"
      DisplayName = "Green Hand of Gaia"
      Description = "Improve gathering from {$Keywords.GardenPlots} so that you harvest all flourished {$Keywords.GardenPlots} at once."
    }
    {
      Id = "WorldUpgradeGardenHarvestAll_Flavor"
      Description = "Those sufficiently experienced may draw greenery from the Earth much like water from a well."
    }
    {
      Id = "WorldUpgradeGardenMultiPlant"
      DisplayName = "Greater Sowing of Gardens"
      Description = "Gain the ability to plant multiples of the same type of seed in all available {$Keywords.GardenPlots} at once."
    }
    {
      Id = "WorldUpgradeGardenMultiPlant_Flavor"
      Description = "Mortal farmers tend to sow new plant life in vast fields, though there are simpler, even more ancient ways."
    }
    {
      Id = "WorldUpgradeAutoHarvestOnExit"
      DisplayName = "Greatest Gift of Gaia"
      Description = "Gain the power to automatically harvest any resources in each {$Keywords.RoomAlt} whenever you exit."
    }
    {
      Id = "WorldUpgradeAutoHarvestOnExit_Flavor"
      Description = "Very few possess such a strong connection to the Earth that it would yield all its riches willingly."
    }
    {
      Id = "WorldUpgradePinning"
      DisplayName = "Forget-Me-Not"
      Description = "Improve your memory. Press {IP} on recipes for at-a-glance reminders for which resources you need."
    }
    {
      Id = "WorldUpgradePinning_Flavor"
      Description = "While witchcraft often demands careful memorization, there are tools as well as spells to aid with this."
    }

    {
      Id = "WorldUpgradePinningBoons"
      DisplayName = "Path to Desired Blessings"
      Description = "While viewing {$Keywords.GodBoonPlural} in the {$Keywords.Codex}, press {IP} to track any offering requirements."
    }
    {
      Id = "WorldUpgradePinningBoons_Flavor"
      Description = "Blessings are fickle by nature, much like the gods themselves; but so too do they have their patterns."
    }

    {
      Id = "WorldUpgradeKeepsakeSaveFirst"
      DisplayName = "Favored of All Keepsakes"
      Description = "Prioritize a {$Keywords.KeepsakeAlt} to re-equip it automatically whenever you return to the Crossroads."
    }
    {
      Id = "WorldUpgradeKeepsakeSaveFirst_Flavor"
      Description = "To draw the power from an artifact, it can be necessary to focus on it, until that process becomes second nature."
    }
    {
      Id = "WorldUpgradeBoonList"
      DisplayName = "Insight into Offerings"
      Description = "Reveal a complete list of each Olympian's {$Keywords.GodBoonPlural} {#ItalicLightFormat}(among other details) {#Prev}in the {$Keywords.Codex}."
    }
    {
      Id = "WorldUpgradeBoonList_Flavor"
      Description = "Through connection to the gods may come a greater depth of knowledge of their power."
    }
    {
      Id = "WorldUpgradeResourceFinder"
      DisplayName = "Reagent Sensing"
      Description = "Become alerted to valuable resources that may sometimes be found in any {$Keywords.RoomAlt}."
    }
    {
      Id = "WorldUpgradeResourceFinder_Flavor"
      Description = "The experienced witch can quickly spot useful reagents most would readily ignore."
    }

    {
      Id = "WorldUpgradeBossDifficultyT2"
      DisplayName = "Rivals of Depth and Sea"
      Description = "Reveal the next rank of the {$MetaUpgradeData.BossDifficultyShrineUpgrade.Name} in the {$Keywords.Shrine} to face stronger {$Keywords.BossPlural}."
    }
    {
      Id = "WorldUpgradeBossDifficultyT2_Flavor"
      Description = "On the darkest nights, our greatest fears may become manifest, lest we assert control."
    }
    {
      Id = "WorldUpgradeBossDifficultyT3"
      DisplayName = "Rivals of Plain and Peak"
      Description = "Reveal the third rank of the {$MetaUpgradeData.BossDifficultyShrineUpgrade.Name} in the {$Keywords.Shrine} to face stronger {$Keywords.BossPlural}."
    }
    {
      Id = "WorldUpgradeBossDifficultyT3_Flavor"
      Description = "Fear grows in the dark, but so too can courage; there, limits are tested, broken, and surpassed."
    }
    {
      Id = "WorldUpgradeBossDifficultyT4"
      DisplayName = "Rivals of Old and Rot"
      Description = "Reveal the final rank of the {$MetaUpgradeData.BossDifficultyShrineUpgrade.Name} in the {$Keywords.Shrine} to face stronger {$Keywords.BossPlural}."
    }
    {
      Id = "WorldUpgradeBossDifficultyT4_Flavor"
      Description = "Primordial forces in this world are so ancient that their own incalculable power may be even greater than they recall."
    }

    /* Repeatable Spells / Cooking Recipes / Alchemy */
    {
      Id = "WorldUpgradeMixerShadow"
      DisplayName = "Shadow Extraction"
      Description = "{$WorldUpgradeData.WorldUpgradeMixerShadow.CookTime}{!Icons.Clock} {$Keywords.RecipeSpell}: Manifest {#UpgradeFormatDark}+{$WorldUpgradeData.WorldUpgradeMixerShadow.OnActivateFinishedFunctionArgs.ResourceAmount}{#Prev}{!Icons.MixerShadow}, used for powerful incantations."
    }
    {
      Id = "WorldUpgradeMixerShadow_Flavor"
      Description = "There are the shadows that we cast, there are shadows that dance in the candlelight, and then there is this."
    }
    {
      Id = "WorldUpgradeNectar"
      DisplayName = "Sweet Nectar"
      Description = "{$WorldUpgradeData.WorldUpgradeNectar.CookTime}{!Icons.Clock} {$Keywords.RecipeSpell}: Brew {#UpgradeFormatDark}+{$WorldUpgradeData.WorldUpgradeNectar.OnActivateFinishedFunctionArgs.ResourceAmount}{#Prev}{!Icons.GiftPointsIcon}, a delectable substance suitable for gifting."
    }
    {
      Id = "WorldUpgradeNectar_Flavor"
      Description = "The very best kind can only be brewed in a particular spot on Olympus, but a decent substitute can be had elsewhere."
    }
    {
      Id = "WorldUpgradeAmbrosia"
      DisplayName = "Shimmering Ambrosia"
      Description = "{$WorldUpgradeData.WorldUpgradeAmbrosia.CookTime}{!Icons.Clock} {$Keywords.RecipeSpell}: Brew {#UpgradeFormatDark}+{$WorldUpgradeData.WorldUpgradeAmbrosia.OnActivateFinishedFunctionArgs.ResourceAmount}{#Prev}{!Icons.SuperGiftPointsIcon}, a rare delicacy suitable for gifting."
    }
    {
      Id = "WorldUpgradeAmbrosia_Flavor"
      Description = "Demeter's old recipe features the complex and varied flavor profile of the Olympian original."
    }
    {
      Id = "WorldUpgradeCardUpgradePoints2"
      DisplayName = "Moonlit Essence from Stars"
      Description = "{$WorldUpgradeData.WorldUpgradeCardUpgradePoints2.CookTime}{!Icons.Clock} {$Keywords.RecipeSpell}: Brew {#UpgradeFormatDark}+{$WorldUpgradeData.WorldUpgradeCardUpgradePoints2.OnActivateFinishedFunctionArgs.ResourceAmount}{#Prev}{!Icons.CardUpgradePointsIcon}, with which to upgrade {$Keywords.CardPlural}."
    }
    {
      Id = "WorldUpgradeCardUpgradePoints2_Flavor"
      Description = "Faint flickers of the first light of creation yet retain their original potential."
    }
    {
      Id = "WorldUpgradeFamiliarPoints"
      DisplayName = "Beast-Loved Morsel"
      Description = "{$WorldUpgradeData.WorldUpgradeFamiliarPoints.CookTime}{!Icons.Clock} {$Keywords.RecipeSpell}: Cook {#UpgradeFormatDark}+{$WorldUpgradeData.WorldUpgradeFamiliarPoints.OnActivateFinishedFunctionArgs.ResourceAmount}{#Prev}{!Icons.FamiliarPointsIcon}, with which to compel {$Keywords.FamiliarPlural}."
    }
    {
      Id = "WorldUpgradeFamiliarPoints_Flavor"
      Description = "An acquired taste even for beasts of particular refinement, ensuring only the strongest, purest bonds."
    }

