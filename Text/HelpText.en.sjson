    /* Ghost Data / Ghost Eavesdrop */
    {
      Id = "UseGhostInspectPoint"
      DisplayName = "{SI} Salute"
    }
    {
      Id = "UseGhostRecruit"
      DisplayName = "{SI} Salute"
    }

    {
      Id = "Ghost_Agent01"
      DisplayName = "dying wish: {#CauseOfDeathFormat}glory"
      Description = "Justice for the Underworld's rightful King and Queen! And for you, Your Grace!"
    }
    {
      Id = "Ghost_Agent02"
      DisplayName = "cause of death: {#CauseOfDeathFormat}backstabbing"
      Description = "Our trust in the Witch of the Crossroads is unwavering! (Well mine wavers a bit...)"
    }
    {
      Id = "Ghost_Agent03"
      DisplayName = "cause of death: {#CauseOfDeathFormat}spoiled meat"
      Description = "Death to Chronos, Princess! And may his be even less pleasant than mine!"
    }
    {
      Id = "Ghost_Agent04"
      DisplayName = "dying wish: {#CauseOfDeathFormat}adoration"
      Description = "She looked at me! When she saluted, she was looking right at me!"
    }
    {
      Id = "Ghost_Agent05"
      DisplayName = "dying wish: {#CauseOfDeathFormat}immortality"
      Description = "We stand ready to die for you, Princess! Again!"
    }
    {
      Id = "Ghost_Agent06"
      DisplayName = "cause of death: {#CauseOfDeathFormat}vermin"
      Description = "The Titan of Time can't be killed! Not even by Zeus and his brothers!"
    }
    {
      Id = "Ghost_Agent07"
      DisplayName = "cause of death: {#CauseOfDeathFormat}pestilence"
      Description = "A pox upon the enemies of Hades! And whosoever angers you, milady!"
    }
    {
      Id = "Ghost_Agent08"
      DisplayName = "dying wish: {#CauseOfDeathFormat}feasting"
      Description = "Wish I could spar with Nemesis just once... the rest of you are total pushovers."
    }
    {
      Id = "Ghost_Agent09"
      DisplayName = "cause of death: {#CauseOfDeathFormat}curse"
      Description = "You have got to be joking. Do you have any idea who we're up against?"
    }
    {
      Id = "Ghost_Agent10"
      DisplayName = "cause of death: {#CauseOfDeathFormat}arrow"
      Description = "Most of us wouldn't even be here if not for the Olympians, you know..."
    }
    {
      Id = "Ghost_Agent11"
      DisplayName = "cause of death: {#CauseOfDeathFormat}falling"
      Description = "Do you have any idea how far down you have to go to get to Tartarus?"
    }
    {
      Id = "Ghost_Agent12"
      DisplayName = "cause of death: {#CauseOfDeathFormat}old age"
      Description = "Make Chronos pay for what he's done, Princess!"
    }
    {
      Id = "Ghost_Agent13"
      DisplayName = "dying wish: {#CauseOfDeathFormat}fame"
      Description = "I don't care what you say! I ought to be down in Elysium, not here!"
    }
    {
      Id = "Ghost_Agent14"
      DisplayName = "cause of death: {#CauseOfDeathFormat}charybdis"
      Description = "This takes me back to my days as a sailor... Master Odysseus remembers me, I'm sure!"
    }
    {
      Id = "Ghost_Agent15"
      DisplayName = "cause of death: {#CauseOfDeathFormat}fright"
      Description = "I am completely frozen with terror right now, I hope you know."
    }
    {
      Id = "Ghost_Agent16"
      DisplayName = "age of death: {#CauseOfDeathFormat}{$TempTextData.AgeOfDeath}"
      Description = "I got to say moonlight-guide-you to Artemis herself!!"
    }
    {
      Id = "Ghost_Agent17"
      DisplayName = "cause of death: {#CauseOfDeathFormat}snake bite"
      Description = "We've got Shades from all over the place turning up here lately!"
    }
    {
      Id = "Ghost_Agent18"
      DisplayName = "cause of death: {#CauseOfDeathFormat}poison"
      Description = "It's rather lively in the taverna, all things considered."
    }
    {
      Id = "Ghost_Agent19"
      DisplayName = "cause of death: {#CauseOfDeathFormat}indulgence"
      Description = "We are unworthy of your presence, Your Grace! At least, I am!"
    }
    {
      Id = "Ghost_Agent20"
      DisplayName = "cause of death: {#CauseOfDeathFormat}allergy"
      Description = "We just returned with our latest report for Master Odysseus! Please take care, Princess!"
    }
    {
      Id = "Ghost_Agent21"
      DisplayName = "cause of death: {#CauseOfDeathFormat}immolation"
      Description = "What I wouldn't give to see the splendor of Elysium again..."
    }
    {
      Id = "Ghost_Agent22"
      DisplayName = "cause of death: {#CauseOfDeathFormat}plague"
      Description = "Life so often could be miserable, but death hasn't been easy lately either."
    }
    {
      Id = "Ghost_Agent23"
      DisplayName = "cause of death: {#CauseOfDeathFormat}cyclops"
      Description = "I don't miss the surface. All my friends are here!"
    }
    {
      Id = "Ghost_Agent24"
      DisplayName = "cause of death: {#CauseOfDeathFormat}harpy"
      Description = "Is there really an entire fleet there sailing on Olympus?"
    }
    {
      Id = "Ghost_Agent25"
      DisplayName = "cause of death: {#CauseOfDeathFormat}python"
      Description = "Every single monster... they're all Typhon's children?"
    }
    {
      Id = "Ghost_Agent26"
      DisplayName = "cause of death: {#CauseOfDeathFormat}dracon"
      Description = "Don't know what's worse, between Typhon and the Titan of Time..."
    }
    {
      Id = "Ghost_Agent27"
      DisplayName = "dying wish: {#CauseOfDeathFormat}flying"
      Description = "Over there with the wings, isn't that the Daedalus kid?"
    }
    {
      Id = "Ghost_Agent28"
      DisplayName = "dying wish: {#CauseOfDeathFormat}peace"
      Description = "We really like what you've done with the place, Your Grace!"
    }
    {
      Id = "Ghost_Agent29"
      DisplayName = "from: {#CauseOfDeathFormat}thessaly"
      Description = "We can't clean up after Eris fast enough, Your Grace!"
    }
    {
      Id = "Ghost_Agent30"
      DisplayName = "from: {#CauseOfDeathFormat}ephyra"
      Description = "We salute you, O vanquisher of the Father of All Monsters!"
    }

    {
      Id = "Ghost_Recruit01"
      DisplayName = "cause of death: {#CauseOfDeathFormat}despair"
      Description = "I thought that I would miss the Fields more..."
    }
    {
      Id = "Ghost_Recruit02"
      DisplayName = "cause of death: {#CauseOfDeathFormat}betrayal"
      Description = "Are you certain it's all right for us to stay...?"
    }
    {
      Id = "Ghost_Recruit03"
      DisplayName = "dying wish: {#CauseOfDeathFormat}insight"
      Description = "How long I wallowed by the bank of the Styx..."
    }
    {
      Id = "Ghost_Recruit04"
      DisplayName = "dying wish: {#CauseOfDeathFormat}strength"
      Description = "I never would have left if not for you, Princess..."
    }
    {
      Id = "Ghost_Recruit05"
      DisplayName = "greatest regret: {#CauseOfDeathFormat}falsehood"
      Description = "It is difficult for me to believe any of this..."
    }
    {
      Id = "Ghost_Recruit06"
      DisplayName = "greatest regret: {#CauseOfDeathFormat}silence"
      Description = "We are grateful for your mercy, O Princess..."
    }

    {
      Id = "Ghost_Scout01"
      DisplayName = "dying wish: {#CauseOfDeathFormat}elysium"
      Description = "Apollo must be even better... he taught her, didn't he?"
    }
    {
      Id = "Ghost_Scout02"
      DisplayName = "dying wish: {#CauseOfDeathFormat}one last sunset"
      Description = "I could listen to her forever... I'd almost rather she shot me through the heart!"
    }
    {
      Id = "Ghost_Scout03"
      DisplayName = "dying wish: {#CauseOfDeathFormat}serenity"
      Description = "It can't be good that Strife herself is here... think she'd talk to us?"
    }
    {
      Id = "Ghost_Scout04"
      DisplayName = "dying wish: {#CauseOfDeathFormat}riches"
      Description = "Is it true about the Titan of Time? I can't believe it. I won't!"
    }
    {
      Id = "Ghost_Scout04a"
      DisplayName = "dying wish: {#CauseOfDeathFormat}rebirth"
      Description = "We knew you had it in you, Princess!! Most of us!"
    }
    {
      Id = "Ghost_Scout05"
      DisplayName = "dying wish: {#CauseOfDeathFormat}long life"
      Description = "What happened on Olympus? Did she really do it? She really did...!"
    }
    {
      Id = "Ghost_Scout05a"
      DisplayName = "dying wish: {#CauseOfDeathFormat}swim-lessons"
      Description = "The Father of All Monsters, vanquished! By our own Princess!!"
    }
    {
      Id = "Ghost_Scout06"
      DisplayName = "cause of death: {#CauseOfDeathFormat}fire"
      Description = "Prometheus did us no favors if you ask me!"
    }
    {
      Id = "Ghost_Scout07"
      DisplayName = "cause of death: {#CauseOfDeathFormat}lightning"
      Description = "Nobody move... Strife and Doom are both here..."
    }
    {
      Id = "Ghost_Scout08"
      DisplayName = "dying wish: {#CauseOfDeathFormat}one more bite"
      Description = "All hail Night's Champion!! We salute you!"
    }
    {
      Id = "Ghost_Scout09"
      DisplayName = "dying wish: {#CauseOfDeathFormat}sunshine"
      Description = "Rain certainly feels different when you're dead."
    }
    {
      Id = "Ghost_Scout10"
      DisplayName = "dying wish: {#CauseOfDeathFormat}oblivion"
      Description = "It's really her... and you as well, Princess!"
    }
    {
      Id = "Ghost_Scout10a"
      DisplayName = "dying wish: {#CauseOfDeathFormat}wings"
      Description = "I'm telling you, Apollo sings even better!"
    }
    {
      Id = "Ghost_Scout11"
      DisplayName = "dying wish: {#CauseOfDeathFormat}that song..."
      Description = "I cannot believe what used to be my ears..."
    }
    {
      Id = "Ghost_Scout11a"
      DisplayName = "cause of death: {#CauseOfDeathFormat}drowning"
      Description = "This was the last music I ever heard... isn't it great?!"
    }
    {
      Id = "Ghost_Ranger01"
      DisplayName = "dying wish: {#CauseOfDeathFormat}an orchard"
      Description = "The Underworld King and Queen are back!! Princess, you prevailed!"
    }
    {
      Id = "Ghost_Ranger02"
      DisplayName = "dying wish: {#CauseOfDeathFormat}to fly"
      Description = "How is it we are working with that Titan now?"
    }
    {
      Id = "Ghost_Ranger03"
      DisplayName = "dying wish: {#CauseOfDeathFormat}to keep fighting"
      Description = "The Underworld shall never be taken again, Princess!"
    }
    {
      Id = "Ghost_Ranger04"
      DisplayName = "cause of death: {#CauseOfDeathFormat}mushrooms"
      Description = "Could you ask Lady Demeter to cease this rain, Your Grace?"
    }
    {
      Id = "Ghost_Ranger05"
      DisplayName = "cause of death: {#CauseOfDeathFormat}chariot"
      Description = "I wonder what the Fates are like? They must have a sense of humor."
    }
    {
      Id = "Ghost_Ranger06"
      DisplayName = "cause of death: {#CauseOfDeathFormat}vermin"
      Description = "The renovation of the House of Hades is proceeding at pace, Princess!"
    }
    {
      Id = "Ghost_Ranger07"
      DisplayName = "cause of death: {#CauseOfDeathFormat}feasting"
      Description = "Whenever this new age comes around, you can count me out."
    }
    {
      Id = "Ghost_Ranger08"
      DisplayName = "dying wish: {#CauseOfDeathFormat}the stars"
      Description = "Selene smiled at me as I passed by! I'm certain of it!"
    }
    {
      Id = "Ghost_Ranger09"
      DisplayName = "cause of death: {#CauseOfDeathFormat}club"
      Description = "We heard, Your Grace! Glory to the current Champion of Elysium!!"
    }
    {
      Id = "Ghost_Ranger10"
      DisplayName = "cause of death: {#CauseOfDeathFormat}sling"
      Description = "Ah, if only we could have been there to see the battle with the Prince!"
    }

