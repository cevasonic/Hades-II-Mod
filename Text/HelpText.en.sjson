    }
    {
      Id = "Cosmetic_TavernaChairs01a_Flavor"
      Description = "Those of the Crossroads are expected to remember the House of Hades, made easier on one of these."
    }
    {
      Id = "Cosmetic_TavernaChairs01b"
      DisplayName = "Benches, Crystal"
      Description = "{$Keywords.CosmeticSwap}: Sleek polished stone seating, for all in the {#BoldFormatGraftDark}Taverna{#Prev}."
    }
    {
      Id = "Cosmetic_TavernaChairs01b_Flavor"
      Description = "Mortals typically dislike having to rest on cold surfaces, but Shades have no such qualms."
    }
    {
      Id = "Cosmetic_TavernaChairs01c"
