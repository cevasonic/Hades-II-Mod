    {
      Id = "Cosmetic_TavernaChairs01_Flavor"
      Description = "Few Shades so much as bother to try to sit, though tend to appreciate fondly-remembered aesthetics."
    }
    {
      Id = "Cosmetic_TavernaChairs01a"
