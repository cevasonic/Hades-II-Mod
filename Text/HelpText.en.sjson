    }

    {
      Id = "Block"
      InheritFrom = "BaseTooltip"
      DisplayName = "Parry"
      Description = "Prevent damage from most types of direct attacks. Can be repeated after {#BoldFormatGraft}{$TraitData.DaggerBlockAspect.OnWeaponChargeFunctions.FunctionArgs.Cooldown} Sec."
    }
    {
      Id = "Shells"
      InheritFrom = "BaseTooltip"
      DisplayName = "{!Icons.LobAmmo_NoTooltip} Shells"
      Description = "Ammunition for your {A2} {$Keywords.AttackSet}. Retrieve from the field to re-use."
    }
    {
      Id = "ShellsAlt"
      InheritFrom = "Shells"
      DisplayName = "Shells"
    }
    {
      Id = "Shell"
      InheritFrom = "Shells"
      DisplayName = "{!Icons.LobAmmo_NoTooltip} Shell"
    }
    {
      Id = "LobAmmoInfo"
      InheritFrom = "Shells"
    }
    {
      Id = "ReRollAlt"
      InheritFrom = "BaseTooltip"
      DisplayName = "{!Icons.ReRoll} Change of Fate"
      Description = "Used to alter various outcomes this night, depending on your {#BoldFormatGraft}Arcana{#Prev}."
    }
    {
      Id = "RecipeSpell"
      InheritFrom = "BaseTooltip"
      DisplayName = "Recipe"
      Description = "A repeatable formula that takes time, during which the {#BoldFormatGraft}Cauldron {#Prev}cannot be used."
    }
    {
      Id = "RepeatSpell"
      InheritFrom = "BaseTooltip"
      DisplayName = "Charm"
      Description = "A repeatable magick spell with some immediate effect."
    }

    {
      Id = "MarketSellOK"
      InheritFrom = "BaseTooltip"
      DisplayName = "Surplus Resource"
      Description = "You have little need for this right now."
    }
    {
      Id = "MarketEarlySellWarning"
      InheritFrom = "BaseTooltip"
      DisplayName = "{!Icons.NeededResource} Needed Resource"
      Description = "This still has other uses, so you may wish to hold onto it for now."
    }
    {
      Id = "MarketEarlySellWarningTooltip"
      InheritFrom = "BaseTooltip"
      DisplayName = "{$Keywords.MarketEarlySellWarning}"
    }

    {
      Id = "Costume"
      InheritFrom = "BaseTooltip"
      DisplayName = "Outfit"
      Description = "A special look and bonus that lasts till your {$Keywords.PlayerArmor} is depleted from taking damage."
    }
    {
      Id = "CosmeticAdd"
      InheritFrom = "BaseTooltip"
      DisplayName = "Extra Decor"
      Description = "Adds a new decorative touch in the vicinity. You may put it away if you wish."
    }
    {
      Id = "CosmeticAltAdd"
      InheritFrom = "BaseTooltip"
      DisplayName = "Extra Decor"
      Description = "Adds a new decorative touch, or replaces a similar one. You may also put it away."
    }
    {
      Id = "CosmeticSwap"
      InheritFrom = "BaseTooltip"
      DisplayName = "Alt Decor"
      Description = "Replaces something in the vicinity with a new look. You may always switch back."
    }
    {
      Id = "CosmeticDefault"
      InheritFrom = "BaseTooltip"
      DisplayName = "Plain Decor"
      Description = "Modest starting furnishings. You may switch this to {$Keywords.CosmeticSwap} of the same type."
    }
    {
      Id = "CosmeticDeck"
      InheritFrom = "BaseTooltip"
      DisplayName = "Card Backs"
      Description = "Different {$Keywords.CardPlural} themes, which you can set for each saved arrangement."
    }
    {
      Id = "FamiliarCostume"
      InheritFrom = "BaseTooltip"
      DisplayName = "Form"
      Description = "How your {$Keywords.Familiar} appears. Changes have no effect on abilities."
    }

    /* Cosmetics */
    {
      Id = "Cosmetic_TentBlanket01"
      DisplayName = "Bedding, Crossroads"
      Description = "{$Keywords.CosmeticDefault}: Clean and unwrinkled; prevents some amount of body heat from escaping."
    }
    {
      Id = "Cosmetic_TentBlanket01_Flavor"
      Description = "The Princess long insisted on sleeping under the stars but eventually conceded to this."
    }

    {
      Id = "Cosmetic_TentBlanket01a"
      DisplayName = "Bedding, Silk"
      Description = "{$Keywords.CosmeticSwap}: Cool and smooth, with earthy hues and a symmetrical diamond pattern."
    }
    {
      Id = "Cosmetic_TentBlanket01a_Flavor"
      Description = "The silken threads as well as the dyes used all come from the woods of Erebus."
    }

    {
      Id = "Cosmetic_TentBlanket01b"
      DisplayName = "Bedding, Moon"
      Description = "{$Keywords.CosmeticSwap}: Light and delicate, with silver embroidery representing the grace of Selene."
    }
    {
      Id = "Cosmetic_TentBlanket01b_Flavor"
      Description = "The Moon cannot warm the skin, but the spirit; this blanket, a little of each."
    }

    {
      Id = "Cosmetic_TentBlanket01c"
      DisplayName = "Bedding, Woolen"
      Description = "{$Keywords.CosmeticSwap}: Warm and soft, despite feeling somewhat coarse on first impression."
    }
    {
      Id = "Cosmetic_TentBlanket01c_Flavor"
      Description = "Made from materials sourced from the one and only shepherd's flock in the city of Ephyra."
    }

    {
      Id = "Cosmetic_ApolloLyre"
      DisplayName = "Lyre, Replica of Apollo's"
      Description = "{$Keywords.CosmeticAdd}: Crafted to look virtually indistinguishable from that of the god of light."
    }
    {
      Id = "Cosmetic_ApolloLyre_Flavor"
      Description = "No one can play as beautifully as Apollo, though owners of this beautiful piece cannot play at all."
    }

    {
      Id = "Cosmetic_TentHangingOrnaments01"
      DisplayName = "Talismans, Hanging"
      Description = "{$Keywords.CosmeticAdd}: Ensures the privacy of one's tent, paradoxically through eyeball imagery."
    }
    {
      Id = "Cosmetic_TentHangingOrnaments01_Flavor"
      Description = "The Earth is always pulling us toward where we came from, and where we shall return."
    }

    {
      Id = "Cosmetic_TentCandle01"
      DisplayName = "Candle, Crimson"
      Description = "{$Keywords.CosmeticDefault}: Poured from enchanted materials and anointed with three drops of blood."
    }
    {
      Id = "Cosmetic_TentCandle01_Flavor"
      Description = "The Headmistress lit this candle when the Princess first arrived in the Crossroads, to mark her passage."
    }

    {
      Id = "Cosmetic_TentCandle01a"
      DisplayName = "Candle, Morbid"
      Description = "{$Keywords.CosmeticSwap}: Poured from ancient materials and anointed with the ashes of great balladeers."
    }
    {
      Id = "Cosmetic_TentCandle01a_Flavor"
      Description = "To mortals, death is one of the most mysterious and captivating forces of all; a source of inspiration, then."
    }

    {
      Id = "Cosmetic_TentCandle01b"
      DisplayName = "Candle, Toadhead"
      Description = "{$Keywords.CosmeticSwap}: Poured with a dash of mineral-rich swamp water and made with real glass."
    }
    {
      Id = "Cosmetic_TentCandle01b_Flavor"
      Description = "Perhaps it was the toad's ability to subsist either above the water's surface or below that first compelled her."
    }

    {
      Id = "Cosmetic_EmployeeOfTheMonth"
      DisplayName = "Placard, House of Hades"
      Description = "{$Keywords.CosmeticAdd}: Once used to honor loyal service to the god of the dead; now a relic."
    }
    {
      Id = "Cosmetic_EmployeeOfTheMonth_Flavor"
      Description = "An old yet sturdy frame showing evidence of heavy use, though the likenesses it featured are nowhere to be found."
    }

    {
      Id = "Cosmetic_ThanPoster"
      DisplayName = "Signboard, House of Hades"
      Description = "{$Keywords.CosmeticAdd}: Once used to motivate Shades serving the god of the dead; now a relic."
    }
    {
      Id = "Cosmetic_ThanPoster_Flavor"
      Description = "Featured on this piece, Death Incarnate must have been a model Houseservant and an imposing presence."
    }

    {
      Id = "Cosmetic_WitchTrinkets01"
      DisplayName = "Baubles, Glass"
      Description = "{$Keywords.CosmeticAdd}: Contains various objects of such an obscure nature that their use is purely aesthetic."
    }
    {
      Id = "Cosmetic_WitchTrinkets01_Flavor"
      Description = "How are we to know that the Princess of the Dead is a witch most powerful, if not for the abundance of these?"
    }

    {
      Id = "Cosmetic_WitchTrinkets02"
      DisplayName = "Trinkets, Bronze"
      Description = "{$Keywords.CosmeticAdd}: Creates the appearance of having various quaint interests and pastimes."
    }
    {
      Id = "Cosmetic_WitchTrinkets02_Flavor"
      Description = "With the extensive study of magick comes a predisposition toward certain eccentricities, or the other way around."
    }

    {
      Id = "Cosmetic_TentQuilt"
      DisplayName = "Quilt, Childhood"
      Description = "{$Keywords.CosmeticAdd}: Provides a perhaps-false sense of security and a perhaps-true sense of comfort."
    }
    {
      Id = "Cosmetic_TentQuilt_Flavor"
      Description = "The Shades agreed to dispose of this when the Princess of the Dead indicated she no longer needed it, yet here it is."
    }

    {
      Id = "Cosmetic_TentShelf01"
      DisplayName = "Shelving, Rustic"
      Description = "{$Keywords.CosmeticDefault}: Offers serviceable storage space with a natural touch."
    }
    {
      Id = "Cosmetic_TentShelf01_Flavor"
      Description = "The Princess would routinely reorganize her belongings on this, yet never settled on the optimal layout."
    }

    {
      Id = "Cosmetic_TentShelf01a"
      DisplayName = "Shelving, Lunar"
      Description = "{$Keywords.CosmeticSwap}: Offers secure storage space with a nocturnal touch."
    }
    {
      Id = "Cosmetic_TentShelf01a_Flavor"
      Description = "Dark lacquer and silver embellishments add a touch of extravagance to this beautifully crafted piece."
    }

    {
      Id = "Cosmetic_TentShelf01b"
      DisplayName = "Shelving, Fancy"
      Description = "{$Keywords.CosmeticSwap}: Offers ample storage space with an elegant touch."
    }
    {
      Id = "Cosmetic_TentShelf01b_Flavor"
      Description = "Various sliding compartments, some well-hidden, give this piece a secretive air."
    }

    {
      Id = "Cosmetic_FanPoster01"
      DisplayName = "Wall-Scroll, Scylla"
      Description = "{$Keywords.CosmeticAltAdd}: Portrays an infamous sea-monster and an obscure musical act."
    }
    {
      Id = "Cosmetic_FanPoster01_Flavor"
      Description = "One's musical tastes can be so deeply personal that to share them is to make oneself feel highly vulnerable."
    }

    {
      Id = "Cosmetic_FanPoster01a"
      DisplayName = "Wall-Scroll, Selene"
      Description = "{$Keywords.CosmeticAltAdd}: Portrays the great Titaness and incarnate of the Moon."
    }
    {
      Id = "Cosmetic_FanPoster01a_Flavor"
      Description = "Even when invisible to the eye, she is always watching, guiding us night after night, cycle after cycle."
    }

    {
      Id = "Cosmetic_FanPoster01b"
      DisplayName = "Wall-Scroll, Heracles"
      Description = "{$Keywords.CosmeticAltAdd}: Portrays the imposing demigod son of Zeus, known as the mightiest of men."
    }
    {
      Id = "Cosmetic_FanPoster01b_Flavor"
      Description = "To mortalkind, he is the pinnacle of sheer strength and of unwavering service to the gods."
    }

    {
      Id = "Cosmetic_TentRug"
      DisplayName = "Rug, Silver Sisters"
      Description = "{$Keywords.CosmeticAdd}: Enhances the entryway to the tent with durable softness."
    }
    {
      Id = "Cosmetic_TentRug_Flavor"
      Description = "Woven with four sets of threads, each of a different vibrant hue, all colors of the Moon."
    }

    {
      Id = "Cosmetic_TentTable01"
      DisplayName = "Table, Rustic"
      Description = "{$Keywords.CosmeticDefault}: Indigo fabric covers this circular but otherwise plain piece."
    }
    {
      Id = "Cosmetic_TentTable01_Flavor"
      Description = "Recovered from the River Acheron long ago; the water damage is superficial and hidden from view."
    }

    {
      Id = "Cosmetic_TentTable01a"
      DisplayName = "Table, Spiked"
      Description = "{$Keywords.CosmeticSwap}: Sleek surface, cool to the touch, yet adorned with dangerous-looking points."
    }
    {
      Id = "Cosmetic_TentTable01a_Flavor"
      Description = "The circumference of the piece is adorned with an old incantation used for finding lost loves."
    }

    {
      Id = "Cosmetic_TentTable01b"
      DisplayName = "Table, Lunar"
      Description = "{$Keywords.CosmeticSwap}: Hard porous surface, with colors of dusky marble and moonstone."
    }
    {
      Id = "Cosmetic_TentTable01b_Flavor"
      Description = "How the artisan was able to chisel the stones with such precision is a matter of dispute."
    }

    {
      Id = "Cosmetic_TentTable01c"
      DisplayName = "Table, Woodsy"
      Description = "{$Keywords.CosmeticSwap}: Rough richly complex surface, the branches of an ancient tree."
    }
    {
      Id = "Cosmetic_TentTable01c_Flavor"
      Description = "Even the Tree of Life loses limbs from time to time; yet they have purpose in death, and new branches grow."
    }

    {
      Id = "Cosmetic_FrinosRock01"
      DisplayName = "Habitat, Mossy"
      Description = "{$Keywords.CosmeticDefault}: A simple resting-place for a special amphibian."
    }
    {
      Id = "Cosmetic_FrinosRock01_Flavor"
      Description = "The softness and dampness of the moss makes this a favored long-time abode for Frinos."
    }

    {
      Id = "Cosmetic_FrinosRock01a"
      DisplayName = "Habitat, Lighted"
      Description = "{$Keywords.CosmeticSwap}: A fanciful resting-place for a special amphibian."
    }
    {
      Id = "Cosmetic_FrinosRock01a_Flavor"
      Description = "The lights come from tiny bioluminescent plants that provide a source of nourishment, and entertainment."
    }

    {
      Id = "Cosmetic_FrinosRock01b"
      DisplayName = "Habitat, Aquatic"
      Description = "{$Keywords.CosmeticSwap}: A comfortable resting-place for a special amphibian."
    }
    {
      Id = "Cosmetic_FrinosRock01b_Flavor"
      Description = "The shape of this particular habitat provides a nostalgic reminder of wistful evenings as a tad."
    }

    {
      Id = "Cosmetic_RespawnCircleFlowers"
      DisplayName = "Flowers, Scattered"
      Description = "{$Keywords.CosmeticAdd}: Adorns the Magick Circle with a calming floral arrangement."
    }
    {
      Id = "Cosmetic_RespawnCircleFlowers_Flavor"
      Description = "One may return to shadows only to a place of utmost safety and solitude, and these can be a contributing factor."
    }

    {
      Id = "Cosmetic_FamiliarEffigy01"
      DisplayName = "Sculpture, Amphibian"
      Description = "{$Keywords.CosmeticAltAdd}: A stone-chiseled likeness of {#BoldFormatGraftDark}Frinos {#Prev}near the Magick Circle."
    }
    {
      Id = "Cosmetic_FamiliarEffigy01_Flavor"
      Description = "The woods of Erebus are beset with creatures that prefer the dampness and the dark; here, they are honored."
    }

    {
      Id = "Cosmetic_FamiliarEffigy01a"
      DisplayName = "Sculpture, Raven"
      Description = "{$Keywords.CosmeticAltAdd}: A stone-chiseled likeness of {#BoldFormatGraftDark}Raki {#Prev}near the Magick Circle."
    }
    {
      Id = "Cosmetic_FamiliarEffigy01a_Flavor"
      Description = "Ravens have always watched over the dead, often from the moment mortal life slips away."
    }

    {
      Id = "Cosmetic_FamiliarEffigy01b"
      DisplayName = "Sculpture, Feline"
      Description = "{$Keywords.CosmeticAltAdd}: A stone-chiseled likeness of {#BoldFormatGraftDark}Toula {#Prev}near the Magick Circle."
    }
    {
      Id = "Cosmetic_FamiliarEffigy01b_Flavor"
      Description = "Natural-born hunters who fend for themselves; is it any wonder witches prefer them?"
    }

    {
      Id = "Cosmetic_MorosChaise"
      DisplayName = "Recliner, Fateful"
      Description = "{$Keywords.CosmeticAdd}: A comfortable seat to never rest upon, near to where {$Keywords.CharMoros} typically resides."
    }
    {
      Id = "Cosmetic_MorosChaise_Flavor"
      Description = "Even feared Doom Incarnate must require a bit of reprieve from time to time."
    }
    {
      Id = "Cosmetic_MorosTentCanopy"
      DisplayName = "Draping, Fateful"
      Description = "{$Keywords.CosmeticAdd}: Some colorful protection from the elements, near to where {$Keywords.CharMoros} typically resides."
    }
    {
      Id = "Cosmetic_MorosTentCanopy_Flavor"
      Description = "The Crossroads are near enough to the surface that its harsh and unpredictable weather patterns sometimes cut in."
    }
    {
      Id = "Cosmetic_MorosScrolls"
      DisplayName = "Parchments, Fateful"
      Description = "{$Keywords.CosmeticAdd}: Crisscrossed shelving with ample reading material, near to where {$Keywords.CharMoros} typically resides."
    }
    {
      Id = "Cosmetic_MorosScrolls_Flavor"
      Description = "Those with access to the Crossroads are invited to learn its ways, and some of its history and secrets."
    }
    {
      Id = "Cosmetic_MorosRug"
      DisplayName = "Rug, Fateful"
      Description = "{$Keywords.CosmeticAdd}: A fine spot on which to ponder the future, near to where {$Keywords.CharMoros} typically resides."
    }
    {
      Id = "Cosmetic_MorosRug_Flavor"
      Description = "Woven in honor of the Fates using threads believed to have come from their own looms."
    }
    {
      Id = "Cosmetic_MorosSpools"
      DisplayName = "Threads, Fateful"
      Description = "{$Keywords.CosmeticAdd}: An arrangement of colorful threads, near to where {$Keywords.CharMoros} typically resides."
    }
    {
      Id = "Cosmetic_MorosSpools_Flavor"
      Description = "A potentially-auspicious reminder of the connections shared by all living beings."
    }
    {
      Id = "Cosmetic_MorosTerrain"
      DisplayName = "Cobblestones, Fateful"
      Description = "{$Keywords.CosmeticAdd}: Engraved stone flooring, neatly arranged near to where {$Keywords.CharMoros} typically resides."
    }
    {
      Id = "Cosmetic_MorosTerrain_Flavor"
      Description = "Reminds us of the weavings of the Fates, the process itself: the apportioning, the spinning, and the cutting."
    }
    {
      Id = "Cosmetic_NemesisChair"
      DisplayName = "Throne, Chthonic"
      Description = "{$Keywords.CosmeticAdd}: A big imposing seat, near to where {$Keywords.CharNemesis} typically resides."
    }
    {
      Id = "Cosmetic_NemesisChair_Flavor"
      Description = "They once held a contest as to who could avoid sitting longer; the victor is to be determined."
    }
    {
      Id = "Cosmetic_NemesisRug"
      DisplayName = "Flooring, Chthonic"
      Description = "{$Keywords.CosmeticAdd}: A spot on which to regard the night, near to where {$Keywords.CharNemesis} typically resides."
    }
    {
      Id = "Cosmetic_NemesisRug_Flavor"
      Description = "Reminds us that Night is all around us; not merely above, but also below."
    }
    {
      Id = "Cosmetic_NemesisGrindstone"
      DisplayName = "Grindstone, Chthonic"
      Description = "{$Keywords.CosmeticAdd}: A device for honing keen edges, near to where {$Keywords.CharNemesis} typically resides."
    }
    {
      Id = "Cosmetic_NemesisGrindstone_Flavor"
      Description = "While the blade called Stygius requires no sharpening, its bearer can never be too certain."
    }
    {
      Id = "Cosmetic_NemesisBraziers"
      DisplayName = "Braziers, Chthonic"
      Description = "{$Keywords.CosmeticAdd}: A pair of tall pale flames, near to where {$Keywords.CharNemesis} typically resides."
    }
    {
      Id = "Cosmetic_NemesisBraziers_Flavor"
      Description = "The bright gleam of silver is perhaps at its most beautiful in this particular light."
    }
    {
      Id = "Cosmetic_NemesisScales"
      DisplayName = "Scales, Balanced"
      Description = "{$Keywords.CosmeticAdd}: A large and symbolic set of scales, near to where {$Keywords.CharNemesis} typically resides."
    }
    {
      Id = "Cosmetic_NemesisScales_Flavor"
      Description = "Fairness is to be carefully doled out, and may punishment befall those who expect more than their share."
    }


    {
      Id = "Cosmetic_OdysseusRug"
      DisplayName = "Rug, Grecian"
      Description = "{$Keywords.CosmeticAltAdd}: A durable mortal-woven piece, near to where {$Keywords.CharOdysseus} typically resides."
    }
    {
      Id = "Cosmetic_OdysseusRug_Flavor"
      Description = "Recovered mostly intact from the City of Ephyra, where it was no longer doing anybody any good."
    }
    {
      Id = "Cosmetic_OdysseusRug02"
      DisplayName = "Rug, Nautical"
      Description = "{$Keywords.CosmeticAltAdd}: An artful piece depicting a beaked ship, near to where {$Keywords.CharOdysseus} typically resides."
    }
    {
      Id = "Cosmetic_OdysseusRug02_Flavor"
      Description = "The ship depicted is said to have had all its pieces replaced, raising provocative questions as to whether it remains itself."
    }
    {
      Id = "Cosmetic_OdysseusTable01"
      DisplayName = "War Table, Rustic"
      Description = "{$Keywords.CosmeticDefault}: Functional for considering various maps, plans, and strategies; oft used by {$Keywords.CharOdysseus}."
    }
    {
      Id = "Cosmetic_OdysseusTable01_Flavor"
      Description = "Assembled from wood fallen from yew trees, which grow in abundance in Erebus."
    }
    {
      Id = "Cosmetic_OdysseusTable01a"
      DisplayName = "War Table, Grecian"
      Description = "{$Keywords.CosmeticSwap}: Grander furnishings for grander plans, near to where {$Keywords.CharOdysseus} typically resides."
    }
    {
      Id = "Cosmetic_OdysseusTable01a_Flavor"
      Description = "Fashioned from the wood of an olive tree, and inscribed with prayers to the gods for peace."
    }
    {
      Id = "Cosmetic_OdysseusVase"
      DisplayName = "Urn, Grecian"
      Description = "{$Keywords.CosmeticAdd}: Ample storage for more plans and reports, near to where {$Keywords.CharOdysseus} typically resides."
    }
    {
      Id = "Cosmetic_OdysseusVase_Flavor"
      Description = "Once held the ashen remains of mortal warriors, some of whom reside in these Crossroads now."
    }
    {
      Id = "Cosmetic_ErisTrashcan"
      DisplayName = "Basket, Rubbish"
      Description = "{$Keywords.CosmeticAdd}: Receptacle suitable for storing detritus, near to where {$Keywords.CharEris} typically resides."
    }
    {
      Id = "Cosmetic_ErisTrashcan_Flavor"
      Description = "While there is no reason to think Strife would ever use such a thing, one nevertheless can hope."
    }
    {
      Id = "Cosmetic_ErisWarningSign01"
      DisplayName = "Warning Sign, Strife"
      Description = "{$Keywords.CosmeticAdd}: Automatically detects when {$Keywords.CharEris} is in the vicinity, for better or worse."
    }
    {
      Id = "Cosmetic_ErisWarningSign01_Flavor"
      Description = "No Shade has taken responsibility for the sign's unflattering likeness, leading to speculation that Eris created it herself."
    }
    {
      Id = "Cosmetic_MainHangingTassles01"
      DisplayName = "Tassels, Silver Sisters"
      Description = "{$Keywords.CosmeticDefault}: Protective and decorative coiled charms near to the Princess' tent."
    }
    {
      Id = "Cosmetic_MainHangingTassles01_Flavor"
      Description = "Whether in the heavens, on the surface, or within the Earth, together they shine."
    }
    {
      Id = "Cosmetic_MainHangingTassles01a"
      DisplayName = "Tassels, Astral"
      Description = "{$Keywords.CosmeticSwap}: Protective and decorative star-shaped charms near to the Princess' tent."
    }
    {
      Id = "Cosmetic_MainHangingTassles01a_Flavor"
      Description = "A reminder that not even the innumerable stars in the sky can overcome the dark of night."
    }
    {
      Id = "Cosmetic_MainHangingTassles01b"
      DisplayName = "Tassels, Stygian"
      Description = "{$Keywords.CosmeticSwap}: Protective and decorative blood-red charms near to the Princess' tent."
    }
    {
      Id = "Cosmetic_MainHangingTassles01b_Flavor"
      Description = "Colored with rare dyes made with waters from the River Styx, among other things."
    }
    {
      Id = "Cosmetic_MainHangingRope01"
      DisplayName = "Rope, Knotted"
      Description = "{$Keywords.CosmeticDefault}: Binding knots with rings of silver hanging above the {#BoldFormatGraftDark}Cauldron{#Prev}."
    }
    {
      Id = "Cosmetic_MainHangingRope01_Flavor"
      Description = "These were already here when the Princess of the Dead first arrived in the Crossroads."
    }
    {
      Id = "Cosmetic_MainHangingRope01a"
      DisplayName = "Rope, Astral"
      Description = "{$Keywords.CosmeticSwap}: Star-shaped charms attached with braided silver hanging above the {#BoldFormatGraftDark}Cauldron{#Prev}."
    }
    {
      Id = "Cosmetic_MainHangingRope01a_Flavor"
      Description = "They seem to enhance the faint light of the stars, which is permitted in the Crossroads."
    }
    {
