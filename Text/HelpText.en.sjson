    }
    {
      Id = "Cosmetic_HypnosPedestal01a_Flavor"
      Description = "The winged tops represent the means by which we quickly slip into oblivion when Sleep takes hold."
    }
    {
      Id = "Cosmetic_HypnosPedestal01b"
