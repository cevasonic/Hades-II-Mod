    }
    {
      Id = "Cosmetic_CauldronPillars01a_Flavor"
      Description = "The Crossroads cannot be found by the uninvited, so strongly do the shadows gather there."
    }
    {
      Id = "Cosmetic_CauldronPillars01b"
