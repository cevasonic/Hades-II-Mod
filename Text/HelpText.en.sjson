    }
    {
      Id = "Cosmetic_TrainingDummy01a_Flavor"
      Description = "'Find the Titan. Slay the Titan.' In the end, the task of the Princess of the Underworld was as simple as that."
    }
    {
      Id = "Cosmetic_TrainingDummy01b"
