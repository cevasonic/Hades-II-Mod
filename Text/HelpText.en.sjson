    }
    {
      Id = "Cosmetic_TavernaChairs01c_Flavor"
      Description = "The durable fabric of the cushions is stuffed with fibers from a delicate but sturdy plant."
    }
    {
      Id = "Cosmetic_TavernaMusicStage01"
