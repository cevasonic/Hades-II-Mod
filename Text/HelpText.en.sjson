      Description = "{$Keywords.CosmeticSwap}: Silver engraved with protective wards surrounding the {#BoldFormatGraftDark}Cauldron{#Prev}."
    }
    {
      Id = "Cosmetic_CauldronRing01a_Flavor"
      Description = "'Great Titaness, the Eye of Night, I draw you down; lend me your might!'"
    }
    {
      Id = "Cosmetic_CauldronRing01b"
      DisplayName = "Circle, Earthen"
      Description = "{$Keywords.CosmeticSwap}: Intertwining branches engraved with protective wards surrounding the {#BoldFormatGraftDark}Cauldron{#Prev}."
    }
    {
      Id = "Cosmetic_CauldronRing01b_Flavor"
      Description = "'Great Tree of Life and Mother Gaia, listen to my heart's desire!'"
    }
    {
      Id = "Cosmetic_CauldronPillars01"
