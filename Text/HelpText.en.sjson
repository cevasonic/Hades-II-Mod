    {
      Id = "Cosmetic_BirdHouse"
      DisplayName = "Birdhouse, Luxurious"
      Description = "{$Keywords.CosmeticAdd}: Well-stocked little domicile, near to where {#BoldFormatGraftDark}Raki {#Prev}typically resides."
    }
    {
      Id = "Cosmetic_BirdHouse_Flavor"
      Description = "Those born with wings strive to use them, though having a place to rest them is welcome, too."
    }
    {
      Id = "Cosmetic_ExitCharm"
      DisplayName = "Charm, Amphibian"
      Description = "{$Keywords.CosmeticAltAdd}: Conspicuous embellishment to the warded gateways leading both above and below."
    }
    {
      Id = "Cosmetic_ExitCharm_Flavor"
      Description = "The amphibian is a master of survival in various habitats, and likewise does this charm inspire perseverance."
    }
    {
      Id = "Cosmetic_ExitCharm02"
      DisplayName = "Charm, Avian"
      Description = "{$Keywords.CosmeticAltAdd}: Beaked embellishment to the warded gateways leading both above and below."
    }
    {
      Id = "Cosmetic_ExitCharm02_Flavor"
      Description = "The raven is sometimes seen as a portent of ill fortune, but the same can be said of the witch."
    }
    {
      Id = "Cosmetic_ExitCharm03"
      DisplayName = "Charm, Feline"
      Description = "{$Keywords.CosmeticAltAdd}: Aloof embellishment to the warded gateways leading both above and below."
    }
    {
      Id = "Cosmetic_ExitCharm03_Flavor"
      Description = "The cat serves no master but her own whim, and reminds us that we may choose our own way."
    }
    {
      Id = "Cosmetic_ExitCharm04"
      DisplayName = "Charm, Canine"
      Description = "{$Keywords.CosmeticAltAdd}: Stately embellishment to the warded gateways leading both above and below."
    }
    {
      Id = "Cosmetic_ExitCharm04_Flavor"
      Description = "The hound is dignified yet a consummate survivor, scavenging whatever she requires wheresoever she may go."
    }
    {
      Id = "Cosmetic_ExitCharm05"
      DisplayName = "Charm, Musteline"
      Description = "{$Keywords.CosmeticAltAdd}: Mischievous embellishment to the warded gateways leading both above and below."
    }
    {
      Id = "Cosmetic_ExitCharm05_Flavor"
      Description = "The polecat is as slippery as beasts can get, able to escape even the most unfavorable situation."
    }
    {
      Id = "Cosmetic_AmbientFrogs"
      DisplayName = "Habitat, Amphibian"
      Description = "{$Keywords.CosmeticAdd}: Mix of hidden aqueous vegetation that small frogs and such find irresistible."
    }
    {
      Id = "Cosmetic_AmbientFrogs_Flavor"
      Description = "Life is a delicate system that revolves around death, and these creatures comprise a useful little corner."
    }
    {
      Id = "Cosmetic_AmbientCats"
      DisplayName = "Habitat, Feline"
      Description = "{$Keywords.CosmeticAdd}: Carefully-chosen assortment of loose string and boxes to draw out any stray cats."
    }
    {
      Id = "Cosmetic_AmbientCats_Flavor"
      Description = "Solitary creatures whose affections can seem feigned, lending them an irresistible complexity."
    }
    {
      Id = "Cosmetic_AmbientDogs"
      DisplayName = "Habitat, Canine"
      Description = "{$Keywords.CosmeticAdd}: Well-scented surfaces upon which any stray dogs in the vicinity ought come to rest."
    }
    {
      Id = "Cosmetic_AmbientDogs_Flavor"
      Description = "Their innate loyalty and inability to be deceiving makes them well-loved among beasts."
    }
    {
      Id = "Cosmetic_ChronosHourglass"
      DisplayName = "Hourglass, Golden"
      Description = "{$Keywords.CosmeticAdd}: Theoretically measures a fixed period of time, and in an elegant way."
    }
    {
      Id = "Cosmetic_ChronosHourglass_Flavor"
      Description = "Death to Chronos: a reminder of inevitability and the transience of the present."
    }
    {
      Id = "Cosmetic_HermesShoes"
      DisplayName = "Footwear, Winged"
      Description = "{$Keywords.CosmeticAdd}: Said to significantly enhance mobility, but are many sizes too large."
    }
    {
      Id = "Cosmetic_HermesShoes_Flavor"
      Description = "Even if they did fit, surely they would combust on contact with the fire-stepping Princess."
    }
    {
      Id = "Cosmetic_IcarusWings"
      DisplayName = "Wings, Prototype"
      Description = "{$Keywords.CosmeticAdd}: Based on an earlier design that {$Keywords.CharIcarus} was able to significantly improve."
    }
    {
      Id = "Cosmetic_IcarusWings_Flavor"
      Description = "The feathers used were both functionally necessary as well as a clear source of inspiration."
    }
    {
      Id = "Cosmetic_PandoraJar"
      DisplayName = "Jar, Nostalgic"
      Description = "{$Keywords.CosmeticAdd}: Based on an old design that spurs latent memories, mostly good."
    }
    {
      Id = "Cosmetic_PandoraJar_Flavor"
      Description = "Reminiscent of a traditional wedding gift, suitable for storing everything from pickles to daemons."
    }
    {
      Id = "Cosmetic_OdysseusTrojanHorse"
      DisplayName = "Equine Sculpture, Wooden"
      Description = "{$Keywords.CosmeticAdd}: Scale replica of an infamous military decoy, near to where {$Keywords.CharOdysseus} typically resides."
    }
    {
      Id = "Cosmetic_OdysseusTrojanHorse_Flavor"
      Description = "The real thing must have been quite a bit bigger if it truly fit the Great Tactician and his elite assault force."
    }
    {
      Id = "Cosmetic_ErisJerkyShelf"
      DisplayName = "Shelving, Pantry"
      Description = "{$Keywords.CosmeticAdd}: Optimal for storing copious snack-foods, not far from where {$Keywords.CharEris} typically resides."
    }
    {
      Id = "Cosmetic_ErisJerkyShelf_Flavor"
      Description = "Originally built for the distribution of Cyclops Jerky. The shelves are spaced to be of little other use."
    }
    {
      Id = "Cosmetic_ErisRug"
      DisplayName = "Rug, Tri-Wing"
      Description = "{$Keywords.CosmeticAdd}: A colorful piece reminiscent of moody skies, near where {$Keywords.CharEris} typically resides."
    }
    {
      Id = "Cosmetic_ErisRug_Flavor"
      Description = "Woven from fabric that can sustain a lot of nightly punishment and cleans easily."
    }

    {
      Id = "Cosmetic_ArtemisLyre"
      DisplayName = "Lyre, Replica of Artemis'"
      Description = "{$Keywords.CosmeticAdd}: Similar to a piece owned by the goddess of hunt, near where she sometimes resides."
    }
    {
      Id = "Cosmetic_ArtemisLyre_Flavor"
      Description = "Perhaps her and her brother's excellence at all things stems from their competitive spirit."
    }
    {
      Id = "Cosmetic_ArtemisTarget"
      DisplayName = "Target, Archery"
      Description = "{$Keywords.CosmeticAdd}: Suggests skill with bow-and-arrow, near to where {#BoldFormatGraftDark}Artemis {#Prev}sometimes resides."
    }
    {
      Id = "Cosmetic_ArtemisTarget_Flavor"
      Description = "Though the goddess of the hunt visits the Crossroads to take her mind off many things, archery is exempted."
    }
    {
      Id = "Cosmetic_ArtemisFlowerCircle01"
      DisplayName = "Flower Circle, Pale"
      Description = "{$Keywords.CosmeticAltAdd}: A bright and delicate arrangement, near to where {#BoldFormatGraftDark}Artemis {#Prev}sometimes resides."
    }
    {
      Id = "Cosmetic_ArtemisFlowerCircle01_Flavor"
      Description = "Deepens the sense of serenity in the small clearing where the goddess of the hunt likes to sing."
    }
    {
      Id = "Cosmetic_ArtemisFlowerCircle01a"
      DisplayName = "Flower Circle, Bluish"
      Description = "{$Keywords.CosmeticAltAdd}: A soft and understated arrangement, near to where {#BoldFormatGraftDark}Artemis {#Prev}sometimes resides."
    }
    {
      Id = "Cosmetic_ArtemisFlowerCircle01a_Flavor"
      Description = "One can feel even more unseen than usual within a circle such as this, if so desired."
    }
    {
      Id = "Cosmetic_ArtemisFlowerCircle01b"
      DisplayName = "Flower Circle, Crimson"
      Description = "{$Keywords.CosmeticAltAdd}: A bold and vibrant arrangement, near to where {#BoldFormatGraftDark}Artemis {#Prev}sometimes resides."
    }
    {
      Id = "Cosmetic_ArtemisFlowerCircle01b_Flavor"
      Description = "Slightly bolsters the sense of protection against negative energy while within it."
    }
    {
      Id = "Cosmetic_ArtemisAmaranthus"
      DisplayName = "Amaranth, Red"
      Description = "{$Keywords.CosmeticAdd}: Sturdy plants favored by the goddess of the hunt, near to where she sometimes resides."
    }
    {
      Id = "Cosmetic_ArtemisAmaranthus_Flavor"
      Description = "This tall, nutritious grain perhaps takes its reddish hue from the River Styx."
    }

    {
      Id = "Cosmetic_FallenLeaves01"
      DisplayName = "Leaves, Autumnal"
      Description = "{$Keywords.CosmeticAltAdd}: Crisp naturally-fallen foliage from cooler climes scattered about the main grounds."
    }
    {
      Id = "Cosmetic_FallenLeaves01_Flavor"
      Description = "Perhaps Lady Demeter herself bade these to fall from the branches that they might find their way to the Crossroads."
    }
    {
      Id = "Cosmetic_FallenLeaves02"
      DisplayName = "Leaves, Vernal"
      Description = "{$Keywords.CosmeticAltAdd}: Vibrant naturally-fallen foliage from warmer climes scattered about the main grounds."
    }
    {
      Id = "Cosmetic_FallenLeaves02_Flavor"
      Description = "These typically would wither and rot in but a few nights, though a minor enchantment keeps them fresh."
    }
    {
      Id = "Cosmetic_CharonOar"
      DisplayName = "Oar, Styx-Splitting"
      Description = "{$Keywords.CosmeticAdd}: Spare wooden paddle, near the docks where the {$Keywords.Broker} typically resides."
    }
    {
      Id = "Cosmetic_CharonOar_Flavor"
      Description = "The Underworld Boatman goes through more of these than he would ever admit."
    }
    {
      Id = "Cosmetic_ArachneTapestry"
      DisplayName = "Tapestry, Silken"
      Description = "{$Keywords.CosmeticAdd}: Depicts the opulence of Olympus, near where the {$Keywords.Broker} typically resides."
    }
    {
      Id = "Cosmetic_ArachneTapestry_Flavor"
      Description = "Cannot possibly be the Arachne original, which is said to have been destroyed after her victory in a fateful contest."
    }
    {
      Id = "Cosmetic_HecateKey"
      DisplayName = "Banner, Threefold Moon"
      Description = "{$Keywords.CosmeticAdd}: Proud insignia of the Silver Sisters hanging from the great {#BoldFormatGraftDark}Tree of Life{#Prev}."
    }
    {
      Id = "Cosmetic_HecateKey_Flavor"
      Description = "The Unseen have no banners, for the light of the Moon marks their passage. Yet banners nonetheless are made."
    }
    {
      Id = "Cosmetic_SkellyZagreusStatue"
      DisplayName = "Statue, Abandoned"
      Description = "{$Keywords.CosmeticAdd}: Stone slab reduced by chisel to the unmistakable form of the Prince of the Underworld."
    }
    {
      Id = "Cosmetic_SkellyZagreusStatue_Flavor"
      Description = "A commission for the House of Hades that was lost due to a series of clerical errors that then were carefully covered up."
    }
    {
      Id = "Cosmetic_CollectableOdysseus"
      DisplayName = "Chthonic Chid, Odysseus"
      Description = "{$Keywords.CosmeticAdd}: Oddly proportioned collectable figure fashioned after the Great Tactician."
    }
    {
      Id = "Cosmetic_CollectableOdysseus_Flavor"
      Description = "“I do like to travel, but... I think you'll always know where to find me.”"
    }
    {
      Id = "Cosmetic_CollectableSkelly"
      DisplayName = "Chthonic Chid, Schelemeus"
      Description = "{$Keywords.CosmeticAdd}: Oddly proportioned collectable figure fashioned after the Training Master."
    }
    {
      Id = "Cosmetic_CollectableSkelly_Flavor"
      Description = "“Less greeting, more beating, if you would be so kind!”"
    }
    {
      Id = "Cosmetic_CollectableMoros"
      DisplayName = "Chthonic Chid, Moros"
      Description = "{$Keywords.CosmeticAdd}: Oddly proportioned collectable figure fashioned after Doom Incarnate."
    }
    {
      Id = "Cosmetic_CollectableMoros_Flavor"
      Description = "“Take heart knowing the Fates themselves believe that you'll succeed!”"
    }
    {
      Id = "Cosmetic_CollectableHecate"
      DisplayName = "Chthonic Chid, Hecate"
      Description = "{$Keywords.CosmeticAdd}: Oddly proportioned collectable figure fashioned after the Witch of the Crossroads."
    }
    {
      Id = "Cosmetic_CollectableHecate_Flavor"
      Description = "“Your training shall never be complete. And I would know if you stand any chance at all against our enemy!”"
    }
    {
      Id = "Cosmetic_CollectableNemesis"
      DisplayName = "Chthonic Chid, Nemesis"
      Description = "{$Keywords.CosmeticAdd}: Oddly proportioned collectable figure fashioned after Retribution Incarnate."
    }
    {
      Id = "Cosmetic_CollectableNemesis_Flavor"
      Description = "“You don't deserve this. But you're stuck with it. So the only question is, what are you going to do about it now?”"
    }
    {
      Id = "Cosmetic_CollectableCharon"
      DisplayName = "Chthonic Chid, Charon"
      Description = "{$Keywords.CosmeticAdd}: Oddly proportioned collectable figure fashioned after the Underworld Boatman."
    }
    {
      Id = "Cosmetic_CollectableCharon_Flavor"
      Description = "“Hrrrrmmm, nnrrrraaauggghh...”"
    }
    {
      Id = "Cosmetic_CollectableIcarus"
      DisplayName = "Chthonic Chid, Icarus"
      Description = "{$Keywords.CosmeticAdd}: Oddly proportioned collectable figure fashioned after the apprentice of Daedalus."
    }
    {
      Id = "Cosmetic_CollectableIcarus_Flavor"
      Description = "“Creating tools that others can use to reach new heights... that's how I reach them myself.”"
    }
    {
      Id = "Cosmetic_CollectableArtemis"
      DisplayName = "Chthonic Chid, Artemis"
      Description = "{$Keywords.CosmeticAdd}: Oddly proportioned collectable figure fashioned after the goddess of the hunt."
    }
    {
      Id = "Cosmetic_CollectableArtemis_Flavor"
      Description = "“The skilled huntress keeps her bag of tricks full and with her at all times.”"
    }
    {
      Id = "Cosmetic_CollectableEris"
      DisplayName = "Chthonic Chid, Eris"
      Description = "{$Keywords.CosmeticAdd}: Oddly proportioned collectable figure fashioned after Strife Incarnate."
    }
    {
      Id = "Cosmetic_CollectableEris_Flavor"
      Description = "“It's not my fault I keep lying to you, manipulating you, shooting you with the Rail, making you clean up after me...”"
    }
    {
      Id = "Cosmetic_CollectableDora"
      DisplayName = "Chthonic Chid, Dora"
      Description = "{$Keywords.CosmeticAdd}: Oddly proportioned collectable figure fashioned after the executor of the Renewal Project."
    }
    {
      Id = "Cosmetic_CollectableDora_Flavor"
      Description = "“Nothing like a bunch of busywork to make you stop thinking about the pointlessness of your existence, right?”"
    }
    {
      Id = "Cosmetic_CollectableSelene"
      DisplayName = "Chthonic Chid, Selene"
      Description = "{$Keywords.CosmeticAdd}: Oddly proportioned collectable figure fashioned after the Moon Incarnate."
    }
    {
      Id = "Cosmetic_CollectableSelene_Flavor"
      Description = "“We breathe, we bleed, we rest, we start anew. Did we create this cycle, or are we merely part of it?”"
    }
    {
      Id = "Cosmetic_IcarusTable01"
      DisplayName = "Workbench, Artisan's"
      Description = "{$Keywords.CosmeticAdd}: Well-equipped space for tinkering and so on, near to where {$Keywords.CharIcarus} typically resides."
    }
    {
      Id = "Cosmetic_IcarusTable01_Flavor"
      Description = "While similar to an old bench once used by Daedalus himself, this one has its own touches and accessories."
    }
    {
      Id = "Cosmetic_IcarusRug01"
      DisplayName = "Rug, Minoan"
      Description = "{$Keywords.CosmeticAdd}: A traditional stretch of flooring fabric, near to where {$Keywords.CharIcarus} typically resides."
    }
    {
      Id = "Cosmetic_IcarusRug01_Flavor"
      Description = "The preponderance of blue is said to be reminiscent of the sight of the sea."
    }
    {
      Id = "Cosmetic_IcarusRug02"
      DisplayName = "Rug, Sunburst"
      Description = "{$Keywords.CosmeticAdd}: A bit of flooring in honor of daybreak, near to where {$Keywords.CharIcarus} typically resides."
    }
    {
      Id = "Cosmetic_IcarusRug02_Flavor"
      Description = "There is some dispute as to whether the subject being honored here is the Titan Helios or the god Apollo."
    }
    {
      Id = "Cosmetic_IcarusBombs01"
      DisplayName = "Arsenal, Incendiary"
      Description = "{$Keywords.CosmeticAdd}: Assortment of defused explosives, near to where {$Keywords.CharIcarus} typically resides."
    }
    {
      Id = "Cosmetic_IcarusBombs01_Flavor"
      Description = "There was no appetite for storing live explosives in the Crossroads, but these are still exciting to an extent."
    }
    {
      Id = "Cosmetic_IcarusMaps"
      DisplayName = "Charts, Aether"
      Description = "{$Keywords.CosmeticAdd}: Fairly up-to-date records of known airways, near to where {$Keywords.CharIcarus} typically resides."
    }
    {
      Id = "Cosmetic_IcarusMaps_Flavor"
      Description = "Though few obstacles exist in the sky, navigating across it nonetheless can be fraught even for experienced flyers."
    }
    {
      Id = "Cosmetic_CardDeck01"
      DisplayName = "Arcana, Unseen"
      Description = "{$Keywords.CosmeticDeck}: Starter set of {#UpgradeFormatDark}{$WorldUpgradeData.Cosmetic_CardDeck01.NumBackings} {#Prev}alternate themes, featuring the realms above and below."
    }
    {
      Id = "Cosmetic_CardDeck01_Flavor"
      Description = "The experienced practitioner uses visual aids to distinguish between arrangements of Arcana for any given night."
    }

    {
      Id = "Cosmetic_CardDeck02"
      DisplayName = "Arcana, Nocturnal"
      Description = "{$Keywords.CosmeticDeck}: Set of {#UpgradeFormatDark}{$WorldUpgradeData.Cosmetic_CardDeck02.NumBackings} {#Prev}alternate themes, featuring each of the Fate-forged Nocturnal Arms."
    }
    {
      Id = "Cosmetic_CardDeck02_Flavor"
      Description = "For the Silver Sisters, the Arcana and the Arms go hand in hand; it is natural to be predisposed to some of each."
    }

    {
      Id = "Cosmetic_CardDeck03"
      DisplayName = "Arcana, Close Aspect"
      Description = "{$Keywords.CosmeticDeck}: Set of {#UpgradeFormatDark}{$WorldUpgradeData.Cosmetic_CardDeck03.NumBackings} {#Prev}alternate themes, featuring an alternate Aspect for each of the Nocturnal Arms."
    }
    {
      Id = "Cosmetic_CardDeck03_Flavor"
      Description = "Each bearer of the Nocturnal Arms is believed to have a close connection to at least one other, if not more."
    }

    {
      Id = "Cosmetic_CardDeck04"
      DisplayName = "Arcana, Distant Aspect"
      Description = "{$Keywords.CosmeticDeck}: Set of {#UpgradeFormatDark}{$WorldUpgradeData.Cosmetic_CardDeck04.NumBackings} {#Prev}alternate themes, featuring an ancient Aspect for each of the Nocturnal Arms."
    }
    {
      Id = "Cosmetic_CardDeck04_Flavor"
      Description = "The bearers of the Arms have in common their dark origins and a charge to serve the realm beneath the Earth."
    }

    {
      Id = "Cosmetic_CardDeck05"
      DisplayName = "Arcana, Familiar"
      Description = "{$Keywords.CosmeticDeck}: Set of {#UpgradeFormatDark}{$WorldUpgradeData.Cosmetic_CardDeck05.NumBackings} {#Prev}alternate themes, featuring your very own {$Keywords.FamiliarPlural}."
    }
    {
      Id = "Cosmetic_CardDeck05_Flavor"
      Description = "The essence of life, a timeless mystery even to the most devoted student of the Arcana; what binds all living beings?"
    }

    {
      Id = "Cosmetic_CardDeck06"
      DisplayName = "Arcana, Fearsome"
      Description = "{$Keywords.CosmeticDeck}: Set of {#UpgradeFormatDark}{$WorldUpgradeData.Cosmetic_CardDeck06.NumBackings} {#Prev}alternate themes, styled after the imposing {$Keywords.Shrine}."
    }
    {
      Id = "Cosmetic_CardDeck06_Flavor"
      Description = "Those who swear the Vows come to have a healthy respect for Fear sooner or later, lest they be consumed by it."
    }

    {
      Id = "Cosmetic_CardDeck07"
      DisplayName = "Arcana, Hidden Aspect"
      Description = "{$Keywords.CosmeticDeck}: Set of {#UpgradeFormatDark}{$WorldUpgradeData.Cosmetic_CardDeck07.NumBackings} {#Prev}alternate themes, featuring a foreign Aspect for each of the Nocturnal Arms."
    }
    {
      Id = "Cosmetic_CardDeck07_Flavor"
      Description = "Perhaps there are or shall be gods presiding over other, distant realms, each a visage of the Underworld we know."
    }

    {
      Id = "Cosmetic_CardDeck08"
      DisplayName = "Arcana, Fate-bound"
      Description = "{$Keywords.CosmeticDeck}: Set of {#UpgradeFormatDark}{$WorldUpgradeData.Cosmetic_CardDeck08.NumBackings} {#Prev}alternate themes, featuring symbols sacred to the Hades line."
    }
    {
      Id = "Cosmetic_CardDeck08_Flavor"
      Description = "The Fates themselves chose Hades as god of the dead, binding him and his offspring forever beneath the Earth."
    }

