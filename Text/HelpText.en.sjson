    /* Debuffs / Status Curses */
    {
      Id = "Blind"
      InheritFrom = "BaseTooltip"
      DisplayName = "Daze"
      Description = "{#ItalicBoldFormat}{$Keywords.Status}: {#Prev}Afflicted foes have {#BoldFormat}{$TooltipData.ExtractData.BlindChance}% {#Prev}chance to deal no damage. Lasts {#BoldFormatGraft}{$TooltipData.ExtractData.BlindDuration} Sec."
    }
    {
      Id = "Root"
      InheritFrom = "BaseTooltip"
      DisplayName = "Freeze"
      Description = "{#ItalicBoldFormat}{$Keywords.Status}: {#Prev}Afflicted foes are stopped for {#BoldFormatGraft}{$TooltipData.ExtractData.ChillActiveDuration} Sec. {#Prev}Can be re-applied after {#BoldFormatGraft}{$TooltipData.ExtractData.ChillDuration} Sec."
    }
    {
      Id = "SlowField"
      InheritFrom = "BaseTooltip"
      DisplayName = "Gust"
      Description = "{#ItalicBoldFormat}{$Keywords.Status}: {#Prev}Afflicted foes are {#BoldFormat}{$TooltipData.ExtractData.ChillAmount}% {#Prev}slower, and their ranged shots {$TooltipData.ExtractData.ProjectileSlow:F} slower. Lasts {#BoldFormatGraft}{$TooltipData.ExtractData.Duration} Sec."
    }
    {
      Id = "DamageOverTime"
      InheritFrom = "BaseTooltip"
      DisplayName = "Hangover"
      Description = "{#ItalicBoldFormat}{$Keywords.Status}: {#Prev}Afflicted foes take damage continuously. Lasts for {#BoldFormatGraft}{$TooltipData.ExtractData.DamageOverTimeDuration} Sec."
    }
    {
      Id = "KnockbackAmplify"
      InheritFrom = "BaseTooltip"
      DisplayName = "Froth"
      Description = "{#ItalicBoldFormat}{$Keywords.Status}: {#Prev}When hit, afflicted foes have {$TooltipData.ExtractData.FontChance:F} chance to take {$TooltipData.ExtractData.FontDamage} damage. Lasts {#BoldFormatGraft}{$TooltipData.ExtractData.KnockbackAmplifyDuration} Sec."
    }
    {
      Id = "Invisible"
      DisplayName = "Dark"
      Description = "You are undetectable and {$Keywords.Invulnerable} for {#BoldFormatGraft}{$TooltipData.ExtractData.Duration} Sec. {#Prev}This can recur only after {#BoldFormatGraft}{$TooltipData.ExtractData.Cooldown} Sec."
    }
    {
      Id = "DelayedKnockback",
      InheritFrom = "BaseTooltip"
      DisplayName = "Glow"
      Description = "{#ItalicBoldFormat}{$Keywords.Status}: {#Prev}Afflicted foes take {#BoldFormatGraft}{$TooltipData.ExtractData.DelayedKnockbackModifier:P} {#Prev}damage for {#BoldFormatGraft}{$TooltipData.ExtractData.DelayedKnockbackDuration} Sec."
    }
    {
      Id = "Burn"
      InheritFrom = "BaseTooltip"
      DisplayName = "Scorch"
      Description = "{#ItalicBoldFormat}{$Keywords.Status}: {#Prev}Afflicted foes take {#BoldFormatGraft}{$TooltipData.ExtractData.BurnRate} {#Prev}damage accrued from this every {#BoldFormatGraft}1 Sec."
    }
    {
      Id = "Mark"
