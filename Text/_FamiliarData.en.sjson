      Speaker = "Melinoe"
      Event = "CatFamiliar.PreAttackVoiceLines"
    }
    {
      Id = "Melinoe_3976"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Tktktk!"
      Speaker = "Melinoe"
      Event = "CatFamiliar.PreAttackVoiceLines"
    }
    {
      Id = "Melinoe_2502"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come, Toula."
      Speaker = "Melinoe"
      Event = "CatFamiliar.EquipVoiceLines"
    }
    {
      Id = "Melinoe_2503"
      InheritFrom = "BaseSubtitle"
      DisplayName = "With me, Toula."
      Speaker = "Melinoe"
      Event = "CatFamiliar.EquipVoiceLines"
    }
    {
      Id = "Melinoe_3882"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come on, Toula."
      Speaker = "Melinoe"
      Event = "CatFamiliar.EquipVoiceLines"
    }
    {
      Id = "MelinoeField_1915"
      InheritFrom = "BaseSubtitle"
      DisplayName = "If this treat is to your liking then it means we share a bond."
      Speaker = "Melinoe"
      Event = "CatFamiliar.RecruitVoiceLines"
    }
    {
      Id = "MelinoeField_1916"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We do! Your name is Toula, isn't it?"
      Speaker = "Melinoe"
      Event = "CatFamiliar.RecruitVoiceLines"
    }
    {
      Id = "MelinoeField_1918"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Let us protect each other from now on."
      Speaker = "Melinoe"
      Event = "CatFamiliar.RecruitVoiceLines"
    }
    {
      Id = "Melinoe_0983"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Are you lost, little one?"
      Speaker = "Melinoe"
      Event = "CatFamiliar.InteractVoiceLines"
    }
    {
      Id = "Melinoe_0985"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Don't be afraid..."
      Speaker = "Melinoe"
      Event = "CatFamiliar.InteractVoiceLines"
    }
    {
      Id = "Melinoe_2509"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Here, girl."
      Speaker = "Melinoe"
      Event = "CatFamiliar.InteractVoiceLines"
    }
    {
      Id = "Melinoe_3398"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Good girl."
      Speaker = "Melinoe"
      Event = "CatFamiliar.InteractVoiceLines"
    }
    {
      Id = "Melinoe_3399"
      InheritFrom = "BaseSubtitle"
      DisplayName = "There's a good girl."
      Speaker = "Melinoe"
      Event = "CatFamiliar.InteractVoiceLines"
    }
    {
      Id = "Melinoe_3400"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hey..."
      Speaker = "Melinoe"
      Event = "CatFamiliar.InteractVoiceLines"
    }
    {
      Id = "Melinoe_3401"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What's the good word...?"
      Speaker = "Melinoe"
      Event = "CatFamiliar.InteractVoiceLines"
    }
    {
      Id = "Melinoe_3402"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}<Chuckle>"
      Speaker = "Melinoe"
      Event = "CatFamiliar.InteractVoiceLines"
    }
    {
      Id = "Melinoe_3403"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Tk-tk-tk."
      Speaker = "Melinoe"
      Event = "CatFamiliar.InteractVoiceLines"
    }
    {
      Id = "Melinoe_3404"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Tk-tk-tk-tk!"
      Speaker = "Melinoe"
      Event = "CatFamiliar.InteractVoiceLines"
    }
    {
      Id = "Melinoe_2504"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come, Raki."
      Speaker = "Melinoe"
      Event = "RavenFamiliar.EquipVoiceLines"
    }
    {
      Id = "Melinoe_2505"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come along, Raki."
      Speaker = "Melinoe"
      Event = "RavenFamiliar.EquipVoiceLines"
    }
    {
      Id = "Melinoe_3881"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Onward, Raki."
      Speaker = "Melinoe"
      Event = "RavenFamiliar.EquipVoiceLines"
    }
    {
      Id = "MelinoeField_1917"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We do! Raki, pleased to meet you."
      Speaker = "Melinoe"
      Event = "RavenFamiliar.RecruitVoiceLines"
    }
    {
      Id = "Melinoe_0984"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Greetings, little raven."
      Speaker = "Melinoe"
      Event = "RavenFamiliar.InteractVoiceLines"
    }
    {
      Id = "Melinoe_0986"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I won't hurt you..."
      Speaker = "Melinoe"
      Event = "RavenFamiliar.InteractVoiceLines"
    }
    {
      Id = "Melinoe_3864"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Little raven..."
      Speaker = "Melinoe"
      Event = "RavenFamiliar.InteractVoiceLines"
    }
    {
      Id = "Melinoe_3865"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're an unusual fellow."
      Speaker = "Melinoe"
      Event = "RavenFamiliar.InteractVoiceLines"
    }
    {
      Id = "Melinoe_3866"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're always here..."
      Speaker = "Melinoe"
      Event = "RavenFamiliar.InteractVoiceLines"
    }
    {
      Id = "Melinoe_3782"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're a fine bird."
      Speaker = "Melinoe"
      Event = "RavenFamiliar.InteractVoiceLines"
    }
    {
      Id = "Melinoe_3783"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hello, Raki."
      Speaker = "Melinoe"
      Event = "RavenFamiliar.InteractVoiceLines"
    }
    {
      Id = "Melinoe_3784"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're all right, Raki."
      Speaker = "Melinoe"
      Event = "RavenFamiliar.InteractVoiceLines"
    }
    {
      Id = "Melinoe_3785"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Easy now, Raki."
      Speaker = "Melinoe"
      Event = "RavenFamiliar.InteractVoiceLines"
    }
    {
      Id = "Melinoe_3786"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Good bird."
      Speaker = "Melinoe"
      Event = "RavenFamiliar.InteractVoiceLines"
    }
    {
      Id = "Melinoe_3787"
      InheritFrom = "BaseSubtitle"
      DisplayName = "It's going to be all right."
      Speaker = "Melinoe"
      Event = "RavenFamiliar.InteractVoiceLines"
    }
    {
      Id = "Melinoe_3867"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Good evening, little raven."
      Speaker = "Melinoe"
      Event = "RavenFamiliar.InteractVoiceLines"
    }
    {
      Id = "Melinoe_2497"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hecuba, would you accompany me on my task?"
      Speaker = "Melinoe"
      Event = "HoundFamiliar.EquipVoiceLines"
    }
    {
      Id = "Melinoe_2508"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come, Hecuba."
      Speaker = "Melinoe"
      Event = "HoundFamiliar.EquipVoiceLines"
    }
    {
      Id = "Melinoe_3883"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Onward, Hecuba."
      Speaker = "Melinoe"
      Event = "HoundFamiliar.EquipVoiceLines"
    }
    {
      Id = "MelinoeField_2545"
      InheritFrom = "BaseSubtitle"
      DisplayName = "If this treat is to your liking then it means we share a bond."
      Speaker = "Melinoe"
      Event = "HoundFamiliar.RecruitVoiceLines"
    }
    {
      Id = "MelinoeField_2546"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Of course we do! Hecuba, the honor is mine."
      Speaker = "Melinoe"
      Event = "HoundFamiliar.RecruitVoiceLines"
    }
    {
      Id = "MelinoeField_2547"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We shall protect each other from now on."
      Speaker = "Melinoe"
      Event = "HoundFamiliar.RecruitVoiceLines"
    }
    {
      Id = "MelinoeField_2816"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Here on a scouting mission for Headmistress, girl?"
      Speaker = "Melinoe"
      Event = "HoundFamiliar.InteractVoiceLines"
    }
    {
      Id = "MelinoeField_2819"
      InheritFrom = "BaseSubtitle"
      DisplayName = "We've come so far from the Crossroads, haven't we?"
      Speaker = "Melinoe"
      Event = "HoundFamiliar.InteractVoiceLines"
    }
    {
      Id = "MelinoeField_2817"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I've not seen Gale anywhere, have you?"
      Speaker = "Melinoe"
      Event = "HoundFamiliar.InteractVoiceLines"
    }
    {
      Id = "MelinoeField_3330"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Should check in with Headmistress about you."
      Speaker = "Melinoe"
      Event = "HoundFamiliar.InteractVoiceLines"
    }
    {
      Id = "MelinoeField_2818"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You keep an eye on Echo there, all right?"
      Speaker = "Melinoe"
      Event = "HoundFamiliar.InteractVoiceLines"
    }
    {
      Id = "Melinoe_3776"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Who's a good girl?"
      Speaker = "Melinoe"
      Event = "HoundFamiliar.InteractVoiceLines"
    }
    {
      Id = "Melinoe_3777"
