    }
    {
      Id = "Storyteller_0178"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Within the silence of the infinite abyss lies infinite possibility; the limitless and unseen building-blocks of all that has ever been conceived, and all that shall ever be."
