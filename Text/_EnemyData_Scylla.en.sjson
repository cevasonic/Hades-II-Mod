    }
    {
      Id = "Scylla_0045"
      InheritFrom = "BaseNarrative"
      DisplayName = "You should hear some of our {#Emph}classic {#Prev}numbers, {#Emph}haha! {#Prev}Oh but first: {#Emph}our latest hit..."
