      Event = "ScyllaMiscStart08"
    }
    {
      Id = "Scylla_0044"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come make {#Emph}sweet music {#Prev}with us, lady! Sure beats whatever it is {#Emph}you {#Prev}do."
