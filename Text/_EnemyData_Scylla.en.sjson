    }
    {
      Id = "Scylla_0002"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ohh, {#Emph}hohoho{#Prev}, no way! {#Emph}No way. {#Prev}Lookit, gals, a {#Emph}lady! {#Prev}Ladies never come to see our shows, you must be different, what's your name? Oh, make yourself comfy, we're just about to start, aren't we, gals?"
      Speaker = "Scylla"
      Event = "ScyllaFirstMeeting"
    }
    {
      Id = "Melinoe_0498"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Sirens. I should have known you were the source of all that singing. Slinked down into the Underworld, have you?"
      Speaker = "Melinoe"
      Event = "ScyllaFirstMeeting"
    }
    {
      Id = "Scylla_0003"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's the perfect pressure down here! Beats the pressure trying to make art while all our fans are watching, begging, {#Emph}Scylla, where's your next song?!"
      Speaker = "Scylla"
      Event = "ScyllaFirstMeeting"
    }
    {
      Id = "Melinoe_0499"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't you drown your so-called fans to death? Have you even got any left?"
      Speaker = "Melinoe"
      Event = "ScyllaFirstMeeting"
    }
    {
      Id = "Scylla_0004"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't {#Emph}ever {#Prev}say such things about our fans! {#Prev}Oh hey gals...? What say we give her the {#Emph}old song and dance?"
      Speaker = "Scylla"
      Event = "ScyllaFirstMeeting"
    }
    {
      Id = "Scylla_0279"
      InheritFrom = "BaseNarrative"
      DisplayName = "Soak it up, lady! One of our proud sponsors made all our dreams come true: a {#Emph}brand-new {#Prev}stage, {#Emph}and{#Prev}... a collaboration with one of the {#Emph}biggest {#Prev}names this side of the sea!"
      Speaker = "Scylla"
      Event = "ScyllaAboutAltFight01"
    }
    {
      Id = "MelinoeField_3538"
      InheritFrom = "BaseNarrative"
      DisplayName = "Charybdis, here with you...? This is no sponsor's doing but the will of Night. As fear spreads, so do these manifestations of nightmares... my own apparently."
      Speaker = "Melinoe"
      Event = "ScyllaAboutAltFight01"
    }
    {
      Id = "Scylla_0280"
      InheritFrom = "BaseNarrative"
      DisplayName = "Bad-mouth our sponsor all you like, but they got taste, and you do not! We're debuting our latest single thanks to them, and there's nothing you can do to stop it...! At least not the first part."
      Speaker = "Scylla"
      Event = "ScyllaAboutAltFight01"
    }
    {
      Id = "Scylla_0282"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come to heckle us some more, lady? Well it won't {#Emph}work! {#Prev}No matter what you do, this crowd thinks it's all part of the act. They're not just here for the music, but the {#Emph}full experience!"
      Speaker = "Scylla"
      Event = "ScyllaAboutAltFight02"
    }
    {
      Id = "MelinoeField_3539"
      InheritFrom = "BaseNarrative"
      DisplayName = "And watching you and your band get trounced repeatedly is the experience you're seeking to provide? You artists truly do make sacrifices for your craft."
      Speaker = "Melinoe"
      Event = "ScyllaAboutAltFight02"
    }
    {
      Id = "Scylla_0283"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's {#Emph}right! {#Prev}I've given {#Emph}everything {#Prev}to reach this point in my career, to reach {#Emph}this {#Prev}very moment, on {#Emph}this {#Prev}very stage! And I'm prepared to give even more... what about {#Emph}you?!"
      Speaker = "Scylla"
      Event = "ScyllaAboutAltFight02"
    }
    {
      Id = "Scylla_0284"
      InheritFrom = "BaseNarrative"
      DisplayName = "Back to our old and smaller stage as you can see, {#Emph}just {#Prev}for the night I'm sure! But our sponsor's going to come through! Put us back in the {#Emph}spotlight {#Prev}where we {#Emph}belong, hm! {#Prev}Eventually!"
      Speaker = "Scylla"
      Event = "ScyllaAboutAltFight03"
    }
    {
      Id = "MelinoeField_3540"
      InheritFrom = "BaseNarrative"
      DisplayName = "Who do you even think this mysterious sponsor is, setting the location for our clash and whether that horrid Charybdis makes a guest appearance?"
      Speaker = "Melinoe"
      Event = "ScyllaAboutAltFight03"
    }
    {
      Id = "Scylla_0285"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nice try, lady. You can barge onto our stage, no {#Emph}matter {#Prev}the size... you can try and take our sense of style... {#Emph}even our fans! {#Prev}But you'll never take our {#Emph}sponsors!!"
      Speaker = "Scylla"
      Event = "ScyllaAboutAltFight03"
    }
    {
      Id = "Scylla_0286"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sometimes we like going back to this smaller venue for old time's sake! Lots of our fans want us sticking to our roots."
      Speaker = "Scylla"
      Event = "ScyllaAboutAltFight04"
    }
    {
      Id = "MelinoeField_3541"
      InheritFrom = "BaseNarrative"
      DisplayName = "So you comply with their every request? They don't sound much like fans if they're forcing their will upon you."
      Speaker = "Melinoe"
      Event = "ScyllaAboutAltFight04"
    }
    {
      Id = "Scylla_0287"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, spoken like somebody who never {#Emph}had {#Prev}any fans to satisfy. We're only here because our audience has come to {#Emph}love {#Prev}our songs. So it's a give-and-take sort of relationship: {#Emph}our {#Prev}music, sailors' {#Emph}lives! {#Prev}And {#Emph}yours!"
      Speaker = "Scylla"
      Event = "ScyllaAboutAltFight04"
    }
    {
      Id = "Scylla_0288"
      InheritFrom = "BaseNarrative"
      DisplayName = "This is the big break we've been {#Emph}waiting for! {#Prev}I told the gals we'd be back in the spotlight on the big stage in {#Emph}no {#Prev}time. {#Emph}Oh{#Prev}, but the {#Emph}bigger {#Prev}we get... the more {#Emph}detractors {#Prev}we'll get..."
      Speaker = "Scylla"
      Event = "ScyllaAboutAltFight05"
    }
    {
      Id = "MelinoeField_3542"
      InheritFrom = "BaseNarrative"
      DisplayName = "And do you try to suffocate all your detractors as well as your fans, and if so, how will you keep accumulating more and more?"
      Speaker = "Melinoe"
      Event = "ScyllaAboutAltFight05"
    }
    {
      Id = "Scylla_0289"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't worry your pretty little head about that, lady! You've got bigger problems, like our special guest... who happens to be good at suffocating multiple detractors all at once."
      Speaker = "Scylla"
      Event = "ScyllaAboutAltFight05"
    }
    {
      Id = "Scylla_0290"
      InheritFrom = "BaseNarrative"
      DisplayName = "Big crowd here tonight, lady! Oh, we don't get turnouts like this {#Emph}every {#Prev}time, {#Emph}even {#Prev}if we really should! Though at our scale, we can't help but pick up some more-casual fans!"
      Speaker = "Scylla"
      Event = "ScyllaAboutAltFight06"
    }
    {
      Id = "MelinoeField_3543"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not every Shade here in the Underworld can devote their every evening to attending your performances, Scylla. You don't even have that many songs."
      Speaker = "Melinoe"
      Event = "ScyllaAboutAltFight06"
    }
    {
      Id = "Scylla_0291"
      InheritFrom = "BaseNarrative"
      DisplayName = "How would you even know?! We like to play our greatest hits, but we got plenty more! Ones you haven't heard of, probably, since you're our most {#Emph}casual {#Prev}fan of all!"
      Speaker = "Scylla"
      Event = "ScyllaAboutAltFight06"
    }
    {
      Id = "MelinoeField_3544"
      InheritFrom = "BaseNarrative"
      DisplayName = "So what's next for Scylla and the Sirens now that you've had your big break? An even bigger venue? Better songs?"
      Speaker = "Melinoe"
      Event = "ScyllaAboutAltFight07"
    }
    {
      Id = "Scylla_0292"
      InheritFrom = "BaseNarrative"
      DisplayName = "Even bigger venue, {#Emph}possibly! {#Prev}Even better songs, {#Emph}impossibly. {#Prev}Because our music is {#Emph}already {#Prev}the best! We {#Emph}could {#Prev}always make more if we really want, {#Emph}heh! {#Prev}Though right now, me and the gals want {#Emph}something more..."
      Speaker = "Scylla"
      Event = "ScyllaAboutAltFight07"
    }
    {
      Id = "Scylla_0293"
      InheritFrom = "BaseNarrative"
      DisplayName = "Too bad Charybdis couldn't be here tonight, lady! Like she was supposed to. Probably back up on the {#Emph}surface{#Prev}, stuffing her face as usual!"
      Speaker = "Scylla"
      Event = "ScyllaAboutAltFight08"
    }
    {
      Id = "MelinoeField_3545"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can see that. It must take a lot of sustenance to regenerate all those tentacles I've had to slice off."
      Speaker = "Melinoe"
      Event = "ScyllaAboutAltFight08"
    }
    {
      Id = "Scylla_0294"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, the show must go on! We're playing {#Emph}Rock and a Hard Place{#Prev}, with or without our special guest! And our small but dedicated audience is gonna {#Emph}eat it up!"
      Speaker = "Scylla"
      Event = "ScyllaAboutAltFight08"
    }
    {
      Id = "Scylla_0008"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}I knew it! {#Prev}She's come {#Emph}back! {#Prev}You ready for another show, lady? We've been rehearsing our material, practicing nonstop, because one day? I'm gonna be a {#Emph}star! {#Prev}Oh, me and the gals!"
      Speaker = "Scylla"
      Event = "ScyllaAboutAmbitions01"
    }
    {
      Id = "Melinoe_1042"
      InheritFrom = "BaseNarrative"
      DisplayName = "What do your musical ambitions have to do with unprovoked acts of violence against {#Emph}me?"
      Speaker = "Melinoe"
      Event = "ScyllaAboutAmbitions01"
    }
    {
      Id = "Scylla_0009"
      InheritFrom = "BaseNarrative"
      DisplayName = "She's just heckling us, gals, ignore her, and take it from the top, {#Emph}two, three, four...!"
      Speaker = "Scylla"
      Event = "ScyllaAboutAmbitions01"
    }
    {
      Id = "Scylla_0010"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, always wanted to sing in front of a great big crowd, you know? And not just a bunch of crusty sailors, but like, one of those gigantic theaters they got up on land!"
      Speaker = "Scylla"
      Event = "ScyllaAboutAmbitions02"
    }
    {
      Id = "Melinoe_1828"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not my area of expertise. Do performances in these theaters typically involve attempts to drown the members of the audience?"
      Speaker = "Melinoe"
      Event = "ScyllaAboutAmbitions02"
    }
    {
      Id = "Scylla_0011"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, yeah... and mortals show up to them in massive droves, kicking and screaming, just to get a glimpse, {#Emph}heh! {#Prev}Yet you get a show {#Emph}all to yourself!"
      Speaker = "Scylla"
      Event = "ScyllaAboutAmbitions02"
    }
    {
      Id = "Melinoe_1830"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know, I thought the Sirens were supposed to be the singing ones. But it's always {#Emph}you {#Prev}flapping your gills at me, Scylla..."
      Speaker = "Melinoe"
      Event = "ScyllaAboutSirens01"
    }
    {
      Id = "Scylla_0023"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Don't {#Prev}listen to her, gals! Your backup vocals are the backbone of this act! I've got the voice, {#Emph}you've {#Prev}got the music, we've got {#Emph}the magick! {#Prev}Let's give her a little taste, {#Emph}huh?"
      Speaker = "Scylla"
      Event = "ScyllaAboutSirens01"
    }
    {
      Id = "Scylla_0213"
      InheritFrom = "BaseNarrative"
      DisplayName = "We have our ups and downs, Jetty and Roxy and me. Our little squabbles! But thanks to {#Emph}you{#Prev}, we started fighting with each other in {#Emph}public! {#Prev}And we can't have {#Emph}that."
      Speaker = "Scylla"
      Event = "ScyllaAboutSirens02"
    }
    {
      Id = "MelinoeField_2720"
      InheritFrom = "BaseNarrative"
      DisplayName = "If it makes you feel any better, the hex I put on them was only temporary. Quite frankly I'm surprised it worked on them at all! Night Bloom normally only works on the dead."
      Speaker = "Melinoe"
      Event = "ScyllaAboutSirens02"
    }
    {
      Id = "Scylla_0214"
      InheritFrom = "BaseNarrative"
      DisplayName = "This is my band. And if anybody's gonna turn Jetty and Roxy red with rage against each other, it's {#Emph}not {#Prev}going to be {#Emph}you! {#Prev}Right, gals?"
      Speaker = "Scylla"
      Event = "ScyllaAboutSirens02"
    }
    {
      Id = "Scylla_0016"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just can't get enough of us, {#Emph}can {#Prev}you, lady? Oh, it's OK, happens to everybody, especially sailors, we're just that {#Emph}good! {#Prev}Do you sail?"
      Speaker = "Scylla"
      Event = "ScyllaAboutStage01"
    }
    {
      Id = "Melinoe_2040"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your self-confidence is enviable, but I'm only here because I have to get past this ridiculous stage. So why don't we skip the show."
      Speaker = "Melinoe"
      Event = "ScyllaAboutStage01"
    }
    {
      Id = "Scylla_0017"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh I got a better idea: Why don't we {#Emph}start {#Prev}the show? All we needed was a little audience, and we've got {#Emph}you {#Prev}right where we want you."
      Speaker = "Scylla"
      Event = "ScyllaAboutStage01"
    }
    {
      Id = "Scylla_0012"
      InheritFrom = "BaseNarrative"
      DisplayName = "They say... our songs are {#Emph}to die for{#Prev}, but lately we don't get a lot of company. Oh, you wouldn't know anything about {#Emph}that{#Prev}, right? Because {#Emph}somebody's {#Prev}been smearing our good name..."
      Speaker = "Scylla"
      Event = "ScyllaAboutReputation01"
    }
    {
      Id = "Melinoe_1043"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your reputation is yours to build or ruin. Doubt anyone I know has even heard of you, besides."
      Speaker = "Melinoe"
      Event = "ScyllaAboutReputation01"
    }
    {
      Id = "Scylla_0013"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come on, gals! Let's go {#Emph}all out {#Prev}again before the crowd shows up! They're {#Emph}going {#Prev}to show up! I just {#Emph}know {#Prev}it!"
      Speaker = "Scylla"
      Event = "ScyllaAboutReputation01"
    }
    {
      Id = "Scylla_0021"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh hey, as one of our fans, {#Emph}what {#Prev}would you say is the best thing about Scylla and the Sirens, {#Emph}hm? {#Prev}Our latest hit song? Our impeccable style?"
      Speaker = "Scylla"
      Event = "ScyllaAboutSurvey01"
    }
    {
      Id = "Melinoe_2039"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your sense of style isn't really to my taste, that I can say for certain."
      Speaker = "Melinoe"
      Event = "ScyllaAboutSurvey01"
    }
    {
      Id = "Scylla_0022"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Aw, {#Prev}that's OK! Not everybody's got {#Emph}good taste{#Prev}. At least you're strong enough to admit it, though we're going to get you for that insult, anyway."
      Speaker = "Scylla"
      Event = "ScyllaAboutSurvey01"
    }
    {
      Id = "Scylla_0014"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ooh, good, {#Prev}you're just in time for our set! Been working on a song called {#Emph}I Am Gonna Claw (Out Your Eyes then Drown You to Death), heh! {#Prev}Comes from a real personal place."
      Speaker = "Scylla"
      Event = "ScyllaAboutSongs01"
    }
    {
      Id = "Melinoe_1829"
      InheritFrom = "BaseNarrative"
      DisplayName = "Is it any better than the one I heard on my way in?"
      Speaker = "Melinoe"
      Event = "ScyllaAboutSongs01"
    }
    {
      Id = "Scylla_0015"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, it's {#Emph}not! {#Prev}Because {#Emph}all {#Prev}our songs are {#Emph}the best, heh! {#Prev}Each like a {#Emph}perfect {#Prev}little child! Not a {#Emph}bad {#Prev}one, like {#Emph}you..."
      Speaker = "Scylla"
      Event = "ScyllaAboutSongs01"
    }
    {
      Id = "Scylla_0138"
      InheritFrom = "BaseNarrative"
      DisplayName = "How did you like our latest song, lady? Be honest! There's no right {#Emph}or {#Prev}wrong answer, OK? We {#Emph}thrive {#Prev}on feedback from our fans!"
      Speaker = "Scylla"
      Event = "ScyllaAboutSongs02"
    }
    {
      Id = "MelinoeField_2017"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you seek feedback from your fans, ask {#Emph}them. {#Prev}As for me, I felt the chorus was catchy enough, but the lyrics and their disturbing themes were rather distracting."
      Speaker = "Melinoe"
      Event = "ScyllaAboutSongs02"
    }
    {
      Id = "Scylla_0139"
      InheritFrom = "BaseNarrative"
      DisplayName = "Disturbing? Distracting?! {#Emph}Compelling! That's {#Prev}what good music {#Emph}is{#Prev}. That's what Scylla and the Sirens {#Emph}are! {#Prev}As for our song, {#Emph}hee! {#Prev}You'll understand it better if you give it {#Emph}another {#Prev}listen..."
      Speaker = "Scylla"
      Event = "ScyllaAboutSongs02"
    }
    {
      Id = "MelinoeField_2564"
      InheritFrom = "BaseNarrative"
      DisplayName = "Scylla, I've noticed your song {#Emph}I Am Gonna Claw {#Prev}may be inspired by true events. Is trying to drown me not sufficiently entertaining that I must also be the subject of your ridicule?"
      Speaker = "Melinoe"
      Event = "ScyllaAboutSongs03"
    }
    {
      Id = "Scylla_0207"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh, hoho {#Prev}how can you be so egotistical even? I had that song worked out since way before {#Emph}you {#Prev}showed up. Any and all similarity is entirely coincidence!"
      Speaker = "Scylla"
      Event = "ScyllaAboutSongs03"
    }
    {
      Id = "MelinoeField_2565"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come on. Insulting my hair and attire? Making claims that I'm obsessed with you? But if I'm not the subject of the song, who was, pray tell?"
      Speaker = "Melinoe"
      Event = "ScyllaAboutSongs03"
    }
    {
      Id = "Scylla_0208"
      InheritFrom = "BaseNarrative"
      DisplayName = "No need to get personal, lady! If I go sharing {#Emph}every {#Prev}detail of my private life with every deranged fan who barges in here, then it wouldn't be a {#Emph}private {#Prev}life, {#Emph}would it?"
      Speaker = "Scylla"
      Event = "ScyllaAboutSongs03"
    }
    {
      Id = "MelinoeField_2562"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't you have any new material yet, Scylla? You'd likely garner a much bigger audience if you had a few more songs."
      Speaker = "Melinoe"
      Event = "ScyllaAboutSongs04"
    }
    {
      Id = "Scylla_0205"
      InheritFrom = "BaseNarrative"
      DisplayName = "Shut {#Emph}up! {#Prev}We have more songs than you can {#Emph}count! {#Prev}You're just not ready for them yet. {#Emph}Nobody {#Prev}is! {#Emph}Perfection {#Prev}takes time, {#Emph}lady."
      Speaker = "Scylla"
      Event = "ScyllaAboutSongs04"
    }
    {
      Id = "MelinoeField_2563"
      InheritFrom = "BaseNarrative"
      DisplayName = "But, perfection is always out of reach... if you keep pursuing it, you'll never get there. You must have a work-in-progress you could play instead of the same old stuff."
      Speaker = "Melinoe"
      Event = "ScyllaAboutSongs04"
    }
    {
      Id = "Scylla_0206"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}The same old stuff...? {#Prev}Did you just hear that, gals? I think she meant to say your {#Emph}greatest hits{#Prev}, or your {#Emph}all-time classics{#Prev}, didn't she? {#Emph}Heh! {#Prev}You just don't get it, lady. We're here to {#Emph}please!"
      Speaker = "Scylla"
      Event = "ScyllaAboutSongs04"
    }
    {
      Id = "Scylla_0309"
      InheritFrom = "BaseNarrative"
      DisplayName = "So, what's your favorite of our latest songs, lady? We've got something for just about {#Emph}everybody {#Prev}now! Even you."
      Speaker = "Scylla"
      Event = "ScyllaAboutSongs05"
    }
    {
      Id = "MelinoeField_3587"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, I'm reluctant to choose. I think all these clashes with you lot must have had a significant impact on my ability to appreciate your music on its own merits."
      Speaker = "Melinoe"
      Event = "ScyllaAboutSongs05"
    }
    {
      Id = "Scylla_0310"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Aw, that's {#Prev}too bad! If you can't appreciate art for its own sake and need to hold those of us who make it to outlandish standards, then {#Emph}what {#Prev}are you even {#Emph}doing?!"
      Speaker = "Scylla"
      Event = "ScyllaAboutSongs05"
    }
    {
      Id = "MelinoeField_4308"
      InheritFrom = "BaseNarrative"
      DisplayName = "Was that a new song I heard on my way in? Something about treasures glimmering. Another one about the sea!"
      Speaker = "Melinoe"
      Event = "ScyllaAboutBallad01"
    }
    {
      Id = "Scylla_0436"
      InheritFrom = "BaseNarrative"
      DisplayName = "You {#Emph}could {#Prev}have said {#Emph}Scylla, I don't know anything about themes, so I just can't appreciate the depth of your work! {#Prev}But {#Emph}yeah{#Prev}, it {#Emph}is {#Prev}a new song! And only the first part."
      Speaker = "Scylla"
      Event = "ScyllaAboutBallad01"
    }
    {
      Id = "MelinoeField_4309"
      InheritFrom = "BaseNarrative"
      DisplayName = "I suppose the second part is imminent. You make your performances unnecessarily difficult by fighting me, but that's a choice you keep on making."
      Speaker = "Melinoe"
      Event = "ScyllaAboutBallad01"
    }
    {
      Id = "Scylla_0437"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well we have to drown {#Emph}someone! {#Prev}And sailors have gotten too {#Emph}easy{#Prev}, lady. You'll never be an artist if you don't push {#Emph}harder, and harder, and harder...!"
      Speaker = "Scylla"
      Event = "ScyllaAboutBallad01"
    }
    {
      Id = "Scylla_0439"
      InheritFrom = "BaseNarrative"
      DisplayName = "What'd you think of our latest number, lady? Critics say {#Emph}Bewitching Eyes {#Prev}reveals a {#Emph}soulful{#Prev}, more {#Emph}vulnerable {#Prev}side of Scylla and the Sirens. But what do they know?"
      Speaker = "Scylla"
      Event = "ScyllaAboutBallad02"
    }
    {
      Id = "MelinoeField_4311"
      InheritFrom = "BaseNarrative"
      DisplayName = "I couldn't make out all the lyrics while fighting back you lot, but you sang of red and green bewitching eyes and love potions and such. Is this truly how you feel about me?"
      Speaker = "Melinoe"
      Event = "ScyllaAboutBallad02"
    }
    {
      Id = "Scylla_0440"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Pff, no! {#Prev}Why would I feel any of those things, especially about {#Emph}you{#Prev}, lady? It's called a {#Emph}fictionalized work? {#Prev}And besides, Jetty mostly wrote that one."
      Speaker = "Scylla"
      Event = "ScyllaAboutBallad02"
    }
    {
      Id = "MelinoeField_4312"
      InheritFrom = "BaseNarrative"
      DisplayName = "You truly expect me to believe that neither {#Emph}I Am Gonna Claw {#Prev}nor {#Emph}Bewitching Eyes {#Prev}concern our meetings? Though if you're drawn to me, you have an odd way of showing it."
      Speaker = "Melinoe"
      Event = "ScyllaAboutBallad03"
    }
    {
      Id = "Scylla_0441"
      InheritFrom = "BaseNarrative"
      DisplayName = "No way! {#Emph}You're {#Prev}the one who always shows up {#Emph}here{#Prev}, lady. You are obviously drawn to {#Emph}me! {#Prev}Or one or more of us. Jetty knows it, Roxy knows it, {#Emph}everyone {#Prev}in Oceanus knows it!"
      Speaker = "Scylla"
      Event = "ScyllaAboutBallad03"
    }
    {
      Id = "MelinoeField_4313"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh come on, Scylla. I'll admit I don't dislike your songs as much as I previously let on, but that's as far as I'll go."
      Speaker = "Melinoe"
      Event = "ScyllaAboutBallad03"
    }
    {
      Id = "Scylla_0442"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Aw{#Prev}, you hear that, gals? That's as far as she'll go! I {#Emph}told {#Prev}you. Now either {#Emph}she {#Prev}gets off this stage, or {#Emph}we {#Prev}do!"
      Speaker = "Scylla"
      Event = "ScyllaAboutBallad03"
    }
    {
      Id = "Scylla_0211"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't know what you did, lady, but lately, I can barely hear myself think... much less {#Emph}sing! {#Prev}I hate you, you {#Emph}witch! {#Prev}You {#Emph}better {#Prev}make it right!"
      Speaker = "Scylla"
      Event = "ScyllaAboutSongVolume01"
    }
    {
      Id = "MelinoeField_2719"
      InheritFrom = "BaseNarrative"
      DisplayName = "Or else what? I'll use what tactics I see fit. Not having to listen to you spout your nonsense makes it easier to send you back to the depths for the night."
      Speaker = "Melinoe"
      Event = "ScyllaAboutSongVolume01"
    }
    {
      Id = "Scylla_0212"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know you like our song. Can't live without it! And I will {#Emph}not {#Prev}be {#Emph}silenced! {#Prev}No matter what you do, I'll always be singing in {#Emph}my {#Prev}head, and {#Emph}yours!"
      Speaker = "Scylla"
      Event = "ScyllaAboutSongVolume01"
    }
    {
      Id = "Scylla_0018"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh hey gals, guess who?! It's the {#Emph}one that got away{#Prev}, that's who! {#Emph}Mm{#Prev}, something you ought to know about me, lady... is once I catch 'em... I never let 'em go."
      Speaker = "Scylla"
      Event = "ScyllaAboutChlams01"
    }
    {
      Id = "Melinoe_2037"
      InheritFrom = "BaseNarrative"
      DisplayName = "That comes as no surprise to me at all. Some sea creatures are famously clingy. Barnacles, chlams..."
      Speaker = "Melinoe"
      Event = "ScyllaAboutChlams01"
    }
    {
      Id = "Scylla_0019"
      InheritFrom = "BaseNarrative"
      DisplayName = "I am {#Emph}not {#Prev}a chlam!! You take that back. I'll {#Emph}make {#Prev}you take that back!"
      Speaker = "Scylla"
      Event = "ScyllaAboutChlams01"
    }
    {
      Id = "Melinoe_2038"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now, see here! I'd no intention to offend last time, and never said you {#Emph}were {#Prev}a chlam. The least you could do is base your anger in reality."
      Speaker = "Melinoe"
      Event = "ScyllaAboutChlams02"
    }
    {
      Id = "Scylla_0020"
      InheritFrom = "BaseNarrative"
      DisplayName = "Would you listen to that, gals, she's still talking about chlams! Poking fun at my little shell here, huh, {#Emph}hm-hm! {#Prev}Well, let's show her how we deal with hecklers 'round {#Emph}these {#Prev}parts!"
      Speaker = "Scylla"
      Event = "ScyllaAboutChlams02"
    }
    {
      Id = "Scylla_0026"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hohh, {#Prev}surprised to see us again, lady? {#Emph}Heh, {#Prev}'cause we're not going anywhere. This is our big {#Emph}comeback tour{#Prev}, after all!"
      Speaker = "Scylla"
      Event = "ScyllaAboutComeback01"
    }
    {
      Id = "Melinoe_2042"
      InheritFrom = "BaseNarrative"
      DisplayName = "I thought I dealt with you last time, yet here you are. Am I going to have to drive you back into the sea?"
      Speaker = "Melinoe"
      Event = "ScyllaAboutComeback01"
    }
    {
      Id = "Scylla_0027"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't know, am I going to have to tell Jetty and Roxy to {#Emph}play {#Prev}their hearts out? {#Emph}No{#Prev}, I'm not! 'Cause that's just what they do! {#Emph}Don't you{#Prev}, gals?"
      Speaker = "Scylla"
      Event = "ScyllaAboutComeback01"
    }
    {
      Id = "Scylla_0140"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ohh{#Prev}, you keep trying to {#Emph}kill {#Prev}me, lady! The former Sea-Nymph side of me says {#Emph}just forget it {#Prev}and move on! But, I don't like to listen to her anymore."
      Speaker = "Scylla"
      Event = "ScyllaAboutDying01"
    }
    {
      Id = "MelinoeField_2018"
      InheritFrom = "BaseNarrative"
      DisplayName = "That you don't listen to yourself explains a lot. I know better than to try and kill an Oceanid. I just need you to get out of my way."
      Speaker = "Melinoe"
      Event = "ScyllaAboutDying01"
    }
    {
      Id = "Scylla_0141"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hear that gals? I distinctly heard the lady say {#Emph}I need you {#Prev}there, {#Emph}hoho! {#Prev}Our art changes lives! What say we change {#Emph}this {#Prev}one right {#Emph}now...?"
      Speaker = "Scylla"
      Event = "ScyllaAboutDying01"
    }
    {
      Id = "Scylla_0209"
      InheritFrom = "BaseNarrative"
      DisplayName = "Look who got here way too early for tonight's show! Doors weren't meant to open yet, lady! Not that {#Emph}you {#Prev}care about this venue's very reasonable code of conduct."
      Speaker = "Scylla"
      Event = "ScyllaAboutPackagedBounties01"
    }
    {
      Id = "MelinoeField_2718"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh I'm familiar with the venue at this point. And if you aren't ready to perform yet, great! I don't really want to hear it from you anyway."
      Speaker = "Melinoe"
      Event = "ScyllaAboutPackagedBounties01"
    }
    {
      Id = "Scylla_0210"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, {#Emph}too bad! {#Prev}Because even though you're way too early, you are {#Emph}just {#Prev}in time for the private {#Emph}pre{#Prev}-show concert that was {#Emph}just about to start!"
      Speaker = "Scylla"
      Event = "ScyllaAboutPackagedBounties01"
    }
    {
      Id = "Scylla_0024"
      InheritFrom = "BaseNarrative"
      DisplayName = "So tell me, lady, {#Emph}how is it {#Prev}that you seem to know our tricks? Other than the part where we keep playing the same act. Usually it slays!"
      Speaker = "Scylla"
      Event = "ScyllaAboutOdysseus01"
    }
    {
      Id = "Melinoe_2041"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Great Tactician Odysseus says hello. Told me all about you. You claim you never let anybody get away, though {#Emph}I {#Prev}understand all but six of his hapless men got well away from you."
      Speaker = "Melinoe"
      Event = "ScyllaAboutOdysseus01"
    }
    {
      Id = "Scylla_0025"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Odysseus, hah! {#Prev}Oh, {#Emph}he's {#Prev}still on the hook! Big fish like that just {#Emph}takes a while to reel in{#Prev}, as he might say. Our song must still be bouncing around in his {#Emph}pretty {#Prev}little head! And now for yours..."
      Speaker = "Scylla"
      Event = "ScyllaAboutOdysseus01"
    }
    {
      Id = "Scylla_0303"
      InheritFrom = "BaseNarrative"
      DisplayName = "We know how come you keep on showing up here, don't we, lady? You're like Odysseus and {#Emph}all {#Prev}the rest! Though... what was with that Princess of the Underworld stuff he was going on about?"
      Speaker = "Scylla"
      Event = "ScyllaAboutOdysseus02"
    }
    {
      Id = "MelinoeField_3584"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nothing that you need concern yourself with at this point. So you think I keep returning because I love your music? Why wouldn't I just listen to it then, instead of fighting you?"
      Speaker = "Melinoe"
      Event = "ScyllaAboutOdysseus02"
    }
    {
      Id = "Scylla_0304"
      InheritFrom = "BaseNarrative"
      DisplayName = "Live music is an interactive experience. You don't just sit back and {#Emph}hear {#Prev}it! You {#Emph}immerse {#Prev}yourself in it... soak it in, {#Emph}ahaha! {#Prev}And you've been doing that more than {#Emph}just {#Prev}about anyone."
      Speaker = "Scylla"
      Event = "ScyllaAboutOdysseus02"
    }
    {
      Id = "MelinoeField_4354"
      InheritFrom = "BaseNarrative"
      DisplayName = "Scylla, would you mind if I put you in touch with a mutual acquaintance? It'll only be a moment. {#Emph}Heed now my voice, Odysseus; one whom you sought is here!"
      Speaker = "Melinoe"
      Event = "ScyllaAboutOdysseusQuest01"
    }
    {
      Id = "Scylla_0296"
      InheritFrom = "BaseNarrative"
      DisplayName = "I knew you'd come back, sailor. Once they hear our song, they always {#Emph}do! {#Prev}Unless they drown, and sometimes even after {#Emph}that. Ah{#Prev}, just had to get another listen, {#Emph}huh?"
      Speaker = "Scylla"
      Event = "ScyllaAboutOdysseusQuest01"
    }
    {
      Id = "Odysseus_0567"
      InheritFrom = "BaseNarrative"
      DisplayName = "Aye, Scylla, you and your Siren song left quite an impression on me in my mortal days! And I no longer wish to keep pretending otherwise."
      Speaker = "Odysseus"
      Event = "ScyllaAboutOdysseusQuest01"
    }
    {
      Id = "Scylla_0297"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, well if you want an earful, {#Emph}suit yourself! {#Prev}Nothing we'd rather do than please our longtime fans. I {#Emph}think {#Prev}some of your old crew's already in the crowd! The ones I {#Emph}took."
      Speaker = "Scylla"
      Event = "ScyllaAboutOdysseusQuest01"
    }
    {
      Id = "Odysseus_0568"
      InheritFrom = "BaseNarrative"
      DisplayName = "We had no choice but to sail past you, and good men gave their lives. But now the Princess of the Underworld shall give them all a show to remember!"
      Speaker = "Odysseus"
      Event = "ScyllaAboutOdysseusQuest01"
    }
    {
      Id = "Scylla_0298"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Princess of the Underworld... this {#Prev}lady? {#Emph}Hah! {#Prev}You always were the scheming sort and haven't changed a bit. Well then listen up, all of you..."
      Speaker = "Scylla"
      Event = "ScyllaAboutOdysseusQuest01"
    }
    {
      Id = "MelinoeField_4355"
      InheritFrom = "BaseNarrative"
      DisplayName = "I think a certain sailor would like another quick word! {#Emph}Heed now my voice, Odysseus; one whom you sought is here!"
      Speaker = "Melinoe"
      Event = "ScyllaAboutOdysseusQuest02"
    }
    {
      Id = "Scylla_0301"
      InheritFrom = "BaseNarrative"
      DisplayName = "How was our show for you last time, Odysseus, as good as you recall? It {#Emph}must {#Prev}have been if you're back here {#Emph}again. {#Prev}Not that you had much choice in the matter!"
      Speaker = "Scylla"
      Event = "ScyllaAboutOdysseusQuest02"
    }
    {
      Id = "Odysseus_0569"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm here because the Princess of the Underworld summoned me, Scylla. Though getting to hear your song again is a nice benefit. It's not my wish to delay your production so I'll be somewhere in the audience, all right?"
      Speaker = "Odysseus"
      Event = "ScyllaAboutOdysseusQuest02"
    }
    {
      Id = "Scylla_0302"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh you go right ahead, {#Emph}heh. {#Prev}We don't want everybody barging up on stage! Not with this {#Emph}Princess of the Underworld {#Prev}already soaking up all the {#Emph}spotlight!"
      Speaker = "Scylla"
      Event = "ScyllaAboutOdysseusQuest02"
    }
    {
      Id = "MelinoeField_3590"
      InheritFrom = "BaseNarrative"
      DisplayName = "If I may ask, who made you this way, Scylla? Because my understanding is that you weren't always, well... the way you are."
      Speaker = "Melinoe"
      Event = "ScyllaAboutCurse01"
    }
    {
      Id = "Scylla_0315"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh-hoh{#Prev}, I'm entirely self-made, {#Emph}thank you{#Prev}, lady! You think I'm going to attribute all my talent to {#Emph}somebody else? {#Prev}A {#Emph}wizened songmaster {#Prev}who taught me all I know?"
      Speaker = "Scylla"
      Event = "ScyllaAboutCurse01"
    }
    {
      Id = "MelinoeField_3591"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your musical talents being innate doesn't surprise me; I'm asking how did you become a sea-monster. Weren't you the victim of a curse?"
      Speaker = "Melinoe"
      Event = "ScyllaAboutCurse01"
    }
    {
      Id = "Scylla_0316"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hah! Oh{#Prev}, something you wouldn't understand is, the more famous you get, the more they're going to say about ya! Because they're {#Emph}jealous! {#Prev}I let all of it {#Emph}roll {#Prev}off my shell. No good artist lets a random lie or {#Emph}insult {#Prev}get to them!"
      Speaker = "Scylla"
      Event = "ScyllaAboutCurse01"
    }
    {
      Id = "MelinoeField_3592"
      InheritFrom = "BaseNarrative"
      DisplayName = "Are you familiar with the enchantress Circe? She mentioned that she knew you in her youth... though, I'm uncertain if you were on friendly terms."
      Speaker = "Melinoe"
      Event = "ScyllaAboutCirce01"
    }
    {
      Id = "Scylla_0317"
      InheritFrom = "BaseNarrative"
      DisplayName = "The {#Emph}enchantress {#Prev}Circe, no that doesn't ring a bell! The only Circe {#Emph}I {#Prev}knew was the talentless pathetic little runt of the litter of Helios himself! What has this {#Emph}other {#Prev}Circe got to say?"
      Speaker = "Scylla"
      Event = "ScyllaAboutCirce01"
    }
    {
      Id = "MelinoeField_3593"
      InheritFrom = "BaseNarrative"
      DisplayName = "She gave me the impression you were always rather boisterous, even back then. Perhaps already practicing the kinds of songs you think shall bring you fame."
      Speaker = "Melinoe"
      Event = "ScyllaAboutCirce01"
    }
    {
      Id = "Scylla_0318"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's no secret I always knew what I wanted to be, lady. Always knew what I was {#Emph}meant {#Prev}to be! Circe and so many others... all they ever did was get in my {#Emph}way! Same as you."
      Speaker = "Scylla"
      Event = "ScyllaAboutCirce01"
    }
    {
      Id = "Scylla_0197"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, if it isn't the little name-dropper! Off to see your good friend Mister Chronos again, {#Emph}hm? {#Prev}He {#Emph}loves {#Prev}our act! You'll {#Emph}drown {#Prev}before you take his sponsorship away from us!"
      Speaker = "Scylla"
      Event = "ScyllaAboutChronos01"
    }
    {
      Id = "MelinoeField_2558"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh I'm not after any sponsorships from him. And we're {#Emph}not {#Prev}friends. We merely have some business to resolve... which {#Emph}you {#Prev}continue to impede night after night."
      Speaker = "Melinoe"
      Event = "ScyllaAboutChronos01"
    }
    {
      Id = "Scylla_0198"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Business? {#Prev}With {#Emph}him? {#Prev}Then you must be somebody's kid, no {#Emph}way {#Prev}you'd have connections like that on your own! You know, some of us had to {#Emph}earn {#Prev}our spotlight, lady!"
      Speaker = "Scylla"
      Event = "ScyllaAboutChronos01"
    }
    {
      Id = "Scylla_0199"
      InheritFrom = "BaseNarrative"
      DisplayName = "Gonna level with you, lady. We can't have you bugging Mister Chronos {#Emph}every night! {#Prev}He doesn't pay much attention to our venue here, and we want to {#Emph}keep {#Prev}it that way."
      Speaker = "Scylla"
      Event = "ScyllaAboutChronos02"
    }
    {
      Id = "MelinoeField_2559"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't think Chronos is concerned with you at all. So maybe back off, focus on your songwriting, instead of trying to asphyxiate me constantly?"
      Speaker = "Melinoe"
      Event = "ScyllaAboutChronos02"
    }
    {
      Id = "Scylla_0200"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh she just doesn't get it, gals! But don't worry. They're {#Emph}never {#Prev}gonna shut us down, not while we keep on drawing crowds like {#Emph}this! {#Prev}It's {#Emph}good publicity!"
      Speaker = "Scylla"
      Event = "ScyllaAboutChronos02"
    }
    {
      Id = "Scylla_0338"
      InheritFrom = "BaseNarrative"
      DisplayName = "By now, every single soul in Oceanus knows our name, lady! Especially {#Emph}mine! {#Prev}For all your efforts to defame us, all you've accomplished is the opposite!"
      Speaker = "Scylla"
      Event = "ScyllaAboutNarcissus01"
    }
    {
      Id = "MelinoeField_3606"
      InheritFrom = "BaseNarrative"
      DisplayName = "At the risk of arguing over a technicality, I've met at least one soul in Oceanus who couldn't care less about your act. He'd much rather stare into a shallow pool than listen to you."
      Speaker = "Melinoe"
      Event = "ScyllaAboutNarcissus01"
    }
    {
      Id = "Scylla_0339"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Well{#Prev}, we can't please everyone, can we? We'd be giving up all our {#Emph}integrity {#Prev}if we even {#Emph}tried... {#Prev}something {#Emph}you {#Prev}wouldn't know the first thing about!"
      Speaker = "Scylla"
      Event = "ScyllaAboutNarcissus01"
    }
    {
      Id = "Scylla_0340"
      InheritFrom = "BaseNarrative"
      DisplayName = "There's a lot to like about this part of Oceanus, don't you think? The acoustics are the {#Emph}perfect {#Prev}blend of {#Emph}land {#Prev}and {#Emph}sea... {#Prev}and that {#Emph}Poseidon {#Prev}has no control over {#Emph}any {#Prev}of it!"
      Speaker = "Scylla"
      Event = "ScyllaAboutPoseidon01"
    }
    {
      Id = "MelinoeField_3607"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're taking advantage of this place being past the border of the realm beneath the Earth. I don't think Lord Poseidon would appreciate that, should you ever return to his waters."
      Speaker = "Melinoe"
      Event = "ScyllaAboutPoseidon01"
    }
    {
      Id = "Scylla_0341"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ohh{#Prev}, if we ever go back to {#Emph}his {#Prev}waters, we'll be {#Emph}so {#Prev}big that he wouldn't {#Emph}dare {#Prev}mess with us! He or {#Emph}any {#Prev}of the gods! Wherever we go, we're gonna be the {#Emph}main attraction."
      Speaker = "Scylla"
      Event = "ScyllaAboutPoseidon01"
    }
    {
      Id = "Scylla_0203"
      InheritFrom = "BaseNarrative"
      DisplayName = "We used to play the {#Emph}surface{#Prev}, you know! That's when we {#Emph}really {#Prev}started to hit it big! Even had {#Emph}Charybdis {#Prev}open for us a few times, can you imagine?"
      Speaker = "Scylla"
      Event = "ScyllaAboutCharybdis01"
    }
    {
      Id = "MelinoeField_2561"
      InheritFrom = "BaseNarrative"
      DisplayName = "So what? Charybdis opened for me just the other night. I practically couldn't get it to shut up!"
      Speaker = "Melinoe"
      Event = "ScyllaAboutCharybdis01"
    }
    {
      Id = "Scylla_0204"
      InheritFrom = "BaseNarrative"
      DisplayName = "Like I believe {#Emph}that! {#Prev}Though I bet you {#Emph}are {#Prev}from up there, aren't you? You think you're underground, like us, but you'll {#Emph}always {#Prev}be {#Emph}mainstream!"
      Speaker = "Scylla"
      Event = "ScyllaAboutCharybdis01"
    }
    {
      Id = "MelinoeField_3598"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sharing the spotlight seems unlike you, Scylla. How will you make a name for yourself if you keep collaborating with a bigger performer like Charybdis? "
      Speaker = "Melinoe"
      Event = "ScyllaAboutCharybdis02"
    }
    {
      Id = "Scylla_0328"
      InheritFrom = "BaseNarrative"
      DisplayName = "Charybdis has the bigger {#Emph}mouth {#Prev}all right, but {#Emph}we {#Prev}got a pretty different act. Sailors often can't decide {#Emph}which {#Prev}of us they like more, so... we figured: Why not let them have both?"
      Speaker = "Scylla"
      Event = "ScyllaAboutCharybdis02"
    }
    {
      Id = "MelinoeField_3599"
      InheritFrom = "BaseNarrative"
      DisplayName = "This also doesn't strike me as the simplest creative partnership. Yet you're working together, to please your audience, or simply to stop {#Emph}me. {#Prev}I'm almost impressed."
      Speaker = "Melinoe"
      Event = "ScyllaAboutCharybdis02"
    }
    {
      Id = "Scylla_0329"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, words we very often hear, yet always mean {#Emph}so {#Prev}much! Especially from our {#Emph}harshest {#Prev}detractors! Won't stop us from trying to drown you like always, lady... but {#Emph}thanks."
      Speaker = "Scylla"
      Event = "ScyllaAboutCharybdis02"
    }
    {
      Id = "Scylla_0189"
      InheritFrom = "BaseNarrative"
      DisplayName = "See anything you like in our greenroom down there, {#Emph}hm? {#Prev}Maybe you didn't notice the sign but that's our {#Emph}private {#Prev}little area where fans are {#Emph}not supposed to go!"
      Speaker = "Scylla"
      Event = "ScyllaAboutGreenRoom01"
    }
    {
      Id = "MelinoeField_2554"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your so-called {#Emph}greenroom {#Prev}happens to be built atop a drain that spills into the Mourning Fields below. You could always flush your sorry work down {#Emph}there{#Prev}, where it'll fit right in."
      Speaker = "Melinoe"
      Event = "ScyllaAboutGreenRoom01"
    }
    {
      Id = "Scylla_0190"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ohh{#Prev}, you went looking through our {#Emph}work! {#Prev}So what if a few ideas go unused here and there? If you don't {#Emph}cut... {#Prev}you never get to the {#Emph}good stuff."
      Speaker = "Scylla"
      Event = "ScyllaAboutGreenRoom01"
    }
    {
      Id = "Scylla_0434"
      InheritFrom = "BaseNarrative"
      DisplayName = "Go on and heckle us, lady! We're {#Emph}big{#Prev}, we've got thick scales! {#Emph}Scylla's got a voice like yelping dogs! Her lustrous hair looks like a bunch of snakey heads! {#Prev}We've heard it all!"
      Speaker = "Scylla"
      Event = "ScyllaAboutRumors01"
    }
    {
      Id = "MelinoeField_4307"
      InheritFrom = "BaseNarrative"
      DisplayName = "I wasn't going to say any of those things, which strike me as bizarre. Perhaps if you didn't antagonize your audience so much, they'd be more charitable."
      Speaker = "Melinoe"
      Event = "ScyllaAboutRumors01"
    }
    {
      Id = "Scylla_0435"
      InheritFrom = "BaseNarrative"
      DisplayName = "Their words roll {#Emph}right {#Prev}off our backs! At least {#Emph}mine. {#Prev}I only care about their {#Emph}cheers {#Prev}and their {#Emph}screams... {#Prev}which all start to sound the same after a while..."
      Speaker = "Scylla"
      Event = "ScyllaAboutRumors01"
    }
    {
      Id = "Scylla_0201"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ohh{#Prev}, it's only {#Emph}you! {#Prev}Not just another one of those sailors we've been seeing more and more of lately here. Look at this {#Emph}crowd! {#Prev}We've been causing a {#Emph}real {#Prev}stir!"
      Speaker = "Scylla"
      Event = "ScyllaAboutThessaly01"
    }
    {
      Id = "MelinoeField_2560"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps those sailors are just remnants of the sunken fleet that Chronos sends against the gods. I've had my scuffles with them recently."
      Speaker = "Melinoe"
      Event = "ScyllaAboutThessaly01"
    }
    {
      Id = "Scylla_0202"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh no, I don't think so, lady. Our fame is due to good old fashioned word-of-mouth! And there is {#Emph}nothing {#Prev}you can do to {#Emph}stop {#Prev}it now!"
      Speaker = "Scylla"
      Event = "ScyllaAboutThessaly01"
    }
    {
      Id = "Scylla_0191"
      InheritFrom = "BaseNarrative"
      DisplayName = "Roxy, and Jetty, and I... we've been through bigger slumps than this, lady. It's gonna take more than your heckling to tear {#Emph}us {#Prev}apart!"
      Speaker = "Scylla"
      Event = "ScyllaAboutSlump01"
    }
    {
      Id = "MelinoeField_2555"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't know why I bother with you, Scylla. Or why Roxy and Jetty do! You've yet to let either one of them speak."
      Speaker = "Melinoe"
      Event = "ScyllaAboutSlump01"
    }
    {
      Id = "Scylla_0192"
      InheritFrom = "BaseNarrative"
      DisplayName = "They {#Emph}speak {#Prev}through their {#Emph}work! {#Prev}Besides I'm not just lead singer, I'm in charge of the talent! And the gals aren't taking interviews right now, especially from the likes of {#Emph}you!"
      Speaker = "Scylla"
      Event = "ScyllaAboutSlump01"
    }
    {
      Id = "Scylla_0193"
      InheritFrom = "BaseNarrative"
      DisplayName = "In my meeting with the gals the other night, we got to talking, {#Emph}I was talking mostly{#Prev}, but we started wondering what is your {#Emph}deal? {#Prev}Jetty thinks maybe you're an {#Emph}agent?"
      Speaker = "Scylla"
      Event = "ScyllaAboutAgents01"
    }
    {
      Id = "MelinoeField_2556"
      InheritFrom = "BaseNarrative"
      DisplayName = "Jetty is rather perceptive, then... for I am indeed an agent of Night. This realm has fallen to the Titan; we shall see it restored to its rightful rule. No matter who gets in our way."
      Speaker = "Melinoe"
      Event = "ScyllaAboutAgents01"
    }
    {
      Id = "Scylla_0194"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can't believe it, Jetty, you were {#Emph}right? {#Prev}An agent on the hunt! Well your search is over, Agent Lady, because {#Emph}you {#Prev}won't find a bigger talent in the sea or out! Just {#Emph}watch!"
      Speaker = "Scylla"
      Event = "ScyllaAboutAgents01"
    }
    {
      Id = "Scylla_0336"
      InheritFrom = "BaseNarrative"
      DisplayName = "Agent Lady, welcome {#Emph}back! {#Prev}So who's this {#Emph}Night {#Prev}you're working for, and who else has she signed? She sounds intense."
      Speaker = "Scylla"
      Event = "ScyllaAboutAgents01_2"
    }
    {
      Id = "MelinoeField_3605"
      InheritFrom = "BaseNarrative"
      DisplayName = "I spoke of the one and only Night, whose presence fills the Underworld and surface. She is one of the eldest primordial powers; yet the Titan Chronos thought he could stop her."
      Speaker = "Melinoe"
      Event = "ScyllaAboutAgents01_2"
    }
    {
      Id = "Scylla_0337"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ooh{#Prev}, sounds like some {#Emph}healthy competition! {#Prev}Well, if this Night {#Emph}really {#Prev}wants us to sign with her, she'd better make a {#Emph}good offer! {#Prev}Else Mister Chronos might snatch up all the talent!"
      Speaker = "Scylla"
      Event = "ScyllaAboutAgents01_2"
    }
    {
      Id = "Scylla_0195"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're not really an agent, are you, lady? Just pulling our fins, trying to get our hopes up, only to {#Emph}dash {#Prev}them against the rocks! How low can you {#Emph}sink?"
      Speaker = "Scylla"
      Event = "ScyllaAboutAgents02"
    }
    {
      Id = "MelinoeField_2557"
      InheritFrom = "BaseNarrative"
      DisplayName = "Get your hopes up? Listen to me: I seek {#Emph}Chronos{#Prev}, not you. Perhaps you shall be hunted by some other agent, though."
      Speaker = "Melinoe"
      Event = "ScyllaAboutAgents02"
    }
    {
      Id = "Scylla_0196"
      InheritFrom = "BaseNarrative"
      DisplayName = "You better believe it, gals! Even {#Emph}this {#Prev}lady knows a rising star when she sees one. When she {#Emph}hears {#Prev}one! And she's gonna put in a good word for us, {#Emph}won't she?"
      Speaker = "Scylla"
      Event = "ScyllaAboutAgents02"
    }
    {
      Id = "Scylla_0028"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh no, you're bleeding. Trouble finding the place? Don't worry, gals. One day? They'll put us up on the biggest stage, for {#Emph}all the world to see!"
      Speaker = "Scylla"
      Event = "ScyllaLowHealth01"
    }
    {
      Id = "Melinoe_2043"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm not particularly interested in listening to your delusions of grandeur right now, so why not start your little song."
      Speaker = "Melinoe"
      Event = "ScyllaLowHealth01"
    }
    {
      Id = "Scylla_0029"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, it may be a little song to you {#Emph}now{#Prev}, lady. But it's going to be huge someday. You'll see. We'll show her, won't we, gals?"
      Speaker = "Scylla"
      Event = "ScyllaLowHealth01"
    }
    {
      Id = "Scylla_0030"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh you know, this is a reputable venue, lady, and we {#Emph}do {#Prev}impose a dress code at the door, {#Emph}hm-hm! {#Prev}Oh, but you come barging in, looking like hell."
      Speaker = "Scylla"
      Event = "ScyllaLowHealth02"
    }
    {
      Id = "Melinoe_2044"
      InheritFrom = "BaseNarrative"
      DisplayName = "You sea-dwellers are not so welcoming to strangers in your habitat. Thus I'm a bit unkempt. And a bit low on patience..."
      Speaker = "Melinoe"
      Event = "ScyllaLowHealth02"
    }
    {
      Id = "Scylla_0031"
      InheritFrom = "BaseNarrative"
      DisplayName = "Got that old sinking feeling, huh? Then let's not keep her waiting any longer, gals! {#Emph}Hit it!"
      Speaker = "Scylla"
      Event = "ScyllaLowHealth02"
    }
    {
      Id = "Scylla_0032"
      InheritFrom = "BaseNarrative"
      DisplayName = "The sea can be a dangerous place if you don't know your way around, lady! {#Emph}Ohoho! {#Prev}Though it looks like you figured that out all on your own!"
      Speaker = "Scylla"
      Event = "ScyllaLowHealth03"
    }
    {
      Id = "Melinoe_2045"
      InheritFrom = "BaseNarrative"
      DisplayName = "Everything is damp, and reeks to the heavens. And now I'm forced to listen to {#Emph}your {#Prev}snide remarks. And your insufferable song, I suppose?"
      Speaker = "Melinoe"
      Event = "ScyllaLowHealth03"
    }
    {
      Id = "Scylla_0033"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're damn right! And we'll {#Emph}keep {#Prev}playing our song until it's {#Emph}pitch perfect{#Prev}. It's a work in progress. So don't hold your breath..."
      Speaker = "Scylla"
      Event = "ScyllaLowHealth03"
    }
    {
      Id = "Scylla_0034"
      InheritFrom = "BaseNarrative"
      DisplayName = "Aw lookit, gals, she's hurt! She's already hurt {#Emph}real bad{#Prev}. Maybe we could ease her passing with a little {#Emph}music{#Prev}, huh?"
      Speaker = "Scylla"
      Event = "ScyllaLowHealth04"
    }
    {
      Id = "Melinoe_2046"
      InheritFrom = "BaseNarrative"
      DisplayName = "I assure you any pain I'm experiencing is nothing compared with the pain I'll inflict on {#Emph}you {#Prev}if you continue to cross me."
      Speaker = "Melinoe"
      Event = "ScyllaLowHealth04"
    }
    {
      Id = "Scylla_0035"
      InheritFrom = "BaseNarrative"
      DisplayName = "Still got some fight left in you, huh? Well good, 'cause we just hate a passive audience! Come on, get in the pit, lady! The show's about to start!"
      Speaker = "Scylla"
      Event = "ScyllaLowHealth04"
    }
    {
      Id = "Scylla_0305"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's been {#Emph}so {#Prev}nice without {#Emph}you {#Prev}recently, lady! We've been playing our {#Emph}full {#Prev}set list night after night, {#Emph}no {#Prev}technical difficulties! Even had more and more {#Emph}sailors {#Prev}dropping in!"
      Speaker = "Scylla"
      Event = "ScyllaAboutNoShow01"
    }
    {
      Id = "MelinoeField_3585"
      InheritFrom = "BaseNarrative"
      DisplayName = "Those sailors dropping in are probably the Titan's naval forces I've been vanquishing throughout the Rift of Thessaly above. I think I recognize a few out in the stands."
      Speaker = "Melinoe"
      Event = "ScyllaAboutNoShow01"
    }
    {
      Id = "Scylla_0306"
      InheritFrom = "BaseNarrative"
      DisplayName = "You expect me to believe you've been promoting our events? We're getting lots of word-of-mouth lately, sure, but you've had {#Emph}nothing {#Prev}to {#Emph}do {#Prev}with it! Except by going {#Emph}away!"
      Speaker = "Scylla"
      Event = "ScyllaAboutNoShow01"
    }
    {
      Id = "Scylla_0307"
      InheritFrom = "BaseNarrative"
      DisplayName = "The gals and I decided recently, we need a {#Emph}product line! {#Prev}Authentic tokens of our {#Emph}breathtaking {#Prev}performances our fans can purchase for a reasonable price after the show! But we can't sell them with {#Emph}you {#Prev}getting in our way."
      Speaker = "Scylla"
      Event = "ScyllaAboutMerch01"
    }
    {
      Id = "MelinoeField_3586"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're the ones getting in {#Emph}my {#Prev}way! I never chose to have these fights! What do I care if you sell wall-scrolls and such to audience members who have resources to spare?"
      Speaker = "Melinoe"
      Event = "ScyllaAboutMerch01"
    }
    {
      Id = "Scylla_0308"
      InheritFrom = "BaseNarrative"
      DisplayName = "How did {#Emph}you {#Prev}know that we offer wall-scrolls? {#Emph}Oh, hohohoh! {#Prev}You probably already got some of our merchandise and want it {#Emph}all to yourself! {#Prev}Well, if you want special treatment, {#Emph}come get it!"
      Speaker = "Scylla"
      Event = "ScyllaAboutMerch01"
    }
    {
      Id = "Scylla_0311"
      InheritFrom = "BaseNarrative"
      DisplayName = "This is gonna be our night! Can't you just {#Emph}feel {#Prev}it, gals? Don't know about you all but {#Emph}I {#Prev}am feeling even more {#Emph}unstoppable {#Prev}than normal! {#Emph}Ohh{#Prev}, and just in {#Emph}time..."
      Speaker = "Scylla"
      Event = "ScyllaAboutShrine01"
    }
    {
      Id = "MelinoeField_3588"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh you're still stoppable, although the will of Night has made you stronger, yes. Shall we find out to what extent?"
      Speaker = "Melinoe"
      Event = "ScyllaAboutShrine01"
    }
    {
      Id = "Scylla_0312"
      InheritFrom = "BaseNarrative"
      DisplayName = "Stoppable? {#Emph}Ahaha. Us? {#Prev}You don't get it, lady. We've never missed a single show, and we are {#Emph}not {#Prev}about to start! {#Emph}Oh{#Prev}, of course with live performances, there's no telling what might happen..."
      Speaker = "Scylla"
      Event = "ScyllaAboutShrine01"
    }
    {
      Id = "Scylla_0313"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ooh! {#Prev}So glad you just decided to show up, lady, because you're really in for it tonight! We're {#Emph}fresh {#Prev}from rehearsing our {#Emph}best {#Prev}moves and can't {#Emph}wait {#Prev}to try them in concert...!"
      Speaker = "Scylla"
      Event = "ScyllaAboutShrine02"
    }
    {
      Id = "MelinoeField_3589"
      InheritFrom = "BaseNarrative"
      DisplayName = "Go on and do it, then. Though I already know all the ways in which you're going to be stronger than you used to be."
      Speaker = "Melinoe"
      Event = "ScyllaAboutShrine02"
    }
    {
      Id = "Scylla_0314"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're just saying that to try and hurt us before we hurt {#Emph}you! {#Prev}An artist's job is to {#Emph}enthrall {#Prev}her audience... and we can't {#Emph}do {#Prev}that just by doing things the same old way, {#Emph}can {#Prev}we?"
      Speaker = "Scylla"
      Event = "ScyllaAboutShrine02"
    }
    {
      Id = "Scylla_0319"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Aww{#Prev}, lookit gals, our number one {#Emph}obsessive {#Prev}fan, come to ruin our show for {#Emph}everybody else! {#Prev}One day, we'll get our own {#Emph}big {#Prev}security team to {#Emph}take care {#Prev}of little incidents like this."
      Speaker = "Scylla"
      Event = "ScyllaAboutShrineBounty01"
    }
    {
      Id = "MelinoeField_3594"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've little choice but to ruin your shows since you refuse to let me by... though this time at least I'm here for you, Scylla. The will of Night demands it."
      Speaker = "Melinoe"
      Event = "ScyllaAboutShrineBounty01"
    }
    {
      Id = "Scylla_0320"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh well that figures. Can't make it big without making some enemies! Well, our audience likes our shows no {#Emph}matter {#Prev}what happens. Like {#Emph}real {#Prev}fans! So {#Emph}do your worst, lady."
      Speaker = "Scylla"
      Event = "ScyllaAboutShrineBounty01"
    }
    {
      Id = "Scylla_0321"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Whew{#Prev}, got a good feeling about this evening's show, how about you gals? The crowd is {#Emph}all worked up! {#Prev}And look who else...!"
      Speaker = "Scylla"
      Event = "ScyllaAboutShrineBounty02"
    }
    {
      Id = "MelinoeField_3595"
      InheritFrom = "BaseNarrative"
      DisplayName = "You likely sense the Testament of Night; those who threaten the Underworld are to be cast into obscurity. Such is law."
      Speaker = "Melinoe"
      Event = "ScyllaAboutShrineBounty02"
    }
    {
      Id = "Scylla_0322"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Obscurity? {#Prev}We've never been {#Emph}bigger! {#Prev}And our stars are rising with each and every performance. And we're about to make {#Emph}this {#Prev}one to remember!"
      Speaker = "Scylla"
      Event = "ScyllaAboutShrineBounty02"
    }
    {
      Id = "Scylla_0330"
      InheritFrom = "BaseNarrative"
      DisplayName = "You better {#Emph}work {#Prev}with us tonight, lady! There's a potential sponsor somewhere in the stands so we have {#Emph}got {#Prev}to put on a {#Emph}big show! {#Prev}Bigger than when you beat us normally."
      Speaker = "Scylla"
      Event = "ScyllaAboutDiving01"
    }
    {
      Id = "MelinoeField_3600"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm not here to contribute to your misguided attempts to earn stardom, or sponsorships for that matter. You truly thought I'd let you beat me just because you asked?"
      Speaker = "Melinoe"
      Event = "ScyllaAboutDiving01"
    }
    {
      Id = "Scylla_0331"
      InheritFrom = "BaseNarrative"
      DisplayName = "I {#Emph}truly thought {#Prev}that you might have a shred of {#Emph}decency! {#Prev}Look, we are gonna start our {#Emph}song {#Prev}now, as we try to {#Emph}drown {#Prev}you, so just think about letting me and the gals {#Emph}have {#Prev}this one!"
      Speaker = "Scylla"
      Event = "ScyllaAboutDiving01"
    }
    {
      Id = "MelinoeField_3601"
      InheritFrom = "BaseNarrative"
      DisplayName = "So did you get the sponsorship the other night? I still feel ashamed for losing to you last time simply because you asked somewhat nicely. There had better be some upside."
      Speaker = "Melinoe"
      Event = "ScyllaAboutDiving02"
    }
    {
      Id = "Scylla_0332"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ooh-hoo-hoo{#Prev}, we got our sponsorship all right, {#Emph}hmhm...! {#Prev}At least, we will eventually. Apparently our sponsor showed up just to see us take a {#Emph}dive! {#Prev}Since {#Emph}you've {#Prev}been messing up our {#Emph}shows {#Prev}night after night!"
      Speaker = "Scylla"
      Event = "ScyllaAboutDiving02"
    }
    {
      Id = "MelinoeField_3602"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're saying I let you beat me for absolutely {#Emph}no reason?"
      Speaker = "Melinoe"
      Event = "ScyllaAboutDiving02"
    }
    {
      Id = "Scylla_0333"
      InheritFrom = "BaseNarrative"
      DisplayName = "You didn't let us beat you, you just {#Emph}lost! {#Prev}You're getting soft and easier to drown. {#Emph}You {#Prev}don't have what it {#Emph}takes {#Prev}to succeed in this business! But {#Emph}we {#Prev}do."
      Speaker = "Scylla"
      Event = "ScyllaAboutDiving02"
    }
    {
      Id = "MelinoeField_3603"
      InheritFrom = "BaseNarrative"
      DisplayName = "So did you end up getting the sponsorship the other night? If your benefactor is interested in supporting you, they may as well know of your propensity to lose to me."
      Speaker = "Melinoe"
      Event = "ScyllaAboutDiving02_B"
    }
    {
      Id = "Scylla_0334"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ohh {#Prev}we got our sponsorship all right! Our sponsor showed up {#Emph}just {#Prev}to see us take a dive, since {#Emph}you've {#Prev}been messing up our shows night after night. And they {#Emph}loved {#Prev}what they saw!"
      Speaker = "Scylla"
      Event = "ScyllaAboutDiving02_B"
    }
    {
      Id = "MelinoeField_3604"
      InheritFrom = "BaseNarrative"
      DisplayName = "But you had asked me to hold back; to let you win. Your sponsor {#Emph}wanted {#Prev}you to lose?"
      Speaker = "Melinoe"
      Event = "ScyllaAboutDiving02_B"
    }
    {
      Id = "Scylla_0335"
      InheritFrom = "BaseNarrative"
      DisplayName = "Our sponsor wanted an {#Emph}authentic performance{#Prev}, and that's {#Emph}exactly {#Prev}what we delivered! What we're {#Emph}always {#Prev}going to deliver from now on! So {#Emph}do your worst{#Prev}, lady."
      Speaker = "Scylla"
      Event = "ScyllaAboutDiving02_B"
    }
    {
      Id = "Scylla_0323"
      InheritFrom = "BaseNarrative"
      DisplayName = "Last time you crashed our show so fast the crowd was left {#Emph}pretty upset{#Prev}, lady! They {#Emph}hardly {#Prev}got to hear our {#Emph}song!"
      Speaker = "Scylla"
      Event = "ScyllaQuickMatch01"
    }
    {
      Id = "MelinoeField_3596"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your concert would perhaps get a more rousing response if you let me pass. Otherwise it's liable to end abruptly again."
      Speaker = "Melinoe"
      Event = "ScyllaQuickMatch01"
    }
    {
      Id = "Scylla_0324"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ohoho{#Prev}, you don't know the {#Emph}first {#Prev}thing about theatrics! We want our crowd to experience a {#Emph}full {#Prev}range of emotions! So if that means {#Emph}occasional crushing disappointment{#Prev}, so be it...!"
      Speaker = "Scylla"
      Event = "ScyllaQuickMatch01"
    }
    {
      Id = "Scylla_0325"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh {#Prev}we won't let you make short work of us again, lady! So why don't you take your {#Emph}time! {#Prev}Bask in the atmosphere while we {#Emph}drown you in it!!"
      Speaker = "Scylla"
      Event = "ScyllaQuickMatch02"
    }
    {
      Id = "Scylla_0326"
      InheritFrom = "BaseNarrative"
      DisplayName = "We didn't get even a little {#Emph}nibble {#Prev}on you last you showed your face here, lady. I've been trying to console Roxy ever since! But it's no {#Emph}use!"
      Speaker = "Scylla"
      Event = "ScyllaNoHitMatch01"
    }
    {
      Id = "MelinoeField_3597"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps if Roxy learned some new percussive patterns she'd have an easier time hitting me against my will."
      Speaker = "Melinoe"
      Event = "ScyllaNoHitMatch01"
    }
    {
      Id = "Scylla_0327"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sure, try and tear us down all you like. But we're just gonna build back up, {#Emph}stronger than ever! {#Prev}And {#Emph}then! {#Prev}We'll bite your head clean off."
      Speaker = "Scylla"
      Event = "ScyllaNoHitMatch01"
    }
    {
      Id = "Scylla_0028_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't worry, gals. One day? They'll put us up on the biggest stage, for {#Emph}all the world to see!"
      Speaker = "Scylla"
      Event = "ScyllaAboutGrandeur01"
    }
    {
      Id = "Scylla_0342"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hey... maybe {#Emph}you {#Prev}know, lady! What happened to Mister Chronos? Lately he stopped answering our calls, {#Emph}heh. {#Prev}He's probably just taking a little break!"
      Speaker = "Scylla"
      Event = "ScyllaPostTrueEnding01"
    }
    {
      Id = "MelinoeField_4122"
      InheritFrom = "BaseNarrative"
      DisplayName = "You could say that. Lord Hades has returned as rightful ruler of the Underworld, which means Chronos now can attend to other matters. He'll likely get back to you."
      Speaker = "Melinoe"
      Event = "ScyllaPostTrueEnding01"
    }
    {
      Id = "Scylla_0343"
      InheritFrom = "BaseNarrative"
      DisplayName = "What are you, his {#Emph}personal assistant? Of course {#Prev}he's getting back to us! And if he's paying no attention to what happens in our venue in the meantime, {#Emph}even better."
      Speaker = "Scylla"
      Event = "ScyllaPostTrueEnding01"
    }
    {
      Id = "Scylla_0443"
      InheritFrom = "BaseNarrative"
      DisplayName = "Still haven't heard from Mister Chronos lately. Have you seen him anywhere, lady? Because his sponsorship seems to have fizzled out... good thing we {#Emph}do {#Prev}have others."
      Speaker = "Scylla"
      Event = "ScyllaPostTrueEnding02"
    }
    {
      Id = "MelinoeField_4314"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lately Chronos has been over at the Isles of the Blessed. Off doing other things, like perhaps you should be. Who else is underwriting these performances of yours?"
      Speaker = "Melinoe"
      Event = "ScyllaPostTrueEnding02"
    }
    {
      Id = "Scylla_0444"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nobody you'd know, I'm sure! And what with all the changes lately, this venue isn't taking on new acts. You're stuck with only {#Emph}me, forever! {#Prev}Me and the gals."
      Speaker = "Scylla"
      Event = "ScyllaPostTrueEnding02"
    }
    {
      Id = "Scylla_0445"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Stop! {#Prev}Don't say {#Emph}anything{#Prev}, lady, it's impolite to talk during the show in case you hadn't noticed! I'm through listening to {#Emph}you {#Prev}anyway! But definitely not the {#Emph}other {#Prev}way around."
      Speaker = "Scylla"
      Event = "ScyllaAboutSayingLittle01"
    }
    {
      Id = "Scylla_0036"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Lookit, gals! {#Prev}We've got ourselves a {#Emph}crowd! {#Prev}Oh, let's knock \n'em {#Emph}dead{#Prev}, what do you say?"
      Speaker = "Scylla"
      Event = "ScyllaMiscStart01"
    }
    {
      Id = "Scylla_0037"
      InheritFrom = "BaseNarrative"
      DisplayName = "All right. All right, gals, this is it, this is the big one! Our {#Emph}big break. {#Prev}Right here!!"
      Speaker = "Scylla"
      Event = "ScyllaMiscStart02"
    }
    {
      Id = "Scylla_0038"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ooh{#Prev}, hey lady! We've been {#Emph}practicing! {#Prev}You want to hear our latest jam?"
      Speaker = "Scylla"
      Event = "ScyllaMiscStart03"
    }
    {
      Id = "Scylla_0039"
      InheritFrom = "BaseNarrative"
      DisplayName = "You {#Emph}love {#Prev}a good show, don't you, lady? And we {#Emph}love {#Prev}to satisfy our fans! Don't we, gals?"
      Speaker = "Scylla"
      Event = "ScyllaMiscStart04"
    }
    {
      Id = "Scylla_0040"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's the power of our songs, gals! Once they {#Emph}hear {#Prev}'em, they can't tear themselves away...!"
      Speaker = "Scylla"
      Event = "ScyllaMiscStart05"
    }
    {
      Id = "Scylla_0041"
      InheritFrom = "BaseNarrative"
      DisplayName = "You just don't know when to {#Emph}quit{#Prev}, lady. Us neither! Hit it, gals!"
