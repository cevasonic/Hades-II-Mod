      Event = "ScyllaMiscStart10"
    }
    {
      Id = "Scylla_0046"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Mm{#Prev}, don't normally play private events... but for you, lady? We'll do {#Emph}anything..."
