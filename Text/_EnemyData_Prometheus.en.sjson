    }
    {
      Id = "Prometheus_0217"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What..."
      Speaker = "Prometheus"
      Event = "Prometheus.CriticalHealthVoiceLines"
    }
    {
      Id = "Prometheus_0218"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How...?"
      Speaker = "Prometheus"
      Event = "Prometheus.CriticalHealthVoiceLines"
    }
    {
      Id = "Prometheus_0219"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I should've..."
      Speaker = "Prometheus"
      Event = "Prometheus.CriticalHealthVoiceLines"
    }
    {
      Id = "Prometheus_0220"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You just..."
      Speaker = "Prometheus"
      Event = "Prometheus.CriticalHealthVoiceLines"
    }
    {
      Id = "Prometheus_0221"
      InheritFrom = "BaseSubtitle"
      DisplayName = "But I..."
      Speaker = "Prometheus"
      Event = "Prometheus.CriticalHealthVoiceLines"
    }
    {
      Id = "Prometheus_0262"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This... changes... nothing..."
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0263"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Heh... heheheheh... ungh..."
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0264"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I should have... expected this..."
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0265"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I've suffered... worse... {#Emph}urgh..."
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0266"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This... too... shall... pass..."
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0268"
      InheritFrom = "BaseSubtitle"
      DisplayName = "All... according... to plan..."
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0269"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You gods... I hate... you all..."
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0270"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Was there nothing... I could have done...?"
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0461"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Such wrath... hold onto it..."
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0463"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I am surpassed... but never beaten..."
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0464"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You gods... have much... to learn..."
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0465"
      InheritFrom = "BaseSubtitle"
      DisplayName = "This was to be my future, then..."
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0466"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You cannot break me; that I know."
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0467"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The strength of Hades... blast..."
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0468"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Far worse... awaits... above..."
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0470"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I shall never... submit to you..."
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0472"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Who would have... fought for you...?"
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0446"
      InheritFrom = "BaseSubtitle"
      DisplayName = "So... swift... {#Emph}urgh..."
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0447"
      InheritFrom = "BaseSubtitle"
      DisplayName = "In the blink... of an eye..."
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0448"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I could not... keep up..."
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0462"
      InheritFrom = "BaseSubtitle"
      DisplayName = "My wounds... shall heal again..."
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0449"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're... far too quick..."
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0471"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You know... what lies... ahead..."
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0469"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Even with Heracles, I... {#Emph}urgh..."
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0460"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I cannot stop you... yet I fight..."
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0267"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I did... what needed... to be done..."
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0271"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I knew... this would happen... yet..."
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0473"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Go give... that monster... hell..."
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0107"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...We'll meet again...!"
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0109"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...I'll get you gods for this!"
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0255"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...This changes nothing!"
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0256"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...I shall be back!"
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0258"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Aetos, we fly!"
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0259"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Fly, Aetos!"
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "Prometheus_0260"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Get us out, Aetos!"
      Speaker = "Prometheus"
      Event = "Prometheus.DefeatedVoiceLines"
    }
    {
      Id = "MelinoeField_2518"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...He's gone."
      Speaker = "Melinoe"
      Event = "Prometheus.BossKillVoiceLines"
    }
    {
      Id = "MelinoeField_2519"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Did he know he'd lose...?"
      Speaker = "Melinoe"
      Event = "Prometheus.BossKillVoiceLines"
    }
    {
      Id = "MelinoeField_2520"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Go lick your wounds."
      Speaker = "Melinoe"
      Event = "Prometheus.BossKillVoiceLines"
    }
    {
      Id = "MelinoeField_2521"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Saw that coming."
      Speaker = "Melinoe"
      Event = "Prometheus.BossKillVoiceLines"
    }
    {
      Id = "MelinoeField_2522"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Enough of his foresight."
      Speaker = "Melinoe"
      Event = "Prometheus.BossKillVoiceLines"
    }
    {
      Id = "MelinoeField_3742"
      InheritFrom = "BaseSubtitle"
      DisplayName = "They're in league..."
      Speaker = "Melinoe"
      Event = "Prometheus.BossKillVoiceLines"
    }
    {
      Id = "MelinoeField_5202"
      InheritFrom = "BaseSubtitle"
      DisplayName = "They're tough..."
      Speaker = "Melinoe"
      Event = "Prometheus.BossKillVoiceLines"
    }
    {
      Id = "MelinoeField_5203"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How long have they conspired...?"
      Speaker = "Melinoe"
      Event = "Prometheus.BossKillVoiceLines"
    }
    {
      Id = "MelinoeField_5204"
      InheritFrom = "BaseSubtitle"
      DisplayName = "So long, you two...!"
      Speaker = "Melinoe"
      Event = "Prometheus.BossKillVoiceLines"
    }
    {
      Id = "MelinoeField_2523"
      InheritFrom = "BaseSubtitle"
      DisplayName = "See you later!"
      Speaker = "Melinoe"
      Event = "Prometheus.BossKillVoiceLines"
    }
    {
      Id = "Prometheus_0002"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah{#Prev}, here comes the unexpected wrinkle in my master's plan! I know who you are, lost daughter of Hades, and I know that you know who I am. I had a premonition of this very moment."
      Speaker = "Prometheus"
      Event = "PrometheusFirstMeeting"
    }
    {
      Id = "MelinoeField_2381"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lord Prometheus, I presume. You must have premonitions all the time. I'd not heard you were liberated, or that Chronos is the master you serve. Solidarity between Titans, then?"
      Speaker = "Melinoe"
      Event = "PrometheusFirstMeeting"
    }
    {
      Id = "Prometheus_0003"
      InheritFrom = "BaseNarrative"
      DisplayName = "Call it a change of heart. I was a coward and a fool, you see; to have sided once with gods against my kind. But no more. This is my attempt at atonement."
      Speaker = "Prometheus"
      Event = "PrometheusFirstMeeting"
    }
    {
      Id = "MelinoeField_2382"
      InheritFrom = "BaseNarrative"
      DisplayName = "What, by leading this reckless assault? I never took you for a coward, but you remain a fool."
      Speaker = "Melinoe"
      Event = "PrometheusFirstMeeting"
    }
    {
      Id = "Prometheus_0004"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps you're right; but I shall be a victorious fool, at least. For I have seen you stand no chance at all."
      Speaker = "Prometheus"
      Event = "PrometheusFirstMeeting"
    }
    {
      Id = "Prometheus_0007"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know what lies beyond, and still returned. I knew you would, of course, yet I don't know why. Because you won't tell me..."
      Speaker = "Prometheus"
      Event = "PrometheusWonAgainstHim01"
    }
    {
      Id = "MelinoeField_2384"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's right. Your nonsense riddles are a bigger threat to my health than you, or your blasted Eagle pet for that matter."
      Speaker = "Melinoe"
      Event = "PrometheusWonAgainstHim01"
    }
    {
      Id = "Prometheus_0008"
      InheritFrom = "BaseNarrative"
      DisplayName = "The threat you face is beyond your understanding; that is the only reason you persevere. Your ignorance is a {#Emph}gift! {#Prev}Much like the fire that I shared with mortalkind, and now with you."
      Speaker = "Prometheus"
      Event = "PrometheusWonAgainstHim01"
    }
    {
      Id = "Prometheus_0031"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know your capability and can anticipate your every move, but... there are times my mind leads me astray, you see. Anticipating possibilities that do not come to pass... resulting in all too many mistakes."
      Speaker = "Prometheus"
      Event = "PrometheusWonAgainstHim02"
    }
    {
      Id = "MelinoeField_2553"
      InheritFrom = "BaseNarrative"
      DisplayName = "Mistakes such as revealing this to me, or being here at all. Have you learned nothing from your past imprisonment?"
      Speaker = "Melinoe"
      Event = "PrometheusWonAgainstHim02"
    }
    {
      Id = "Prometheus_0032"
      InheritFrom = "BaseNarrative"
      DisplayName = "To be imprisoned is to be denied the opportunity to learn. A cruel form of torture in itself, but I did learn something, yes: I cannot break."
      Speaker = "Prometheus"
      Event = "PrometheusWonAgainstHim02"
    }
    {
      Id = "Prometheus_0009"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know you think that you can get past me, if you but continue to try, and to try, and to try. The truth is you shall! Perhaps not this night, but inevitably nonetheless."
      Speaker = "Prometheus"
      Event = "PrometheusLostAgainstHim01"
    }
    {
      Id = "MelinoeField_2385"
      InheritFrom = "BaseNarrative"
      DisplayName = "At least you saved me some suspense. If I knew every outcome as does the infamous Titan of Foresight, perhaps I too would become a disaffected, traitorous wretch."
      Speaker = "Melinoe"
      Event = "PrometheusLostAgainstHim01"
    }
    {
      Id = "Prometheus_0010"
      InheritFrom = "BaseNarrative"
      DisplayName = "What would you know of my plight?! You, who flail against Time itself? So much courage born of pride. Come then, Agent of Change, and show me what I know you can do!"
      Speaker = "Prometheus"
      Event = "PrometheusLostAgainstHim01"
    }
    {
      Id = "Prometheus_0033"
      InheritFrom = "BaseNarrative"
      DisplayName = "Aetos has excellent vision, of course. Saw you since you first set foot at the base of the mountain. Slowed you down, perhaps, but still... I knew you'd be here now."
      Speaker = "Prometheus"
      Event = "PrometheusLostAgainstHim02"
    }
    {
      Id = "MelinoeField_2722"
      InheritFrom = "BaseNarrative"
      DisplayName = "Truly? And what shall be the outcome of our confrontation {#Emph}this {#Prev}time, since you know everything? Same as the last?"
      Speaker = "Melinoe"
      Event = "PrometheusLostAgainstHim02"
    }
    {
      Id = "Prometheus_0034"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you knew, the outcome would invariably be rather different than the one that's imminent. Though I suppose I can at least give you a hint..."
      Speaker = "Prometheus"
      Event = "PrometheusLostAgainstHim02"
    }
    {
      Id = "MelinoeField_3551"
      InheritFrom = "BaseNarrative"
      DisplayName = "Heracles! What are you doing, fraternizing with our foe?"
      Speaker = "Melinoe"
      Event = "PrometheusAboutAltFight01"
    }
    {
      Id = "Heracles_0212"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Our {#Prev}foe? {#Emph}Heh. {#Prev}Well you were right again, Prometheus. So then what now? She finally caught us in the act."
      Speaker = "Heracles"
      Event = "PrometheusAboutAltFight01"
    }
    {
      Id = "Prometheus_0300"
      InheritFrom = "BaseNarrative"
      DisplayName = "We fight is what, big man; slow her at least. She shall not tell a soul that you were here. The damage it would cause her family would be catastrophic if she did."
      Speaker = "Prometheus"
      Event = "PrometheusAboutAltFight01"
    }
    {
      Id = "MelinoeField_3552"
      InheritFrom = "BaseNarrative"
      DisplayName = "So then you're {#Emph}both {#Prev}traitors. And you expect me not to notify Lord Zeus and the others? Heracles, he's your {#Emph}father! {#Prev}Yet you would turn on him?"
      Speaker = "Melinoe"
      Event = "PrometheusAboutAltFight01"
    }
    {
      Id = "Heracles_0214"
      InheritFrom = "BaseNarrative"
      DisplayName = "Don't we all? Besides, the Titan of Foresight here knew I would, and who am I to argue? Now allow me and my club to ensure you'll forget what you have seen."
      Speaker = "Heracles"
      Event = "PrometheusAboutAltFight01"
    }
    {
      Id = "Heracles_0214_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Titan of Foresight here knew I would, and who am I to argue? Now allow me and my club to ensure you'll forget what you have seen."
      Speaker = "Heracles"
      Event = "PrometheusAboutAltFight01"
    }
    {
      Id = "MelinoeField_3999"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Heracles! {#Prev}What are you doing, fraternizing with {#Emph}him? {#Prev}You're supposed to be defending this mountain like before!"
      Speaker = "Melinoe"
      Event = "PrometheusAboutAltFight01_B"
    }
    {
      Id = "Heracles_0213"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Fraternizing! Heh. {#Prev}Well you were right again, Prometheus. So then what now? She finally caught us in the act."
      Speaker = "Heracles"
      Event = "PrometheusAboutAltFight01_B"
    }
    {
      Id = "Prometheus_0301"
      InheritFrom = "BaseNarrative"
      DisplayName = "We fight is what, big man; slow her at least. She shall not tell a soul that you were here. Her family is in no position to absorb the truth of it, at least not now, or soon."
      Speaker = "Prometheus"
      Event = "PrometheusAboutAltFight01_B"
    }
    {
      Id = "MelinoeField_4000"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't know, this sounds a little treasonous. Yet you expect me not to notify Lord Zeus and the others? Heracles, he's your {#Emph}father! {#Prev}Of all the gods, you'd even turn on {#Emph}him?"
      Speaker = "Melinoe"
      Event = "PrometheusAboutAltFight01_B"
    }
    {
      Id = "Prometheus_0302"
      InheritFrom = "BaseNarrative"
      DisplayName = "Agent of Change! I of course foresaw my own defeats. As to whether you can stop both Heracles {#Emph}and {#Prev}me, you'll find there are far fewer paths to that outcome."
      Speaker = "Prometheus"
      Event = "PrometheusAboutAltFight02"
    }
    {
      Id = "Heracles_0215"
      InheritFrom = "BaseNarrative"
      DisplayName = "Is it necessary that you tell this witch such things, Flame Thief? Leave her to figure it out the hard way."
      Speaker = "Heracles"
      Event = "PrometheusAboutAltFight02"
    }
    {
      Id = "Prometheus_0303"
      InheritFrom = "BaseNarrative"
      DisplayName = "I knew you'd say that, man. And you've the right of it of course; we are not here for conversation. {#Emph}Nor is she."
      Speaker = "Prometheus"
      Event = "PrometheusAboutAltFight02"
    }
    {
      Id = "Prometheus_0304"
      InheritFrom = "BaseNarrative"
      DisplayName = "If there exists a downside to having the ferocious strength of Heracles at one's call, it must be overconfidence. How could we possibly not prevail, I theorized. Well... there were ways."
      Speaker = "Prometheus"
      Event = "PrometheusAboutAltFight03"
    }
    {
      Id = "Heracles_0216"
      InheritFrom = "BaseNarrative"
      DisplayName = "You ought have told me of these ways, Flame Thief. For I am unaccustomed to defeat. It's fortunate we have no onlookers, for all the smoke and ash..."
      Speaker = "Heracles"
      Event = "PrometheusAboutAltFight03"
    }
    {
      Id = "MelinoeField_3750"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you two would like to keep this lovely conversation going, I've no great impulse to break it up. But you're going to force me to fight, I suppose."
      Speaker = "Melinoe"
      Event = "PrometheusAboutAltFight03"
    }
    {
      Id = "Prometheus_0305"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's ultimately why we're here, so {#Emph}yes. {#Prev}Where you're going, Change follows. And Change does not come without conflict."
      Speaker = "Prometheus"
      Event = "PrometheusAboutAltFight03"
    }
    {
      Id = "MelinoeField_3751"
      InheritFrom = "BaseNarrative"
      DisplayName = "Heracles! What do you have to say for yourself in all this? Are {#Emph}you {#Prev}the one who broke Prometheus from his bonds?"
      Speaker = "Melinoe"
      Event = "PrometheusAboutAltFight04"
    }
    {
      Id = "Heracles_0217"
      InheritFrom = "BaseNarrative"
      DisplayName = "You'll get no answers from me, sister; only a splitting headache. You're better off demanding truths from the Titan standing by my side, who speaks them willingly."
      Speaker = "Heracles"
      Event = "PrometheusAboutAltFight04"
    }
    {
      Id = "Prometheus_0306"
      InheritFrom = "BaseNarrative"
      DisplayName = "Truths are only truths if they're believed. And no matter what I tell our adversary, she shall not believe me; not entirely at least... the splitting headache is the better course for now."
      Speaker = "Prometheus"
      Event = "PrometheusAboutAltFight04"
    }
    {
      Id = "MelinoeField_3752"
      InheritFrom = "BaseNarrative"
      DisplayName = "No sign of your big friend. It seems you'll have to contend with me on your own, since I'm ignoring your {#Emph}bird."
      Speaker = "Melinoe"
      Event = "PrometheusAboutAltFight05"
    }
    {
      Id = "Prometheus_0307"
      InheritFrom = "BaseNarrative"
      DisplayName = "My {#Emph}big friend{#Prev}, as you call him, answers to a higher power, and I know that you know what it is. You wish to face the two of us again... you know precisely how."
      Speaker = "Prometheus"
      Event = "PrometheusAboutAltFight05"
    }
    {
      Id = "MelinoeField_3928"
      InheritFrom = "BaseNarrative"
      DisplayName = "And why would I possibly wish to go through {#Emph}that {#Prev}again? You're enough on your own, without also having to evade a club twice my size."
      Speaker = "Melinoe"
      Event = "PrometheusAboutAltFight05"
    }
    {
      Id = "Prometheus_0308"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're eager to please! To do that which you're called upon to do. That's why you're here. And that's why Heracles shall be here again not very long from now."
      Speaker = "Prometheus"
      Event = "PrometheusAboutAltFight05"
    }
    {
      Id = "MelinoeField_3929"
      InheritFrom = "BaseNarrative"
      DisplayName = "Aetos has you to himself again! They say that Heracles once slew an entire flock of voracious birds... must make yours a bit uneasy."
      Speaker = "Melinoe"
      Event = "PrometheusAboutAltFight05_2"
    }
    {
      Id = "Prometheus_0311"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your insincere concern is meaningless to me. You gods have a shared purpose, merely to reassert your dominance. We share a purpose, too! But one completely different from your own."
      Speaker = "Prometheus"
      Event = "PrometheusAboutAltFight05_2"
    }
    {
      Id = "Prometheus_0309"
      InheritFrom = "BaseNarrative"
      DisplayName = "You see, big man? She didn't keep you waiting long at all. Though I know how much you detest having your labors dictated by goddesses or gods."
      Speaker = "Prometheus"
      Event = "PrometheusAboutAltFight06"
    }
    {
      Id = "Heracles_0218"
      InheritFrom = "BaseNarrative"
      DisplayName = "I grow accustomed to it more and more. Relieves me of having to make hard choices; I need but make the easy ones, such as which bones to shatter first."
      Speaker = "Heracles"
      Event = "PrometheusAboutAltFight06"
    }
    {
      Id = "Prometheus_0310"
      InheritFrom = "BaseNarrative"
      DisplayName = "And I look forward to seeing what you decide; though I already know, of course..."
      Speaker = "Prometheus"
      Event = "PrometheusAboutAltFight06"
    }
    {
      Id = "MelinoeField_3753"
      InheritFrom = "BaseNarrative"
      DisplayName = "We have some matters to discuss, Prometheus! So why not ask your big friend there to step aside? It would be rather rude of him to eavesdrop on our private conversations."
      Speaker = "Melinoe"
      Event = "PrometheusAboutAltFight07"
    }
    {
      Id = "Prometheus_0312"
      InheritFrom = "BaseNarrative"
      DisplayName = "You shall not believe this for some time, Agent of Change, but Heracles {#Emph}can {#Prev}be trusted... certainly not in your present case, but still."
      Speaker = "Prometheus"
      Event = "PrometheusAboutAltFight07"
    }
    {
      Id = "Heracles_0219"
      InheritFrom = "BaseNarrative"
      DisplayName = "I care next to naught for what you say, sister. You wish for me to step aside, make me. Either here and now, or by whichever means you got me to show up."
      Speaker = "Heracles"
      Event = "PrometheusAboutAltFight07"
    }
    {
      Id = "MelinoeField_3754"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well since the both of you are here, I just want you to know: Neither one of you is as strong as you look."
      Speaker = "Melinoe"
      Event = "PrometheusAboutAltFight07"
    }
    {
      Id = "Prometheus_0313"
      InheritFrom = "BaseNarrative"
      DisplayName = "You underestimate our combined strength, though not for much longer. Let's show her, Heracles!"
      Speaker = "Prometheus"
      Event = "PrometheusAboutAltFight07"
    }
    {
      Id = "Prometheus_0316"
      InheritFrom = "BaseNarrative"
      DisplayName = "If I may, Heracles? It is not necessary to converse with her like this. We could simply attack without warning."
      Speaker = "Prometheus"
      Event = "PrometheusAboutAltFight08"
    }
    {
      Id = "Heracles_0232"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm only making conversation here because of {#Emph}you. {#Prev}No need to persuade me about the benefits of attack without warning."
      Speaker = "Heracles"
      Event = "PrometheusAboutAltFight08"
    }
    {
      Id = "Prometheus_0317"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then it's settled! We agree to keep her guessing. Even though we're going to fall back on old habits, with me doing most of the talking henceforth."
      Speaker = "Prometheus"
      Event = "PrometheusAboutAltFight08"
    }
    {
      Id = "MelinoeField_3755"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}You{#Prev}, Heracles! When we meet elsewhere it's as though nothing's changed, and still you face me here? I knew you for a great warrior, but you're just a great actor!"
      Speaker = "Melinoe"
      Event = "PrometheusAboutAltFight09"
    }
    {
      Id = "Heracles_0220"
      InheritFrom = "BaseNarrative"
      DisplayName = "We're all actors throughout our wretched lives, sister. And don't you dare address me here again; this is the Flame Thief's fight. I'm merely the supporting actor here."
      Speaker = "Heracles"
      Event = "PrometheusAboutAltFight09"
    }
    {
      Id = "Prometheus_0314"
      InheritFrom = "BaseNarrative"
      DisplayName = "And is this not a fitting stage on which we're to perform before the gods? Including whichever dark gods you yourself invoked, forcing obedient Heracles to answer their call. Let's give them what they desire!"
      Speaker = "Prometheus"
      Event = "PrometheusAboutAltFight09"
    }
    {
      Id = "Heracles_0221"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why don't I take point for a while here, Flame Thief? There are such times as you are liable to talk too much."
      Speaker = "Heracles"
      Event = "PrometheusAboutAltFightHeracles01"
    }
    {
      Id = "Prometheus_0315"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'd say I thought you'd never ask, big man, but we both know the truth. I don't foresee the two of you speaking for long."
      Speaker = "Prometheus"
      Event = "PrometheusAboutAltFightHeracles01"
    }
    {
      Id = "Heracles_0222"
      InheritFrom = "BaseNarrative"
      DisplayName = "Been so long since I last lost a fight, that I'd forgotten how it felt. The shame... the anger... the blood boiling in my veins."
      Speaker = "Heracles"
      Event = "PrometheusAboutAltFightHeracles02"
    }
    {
      Id = "MelinoeField_3756"
      InheritFrom = "BaseNarrative"
      DisplayName = "And it probably doesn't make you feel any better knowing Prometheus there was certain you were going to lose."
      Speaker = "Melinoe"
      Event = "PrometheusAboutAltFightHeracles02"
    }
    {
      Id = "Heracles_0223"
      InheritFrom = "BaseNarrative"
      DisplayName = "No. But something else also occurred: I found myself longing to fight again. To tear my enemies to pieces. I still can suppress the worst part, but I thought all of it was gone..."
      Speaker = "Heracles"
      Event = "PrometheusAboutAltFightHeracles02"
    }
    {
      Id = "MelinoeField_3757"
      InheritFrom = "BaseNarrative"
      DisplayName = "When first we met, you said you work alone, Heracles sir. Yet here you are cooperating with this Titan, and I'd say even that Eagle too. Another one of your lies, then?"
      Speaker = "Melinoe"
      Event = "PrometheusAboutAltFightHeracles03"
    }
    {
      Id = "Heracles_0224"
      InheritFrom = "BaseNarrative"
      DisplayName = "Who says I'm working, sister? For all you know, this is what I do for sake of recreation. My work and interests coincide."
      Speaker = "Heracles"
      Event = "PrometheusAboutAltFightHeracles03"
    }
    {
      Id = "MelinoeField_3758"
      InheritFrom = "BaseNarrative"
      DisplayName = "You expect me to believe you're here because you want to be, and not because the will of Night demanded it? I know you haven't shown up by coincidence alone."
      Speaker = "Melinoe"
      Event = "PrometheusAboutAltFightHeracles03"
    }
    {
      Id = "Heracles_0225"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Believe {#Prev}whatever you like. Now, {#Emph}I {#Prev}believe it's time to drive this club into your skull; not for business, but for {#Emph}pleasure."
      Speaker = "Heracles"
      Event = "PrometheusAboutAltFightHeracles03"
    }
    {
      Id = "Heracles_0226"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's dark out there, sister. Yet you always seem to find your way, stalking around like a {#Emph}cat. {#Prev}Know what I do to cats?"
      Speaker = "Heracles"
      Event = "PrometheusAboutAltFightHeracles04"
    }
    {
      Id = "MelinoeField_3759"
      InheritFrom = "BaseNarrative"
      DisplayName = "Apparently you turn them into fashionable pelts! Well you're not doing that to {#Emph}me. {#Prev}How would it even work? I'm too small."
      Speaker = "Melinoe"
      Event = "PrometheusAboutAltFightHeracles04"
    }
    {
      Id = "Heracles_0227"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're too {#Emph}clever. {#Prev}How about you keep talking, while I let my club do the rest of the talking for {#Emph}me."
      Speaker = "Heracles"
      Event = "PrometheusAboutAltFightHeracles04"
    }
    {
      Id = "Heracles_0228"
      InheritFrom = "BaseNarrative"
      DisplayName = "Whatever it is you do to get me to show up, tonight you must have done a lot of it, sister. It's crawling out there..."
      Speaker = "Heracles"
      Event = "PrometheusAboutAltFightHeracles05"
    }
    {
      Id = "MelinoeField_3760"
      InheritFrom = "BaseNarrative"
      DisplayName = "Is that a touch of fear in the voice of mighty Heracles? Though I ought to be the one afraid, having to confront you and Prometheus like this. He knows it's going to get {#Emph}ugly."
      Speaker = "Melinoe"
      Event = "PrometheusAboutAltFightHeracles05"
    }
    {
      Id = "Heracles_0229"
      InheritFrom = "BaseNarrative"
      DisplayName = "When does it ever not? But this is nothing. You wish to know true fear, go train under the Centaur Chiron for a while..."
      Speaker = "Heracles"
      Event = "PrometheusAboutAltFightHeracles05"
    }
    {
      Id = "Heracles_0230"
      InheritFrom = "BaseNarrative"
      DisplayName = "I never used to lose. Felt like the Flame Thief here probably does, knowing the outcome of every battle. Not anymore..."
      Speaker = "Heracles"
      Event = "PrometheusAboutAltFightHeracles06"
    }
    {
      Id = "MelinoeField_3761"
      InheritFrom = "BaseNarrative"
      DisplayName = "Surely the added bit of unexpectedness helps keep things livelier and more entertaining for you now."
      Speaker = "Melinoe"
      Event = "PrometheusAboutAltFightHeracles06"
    }
    {
      Id = "Heracles_0231"
      InheritFrom = "BaseNarrative"
      DisplayName = "No. I never used to lose, but I never liked surprises, either. So, all in all, things lately haven't gone too well for my career..."
      Speaker = "Heracles"
      Event = "PrometheusAboutAltFightHeracles06"
    }
    {
      Id = "Prometheus_0049"
      InheritFrom = "BaseNarrative"
      DisplayName = "I knew your injuries would be this grave, though perhaps you did not. Nothing a little {#Emph}time {#Prev}can't eventually heal of course."
      Speaker = "Prometheus"
      Event = "PrometheusLowHealth01"
    }
    {
      Id = "MelinoeField_2733"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm grateful for your concern, though best mind your {#Emph}own {#Prev}injuries. Those bandages... you aren't at your peak. Although perhaps this means we'll have a fairer fight."
      Speaker = "Melinoe"
      Event = "PrometheusLowHealth01"
    }
    {
      Id = "Prometheus_0050"
      InheritFrom = "BaseNarrative"
      DisplayName = "My wounds have long since been a hindrance to me. I do not let them fully heal, so I am always cognizant of what I'm fighting for. And Aetos here appreciates it, too."
      Speaker = "Prometheus"
      Event = "PrometheusLowHealth01"
    }
    {
      Id = "Prometheus_0128"
      InheritFrom = "BaseNarrative"
      DisplayName = "My forces almost stopped you but they didn't quite succeed. Yet even now you're outnumbered against Aetos and me."
      Speaker = "Prometheus"
      Event = "PrometheusLowHealth02"
    }
    {
      Id = "MelinoeField_2883"
      InheritFrom = "BaseNarrative"
      DisplayName = "The prospect of exacting vengeance on your troublesome Eagle, if not you yourself, helps keep me going. Shall we commence?"
      Speaker = "Melinoe"
      Event = "PrometheusLowHealth02"
    }
    {
      Id = "Prometheus_0129"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes. I mustn't keep you waiting. For I know who shall have their vengeance here, and I'm eager for {#Emph}you {#Prev}to find out."
      Speaker = "Prometheus"
      Event = "PrometheusLowHealth02"
    }
    {
      Id = "Prometheus_0128_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "My forces almost stopped you but they didn't quite succeed. Now you're against Aetos and me."
      Speaker = "Prometheus"
      Event = "PrometheusLowHealth02_B"
    }
    {
      Id = "Prometheus_0130"
      InheritFrom = "BaseNarrative"
      DisplayName = "How can you hope to surpass me in such a wretched state? Perhaps if I were bound in chains and my liver half-eaten this would have been more of an even match."
      Speaker = "Prometheus"
      Event = "PrometheusLowHealth03"
    }
    {
      Id = "MelinoeField_2884"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm not under the impression that you seek sporting competition here, Prometheus. Now let's get on with it."
      Speaker = "Melinoe"
      Event = "PrometheusLowHealth03"
    }
    {
      Id = "Prometheus_0131"
      InheritFrom = "BaseNarrative"
      DisplayName = "A sporting competition! There must be a certain thrill in not knowing a battle's outcome before it occurs. Even outcomes as likely as this."
      Speaker = "Prometheus"
      Event = "PrometheusLowHealth03"
    }
    {
      Id = "Prometheus_0143"
      InheritFrom = "BaseNarrative"
      DisplayName = "How quickly you arrived this night! Bending the very laws of nature to achieve your goal... forging alliances with beings who care nothing for you."
      Speaker = "Prometheus"
      Event = "PrometheusPackagedBounties01"
    }
    {
      Id = "MelinoeField_2890"
      InheritFrom = "BaseNarrative"
      DisplayName = "I did take a shortcut, but you're wrong about the rest. I know the being to whom you refer, and they're not what you presume them to be."
      Speaker = "Melinoe"
      Event = "PrometheusPackagedBounties01"
    }
    {
      Id = "Prometheus_0144"
      InheritFrom = "BaseNarrative"
      DisplayName = "No...? But isn't it {#Emph}Chaos {#Prev}that delivers you so close to your goal, yet shall let you go no farther... even if you should prevail here? I know where this all leads; let's see it through!"
      Speaker = "Prometheus"
      Event = "PrometheusPackagedBounties01"
    }
    {
      Id = "Prometheus_0334"
      InheritFrom = "BaseNarrative"
      DisplayName = "What has the whim of Chaos wrought, that our existence led us to this point, in opposition to each other endlessly?"
      Speaker = "Prometheus"
      Event = "PrometheusAboutRandomBounty01"
    }
    {
      Id = "MelinoeField_3979"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're welcome to surrender at any point, Titan. I'm certain that Chaos would find it terribly amusing if you did."
      Speaker = "Melinoe"
      Event = "PrometheusAboutRandomBounty01"
    }
    {
      Id = "Prometheus_0335"
      InheritFrom = "BaseNarrative"
      DisplayName = "As would you, I suppose. But no such outcome ever shall occur, of that you can be certain. Perhaps, however, we may yet provide to Chaos some amusement anyway."
      Speaker = "Prometheus"
      Event = "PrometheusAboutRandomBounty01"
    }
    {
      Id = "Prometheus_0037"
      InheritFrom = "BaseNarrative"
      DisplayName = "You gods coerced all mortalkind into worshiping you, and for what? You've nothing to gain by slaughtering them at your whim. Leave them be!"
      Speaker = "Prometheus"
      Event = "PrometheusAboutMortals01"
    }
    {
      Id = "MelinoeField_2724"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll be sure to put in the request with my Lord Uncle Zeus, if you could go ahead and let me past so I can pay him a visit."
      Speaker = "Melinoe"
      Event = "PrometheusAboutMortals01"
    }
    {
      Id = "Prometheus_0038"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your Lord Uncle had me bound to a mountain for aeons, so that Aetos here could feast upon my flesh for all that time. Aetos came around eventually, but Zeus...? He never shall."
      Speaker = "Prometheus"
      Event = "PrometheusAboutMortals01"
    }
    {
      Id = "MelinoeField_2725"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why do you care so much for mortals, anyhow? Their lives are short, their flesh is weak. Only in death do many of them finally begin to gain some sense."
      Speaker = "Melinoe"
      Event = "PrometheusAboutMortals02"
    }
    {
      Id = "Prometheus_0039"
      InheritFrom = "BaseNarrative"
      DisplayName = "Any laborer of skill cares for their work. Mortals! Poor sods created in the image of the gods, yet forced to be inferior, so that they could never achieve what my master and I now intend."
      Speaker = "Prometheus"
      Event = "PrometheusAboutMortals02"
    }
    {
      Id = "MelinoeField_2726"
      InheritFrom = "BaseNarrative"
      DisplayName = "You mean to say that {#Emph}you {#Prev}fashioned mortalkind? Then stole the fire from this mountain for {#Emph}their {#Prev}sake? Absurd."
      Speaker = "Melinoe"
      Event = "PrometheusAboutMortals02"
    }
    {
      Id = "Prometheus_0040"
      InheritFrom = "BaseNarrative"
      DisplayName = "The truth can be difficult to absorb. Mortals live only to suffer; as I'm responsible for that, I sought to take some of their suffering from them. And redistribute it to all of you."
      Speaker = "Prometheus"
      Event = "PrometheusAboutMortals02"
    }
    {
      Id = "Prometheus_0118"
      InheritFrom = "BaseNarrative"
      DisplayName = "Gods could learn something from mortals, you know. For all their many failings, they have an admirable tendency to cling to hope; a certain quality we deathless often lack."
      Speaker = "Prometheus"
      Event = "PrometheusAboutMortals03"
    }
    {
      Id = "MelinoeField_2737"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hope can be the salve for the naive. So many mortals hope they'll never die; a feeling born of delusion and fear."
      Speaker = "Melinoe"
      Event = "PrometheusAboutMortals03"
    }
    {
      Id = "Prometheus_0119"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes! Mortals live short, painful lives. And even still they strive for something greater than they mostly can achieve. I fight for {#Emph}them! {#Prev}You gods fight only for {#Emph}yourselves."
      Speaker = "Prometheus"
      Event = "PrometheusAboutMortals03"
    }
    {
      Id = "MelinoeField_3972"
      InheritFrom = "BaseNarrative"
      DisplayName = "It seems the mortals whom you love so much don't all reciprocate, Prometheus. For all you claim to have done, they still don't worship you."
      Speaker = "Melinoe"
      Event = "PrometheusAboutWorship01"
    }
    {
      Id = "Prometheus_0365"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nor shall they ever, I know. Perhaps make cautionary tales I've inspired but that's it. Fortunately, I don't require affirmation; they can save their Nectar and Ambrosia for {#Emph}you."
      Speaker = "Prometheus"
      Event = "PrometheusAboutWorship01"
    }
    {
      Id = "Prometheus_0114"
      InheritFrom = "BaseNarrative"
      DisplayName = "Resist all you like, yet the age of gods shall end! {#Emph}Time {#Prev}shall see to it. And thereafter, a Golden Age of enlightenment shall begin, in which you gods hold far less sway."
      Speaker = "Prometheus"
      Event = "PrometheusAboutGoldenAge01"
    }
    {
      Id = "MelinoeField_2735"
      InheritFrom = "BaseNarrative"
      DisplayName = "If I somehow gave you the impression that I'm interested in your doomsaying and false prophecies, I assure you, I'm not."
      Speaker = "Melinoe"
      Event = "PrometheusAboutGoldenAge01"
    }
    {
      Id = "Prometheus_0115"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your disregard is the very reason you're no longer fit to rule. I know you'll never relinquish this mountain; fall with it, then!"
      Speaker = "Prometheus"
      Event = "PrometheusAboutGoldenAge01"
    }
    {
      Id = "Prometheus_0035"
      InheritFrom = "BaseNarrative"
      DisplayName = "My master's plan of course requires time. The objective here is not to stop you permanently, but to slow you down."
      Speaker = "Prometheus"
      Event = "PrometheusAboutPlans01"
    }
    {
      Id = "MelinoeField_2723"
      InheritFrom = "BaseNarrative"
      DisplayName = "Unless you just can't help revealing vital information to your enemies, I'm going to assume you're spouting this drivel to mislead me. Either way, my own objective remains the same."
      Speaker = "Melinoe"
      Event = "PrometheusAboutPlans01"
    }
    {
      Id = "Prometheus_0036"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yes, bullheadedness is one of your family's defining traits. Then let us execute our respective plans; there is a possibility that mine shall succeed here beyond measure."
      Speaker = "Prometheus"
      Event = "PrometheusAboutPlans01"
    }
    {
      Id = "MelinoeField_2728"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why bother talking to me all these nights, Titan? If you know everything I'm going to say. How tedious your life must be."
      Speaker = "Melinoe"
      Event = "PrometheusAboutForesight01"
    }
    {
      Id = "Prometheus_0043"
      InheritFrom = "BaseNarrative"
      DisplayName = "It used to be much worse! But to your point, I would not wish the curse of foresight unto anyone... except perhaps the worst of all my enemies. And you are not yet one."
      Speaker = "Prometheus"
      Event = "PrometheusAboutForesight01"
    }
    {
      Id = "MelinoeField_2729"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh? I'll have to work harder to earn that distinction, then. And when I set my mind to something, I typically succeed."
      Speaker = "Melinoe"
      Event = "PrometheusAboutForesight01"
    }
    {
      Id = "Prometheus_0044"
      InheritFrom = "BaseNarrative"
      DisplayName = "I am aware. But I also know that pride, one of the defining traits of your kind, tends to precede a fall. You shall see where all your certainty gets you."
      Speaker = "Prometheus"
      Event = "PrometheusAboutForesight01"
    }
    {
      Id = "Prometheus_0045"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have questions for me about a great many things... I shall not answer them, not yet. The words must first escape your lips, for one."
      Speaker = "Prometheus"
      Event = "PrometheusAboutForesight02"
    }
    {
      Id = "MelinoeField_2730"
      InheritFrom = "BaseNarrative"
      DisplayName = "How about I save my breath instead? You won't know what I'm going to say if I never say it."
      Speaker = "Melinoe"
      Event = "PrometheusAboutForesight02"
    }
    {
      Id = "Prometheus_0046"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yet your heart if not your eyes and ears suggest to you that I am not the liar that your mind believes me to be. We stand in opposition nonetheless."
      Speaker = "Prometheus"
      Event = "PrometheusAboutForesight02"
    }
    {
      Id = "Prometheus_0120"
      InheritFrom = "BaseNarrative"
      DisplayName = "The question you're about to ask is mocking nonsense to supplant the more important subject troubling you now. Go on! I cannot respond if you hold back."
      Speaker = "Prometheus"
      Event = "PrometheusAboutForesight03"
    }
    {
      Id = "MelinoeField_2738"
      InheritFrom = "BaseNarrative"
      DisplayName = "No. You have no control over me or my future. And don't worry, I'm {#Emph}not {#Prev}going to hold back."
      Speaker = "Melinoe"
      Event = "PrometheusAboutForesight03"
    }
    {
      Id = "Prometheus_0121"
      InheritFrom = "BaseNarrative"
      DisplayName = "I knew you would react this way, but knew no other way to broach the subject. How often I create the outcomes I'm attempting to prevent..."
      Speaker = "Prometheus"
      Event = "PrometheusAboutForesight03"
    }
    {
      Id = "MelinoeField_2739"
      InheritFrom = "BaseNarrative"
      DisplayName = "Answer me this one question, Titan. If you know everything the future holds, why make the choices leading to the awful punishment that you endured? Why let yourself get caught?"
      Speaker = "Melinoe"
      Event = "PrometheusAboutForesight04"
    }
    {
      Id = "Prometheus_0122"
      InheritFrom = "BaseNarrative"
      DisplayName = "Our choices can reverberate through time, creating outcomes of far greater consequence. If not for my imprisonment, I wouldn't be here now; where I must be."
      Speaker = "Prometheus"
      Event = "PrometheusAboutForesight04"
    }
    {
      Id = "MelinoeField_2740"
      InheritFrom = "BaseNarrative"
      DisplayName = "You suffered as you did just so I could beat you up some more tonight? You're a fraud... making unprovable claims to sound righteous and wise."
      Speaker = "Melinoe"
      Event = "PrometheusAboutForesight04"
    }
    {
      Id = "Prometheus_0123"
      InheritFrom = "BaseNarrative"
      DisplayName = "You, of all gods, ought to understand something of sacrifice... but for now, at least, it matters not. I've nothing to prove to you, no secrets I'm willing to share; only my rage."
      Speaker = "Prometheus"
      Event = "PrometheusAboutForesight04"
    }
    {
      Id = "MelinoeField_2880"
      InheritFrom = "BaseNarrative"
      DisplayName = "Either you're a liar when it comes to your supposed foresight, or you're letting me win. Who doesn't want a good thrashing from some witch every so often?"
      Speaker = "Melinoe"
      Event = "PrometheusAboutForesight05"
    }
    {
      Id = "Prometheus_0124"
      InheritFrom = "BaseNarrative"
      DisplayName = "The difference between you and me is that you merely can suspect and theorize, whilst I know for certain. Yet there are truths that I cannot impart."
      Speaker = "Prometheus"
      Event = "PrometheusAboutForesight05"
    }
    {
      Id = "MelinoeField_2881"
      InheritFrom = "BaseNarrative"
      DisplayName = "That's quite all right, I didn't think you would. I can change the future with my actions whether I know what the future holds or not."
      Speaker = "Melinoe"
      Event = "PrometheusAboutForesight05"
    }
    {
      Id = "Prometheus_0125"
      InheritFrom = "BaseNarrative"
      DisplayName = "Take it from me, Agent of Change: The more you know of the future, the less likely you are to shape it as you desire."
      Speaker = "Prometheus"
      Event = "PrometheusAboutForesight05"
    }
    {
      Id = "Prometheus_0041"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know what you're about to say, Agent of Change, and caution you: {#Emph}Don't say it. {#Prev}Should you verbalize your thoughts, the outcome shall be of no benefit to either of us."
      Speaker = "Prometheus"
      Event = "PrometheusAboutFuture01"
    }
    {
      Id = "MelinoeField_2727"
      InheritFrom = "BaseNarrative"
      DisplayName = "Fine... just in case. But you'll forgive me if I'm a little skeptical that we changed the course of history like this."
      Speaker = "Melinoe"
      Event = "PrometheusAboutFuture01"
    }
    {
      Id = "Prometheus_0042"
      InheritFrom = "BaseNarrative"
      DisplayName = "You still don't understand. We are as clay, the lot of us. Able to be moulded and re-moulded. One disastrous consequence we avoided; but there's no preventing the next."
      Speaker = "Prometheus"
      Event = "PrometheusAboutFuture01"
    }
    {
      Id = "Prometheus_0126"
      InheritFrom = "BaseNarrative"
      DisplayName = "You, who condemn me as a criminal: Would you know {#Emph}why {#Prev}I liberated fire from this mountain, for the sake of mortalkind?"
      Speaker = "Prometheus"
      Event = "PrometheusAboutFire01"
    }
    {
      Id = "MelinoeField_2882"
      InheritFrom = "BaseNarrative"
      DisplayName = "My own increasingly strong sense of foresight indicates you're going to tell me no matter what."
      Speaker = "Melinoe"
      Event = "PrometheusAboutFire01"
    }
    {
      Id = "Prometheus_0127"
      InheritFrom = "BaseNarrative"
      DisplayName = "When I gave mortals nourishment... the meat they would have sacrificed to you... they needed fire then, and more. But {#Emph}you hoarded all of it! {#Prev}So I saved them; and I'll do it again."
      Speaker = "Prometheus"
      Event = "PrometheusAboutFire01"
    }
    {
      Id = "Prometheus_0145"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah... {#Prev}so it's to be my borrowed flames against your own this night. This could be rather entertaining if I didn't know already how it's going to play out..."
      Speaker = "Prometheus"
      Event = "PrometheusAboutTorch01"
    }
    {
      Id = "MelinoeField_2891"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm not here for your amusement, Titan. Your stolen flame hasn't made you immune."
      Speaker = "Melinoe"
      Event = "PrometheusAboutTorch01"
    }
    {
      Id = "Prometheus_0146"
      InheritFrom = "BaseNarrative"
      DisplayName = "Certainly not. And, I anticipate that Ygnium, for I know the weapons that you bear, shall rather sting. But I've felt worse."
      Speaker = "Prometheus"
      Event = "PrometheusAboutTorch01"
    }
    {
      Id = "MelinoeField_2886"
      InheritFrom = "BaseNarrative"
      DisplayName = "Tell me, Titan: Do you recall a mortal woman by the name of Dora? Her Shade responded strangely when I mentioned you, but can't seem to remember what you did."
      Speaker = "Melinoe"
      Event = "PrometheusAboutDora01"
    }
    {
      Id = "Prometheus_0137"
      InheritFrom = "BaseNarrative"
      DisplayName = "Best leave it be, Agent of Change. That old Shade's latent memories have more to do with gods and their deceptions than with anything I did."
      Speaker = "Prometheus"
      Event = "PrometheusAboutDora01"
    }
    {
      Id = "MelinoeField_2887"
      InheritFrom = "BaseNarrative"
      DisplayName = "Elaborate! Tell me what happened to her. You keep blaming everything on the gods, as though all this is solely their responsibility."
      Speaker = "Melinoe"
      Event = "PrometheusAboutDora01"
    }
    {
      Id = "Prometheus_0138"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, on the contrary, I take responsibility for mortalkind. But for all their failings, vices, and downfalls, I am not to blame. Nor is this {#Emph}Dora. {#Prev}You tell her I said that."
      Speaker = "Prometheus"
      Event = "PrometheusAboutDora01"
    }
    {
      Id = "Prometheus_0139"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your companion, Dora... she does not remember me, not yet. But she shall! And in so doing, remember why she chose to forget me to begin with... and forget so much more."
      Speaker = "Prometheus"
      Event = "PrometheusAboutDora02"
    }
    {
      Id = "MelinoeField_2888"
      InheritFrom = "BaseNarrative"
      DisplayName = "You say she's not to blame for the failings of mortalkind, as though she could have carried such a burden to begin with. What happened? How do you know her?"
      Speaker = "Melinoe"
      Event = "PrometheusAboutDora02"
    }
    {
      Id = "Prometheus_0140"
      InheritFrom = "BaseNarrative"
      DisplayName = "That one is haunted by her past, as you can see. But, it is not my place to tell you any more than I already have, lest she recall too much, too quickly. {#Emph}All in due time{#Prev}, as my master would say."
      Speaker = "Prometheus"
      Event = "PrometheusAboutDora02"
    }
    {
      Id = "MelinoeField_3951"
      InheritFrom = "BaseNarrative"
      DisplayName = "You {#Emph}do {#Prev}know Dora, don't you? She and some brother of yours... they were {#Emph}wed? {#Prev}And somehow this resulted in her letting loose all sorts of daemons in the mortal world?"
      Speaker = "Melinoe"
      Event = "PrometheusAboutDora03"
    }
    {
      Id = "Prometheus_0318"
      InheritFrom = "BaseNarrative"
      DisplayName = "That is one telling of it, more or less... so she remembers, finally? Perhaps with great regret. After all this time, mortals still cannot decide whether to blame themselves or gods for their plight..."
      Speaker = "Prometheus"
      Event = "PrometheusAboutDora03"
    }
    {
      Id = "MelinoeField_3952"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh they should blame only {#Emph}gods? {#Prev}Take no responsibility for their own wretched state? Not even Dora would do that, and she's one of the most complacent beings I know. In an impressive way!"
      Speaker = "Melinoe"
      Event = "PrometheusAboutDora03"
    }
    {
      Id = "Prometheus_0319"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your companion Dora remembers some of the events, but this does not mean she {#Emph}understands {#Prev}any of them. Her actions pitted mortalkind against itself forever!"
      Speaker = "Prometheus"
      Event = "PrometheusAboutDora03"
    }
    {
      Id = "MelinoeField_3953"
      InheritFrom = "BaseNarrative"
      DisplayName = "What became of Dora's husband? Your brother, by her recollection. He abandoned her after what happened?"
      Speaker = "Melinoe"
      Event = "PrometheusAboutDora04"
    }
    {
      Id = "Prometheus_0320"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's more correct to say that your companion Dora finally saw my scatter-minded brother for who he was. Their marriage lasted for about as long as many do."
      Speaker = "Prometheus"
      Event = "PrometheusAboutDora04"
    }
    {
      Id = "MelinoeField_3954"
      InheritFrom = "BaseNarrative"
      DisplayName = "All while you stood idly by and did nothing; but now feel bad and thus decided to shoulder this righteous cause? Perhaps to feel a bit of absolution that you never got from her."
      Speaker = "Melinoe"
      Event = "PrometheusAboutDora04"
    }
    {
      Id = "Prometheus_0321"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your words are harsh but for the most part accurate. Dora remembers now what your own family did to her. If she can forgive you all for that... then she's a stronger soul than I."
      Speaker = "Prometheus"
      Event = "PrometheusAboutDora04"
    }
    {
      Id = "Prometheus_0322"
      InheritFrom = "BaseNarrative"
      DisplayName = "Look at us, Agent of Change! The daemons your companion Dora inadvertently set free... {#Emph}every ill {#Prev}that could befall mortalkind... most all of them yet plague the gods as well."
      Speaker = "Prometheus"
      Event = "PrometheusAboutDora05"
    }
    {
      Id = "MelinoeField_3955"
      InheritFrom = "BaseNarrative"
      DisplayName = "Existence has its hardships. I'm very familiar with many of these daemons, and they are nuisances; but their power has its limits, and they can be driven back."
      Speaker = "Melinoe"
      Event = "PrometheusAboutDora05"
    }
    {
      Id = "Prometheus_0323"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps... but mortals tend to have a harder time of it than you. Don't you see? So long as they suffer, so shall we all."
      Speaker = "Prometheus"
      Event = "PrometheusAboutDora05"
    }
    {
      Id = "MelinoeField_2731"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps your so-called master Chronos wants for you to fail... to suffer more than you already have. He seeks vengeance on the gods for overthrowing him before. When you were their ally!"
      Speaker = "Melinoe"
      Event = "PrometheusAboutChronos01"
    }
    {
      Id = "Prometheus_0047"
      InheritFrom = "BaseNarrative"
      DisplayName = "I don't seek my master's forgiveness, nor assume his loyalty. Alliances are born of shared goals, perhaps ideals; whereas the gods and I are at cross purposes."
      Speaker = "Prometheus"
      Event = "PrometheusAboutChronos01"
    }
    {
      Id = "MelinoeField_2732"
      InheritFrom = "BaseNarrative"
      DisplayName = "Because they punished you for crimes you knowingly committed? What else could they have done after you deceived them, and took from them?"
      Speaker = "Melinoe"
      Event = "PrometheusAboutChronos01"
    }
    {
      Id = "Prometheus_0048"
      InheritFrom = "BaseNarrative"
      DisplayName = "I took {#Emph}nothing! {#Prev}Fire spreads; burns anything that stands in its path. The gods sought to imprison it, but I set it loose. Now at last, we each are free. And burning still."
      Speaker = "Prometheus"
      Event = "PrometheusAboutChronos01"
    }
    {
      Id = "Prometheus_0147"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm but a Titan, and unarmed. Should you get past me, however... I know that you know you're certainly no match for what awaits."
      Speaker = "Prometheus"
      Event = "PrometheusAboutTyphon01"
    }
    {
      Id = "MelinoeField_2969"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps you simply know less than you think. And now you're going to call me arrogant or something, I suppose?"
      Speaker = "Melinoe"
      Event = "PrometheusAboutTyphon01"
    }
    {
      Id = "Prometheus_0148"
      InheritFrom = "BaseNarrative"
      DisplayName = "I would have, yes; but since you've foreseen that outcome, it shall not come to pass. Well if you truly think you can withstand that monstrosity... let's see you withstand {#Emph}me."
      Speaker = "Prometheus"
      Event = "PrometheusAboutTyphon01"
    }
    {
      Id = "Prometheus_0149"
      InheritFrom = "BaseNarrative"
      DisplayName = "The monster Typhon isn't liable to stop, you know. He has your family on the back foot, cowering in your Lord Uncle's palace. Exactly where we want them."
      Speaker = "Prometheus"
      Event = "PrometheusAboutTyphon02"
    }
    {
      Id = "MelinoeField_2970"
      InheritFrom = "BaseNarrative"
      DisplayName = "A suitable distraction I can take advantage of... just as soon as you're out of the way, along with your bird."
      Speaker = "Melinoe"
      Event = "PrometheusAboutTyphon02"
    }
    {
      Id = "Prometheus_0150"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're telling me your plans! Now we're truly getting to know each other. I almost regret what's about to transpire."
      Speaker = "Prometheus"
      Event = "PrometheusAboutTyphon02"
    }
    {
      Id = "Prometheus_0296"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do you hear that? Typhon climbs the dark side of the mountain even now. Impressive that you cast him down before... but he shall not rest till the Palace of Zeus lies in ruin."
      Speaker = "Prometheus"
      Event = "PrometheusAboutTyphon03"
    }
    {
      Id = "MelinoeField_3781"
      InheritFrom = "BaseNarrative"
      DisplayName = "He'll be destroyed. You along with him if that's what it takes. If he were truly unstoppable, you wouldn't be impeding my ascent. You're buying him time."
      Speaker = "Melinoe"
      Event = "PrometheusAboutTyphon03"
    }
    {
      Id = "Prometheus_0297"
      InheritFrom = "BaseNarrative"
      DisplayName = "I am. It's strange to think that time can be a limited commodity, even for deathless such as we. But no more stalling for now."
      Speaker = "Prometheus"
      Event = "PrometheusAboutTyphon03"
    }
    {
      Id = "Prometheus_0298"
      InheritFrom = "BaseNarrative"
      DisplayName = "It may have taken all your godly relatives, but they were able to resist the monster Typhon's wrath, despite the blunders that you made. Yet now you hurry back."
      Speaker = "Prometheus"
      Event = "PrometheusAboutTyphonL01"
    }
    {
      Id = "MelinoeField_3782"
      InheritFrom = "BaseNarrative"
      DisplayName = "I realize this must be complicated for you, as someone whose loyalties are mostly to an Eagle, but I am not about to let that thing destroy everything my family built."
      Speaker = "Melinoe"
      Event = "PrometheusAboutTyphonL01"
    }
    {
      Id = "Prometheus_0299"
      InheritFrom = "BaseNarrative"
      DisplayName = "You ought to choose your loyalties with greater care, not let them be decided by birthright. Well then, {#Emph}come on! {#Prev}You have a summit and a family to protect."
      Speaker = "Prometheus"
      Event = "PrometheusAboutTyphonL01"
    }
    {
      Id = "Prometheus_0116"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Great Zeus {#Prev}did not have me bound and tortured merely for the supposed crime of taking fire from this mountain. No; he wanted certain information... about his eventual downfall."
      Speaker = "Prometheus"
      Event = "PrometheusAboutZeus01"
    }
    {
      Id = "MelinoeField_2736"
      InheritFrom = "BaseNarrative"
      DisplayName = "So you threatened the King of the Olympians with false prophecies and he took it out on you. Perhaps not one of my Lord Uncle's proudest moments, and yet understandable. What did you tell him?"
      Speaker = "Melinoe"
      Event = "PrometheusAboutZeus01"
    }
    {
      Id = "Prometheus_0117"
      InheritFrom = "BaseNarrative"
      DisplayName = "I told him {#Emph}nothing! {#Prev}Merely that his time shall come. A specific outcome that grows more likely with each passing night. {#Emph}You {#Prev}are but a wrinkle in the plan, nothing more."
      Speaker = "Prometheus"
      Event = "PrometheusAboutZeus01"
    }
    {
      Id = "Prometheus_0294"
      InheritFrom = "BaseNarrative"
      DisplayName = "Of all your kin on this accursed mountain, Lady Athena is the worthiest opponent. My master's legions must be keeping her quite busy, that she'd lend some of her strength to you."
      Speaker = "Prometheus"
      Event = "PrometheusAboutAthena01"
    }
    {
      Id = "MelinoeField_3780"
      InheritFrom = "BaseNarrative"
      DisplayName = "You call her an opponent but have been avoiding any direct confrontations, throwing your disposable forces against her. You know you'd lose to her in a fair fight."
      Speaker = "Melinoe"
      Event = "PrometheusAboutAthena01"
    }
    {
      Id = "Prometheus_0295"
      InheritFrom = "BaseNarrative"
      DisplayName = "I would. I lack her martial training, her divinity. But despite her vaunted wisdom, she, like all your kin, possesses what to mortals would be called a {#Emph}fatal flaw. {#Prev}And I know that you know what it is."
      Speaker = "Prometheus"
      Event = "PrometheusAboutAthena01"
    }
    {
      Id = "MelinoeField_2893"
      InheritFrom = "BaseNarrative"
      DisplayName = "The gods, one of them anyway, extend an offering of peace, Prometheus! Lord Dionysus would have you as a guest of honor at his latest celebration, if you'll indulge him. Given your gift of foresight, you must know I'm entirely sincere."
      Speaker = "Melinoe"
      Event = "PrometheusAboutDionysus01"
    }
    {
      Id = "Prometheus_0132"
      InheritFrom = "BaseNarrative"
      DisplayName = "My foresight only works if there is any possibility of an outcome taking place. Whatever deception you have in mind, you shall have to try harder than {#Emph}that."
      Speaker = "Prometheus"
      Event = "PrometheusAboutDionysus01"
    }
    {
      Id = "MelinoeField_2894"
      InheritFrom = "BaseNarrative"
      DisplayName = "You and your master are different; can you not accept that the gods aren't all aligned in their thinking, either? Dionysus wants no part in your feud!"
      Speaker = "Melinoe"
      Event = "PrometheusAboutDionysus01"
    }
    {
      Id = "Prometheus_0133"
      InheritFrom = "BaseNarrative"
      DisplayName = "Dionysus wants merely to drown his few remaining complicated thoughts, and seek more pleasures of the flesh. More beast than god, lacking all self-control."
      Speaker = "Prometheus"
      Event = "PrometheusAboutDionysus01"
    }
    {
      Id = "MelinoeField_2895"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lord Dionysus was quite disappointed that you'd not accept the invitation to his feast! Is there truly not some future possibility in which you change your mind?"
      Speaker = "Melinoe"
      Event = "PrometheusAboutDionysus02"
    }
    {
      Id = "Prometheus_0134"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}None! {#Prev}I've had my liver shorn apart for aeons by good Aetos here; I'll not permit the god of wine to further damage it!"
      Speaker = "Prometheus"
      Event = "PrometheusAboutDionysus02"
    }
    {
      Id = "Prometheus_0141"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know the tinge of gods, but you have something else. Something older... the mark of Chaos. The eldest, most indifferent force in existence, goaded into action!"
      Speaker = "Prometheus"
      Event = "PrometheusAboutChaos01"
    }
    {
      Id = "MelinoeField_2889"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not even Chaos wishes to see Chronos prevail. What does that tell you about your {#Emph}own {#Prev}decision to take sides?"
      Speaker = "Melinoe"
      Event = "PrometheusAboutChaos01"
    }
    {
      Id = "Prometheus_0142"
      InheritFrom = "BaseNarrative"
      DisplayName = "It tells me that all beings are fallible, beginning with Chaos. We are {#Emph}all {#Prev}vulgar accidents, do you see? Yet still we strive toward perfection, which remains ever out of reach."
      Speaker = "Prometheus"
      Event = "PrometheusAboutChaos01"
    }
    {
      Id = "Prometheus_0292"
      InheritFrom = "BaseNarrative"
      DisplayName = "You work with enchantresses to try and gain the upper hand... but such distractions shall be of no avail against me. It is not the size of the opponent that's of consequence."
      Speaker = "Prometheus"
      Event = "PrometheusAboutCirce01"
    }
    {
      Id = "MelinoeField_2892"
      InheritFrom = "BaseNarrative"
      DisplayName = "To have recognized Madame Circe's craft, only to underestimate its potency. Your foresight evidently has its limits, Titan."
      Speaker = "Melinoe"
      Event = "PrometheusAboutCirce01"
    }
    {
      Id = "Prometheus_0293"
      InheritFrom = "BaseNarrative"
      DisplayName = "That it does. But your incantations have {#Emph}their {#Prev}limitations, in kind. You would be wise not to depend on them too much."
      Speaker = "Prometheus"
      Event = "PrometheusAboutCirce01"
    }
    {
      Id = "Prometheus_0051"
      InheritFrom = "BaseNarrative"
      DisplayName = "The future is a series of fixed points. Not even my master believes this to be true, but I have seen the many possibilities. The only question is... which is our destination?"
      Speaker = "Prometheus"
      Event = "PrometheusAboutFates01"
    }
    {
      Id = "MelinoeField_2734"
      InheritFrom = "BaseNarrative"
      DisplayName = "You fill my mind with this nonsense. Not even the Three Fates know entirely what the future holds, for they are always weaving."
      Speaker = "Melinoe"
      Event = "PrometheusAboutFates01"
    }
    {
      Id = "Prometheus_0052"
      InheritFrom = "BaseNarrative"
      DisplayName = "They {#Emph}were {#Prev}always weaving, yes. I know that you know that they weave no longer now. Yet moment by moment, the future still unfolds. Let us give shape to it ourselves!"
      Speaker = "Prometheus"
      Event = "PrometheusAboutFates01"
    }
    {
      Id = "Prometheus_0354"
      InheritFrom = "BaseNarrative"
      DisplayName = "Where do you suppose they are, Agent of Change? The Fates, I mean. They, who set the Titans and the gods against each other to begin with, long ago."
      Speaker = "Prometheus"
      Event = "PrometheusAboutFates02"
    }
    {
      Id = "MelinoeField_3964"
      InheritFrom = "BaseNarrative"
      DisplayName = "Wherever they are, pray they can't hear you speaking ill of them. Though why ask me? You're the one who knows everything, including whether they'll ever be located or not."
      Speaker = "Melinoe"
      Event = "PrometheusAboutFates02"
    }
    {
      Id = "Prometheus_0355"
      InheritFrom = "BaseNarrative"
      DisplayName = "That I do. I but spur you to consider the possibility, and your place in their scheme; and, I suppose, in mine."
      Speaker = "Prometheus"
      Event = "PrometheusAboutFates02"
    }
    {
      Id = "Prometheus_0135"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have a brother you never even knew. I had a prideful one, a scatter-minded one, and a pathetic one bearing the weight of the world on his shoulders. Which do you suppose {#Emph}yours {#Prev}is most like?"
      Speaker = "Prometheus"
      Event = "PrometheusAboutBrothers01"
    }
    {
      Id = "MelinoeField_2885"
      InheritFrom = "BaseNarrative"
      DisplayName = "No wonder you hate my family; you hate yours. Shall we proceed to try and kill each other now? I don't have all night."
      Speaker = "Melinoe"
      Event = "PrometheusAboutBrothers01"
    }
    {
      Id = "Prometheus_0136"
      InheritFrom = "BaseNarrative"
      DisplayName = "My brothers and I also used to quarrel frequently. I thought I had outgrown it; become more civilized. But clearly no."
      Speaker = "Prometheus"
      Event = "PrometheusAboutBrothers01"
    }
    {
      Id = "Prometheus_0338"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have an avian companion of your own. A scraggly and pallid raven, mediocre wingspan, lacking the raw instinct to hunt and kill like Aetos here. But still, a loyal bird."
      Speaker = "Prometheus"
      Event = "PrometheusAboutRavenFamiliar01"
    }
    {
      Id = "MelinoeField_3982"
      InheritFrom = "BaseNarrative"
      DisplayName = "And not once has Raki tried to rip my liver out of me. There are much more effective ways to forge bonds with animals, but you must know that now."
      Speaker = "Melinoe"
      Event = "PrometheusAboutRavenFamiliar01"
    }
    {
      Id = "Prometheus_0339"
      InheritFrom = "BaseNarrative"
      DisplayName = "I was in no position to negotiate with Aetos when first we met. But now he listens to me, typically... although when he identifies his prey, he can become {#Emph}quite {#Prev}fixated by it."
      Speaker = "Prometheus"
      Event = "PrometheusAboutRavenFamiliar01"
    }
    {
      Id = "Prometheus_0336"
      InheritFrom = "BaseNarrative"
      DisplayName = "You bear an artifact belonging to one whom I know, I sense it there. How did you get it...? {#Emph}Ah{#Prev}, no need to say; doubtless the gifting custom of Olympus, nothing more."
      Speaker = "Prometheus"
      Event = "PrometheusAboutHeraclesKeepsake01"
    }
    {
      Id = "MelinoeField_3980"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Gifting custom? {#Prev}You mean this Lion Fang from Heracles. What, were you counting on the son of Zeus giving his hard-fought trophy to one such as you instead?"
      Speaker = "Melinoe"
      Event = "PrometheusAboutHeraclesKeepsake01"
    }
    {
      Id = "Prometheus_0337"
      InheritFrom = "BaseNarrative"
      DisplayName = "You can be every bit as stubborn and brutish as the beast from which that tooth was torn. Yet you are unworthy of it all the same."
      Speaker = "Prometheus"
      Event = "PrometheusAboutHeraclesKeepsake01"
    }
    {
      Id = "MelinoeField_3981"
      InheritFrom = "BaseNarrative"
      DisplayName = "You mean this Lion Fang from your friend Heracles. What, were you counting on the son of Zeus giving his hard-fought trophy to {#Emph}you {#Prev}instead?"
      Speaker = "Melinoe"
      Event = "PrometheusAboutHeraclesKeepsake01_B"
    }
    {
      Id = "Prometheus_0324"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have been busying yourself elsewhere... down in that Underworld of yours, no doubt. Unless you've started having greater difficulty getting to this point?"
      Speaker = "Prometheus"
      Event = "PrometheusAboutUnderworld01"
    }
    {
      Id = "MelinoeField_3974"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're the Titan of Foresight, why don't you tell me? It's a chance to prove this gift of yours is more than a tall claim."
      Speaker = "Melinoe"
      Event = "PrometheusAboutUnderworld01"
    }
    {
      Id = "Prometheus_0325"
      InheritFrom = "BaseNarrative"
      DisplayName = "I knew you were going to say that; so that I could now take {#Emph}this {#Prev}as an opportunity to clarify that {#Emph}foresight is not mind-reading."
      Speaker = "Prometheus"
      Event = "PrometheusAboutUnderworld01"
    }
    {
      Id = "Prometheus_0342"
      InheritFrom = "BaseNarrative"
      DisplayName = "Something has changed in you since when last you were here. I know what it is... and what shall happen when you finally make use of it, perhaps even tonight."
      Speaker = "Prometheus"
      Event = "PrometheusAboutUltimateProgress01"
    }
    {
      Id = "MelinoeField_3956"
      InheritFrom = "BaseNarrative"
      DisplayName = "You must mean {#Emph}Disintegration of Monstrosity{#Prev}. Yes, I have something for Typhon here. You're fortunate I don't first put it to the test on {#Emph}you."
      Speaker = "Melinoe"
      Event = "PrometheusAboutUltimateProgress01"
    }
    {
      Id = "Prometheus_0343"
      InheritFrom = "BaseNarrative"
      DisplayName = "Stay your threats! I know you shall not use this power against me; if gods and Titans could kill one another as mortals do, our history would have been {#Emph}much, much shorter."
      Speaker = "Prometheus"
      Event = "PrometheusAboutUltimateProgress01"
    }
    {
      Id = "Prometheus_0340"
      InheritFrom = "BaseNarrative"
      DisplayName = "My master does not realize what shall become of him once all is said and done; do you? How abhorrent, to try and steal away one's immortality."
      Speaker = "Prometheus"
      Event = "PrometheusAboutUltimateProgress02"
    }
    {
      Id = "MelinoeField_3983"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've truly heard it all. A {#Emph}thief{#Prev}, lecturing me about {#Emph}stealing! {#Prev}Chronos took my family, and more... he should realize what shall become of him."
      Speaker = "Melinoe"
      Event = "PrometheusAboutUltimateProgress02"
    }
    {
      Id = "Prometheus_0341"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your father's father... you share some of his ancient lineage, and his obsession with the inevitable. Come get what you desire, then! But one outcome awaits as you continue down this path."
      Speaker = "Prometheus"
      Event = "PrometheusAboutUltimateProgress02"
    }
    {
      Id = "Prometheus_0344"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, Agent of Change... the monster Typhon is eliminated and my master certainly is not himself; or rather, now he {#Emph}is. {#Prev}Many have said they knew you could do it but only {#Emph}I {#Prev}truly did. Yet you know as well as I that we're not finished."
      Speaker = "Prometheus"
      Event = "PrometheusPostTrueEnding01"
    }
    {
      Id = "MelinoeField_3957"
      InheritFrom = "BaseNarrative"
      DisplayName = "Chronos has surrendered, but here you still are, giving his remnant legions their orders. Decided to take matters into your {#Emph}own {#Prev}thieving hands, then?"
      Speaker = "Melinoe"
      Event = "PrometheusPostTrueEnding01"
    }
    {
      Id = "Prometheus_0345"
      InheritFrom = "BaseNarrative"
      DisplayName = "That I decided long ago, when I gave myself to your lord uncle's chains. And I still oppose you, yes. For what you seek beyond, you shall find only through the flames of battle!"
      Speaker = "Prometheus"
      Event = "PrometheusPostTrueEnding01"
    }
    {
      Id = "MelinoeField_3958"
      InheritFrom = "BaseNarrative"
      DisplayName = "The gods are grudgingly {#Emph}permitting {#Prev}this behavior of yours, Titan? The vandalizing of their mountain... the perpetual assaults on their defenses... fighting me?"
      Speaker = "Melinoe"
      Event = "PrometheusPostTrueEnding02"
    }
    {
      Id = "Prometheus_0346"
      InheritFrom = "BaseNarrative"
      DisplayName = "My master, or perhaps my {#Emph}former {#Prev}master as I now should say, wishes to undo certain perceived wrongs, as you are well aware. I merely have a part to play in this."
      Speaker = "Prometheus"
      Event = "PrometheusPostTrueEnding02"
    }
    {
      Id = "MelinoeField_3959"
      InheritFrom = "BaseNarrative"
      DisplayName = "And you're prepared to fight eternally against me, then? For my grandfather to be absolved of the mistakes of his past, and for the future of the gods to be secured?"
      Speaker = "Melinoe"
      Event = "PrometheusPostTrueEnding02"
    }
    {
      Id = "Prometheus_0347"
      InheritFrom = "BaseNarrative"
      DisplayName = "I am prepared to fight eternally for what I believe in; and so that {#Emph}time flows freely forth{#Prev}, if that is what it takes."
      Speaker = "Prometheus"
      Event = "PrometheusPostTrueEnding02"
    }
    {
      Id = "MelinoeField_3961"
      InheritFrom = "BaseNarrative"
      DisplayName = "The war is over, Titan! Drop the act. You still refer to Chronos as your master, and seem no less charitable towards the gods, despite now doing this for their sake not just yours."
      Speaker = "Melinoe"
      Event = "PrometheusPostTrueEnding03"
    }
    {
      Id = "Prometheus_0350"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know as well as I that the conditions of your climb need to approximate your prior path, if you are going to succeed. And I admit that the result I seek would otherwise not be possible. Thus, here we find ourselves."
      Speaker = "Prometheus"
      Event = "PrometheusPostTrueEnding03"
    }
    {
      Id = "MelinoeField_3962"
      InheritFrom = "BaseNarrative"
      DisplayName = "The result you seek involves me repeatedly beating you up? Perhaps all you really {#Emph}do {#Prev}want is a proper thrashing, under the guise of acting like some sort of savior."
      Speaker = "Melinoe"
      Event = "PrometheusPostTrueEnding03"
    }
    {
      Id = "Prometheus_0351"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have extraordinarily high tolerance for pain. Though for such mockery, less so. Remember, we can {#Emph}both {#Prev}administer a thrashing here."
      Speaker = "Prometheus"
      Event = "PrometheusPostTrueEnding03"
    }
    {
      Id = "Prometheus_0348"
      InheritFrom = "BaseNarrative"
      DisplayName = "When my master lets you cross a boundary beyond this realm to face the monster Typhon as before, the outcome of {#Emph}that{#Prev}, I cannot foresee... how did the last one go?"
      Speaker = "Prometheus"
      Event = "PrometheusAboutPostTyphon01"
    }
    {
      Id = "MelinoeField_3960"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps I'll leave it to your imagination. It must be novel for you not to know the outcome of such incidents."
      Speaker = "Melinoe"
      Event = "PrometheusAboutPostTyphon01"
    }
    {
      Id = "Prometheus_0349"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh that it is. Well then don't tell me, if you like; I'm {#Emph}far {#Prev}more interested in the end result than in the many steps we shall be taking on the way."
      Speaker = "Prometheus"
      Event = "PrometheusAboutPostTyphon01"
    }
    {
      Id = "Prometheus_0352"
      InheritFrom = "BaseNarrative"
      DisplayName = "My master indicates that your accomplishments are mounting night by night. He awaits beyond, should you prevail again."
      Speaker = "Prometheus"
      Event = "PrometheusAboutPostTyphon02"
    }
    {
      Id = "MelinoeField_3963"
      InheritFrom = "BaseNarrative"
      DisplayName = "First you, then Typhon, same as ever. Though I'm delighted to know I'm living up to Grandfather's expectations. Could always use more family members to appease."
      Speaker = "Melinoe"
      Event = "PrometheusAboutPostTyphon02"
    }
    {
      Id = "Prometheus_0353"
      InheritFrom = "BaseNarrative"
      DisplayName = "I do not envy you in that. Nevertheless, so long as our paths are intertwined, I shall be here; no need to let me know ahead of time."
      Speaker = "Prometheus"
      Event = "PrometheusAboutPostTyphon02"
    }
    {
      Id = "Prometheus_0356"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's done...! It's finally done, except... I need to hear you say it first. To know for certain what I have foreseen. Now, please..."
      Speaker = "Prometheus"
      Event = "PrometheusAboutEpilogue01"
    }
    {
      Id = "MelinoeField_3965"
      InheritFrom = "BaseNarrative"
      DisplayName = "You may have to be a little more specific, but... I take it you mean that I found the Fates? Or they found me, but either way. I thought you didn't care for them too much."
      Speaker = "Melinoe"
      Event = "PrometheusAboutEpilogue01"
    }
    {
      Id = "Prometheus_0357"
      InheritFrom = "BaseNarrative"
      DisplayName = "I care for what they say... what they decide to make of this world of ours. What has their exile driven them to do? They would not make the same mistakes again."
      Speaker = "Prometheus"
      Event = "PrometheusAboutEpilogue01"
    }
    {
      Id = "MelinoeField_3966"
      InheritFrom = "BaseNarrative"
      DisplayName = "They've had it with our squabbling; that I can understand. So they have deemed the coming of another age in which the gods apparently shall hold less sway. A time of fewer burdens on us, so our tempers can subside."
      Speaker = "Melinoe"
      Event = "PrometheusAboutEpilogue01"
    }
    {
      Id = "Prometheus_0358"
      InheritFrom = "BaseNarrative"
      DisplayName = "...The coming of a golden age... perhaps not quite the one my master had envisioned, but nevertheless. All this toil, at long last... and till then... I suppose we fight."
      Speaker = "Prometheus"
      Event = "PrometheusAboutEpilogue01"
    }
    {
      Id = "MelinoeField_3967"
      InheritFrom = "BaseNarrative"
      DisplayName = "So you truly saw all this coming? The Three Fates and their prophecy of a new age. Why have you fought so hard to stop me, then? What if you had prevailed?"
      Speaker = "Melinoe"
      Event = "PrometheusAboutEpilogue02"
    }
    {
      Id = "Prometheus_0360"
      InheritFrom = "BaseNarrative"
      DisplayName = "I knew my efforts to prevent you all would be for naught; but I was compelled to make those efforts anyhow. To put it simply, I could see no other way."
      Speaker = "Prometheus"
      Event = "PrometheusAboutEpilogue02"
    }
    {
      Id = "MelinoeField_3968"
      InheritFrom = "BaseNarrative"
      DisplayName = "We might have fought on the same side. Surely that would have sooner led to your result than sending Aetos after me."
      Speaker = "Melinoe"
      Event = "PrometheusAboutEpilogue02"
    }
    {
      Id = "Prometheus_0361"
      InheritFrom = "BaseNarrative"
      DisplayName = "A reasonable theory but it never would have gone the way you expect. This was never about mortalkind for you."
      Speaker = "Prometheus"
      Event = "PrometheusAboutEpilogue02"
    }
    {
      Id = "MelinoeField_3969"
      InheritFrom = "BaseNarrative"
      DisplayName = "...You're right, it wasn't. I had my own problems to contend with before attempting to rid mortalkind of theirs."
      Speaker = "Melinoe"
      Event = "PrometheusAboutEpilogue02"
    }
    {
      Id = "Prometheus_0362"
      InheritFrom = "BaseNarrative"
      DisplayName = "Yet now you have done both. Fear not; the dead may worship you, but the living couldn't care less. Though still we did what needed to be done."
      Speaker = "Prometheus"
      Event = "PrometheusAboutEpilogue02"
    }
    {
      Id = "MelinoeField_3970"
      InheritFrom = "BaseNarrative"
      DisplayName = "What of your companion Heracles? I suppose he's been in on your scheme this entire time as well. Appearing to defy the gods while serving them anyway."
      Speaker = "Melinoe"
      Event = "PrometheusAboutEpilogue03"
    }
    {
      Id = "Prometheus_0363"
      InheritFrom = "BaseNarrative"
      DisplayName = "You'll have no more success getting such answers out of me than out of him. You've seen the man; he has his reasons."
      Speaker = "Prometheus"
      Event = "PrometheusAboutEpilogue03"
    }
    {
      Id = "MelinoeField_3971"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hence your affiliation? You must have bonded over your disdain for this mountain and all it stands for. Was he the one who liberated you?"
      Speaker = "Melinoe"
      Event = "PrometheusAboutEpilogue03"
    }
    {
      Id = "Prometheus_0364"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}No answers out of me{#Prev}, I said. Not when it comes to {#Emph}him. {#Prev}But at least you now know there are offshoots of your family made of stronger stuff."
      Speaker = "Prometheus"
      Event = "PrometheusAboutEpilogue03"
    }
    {
      Id = "MelinoeField_3973"
      InheritFrom = "BaseNarrative"
      DisplayName = "Seeing as you know all about the coming age... any interesting details you can share about what's in store?"
      Speaker = "Melinoe"
      Event = "PrometheusAboutEpilogue04"
    }
    {
      Id = "Prometheus_0366"
      InheritFrom = "BaseNarrative"
      DisplayName = "The world shall be a very different place, in ways you cannot possibly conceive. In other ways, nothing shall change at all; even regress. We shall all be forgotten, then remembered, and forgotten. Again, and again, and again..."
      Speaker = "Prometheus"
      Event = "PrometheusAboutEpilogue04"
    }
    {
      Id = "Prometheus_0332"
      InheritFrom = "BaseNarrative"
      DisplayName = "This suffocating smoke on a night so black... it fills me with an older strength I thought I'd lost. A good reminder I yet live...!"
      Speaker = "Prometheus"
      Event = "PrometheusAboutShrine01"
    }
    {
      Id = "MelinoeField_3978"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm pleased to hear about this positive new turn in your existence, Titan. A fearsome night can certainly instill heightened awareness, and a will to survive."
      Speaker = "Melinoe"
      Event = "PrometheusAboutShrine01"
    }
    {
      Id = "Prometheus_0333"
      InheritFrom = "BaseNarrative"
      DisplayName = "You speak as though you are the cause yourself; impossible. Or quite unlikely I should say, but then again... {#Emph}augh{#Prev}, you dark gods. Come, let us see whether this is your night or mine!"
      Speaker = "Prometheus"
      Event = "PrometheusAboutShrine01"
    }
    {
      Id = "Prometheus_0328"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've come specifically for me tonight, haven't you? Some barbarous assignment, perhaps, from dark gods far older and greater. Well here I am."
      Speaker = "Prometheus"
      Event = "PrometheusAboutShrineBounty01"
    }
    {
      Id = "MelinoeField_3975"
      InheritFrom = "BaseNarrative"
      DisplayName = "And how could you possibly know? I've said nothing of the sort, Titan. Nor shall I."
      Speaker = "Melinoe"
      Event = "PrometheusAboutShrineBounty01"
    }
    {
      Id = "Prometheus_0329"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not this eve you won't, but later. It shall slip your mind that we had this discussion earlier and you shall tell me more. For now, come fight me for the glory of your kind."
      Speaker = "Prometheus"
      Event = "PrometheusAboutShrineBounty01"
    }
    {
      Id = "MelinoeField_3976"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're not my objective, Titan. So what do we say we make this quick? Lest you impede the will of Night."
      Speaker = "Melinoe"
      Event = "PrometheusAboutShrineBounty02"
    }
    {
      Id = "Prometheus_0330"
      InheritFrom = "BaseNarrative"
      DisplayName = "The will of Night, is it... demanding Typhon's sacrifice. Is that what you're after, scaling this mountain again and again?"
      Speaker = "Prometheus"
      Event = "PrometheusAboutShrineBounty02"
    }
    {
      Id = "MelinoeField_3977"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not necessarily just Typhon's sacrifice. All enemies of the Underworld shall have their punishment. Even {#Emph}you{#Prev}, if you dare keep this up."
      Speaker = "Melinoe"
      Event = "PrometheusAboutShrineBounty02"
    }
    {
      Id = "Prometheus_0331"
      InheritFrom = "BaseNarrative"
      DisplayName = "I am no stranger to the punishment of gods. It did not deter me then, nor shall it now, or evermore!"
      Speaker = "Prometheus"
      Event = "PrometheusAboutShrineBounty02"
    }
    {
      Id = "Prometheus_0326"
      InheritFrom = "BaseNarrative"
      DisplayName = "It seems we may be locked here in this struggle for some time; that is the consequence, of course, for what you did."
      Speaker = "Prometheus"
      Event = "PrometheusAboutSayingLittle01"
    }
    {
      Id = "MelinoeField_3984"
      InheritFrom = "BaseNarrative"
      DisplayName = "I got my family back. If it means having to get chastised every now and then by {#Emph}you{#Prev}, that's perfectly all right."
      Speaker = "Melinoe"
      Event = "PrometheusAboutSayingLittle01"
    }
    {
      Id = "Prometheus_0327"
      InheritFrom = "BaseNarrative"
      DisplayName = "I did not mean it thus. In fact, knowing these meetings may be quite habitual, perhaps it's best we keep our conversations curt. I ought not say too much from here."
      Speaker = "Prometheus"
      Event = "PrometheusAboutSayingLittle01"
    }
    {
      Id = "Prometheus_0011"
      InheritFrom = "BaseNarrative"
      DisplayName = "You cannot die but can be driven back. And you can burn, and shall."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart01"
    }
    {
      Id = "Prometheus_0012"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know the outcome of our each and every clash; yet somehow you surprise me even still."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart02"
    }
    {
      Id = "Prometheus_0013"
      InheritFrom = "BaseNarrative"
      DisplayName = "The entirety of my strength shall never again return, but I've enough for this."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart03"
    }
    {
      Id = "Prometheus_0014"
      InheritFrom = "BaseNarrative"
      DisplayName = "Aetos here still longs for the taste of liver, and who are we to deny him that?"
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart04"
    }
    {
      Id = "Prometheus_0015"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Agent of Change returns, and the course of history shall never be the same."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart05"
    }
    {
      Id = "Prometheus_0016"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sooner or later, the age of gods shall end, no matter how ferociously you fight."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart06"
    }
    {
      Id = "Prometheus_0017"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm still a little sore after what the gods did to me, for all my so-called crimes."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart07"
    }
    {
      Id = "Prometheus_0018"
      InheritFrom = "BaseNarrative"
      DisplayName = "You gods seek worshipers, in all your vanity; we Titans seek only what is ours."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart08"
    }
    {
      Id = "Prometheus_0019"
      InheritFrom = "BaseNarrative"
      DisplayName = "I endured having my liver eaten for an aeon; these bouts with you are nothing."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart09"
    }
    {
      Id = "Prometheus_0020"
      InheritFrom = "BaseNarrative"
      DisplayName = "The gift of fire I bestowed to mortalkind; I made certain to save some for you."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart10"
    }
    {
      Id = "Prometheus_0021"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do you see? Each moment I delay you, Time's plan comes closer to fruition."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart11"
    }
    {
      Id = "Prometheus_0022"
      InheritFrom = "BaseNarrative"
      DisplayName = "Whether you shall break me here again is for me to know and for you to find out."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart12"
    }
    {
      Id = "Prometheus_0023"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've seen your every trick; all that you are capable of! And you are not at your best."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart13"
    }
    {
      Id = "Prometheus_0024"
      InheritFrom = "BaseNarrative"
      DisplayName = "I shall not be the one to topple this mountain; neither shall you be the one to save it."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart14"
    }
    {
      Id = "Prometheus_0155"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've seen nothing of this world, yet defend it; I have seen it all, and shall burn it down."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart15"
    }
    {
      Id = "Prometheus_0156"
      InheritFrom = "BaseNarrative"
      DisplayName = "You owe your family nothing, yet give everything to them. Fools, all of you."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart16"
    }
    {
      Id = "Prometheus_0157"
      InheritFrom = "BaseNarrative"
      DisplayName = "There shall come a time when our conflict has ended; but I wouldn't hold my breath."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart17"
    }
    {
      Id = "Prometheus_0158"
      InheritFrom = "BaseNarrative"
      DisplayName = "What gods and Titans did to one another can never be forgiven... merely forgotten."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart18"
    }
    {
      Id = "Prometheus_0159"
      InheritFrom = "BaseNarrative"
      DisplayName = "This fire coursing through me, burning me inside... I'll show you how it feels."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart19"
    }
    {
      Id = "Prometheus_0160"
      InheritFrom = "BaseNarrative"
      DisplayName = "If I'm already guilty of unforgivable crimes according to Olympus, then this matters not."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart20"
    }
    {
      Id = "Prometheus_0161"
      InheritFrom = "BaseNarrative"
      DisplayName = "No chains shall ever bind me again; I both swear it and I know it to be true."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart21"
    }
    {
      Id = "Prometheus_0162"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've some small amount of foresight by now, do you not? You know how this ends."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart22"
    }
    {
      Id = "Prometheus_0478"
      InheritFrom = "BaseNarrative"
      DisplayName = "The gods demand your services and you comply; but I am obligated to resist."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart23"
    }
    {
      Id = "Prometheus_0479"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll not attempt to tell you what shall come of this... for you would never believe it."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart24"
    }
    {
      Id = "Prometheus_0481"
      InheritFrom = "BaseNarrative"
      DisplayName = "I need no armaments to drive you back... unless you count this flame."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart25"
    }
    {
      Id = "Prometheus_0482"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've kept good Heracles there waiting patiently to put that club of his to further use."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart26"
    }
    {
      Id = "Prometheus_0483"
      InheritFrom = "BaseNarrative"
      DisplayName = "We are the fury of Olympus here, not you; and we shall never abandon this fight."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart27"
    }
    {
      Id = "Prometheus_0484"
      InheritFrom = "BaseNarrative"
      DisplayName = "Heracles is bound to serve the gods, as apparently are you. Yet {#Emph}this {#Prev}is the result."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart28"
    }
    {
      Id = "Prometheus_0485"
      InheritFrom = "BaseNarrative"
      DisplayName = "You cannot break us, Agent of Change; but perhaps you can break past us again."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart29"
    }
    {
      Id = "Prometheus_0539"
      InheritFrom = "BaseNarrative"
      DisplayName = "I had a premonition of this very moment."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart30"
    }
    {
      Id = "Prometheus_0540"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know where this all leads. Let's see it through!"
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart31"
    }
    {
      Id = "Prometheus_0541"
      InheritFrom = "BaseNarrative"
      DisplayName = "I almost regret what's about to transpire."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart32"
    }
    {
      Id = "Prometheus_0542"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come, let us see whether this is your night or mine!"
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart33"
    }
    {
      Id = "Prometheus_0543"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps it's best we keep our conversations curt."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart34"
    }
    {
      Id = "Prometheus_0544"
      InheritFrom = "BaseNarrative"
      DisplayName = "Change does not come without conflict."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart35"
    }
    {
      Id = "Prometheus_0480"
      InheritFrom = "BaseNarrative"
      DisplayName = "It seems I now pay penance to the gods once more, though they shall never bind me."
      Speaker = "Prometheus"
      Event = "PrometheusMiscStart36"
    }
    {
      Id = "Heracles_0640"
      InheritFrom = "BaseNarrative"
      DisplayName = "One night after another you just keep turning up, sister. Are you enjoying this?"
      Speaker = "Heracles"
      Event = "HeraclesFightMiscStart01"
    }
    {
      Id = "Heracles_0690"
      InheritFrom = "BaseNarrative"
      DisplayName = "You got here rather quick tonight, didn't you, witch. Some dark gods aiding your ascent?"
      Speaker = "Heracles"
      Event = "HeraclesFightMiscStart02"
    }
    {
      Id = "Heracles_0691"
      InheritFrom = "BaseNarrative"
      DisplayName = "Already made it all this way. Some strangeness is afoot... but I care not for that right now."
      Speaker = "Heracles"
      Event = "HeraclesFightMiscStart03"
    }
    {
      Id = "Heracles_0349"
      InheritFrom = "BaseNarrative"
      DisplayName = "Whether we fight together or against each other matters not; only the fight itself."
      Speaker = "Heracles"
      Event = "HeraclesFightMiscStart04"
    }
    {
      Id = "Heracles_0642"
      InheritFrom = "BaseNarrative"
      DisplayName = "Should be more than enough carnage for the both of us here any moment now."
      Speaker = "Heracles"
      Event = "HeraclesFightMiscStart05"
    }
    {
      Id = "Heracles_0402"
      InheritFrom = "BaseNarrative"
      DisplayName = "Go home, witch. You're no match for my club."
      Speaker = "Heracles"
      Event = "HeraclesFightMiscStart06"
    }
    {
      Id = "Heracles_0342"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not too cold for you up here, sister? Or does battle warm you over as it does me?"
      Speaker = "Heracles"
      Event = "HeraclesFightMiscStart07"
    }
    {
      Id = "Heracles_0340"
      InheritFrom = "BaseNarrative"
      DisplayName = "Notice it's harder to breathe up here, sister? Almost like this mountain's cursed."
      Speaker = "Heracles"
      Event = "HeraclesFightMiscStart08"
    }
    {
      Id = "Heracles_0031"
      InheritFrom = "BaseNarrative"
      DisplayName = "Keep letting Olympus toss you around, and someday you'll be just like me."
      Speaker = "Heracles"
      Event = "HeraclesFightMiscStart09"
    }
    {
      Id = "Heracles_0024"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're either good or ill fortune, not yet made up my mind."
      Speaker = "Heracles"
      Event = "HeraclesFightMiscStart10"
    }
    {
      Id = "Prometheus_0005"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Urgh... {#Prev}I knew this would happen. Yet I could not prevent it, do you see? I could only... do my part..."
      Speaker = "Prometheus"
      Event = "PrometheusBossOutro01"
    }
    {
      Id = "MelinoeField_2383"
      InheritFrom = "BaseNarrative"
      DisplayName = "Silence. Save your troubles for your master Chronos."
      Speaker = "Melinoe"
      Event = "PrometheusBossOutro01"
    }
    {
      Id = "Prometheus_0006"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's not my troubles that I mean to save... Agent of Change..."
      Speaker = "Prometheus"
      Event = "PrometheusBossOutro01"
    }
    {
      Id = "Prometheus_0025"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I've done my part here, just as you did yours... for this was bound to happen as it did."
      Speaker = "Prometheus"
      Event = "PrometheusBossMiscDefeat01"
    }
    {
      Id = "Prometheus_0026"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Curse these old wounds of mine... I once was stronger than this...!"
      Speaker = "Prometheus"
      Event = "PrometheusBossMiscDefeat02"
    }
    {
      Id = "Prometheus_0027"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I knew that this would be a struggle... but hold always to the chance I may be wrong..."
      Speaker = "Prometheus"
      Event = "PrometheusBossMiscDefeat03"
    }
    {
      Id = "Prometheus_0028"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I am beaten. But you cannot afford to give chase, and my strength shall return."
      Speaker = "Prometheus"
      Event = "PrometheusBossMiscDefeat04"
    }
    {
      Id = "Prometheus_0029"
      InheritFrom = "BaseNarrative"
      DisplayName = "...The famous wrath of Olympus... it cannot easily be stopped, you see?"
      Speaker = "Prometheus"
      Event = "PrometheusBossMiscDefeat05"
    }
    {
      Id = "Prometheus_0030"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Aetos and I have done what needed to be done. Now you go do the same."
      Speaker = "Prometheus"
      Event = "PrometheusBossMiscDefeat06"
    }
    {
      Id = "Prometheus_0151"
      InheritFrom = "BaseNarrative"
      DisplayName = "...If suffering today brings about a better tomorrow, so be it."
      Speaker = "Prometheus"
      Event = "PrometheusBossMiscDefeat07"
    }
    {
      Id = "Prometheus_0152"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I foresaw your trickery yet still could not prevent it, no matter what I tried."
      Speaker = "Prometheus"
      Event = "PrometheusBossMiscDefeat08"
    }
    {
      Id = "Prometheus_0153"
      InheritFrom = "BaseNarrative"
      DisplayName = "...{#Emph}Heh! {#Prev}Compared to what I have withstood before, this was nothing at all."
      Speaker = "Prometheus"
      Event = "PrometheusBossMiscDefeat09"
    }
    {
      Id = "Prometheus_0154"
      InheritFrom = "BaseNarrative"
      DisplayName = "...If you could see what I've foreseen, you'd not believe it anyhow."
      Speaker = "Prometheus"
      Event = "PrometheusBossMiscDefeat10"
    }
    {
      Id = "Prometheus_0451"
      InheritFrom = "BaseNarrative"
      DisplayName = "...You gods never forgive; why then should I, when I could fight instead?"
      Speaker = "Prometheus"
      Event = "PrometheusBossMiscDefeat11"
    }
    {
      Id = "Prometheus_0452_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "...The strength to best both Heracles and me... I can foresee no way to stop it now."
      Speaker = "Prometheus"
      Event = "PrometheusBossMiscDefeat12"
    }
    {
      Id = "Prometheus_0453"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I have foreseen defeats of mine before... every last one of them, in point of fact..."
      Speaker = "Prometheus"
      Event = "PrometheusBossMiscDefeat13"
    }
    {
      Id = "Prometheus_0456"
      InheritFrom = "BaseNarrative"
      DisplayName = "...You have defeated me again... but all my wounds shall heal. They always do..."
      Speaker = "Prometheus"
      Event = "PrometheusBossMiscDefeat14"
    }
    {
      Id = "Prometheus_0457"
      InheritFrom = "BaseNarrative"
      DisplayName = "...My strength has failed me repeatedly... but it always comes back..."
      Speaker = "Prometheus"
      Event = "PrometheusBossMiscDefeat15"
    }
    {
      Id = "Prometheus_0458"
      InheritFrom = "BaseNarrative"
      DisplayName = "...The flames that you withstood... perhaps they were never meant for you..."
      Speaker = "Prometheus"
      Event = "PrometheusBossMiscDefeat16"
    }
    {
      Id = "Prometheus_0459_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "...My foreknowledge of this moment... it's as though... we've done this all before..."
      Speaker = "Prometheus"
      Event = "PrometheusBossMiscDefeat17"
    }
    {
      Id = "Prometheus_0450"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Now do you begin to understand... what I have done at every turn...?"
      Speaker = "Prometheus"
      Event = "PrometheusBossMiscDefeat18"
    }
    {
      Id = "Prometheus_0454"
      InheritFrom = "BaseNarrative"
      DisplayName = "...I knew I could not stop you... on the contrary, you... needed to prevail..."
      Speaker = "Prometheus"
      Event = "PrometheusBossMiscDefeat19"
    }
    {
      Id = "Prometheus_0455"
      InheritFrom = "BaseNarrative"
      DisplayName = "...Were it not for this fight... you'd never find a single remnant of Typhon..."
      Speaker = "Prometheus"
      Event = "PrometheusBossMiscDefeat20"
    }
    {
      Id = "Prometheus_0095"
      InheritFrom = "BaseNarrative"
      DisplayName = "Legions of the Titan Lord, {#Emph}attack!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusSpawnWaveLines"
    }
    {
      Id = "Prometheus_0096"
      InheritFrom = "BaseNarrative"
      DisplayName = "Reinforcements, {#Emph}now!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusSpawnWaveLines"
    }
    {
      Id = "Prometheus_0097"
      InheritFrom = "BaseNarrative"
      DisplayName = "Here come my master's legions!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusSpawnWaveLines"
    }
    {
      Id = "Prometheus_0098"
      InheritFrom = "BaseNarrative"
      DisplayName = "My forces have regrouped!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusSpawnWaveLines"
    }
    {
      Id = "Prometheus_0248"
      InheritFrom = "BaseNarrative"
      DisplayName = "Legions, on me!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusSpawnWaveLines"
    }
    {
      Id = "Prometheus_0249"
      InheritFrom = "BaseNarrative"
      DisplayName = "Legions, form up!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusSpawnWaveLines"
    }
    {
      Id = "Prometheus_0250_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "Legions of the Titan Lord!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusSpawnWaveLines"
    }
    {
      Id = "Prometheus_0251"
      InheritFrom = "BaseNarrative"
      DisplayName = "Assault forces, to me!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusSpawnWaveLines"
    }
    {
      Id = "Prometheus_0252"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've more to contend with than me."
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusSpawnWaveLines"
    }
    {
      Id = "Prometheus_0440"
      InheritFrom = "BaseNarrative"
      DisplayName = "Quickly, Legions: Get her {#Emph}now!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusSpawnWaveLines"
    }
    {
      Id = "Prometheus_0441"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now, Legions! {#Emph}Descend!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusSpawnWaveLines"
    }
    {
      Id = "Prometheus_0442"
      InheritFrom = "BaseNarrative"
      DisplayName = "We have you surrounded!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusSpawnWaveLines"
    }
    {
      Id = "Prometheus_0443"
      InheritFrom = "BaseNarrative"
      DisplayName = "Legions, fire support!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusSpawnWaveLines"
    }
    {
      Id = "Prometheus_0444"
      InheritFrom = "BaseNarrative"
      DisplayName = "Legions, open fire!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusSpawnWaveLines"
    }
    {
      Id = "Prometheus_0445"
      InheritFrom = "BaseNarrative"
      DisplayName = "Legions of the Titan Lord, {#Emph}come in!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusSpawnWaveLines"
    }
    {
      Id = "Prometheus_0253"
      InheritFrom = "BaseNarrative"
      DisplayName = "I do not fight alone!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusSpawnWaveLines"
    }
    {
      Id = "Prometheus_0065"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now..."
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusPreAttackLines"
    }
    {
      Id = "Prometheus_0066"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now then..."
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusPreAttackLines"
    }
    {
      Id = "Prometheus_0067"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ready...?"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusPreAttackLines"
    }
    {
      Id = "Prometheus_0068"
      InheritFrom = "BaseNarrative"
      DisplayName = "Enough!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusPreAttackLines"
    }
    {
      Id = "Prometheus_0069"
      InheritFrom = "BaseNarrative"
      DisplayName = "See here..."
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusPreAttackLines"
    }
    {
      Id = "Prometheus_0070"
      InheritFrom = "BaseNarrative"
      DisplayName = "Very well..."
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusPreAttackLines"
    }
    {
      Id = "Prometheus_0244"
      InheritFrom = "BaseNarrative"
      DisplayName = "You'll suffer."
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusPreAttackLines"
    }
    {
      Id = "Prometheus_0245"
      InheritFrom = "BaseNarrative"
      DisplayName = "Back off...!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusPreAttackLines"
    }
    {
      Id = "Prometheus_0517"
      InheritFrom = "BaseNarrative"
      DisplayName = "Prepare...!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusPreAttackLines"
    }
    {
      Id = "Prometheus_0518"
      InheritFrom = "BaseNarrative"
      DisplayName = "You..."
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusPreAttackLines"
    }
    {
      Id = "Prometheus_0519"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now this..."
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusPreAttackLines"
    }
    {
      Id = "Prometheus_0520"
      InheritFrom = "BaseNarrative"
      DisplayName = "For you..."
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusPreAttackLines"
    }
    {
      Id = "Prometheus_0521"
      InheritFrom = "BaseNarrative"
      DisplayName = "See this...?"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusPreAttackLines"
    }
    {
      Id = "Prometheus_0522"
      InheritFrom = "BaseNarrative"
      DisplayName = "I see..."
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusPreAttackLines"
    }
    {
      Id = "Prometheus_0242"
      InheritFrom = "BaseNarrative"
      DisplayName = "Curse you gods!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusPreAttackLines"
    }
    {
      Id = "Prometheus_0243"
      InheritFrom = "BaseNarrative"
      DisplayName = "For what you did!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusPreAttackLines"
    }
    {
      Id = "Prometheus_0087"
      InheritFrom = "BaseNarrative"
      DisplayName = "See {#Emph}this!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusAttackLines"
    }
    {
      Id = "Prometheus_0088"
      InheritFrom = "BaseNarrative"
      DisplayName = "Here!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusAttackLines"
    }
    {
      Id = "Prometheus_0178"
      InheritFrom = "BaseNarrative"
      DisplayName = "There!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusAttackLines"
    }
    {
      Id = "Prometheus_0089"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Here{#Prev}, then!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusAttackLines"
    }
    {
      Id = "Prometheus_0090"
      InheritFrom = "BaseNarrative"
      DisplayName = "Fall!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusAttackLines"
    }
    {
      Id = "Prometheus_0091"
      InheritFrom = "BaseNarrative"
      DisplayName = "Out of my sight!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusAttackLines"
    }
    {
      Id = "Prometheus_0093"
      InheritFrom = "BaseNarrative"
      DisplayName = "Watch {#Emph}this!"
