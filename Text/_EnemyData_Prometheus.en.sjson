    }
    {
      Id = "Prometheus_0189"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Damn {#Emph}you."
      Speaker = "Prometheus"
      Event = "Prometheus.LastStandReactionVoiceLines"
    }
    {
      Id = "Prometheus_0105"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Your strength fades."
      Speaker = "Prometheus"
      Event = "Prometheus.LastStandReactionVoiceLines"
    }
    {
      Id = "Prometheus_0106"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Withstood all that..."
      Speaker = "Prometheus"
      Event = "Prometheus.LastStandReactionVoiceLines"
    }
    {
      Id = "Prometheus_0099"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What's life without pain?"
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0100"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Suffer as I did."
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0101"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Suffer, then."
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0102"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Turn back."
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0172"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Go back."
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0173"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Return to hell."
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0174"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Leave this place."
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0175"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Do you see?"
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0176"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll not hold back."
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0177"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll burn you to ash."
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0393"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're not prepared for what awaits you at the summit!"
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0394"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come, show me what little foresight you can muster!"
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0395"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You need but to evade three waves of flame, but {#Emph}where?"
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0396"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Choose your path carefully, Agent of Change! Lest you burn."
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0397"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You know where I intend to strike, but shall that be enough?"
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0399"
      InheritFrom = "BaseSubtitle"
      DisplayName = "But one false step and I shall char you to a crisp."
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0401"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Was it the top path, or the middle path, perhaps...?"
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0402"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Surely the lower path first, followed by the top?"
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0403"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Best stay there in the middle path? Or, the lower path perhaps...?"
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0400"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Am I becoming too predictable for you, Agent of Change?"
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0398"
      InheritFrom = "BaseSubtitle"
      DisplayName = "How easily you can anticipate my flames by now..."
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0179"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You gods..."
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0404"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What have I to hide from the likes of you?"
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0405"
      InheritFrom = "BaseSubtitle"
      DisplayName = "All you gods, your memories are {#Emph}far {#Prev}too short."
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0406"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Try to find a pattern if you wish; but there is none."
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0407"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I know what is about to happen to you here; do you?"
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0408"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Remember what you are about to see..."
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0409"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Can you predict what shall occur as easily as I?"
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0410"
      InheritFrom = "BaseSubtitle"
      DisplayName = "My flames shall not spare you or {#Emph}any {#Prev}god...!"
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0411"
      InheritFrom = "BaseSubtitle"
      DisplayName = "These flames never belonged to you, but here! {#Emph}Have {#Prev}them!"
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0412"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I know what shall become of you, Agent of Change... but first..."
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0413"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You gods have much to answer for, yet no one to make you..."
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0414"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Let's see you once again evade these flames!"
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Prometheus_0415"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I was shorn apart on a freezing mountain; {#Emph}this {#Prev}is {#Emph}nothing."
      Speaker = "Prometheus"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Heracles_0381"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You burn. I don't."
      Speaker = "Heracles"
      Event = "Prometheus.MemoryAttackIntroVoiceLines"
    }
    {
      Id = "Heracles_0382"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Now what, witch?"
