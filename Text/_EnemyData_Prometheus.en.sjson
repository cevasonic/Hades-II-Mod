    }
    {
      Id = "Prometheus_0528"
      InheritFrom = "BaseNarrative"
      DisplayName = "Return!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusAttackLines"
    }
    {
      Id = "Prometheus_0092"
      InheritFrom = "BaseNarrative"
      DisplayName = "This is {#Emph}over!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusAttackLines"
    }
    {
      Id = "Prometheus_0094"
      InheritFrom = "BaseNarrative"
      DisplayName = "You wretched gods..."
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusAttackLines"
    }
    {
      Id = "Prometheus_0071"
      InheritFrom = "BaseNarrative"
      DisplayName = "Aetos, attack!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusEagleComboLines"
    }
    {
      Id = "Prometheus_0072"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now, Aetos!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusEagleComboLines"
    }
    {
      Id = "Prometheus_0073"
      InheritFrom = "BaseNarrative"
      DisplayName = "Aetos, {#Emph}now!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusEagleComboLines"
    }
    {
      Id = "Prometheus_0074"
      InheritFrom = "BaseNarrative"
      DisplayName = "Aetos, go!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusEagleComboLines"
    }
    {
      Id = "Prometheus_0075"
      InheritFrom = "BaseNarrative"
      DisplayName = "Go, Aetos!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusEagleComboLines"
    }
    {
      Id = "Prometheus_0076"
      InheritFrom = "BaseNarrative"
      DisplayName = "Together, Aetos!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusEagleComboLines"
    }
    {
      Id = "Prometheus_0077"
      InheritFrom = "BaseNarrative"
      DisplayName = "Get her, Aetos!"
      Speaker = "Prometheus"
      Event = "GlobalVoiceLines.PrometheusEagleComboLines"
    }
    {
      Id = "Prometheus_0078"
      InheritFrom = "BaseNarrative"
