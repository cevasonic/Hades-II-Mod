    }
    {
      Id = "Zagreus_0283"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...Don't... back... down...!"
      Speaker = "Zagreus"
      Event = "Zagreus.PhaseEndedVoiceLines"
    }
    {
      Id = "Zagreus_0108"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That was... beginner's... luck..."
      Speaker = "Zagreus"
      Event = "Zagreus.DefeatedVoiceLines"
    }
    {
      Id = "Zagreus_0341"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I'll... be going... now..."
      Speaker = "Zagreus"
      Event = "Zagreus.DefeatedVoiceLines"
    }
    {
      Id = "Zagreus_0342"
      InheritFrom = "BaseSubtitle"
      DisplayName = "You're... not... bad..."
      Speaker = "Zagreus"
      Event = "Zagreus.DefeatedVoiceLines"
    }
    {
      Id = "Zagreus_0343"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Let's... do this... again..."
      Speaker = "Zagreus"
      Event = "Zagreus.DefeatedVoiceLines"
    }
    {
      Id = "Zagreus_0344"
      InheritFrom = "BaseSubtitle"
      DisplayName = "See... you... soon..."
      Speaker = "Zagreus"
      Event = "Zagreus.DefeatedVoiceLines"
    }
    {
      Id = "Zagreus_0345"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Down... we... go..."
