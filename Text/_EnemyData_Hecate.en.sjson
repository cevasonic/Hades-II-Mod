      Event = "Hecate.BossKillVoiceLines"
    }
    {
      Id = "HecateField_0446"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hold! Short work...!"
      Speaker = "Hecate"
      Event = "Hecate.BossKillVoiceLines"
    }
    {
      Id = "HecateField_0447"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hold! Swiftly done!"
      Speaker = "Hecate"
      Event = "Hecate.BossKillVoiceLines"
    }
    {
      Id = "HecateField_0448"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hold! 'Twas nigh unfair..."
      Speaker = "Hecate"
      Event = "Hecate.BossKillVoiceLines"
    }
    {
      Id = "HecateField_0449"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hold! I think you won...!"
      Speaker = "Hecate"
      Event = "Hecate.BossKillVoiceLines"
    }
    {
      Id = "HecateField_0450"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hold! Flawless form."
      Speaker = "Hecate"
      Event = "Hecate.BossKillVoiceLines"
    }
    {
      Id = "HecateField_0451"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hold! I was outmatched...!"
      Speaker = "Hecate"
      Event = "Hecate.BossKillVoiceLines"
    }
    {
      Id = "HecateField_0452"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Hold! {#Emph}Whew! {#Prev}Good."
      Speaker = "Hecate"
      Event = "Hecate.BossKillVoiceLines"
    }
    {
      Id = "Hecate_0007"
      InheritFrom = "BaseNarrative"
      DisplayName = "Welcome to the edge of Erebus. Well done, Melinoë."
      Speaker = "Hecate"
      Event = "HecateBossFirstAppearance"
    }
    {
      Id = "Melinoe_0037"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thank you, Headmistress Hecate. I could not have reached this point without your guidance."
      Speaker = "Melinoe"
      Event = "HecateBossFirstAppearance"
    }
    {
      Id = "Hecate_0008"
      InheritFrom = "BaseNarrative"
      DisplayName = "And, in turn, you shall not {#Emph}pass {#Prev}this point without a demonstration of your capability."
      Speaker = "Hecate"
      Event = "HecateBossFirstAppearance"
    }
    {
      Id = "Melinoe_1171"
      InheritFrom = "BaseNarrative"
      DisplayName = "My capability? You'd have us face each other here... even though my task has already begun?"
      Speaker = "Melinoe"
      Event = "HecateBossFirstAppearance"
    }
    {
      Id = "Hecate_0438"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your training shall never be complete. And I would know if you stand any chance at all against our enemy."
      Speaker = "Hecate"
      Event = "HecateBossFirstAppearance"
    }
    {
      Id = "Hecate_0436"
      InheritFrom = "BaseNarrative"
      DisplayName = "You reached the edge of Erebus already. You have surpassed my expectations, Melinoë."
      Speaker = "Hecate"
      Event = "HecateBossFirstAppearanceAlt"
    }
    {
      Id = "Melinoe_1170"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thank you, Headmistress Hecate. For all your guidance, and the compliment."
      Speaker = "Melinoe"
      Event = "HecateBossFirstAppearanceAlt"
    }
    {
      Id = "HecateField_0271"
      InheritFrom = "BaseNarrative"
      DisplayName = "'Twas not a compliment, merely a point of fact. Though I would see firsthand a demonstration of your capability."
      Speaker = "Hecate"
      Event = "HecateBossFirstAppearanceAlt"
    }
    {
      Id = "HecateField_0341"
      InheritFrom = "BaseNarrative"
      DisplayName = "Are you better prepared this time? Look at yourself, you are {#Emph}too calm. {#Prev}Suppressing your anger for the illusion of control."
      Speaker = "Hecate"
      Event = "HecateBossAboutRage01"
    }
    {
      Id = "MelinoeField_4301"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've taught me patience, Headmistress. But now you ask me to lash out at you in rage. Which shall it be?"
      Speaker = "Melinoe"
      Event = "HecateBossAboutRage01"
    }
    {
      Id = "HecateField_0342"
      InheritFrom = "BaseNarrative"
      DisplayName = "Give me both: rage, which you can {#Emph}control. {#Prev}Leave the serenity to our Sister the Moon, and {#Emph}fight me properly!"
      Speaker = "Hecate"
      Event = "HecateBossAboutRage01"
    }
    {
      Id = "Hecate_0076"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sister Selene aided you in getting here to me. But have you learned to harness her power?"
      Speaker = "Hecate"
      Event = "HecateBossAboutSelene01"
    }
    {
      Id = "Melinoe_0160"
      InheritFrom = "BaseNarrative"
      DisplayName = "On that account, I would prefer to demonstrate than speak. With your permission, of course, Headmistress."
      Speaker = "Melinoe"
      Event = "HecateBossAboutSelene01"
    }
    {
      Id = "Hecate_0077"
      InheritFrom = "BaseNarrative"
      DisplayName = "Permission granted. Now, show me what the Moon can do once in your grasp."
      Speaker = "Hecate"
      Event = "HecateBossAboutSelene01"
    }
    {
      Id = "Hecate_0427"
      InheritFrom = "BaseNarrative"
      DisplayName = "How fares the goddess of the hunt? By now these woods must feel a second home to her."
      Speaker = "Hecate"
      Event = "HecateBossAboutArtemis01"
    }
    {
      Id = "Melinoe_1601"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sister Artemis appears quite well, so much as possible of late. If anything, she seems in better spirits than before."
      Speaker = "Melinoe"
      Event = "HecateBossAboutArtemis01"
    }
    {
      Id = "Hecate_0428"
      InheritFrom = "BaseNarrative"
      DisplayName = "Good. She, Selene, you, and I have all prepared for this contingency, and now 'tis time we shine... particularly you and I, right now."
      Speaker = "Hecate"
      Event = "HecateBossAboutArtemis01"
    }
    {
      Id = "HecateField_0287"
      InheritFrom = "BaseNarrative"
      DisplayName = "Athena deigned to grace these woods of ours, has she? Perhaps a mere projection of her power now that you and she have built up more of a working relationship."
      Speaker = "Hecate"
      Event = "HecateBossAboutAthena01"
    }
    {
      Id = "MelinoeField_3476"
      InheritFrom = "BaseNarrative"
      DisplayName = "Her Gorgon Amulet lets her locate me almost anywhere, though she can never stay for very long. I hate to inconvenience her."
      Speaker = "Melinoe"
      Event = "HecateBossAboutAthena01"
    }
    {
      Id = "HecateField_0288"
      InheritFrom = "BaseNarrative"
      DisplayName = "She would not bother if she deemed you unworthy. Whilst her power may be limited beyond Olympus, I shall not underestimate it here."
      Speaker = "Hecate"
      Event = "HecateBossAboutAthena01"
    }
    {
      Id = "MelinoeField_0010"
      InheritFrom = "BaseNarrative"
      DisplayName = "Does anyone besides me ever happen on you in this glade? Perhaps some evening Artemis or someone may appear instead."
      Speaker = "Melinoe"
      Event = "HecateBossAboutNemesis01"
    }
    {
      Id = "HecateField_0012"
      InheritFrom = "BaseNarrative"
      DisplayName = "This clearing, rest assured, is ours alone; these woods are vast enough. Yet I see everyone who passes through. No matter how clandestine they may think they are..."
      Speaker = "Hecate"
      Event = "HecateBossAboutNemesis01"
    }
    {
      Id = "HecateField_0007"
      InheritFrom = "BaseNarrative"
      DisplayName = "A chill swept through the air as you approached. Unseasonably cold; though perhaps it is as Demeter desires. She aids you, does she not?"
      Speaker = "Hecate"
      Event = "HecateBossAboutDemeter01"
    }
    {
      Id = "MelinoeField_0007"
      InheritFrom = "BaseNarrative"
      DisplayName = "She does. She knew me for her granddaughter at once. Have you had opportunity to speak with her, about me and all that's transpired?"
      Speaker = "Melinoe"
      Event = "HecateBossAboutDemeter01"
    }
    {
      Id = "HecateField_0008"
      InheritFrom = "BaseNarrative"
      DisplayName = "No; I've been a bit preoccupied. At least here, Demeter shall be able to cool her wrath against me for keeping you a secret for so long..."
      Speaker = "Hecate"
      Event = "HecateBossAboutDemeter01"
    }
    {
      Id = "HecateField_0009"
      InheritFrom = "BaseNarrative"
      DisplayName = "I sense that Demeter is with you once again. I suspected she would either be among the first to lend support, or to refuse."
      Speaker = "Hecate"
      Event = "HecateBossAboutDemeter02"
    }
    {
      Id = "MelinoeField_0008"
      InheritFrom = "BaseNarrative"
      DisplayName = "Could you not have told her about me, Headmistress? To have lost her daughter and grandchildren... I cannot imagine her sorrow."
      Speaker = "Melinoe"
      Event = "HecateBossAboutDemeter02"
    }
    {
      Id = "HecateField_0010"
      InheritFrom = "BaseNarrative"
      DisplayName = "'Twas a painful choice to leave her in the dark. She would have gone to war immediately; but our task requires patience, as you know."
      Speaker = "Hecate"
      Event = "HecateBossAboutDemeter02"
    }
    {
      Id = "MelinoeField_0004"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress, I'm concerned Chronos may find us. I first encountered him not far beyond these woods..."
      Speaker = "Melinoe"
      Event = "HecateBossAboutChronos01"
    }
    {
      Id = "HecateField_0003"
      InheritFrom = "BaseNarrative"
      DisplayName = "There are so many passageways to Erebus, 'tis exceedingly unlikely he shall find the way. {#Emph}You {#Prev}face a greater risk than {#Emph}that {#Prev}right now..."
      Speaker = "Hecate"
      Event = "HecateBossAboutChronos01"
    }
    {
      Id = "Hecate_0078"
      InheritFrom = "BaseNarrative"
      DisplayName = "Our enemy's strength even exceeds my own. We're both Titans, yes, Chronos and I, but he is my elder... as I am yours. What say you?"
      Speaker = "Hecate"
      Event = "HecateBossAboutChronos02"
    }
    {
      Id = "Melinoe_0161"
      InheritFrom = "BaseNarrative"
      DisplayName = "His age doesn't mean anything to me. The old are seldom wise, and often weak. And, he did not study under {#Emph}you{#Prev}, Headmistress. Only I have."
      Speaker = "Melinoe"
      Event = "HecateBossAboutChronos02"
    }
    {
      Id = "Hecate_0079"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hah! {#Prev}Just so. He is an arrogant old fool. The impression of wisdom comes with age more than the real thing. Remember that."
      Speaker = "Hecate"
      Event = "HecateBossAboutChronos02"
    }
    {
      Id = "Melinoe_2136"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll get him, Headmistress. I swear it. All that you've taught, I'll bring to bear. And no matter the obstacles that stand in the way, Chronos shall fall by {#Emph}my {#Prev}hand."
      Speaker = "Melinoe"
      Event = "HecateBossAboutChronos03"
    }
    {
      Id = "HecateField_0100"
      InheritFrom = "BaseNarrative"
      DisplayName = "I require no convincing, Melinoë, although perhaps you do. However much I've taught, what's important is you're a capable student."
      Speaker = "Hecate"
      Event = "HecateBossAboutChronos03"
    }
    {
      Id = "Melinoe_2137"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I have to be more than that."
      Speaker = "Melinoe"
      Event = "HecateBossAboutChronos03"
    }
    {
      Id = "HecateField_0293"
      InheritFrom = "BaseNarrative"
      DisplayName = "You bested our enemy, and now are eager to reach him again. As much as I am curious to know more, you must have your reasons for withholding the details."
      Speaker = "Hecate"
      Event = "HecateBossAboutChronosBossW00"
    }
    {
      Id = "MelinoeField_3481"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can hardly believe what happened, much less explain it. But, it went largely the way you expected, Headmistress. I apologize for not informing you."
      Speaker = "Melinoe"
      Event = "HecateBossAboutChronosBossW00"
    }
    {
      Id = "HecateField_0294"
      InheritFrom = "BaseNarrative"
      DisplayName = "Never apologize when you are not at fault. Speak no more of this than necessary, not to me or anyone. And press on."
      Speaker = "Hecate"
      Event = "HecateBossAboutChronosBossW00"
    }
    {
      Id = "MelinoeField_1513"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've vanquished Chronos... everything you've trained me to do. Yet still you stand in my way. Still more to learn even now."
      Speaker = "Melinoe"
      Event = "HecateBossAboutChronosBossW01"
    }
    {
      Id = "HecateField_0126"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now and always. That tinge of frustration you expressed? I would see you rid yourself of it, in your attempts to rid yourself of {#Emph}me."
      Speaker = "Hecate"
      Event = "HecateBossAboutChronosBossW01"
    }
    {
      Id = "HecateField_0127"
      InheritFrom = "BaseNarrative"
      DisplayName = "Our enemy surely is beginning to wonder how you are able to thwart him. Do leave him in the dark. The less he knows of us, the better."
      Speaker = "Hecate"
      Event = "HecateBossAboutChronosBossW02"
    }
    {
      Id = "MelinoeField_1514"
      InheritFrom = "BaseNarrative"
      DisplayName = "Chronos seems to think my family bond with him is why I'm able to resist. He hasn't made the connection that {#Emph}you're {#Prev}the one who's prepared me."
      Speaker = "Melinoe"
      Event = "HecateBossAboutChronosBossW02"
    }
    {
      Id = "HecateField_0128"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}You {#Prev}have prepared {#Emph}yourself. {#Prev}'Tis good that you are drawing his attention and his wrath, whilst I remain unseen. We slowly undermine his strength... and through our efforts, buy your mountain relatives more time."
      Speaker = "Hecate"
      Event = "HecateBossAboutChronosBossW02"
    }
    {
      Id = "HecateField_0418"
      InheritFrom = "BaseNarrative"
      DisplayName = "Trust in your training, ere you reach your destination at the House. That and your connection to Chronos affords you some degree of control over his abilities... an unwitting inheritance he gave to you."
      Speaker = "Hecate"
      Event = "HecateBossAboutEndingPath00"
    }
    {
      Id = "MelinoeField_5185"
      InheritFrom = "BaseNarrative"
      DisplayName = "My knowledge of dream, his command over Time... a potent combination, but one I know I must approach with a great deal of caution and respect."
      Speaker = "Melinoe"
      Event = "HecateBossAboutEndingPath00"
    }
    {
      Id = "HecateField_0419"
      InheritFrom = "BaseNarrative"
      DisplayName = "Approaching matters with caution and respect shall rarely lead you astray. I shall await word of whatever it is you discover... and whether our plans may come to pass."
      Speaker = "Hecate"
      Event = "HecateBossAboutEndingPath00"
    }
    {
      Id = "HecateField_0297"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}To the abyss of the subconscious I descend... {#Prev}remember well those words and those that follow, lest the thrill of battle cloud your memory."
      Speaker = "Hecate"
      Event = "HecateBossAboutEndingPath01"
    }
    {
      Id = "MelinoeField_3483"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}To the abyss of the subconscious I descend. Night and Darkness, guide me to my blood beyond the grasp of Time."
      Speaker = "Melinoe"
      Event = "HecateBossAboutEndingPath01"
    }
    {
      Id = "HecateField_0298"
      InheritFrom = "BaseNarrative"
      DisplayName = "A potent prayer, although here it shall avail you not. Perhaps you soon shall have the opportunity to make the invocations in the proper place and time."
      Speaker = "Hecate"
      Event = "HecateBossAboutEndingPath01"
    }
    {
      Id = "MelinoeField_5098"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've told my brother of what Chronos has done... but he expressed reluctance about having to destroy a member of our family. He even... suggested Father may be partly to blame."
      Speaker = "Melinoe"
      Event = "HecateBossAboutEndingPath02"
    }
    {
      Id = "HecateField_0421"
      InheritFrom = "BaseNarrative"
      DisplayName = "A complication. Your brother never was keen on taking direction, especially from your father. And now he's filling your own head with doubt. We have no recourse here, Melinoë. Persuade him, or all shall be for naught."
      Speaker = "Hecate"
      Event = "HecateBossAboutEndingPath02"
    }
    {
      Id = "MelinoeField_5099"
      InheritFrom = "BaseNarrative"
      DisplayName = "He also asked me what exactly happened between Chronos and my father, and... I realized I didn't know. Does anyone? This war he's waged... it isn't merely over who should rule."
      Speaker = "Melinoe"
      Event = "HecateBossAboutEndingPath02"
    }
    {
      Id = "HecateField_0422"
      InheritFrom = "BaseNarrative"
      DisplayName = "Their precise history is of no bearing to our present state. In war, one would be wise to not give undue credit to one's enemies. If you spend all your time so deep in thought, then you shall hesitate to act... and your moment shall pass!"
      Speaker = "Hecate"
      Event = "HecateBossAboutEndingPath02"
    }
    {
      Id = "HecateField_0424"
      InheritFrom = "BaseNarrative"
      DisplayName = "Tell me, ere we clash again: Has your brother come to understand yet the necessity of his participation in your task?"
      Speaker = "Hecate"
      Event = "HecateBossAboutEndingPath03"
    }
    {
      Id = "MelinoeField_5100"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's been a bit of a struggle. He's found a suitable weapon in our father's spear... but he hasn't granted me its essence yet."
      Speaker = "Melinoe"
      Event = "HecateBossAboutEndingPath03"
    }
    {
      Id = "HecateField_0425"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then tell him what he needs to hear, if that is what it takes to spur him on. I do not like having to count on him any more than you, but... his cooperation is an absolute necessity."
      Speaker = "Hecate"
      Event = "HecateBossAboutEndingPath03"
    }
    {
      Id = "MelinoeField_5101"
      InheritFrom = "BaseNarrative"
      DisplayName = "I need more than his cooperation... I need his trust. I'm not going to deceive him, if that's what you suggest."
      Speaker = "Melinoe"
      Event = "HecateBossAboutEndingPath03"
    }
    {
      Id = "HecateField_0426"
      InheritFrom = "BaseNarrative"
      DisplayName = "I suggest {#Emph}nothing. {#Prev}The task is yours, as are the methods you employ to achieve it. But, {#Emph}achieve it!"
      Speaker = "Hecate"
      Event = "HecateBossAboutEndingPath03"
    }
    {
      Id = "MelinoeField_5102"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I intend to!"
      Speaker = "Melinoe"
      Event = "HecateBossAboutEndingPath03"
    }
    {
      Id = "Melinoe_5731"
      InheritFrom = "BaseNarrative"
      DisplayName = "Zagreus and I finally reached an understanding. He knows what needs to be done... but, I wanted to ask you something, Headmistress. With Chronos, in the past... there's truly no other course but to destroy him?"
      Speaker = "Melinoe"
      Event = "HecateBossAboutEndingPath04"
    }
    {
      Id = "Hecate_0942"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Oh{#Prev}, blood and darkness, he's got to you, hasn't he? Your brother at least, if not Chronos himself. Why are you asking me such things when you have come so close to the completion of your task, Melinoë?"
      Speaker = "Hecate"
      Event = "HecateBossAboutEndingPath04"
    }
    {
      Id = "Melinoe_5732"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, for one... we're on the verge of destroying Time itself. For all you've taught me, I've never fully understood the repercussions this would have."
      Speaker = "Melinoe"
      Event = "HecateBossAboutEndingPath04"
    }
    {
      Id = "Hecate_0943"
      InheritFrom = "BaseNarrative"
      DisplayName = "We cannot know such repercussions ere they come to pass. Our charge, {#Emph}your {#Prev}charge, is to stop Chronos. Whatever it takes. I trust you shall require no additional reminders?"
      Speaker = "Hecate"
      Event = "HecateBossAboutEndingPath04"
    }
    {
      Id = "Melinoe_5733"
      InheritFrom = "BaseSubtitle"
      DisplayName = "...None."
      Speaker = "Melinoe"
      Event = "HecateBossAboutEndingPath04"
    }
    {
      Id = "MelinoeField_3477"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lately I dreamt of Father once again, when Chronos came for him, and you took me to safety. Except this time, I saw more than before..."
      Speaker = "Melinoe"
      Event = "HecateBossAboutFates01"
    }
    {
      Id = "HecateField_0289"
      InheritFrom = "BaseNarrative"
      DisplayName = "Twas no mere dream, of course. What more did you learn whilst you lingered thus?"
      Speaker = "Hecate"
      Event = "HecateBossAboutFates01"
    }
    {
      Id = "MelinoeField_3478"
      InheritFrom = "BaseNarrative"
      DisplayName = "Chronos demanded Father tell him how to locate the Three Fates. Chronos hates them, or feels threatened by them. He was searching for them all this time... and must have found them finally."
      Speaker = "Melinoe"
      Event = "HecateBossAboutFates01"
    }
    {
      Id = "HecateField_0290"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Blast... {#Prev}Hermes suspected that this was the case, but has been unable to prove it beyond doubt. For now, let us proceed as though the Fates themselves oppose us; as though we've nobody to count on save ourselves."
      Speaker = "Hecate"
      Event = "HecateBossAboutFates01"
    }
    {
      Id = "Hecate_0751"
      InheritFrom = "BaseNarrative"
      DisplayName = "Has the thin air upon that mountain made you mad, Melinoë? Confronting Typhon of all creatures face to face! Hermes told me everything. Save what was going through your head."
      Speaker = "Hecate"
      Event = "HecateBossAboutTyphonFight01"
    }
    {
      Id = "Melinoe_4042"
      InheritFrom = "BaseNarrative"
      DisplayName = "I was not about to turn my back on my family, especially not after having come so far. What should I have done, flee at the first sight of that monster? We flee only as a last resort."
      Speaker = "Melinoe"
      Event = "HecateBossAboutTyphonFight01"
    }
    {
      Id = "Hecate_0752_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "That we do. And you had best keep reminding yourself of it ere you confront the Father of All Monsters again. Do not take unnecessary risks, or lose sight of the task."
      Speaker = "Hecate"
      Event = "HecateBossAboutTyphonFight01"
    }
    {
      Id = "Melinoe_4043"
      InheritFrom = "BaseNarrative"
      DisplayName = "He's much, much larger than any other foe I've faced, but that doesn't make him invincible. I suspected he'd have a difficult time contending with a small, quick adversary."
      Speaker = "Melinoe"
      Event = "HecateBossAboutTyphonFight01_B"
    }
    {
      Id = "Hecate_0753_B"
      InheritFrom = "BaseNarrative"
      DisplayName = "I would commend you for the outcome were I not so utterly aghast. The Father of All Monsters may not be quite so easy to surprise ere you confront him again. Do not take unnecessary risks, or lose sight of the task!"
      Speaker = "Hecate"
      Event = "HecateBossAboutTyphonFight01_B"
    }
    {
      Id = "HecateField_0274"
      InheritFrom = "BaseNarrative"
      DisplayName = "Had your fill of Olympus for a while? Surpassing me here must be far less burdensome than having to gouge all of Typhon's eyes."
      Speaker = "Hecate"
      Event = "HecateBossAboutTyphonFight02"
    }
    {
      Id = "MelinoeField_3158"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's positively pleasant by comparison. But I'll get back to dealing with the Father of All Monsters soon enough."
      Speaker = "Melinoe"
      Event = "HecateBossAboutTyphonFight02"
    }
    {
      Id = "HecateField_0275"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then gather what strength you can in the meantime. For now, the Underworld awaits; but I yet hold the key."
      Speaker = "Hecate"
      Event = "HecateBossAboutTyphonFight02"
    }
    {
      Id = "Hecate_0193"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your aura is different. Stronger. You have been studying the Arcana. Meditating at your Altar to prepare for your attempts."
      Speaker = "Hecate"
      Event = "HecateBossAboutArcana01"
    }
    {
      Id = "Melinoe_0581"
      InheritFrom = "BaseNarrative"
      DisplayName = "Each Card reveals to me a different strength. If I steady myself and concentrate, then it's as though I become one with whomever they depict. If only I could focus on them all."
      Speaker = "Melinoe"
      Event = "HecateBossAboutArcana01"
    }
    {
      Id = "Hecate_0194"
      InheritFrom = "BaseNarrative"
      DisplayName = "To focus, by its nature, is to choose. Come, demonstrate to me this newfound understanding of yours..."
      Speaker = "Hecate"
      Event = "HecateBossAboutArcana01"
    }
    {
      Id = "Hecate_0442"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Altar in our training grounds is for your benefit, yet you would face me whilst ignoring the Arcana! An oversight, or bit of cheekiness?"
      Speaker = "Hecate"
      Event = "HecateBossAboutArcana02"
    }
    {
      Id = "MelinoeField_0003"
      InheritFrom = "BaseNarrative"
      DisplayName = "Merely a bit of deception with which to take you off your guard, Headmistress."
      Speaker = "Melinoe"
      Event = "HecateBossAboutArcana02"
    }
    {
      Id = "Hecate_0443"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hah! {#Prev}I think not. I'm fully on my guard, and suggest {#Emph}you {#Prev}be on yours."
      Speaker = "Hecate"
      Event = "HecateBossAboutArcana02"
    }
    {
      Id = "Hecate_0080"
      InheritFrom = "BaseNarrative"
      DisplayName = "Forgive my bluntness but you're in a rather sorry-looking state, Witch. 'Tis unfair for me to fight you whilst I am at my best and you are not."
      Speaker = "Hecate"
      Event = "HecateBossLowHealth01"
    }
    {
      Id = "Melinoe_0157"
      InheritFrom = "BaseNarrative"
      DisplayName = "Life, however, is unfair, is it not, Headmistress? Here lies a lesson to be learned I think."
      Speaker = "Melinoe"
      Event = "HecateBossLowHealth01"
    }
    {
      Id = "Hecate_0081"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just so. Pray you fare as capably in battle as in speech. Now commence!"
      Speaker = "Hecate"
      Event = "HecateBossLowHealth01"
    }
    {
      Id = "Hecate_0082"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've suffered injuries, Melinoë. You know that I can cure them for you, and you know that I shall not. Not here. It brings me no pleasure."
      Speaker = "Hecate"
      Event = "HecateBossLowHealth02"
    }
    {
      Id = "Melinoe_0158"
      InheritFrom = "BaseNarrative"
      DisplayName = "My injuries are teachings, Headmistress. I could have been more careful getting here. Now I face the consequence."
      Speaker = "Melinoe"
      Event = "HecateBossLowHealth02"
    }
    {
      Id = "Hecate_0083"
      InheritFrom = "BaseNarrative"
      DisplayName = "Correct! Stand tall and fight me, then. Use well your last remaining strength."
      Speaker = "Hecate"
      Event = "HecateBossLowHealth02"
    }
    {
      Id = "Hecate_0084"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your wounds give me the upper hand, Melinoë. What hope have you of ever finding our enemy in such a state?"
      Speaker = "Hecate"
      Event = "HecateBossLowHealth03"
    }
    {
      Id = "MelinoeField_0002"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've not much hope for it at all, Headmistress. Although perhaps I'll get through {#Emph}you{#Prev}, at least."
      Speaker = "Melinoe"
      Event = "HecateBossLowHealth03"
    }
    {
      Id = "HecateField_0002"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Perhaps{#Prev}, as you say. We fight for every step, for every scrap that we can get. Get through {#Emph}me {#Prev}if you can!"
      Speaker = "Hecate"
      Event = "HecateBossLowHealth03"
    }
    {
      Id = "Hecate_0440"
      InheritFrom = "BaseNarrative"
      DisplayName = "A flash of silver... Lim and Oros. So, the Sister Blades availed themselves to you. The other Nocturnal Arms shall follow their lead, I expect."
      Speaker = "Hecate"
      Event = "HecateBossAboutDagger01"
    }
    {
      Id = "Melinoe_1801"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nyx entrusted them to you to safeguard the realm as a last resort. But, this cannot possibly be how they were meant to be used..."
      Speaker = "Melinoe"
      Event = "HecateBossAboutDagger01"
    }
    {
      Id = "Hecate_0441"
      InheritFrom = "BaseNarrative"
      DisplayName = "And whyever not? To safeguard the realm, you shall have to clear a wide variety of obstacles standing in your way. {#Emph}I {#Prev}am but one."
      Speaker = "Hecate"
      Event = "HecateBossAboutDagger01"
    }
    {
      Id = "HecateField_0167"
      InheritFrom = "BaseNarrative"
      DisplayName = "I trust the dark of Erebus was not too much to handle with the ever-burning Flames of Ygnium to light your path?"
      Speaker = "Hecate"
      Event = "HecateBossAboutTorch01"
    }
    {
      Id = "Melinoe_1034"
      InheritFrom = "BaseNarrative"
      DisplayName = "No, Headmistress, it was not. Although, I've much to learn in how to wield these Flames."
      Speaker = "Melinoe"
      Event = "HecateBossAboutTorch01"
    }
    {
      Id = "Hecate_0300"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then you have come to the right place. Show me how you make the shadows dance."
      Speaker = "Hecate"
      Event = "HecateBossAboutTorch01"
    }
    {
      Id = "HecateField_0112"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Umbral Flames of Ygnium, at your command! You use them in your own way; not merely copy my technique."
      Speaker = "Hecate"
      Event = "HecateBossAboutTorch02"
    }
    {
      Id = "MelinoeField_0506"
      InheritFrom = "BaseNarrative"
      DisplayName = "You always said once I was ready to brandish the Flames, that I ought wield them with my intuition as my guide."
      Speaker = "Melinoe"
      Event = "HecateBossAboutTorch02"
    }
    {
      Id = "HecateField_0113"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just so. I always favored these old Flames of mine, but... as to whether {#Emph}you {#Prev}and {#Emph}yours {#Prev}truly connect, we'll have to see."
      Speaker = "Hecate"
      Event = "HecateBossAboutTorch02"
    }
    {
      Id = "HecateField_0108"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now that's a sight, you bearing down on me with that gigantic Moonstone Axe! I wasn't certain you'd prefer that one."
      Speaker = "Hecate"
      Event = "HecateBossAboutAxe01"
    }
    {
      Id = "MelinoeField_0504"
      InheritFrom = "BaseNarrative"
      DisplayName = "Zorephet is weightier than the other Arms. But having an axe such as this in woods such as these has been convenient, overall."
      Speaker = "Melinoe"
      Event = "HecateBossAboutAxe01"
    }
    {
      Id = "HecateField_0109"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, much as I hate to {#Emph}inconvenience {#Prev}you, I must. Although, that monstrous thing suggests this oughtn't take too long..."
      Speaker = "Hecate"
      Event = "HecateBossAboutAxe01"
    }
    {
      Id = "HecateField_0110"
      InheritFrom = "BaseNarrative"
      DisplayName = "Using the Argent Skull of Revaal, now, are we? You're becoming a most-capable necromancer, to have earned its trust."
      Speaker = "Hecate"
      Event = "HecateBossAboutLob01"
    }
    {
      Id = "MelinoeField_0505"
      InheritFrom = "BaseNarrative"
      DisplayName = "Was this once a living creature's skull, Headmistress? Only to be infused with silver and enchanted as an instrument of Night..."
      Speaker = "Melinoe"
      Event = "HecateBossAboutLob01"
    }
    {
      Id = "HecateField_0111"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}That {#Prev}is rather a personal question, considering all evidence at hand! Perhaps Revaal herself shall reveal to you the answer in due course."
      Speaker = "Hecate"
      Event = "HecateBossAboutLob01"
    }
    {
      Id = "HecateField_0255"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Black Coat you now possess... surrounding you as though 'twas forged with you in mind. I feared that it was broken and beyond repair, but... it was merely waiting."
      Speaker = "Hecate"
      Event = "HecateBossAboutSuit01"
    }
    {
      Id = "MelinoeField_2857"
      InheritFrom = "BaseNarrative"
      DisplayName = "Waiting for me... I've never wielded anything like it. Xinth doesn't exactly listen to my thoughts, but heeds my every instinct."
      Speaker = "Melinoe"
      Event = "HecateBossAboutSuit01"
    }
    {
      Id = "HecateField_0256"
      InheritFrom = "BaseNarrative"
      DisplayName = "Not your {#Emph}every {#Prev}instinct; the Arms of Night have a singular purpose, which they go about each in their own peculiar respect. You are to execute that purpose without fail."
      Speaker = "Hecate"
      Event = "HecateBossAboutSuit01"
    }
    {
      Id = "HecateField_0104"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your staff takes on an unexpected form. Last I saw it thus was on a distant isle in the seas above. Where the enchantress Circe plied her trade."
      Speaker = "Hecate"
      Event = "HecateBossAboutCirceAspect01"
    }
    {
      Id = "MelinoeField_0502"
      InheritFrom = "BaseNarrative"
      DisplayName = "This is the form Descura took with her. I feel a greater sense of calm and focus now, as though her own experience fused with mine."
      Speaker = "Melinoe"
      Event = "HecateBossAboutCirceAspect01"
    }
    {
      Id = "HecateField_0105"
      InheritFrom = "BaseNarrative"
      DisplayName = "Circe knew Descura's next bearer would need it for a task of some import. Thus she lent some of her strength to complement your own."
      Speaker = "Hecate"
      Event = "HecateBossAboutCirceAspect01"
    }
    {
      Id = "HecateField_0173"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now in whose guise is Ygnium this time? If you are comfortable answering. 'Tis not {#Emph}your {#Prev}Aspect of the Umbral Flames, that much is clear."
      Speaker = "Hecate"
      Event = "HecateBossAboutMorosAspect01"
    }
    {
      Id = "MelinoeField_2129"
      InheritFrom = "BaseNarrative"
      DisplayName = "This Aspect is of Moros, Headmistress. But he has not yet used the Flames. Perhaps in knowing first... we become instrumental in bringing him into our fold."
      Speaker = "Melinoe"
      Event = "HecateBossAboutMorosAspect01"
    }
    {
      Id = "HecateField_0174"
      InheritFrom = "BaseNarrative"
      DisplayName = "'Tis how the Fates do like to operate. As soon as we know what the future holds, we may try to resist... only to stumble into bringing it about."
      Speaker = "Hecate"
      Event = "HecateBossAboutMorosAspect01"
    }
    {
      Id = "HecateField_0291"
      InheritFrom = "BaseNarrative"
      DisplayName = "That form of Ygnium is rather fetching! You could always decorate the Crossroads with those lights should they not prove sufficiently dependable for your task."
      Speaker = "Hecate"
      Event = "HecateBossAboutEosAspect01"
    }
    {
      Id = "MelinoeField_3480"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Aspect of Eos is not as delicate as it appears. Though I'll admit I half-expected that this Aspect of the Flames would be your own."
      Speaker = "Melinoe"
      Event = "HecateBossAboutEosAspect01"
    }
    {
      Id = "HecateField_0292"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nonsense. If I myself wielded those very torches, {#Emph}you {#Prev}would not be bearing them. Now come remind me what the rosy flickering of Dawn can do."
      Speaker = "Hecate"
      Event = "HecateBossAboutEosAspect01"
    }
    {
      Id = "HecateField_0175"
      InheritFrom = "BaseNarrative"
      DisplayName = "'Tis not the typical slim figure of the Moonstone Axe. {#Emph}Ah! {#Prev}The Aspect of Charon! He has since taken up the simple oar."
      Speaker = "Hecate"
      Event = "HecateBossAboutCharonAspect01"
    }
    {
      Id = "MelinoeField_3479"
      InheritFrom = "BaseNarrative"
      DisplayName = "So {#Emph}this {#Prev}is why Lord Charon has such definition in his arms. Do you suppose he used to row his boat with Zorephet?"
      Speaker = "Melinoe"
      Event = "HecateBossAboutCharonAspect01"
    }
    {
      Id = "HecateField_0176"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps he did, or hewed off a few heads. If Nyx and the Three Fates entrusted the protection of the Underworld to a certain few, they could have chosen worse."
      Speaker = "Hecate"
      Event = "HecateBossAboutCharonAspect01"
    }
    {
      Id = "HecateField_0106"
      InheritFrom = "BaseNarrative"
      DisplayName = "What's that you're brandishing? {#Emph}Ahh{#Prev}, the Nocturnal Arms begin to show their myriad colors. The silver you well know is but one."
      Speaker = "Hecate"
      Event = "HecateBossAboutWeaponAspects01"
    }
    {
      Id = "MelinoeField_0503"
      InheritFrom = "BaseNarrative"
      DisplayName = "Each of the Aspects of the Arms of Night represents a bearer from another time. I'm still learning the full extent of what they can do."
      Speaker = "Melinoe"
      Event = "HecateBossAboutWeaponAspects01"
    }
    {
      Id = "HecateField_0107"
      InheritFrom = "BaseNarrative"
      DisplayName = "And I suspect you shall continue doing so. If nothing else, this ought to make things further interesting here for the both of us."
      Speaker = "Hecate"
      Event = "HecateBossAboutWeaponAspects01"
    }
    {
      Id = "HecateField_0285"
      InheritFrom = "BaseNarrative"
      DisplayName = "Each night, I wonder which of your forms I shall confront. Have you considered why so many different Aspects of the Nocturnal Arms are at your disposal?"
      Speaker = "Hecate"
      Event = "HecateBossAboutWeaponAspects02"
    }
    {
      Id = "MelinoeField_3475"
      InheritFrom = "BaseNarrative"
      DisplayName = "The bearers of the Arms safeguard the Underworld, but... I don't think they all could wield Aspects other than their own. Perhaps something about my task requires it."
      Speaker = "Melinoe"
      Event = "HecateBossAboutWeaponAspects02"
    }
    {
      Id = "HecateField_0286"
      InheritFrom = "BaseNarrative"
      DisplayName = "Or perhaps the Arms have come to have affinity for you; not unlike a close companion who entrusts you with a secret that is never to be shared! Do not betray their confidence."
      Speaker = "Hecate"
      Event = "HecateBossAboutWeaponAspects02"
    }
    {
      Id = "HecateField_0339"
      InheritFrom = "BaseNarrative"
      DisplayName = "Each hidden Aspect of the Arms of Night is in your grasp, at least the ones that had been set aside for you. What have you surmised about their bearers?"
      Speaker = "Hecate"
      Event = "HecateBossAboutHiddenAspects01"
    }
    {
      Id = "MelinoeField_4300"
      InheritFrom = "BaseNarrative"
      DisplayName = "That they're all gods or goddesses of death or destruction. Some past, some future, others perhaps contemporaries but of realms other than our own. But, where...?"
      Speaker = "Melinoe"
      Event = "HecateBossAboutHiddenAspects01"
    }
    {
      Id = "HecateField_0340"
      InheritFrom = "BaseNarrative"
      DisplayName = "Our realm is hidden; theirs may be as well. Besides, for as much of the world as you've seen, 'tis but a narrow swath. You have eternity to meet these other gods, or not."
      Speaker = "Hecate"
      Event = "HecateBossAboutHiddenAspects01"
    }
    {
      Id = "HecateField_0156"
      InheritFrom = "BaseNarrative"
      DisplayName = "There's not much glory in confronting adversaries one to one. I myself invoke Shades of the dead to alter the odds. Some may well favor {#Emph}you{#Prev}, instead."
      Speaker = "Hecate"
      Event = "HecateBossAboutFamiliarSystem01"
    }
    {
      Id = "MelinoeField_1998"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps if I brought with me a legion of Animal Familiars next time, Headmistress? Not that any beast would bare its fangs at {#Emph}you."
      Speaker = "Melinoe"
      Event = "HecateBossAboutFamiliarSystem01"
    }
    {
      Id = "HecateField_0157"
      InheritFrom = "BaseNarrative"
      DisplayName = "You jest, yet a Familiar may be of considerable benefit given all that you have to do. A possibility to think upon, once you are rid of me..."
      Speaker = "Hecate"
      Event = "HecateBossAboutFamiliarSystem01"
    }
    {
      Id = "HecateField_0162"
      InheritFrom = "BaseNarrative"
      DisplayName = "You brought some company along! An unassuming choice. Your amphibious friend does not appear to have capacity to sway the outcome here."
      Speaker = "Hecate"
      Event = "HecateBossAboutFrogFamiliar01"
    }
    {
      Id = "MelinoeField_2026"
      InheritFrom = "BaseNarrative"
      DisplayName = "I never trust appearances entirely, Headmistress, and know neither do you. This must be an exciting night for Frinos."
      Speaker = "Melinoe"
      Event = "HecateBossAboutFrogFamiliar01"
    }
    {
      Id = "HecateField_0163"
      InheritFrom = "BaseNarrative"
      DisplayName = "We are not here to entertain your woodland friends, Melinoë. Pray they don't get underfoot."
      Speaker = "Hecate"
      Event = "HecateBossAboutFrogFamiliar01"
    }
    {
      Id = "HecateField_0269"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have a raven friend with you! Birds seldom take to Erebus, if they can even make their way! A spy, I thought at first, but no. Perhaps Selene sent him down to you."
      Speaker = "Hecate"
      Event = "HecateBossAboutRavenFamiliar01"
    }
    {
      Id = "MelinoeField_3155"
      InheritFrom = "BaseNarrative"
      DisplayName = "This is Raki, whom I found in a secluded glade nearby all on his own. I know better than to trust inherently, though felt a strong connection to this one."
      Speaker = "Melinoe"
      Event = "HecateBossAboutRavenFamiliar01"
    }
    {
      Id = "HecateField_0270"
      InheritFrom = "BaseNarrative"
      DisplayName = "I likewise sense no ill intent from him. Our Familiars may take on a variety of forms, no different from our friends or enemies. Let's see how well this one keeps up!"
      Speaker = "Hecate"
      Event = "HecateBossAboutRavenFamiliar01"
    }
    {
      Id = "HecateField_0338"
      InheritFrom = "BaseNarrative"
      DisplayName = "That little cat there by your side, I noticed her within our Crossroads recently. Your power must be great indeed, to have persuaded her to follow you..."
      Speaker = "Hecate"
      Event = "HecateBossAboutCatFamiliar01"
    }
    {
      Id = "MelinoeField_2027"
      InheritFrom = "BaseNarrative"
      DisplayName = "Toula did take some convincing, Headmistress. But she seems to appreciate my company! At least, most of the time."
      Speaker = "Melinoe"
      Event = "HecateBossAboutCatFamiliar01"
    }
    {
      Id = "HecateField_0165"
      InheritFrom = "BaseNarrative"
      DisplayName = "Moody creatures, cats; born huntresses but uncontrollable. I almost fear to see just what this little one can do! With hounds, at least I know exactly where I stand."
      Speaker = "Hecate"
      Event = "HecateBossAboutCatFamiliar01"
    }
    {
      Id = "HecateField_0118"
      InheritFrom = "BaseNarrative"
      DisplayName = "Look at that prim posture! We're in the presence of majestic Hecuba herself...! How fares my favored hound?"
      Speaker = "Hecate"
      Event = "HecateBossAboutHoundFamiliar01"
    }
    {
      Id = "MelinoeField_0509"
      InheritFrom = "BaseNarrative"
      DisplayName = "She's very well, and a most-capable companion to have at my side. Though I hate to have to strain her loyalties like this."
      Speaker = "Melinoe"
      Event = "HecateBossAboutHoundFamiliar01"
    }
    {
      Id = "HecateField_0119"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come, you want to see what she shall do! Her loyalty is absolute. I permitted her to serve you as she serves me! Let's all now bare our fangs."
      Speaker = "Hecate"
      Event = "HecateBossAboutHoundFamiliar01"
    }
    {
      Id = "HecateField_0114"
      InheritFrom = "BaseNarrative"
      DisplayName = "Why, if it isn't little Gale scurrying about your feet! {#Emph}Ah{#Prev}, how the tables have turned. Her vengeance finally is nigh!"
      Speaker = "Hecate"
      Event = "HecateBossAboutPolecatFamiliar01"
    }
    {
      Id = "MelinoeField_0507"
      InheritFrom = "BaseNarrative"
      DisplayName = "You jest, Headmistress, but I put poor Gale in a terrible position here, to have to square against you. Can't she refuse to be a part of this?"
      Speaker = "Melinoe"
      Event = "HecateBossAboutPolecatFamiliar01"
    }
    {
      Id = "HecateField_0115"
      InheritFrom = "BaseNarrative"
      DisplayName = "She is to do your bidding when required, and besides, I do think she is going to enjoy this. I let you go all-out; same goes for {#Emph}her."
      Speaker = "Hecate"
      Event = "HecateBossAboutPolecatFamiliar01"
    }
    {
      Id = "HecateField_0018"
      InheritFrom = "BaseNarrative"
      DisplayName = "You are preoccupied with that Arachne's curse! I know about it, yes. The remedy is no straightforward feat."
      Speaker = "Hecate"
      Event = "HecateBossAboutArachne01"
    }
    {
      Id = "MelinoeField_2877"
      InheritFrom = "BaseNarrative"
      DisplayName = "Nor is my task, yet here we are, night after night. If there's a way to aid my friend, I wish to know of it."
      Speaker = "Melinoe"
      Event = "HecateBossAboutArachne01"
    }
    {
      Id = "HecateField_0019"
      InheritFrom = "BaseNarrative"
      DisplayName = "Athena is the one to persuade; so long as she wishes for the curse to remain, it shall. That, and you must discover who created it."
      Speaker = "Hecate"
      Event = "HecateBossAboutArachne01"
    }
    {
      Id = "MelinoeField_2878"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Sounds straightforward enough!"
      Speaker = "Melinoe"
      Event = "HecateBossAboutArachne01"
    }
    {
      Id = "MelinoeField_2879"
      InheritFrom = "BaseNarrative"
      DisplayName = "I appreciate your candor with Arachne, Headmistress. You must have known full well that she would not forgive you."
      Speaker = "Melinoe"
      Event = "HecateBossAboutArachne02"
    }
    {
      Id = "HecateField_0020"
      InheritFrom = "BaseNarrative"
      DisplayName = "Far easier to beg forgiveness than to dole it out. As you grow longer in years, you, too, shall have relationships that cannot be repaired."
      Speaker = "Hecate"
      Event = "HecateBossAboutArachne02"
    }
    {
      Id = "HecateField_0166"
      InheritFrom = "BaseNarrative"
      DisplayName = "You wear one of those silken dresses, always with a vivid hue. I know whose handiwork they are. This one quite suits you, though it is unlikely to withstand the heat..."
      Speaker = "Hecate"
      Event = "HecateBossAboutArachneOutfit01"
    }
    {
      Id = "MelinoeField_2029"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Just have to avoid it!"
      Speaker = "Melinoe"
      Event = "HecateBossAboutArachneOutfit01"
    }
    {
      Id = "HecateField_0116"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've a particular objective to achieve here, haven't you? Seen what must be done within the facets of the {#Emph}Pitch-Black Stone."
      Speaker = "Hecate"
      Event = "HecateBossAboutPackagedBounties01"
    }
    {
      Id = "MelinoeField_1928"
      InheritFrom = "BaseNarrative"
      DisplayName = "A trial, on top of a trial. This is one of the infinite possibilities that Chaos anticipated. I chose this path, but... it was already there for me to find."
      Speaker = "Melinoe"
      Event = "HecateBossAboutPackagedBounties01"
    }
    {
      Id = "HecateField_0117"
      InheritFrom = "BaseNarrative"
      DisplayName = "'Tis very much disquieting to know the choices that we make might all be preordained to some extent. Nevertheless, Night's will is to be done."
      Speaker = "Hecate"
      Event = "HecateBossAboutPackagedBounties01"
    }
    {
      Id = "Hecate_0624"
      InheritFrom = "BaseNarrative"
      DisplayName = "That Pitch-Black Stone in our training grounds... I've sensed it ever since your incantation. The subtle influence of Chaos on this realm."
      Speaker = "Hecate"
      Event = "HecateBossAboutPackagedBounties01_B"
    }
    {
      Id = "Melinoe_2796"
      InheritFrom = "BaseNarrative"
      DisplayName = "Our goals are intertwined. When I gaze upon the Stone, I begin to see different paths and possibilities in every facet. Some leading closer to our victory."
      Speaker = "Melinoe"
      Event = "HecateBossAboutPackagedBounties01_B"
    }
    {
      Id = "HecateField_0168"
      InheritFrom = "BaseNarrative"
      DisplayName = "I sense the changes in the night; in {#Emph}you. {#Prev}Your strength has waned significantly. Chaos wishes to see the outcome of this particular arrangement, then?"
      Speaker = "Hecate"
      Event = "HecateBossAboutPackagedBounties02"
    }
    {
      Id = "MelinoeField_2030"
      InheritFrom = "BaseNarrative"
      DisplayName = "Another trial, Headmistress. My magick may be weakened, but you taught me never to depend on it entirely."
      Speaker = "Melinoe"
      Event = "HecateBossAboutPackagedBounties02"
    }
    {
      Id = "HecateField_0169"
      InheritFrom = "BaseNarrative"
      DisplayName = "And whether you took such lessons to heart, we shall imminently see. As Selene be our witness above, so shall Chaos below."
      Speaker = "Hecate"
      Event = "HecateBossAboutPackagedBounties02"
    }
    {
      Id = "HecateField_0120"
      InheritFrom = "BaseNarrative"
      DisplayName = "You spoke the Oath of the Unseen, and would enact Night's Testament this eve. I sensed the growing Fear. How much of it is yours?"
      Speaker = "Hecate"
      Event = "HecateBossAboutShrine01"
    }
    {
      Id = "MelinoeField_1510"
      InheritFrom = "BaseNarrative"
      DisplayName = "A healthy fear, no more, no less, Headmistress. I'm honored that you granted me the right to take the Oath. Assuming it was your doing, rather than Commander Schelemeus."
      Speaker = "Melinoe"
      Event = "HecateBossAboutShrine01"
    }
    {
      Id = "HecateField_0121"
      InheritFrom = "BaseNarrative"
      DisplayName = "Best not to speculate too much. 'Twas your own doing most of all. Then, face me on this terror-stricken eve! You have made certain vows, and shall experience the consequence."
      Speaker = "Hecate"
      Event = "HecateBossAboutShrine01"
    }
    {
      Id = "HecateField_0122"
      InheritFrom = "BaseNarrative"
      DisplayName = "Decided to forgo the Oath for now? A wise move, like as not. Or, evidence of some restraint and circumspection on your part, at least."
      Speaker = "Hecate"
      Event = "HecateBossAboutShrine02"
    }
    {
      Id = "MelinoeField_1511"
      InheritFrom = "BaseNarrative"
      DisplayName = "My path is treacherous enough as it is; why make such Vows as would reduce my chances of success?"
      Speaker = "Melinoe"
      Event = "HecateBossAboutShrine02"
    }
    {
      Id = "HecateField_0123"
      InheritFrom = "BaseNarrative"
      DisplayName = "'Tis through adversity that we grow strong! But to your point, you face adversity enough. The Oath is there to guarantee you always shall."
      Speaker = "Hecate"
      Event = "HecateBossAboutShrine02"
    }
    {
      Id = "HecateField_0124"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Fear in the air... 'tis almost palpable tonight. You have made many Vows this eve. Feeling so very bold, or merely curious to see what shall transpire?"
      Speaker = "Hecate"
      Event = "HecateBossAboutShrine03"
    }
    {
      Id = "MelinoeField_1512"
      InheritFrom = "BaseNarrative"
      DisplayName = "A little of each, Headmistress? Perhaps I made a terrible mistake. It's fortunate the Vows contained within the Oath can be undone... unlike most vows."
      Speaker = "Melinoe"
      Event = "HecateBossAboutShrine03"
    }
    {
      Id = "HecateField_0125"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}All {#Prev}vows can be undone. But yes, the Oath is oddly forgiving in this way; its Vows, never strictly binding. Perhaps so that each evening may be interestingly different from the last."
      Speaker = "Hecate"
      Event = "HecateBossAboutShrine03"
    }
    {
      Id = "HecateField_0299"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Testament of Night requires my defeat specifically, is that not so? The Titan Lord can wait; the key to making the Nocturnal Arms more powerful stands right in front of you."
      Speaker = "Hecate"
      Event = "HecateBossAboutShrine04"
    }
    {
      Id = "MelinoeField_3484"
      InheritFrom = "BaseNarrative"
      DisplayName = "You know much more about the Oath of the Unseen than I, Headmistress. So why don't you tell me what it desires."
      Speaker = "Melinoe"
      Event = "HecateBossAboutShrine04"
    }
    {
      Id = "HecateField_0300"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, I just did! Perhaps when you come to be my age, you too shall find a new connection to the Oath. For now, come earn the Nightmare that you seek."
      Speaker = "Hecate"
      Event = "HecateBossAboutShrine04"
    }
    {
      Id = "HecateField_0276"
      InheritFrom = "BaseNarrative"
      DisplayName = "The greatest teacher is out there, and evidently taught you quite a bit. You're able to surpass me here consistently. But has this proved to be enough...?"
      Speaker = "Hecate"
      Event = "HecateBossAboutShrineUpgrade01"
    }
    {
      Id = "MelinoeField_3473"
      InheritFrom = "BaseNarrative"
      DisplayName = "There's always more to be learned, Headmistress; you taught me that yourself. If you believe that I'm prepared, why hesitate?"
      Speaker = "Melinoe"
      Event = "HecateBossAboutShrineUpgrade01"
    }
    {
      Id = "HecateField_0277"
      InheritFrom = "BaseNarrative"
      DisplayName = "Because your path toward mastery is yours alone; when you decide you are prepared for more, remember that the Oath of the Unseen is there for you. As am I."
      Speaker = "Hecate"
      Event = "HecateBossAboutShrineUpgrade01"
    }
    {
      Id = "HecateField_0280"
      InheritFrom = "BaseNarrative"
      DisplayName = "A frightful night... cold, and dark, and {#Emph}everything. {#Prev}You've spoken certain vows, and as the Moon is our witness, I too have spoken mine. Now we may clash in earnest finally."
      Speaker = "Hecate"
      Event = "HecateBossAboutAltFight01"
    }
    {
      Id = "MelinoeField_3394"
      InheritFrom = "BaseNarrative"
      DisplayName = "In earnest... so you {#Emph}have {#Prev}been holding back against me. You said you'd push me to my limits and beyond."
      Speaker = "Melinoe"
      Event = "HecateBossAboutAltFight01"
    }
    {
      Id = "HecateField_0281"
      InheritFrom = "BaseNarrative"
      DisplayName = "Our limits grow along with us. I know mine well enough by now; do you know yours? I am eager to find out for myself!"
      Speaker = "Hecate"
      Event = "HecateBossAboutAltFight01"
    }
    {
      Id = "MelinoeField_3395"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Her Dark Side..."
      Speaker = "Melinoe"
      Event = "HecateBossAboutAltFight01"
    }
    {
      Id = "HecateField_0283"
      InheritFrom = "BaseNarrative"
      DisplayName = "You look upon the Oath of the Unseen night after night, but: Do you understand as yet the lesson it imparts?"
      Speaker = "Hecate"
      Event = "HecateBossAboutAltFight02"
    }
    {
      Id = "MelinoeField_3397"
      InheritFrom = "BaseNarrative"
      DisplayName = "Fear manifests at night. Either we give in to that fear, or we become its cause."
      Speaker = "Melinoe"
      Event = "HecateBossAboutAltFight02"
    }
    {
      Id = "HecateField_0284"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Either give in to fear or become its cause. {#Prev}Your words, not mine, though I concur with them. Let us become that fear for one another once again."
      Speaker = "Hecate"
      Event = "HecateBossAboutAltFight02"
    }
    {
      Id = "HecateField_0320"
      InheritFrom = "BaseNarrative"
      DisplayName = "Whether 'tis wise to speak the Vow of Rivals is for you to decide, but... I can see the wisdom in rescinding {#Emph}that {#Prev}one. I'd not wish to face me at my best, either."
      Speaker = "Hecate"
      Event = "HecateBossAboutAltFight03"
    }
    {
      Id = "MelinoeField_4201"
      InheritFrom = "BaseNarrative"
      DisplayName = "I may not be finished with that Vow just yet, Headmistress. I wonder what else you're holding back, if you possess such power you suppress by will of Night alone."
      Speaker = "Melinoe"
      Event = "HecateBossAboutAltFight03"
    }
    {
      Id = "HecateField_0321"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do wonder, by all means. And should you require more of an advanced test of your aptitude, I shall be waiting."
      Speaker = "Hecate"
      Event = "HecateBossAboutAltFight03"
    }
    {
      Id = "Melinoe_1035"
      InheritFrom = "BaseNarrative"
      DisplayName = "What can we do for the wretched souls wandering lost in Erebus, Headmistress? An afterlife of lashing out in impotent rage..."
      Speaker = "Melinoe"
      Event = "HecateBossAboutErebus01"
    }
    {
      Id = "Hecate_0301"
      InheritFrom = "BaseNarrative"
      DisplayName = "We can achieve our task. The souls of Erebus ought have been placed somewhere within your father's realm, but all that ceased once Chronos took the throne. Go, wrest it back from him."
      Speaker = "Hecate"
      Event = "HecateBossAboutErebus01"
    }
    {
      Id = "Melinoe_1599"
      InheritFrom = "BaseNarrative"
      DisplayName = "This grove is already regrown since last we clashed. For all the death in Erebus, life flourishes as well."
      Speaker = "Melinoe"
      Event = "HecateBossAboutErebus02"
    }
    {
      Id = "Hecate_0432"
      InheritFrom = "BaseNarrative"
      DisplayName = "Death and life; the two are intricately intertwined. These woods shall easily survive our clashes here. What about {#Emph}you?"
      Speaker = "Hecate"
      Event = "HecateBossAboutErebus02"
    }
    {
      Id = "Melinoe_1172"
      InheritFrom = "BaseNarrative"
      DisplayName = "I heard from Hermes, Headmistress. He gave me the impression that Olympus needs my aid. What of my task?"
      Speaker = "Melinoe"
      Event = "HecateBossAboutHermes01"
    }
    {
      Id = "Hecate_0429"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your task remains, as does the adversary whom you face. We shall discuss the matter with Hermes elsewhere. We have other matters first."
      Speaker = "Hecate"
      Event = "HecateBossAboutHermes01"
    }
    {
      Id = "Hecate_0430"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hermes urged me to address a certain matter with you here. However, my view is you are unprepared for the surface, as of yet."
      Speaker = "Hecate"
      Event = "HecateBossAboutHermes02"
    }
    {
      Id = "Melinoe_1175"
      InheritFrom = "BaseNarrative"
      DisplayName = "Meaning you won't lift the wards barring the path to the surface. What if I remove them myself? I've seen how you do it."
      Speaker = "Melinoe"
      Event = "HecateBossAboutHermes02"
    }
    {
      Id = "Hecate_0431"
      InheritFrom = "BaseNarrative"
      DisplayName = "Then you'll be more prepared than you are now. Till then, remember your objective lies below. Past {#Emph}me."
      Speaker = "Hecate"
      Event = "HecateBossAboutHermes02"
    }
    {
      Id = "Melinoe_4840"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Permeation of Witching-Wards..."
      Speaker = "Melinoe"
      Event = "HecateBossAboutHermes02"
    }
    {
      Id = "MelinoeField_0009"
      InheritFrom = "BaseNarrative"
      DisplayName = "Perhaps some evening I shall reach this point so quickly that I'll slip by before you arrive, Headmistress."
      Speaker = "Melinoe"
      Event = "HecateBossAboutHermes03"
    }
    {
      Id = "HecateField_0011"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've no intent to permit any such possibility, not even if you've the swiftness of Hermes speeding you on. Though, why don't we get to it, then."
      Speaker = "Hecate"
      Event = "HecateBossAboutHermes03"
    }
    {
      Id = "Hecate_0302"
      InheritFrom = "BaseNarrative"
      DisplayName = "You cannot beat me with anxiety, you know. Still your senses, and prepare yourself. Know you the purpose of these bouts of ours?"
      Speaker = "Hecate"
      Event = "HecateBossAboutLearning01"
    }
    {
      Id = "Melinoe_1036"
      InheritFrom = "BaseNarrative"
      DisplayName = "To complete my training. Each clash between us is an opportunity to learn and grow strong."
      Speaker = "Melinoe"
      Event = "HecateBossAboutLearning01"
    }
    {
      Id = "Hecate_0303"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're partially correct. For our training shall never be complete. Yet, onward we must strive."
      Speaker = "Hecate"
      Event = "HecateBossAboutLearning01"
    }
    {
      Id = "Hecate_0304"
      InheritFrom = "BaseNarrative"
      DisplayName = "You bear the Wheel trinket I bestowed. I once used it to hone my craft. May it now help you do the same."
      Speaker = "Hecate"
      Event = "HecateBossAboutHecateKeepsake01"
    }
    {
      Id = "Melinoe_1037"
      InheritFrom = "BaseNarrative"
      DisplayName = "This wheel, a labyrinth with no beginning and no end... pathways that circle back upon themselves. Like Erebus..."
      Speaker = "Melinoe"
      Event = "HecateBossAboutHecateKeepsake01"
    }
    {
      Id = "Hecate_0305"
      InheritFrom = "BaseNarrative"
      DisplayName = "Like life itself! Three stages, intertwined. Let us go through the stages now."
      Speaker = "Hecate"
      Event = "HecateBossAboutHecateKeepsake01"
    }
    {
      Id = "HecateField_0158"
      InheritFrom = "BaseNarrative"
      DisplayName = "Again you bear the Wheel I gave to you; rather, that I {#Emph}held {#Prev}for you ere you were ready, for it was always yours. A means of focusing your magickal acuity, if nothing else."
      Speaker = "Hecate"
      Event = "HecateBossAboutHecateKeepsake02"
    }
    {
      Id = "MelinoeField_1997"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's much more. A never-ending labyrinth with three distinct sides... a reminder of our home, and the limits of our power."
      Speaker = "Melinoe"
      Event = "HecateBossAboutHecateKeepsake02"
    }
    {
      Id = "HecateField_0159"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Crossroads may serve as something of a home to you, but most certainly it is {#Emph}not your home. {#Prev}It is that labyrinth in which you are trapped. {#Emph}Break free!"
      Speaker = "Hecate"
      Event = "HecateBossAboutHecateKeepsake02"
    }
    {
      Id = "HecateField_0013"
      InheritFrom = "BaseNarrative"
      DisplayName = "What is that foul artifact you bear? {#Emph}Ah! {#Prev}An Eye of Nemesis. Warding against those harboring ill will. The sheer irony of it, coming from her."
      Speaker = "Hecate"
      Event = "HecateBossAboutNemesisKeepsake01"
    }
    {
      Id = "MelinoeField_0011"
      InheritFrom = "BaseNarrative"
      DisplayName = "I mean nothing untoward, Headmistress. The Eye is indiscriminate in its effect, and makes me match more strongly with my strongest foes."
      Speaker = "Melinoe"
      Event = "HecateBossAboutNemesisKeepsake01"
    }
    {
      Id = "HecateField_0170"
      InheritFrom = "BaseNarrative"
      DisplayName = "'Tis a wonder this Eye does not cause the two of us to combust on the spot! Then take your vengeance, if you can!"
      Speaker = "Hecate"
      Event = "HecateBossAboutNemesisKeepsake01"
    }
    {
      Id = "HecateField_0015"
      InheritFrom = "BaseNarrative"
      DisplayName = "Blood and darkness, I can sense you've those accursed Knuckle Bones on you. I shall have to thank Odysseus for providing such a gift..."
      Speaker = "Hecate"
      Event = "HecateBossAboutOdysseusKeepsake01"
    }
    {
      Id = "MelinoeField_0012"
      InheritFrom = "BaseNarrative"
      DisplayName = "My Keepsake? I'm surprised these have any effect on you, Headmistress. I thought for certain you enchanted them yourself."
      Speaker = "Melinoe"
      Event = "HecateBossAboutOdysseusKeepsake01"
    }
    {
      Id = "HecateField_0016"
      InheritFrom = "BaseNarrative"
      DisplayName = "Odysseus has known his share of witches besides us. Well, I'm braced for impact; the Knuckle Bones strike first, and then, we fight."
      Speaker = "Hecate"
      Event = "HecateBossAboutOdysseusKeepsake01"
    }
    {
      Id = "HecateField_0017"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do I detect an artifact from Moros? Something to bring Doom swiftly to your foes by forestalling your own. Seems rather handy, that."
      Speaker = "Hecate"
      Event = "HecateBossAboutMorosKeepsake01"
    }
    {
      Id = "MelinoeField_0013"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm certain Lord Moros means you no offense. But his Keepsake is of benefit to me, and I'm to take every advantage that I can."
      Speaker = "Melinoe"
      Event = "HecateBossAboutMorosKeepsake01"
    }
    {
      Id = "HecateField_0025"
      InheritFrom = "BaseNarrative"
      DisplayName = "Correct. 'Tis no wonder Doom has come to stay with us for now. His presence lingers over every action that we take..."
      Speaker = "Hecate"
      Event = "HecateBossAboutMorosKeepsake01"
    }
    {
      Id = "HecateField_0102"
      InheritFrom = "BaseNarrative"
      DisplayName = "The air hangs heavily about you here tonight. {#Emph}Ah! {#Prev}'Tis from the scrap of something that Medea gave to you. A gift more than a curse, I trust?"
      Speaker = "Hecate"
      Event = "HecateBossAboutMedeaKeepsake01"
    }
    {
      Id = "MelinoeField_0501"
      InheritFrom = "BaseNarrative"
      DisplayName = "Her Keepsake, yes. A bit of fleece... sheep roam about Ephyra, but none with coats as black and brilliant as this. It's something special, I can tell."
      Speaker = "Melinoe"
      Event = "HecateBossAboutMedeaKeepsake01"
    }
    {
      Id = "HecateField_0103"
      InheritFrom = "BaseNarrative"
      DisplayName = "Indeed it is, as fleeces go, at least. Medea is not quick to accept others into her circle; bit of a black sheep herself. But, aren't we all?"
      Speaker = "Hecate"
      Event = "HecateBossAboutMedeaKeepsake01"
    }
    {
      Id = "HecateField_0171"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Eugh...! {#Prev}Whatever foul Keepsake you decided to bring along for good fortune this eve, 'tis a horrid thing. Which sort of comrade would reward you thus?"
      Speaker = "Hecate"
      Event = "HecateBossAboutErisKeepsake01"
    }
    {
      Id = "MelinoeField_2028"
      InheritFrom = "BaseNarrative"
      DisplayName = "It... was a gift from Eris, Headmistress. I know the effect isn't strictly to my benefit, or anyone's... but I just thought..."
      Speaker = "Melinoe"
      Event = "HecateBossAboutErisKeepsake01"
    }
    {
      Id = "HecateField_0172"
      InheritFrom = "BaseNarrative"
      DisplayName = "...That Eris was doing you a favor? Or has {#Emph}any {#Prev}sense of purpose other than to sow disorder where she can? You two make a strange match, Melinoë. So shall {#Emph}this {#Prev}be."
      Speaker = "Hecate"
      Event = "HecateBossAboutErisKeepsake01"
    }
    {
      Id = "Hecate_0306"
      InheritFrom = "BaseNarrative"
      DisplayName = "Olympus has emboldened you, and made you strong. Yet, 'tis a fleeting strength; one false step, and I could wipe it all away."
      Speaker = "Hecate"
      Event = "HecateBossAboutOlympians01"
    }
    {
      Id = "Melinoe_1038"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'll take a fleeting strength over no strength at all. We take every advantage that avails itself."
      Speaker = "Melinoe"
      Event = "HecateBossAboutOlympians01"
    }
    {
      Id = "Hecate_0307"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just so. Then come and show me how you would make use of such {#Emph}advantages."
      Speaker = "Hecate"
      Event = "HecateBossAboutOlympians01"
    }
    {
      Id = "Hecate_0195"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hmm. {#Prev}I was beginning to think you had grown so fond of the surface that you would not be coming back here anytime soon."
      Speaker = "Hecate"
      Event = "HecateBossAboutSurface01"
    }
    {
      Id = "Melinoe_0654"
      InheritFrom = "BaseNarrative"
      DisplayName = "Our task takes me to the very ends of the Earth. I have unfinished business there as well as here. I'm much more comfortable in these environs, though."
      Speaker = "Melinoe"
      Event = "HecateBossAboutSurface01"
    }
    {
      Id = "Hecate_0196"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Comfortable? {#Prev}You should be fully on your guard, and braced for battle! Let's see how {#Emph}comfortable {#Prev}this is for both of us."
      Speaker = "Hecate"
      Event = "HecateBossAboutSurface01"
    }
    {
      Id = "Hecate_0308"
      InheritFrom = "BaseNarrative"
      DisplayName = "Decided to take a break from all your recent outings to the surface, have you now?"
      Speaker = "Hecate"
      Event = "HecateBossAboutFlattery01"
    }
    {
      Id = "Melinoe_1176"
      InheritFrom = "BaseNarrative"
      DisplayName = "There's much to be done, both above and below. You always say the greatest teacher is {#Emph}out there{#Prev}. But I always seem to find her here."
      Speaker = "Melinoe"
      Event = "HecateBossAboutFlattery01"
    }
    {
      Id = "Hecate_0309"
      InheritFrom = "BaseNarrative"
      DisplayName = "I taught you {#Emph}nothing {#Prev}of such flattery. One of Odysseus' tricks, perhaps...! Let's see what others you have learned."
      Speaker = "Hecate"
      Event = "HecateBossAboutFlattery01"
    }
    {
      Id = "Melinoe_2138"
      InheritFrom = "BaseNarrative"
      DisplayName = "You must wear that veil so as not to betray your disappointment, Headmistress. All these failures yet you still do not admonish me?"
      Speaker = "Melinoe"
      Event = "HecateBossAboutFailure01"
    }
    {
      Id = "HecateField_0101"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh silence, Melinoë. For your setbacks I've boundless patience, but for your petulance, I've none. You ought find a better catalyst for such inner turmoils, as I lack sympathy for them!"
      Speaker = "Hecate"
      Event = "HecateBossAboutFailure01"
    }
    {
      Id = "Melinoe_2139"
      InheritFrom = "BaseSubtitle"
      DisplayName = "That's fine...!"
      Speaker = "Melinoe"
      Event = "HecateBossAboutFailure01"
    }
    {
      Id = "MelinoeField_0005"
      InheritFrom = "BaseNarrative"
      DisplayName = "I didn't mean to keep you waiting long, Headmistress. Or do you always arrive at just the right instant?"
      Speaker = "Melinoe"
      Event = "HecateBossAboutSolitude01"
    }
    {
      Id = "HecateField_0004"
      InheritFrom = "BaseNarrative"
      DisplayName = "A bit of solitude here hardly is a waste of time; I never merely wait. I've more matters to attend to in these woods, besides. But {#Emph}first..."
      Speaker = "Hecate"
      Event = "HecateBossAboutSolitude01"
    }
    {
      Id = "HecateField_0005"
      InheritFrom = "BaseNarrative"
      DisplayName = "'Tis a particularly quiet night. Observe the silence for a moment, ere we begin our little test of just how capable you have become."
      Speaker = "Hecate"
      Event = "HecateBossAboutSilence01"
    }
    {
      Id = "MelinoeField_0006"
      InheritFrom = "BaseNarrative"
      DisplayName = "It does seem unusually still, and the Moon wanes. An ill portent, Headmistress? Our Shades should check up on your hounds..."
      Speaker = "Melinoe"
      Event = "HecateBossAboutSilence01"
    }
    {
      Id = "HecateField_0006"
      InheritFrom = "BaseNarrative"
      DisplayName = "No need, the hounds fend mostly for themselves. Like as not, they use this time to rest; as you'd be wise to do, now and again."
      Speaker = "Hecate"
      Event = "HecateBossAboutSilence01"
    }
    {
      Id = "Hecate_0310"
      InheritFrom = "BaseNarrative"
      DisplayName = "Strength; knowledge; patience. You have exhibited the three repeatedly. Well done."
      Speaker = "Hecate"
      Event = "HecateBossRepeatedWins01"
    }
    {
      Id = "Melinoe_1040"
      InheritFrom = "BaseNarrative"
      DisplayName = "Thank you, Headmistress. Though I continue learning from our every clash."
      Speaker = "Melinoe"
      Event = "HecateBossRepeatedWins01"
    }
    {
      Id = "Hecate_0311"
      InheritFrom = "BaseNarrative"
      DisplayName = "Good, because I've no intent to stand aside. Our craft is called a {#Emph}practice {#Prev}for a reason. Now, on your guard."
      Speaker = "Hecate"
      Event = "HecateBossRepeatedWins01"
    }
    {
      Id = "Hecate_0433"
      InheritFrom = "BaseNarrative"
      DisplayName = "You surpassed me before, yet I wonder: Was it your mastery over our craft, or did the Fates themselves perhaps provide a little {#Emph}nudge?"
      Speaker = "Hecate"
      Event = "HecateBossRepeatedWins02"
    }
    {
      Id = "Melinoe_1600"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come, Headmistress. If I could be provoked {#Emph}that {#Prev}easily, I'd stand no chance at all. Not even if the Fates desired otherwise."
      Speaker = "Melinoe"
      Event = "HecateBossRepeatedWins02"
    }
    {
      Id = "Hecate_0434"
      InheritFrom = "BaseNarrative"
      DisplayName = "Good fortune seldom comes to those in no position to receive it. Show me your victory was no mere accident."
      Speaker = "Hecate"
      Event = "HecateBossRepeatedWins02"
    }
    {
      Id = "Hecate_0435"
      InheritFrom = "BaseNarrative"
      DisplayName = "You almost had me last we clashed, although a narrow loss is nonetheless a loss. I expect you to follow through to victory this time."
      Speaker = "Hecate"
      Event = "HecateBossCloseMatch01"
    }
    {
      Id = "HecateField_0295"
      InheritFrom = "BaseNarrative"
      DisplayName = "When last we fought like this, I posed no real threat to you at all, I know. But your enemies are stubborn; there is nothing you can do to make us stay out of your way."
      Speaker = "Hecate"
      Event = "HecateBossQuickMatch01"
    }
    {
      Id = "MelinoeField_3482"
      InheritFrom = "BaseNarrative"
      DisplayName = "All the more reason I would like to make this quick. Though if I'm in a different mood perhaps I'll make things go profoundly worse with just a few Vows from the Oath."
      Speaker = "Melinoe"
      Event = "HecateBossQuickMatch01"
    }
    {
      Id = "HecateField_0296"
      InheritFrom = "BaseNarrative"
      DisplayName = "Each night has something of its own to offer. Whether you are concentrating on your swiftness or your strength, ensure you're using well this time we have."
      Speaker = "Hecate"
      Event = "HecateBossQuickMatch01"
    }
    {
      Id = "Hecate_0439"
      InheritFrom = "BaseNarrative"
      DisplayName = "I had expected your arrival here the prior eve, but 'twas not for me to cut short that attempt. However, I shan't hesitate to cut short {#Emph}this {#Prev}one."
      Speaker = "Hecate"
      Event = "HecateBossMissedFight01"
    }
    {
      Id = "Hecate_0312"
      InheritFrom = "BaseNarrative"
      DisplayName = "So much ado of late, both on Olympus and below. Yet I would have you cast all your worldly troubles aside whilst here."
      Speaker = "Hecate"
      Event = "HecateBossStrictlyBusiness01"
    }
    {
      Id = "Melinoe_1041"
      InheritFrom = "BaseNarrative"
      DisplayName = "My circumstances are what spur me on. Casting them aside shall be difficult, Headmistress..."
      Speaker = "Melinoe"
      Event = "HecateBossStrictlyBusiness01"
    }
    {
      Id = "Hecate_0313"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've no concern for {#Emph}difficult{#Prev}. We've time enough to gaze upon our navels at the Crossroads. Here, we are adversaries. Nothing more."
      Speaker = "Hecate"
      Event = "HecateBossStrictlyBusiness01"
    }
    {
      Id = "Hecate_0072"
      InheritFrom = "BaseNarrative"
      DisplayName = "There you are. I cannot stay for long. Just long enough to put you to the test."
      Speaker = "Hecate"
      Event = "HecateBossAboutTesting01"
    }
    {
      Id = "Melinoe_0039"
      InheritFrom = "BaseNarrative"
      DisplayName = "I got here as quickly as I could, Headmistress. And still you had to wait."
      Speaker = "Melinoe"
      Event = "HecateBossAboutTesting01"
    }
    {
      Id = "Hecate_0073"
      InheritFrom = "BaseNarrative"
      DisplayName = "To wait is the practice of patience. Now, on to other practices, I think."
      Speaker = "Hecate"
      Event = "HecateBossAboutTesting01"
    }
    {
      Id = "Hecate_0074"
      InheritFrom = "BaseNarrative"
      DisplayName = "Set your respect for me aside whilst here. You must give no such quarter to our enemies."
      Speaker = "Hecate"
      Event = "HecateBossAboutRespect01"
    }
    {
      Id = "Melinoe_0040"
      InheritFrom = "BaseNarrative"
      DisplayName = "But you are not my enemy, Headmistress. How am I to treat you as one?"
      Speaker = "Melinoe"
      Event = "HecateBossAboutRespect01"
    }
    {
      Id = "Hecate_0075"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}How? {#Prev}Allow me to give you a demonstration, then."
      Speaker = "Hecate"
      Event = "HecateBossAboutRespect01"
    }
    {
      Id = "MelinoeField_3156"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress, why is it that we have to keep this up? I've passed your test repeatedly; we're each needed elsewhere."
      Speaker = "Melinoe"
      Event = "HecateBossAboutRepetition01"
    }
    {
      Id = "HecateField_0272"
      InheritFrom = "BaseNarrative"
      DisplayName = "You may be strong but not yet strong enough! And evidently quite impatient, too. Shall you attempt to talk Chronos out of a fight as well?"
      Speaker = "Hecate"
      Event = "HecateBossAboutRepetition01"
    }
    {
      Id = "MelinoeField_3157"
      InheritFrom = "BaseNarrative"
      DisplayName = "Of course not, but... I could be halfway to the Mourning Fields by now, if not for this."
      Speaker = "Melinoe"
      Event = "HecateBossAboutRepetition01"
    }
    {
      Id = "HecateField_0273"
      InheritFrom = "BaseNarrative"
      DisplayName = "Alas that things don't always go our way. Go on now, vent the anger that you feel! We each have much of it to spare."
      Speaker = "Hecate"
      Event = "HecateBossAboutRepetition01"
    }
    {
      Id = "HecateField_0330"
      InheritFrom = "BaseNarrative"
      DisplayName = "Everything as it once was, yet nothing is the same! A feeling I know only too well. It seems we are to prolong your training for a while..."
      Speaker = "Hecate"
      Event = "HecateBossPostTrueEnding01"
    }
    {
      Id = "MelinoeField_4121"
      InheritFrom = "BaseNarrative"
      DisplayName = "My training shall never be complete, isn't that right? Although it's odd to think that following my prior steps to Tartarus shall help maintain the proper course of Time..."
      Speaker = "Melinoe"
      Event = "HecateBossPostTrueEnding01"
    }
    {
      Id = "HecateField_0331"
      InheritFrom = "BaseNarrative"
      DisplayName = "Whether we truly possess the capability to maintain Time remains to be seen! But we can at least maintain ourselves."
      Speaker = "Hecate"
      Event = "HecateBossPostTrueEnding01"
    }
    {
      Id = "HecateField_0332"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your grandfather Chronos like as not awaits beyond this very threshold, where once he stalked that clearing as our bitter enemy. How has collaborating with him been?"
      Speaker = "Hecate"
      Event = "HecateBossPostTrueEnding02"
    }
    {
      Id = "MelinoeField_4202"
      InheritFrom = "BaseNarrative"
      DisplayName = "Unusual, I'd say... he's proven instrumental in eliminating the remnants of his past self. It must be very strange to face oneself in such a way."
      Speaker = "Melinoe"
      Event = "HecateBossPostTrueEnding02"
    }
    {
      Id = "HecateField_0333"
      InheritFrom = "BaseNarrative"
      DisplayName = "How very strange indeed. But if it works, I shall not question it too much. Perhaps we'll all learn more of the mysteries of Time ere this is ended."
      Speaker = "Hecate"
      Event = "HecateBossPostTrueEnding02"
    }
    {
      Id = "HecateField_0334"
      InheritFrom = "BaseNarrative"
      DisplayName = "Tell me something now, Melinoë. Who is the fiercest enemy that you have overcome in all of this? Chronos? Typhon?"
      Speaker = "Hecate"
      Event = "HecateBossPostEpilogue01"
    }
    {
      Id = "MelinoeField_4203"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know what you insinuate, Headmistress... Hecate. I got in my {#Emph}own {#Prev}way more than any of my foes. Save for you, perhaps, but that's more or less the same thing."
      Speaker = "Melinoe"
      Event = "HecateBossPostEpilogue01"
    }
    {
      Id = "HecateField_0335"
      InheritFrom = "BaseNarrative"
      DisplayName = "The limits we impose upon ourselves inhibit what we can achieve. Overcoming those limits is extraordinarily difficult. But, you have done it now... again, and again."
      Speaker = "Hecate"
      Event = "HecateBossPostEpilogue01"
    }
    {
      Id = "MelinoeField_4387"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've had those flames for quite a while, haven't you, Hecate? Are they... from your place of origin?"
      Speaker = "Melinoe"
      Event = "HecateBossPostEpilogue02"
    }
    {
      Id = "HecateField_0336"
      InheritFrom = "BaseNarrative"
      DisplayName = "They lighted my way in my youth, and even still. Care for your possessions, and they may last you a good while..."
      Speaker = "Hecate"
      Event = "HecateBossPostEpilogue02"
    }
    {
      Id = "MelinoeField_4388"
      InheritFrom = "BaseNarrative"
      DisplayName = "I always wondered why none of the Aspects of the Nocturnal Arms I'd discovered were yours..."
      Speaker = "Melinoe"
      Event = "HecateBossPostEpilogue02"
    }
    {
      Id = "HecateField_0337"
      InheritFrom = "BaseNarrative"
      DisplayName = "Try not to dwell on it too much, lest it scatter your mind to no end. But yes, these flames and I do not truly belong. And for that very reason, I suspect the Fates figured me out."
      Speaker = "Hecate"
      Event = "HecateBossPostEpilogue02"
    }
    {
      Id = "HecateField_0343"
      InheritFrom = "BaseNarrative"
      DisplayName = "Shall we continue with these clashes for eternity? 'Twould seem there are sufficient possibilities of Chronos to keep you occupied that long."
      Speaker = "Hecate"
      Event = "HecateBossAboutSayingLittle01"
    }
    {
      Id = "MelinoeField_4302"
      InheritFrom = "BaseNarrative"
      DisplayName = "I'm in no hurry, Hecate. Besides, if I once dreaded having to confront you here, I came to enjoy it at some point."
      Speaker = "Melinoe"
      Event = "HecateBossAboutSayingLittle01"
    }
    {
      Id = "HecateField_0344"
      InheritFrom = "BaseNarrative"
      DisplayName = "I would prefer more frequent victories but I came to enjoy it in kind. Let us continue, then... for however long it takes."
      Speaker = "Hecate"
      Event = "HecateBossAboutSayingLittle01"
    }
    {
      Id = "Hecate_0444"
      InheritFrom = "BaseNarrative"
      DisplayName = "We are alone; nary the baying of a single hound is to be heard. Selene high above shall have to be sufficient for an audience."
      Speaker = "Hecate"
      Event = "HecateBossAboutSolitude02"
    }
    {
      Id = "Hecate_0447"
      InheritFrom = "BaseNarrative"
      DisplayName = "Much is expected of you. So you must learn to bear that burden with grace."
      Speaker = "Hecate"
      Event = "HecateBossAboutExpectations01"
    }
    {
      Id = "Hecate_0048"
      InheritFrom = "BaseNarrative"
      DisplayName = "I know your task is difficult, and also know you have it in you to succeed."
      Speaker = "Hecate"
      Event = "HecateBossAboutTask01"
    }
    {
      Id = "Hecate_0450"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your task may be an honor, but the wisest whom you know shall not envy you for it."
      Speaker = "Hecate"
      Event = "HecateBossAboutTask02"
    }
    {
      Id = "HecateField_0096"
      InheritFrom = "BaseNarrative"
      DisplayName = "Our craft leaves little room for doubt, yet some always remains; and even a little can be far too much."
      Speaker = "Hecate"
      Event = "HecateBossAboutWitchcraft01"
    }
    {
      Id = "HecateField_0098"
      InheritFrom = "BaseNarrative"
      DisplayName = "If you lack confidence, then how are you to manifest your will? Be certain of your heart's desire."
      Speaker = "Hecate"
      Event = "HecateBossAboutConfidence01"
    }
    {
      Id = "HecateField_0099"
      InheritFrom = "BaseNarrative"
      DisplayName = "You're angry; let it out. Anger's not to be suppressed, nor misdirected. To be {#Emph}angry{#Prev}... is to be {#Emph}alive."
      Speaker = "Hecate"
      Event = "HecateBossAboutAnger01"
    }
    {
      Id = "Chronos_0973"
      InheritFrom = "BaseNarrative"
      DisplayName = "It seems the pathways into Erebus are not as well-protected as they used to be. I take it this here is the individual who pitted you against me, is this not?"
      Speaker = "Chronos"
      Event = "HecateBossKidnapped01"
    }
    {
      Id = "MelinoeField_3873"
      InheritFrom = "BaseNarrative"
      DisplayName = "Headmistress! Headmistress, fight him, {#Emph}fight! {#Prev}Fight back!!"
      Speaker = "Melinoe"
      Event = "HecateBossKidnapped01"
    }
    {
      Id = "/EmptyCue"
      InheritFrom = "BaseNarrative"
      DisplayName = ". . . ."
      Speaker = "Empty"
      Event = "HecateBossKidnapped01"
    }
    {
      Id = "Chronos_0974"
      InheritFrom = "BaseNarrative"
      DisplayName = "This {#Emph}headmistress {#Prev}of yours has considerable knowledge, to have thus concealed you... but she is weary, such that {#Emph}Time {#Prev}caught up with her at last. She hears not a word you say."
      Speaker = "Chronos"
      Event = "HecateBossKidnapped01"
    }
    {
      Id = "MelinoeField_3874"
      InheritFrom = "BaseNarrative"
      DisplayName = "Unhand her, wretch. Unhand her, or I'll tear you to pieces."
      Speaker = "Melinoe"
      Event = "HecateBossKidnapped01"
    }
    {
      Id = "Chronos_0975"
      InheritFrom = "BaseNarrative"
      DisplayName = "My own children tore me to pieces once before. Look where {#Emph}that {#Prev}got them! Whoever this is, perhaps she shall be more cooperative than you, although I am not particularly optimistic; nor should you be. Good evening!"
      Speaker = "Chronos"
      Event = "HecateBossKidnapped01"
    }
    {
      Id = "MelinoeField_3875"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Come back! {#Emph}Augh!!"
      Speaker = "Melinoe"
      Event = "HecateBossKidnapped01"
    }
    {
      Id = "Hecate_0086"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come show to me what you have lately learned."
      Speaker = "Hecate"
      Event = "HecateBossMiscStart01"
    }
    {
      Id = "Hecate_0087"
      InheritFrom = "BaseNarrative"
      DisplayName = "Let us begin the lesson, then, Melinoë."
      Speaker = "Hecate"
      Event = "HecateBossMiscStart02"
    }
    {
      Id = "Hecate_0088"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Moon shall be our witness here tonight. Prepare!"
      Speaker = "Hecate"
      Event = "HecateBossMiscStart03"
    }
    {
      Id = "Hecate_0089"
      InheritFrom = "BaseNarrative"
      DisplayName = "Are all your sorceries prepared? Then let us clash."
      Speaker = "Hecate"
      Event = "HecateBossMiscStart04"
    }
    {
      Id = "Hecate_0090"
      InheritFrom = "BaseNarrative"
      DisplayName = "Strike at me so that the heavens themselves shudder!"
      Speaker = "Hecate"
      Event = "HecateBossMiscStart05"
    }
    {
      Id = "Hecate_0091"
      InheritFrom = "BaseNarrative"
      DisplayName = "Steady your breathing, and steel your nerves, Melinoë."
      Speaker = "Hecate"
      Event = "HecateBossMiscStart06"
    }
    {
      Id = "Hecate_0092"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hold nothing back against me here, Melinoë."
      Speaker = "Hecate"
      Event = "HecateBossMiscStart07"
    }
    {
      Id = "Hecate_0093"
      InheritFrom = "BaseNarrative"
      DisplayName = "Each time you face me you step closer to your true potential, Witch."
      Speaker = "Hecate"
      Event = "HecateBossMiscStart08"
    }
    {
      Id = "Hecate_0094"
      InheritFrom = "BaseNarrative"
      DisplayName = "Now let us match our powers, one Witch to another."
      Speaker = "Hecate"
      Event = "HecateBossMiscStart09"
    }
    {
      Id = "Hecate_0166"
      InheritFrom = "BaseNarrative"
      DisplayName = "Shall we discern if you can vanquish me again, Witch?"
      Speaker = "Hecate"
      Event = "HecateBossMiscStart10"
    }
    {
      Id = "Hecate_0167"
      InheritFrom = "BaseNarrative"
      DisplayName = "You may surpass me, but how much strength shall doing so cost you?"
      Speaker = "Hecate"
      Event = "HecateBossMiscStart11"
    }
    {
      Id = "Hecate_0168"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come forth, and I expect a better outcome than when last we clashed."
      Speaker = "Hecate"
      Event = "HecateBossMiscStart12"
    }
    {
      Id = "Hecate_0169"
      InheritFrom = "BaseNarrative"
      DisplayName = "Are you prepared for another hard lesson, or are you going to get past me?"
      Speaker = "Hecate"
      Event = "HecateBossMiscStart13"
    }
    {
      Id = "Hecate_0170"
      InheritFrom = "BaseNarrative"
      DisplayName = "You got here quickly, though with haste comes more capacity to make mistakes."
      Speaker = "Hecate"
      Event = "HecateBossMiscStart14"
    }
    {
      Id = "Hecate_0171"
      InheritFrom = "BaseNarrative"
      DisplayName = "No getting out of Erebus except through me."
      Speaker = "Hecate"
      Event = "HecateBossMiscStart15"
    }
    {
      Id = "Hecate_0172"
      InheritFrom = "BaseNarrative"
      DisplayName = "It seems to me that you are well prepared, so let's begin."
      Speaker = "Hecate"
      Event = "HecateBossMiscStart16"
    }
    {
      Id = "Hecate_0453"
      InheritFrom = "BaseNarrative"
      DisplayName = "Let us see if you shall keep your streak of victories intact."
      Speaker = "Hecate"
      Event = "HecateBossMiscStart17"
    }
    {
      Id = "Hecate_0454"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do me the dignity of never letting down your guard."
      Speaker = "Hecate"
      Event = "HecateBossMiscStart18"
    }
    {
      Id = "Hecate_0455"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have learned much since first we fought, though there is always more."
      Speaker = "Hecate"
      Event = "HecateBossMiscStart19"
    }
    {
      Id = "Hecate_0456"
      InheritFrom = "BaseNarrative"
      DisplayName = "The pleasantries can wait until we reunite at the Crossroads anon."
      Speaker = "Hecate"
      Event = "HecateBossMiscStart20"
    }
    {
      Id = "HecateField_0021"
      InheritFrom = "BaseNarrative"
      DisplayName = "I've a sense this shan't take very long at all."
      Speaker = "Hecate"
      Event = "HecateBossMiscStart21"
    }
    {
      Id = "HecateField_0022"
      InheritFrom = "BaseNarrative"
      DisplayName = "What say we give Sister Selene a good show up there."
      Speaker = "Hecate"
      Event = "HecateBossMiscStart22"
    }
    {
      Id = "HecateField_0024"
      InheritFrom = "BaseNarrative"
      DisplayName = "'Tis a new moon, and an opportunity for a new beginning. But first...!"
      Speaker = "Hecate"
      Event = "HecateBossMiscStart23"
    }
    {
      Id = "Hecate_0173"
      InheritFrom = "BaseNarrative"
      DisplayName = "You are not merely being tested here; you are never to cease learning."
      Speaker = "Hecate"
      Event = "HecateBossMiscStart24"
    }
    {
      Id = "HecateField_0023"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Moon is full and clear this eve. Brings a certain drama to our confrontation, does it not?"
      Speaker = "Hecate"
      Event = "HecateBossMiscStart25"
    }
    {
      Id = "Hecate_0746"
      InheritFrom = "BaseNarrative"
      DisplayName = "We witches oft are underestimated. But, I am well aware how capable you are."
      Speaker = "Hecate"
      Event = "HecateBossMiscStart26"
    }
    {
      Id = "HecateField_0345"
      InheritFrom = "BaseNarrative"
      DisplayName = "I can recall some of your many tricks whilst brandishing Descura there, though why don't you remind me?"
      Speaker = "Hecate"
      Event = "HecateBossMiscStart27"
    }
    {
      Id = "HecateField_0346"
      InheritFrom = "BaseNarrative"
      DisplayName = "It's not my custom to let others rush at me with knives. But for you and Lim and Oros, {#Emph}anything."
      Speaker = "Hecate"
      Event = "HecateBossMiscStart28"
    }
    {
      Id = "HecateField_0347"
      InheritFrom = "BaseNarrative"
      DisplayName = "So it's to be these old torches of mine against your own once more? I am quite partial to this clash."
      Speaker = "Hecate"
      Event = "HecateBossMiscStart29"
    }
    {
      Id = "HecateField_0348"
      InheritFrom = "BaseNarrative"
      DisplayName = "These woods shall look more like a meadow soon as you keep swinging that old Moonstone Axe about..."
      Speaker = "Hecate"
      Event = "HecateBossMiscStart30"
    }
    {
      Id = "HecateField_0349"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Argent Skull, the very face of death... I daresay it shows the hint of a smile in our midst."
      Speaker = "Hecate"
      Event = "HecateBossMiscStart31"
    }
    {
      Id = "HecateField_0350"
      InheritFrom = "BaseNarrative"
      DisplayName = "Xinth the Black Coat once again tonight? Then I shall brace myself for impact, and suggest {#Emph}you {#Prev}do the same."
      Speaker = "Hecate"
      Event = "HecateBossMiscStart32"
    }
    {
      Id = "HecateField_0351"
      InheritFrom = "BaseNarrative"
      DisplayName = "We each have a Dark Side waiting to reveal itself. Now's as good a time as any to show {#Emph}mine."
      Speaker = "Hecate"
      Event = "HecateBossMiscStart33"
    }
    {
      Id = "HecateField_0352"
      InheritFrom = "BaseNarrative"
      DisplayName = "Let us ensure that such a terrifying night is not to be forgotten by our witnesses."
      Speaker = "Hecate"
      Event = "HecateBossMiscStart34"
    }
    {
      Id = "Hecate_0012"
      InheritFrom = "BaseNarrative"
      DisplayName = "You fought with diligence and with ferocity. But surely there is more for you to learn beyond this threshold."
      Speaker = "Hecate"
      Event = "HecateBossOutro01"
    }
    {
      Id = "Melinoe_0041"
      InheritFrom = "BaseNarrative"
      DisplayName = "I look forward to it, Headmistress. What about you? Can you not join me?"
      Speaker = "Melinoe"
      Event = "HecateBossOutro01"
    }
    {
      Id = "Hecate_0445"
      InheritFrom = "BaseNarrative"
      DisplayName = "No; I dare not stray too far from our abode. Continue now your task. I shall await your safe return."
      Speaker = "Hecate"
      Event = "HecateBossOutro01"
    }
    {
      Id = "Melinoe_0176"
      InheritFrom = "BaseSubtitle"
      DisplayName = "Thank you, Headmistress..."
      Speaker = "Melinoe"
      Event = "HecateBossOutro01"
    }
    {
      Id = "HecateField_0161"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Arcana gave to you no benefit at all this eve and still you bested me. I know not whether to heap praise, or reprimand you for being such a little show-off! {#Emph}Hah!"
      Speaker = "Hecate"
      Event = "HecateBossOutroNoArcana01"
    }
    {
      Id = "MelinoeField_2031"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I've gotten stronger..."
      Speaker = "Melinoe"
      Event = "HecateBossOutroNoArcana01"
    }
    {
      Id = "HecateField_0282"
      InheritFrom = "BaseNarrative"
      DisplayName = "...You've grown. There was a time you never could have stopped me had I used Dark Side against you thus. {#Emph}Hm."
      Speaker = "Hecate"
      Event = "HecateBossOutroAltFight01"
    }
    {
      Id = "MelinoeField_3396"
      InheritFrom = "BaseSubtitle"
      DisplayName = "She still held something back..."
      Speaker = "Melinoe"
      Event = "HecateBossOutroAltFight01"
    }
    {
      Id = "Hecate_0143"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have survived against me, and for {#Emph}that{#Prev}, you're owed a gift. May you learn well through it, Melinoë."
      Speaker = "Hecate"
      Event = "HecateBossGrantsCodex01"
    }
    {
      Id = "Melinoe_0177"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The Book of Shadows..."
      Speaker = "Melinoe"
      Event = "HecateBossGrantsCodex01"
    }
    {
      Id = "HecateField_0160"
      InheritFrom = "BaseNarrative"
      DisplayName = "Do bring an Animal Familiar along next time, if but to keep things livelier for me! We have the means to keep them safe, even in scuffles such as these."
      Speaker = "Hecate"
      Event = "HecateBossGrantsFamiliarSystem01"
    }
    {
      Id = "MelinoeField_1999"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}Faith of Familiar Spirits{#Prev}... this should work on Frinos, or perhaps..."
      Speaker = "Melinoe"
      Event = "HecateBossGrantsFamiliarSystem01"
    }
    {
      Id = "HecateField_0178"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have grown physically quite strong... but spiritually, more is to be done. The Altar of Ashes; there is an incantation that may make your nightly meditations at it better spent."
      Speaker = "Hecate"
      Event = "HecateBossGrantsCardUpgradeSystem01"
    }
    {
      Id = "Melinoe_3449"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}The Consecration of Ashes..."
      Speaker = "Melinoe"
      Event = "HecateBossGrantsCardUpgradeSystem01"
    }
    {
      Id = "HecateField_0177"
      InheritFrom = "BaseNarrative"
      DisplayName = "To bear each of the Nocturnal Arms is a terrible responsibility. You've only begun to realize their nature; a certain incantation shall deepen your understanding."
      Speaker = "Hecate"
      Event = "HecateBossGrantsWeaponUpgradeSystem01"
    }
    {
      Id = "Melinoe_3448"
      InheritFrom = "BaseSubtitle"
      DisplayName = "{#Emph}The Aspects of Night and Darkness..."
      Speaker = "Melinoe"
      Event = "HecateBossGrantsWeaponUpgradeSystem01"
    }
    {
      Id = "HecateField_0278"
      InheritFrom = "BaseNarrative"
      DisplayName = "One further secret of the Oath of the Unseen I shall reveal now. When you feel suitably prepared, consider this. Then perhaps we shall clash under a new set of circumstances..."
      Speaker = "Hecate"
      Event = "HecateBossGrantsShrineUpgrade01"
    }
    {
      Id = "MelinoeField_3474"
      InheritFrom = "BaseSubtitle"
      DisplayName = "The secret to the Vow of Rivals..."
      Speaker = "Melinoe"
      Event = "HecateBossGrantsShrineUpgrade01"
    }
    {
      Id = "Hecate_0140"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well fought again, Melinoë. Proceed, and moonlight guide you."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro01"
    }
    {
      Id = "Hecate_0141"
      InheritFrom = "BaseNarrative"
      DisplayName = "May all your enemies beyond succumb to you as readily."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro02"
    }
    {
      Id = "Hecate_0142"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well fought. But I cannot mend your wounds, and neither shall your enemies."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro03"
    }
    {
      Id = "Hecate_0314"
      InheritFrom = "BaseNarrative"
      DisplayName = "You'll continue to grow, whilst I continue thusly testing you."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro04"
    }
    {
      Id = "Hecate_0315"
      InheritFrom = "BaseNarrative"
      DisplayName = "Impressive show of force. Hold nothing back as you continue on."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro05"
    }
    {
      Id = "Hecate_0316"
      InheritFrom = "BaseNarrative"
      DisplayName = "You passed this test again, though how much farther you can go, we'll see."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro06"
    }
    {
      Id = "Hecate_0317"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've earned these spoils; may they strengthen your craft."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro07"
    }
    {
      Id = "Hecate_0318"
      InheritFrom = "BaseNarrative"
      DisplayName = "I shall see you at the Crossroads anon. I shall be catching there my breath..."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro08"
    }
    {
      Id = "Hecate_0319"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Whew! {#Prev}No further need to keep each other here, I suppose..."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro09"
    }
    {
      Id = "Hecate_0320"
      InheritFrom = "BaseNarrative"
      DisplayName = "Go on, Melinoë. The greatest teacher is out {#Emph}there."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro10"
    }
    {
      Id = "HecateField_0086"
      InheritFrom = "BaseNarrative"
      DisplayName = "Just when I thought I had you, you seized control of the fight! Well fought!"
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro11"
    }
    {
      Id = "HecateField_0087"
      InheritFrom = "BaseNarrative"
      DisplayName = "You used your last remaining moments very well. May you fare well below."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro12"
    }
    {
      Id = "HecateField_0088"
      InheritFrom = "BaseNarrative"
      DisplayName = "You wield Descura capably, and I can tell the bond you share is strong. Now farewell."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro13"
    }
    {
      Id = "HecateField_0089"
      InheritFrom = "BaseNarrative"
      DisplayName = "Your growing skill with Lim and Oros makes you something to be feared. Good."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro14"
    }
    {
      Id = "HecateField_0090"
      InheritFrom = "BaseNarrative"
      DisplayName = "I shall return to shadows hence. Trust that your eve is only beginning."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro15"
    }
    {
      Id = "HecateField_0091"
      InheritFrom = "BaseNarrative"
      DisplayName = "We shall have to do this again some other eve."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro16"
    }
    {
      Id = "HecateField_0092"
      InheritFrom = "BaseNarrative"
      DisplayName = "You have grown strong, although we've an eternity to hone our craft."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro17"
    }
    {
      Id = "HecateField_0093"
      InheritFrom = "BaseNarrative"
      DisplayName = "May you show even greater wrath against the enemies awaiting you below."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro18"
    }
    {
      Id = "HecateField_0094"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well fought, and may the Fates be generous to you in your descent."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro19"
    }
    {
      Id = "HecateField_0095"
      InheritFrom = "BaseNarrative"
      DisplayName = "I have impeded you for long enough this night. Go, make the most of this attempt."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro20"
    }
    {
      Id = "HecateField_0353"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Flames of Ygnium burn bright for you... but mastery is an everlasting pursuit."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro21"
    }
    {
      Id = "HecateField_0354"
      InheritFrom = "BaseNarrative"
      DisplayName = "You handle Zorephet as though its bulk is not an inconvenience but a strength..."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro22"
    }
    {
      Id = "HecateField_0355"
      InheritFrom = "BaseNarrative"
      DisplayName = "The Skull of Revaal is not a simple artifact to wield... but I can see you two have come to grips."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro23"
    }
    {
      Id = "HecateField_0356"
      InheritFrom = "BaseNarrative"
      DisplayName = "At least let me get in a strike or two next time for sake of pride, Melinoë?"
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro24"
    }
    {
      Id = "HecateField_0357"
      InheritFrom = "BaseNarrative"
      DisplayName = "As elusive as a Shade. I don't believe I struck you even once."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro25"
    }
    {
      Id = "HecateField_0358"
      InheritFrom = "BaseNarrative"
      DisplayName = "Impressive work to have evaded every strike; my own and that of my Sisters as well."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro26"
    }
    {
      Id = "HecateField_0359"
      InheritFrom = "BaseNarrative"
      DisplayName = "You arrived with not so much as a single cut or scrape, and thus depart. Such strength and agility as can stop Time."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro27"
    }
    {
      Id = "HecateField_0361"
      InheritFrom = "BaseNarrative"
      DisplayName = "You scarce afforded me a single opening. Show no such mercy to our enemies either."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro28"
    }
    {
      Id = "HecateField_0362"
      InheritFrom = "BaseNarrative"
      DisplayName = "Swiftly and thoroughly dispatched as though I was no threat to you at all."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro29"
    }
    {
      Id = "HecateField_0363"
      InheritFrom = "BaseNarrative"
      DisplayName = "I see you are not in any mood to be slowed down! Hold fast to that ferocity."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro30"
    }
    {
      Id = "HecateField_0364"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, go on! 'Tis clear that you are in a hurry, for how quickly you were able to overcome what threat I posed!"
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro31"
    }
    {
      Id = "HecateField_0365"
      InheritFrom = "BaseNarrative"
      DisplayName = "Lord Hermes would be most impressed with how swiftly and thoroughly you settled the score here."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro32"
    }
    {
      Id = "HecateField_0366"
      InheritFrom = "BaseNarrative"
      DisplayName = "Know only that I would not willingly confront the fury of Xinth for merely anyone, Melinoë..."
      Speaker = "Hecate"
      Event = "HecateBossMiscOutro33"
    }
    {
      Id = "Chronos_0972"
      InheritFrom = "BaseNarrative"
      DisplayName = "Oh, hello, Granddaughter."
      Speaker = "Chronos"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "MelinoeField_3872"
      InheritFrom = "BaseNarrative"
      DisplayName = "No...!"
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "HecateField_0457"
      InheritFrom = "BaseNarrative"
      DisplayName = "You look inquisitive."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "HecateField_0458"
      InheritFrom = "BaseNarrative"
      DisplayName = "You've a question."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "HecateField_0460"
      InheritFrom = "BaseNarrative"
      DisplayName = "Aught to discuss?"
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "HecateField_0459"
      InheritFrom = "BaseNarrative"
      DisplayName = "What concerns you?"
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "HecateField_0461"
      InheritFrom = "BaseNarrative"
      DisplayName = "You are concerned."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "HecateField_0417"
      InheritFrom = "BaseNarrative"
      DisplayName = "Steady yourself..."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "HecateField_0420"
      InheritFrom = "BaseNarrative"
      DisplayName = "How fares the task?"
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "HecateField_0423"
      InheritFrom = "BaseNarrative"
      DisplayName = "Question..."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "MelinoeField_4305"
      InheritFrom = "BaseNarrative"
      DisplayName = "Head— Hecate."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "MelinoeField_4303"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hecate..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "MelinoeField_4306"
      InheritFrom = "BaseNarrative"
      DisplayName = "Good evening..."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "MelinoeField_4304"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hecate."
      Speaker = "Melinoe"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "Hecate_0487"
      InheritFrom = "BaseNarrative"
      DisplayName = "There she is."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "Hecate_0066"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Ah."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "Hecate_0067"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hm."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "Hecate_0071"
      InheritFrom = "BaseNarrative"
      DisplayName = "I sensed your presence."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "Hecate_0334"
      InheritFrom = "BaseNarrative"
      DisplayName = "At last."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "Hecate_0336"
      InheritFrom = "BaseNarrative"
      DisplayName = "Well, well."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "Hecate_0337"
      InheritFrom = "BaseNarrative"
      DisplayName = "{#Emph}Hrm..."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "Hecate_0338"
      InheritFrom = "BaseNarrative"
      DisplayName = "Come forward."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "Hecate_0483"
      InheritFrom = "BaseNarrative"
      DisplayName = "Shall we?"
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "Hecate_0484"
      InheritFrom = "BaseNarrative"
      DisplayName = "Ready?"
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "Hecate_0485"
      InheritFrom = "BaseNarrative"
      DisplayName = "Breathe."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "Hecate_0486"
      InheritFrom = "BaseNarrative"
      DisplayName = "There you are."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "Hecate_0488"
      InheritFrom = "BaseNarrative"
      DisplayName = "Sure enough."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "HecateField_0179"
      InheritFrom = "BaseNarrative"
      DisplayName = "Welcome."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "HecateField_0180"
      InheritFrom = "BaseNarrative"
      DisplayName = "Hold."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.HecateBossGreetingLines"
    }
    {
      Id = "HecateField_0183"
      InheritFrom = "BaseNarrative"
