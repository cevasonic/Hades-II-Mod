      Event = "GlobalVoiceLines.HecatePolymorphVoiceLines"
    }
    {
      Id = "Hecate_0152"
      InheritFrom = "BaseSubtitle"
      DisplayName = "If you could see yourself."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.HecatePolymorphVoiceLines"
    }
    {
      Id = "Hecate_0153"
      InheritFrom = "BaseSubtitle"
      DisplayName = "I know you hate this trick."
      Speaker = "Hecate"
      Event = "GlobalVoiceLines.HecatePolymorphVoiceLines"
    }
    {
      Id = "Hecate_0356"
      InheritFrom = "BaseSubtitle"
      DisplayName = "What's wrong, Melinoë?"
